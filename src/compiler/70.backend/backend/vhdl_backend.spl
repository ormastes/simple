# VHDL Backend - VHDL-2008 Code Generation
#
# Compiles MIR to synthesizable VHDL-2008 source code.
# Produces .vhd files for entity/architecture and package declarations.

use compiler.mir.mir_data.*
use compiler.backend.backend_api.*
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.hardware_codegen_types.{HardwareCodegen}
use compiler.backend.vhdl_type_mapper.VhdlTypeMapper
use compiler.backend.vhdl.vhdl_builder.VhdlBuilder
use compiler.backend.vhdl.vhdl_helpers.{vhdl_sanitize_identifier, vhdl_function_is_hardware_entity, vhdl_helper_is_procedure, vhdl_helper_collision_message}
use compiler.backend.vhdl.vhdl_memory_templates.{VhdlConstrainedSignalMemoryTemplate, render_constrained_signal_memory_template}
use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{VhdlResetPolarity, VhdlResetSynchrony}

# ============================================================================
# VHDL Return ABI
# ============================================================================

struct VhdlPortSpec:
    name: text
    direction: text
    type_name: text

struct VhdlReturnField:
    name: text
    type_: MirType
    index: i64

struct VhdlReturnAbi:
    is_tuple: bool
    fields: [VhdlReturnField]

# ============================================================================
# VHDL Backend
# ============================================================================

class VhdlBackend:
    """
    VHDL backend for hardware description generation.

    Compiles MIR modules to synthesizable VHDL-2008 source code.
    Produces entity/architecture pairs and package declarations.

    Features:
    - Entity/architecture generation
    - Package generation (records, enums, constants)
    - Process generation (combinational + clocked)
    - Signal/port mapping
    - Component instantiation
    - Verification assertions

    Usage:
        val backend = VhdlBackend.create()
        val result = backend.compile(mir_module)
    """

    type_mapper: VhdlTypeMapper
    options: CompileOptions
    use_resolved: bool
    active_local_names: Dict<i64, text>
    active_local_types: Dict<i64, MirType>
    active_local_kinds: Dict<i64, LocalKind>
    active_blocks: Dict<i64, MirBlock>
    active_type_defs: Dict<i64, MirTypeDef>
    active_tuple_type_names: Dict<text, text>
    active_tuple_type_shapes: Dict<text, [MirType]>
    active_tuple_type_order: [text]
    active_return_abi: VhdlReturnAbi
    active_function_by_name: Dict<text, MirFunction>
    active_helper_name_by_source: Dict<text, text>
    active_local_memory_type_names: Dict<i64, text>

    static fn empty_span() -> Span:
        Span(start: 0, end_pos: 0, line: 1, col: 1)

    static fn create(target: CodegenTarget, options: CompileOptions) -> VhdlBackend:
        """Create VHDL backend with default options (unresolved types)."""
        VhdlBackend(
            type_mapper: VhdlTypeMapper.create(),
            options: options,
            use_resolved: false,
            active_local_names: {},
            active_local_types: {},
            active_local_kinds: {},
            active_blocks: {},
            active_type_defs: {},
            active_tuple_type_names: {},
            active_tuple_type_shapes: {},
            active_tuple_type_order: [],
            active_return_abi: VhdlReturnAbi(is_tuple: false, fields: []),
            active_function_by_name: {},
            active_helper_name_by_source: {},
            active_local_memory_type_names: {}
        )

    static fn create_resolved(target: CodegenTarget, options: CompileOptions) -> VhdlBackend:
        """Create VHDL backend using resolved std_logic types."""
        VhdlBackend(
            type_mapper: VhdlTypeMapper.create_resolved(),
            options: options,
            use_resolved: true,
            active_local_names: {},
            active_local_types: {},
            active_local_kinds: {},
            active_blocks: {},
            active_type_defs: {},
            active_tuple_type_names: {},
            active_tuple_type_shapes: {},
            active_tuple_type_order: [],
            active_return_abi: VhdlReturnAbi(is_tuple: false, fields: []),
            active_function_by_name: {},
            active_helper_name_by_source: {},
            active_local_memory_type_names: {}
        )

    fn compile(module: MirModule) -> Result<VhdlCompiledModule, CompileError>:
        """Compile MIR module to VHDL."""
        val builder = VhdlBuilder.create(module.name)
        self.active_type_defs = {}
        self.active_function_by_name = {}
        self.active_helper_name_by_source = {}
        for symbol in module.types.keys():
            self.active_type_defs = self.active_type_defs.set(symbol.id, module.types[symbol])
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            self.active_function_by_name = self.active_function_by_name.set(func.name, func)
        self.prepare_tuple_types_for_module(module)
        val hardware_mode = self.module_has_vhdl_hardware(module)
        if hardware_mode:
            val helper_plan_result = self.prepare_helper_subprograms(module)
            if helper_plan_result.is_err():
                return Err(helper_plan_result.unwrap_err())
        val supported_result = self.validate_module_supported_before_emit(module, hardware_mode)
        if supported_result.is_err():
            return Err(supported_result.unwrap_err())

        # Emit library header
        builder.emit_library_header()
        if module.types.len() > 0 or module.constants.len() > 0 or self.active_tuple_type_order.len() > 0 or self.active_helper_name_by_source.len() > 0:
            builder.emit_use_package("work", "{module.name}_pkg")
            builder.emit_raw("")

        # Generate package for types/constants
        var pkg_vhdl = ""
        if module.types.len() > 0 or module.constants.len() > 0 or self.active_tuple_type_order.len() > 0 or self.active_helper_name_by_source.len() > 0:
            val pkg_builder = VhdlBuilder.create(module.name)
            pkg_builder.emit_library_header()
            val pkg_result = self.compile_package_into(pkg_builder, module)
            if pkg_result.is_err():
                return Err(pkg_result.unwrap_err())
            pkg_vhdl = pkg_builder.build()

        # Compile each function as an entity/architecture
        var entities: [VhdlEntity] = []
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            if hardware_mode and not vhdl_function_is_hardware_entity(func):
                continue
            val result = self.compile_function(builder, func)
            match result:
                case Ok(entity):
                    entities = entities.push(entity)
                case Err(e):
                    return Err(e)

        val vhdl_code = builder.build()

        Ok(VhdlCompiledModule(
            name: module.name,
            vhdl: vhdl_code,
            package_vhdl: if pkg_vhdl.len() > 0: Some(pkg_vhdl) else: nil,
            entities: entities
        ))

    fn backend_error(message: text) -> CompileError:
        compileerror_backend_error(BackendKind.Vhdl, message)

    fn backend_error_at(message: text, span: Span?) -> CompileError:
        var err = self.backend_error(message)
        if span.?:
            err.has_location = true
            err.location = span.unwrap().to_range_string()
        err

    fn unsupported_type_error(ty: MirType, context: text, span: Span?) -> CompileError?:
        val diagnostic = self.type_mapper.unsupported_mir_type_diagnostic(ty, context)
        if diagnostic.?:
            Some(self.backend_error_at(diagnostic.unwrap(), span))
        else:
            nil

    fn module_has_vhdl_hardware(module: MirModule) -> bool:
        for symbol in module.functions.keys():
            if vhdl_function_is_hardware_entity(module.functions[symbol]):
                return true
        false

    fn prepare_helper_subprograms(module: MirModule) -> Result<(), CompileError>:
        var used: Dict<text, text> = {}
        self.active_helper_name_by_source = {}
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            if vhdl_function_is_hardware_entity(func):
                continue
            val safe_name = vhdl_sanitize_identifier(func.name)
            val prior = used.get(safe_name)
            if prior.?:
                return Err(self.backend_error(vhdl_helper_collision_message(safe_name, prior.unwrap(), func.name)))
            used[safe_name] = func.name
            self.active_helper_name_by_source = self.active_helper_name_by_source.set(func.name, safe_name)
        Ok(())

    fn validate_module_supported_before_emit(module: MirModule, hardware_mode: bool) -> Result<(), CompileError>:
        for symbol in module.types.keys():
            val type_def_result = self.validate_type_def_supported_before_emit(module.types[symbol])
            if type_def_result.is_err():
                return Err(type_def_result.unwrap_err())
        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            val constant_result = self.validate_vhdl_value_type_supported(constant.type_, "constant `{constant.name}`", nil)
            if constant_result.is_err():
                return Err(constant_result.unwrap_err())
            val constant_value_result = self.validate_vhdl_constant_supported_before_emit(constant.value, constant.type_, "constant `{constant.name}`", nil)
            if constant_value_result.is_err():
                return Err(constant_value_result.unwrap_err())
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            if hardware_mode:
                if vhdl_function_is_hardware_entity(func):
                    val entity_result = self.validate_function_supported_before_emit(func, false)
                    if entity_result.is_err():
                        return Err(entity_result.unwrap_err())
                elif self.active_helper_name_by_source.get(func.name).?:
                    val helper_result = self.validate_function_supported_before_emit(func, true)
                    if helper_result.is_err():
                        return Err(helper_result.unwrap_err())
            else:
                val result = self.validate_function_supported_before_emit(func, false)
                if result.is_err():
                    return Err(result.unwrap_err())
        Ok(())

    fn validate_type_def_supported_before_emit(type_def: MirTypeDef) -> Result<(), CompileError>:
        match type_def.kind:
            case Struct(fields):
                for field in fields:
                    val result = self.validate_vhdl_value_type_supported(field.type_, "field `{type_def.name}.{field.name}`", nil)
                    if result.is_err():
                        return Err(result.unwrap_err())
                Ok(())
            case Enum(variants):
                for variant in variants:
                    if variant.payload.?:
                        val result = self.validate_vhdl_value_type_supported(variant.payload.unwrap(), "payload `{type_def.name}.{variant.name}`", nil)
                        if result.is_err():
                            return Err(result.unwrap_err())
                Ok(())
            case Union(members):
                for member in members:
                    val result = self.validate_vhdl_value_type_supported(member, "union member `{type_def.name}`", nil)
                    if result.is_err():
                        return Err(result.unwrap_err())
                Ok(())

    fn validate_vhdl_value_type_supported(ty: MirType, context: text, span: Span?) -> Result<(), CompileError>:
        val unsupported = self.unsupported_type_error(ty, context, span)
        if unsupported.?:
            return Err(unsupported.unwrap())
        match ty.kind:
            case Array(element, _):
                self.validate_vhdl_value_type_supported(element, context, span)
            case Tuple(elements):
                for element in elements:
                    val result = self.validate_vhdl_value_type_supported(element, context, span)
                    if result.is_err():
                        return Err(result.unwrap_err())
                Ok(())
            case Union(members):
                for member in members:
                    val result = self.validate_vhdl_value_type_supported(member, context, span)
                    if result.is_err():
                        return Err(result.unwrap_err())
                Ok(())
            case _:
                Ok(())

    fn validate_vhdl_constant_supported_before_emit(value: MirConstValue, ty: MirType, context: text, span: Span?) -> Result<(), CompileError>:
        val unsupported = self.unsupported_type_error(ty, context, span)
        if unsupported.?:
            return Err(unsupported.unwrap())
        match value:
            case Float(_):
                Err(self.backend_error_at("VHDL backend does not support floating-point {context}; floating-point constants require explicit fixed-point or integer lowering before VHDL emission", span))
            case _:
                Ok(())

    fn validate_function_supported_before_emit(func: MirFunction, is_helper: bool) -> Result<(), CompileError>:
        var idx = 0
        while idx < func.signature.params.len():
            val param_result = self.validate_vhdl_value_type_supported(func.signature.params[idx], "input port `arg{idx}`", Some(func.span))
            if param_result.is_err():
                return Err(param_result.unwrap_err())
            idx = idx + 1
        if func.signature.return_type.kind != MirTypeKind.Unit:
            val output_abi_result = self.validate_hardware_output_abi_supported(func)
            if output_abi_result.is_err():
                return Err(output_abi_result.unwrap_err())
            val return_result = self.validate_vhdl_value_type_supported(func.signature.return_type, "output port", Some(func.span))
            if return_result.is_err():
                return Err(return_result.unwrap_err())
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    val local_result = self.validate_vhdl_value_type_supported(local.type_, "local signal", Some(func.span))
                    if local_result.is_err():
                        return Err(local_result.unwrap_err())
                case _:
                    ()
        var blocks: Dict<i64, MirBlock> = {}
        for block in func.blocks:
            blocks = blocks.set(block.id.id, block)
        for block in func.blocks:
            val result = self.validate_block_supported_before_emit(block, blocks, is_helper)
            if result.is_err():
                return Err(result.unwrap_err())
        Ok(())

    fn validate_hardware_output_abi_supported(func: MirFunction) -> Result<(), CompileError>:
        if not vhdl_function_is_hardware_entity(func):
            return Ok(())
        match func.signature.return_type.kind:
            case Tuple(elements):
                if not func.has_vhdl_metadata:
                    return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                val fields = func.vhdl_metadata.return_fields
                if fields.len() < elements.len():
                    return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                var field_index = 0
                while field_index < elements.len():
                    if fields[field_index].label.trim() == "":
                        return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                    field_index = field_index + 1
                Ok(())
            case _:
                Ok(())

    fn validate_block_supported_before_emit(block: MirBlock, blocks: Dict<i64, MirBlock>, is_helper: bool) -> Result<(), CompileError>:
        for inst in block.instructions:
            val result = self.validate_instruction_supported_before_emit(inst, blocks, is_helper)
            if result.is_err():
                return Err(result.unwrap_err())
        Ok(())

    fn validate_instruction_supported_before_emit(inst: MirInst, blocks: Dict<i64, MirBlock>, is_helper: bool) -> Result<(), CompileError>:
        if is_helper:
            match inst.kind:
                case Const(_, _, _) | Copy(_, _) | Move(_, _) | BinOp(_, _, _, _) | CheckedBinOp(_, _, _, _) | UnaryOp(_, _, _) | Cast(_, _, _) | Bitcast(_, _, _) | Aggregate(_, _, _) | GetField(_, _, _) | VhdlResize(_, _, _, _) | VhdlSlice(_, _, _, _) | VhdlConcat(_, _) | Nop:
                    Ok(())
                case Call(_, func, _):
                    self.validate_call_supported_before_emit(func)
                case _:
                    Err(self.unsupported_vhdl_helper_instruction_error(inst))
        else:
            match inst.kind:
                case Const(_, _, _) | Copy(_, _) | Move(_, _) | BinOp(_, _, _, _) | CheckedBinOp(_, _, _, _) | UnaryOp(_, _, _) | Aggregate(_, _, _) | GetField(_, _, _) | SetField(_, _, _) | Cast(_, _, _) | Bitcast(_, _, _) | VhdlSignalAssign(_, _, _) | VhdlVarAssign(_, _) | VhdlPortMap(_, _, _) | VhdlResize(_, _, _, _) | VhdlSlice(_, _, _, _) | VhdlConcat(_, _) | Nop:
                    Ok(())
                case VhdlProcess(_, body_block):
                    val block = blocks.get(body_block.id)
                    if block.?:
                        self.validate_block_supported_before_emit(block.unwrap(), blocks, false)
                    else:
                        Err(self.backend_error("VHDL process references unknown block BB{body_block.id}"))
                case Call(_, func, _):
                    self.validate_call_supported_before_emit(func)
                case _:
                    Err(self.unsupported_vhdl_instruction_error(inst))

    fn validate_call_supported_before_emit(func: MirOperand) -> Result<(), CompileError>:
        val target_result = self.call_target_name(func)
        if target_result.is_err():
            return Err(target_result.unwrap_err())
        val target = target_result.unwrap()
        val helper_name = self.active_helper_name_by_source.get(target)
        if not helper_name.?:
            val known = self.active_function_by_name.get(target)
            if known.? and vhdl_function_is_hardware_entity(known.unwrap()):
                return Err(self.backend_error("VHDL helper call `{target}` targets a hardware entity; instantiate entities with VhdlPortMap instead of subprogram calls"))
            return Err(self.backend_error("Synthesizable VHDL backend does not support generic Call lowering for `{target}`; only planned pure combinational helpers can be called"))
        Ok(())

    fn unsupported_vhdl_helper_instruction_error(inst: MirInst) -> CompileError:
        match inst.kind:
            case Load(_, _) | Store(_, _) | Alloc(_, _) | GetElementPtr(_, _, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer or memory instruction in helper subprogram: {inst.kind}", inst.span)
            case CallIndirect(_, _, _, _):
                self.backend_error("Unsupported VHDL helper subprogram indirect call behavior: {inst.kind}; helpers must use direct planned calls")
            case VhdlProcess(_, _) | VhdlPortMap(_, _, _) | VhdlSignalAssign(_, _, _) | VhdlVarAssign(_, _):
                self.backend_error("Unsupported VHDL helper subprogram hardware behavior: {inst.kind}; keep public hardware as entity lowering")
            case Intrinsic(_, name, _):
                self.backend_error("Unsupported VHDL helper subprogram intrinsic `{name}`; helpers must be pure combinational")
            case _:
                self.backend_error("Unsupported VHDL helper subprogram instruction: {inst.kind}")

    fn unsupported_vhdl_instruction_error(inst: MirInst) -> CompileError:
        match inst.kind:
            case Alloc(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Alloc storage allocation", inst.span)
            case Load(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span)
            case Store(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span)
            case GetElementPtr(_, _, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer GetElementPtr lowering", inst.span)
            case CallIndirect(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support CallIndirect lowering")
            case CheckedBinOp(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support checked arithmetic MIR instruction: {inst.kind}")
            case Intrinsic(_, name, _):
                self.backend_error("Synthesizable VHDL backend does not support intrinsic '{name}'")
            case SimdAddF32x4(_, _, _) | SimdSubF32x4(_, _, _) | SimdMulF32x4(_, _, _) | SimdDivF32x4(_, _, _) | SimdFmaF32x4(_, _, _, _) | SimdAddF32x8(_, _, _) | SimdSubF32x8(_, _, _) | SimdMulF32x8(_, _, _) | SimdDivF32x8(_, _, _) | SimdFmaF32x8(_, _, _, _) | SimdAddF64x4(_, _, _) | SimdSubF64x4(_, _, _) | SimdMulF64x4(_, _, _) | SimdDivF64x4(_, _, _) | SimdFmaF64x4(_, _, _, _) | SimdAddI32x4(_, _, _) | SimdSubI32x4(_, _, _) | SimdMulI32x4(_, _, _) | SimdAddI32x8(_, _, _) | SimdSubI32x8(_, _, _) | SimdMulI32x8(_, _, _) | SimdHaddF32x4(_, _) | SimdHmaxF32x4(_, _) | SimdHminF32x4(_, _):
                self.backend_error("Synthesizable VHDL backend does not support SIMD MIR instruction: {inst.kind}")
            case InlineAsm(_, _, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support inline assembly MIR instruction")
            case PipeForward(_, _, _) | Compose(_, _, _, _) | Parallel(_, _) | LayerConnect(_, _, _):
                self.backend_error("Synthesizable VHDL backend does not support functional pipeline MIR instruction: {inst.kind}")
            case DebugValue(_, _):
                self.backend_error("Synthesizable VHDL backend does not support debug metadata MIR instruction: {inst.kind}")
            case CreatePromise(_, _, _) | Await(_, _) | Yield(_) | Spawn(_, _, _) | Send(_, _) | Receive(_, _):
                self.backend_error("Synthesizable VHDL backend does not support async or actor MIR instruction: {inst.kind}")
            case Ref(_, _, _):
                self.backend_error("Synthesizable VHDL backend does not support borrow/reference MIR instruction: {inst.kind}")
            case GpuKernelDef(_) | GpuLaunch(_) | GpuGlobalId(_, _) | GpuLocalId(_, _) | GpuBlockId(_, _) | GpuBlockDim(_, _) | GpuGridDim(_, _) | GpuBarrier(_) | GpuMemFence(_) | GpuSharedAlloc(_, _, _) | GpuAtomicOp(_, _, _, _) | GpuAtomicCas(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support GPU MIR instruction: {inst.kind}")
            case _:
                self.backend_error("Synthesizable VHDL backend does not support MIR instruction: {inst.kind}")

    fn compile_package_into(builder: VhdlBuilder, module: MirModule) -> Result<(), CompileError>:
        """Compile type and constant definitions into a VHDL package."""
        builder.emit_package_begin(module.name)

        for tuple_key in self.active_tuple_type_order:
            val tuple_name = self.active_tuple_type_names[tuple_key]
            val tuple_elements = self.active_tuple_type_shapes[tuple_key]
            if tuple_elements.len() == 0:
                return Err(self.backend_error("Empty tuple types are not supported by the VHDL backend"))
            var tuple_fields: [(text, text)] = []
            var tuple_idx = 0
            for tuple_element in tuple_elements:
                val tuple_type_result = self.mir_type_to_vhdl(tuple_element)
                if tuple_type_result.is_err():
                    return Err(tuple_type_result.unwrap_err())
                tuple_fields = tuple_fields.push(("f{tuple_idx}", tuple_type_result.unwrap()))
                tuple_idx = tuple_idx + 1
            val tuple_def = self.type_mapper.map_record(tuple_fields)
            builder.emit_type_decl(tuple_name, tuple_def)

        # Emit type definitions
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in module.types.keys():
            val type_def = module.types[symbol]
            match type_def.kind:
                case Struct(fields):
                    var field_pairs: [(text, text)] = []
                    for f in fields:
                        val mapped_result = self.mir_type_to_vhdl(f.type_)
                        if mapped_result.is_err():
                            return Err(mapped_result.unwrap_err())
                        val mapped = mapped_result.unwrap()
                        field_pairs = field_pairs.push((f.name, mapped))
                    val record_def = self.type_mapper.map_record(field_pairs)
                    builder.emit_type_decl(type_def.name, record_def)

                case Enum(variants):
                    val enum_result = self.emit_enum_type_decls(builder, type_def, variants)
                    if enum_result.is_err():
                        return Err(enum_result.unwrap_err())

                case _:
                    return Err(self.backend_error(
                        "Unsupported VHDL package type definition: {type_def.name}"
                    ))

        # Emit constants
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            val vhdl_type_result = self.mir_type_to_vhdl(constant.type_)
            if vhdl_type_result.is_err():
                return Err(vhdl_type_result.unwrap_err())
            val vhdl_value_result = self.const_value_to_vhdl(constant.value, constant.type_)
            if vhdl_value_result.is_err():
                return Err(vhdl_value_result.unwrap_err())
            val vhdl_type = vhdl_type_result.unwrap()
            val vhdl_value = vhdl_value_result.unwrap()
            builder.emit_constant_decl(constant.name, vhdl_type, vhdl_value)

        for source_name in self.active_helper_name_by_source.keys():
            val func_result = self.helper_function_by_name(source_name)
            if func_result.is_err():
                return Err(func_result.unwrap_err())
            val decl_result = self.emit_helper_declaration(builder, func_result.unwrap())
            if decl_result.is_err():
                return Err(decl_result.unwrap_err())

        builder.emit_package_end(module.name)

        if self.active_helper_name_by_source.len() > 0:
            builder.emit_library_header()
            builder.emit_line("package body {module.name}_pkg is")
            builder.indent_level = builder.indent_level + 1
            for source_name in self.active_helper_name_by_source.keys():
                val func_result = self.helper_function_by_name(source_name)
                if func_result.is_err():
                    return Err(func_result.unwrap_err())
                val body_result = self.emit_helper_body(builder, func_result.unwrap())
                if body_result.is_err():
                    return Err(body_result.unwrap_err())
            builder.indent_level = builder.indent_level - 1
            builder.emit_line("end package body {module.name}_pkg;")
            builder.emit_raw("")

        Ok(())

    fn emit_enum_type_decls(builder: VhdlBuilder, type_def: MirTypeDef, variants: [MirVariantDef]) -> Result<(), CompileError>:
        var names: [text] = []
        var used_names: Dict<text, bool> = {}
        var has_payload = false
        for v in variants:
            val safe_name = self.sanitize_vhdl_identifier(v.name)
            if used_names.get(safe_name).?:
                return Err(self.backend_error(
                    "Duplicate VHDL enum literal after sanitization in `{type_def.name}`: `{safe_name}`"
                ))
            used_names[safe_name] = true
            names = names.push(safe_name)
            if v.payload.?:
                has_payload = true
        if not has_payload:
            val enum_def = self.type_mapper.map_enum_type(names)
            builder.emit_type_decl(type_def.name, enum_def)
            return Ok(())

        builder.emit_type_decl("{type_def.name}_tag_t", self.type_mapper.map_enum_type(names))
        var record_fields: [(text, text)] = [("tag", "{type_def.name}_tag_t")]
        var used_payload_fields: Dict<text, bool> = {"tag": true}
        for v in variants:
            if v.payload.?:
                val field_name = self.payload_enum_field_name(v)
                if used_payload_fields.get(field_name).?:
                    return Err(self.backend_error(
                        "Duplicate VHDL payload enum field after sanitization in `{type_def.name}`: `{field_name}`"
                    ))
                used_payload_fields[field_name] = true
                val payload_type_result = self.mir_type_to_vhdl(v.payload.unwrap())
                if payload_type_result.is_err():
                    return Err(payload_type_result.unwrap_err())
                record_fields = record_fields.push((field_name, payload_type_result.unwrap()))
        builder.emit_type_decl(type_def.name, self.type_mapper.map_record(record_fields))
        Ok(())

    fn prepare_tuple_types_for_module(module: MirModule):
        self.active_tuple_type_names = {}
        self.active_tuple_type_shapes = {}
        self.active_tuple_type_order = []

        for symbol in module.types.keys():
            val type_def = module.types[symbol]
            self.register_tuple_types_in_type_def(type_def)

        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            self.register_tuple_types_in_type(constant.type_)

        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            self.register_tuple_types_in_type(func.signature.return_type)
            for param_type in func.signature.params:
                self.register_tuple_types_in_type(param_type)
            for local in func.locals:
                self.register_tuple_types_in_type(local.type_)

    fn register_tuple_types_in_type_def(type_def: MirTypeDef):
        match type_def.kind:
            case Struct(fields):
                for field in fields:
                    self.register_tuple_types_in_type(field.type_)
            case Enum(variants):
                for variant in variants:
                    if variant.payload.?:
                        self.register_tuple_types_in_type(variant.payload.unwrap())
            case Union(members):
                for member in members:
                    self.register_tuple_types_in_type(member)

    fn register_tuple_types_in_type(ty: MirType):
        match ty.kind:
            case Tuple(elements):
                for element in elements:
                    self.register_tuple_types_in_type(element)
                val tuple_key = self.tuple_type_key(ty)
                if not self.active_tuple_type_names.get(tuple_key).?:
                    val tuple_name = "tuple_t_{self.active_tuple_type_order.len()}"
                    self.active_tuple_type_names[tuple_key] = tuple_name
                    self.active_tuple_type_shapes[tuple_key] = elements
                    self.active_tuple_type_order = self.active_tuple_type_order.push(tuple_key)
            case Array(element, _):
                self.register_tuple_types_in_type(element)
            case Slice(element):
                self.register_tuple_types_in_type(element)
            case Ptr(pointee, _):
                self.register_tuple_types_in_type(pointee)
            case Ref(referent, _):
                self.register_tuple_types_in_type(referent)
            case FuncPtr(signature):
                for param_type in signature.params:
                    self.register_tuple_types_in_type(param_type)
                self.register_tuple_types_in_type(signature.return_type)
            case Promise(inner):
                self.register_tuple_types_in_type(inner)
            case Generator(yield_ty, return_ty):
                self.register_tuple_types_in_type(yield_ty)
                self.register_tuple_types_in_type(return_ty)
            case ActorType(message):
                self.register_tuple_types_in_type(message)
            case Union(members):
                for member in members:
                    self.register_tuple_types_in_type(member)
            case _:
                ()

    fn tuple_type_key(ty: MirType) -> text:
        match ty.kind:
            case Tuple(elements):
                var element_keys: [text] = []
                for element in elements:
                    element_keys = element_keys.push(self.tuple_type_key_or_leaf(element))
                "tuple({element_keys.join(\",\")})"
            case _:
                self.tuple_type_key_or_leaf(ty)

    fn tuple_type_key_or_leaf(ty: MirType) -> text:
        match ty.kind:
            case I8: "i8"
            case I16: "i16"
            case I32: "i32"
            case I64: "i64"
            case U8: "u8"
            case U16: "u16"
            case U32: "u32"
            case U64: "u64"
            case F32: "f32"
            case F64: "f64"
            case Bool: "bool"
            case Char: "char"
            case Unit: "unit"
            case Vec4f: "vec4f"
            case Vec8f: "vec8f"
            case Vec4d: "vec4d"
            case Vec4i: "vec4i"
            case Vec8i: "vec8i"
            case Array(element, size): "array({self.tuple_type_key_or_leaf(element)};{size})"
            case Slice(element): "slice({self.tuple_type_key_or_leaf(element)})"
            case Tuple(elements):
                var nested_keys: [text] = []
                for element in elements:
                    nested_keys = nested_keys.push(self.tuple_type_key_or_leaf(element))
                "tuple({nested_keys.join(\",\")})"
            case Struct(symbol): "struct#{symbol.id}"
            case Enum(symbol): "enum#{symbol.id}"
            case Union(members):
                var member_keys: [text] = []
                for member in members:
                    member_keys = member_keys.push(self.tuple_type_key_or_leaf(member))
                "union({member_keys.join(\",\")})"
            case Ptr(pointee, mutable):
                "ptr({self.tuple_type_key_or_leaf(pointee)},{mutable})"
            case Ref(referent, mutable):
                "ref({self.tuple_type_key_or_leaf(referent)},{mutable})"
            case FuncPtr(signature):
                var param_keys: [text] = []
                for param_type in signature.params:
                    param_keys = param_keys.push(self.tuple_type_key_or_leaf(param_type))
                "fn({param_keys.join(\",\")})->{self.tuple_type_key_or_leaf(signature.return_type)}"
            case Promise(inner):
                "promise({self.tuple_type_key_or_leaf(inner)})"
            case Generator(yield_ty, return_ty):
                "gen({self.tuple_type_key_or_leaf(yield_ty)}->{self.tuple_type_key_or_leaf(return_ty)})"
            case ActorType(message):
                "actor({self.tuple_type_key_or_leaf(message)})"
            case Never: "never"
            case Opaque(name): "opaque({name})"
            case _: "type#{ty.kind}"

    fn sanitize_vhdl_identifier(name: text) -> text:
        """Return a deterministic VHDL-safe identifier fragment."""
        var result = name.trim()
        if result.len() == 0:
            result = "out"
        result = result.replace(" ", "_")
        result = result.replace("-", "_")
        result = result.replace(".", "_")
        result = result.replace(":", "_")
        result = result.replace("/", "_")
        result = result.replace("\\", "_")
        result = result.replace("(", "_")
        result = result.replace(")", "_")
        result = result.replace("[", "_")
        result = result.replace("]", "_")
        result

    fn vhdl_return_field_name(func: MirFunction, index: i64) -> text:
        if func.has_vhdl_metadata:
            val meta = func.vhdl_metadata
            if index < meta.return_fields.len():
                val label = meta.return_fields[index].label
                if label.len() > 0:
                    return self.sanitize_vhdl_identifier(label)
        "out{index}"

    fn vhdl_return_abi(func: MirFunction) -> Result<VhdlReturnAbi, CompileError>:
        match func.signature.return_type.kind:
            case Unit:
                Ok(VhdlReturnAbi(is_tuple: false, fields: []))
            case Tuple(elements):
                var fields: [VhdlReturnField] = []
                var used: Dict<text, bool> = {}
                var idx = 0
                while idx < elements.len():
                    val name = self.vhdl_return_field_name(func, idx)
                    if used.get(name).?:
                        return Err(self.backend_error("Duplicate VHDL output port after sanitization: {name}"))
                    used[name] = true
                    fields = fields.push(VhdlReturnField(
                        name: name,
                        type_: elements[idx],
                        index: idx
                    ))
                    idx = idx + 1
                Ok(VhdlReturnAbi(is_tuple: true, fields: fields))
            case _:
                Ok(VhdlReturnAbi(is_tuple: false, fields: [
                    VhdlReturnField(
                        name: "result_out",
                        type_: func.signature.return_type,
                        index: 0
                    )
                ]))

    fn vhdl_ports_for_function(func: MirFunction) -> Result<[VhdlPortSpec], CompileError>:
        var ports: [VhdlPortSpec] = []

        var idx = 0
        while idx < func.signature.params.len():
            if self.type_has_general_memory(func.signature.params[idx]):
                return Err(self.backend_error("VHDL-MEM-GENERAL: Array, slice, pointer, and reference ports require an explicit package-level memory ABI before VHDL emission"))
            val param_type_result = self.mir_type_to_vhdl_at(func.signature.params[idx], Some(func.span))
            if param_type_result.is_err():
                return Err(param_type_result.unwrap_err())
            ports = ports.push(VhdlPortSpec(
                name: "arg{idx}",
                direction: "in",
                type_name: param_type_result.unwrap()
            ))
            idx = idx + 1

        val abi_result = self.vhdl_return_abi(func)
        if abi_result.is_err():
            return Err(abi_result.unwrap_err())
        val abi = abi_result.unwrap()
        for field in abi.fields:
            if self.type_has_general_memory(field.type_):
                return Err(self.backend_error("VHDL-MEM-GENERAL: Array, slice, pointer, and reference result ports require an explicit package-level memory ABI before VHDL emission"))
            val return_type_result = self.mir_type_to_vhdl_at(field.type_, Some(func.span))
            if return_type_result.is_err():
                return Err(return_type_result.unwrap_err())
            ports = ports.push(VhdlPortSpec(
                name: field.name,
                direction: "out",
                type_name: return_type_result.unwrap()
            ))

        Ok(ports)

    fn type_has_general_memory(ty: MirType) -> bool:
        match ty.kind:
            case Array(_, _) | Slice(_) | Ptr(_, _) | Ref(_, _):
                true
            case Tuple(elements):
                for element in elements:
                    if self.type_has_general_memory(element):
                        return true
                false
            case Union(members):
                for member in members:
                    if self.type_has_general_memory(member):
                        return true
                false
            case _:
                false

    fn helper_function_by_name(name: text) -> Result<MirFunction, CompileError>:
        val found = self.active_function_by_name.get(name)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("VHDL helper subprogram `{name}` was planned but no function body is available"))

    fn helper_vhdl_name(func: MirFunction) -> Result<text, CompileError>:
        val found = self.active_helper_name_by_source.get(func.name)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("Function `{func.name}` is not a planned VHDL helper subprogram"))

    fn helper_param_name(func: MirFunction, index: i64) -> text:
        for local in func.locals:
            match local.kind:
                case Arg(idx):
                    if idx == index:
                        if local.name.?:
                            return vhdl_sanitize_identifier(local.name.unwrap())
                case _:
                    ()
        "arg{index}"

    fn helper_local_name(local: MirLocal) -> text:
        match local.kind:
            case Arg(idx):
                if local.name.?:
                    vhdl_sanitize_identifier(local.name.unwrap())
                else:
                    "arg{idx}"
            case Return:
                "return_value"
            case Var | Temp:
                if local.name.?:
                    vhdl_sanitize_identifier(local.name.unwrap())
                else:
                    "v_{local.id.id}"

    fn helper_param_list(func: MirFunction) -> Result<text, CompileError>:
        var params: [text] = []
        var idx = 0
        while idx < func.signature.params.len():
            if self.type_has_general_memory(func.signature.params[idx]):
                return Err(self.backend_error("VHDL-MEM-GENERAL: Helper subprogram memory parameters require an explicit package-level memory ABI before VHDL emission"))
            val ty_result = self.mir_type_to_vhdl_at(func.signature.params[idx], Some(func.span))
            if ty_result.is_err():
                return Err(ty_result.unwrap_err())
            params = params.push("{self.helper_param_name(func, idx)} : {ty_result.unwrap()}")
            idx = idx + 1
        Ok(params.join("; "))

    fn helper_signature(func: MirFunction, with_semicolon: bool) -> Result<text, CompileError>:
        val name_result = self.helper_vhdl_name(func)
        if name_result.is_err():
            return Err(name_result.unwrap_err())
        val params_result = self.helper_param_list(func)
        if params_result.is_err():
            return Err(params_result.unwrap_err())
        val params = params_result.unwrap()
        val suffix = if with_semicolon: ";" else: ""
        val maybe_params = if params.len() > 0: "({params})" else: ""
        if vhdl_helper_is_procedure(func):
            return Ok("procedure {name_result.unwrap()}{maybe_params}{suffix}")
        if self.type_has_general_memory(func.signature.return_type):
            return Err(self.backend_error("VHDL-MEM-GENERAL: Helper subprogram memory results require an explicit package-level memory ABI before VHDL emission"))
        val ret_type_result = self.mir_type_to_vhdl_at(func.signature.return_type, Some(func.span))
        if ret_type_result.is_err():
            return Err(ret_type_result.unwrap_err())
        Ok("function {name_result.unwrap()}{maybe_params} return {ret_type_result.unwrap()}{suffix}")

    fn emit_helper_declaration(builder: VhdlBuilder, func: MirFunction) -> Result<(), CompileError>:
        val sig_result = self.helper_signature(func, true)
        if sig_result.is_err():
            return Err(sig_result.unwrap_err())
        builder.emit_line(sig_result.unwrap())
        Ok(())

    fn prepare_helper_context(func: MirFunction):
        self.active_local_names = {}
        self.active_local_types = {}
        self.active_local_kinds = {}
        self.active_blocks = {}
        self.active_local_memory_type_names = {}
        for block in func.blocks:
            self.active_blocks = self.active_blocks.set(block.id.id, block)
        for local in func.locals:
            self.active_local_names = self.active_local_names.set(local.id.id, self.helper_local_name(local))
            self.active_local_types = self.active_local_types.set(local.id.id, local.type_)
            self.active_local_kinds = self.active_local_kinds.set(local.id.id, local.kind)

    fn emit_helper_body(builder: VhdlBuilder, func: MirFunction) -> Result<(), CompileError>:
        self.prepare_helper_context(func)
        val sig_result = self.helper_signature(func, false)
        if sig_result.is_err():
            return Err(sig_result.unwrap_err())
        builder.emit_line(sig_result.unwrap() + " is")
        builder.indent_level = builder.indent_level + 1
        for local in func.locals:
            match local.kind:
                case Var | Temp | Return:
                    if local.kind == LocalKind.Return and vhdl_helper_is_procedure(func):
                        continue
                    if self.type_has_general_memory(local.type_):
                        return Err(self.backend_error("VHDL-MEM-GENERAL: Helper subprogram local memory requires explicit constrained lowering before VHDL emission"))
                    val ty_result = self.mir_type_to_vhdl_at(local.type_, Some(func.span))
                    if ty_result.is_err():
                        return Err(ty_result.unwrap_err())
                    builder.emit_line("variable {self.helper_local_name(local)} : {ty_result.unwrap()};")
                case _:
                    ()
        builder.indent_level = builder.indent_level - 1
        builder.emit_line("begin")
        builder.indent_level = builder.indent_level + 1
        val block_result = self.emit_helper_block(builder, func, func.entry_block)
        if block_result.is_err():
            return Err(block_result.unwrap_err())
        builder.indent_level = builder.indent_level - 1
        val name_result = self.helper_vhdl_name(func)
        if name_result.is_err():
            return Err(name_result.unwrap_err())
        if vhdl_helper_is_procedure(func):
            builder.emit_line("end procedure {name_result.unwrap()};")
        else:
            builder.emit_line("end function {name_result.unwrap()};")
        builder.emit_raw("")
        Ok(())

    fn emit_helper_block(builder: VhdlBuilder, func: MirFunction, block_id: BlockId) -> Result<(), CompileError>:
        val block_result = self.block_by_id(block_id)
        if block_result.is_err():
            return Err(block_result.unwrap_err())
        val block = block_result.unwrap()
        for inst in block.instructions:
            val inst_result = self.compile_helper_instruction(builder, inst)
            if inst_result.is_err():
                return Err(inst_result.unwrap_err())
        match block.terminator:
            case Return(value):
                if value.?:
                    val value_result = self.helper_operand_to_vhdl(value.unwrap())
                    if value_result.is_err():
                        return Err(value_result.unwrap_err())
                    builder.emit_line("return {value_result.unwrap()};")
                elif not vhdl_helper_is_procedure(func):
                    builder.emit_line("return return_value;")
                Ok(())
            case _:
                Err(self.backend_error("Unsupported VHDL helper subprogram terminator: {block.terminator}; helpers must be single-block pure combinational returns"))

    fn helper_operand_to_vhdl(operand: MirOperand) -> Result<text, CompileError>:
        match operand.kind:
            case Copy(local) | Move(local):
                self.local_to_vhdl(local)
            case Const(value, ty):
                self.const_value_to_vhdl(value, ty)

    fn emit_helper_dest_assign(builder: VhdlBuilder, dest: LocalId, expr: text) -> Result<(), CompileError>:
        val kind_result = self.local_kind(dest)
        if kind_result.is_err():
            return Err(kind_result.unwrap_err())
        match kind_result.unwrap():
            case Arg(_):
                Err(self.backend_error("VHDL helper subprogram cannot assign argument local {dest.id}"))
            case _:
                val dest_name = self.local_to_vhdl(dest)
                if dest_name.is_err():
                    return Err(dest_name.unwrap_err())
                builder.emit_var_assign(dest_name.unwrap(), expr)
                Ok(())

    fn call_target_name(func: MirOperand) -> Result<text, CompileError>:
        match func.kind:
            case Const(value, _):
                match value:
                    case Str(name):
                        Ok(name)
                    case _:
                        Err(self.backend_error("Synthesizable VHDL backend does not support generic Call lowering; only direct planned pure combinational helpers can be called"))
            case _:
                Err(self.backend_error("Synthesizable VHDL backend does not support generic Call lowering; only direct planned pure combinational helpers can be called"))

    fn helper_call_expr(func: MirOperand, args: [MirOperand], in_helper: bool) -> Result<text, CompileError>:
        val call_result = self.validate_call_supported_before_emit(func)
        if call_result.is_err():
            return Err(call_result.unwrap_err())
        val target_result = self.call_target_name(func)
        if target_result.is_err():
            return Err(target_result.unwrap_err())
        val target = target_result.unwrap()
        val helper_name = self.active_helper_name_by_source.get(target)
        if not helper_name.?:
            val known = self.active_function_by_name.get(target)
            if known.? and vhdl_function_is_hardware_entity(known.unwrap()):
                return Err(self.backend_error("VHDL helper call `{target}` targets a hardware entity; instantiate entities with VhdlPortMap instead of subprogram calls"))
            return Err(self.backend_error("Synthesizable VHDL backend does not support generic Call lowering for `{target}`; only planned pure combinational helpers can be called"))
        var arg_exprs: [text] = []
        for arg in args:
            val arg_result = if in_helper: self.helper_operand_to_vhdl(arg) else: self.operand_to_vhdl(arg)
            if arg_result.is_err():
                return Err(arg_result.unwrap_err())
            arg_exprs = arg_exprs.push(arg_result.unwrap())
        if arg_exprs.len() == 0:
            Ok(helper_name.unwrap())
        else:
            Ok("{helper_name.unwrap()}({arg_exprs.join(\", \")})")

    fn emit_entity_helper_call(builder: VhdlBuilder, dest: LocalId?, func: MirOperand, args: [MirOperand]) -> Result<(), CompileError>:
        val expr_result = self.helper_call_expr(func, args, false)
        if expr_result.is_err():
            return Err(expr_result.unwrap_err())
        if dest.?:
            val dest_name = self.local_to_vhdl(dest.unwrap())
            if dest_name.is_err():
                return Err(dest_name.unwrap_err())
            builder.emit_signal_assign(dest_name.unwrap(), expr_result.unwrap())
        else:
            builder.emit_line("{expr_result.unwrap()};")
        Ok(())

    fn compile_helper_instruction(builder: VhdlBuilder, inst: MirInst) -> Result<(), CompileError>:
        match inst.kind:
            case Const(dest, value, ty):
                val value_result = self.const_value_to_vhdl_at(value, ty, inst.span)
                if value_result.is_err():
                    return Err(value_result.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, value_result.unwrap())
            case Copy(dest, src) | Move(dest, src):
                val value_result = self.helper_operand_to_vhdl(MirOperand(kind: MirOperandKind.Copy(src)))
                if value_result.is_err():
                    return Err(value_result.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, value_result.unwrap())
            case BinOp(dest, op, left, right) | CheckedBinOp(dest, op, left, right):
                val left_name = self.helper_operand_to_vhdl(left)
                if left_name.is_err():
                    return Err(left_name.unwrap_err())
                val right_name = self.helper_operand_to_vhdl(right)
                if right_name.is_err():
                    return Err(right_name.unwrap_err())
                val left_type = self.operand_type(left)
                if left_type.is_err():
                    return Err(left_type.unwrap_err())
                val right_type = self.operand_type(right)
                if right_type.is_err():
                    return Err(right_type.unwrap_err())
                val expr = self.binop_to_vhdl(op, left_name.unwrap(), left_type.unwrap(), right_name.unwrap(), right_type.unwrap(), right)
                if expr.is_err():
                    return Err(expr.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, expr.unwrap())
            case UnaryOp(dest, op, operand):
                val src_name = self.helper_operand_to_vhdl(operand)
                if src_name.is_err():
                    return Err(src_name.unwrap_err())
                val expr = self.unaryop_to_vhdl(op, src_name.unwrap())
                if expr.is_err():
                    return Err(expr.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, expr.unwrap())
            case Cast(dest, operand, target) | Bitcast(dest, operand, target):
                val src_name = self.helper_operand_to_vhdl(operand)
                if src_name.is_err():
                    return Err(src_name.unwrap_err())
                val src_type = self.operand_type(operand)
                if src_type.is_err():
                    return Err(src_type.unwrap_err())
                val expr = self.cast_to_vhdl(src_name.unwrap(), src_type.unwrap(), target)
                if expr.is_err():
                    return Err(expr.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, expr.unwrap())
            case Aggregate(dest, kind, operands):
                val dest_type = self.local_type(dest)
                if dest_type.is_err():
                    return Err(dest_type.unwrap_err())
                val expr = self.aggregate_to_vhdl_helper(kind, operands, dest_type.unwrap(), inst.span)
                if expr.is_err():
                    return Err(expr.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, expr.unwrap())
            case GetField(dest, base, field):
                val base_name = self.helper_operand_to_vhdl(base)
                if base_name.is_err():
                    return Err(base_name.unwrap_err())
                val field_name = self.field_name_for_operand(base, field)
                if field_name.is_err():
                    return Err(field_name.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, "{base_name.unwrap()}.{field_name.unwrap()}")
            case Call(dest, func, args):
                val expr = self.helper_call_expr(func, args, true)
                if expr.is_err():
                    return Err(expr.unwrap_err())
                if dest.?:
                    self.emit_helper_dest_assign(builder, dest.unwrap(), expr.unwrap())
                else:
                    builder.emit_line("{expr.unwrap()};")
                    Ok(())
            case VhdlResize(dest, operand, new_width, signed):
                val src_name = self.helper_operand_to_vhdl(operand)
                if src_name.is_err():
                    return Err(src_name.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, "resize({src_name.unwrap()}, {new_width})")
            case VhdlSlice(dest, signal, hi, lo):
                val src_name = self.helper_operand_to_vhdl(signal)
                if src_name.is_err():
                    return Err(src_name.unwrap_err())
                val dest_type = self.local_type(dest)
                if dest_type.is_err():
                    return Err(dest_type.unwrap_err())
                val slice_width = hi - lo + 1
                val expr = "{src_name.unwrap()}({hi} downto {lo})"
                val casted = self.cast_to_vhdl(expr, MirType.bits(slice_width), dest_type.unwrap())
                if casted.is_err():
                    return Err(casted.unwrap_err())
                self.emit_helper_dest_assign(builder, dest, casted.unwrap())
            case VhdlConcat(dest, parts):
                var part_names: [text] = []
                for part in parts:
                    val part_name = self.helper_operand_to_vhdl(part)
                    if part_name.is_err():
                        return Err(part_name.unwrap_err())
                    part_names = part_names.push(part_name.unwrap())
                self.emit_helper_dest_assign(builder, dest, part_names.join(" & "))
            case Nop:
                Ok(())
            case _:
                Err(self.unsupported_vhdl_helper_instruction_error(inst))

    fn emit_return_assign(builder: VhdlBuilder, value: MirOperand) -> Result<(), CompileError>:
        val value_name_result = self.operand_to_vhdl(value)
        if value_name_result.is_err():
            return Err(value_name_result.unwrap_err())
        val value_name = value_name_result.unwrap()
        self.emit_return_expr(builder, value_name)

    fn emit_return_expr(builder: VhdlBuilder, value_name: text) -> Result<(), CompileError>:
        if self.active_return_abi.is_tuple:
            for field in self.active_return_abi.fields:
                builder.emit_signal_assign(field.name, "{value_name}.f{field.index}")
        else:
            builder.emit_signal_assign("result_out", value_name)
        Ok(())

    fn compile_function(builder: VhdlBuilder, func: MirFunction) -> Result<VhdlEntity, CompileError>:
        """Compile a function as a VHDL entity/architecture pair."""
        val entity_name = func.name
        self.active_local_names = {}
        self.active_local_types = {}
        self.active_local_kinds = {}
        self.active_blocks = {}
        self.active_local_memory_type_names = {}
        val return_abi_result = self.vhdl_return_abi(func)
        if return_abi_result.is_err():
            return Err(return_abi_result.unwrap_err())
        self.active_return_abi = return_abi_result.unwrap()

        for block in func.blocks:
            self.active_blocks = self.active_blocks.set(block.id.id, block)

        for local in func.locals:
            val resolved_name = self.default_local_name(local)
            self.active_local_names = self.active_local_names.set(local.id.id, resolved_name)
            self.active_local_types = self.active_local_types.set(local.id.id, local.type_)
            self.active_local_kinds = self.active_local_kinds.set(local.id.id, local.kind)

        val ports_result = self.vhdl_ports_for_function(func)
        if ports_result.is_err():
            return Err(ports_result.unwrap_err())
        val ports = ports_result.unwrap()

        # Emit entity
        builder.emit_entity_begin(entity_name)
        builder.emit_port_begin()
        for i in 0..ports.len():
            val port = ports[i]
            builder.emit_port(port.name, port.direction, port.type_name, i == ports.len() - 1)

        builder.emit_port_end()
        builder.emit_entity_end(entity_name)

        # Emit architecture
        builder.emit_architecture_begin(entity_name, "rtl")

        # Declare internal signals for local variables
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    val declare_result = self.emit_local_signal_declaration(builder, local, Some(func.span))
                    if declare_result.is_err():
                        return Err(declare_result.unwrap_err())
                case _:
                    ()

        builder.emit_architecture_body_begin()

        if self.needs_control_process(func):
            val process_result = self.compile_function_control_process(builder, func)
            if process_result.is_err():
                return Err(process_result.unwrap_err())
            builder.emit_architecture_end("rtl")
            return Ok(VhdlEntity(
                name: entity_name,
                port_count: ports.len()
            ))

        # Compile basic blocks
        var handled_branch_blocks: Dict<i64, bool> = {}
        for block in func.blocks:
            if handled_branch_blocks.get(block.id.id).?:
                continue
            builder.emit_comment("Block BB{block.id.id}")
            for inst in block.instructions:
                val result = self.compile_instruction(builder, inst)
                if result.is_err():
                    return Err(result.unwrap_err())
            if block.terminator != nil:
                match block.terminator:
                    case If(cond, then_, else_):
                        val if_result = self.compile_if_return_terminator(builder, cond, then_, else_)
                        if if_result.is_err():
                            return Err(if_result.unwrap_err())
                        handled_branch_blocks = self.mark_return_chain_handled(then_, handled_branch_blocks)
                        handled_branch_blocks = self.mark_return_chain_handled(else_, handled_branch_blocks)
                    case Switch(value, targets, default):
                        val switch_result = self.compile_switch_return_terminator(builder, value, targets, default)
                        if switch_result.is_err():
                            return Err(switch_result.unwrap_err())
                        for target in targets:
                            handled_branch_blocks = self.mark_return_chain_handled(target.target, handled_branch_blocks)
                        handled_branch_blocks = self.mark_return_chain_handled(default, handled_branch_blocks)
                    case Goto(target):
                        val term_result = self.compile_terminator(builder, block.terminator)
                        if term_result.is_err():
                            return Err(term_result.unwrap_err())
                        handled_branch_blocks = self.mark_return_chain_handled(target, handled_branch_blocks)
                    case _:
                        val term_result = self.compile_terminator(builder, block.terminator)
                        if term_result.is_err():
                            return Err(term_result.unwrap_err())

        builder.emit_architecture_end("rtl")

        Ok(VhdlEntity(
            name: entity_name,
            port_count: ports.len()
        ))

    fn default_local_name(local: MirLocal) -> text:
        match local.kind:
            case Arg(idx):
                if local.name.?:
                    local.name.unwrap()
                else:
                    "arg{idx}"
            case Return:
                if self.active_return_abi.is_tuple:
                    "return_value"
                else:
                    "result_out"
            case Var | Temp:
                if local.name.?:
                    local.name.unwrap()
                else:
                    "sig_{local.id.id}"

    fn local_memory_type_name(local: MirLocal) -> text:
        vhdl_sanitize_identifier("{self.default_local_name(local)}_memory_t")

    fn memory_template_error(code: text, message: text) -> CompileError:
        self.backend_error("{code}: {message}")

    fn emit_local_signal_declaration(builder: VhdlBuilder, local: MirLocal, span: Span?) -> Result<(), CompileError>:
        val name = self.default_local_name(local)
        match local.type_.kind:
            case Array(element, size):
                if size <= 0:
                    return Err(self.backend_error("VHDL-MEM-UNCONSTRAINED: Local memory `{name}` must have a concrete positive array size before VHDL emission"))
                match element.kind:
                    case Array(_, _) | Slice(_) | Ptr(_, _) | Ref(_, _):
                        return Err(self.backend_error("VHDL-MEM-GENERAL: Local memory `{name}` has nested, slice, pointer, or reference element type; constrained VHDL memory lowering is not implemented"))
                    case _:
                        ()
                val element_type_result = self.mir_type_to_vhdl_at(element, span)
                if element_type_result.is_err():
                    return Err(element_type_result.unwrap_err())
                val type_name = self.local_memory_type_name(local)
                val template_result = render_constrained_signal_memory_template(VhdlConstrainedSignalMemoryTemplate(
                    name: name,
                    type_name: type_name,
                    data_type: element_type_result.unwrap(),
                    depth: size,
                    initial_value: nil
                ))
                if template_result.is_err():
                    val diagnostic = template_result.unwrap_err()
                    return Err(self.memory_template_error(diagnostic.code, diagnostic.message))
                builder.emit_raw(template_result.unwrap().declarations)
                self.active_local_memory_type_names = self.active_local_memory_type_names.set(local.id.id, type_name)
            case _:
                val vhdl_type_result = self.mir_type_to_vhdl_at(local.type_, span)
                if vhdl_type_result.is_err():
                    return Err(vhdl_type_result.unwrap_err())
                builder.emit_signal_decl(name, vhdl_type_result.unwrap(), nil)
        Ok(())

    fn local_object_type_to_vhdl(local: MirLocal, span: Span?) -> Result<text, CompileError>:
        val memory_type_name = self.active_local_memory_type_names.get(local.id.id)
        if memory_type_name.?:
            Ok(memory_type_name.unwrap())
        else:
            self.mir_type_to_vhdl_at(local.type_, span)

    fn local_to_vhdl(local: LocalId) -> Result<text, CompileError>:
        val found = self.active_local_names.get(local.id)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("No active VHDL name for local {local.id}"))

    fn local_type(local: LocalId) -> Result<MirType, CompileError>:
        val found = self.active_local_types.get(local.id)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("No active MIR type for local {local.id}"))

    fn operand_to_vhdl(operand: MirOperand) -> Result<text, CompileError>:
        """Convert operand to VHDL signal/variable name."""
        match operand.kind:
            case Copy(local): self.local_to_vhdl(local)
            case Move(local): self.local_to_vhdl(local)
            case Const(value, ty):
                self.const_value_to_vhdl(value, ty)

    fn operand_type(operand: MirOperand) -> Result<MirType, CompileError>:
        match operand.kind:
            case Copy(local): self.local_type(local)
            case Move(local): self.local_type(local)
            case Const(_, ty): Ok(ty)

    fn type_def_by_symbol(symbol: SymbolId) -> Result<MirTypeDef, CompileError>:
        val found = self.active_type_defs.get(symbol.id)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("No active VHDL type definition for symbol {symbol.id}"))

    fn block_by_id(id: BlockId) -> Result<MirBlock, CompileError>:
        val found = self.active_blocks.get(id.id)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("VHDL process references unknown block BB{id.id}"))

    fn needs_control_process(func: MirFunction) -> bool:
        val entry = self.block_by_id(func.entry_block)
        if entry.is_err():
            return false
        match entry.unwrap().terminator:
            case If(_, then_, else_):
                self.block_chain_has_instructions(then_, []) or self.block_chain_has_instructions(else_, [])
            case Switch(_, targets, default):
                var has_target_instructions = self.block_chain_has_instructions(default, [])
                for target in targets:
                    if self.block_chain_has_instructions(target.target, []):
                        has_target_instructions = true
                has_target_instructions
            case _:
                false

    fn block_chain_has_instructions(id: BlockId, seen: [i64]) -> bool:
        for prior in seen:
            if prior == id.id:
                return false
        val block = self.active_blocks.get(id.id)
        if not block.?:
            return false
        val current = block.unwrap()
        if current.instructions.len() > 0:
            return true
        var next_seen = seen
        next_seen = next_seen.push(id.id)
        match current.terminator:
            case Goto(target):
                self.block_chain_has_instructions(target, next_seen)
            case If(_, then_, else_):
                self.block_chain_has_instructions(then_, next_seen) or self.block_chain_has_instructions(else_, next_seen)
            case _:
                false

    fn process_local_name(local: LocalId) -> Result<text, CompileError>:
        val name_result = self.local_to_vhdl(local)
        if name_result.is_err():
            return Err(name_result.unwrap_err())
        val ty_result = self.local_type(local)
        if ty_result.is_err():
            return Err(ty_result.unwrap_err())
        match ty_result.unwrap().kind:
            case _:
                Ok("v_{name_result.unwrap()}")

    fn process_operand_to_vhdl(operand: MirOperand) -> Result<text, CompileError>:
        match operand.kind:
            case Copy(local) | Move(local):
                val ty_result = self.local_type(local)
                if ty_result.is_err():
                    return Err(ty_result.unwrap_err())
                match ty_result.unwrap().kind:
                    case I8 | I16 | I32 | I64 | U8 | U16 | U32 | U64 | Bool | Array(_, _) | Struct(_) | Enum(_):
                        val local_name = self.local_to_vhdl(local)
                        if local_name.is_err():
                            return Err(local_name.unwrap_err())
                        val name = local_name.unwrap()
                        if name == "result_out":
                            Ok(name)
                        else:
                            val kind_result = self.local_kind(local)
                            if kind_result.is_err():
                                return Err(kind_result.unwrap_err())
                            match kind_result.unwrap():
                                case Arg(_):
                                    Ok(name)
                                case _:
                                    Ok("v_{name}")
                    case _:
                        self.local_to_vhdl(local)
            case Const(value, ty):
                self.const_value_to_vhdl(value, ty)

    fn local_kind(local: LocalId) -> Result<LocalKind, CompileError>:
        val found = self.active_local_kinds.get(local.id)
        if found.?:
            Ok(found.unwrap())
        else:
            Err(self.backend_error("No active MIR local kind for local {local.id}"))

    fn emit_process_dest_assign(builder: VhdlBuilder, dest: LocalId, expr: text) -> Result<(), CompileError>:
        val kind_result = self.local_kind(dest)
        if kind_result.is_err():
            return Err(kind_result.unwrap_err())
        match kind_result.unwrap():
            case Return:
                builder.emit_signal_assign("result_out", expr)
            case Var | Temp:
                val dest_name_result = self.process_local_name(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                builder.emit_var_assign(dest_name_result.unwrap(), expr)
            case Arg(_):
                return Err(self.backend_error("Synthesizable VHDL process cannot assign function argument local {dest.id}"))
        Ok(())

    fn compile_function_control_process(builder: VhdlBuilder, func: MirFunction) -> Result<(), CompileError>:
        builder.emit_process_begin(Some("comb"), ["all"])
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    val vhdl_type_result = self.local_object_type_to_vhdl(local, Some(func.span))
                    if vhdl_type_result.is_err():
                        return Err(vhdl_type_result.unwrap_err())
                    val name = self.default_local_name(local)
                    builder.emit_process_var("v_{name}", vhdl_type_result.unwrap(), nil)
                case _:
                    ()
        builder.emit_process_body_begin()
        val block_result = self.compile_control_block(builder, func.entry_block, [])
        if block_result.is_err():
            return Err(block_result.unwrap_err())
        builder.emit_process_end(Some("comb"))
        Ok(())

    fn compile_control_block(builder: VhdlBuilder, block_id: BlockId, seen: [i64]) -> Result<(), CompileError>:
        for prior in seen:
            if prior == block_id.id:
                return Err(self.backend_error("Synthesizable VHDL process cannot lower cyclic control flow at BB{block_id.id}"))
        val block_result = self.block_by_id(block_id)
        if block_result.is_err():
            return Err(block_result.unwrap_err())
        val block = block_result.unwrap()
        var next_seen = seen
        next_seen = next_seen.push(block_id.id)
        for inst in block.instructions:
            val inst_result = self.compile_process_instruction(builder, inst)
            if inst_result.is_err():
                return Err(inst_result.unwrap_err())
        if block.terminator != nil:
            match block.terminator:
                case Return(value):
                    if value.?:
                        val value_result = self.process_operand_to_vhdl(value.unwrap())
                        if value_result.is_err():
                            return Err(value_result.unwrap_err())
                        val assign_result = self.emit_return_expr(builder, value_result.unwrap())
                        if assign_result.is_err():
                            return Err(assign_result.unwrap_err())
                    Ok(())
                case Goto(target):
                    self.compile_control_block(builder, target, next_seen)
                case If(cond, then_, else_):
                    val cond_result = self.process_operand_to_vhdl(cond)
                    if cond_result.is_err():
                        return Err(cond_result.unwrap_err())
                    builder.emit_if_begin("{cond_result.unwrap()} = '1'")
                    val then_result = self.compile_control_block(builder, then_, next_seen)
                    if then_result.is_err():
                        return Err(then_result.unwrap_err())
                    builder.emit_else()
                    val else_result = self.compile_control_block(builder, else_, next_seen)
                    if else_result.is_err():
                        return Err(else_result.unwrap_err())
                    builder.emit_if_end()
                    Ok(())
                case Switch(value, targets, default):
                    val value_expr_result = self.switch_value_expr_to_vhdl(value, true)
                    if value_expr_result.is_err():
                        return Err(value_expr_result.unwrap_err())
                    val value_type_result = self.operand_type(value)
                    if value_type_result.is_err():
                        return Err(value_type_result.unwrap_err())
                    val value_expr = value_expr_result.unwrap()
                    val value_type = value_type_result.unwrap()
                    var emitted_case = false
                    for target in targets:
                        val literal_result = self.switch_case_value_to_vhdl(target.value, value_type)
                        if literal_result.is_err():
                            return Err(literal_result.unwrap_err())
                        val condition = "{value_expr} = {literal_result.unwrap()}"
                        if emitted_case:
                            builder.emit_elsif(condition)
                        else:
                            builder.emit_if_begin(condition)
                            emitted_case = true
                        val target_result = self.compile_control_block(builder, target.target, next_seen)
                        if target_result.is_err():
                            return Err(target_result.unwrap_err())
                    if emitted_case:
                        builder.emit_else()
                        val default_result = self.compile_control_block(builder, default, next_seen)
                        if default_result.is_err():
                            return Err(default_result.unwrap_err())
                        builder.emit_if_end()
                    else:
                        val default_only_result = self.compile_control_block(builder, default, next_seen)
                        if default_only_result.is_err():
                            return Err(default_only_result.unwrap_err())
                    Ok(())
                case Unreachable:
                    Ok(())
                case _:
                    Err(self.backend_error("Unsupported VHDL process terminator: {block.terminator}"))
        else:
            Ok(())

    fn compile_process_instruction(builder: VhdlBuilder, inst: MirInst) -> Result<(), CompileError>:
        match inst.kind:
            case Const(dest, value, ty):
                val value_result = self.const_value_to_vhdl_at(value, ty, inst.span)
                if value_result.is_err():
                    return Err(value_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, value_result.unwrap())

            case Copy(dest, src) | Move(dest, src):
                val value_result = self.process_operand_to_vhdl(MirOperand(kind: MirOperandKind.Copy(src)))
                if value_result.is_err():
                    return Err(value_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, value_result.unwrap())

            case Load(dest, ptr):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span))

            case Store(ptr, value):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span))

            case BinOp(dest, op, left, right) | CheckedBinOp(dest, op, left, right):
                val left_name_result = self.process_operand_to_vhdl(left)
                if left_name_result.is_err():
                    return Err(left_name_result.unwrap_err())
                val right_name_result = self.process_operand_to_vhdl(right)
                if right_name_result.is_err():
                    return Err(right_name_result.unwrap_err())
                val left_type_result = self.operand_type(left)
                if left_type_result.is_err():
                    return Err(left_type_result.unwrap_err())
                val right_type_result = self.operand_type(right)
                if right_type_result.is_err():
                    return Err(right_type_result.unwrap_err())
                val expr_result = self.binop_to_vhdl(op, left_name_result.unwrap(), left_type_result.unwrap(), right_name_result.unwrap(), right_type_result.unwrap(), right)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, expr_result.unwrap())

            case Cast(dest, operand, target) | Bitcast(dest, operand, target):
                val src_name_result = self.process_operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val src_type_result = self.operand_type(operand)
                if src_type_result.is_err():
                    return Err(src_type_result.unwrap_err())
                val expr_result = self.cast_to_vhdl(src_name_result.unwrap(), src_type_result.unwrap(), target)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, expr_result.unwrap())

            case Aggregate(dest, kind, operands):
                val dest_type_result = self.local_type(dest)
                if dest_type_result.is_err():
                    return Err(dest_type_result.unwrap_err())
                val aggregate_result = self.aggregate_to_vhdl_process(kind, operands, dest_type_result.unwrap(), inst.span)
                if aggregate_result.is_err():
                    return Err(aggregate_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, aggregate_result.unwrap())

            case GetField(dest, base, field):
                val base_name_result = self.process_operand_to_vhdl(base)
                if base_name_result.is_err():
                    return Err(base_name_result.unwrap_err())
                val field_name_result = self.field_name_for_operand(base, field)
                if field_name_result.is_err():
                    return Err(field_name_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, "{base_name_result.unwrap()}.{field_name_result.unwrap()}")

            case SetField(base, field, value):
                val field_name_result = self.field_name_for_operand(base, field)
                if field_name_result.is_err():
                    return Err(field_name_result.unwrap_err())
                val value_name_result = self.process_operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                match base.kind:
                    case Copy(local) | Move(local):
                        val kind_result = self.local_kind(local)
                        if kind_result.is_err():
                            return Err(kind_result.unwrap_err())
                        val base_name_result = self.process_operand_to_vhdl(base)
                        if base_name_result.is_err():
                            return Err(base_name_result.unwrap_err())
                        val target = "{base_name_result.unwrap()}.{field_name_result.unwrap()}"
                        match kind_result.unwrap():
                            case Var | Temp:
                                builder.emit_var_assign(target, value_name_result.unwrap())
                            case Return:
                                builder.emit_signal_assign(target, value_name_result.unwrap())
                            case Arg(_):
                                return Err(self.backend_error("Synthesizable VHDL process cannot set field on argument local {local.id}"))
                    case _:
                        return Err(self.backend_error("Synthesizable VHDL process field set requires local base"))

            case VhdlResize(dest, operand, new_width, signed):
                val src_name_result = self.process_operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val expr_result = self.resize_expr_to_vhdl(src_name_result.unwrap(), signed, new_width)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, expr_result.unwrap())

            case VhdlSlice(dest, signal, hi, lo):
                val src_name_result = self.process_operand_to_vhdl(signal)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val expr = "{src_name_result.unwrap()}({hi} downto {lo})"
                val dest_type_result = self.local_type(dest)
                if dest_type_result.is_err():
                    return Err(dest_type_result.unwrap_err())
                val slice_width = hi - lo + 1
                val cast_result = self.cast_to_vhdl(expr, MirType.bits(slice_width), dest_type_result.unwrap())
                if cast_result.is_err():
                    return Err(cast_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, cast_result.unwrap())

            case VhdlConcat(dest, parts):
                var part_names: [text] = []
                for part in parts:
                    val part_name_result = self.process_operand_to_vhdl(part)
                    if part_name_result.is_err():
                        return Err(part_name_result.unwrap_err())
                    part_names = part_names.push(part_name_result.unwrap())
                self.emit_process_dest_assign(builder, dest, part_names.join(" & "))

            case VhdlSignalAssign(target, value, delay_ns):
                if delay_ns.?:
                    return Err(self.backend_error("Synthesizable VHDL process signal assignment does not support delayed assignment"))
                val target_name_result = self.process_operand_to_vhdl(target)
                if target_name_result.is_err():
                    return Err(target_name_result.unwrap_err())
                val value_name_result = self.process_operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                builder.emit_signal_assign(target_name_result.unwrap(), value_name_result.unwrap())

            case VhdlVarAssign(target, value):
                val target_name_result = self.process_operand_to_vhdl(target)
                if target_name_result.is_err():
                    return Err(target_name_result.unwrap_err())
                val value_name_result = self.process_operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                builder.emit_var_assign(target_name_result.unwrap(), value_name_result.unwrap())

            case UnaryOp(dest, op, operand):
                val src_name_result = self.process_operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val expr_result = self.unaryop_to_vhdl(op, src_name_result.unwrap())
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                self.emit_process_dest_assign(builder, dest, expr_result.unwrap())

            case Nop:
                ()

            case _:
                return Err(self.unsupported_vhdl_instruction_error(inst))
        Ok(())

    fn mark_return_chain_handled(id: BlockId, handled: Dict<i64, bool>) -> Dict<i64, bool>:
        var next_handled = handled.set(id.id, true)
        val block = self.active_blocks.get(id.id)
        if block.?:
            match block.unwrap().terminator:
                case Goto(target):
                    if not next_handled.get(target.id).?:
                        next_handled = self.mark_return_chain_handled(target, next_handled)
                case _:
                    ()
        next_handled

    fn compile_block_instructions(builder: VhdlBuilder, block: MirBlock) -> Result<(), CompileError>:
        for inst in block.instructions:
            val result = self.compile_instruction(builder, inst)
            if result.is_err():
                return Err(result.unwrap_err())
        Ok(())

    fn reset_asserted_literal(domain: VhdlClockDomain) -> text:
        match domain.reset_polarity:
            case ActiveLow:
                "'0'"
            case ActiveHigh:
                "'1'"

    fn compile_process_into(builder: VhdlBuilder, kind: compiler.mir.mir_data.VhdlProcessKind, block: MirBlock) -> Result<(), CompileError>:
        val label = builder.alloc_label()
        match kind:
            case Combinational(sensitivity):
                builder.emit_process_begin(Some(label), sensitivity)
                builder.emit_process_body_begin()
                val block_result = self.compile_block_instructions(builder, block)
                if block_result.is_err():
                    return Err(block_result.unwrap_err())
                builder.emit_process_end(Some(label))
            case Clocked(domain):
                val sensitivity_reset: text? = if domain.reset_synchrony == VhdlResetSynchrony.Async: domain.reset_signal else: nil
                builder.emit_clocked_process_begin(Some(label), domain.clock_signal, sensitivity_reset)
                builder.emit_process_body_begin()
                match domain.edge:
                    case Rising:
                        builder.emit_rising_edge_check(domain.clock_signal)
                    case Falling:
                        builder.emit_falling_edge_check(domain.clock_signal)
                if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Sync:
                    val reset_signal = domain.reset_signal.unwrap()
                    builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
                    builder.emit_comment("sync reset branch")
                    builder.emit_else()
                val block_result = self.compile_block_instructions(builder, block)
                if block_result.is_err():
                    return Err(block_result.unwrap_err())
                if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Sync:
                    builder.emit_if_end()
                builder.emit_if_end()
                builder.emit_process_end(Some(label))
            case AsyncReset(domain):
                builder.emit_clocked_process_begin(Some(label), domain.clock_signal, domain.reset_signal)
                builder.emit_process_body_begin()
                if domain.reset_signal.?:
                    val reset_signal = domain.reset_signal.unwrap()
                    builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
                    builder.emit_comment("async reset branch")
                    builder.emit_else()
                match domain.edge:
                    case Rising:
                        builder.emit_rising_edge_check(domain.clock_signal)
                    case Falling:
                        builder.emit_falling_edge_check(domain.clock_signal)
                val block_result = self.compile_block_instructions(builder, block)
                if block_result.is_err():
                    return Err(block_result.unwrap_err())
                builder.emit_if_end()
                if domain.reset_signal.?:
                    builder.emit_if_end()
                builder.emit_process_end(Some(label))
        Ok(())

    fn compile_instruction(builder: VhdlBuilder, inst: MirInst) -> Result<(), CompileError>:
        """Compile a single MIR instruction to VHDL."""
        match inst.kind:
            case Const(dest, value, ty):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val vhdl_value_result = self.const_value_to_vhdl_at(value, ty, inst.span)
                if vhdl_value_result.is_err():
                    return Err(vhdl_value_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val vhdl_value = vhdl_value_result.unwrap()
                builder.emit_signal_assign(dest_name, vhdl_value)

            case Copy(dest, src) | Move(dest, src):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val src_name_result = self.local_to_vhdl(src)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val src_name = src_name_result.unwrap()
                builder.emit_signal_assign(dest_name, src_name)

            case Load(dest, ptr):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span))

            case Store(ptr, value):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span))

            case BinOp(dest, op, left, right) | CheckedBinOp(dest, op, left, right):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val left_name_result = self.operand_to_vhdl(left)
                if left_name_result.is_err():
                    return Err(left_name_result.unwrap_err())
                val right_name_result = self.operand_to_vhdl(right)
                if right_name_result.is_err():
                    return Err(right_name_result.unwrap_err())
                val left_type_result = self.operand_type(left)
                if left_type_result.is_err():
                    return Err(left_type_result.unwrap_err())
                val right_type_result = self.operand_type(right)
                if right_type_result.is_err():
                    return Err(right_type_result.unwrap_err())
                val expr_result = self.binop_to_vhdl(op, left_name_result.unwrap(), left_type_result.unwrap(), right_name_result.unwrap(), right_type_result.unwrap(), right)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val expr = expr_result.unwrap()
                builder.emit_signal_assign(dest_name, expr)

            case Cast(dest, operand, target) | Bitcast(dest, operand, target):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val src_name_result = self.operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val src_type_result = self.operand_type(operand)
                if src_type_result.is_err():
                    return Err(src_type_result.unwrap_err())
                val expr_result = self.cast_to_vhdl(src_name_result.unwrap(), src_type_result.unwrap(), target)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                builder.emit_signal_assign(dest_name_result.unwrap(), expr_result.unwrap())

            case Aggregate(dest, kind, operands):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val dest_type_result = self.local_type(dest)
                if dest_type_result.is_err():
                    return Err(dest_type_result.unwrap_err())
                val aggregate_result = self.aggregate_to_vhdl(kind, operands, dest_type_result.unwrap(), inst.span)
                if aggregate_result.is_err():
                    return Err(aggregate_result.unwrap_err())
                builder.emit_signal_assign(dest_name_result.unwrap(), aggregate_result.unwrap())

            case GetField(dest, base, field):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val base_name_result = self.operand_to_vhdl(base)
                if base_name_result.is_err():
                    return Err(base_name_result.unwrap_err())
                val field_name_result = self.field_name_for_operand(base, field)
                if field_name_result.is_err():
                    return Err(field_name_result.unwrap_err())
                builder.emit_signal_assign(dest_name_result.unwrap(), "{base_name_result.unwrap()}.{field_name_result.unwrap()}")

            case SetField(base, field, value):
                val base_name_result = self.operand_to_vhdl(base)
                if base_name_result.is_err():
                    return Err(base_name_result.unwrap_err())
                val field_name_result = self.field_name_for_operand(base, field)
                if field_name_result.is_err():
                    return Err(field_name_result.unwrap_err())
                val value_name_result = self.operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                builder.emit_signal_assign("{base_name_result.unwrap()}.{field_name_result.unwrap()}", value_name_result.unwrap())

            case UnaryOp(dest, op, operand):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val src_name_result = self.operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val expr_result = self.unaryop_to_vhdl(op, src_name_result.unwrap())
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val expr = expr_result.unwrap()
                builder.emit_signal_assign(dest_name, expr)

            # VHDL-specific instructions
            case VhdlProcess(kind, body_block):
                val block_result = self.block_by_id(body_block)
                if block_result.is_err():
                    return Err(block_result.unwrap_err())
                val process_result = self.compile_process_into(builder, kind, block_result.unwrap())
                if process_result.is_err():
                    return Err(process_result.unwrap_err())

            case VhdlSignalAssign(target, value, delay_ns):
                val target_name_result = self.operand_to_vhdl(target)
                if target_name_result.is_err():
                    return Err(target_name_result.unwrap_err())
                val value_name_result = self.operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                val target_name = target_name_result.unwrap()
                val value_name = value_name_result.unwrap()
                if delay_ns.?:
                    builder.emit_signal_assign_delay(target_name, value_name, delay_ns.unwrap())
                else:
                    builder.emit_signal_assign(target_name, value_name)

            case VhdlVarAssign(target, value):
                val target_name_result = self.operand_to_vhdl(target)
                if target_name_result.is_err():
                    return Err(target_name_result.unwrap_err())
                val value_name_result = self.operand_to_vhdl(value)
                if value_name_result.is_err():
                    return Err(value_name_result.unwrap_err())
                val target_name = target_name_result.unwrap()
                val value_name = value_name_result.unwrap()
                builder.emit_var_assign(target_name, value_name)

            case VhdlPortMap(entity, instance, connections):
                builder.emit_instance_begin(instance, entity)
                builder.emit_port_map_begin()
                var idx = 0
                for conn in connections:
                    val actual_result = self.operand_to_vhdl(conn.1)
                    if actual_result.is_err():
                        return Err(actual_result.unwrap_err())
                    val actual = actual_result.unwrap()
                    val is_last = idx == connections.len() - 1
                    builder.emit_port_map_entry(conn.0, actual, is_last)
                    idx = idx + 1
                builder.emit_port_map_end()

            case VhdlResize(dest, operand, new_width, signed):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val src_name_result = self.operand_to_vhdl(operand)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val expr_result = self.resize_expr_to_vhdl(src_name_result.unwrap(), signed, new_width)
                if expr_result.is_err():
                    return Err(expr_result.unwrap_err())
                builder.emit_signal_assign(dest_name, expr_result.unwrap())

            case VhdlSlice(dest, signal, hi, lo):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val src_name_result = self.operand_to_vhdl(signal)
                if src_name_result.is_err():
                    return Err(src_name_result.unwrap_err())
                val dest_type_result = self.local_type(dest)
                if dest_type_result.is_err():
                    return Err(dest_type_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                val src_name = src_name_result.unwrap()
                val slice_width = hi - lo + 1
                val expr = "{src_name}({hi} downto {lo})"
                val cast_result = self.cast_to_vhdl(expr, MirType.bits(slice_width), dest_type_result.unwrap())
                if cast_result.is_err():
                    return Err(cast_result.unwrap_err())
                builder.emit_signal_assign(dest_name, cast_result.unwrap())

            case VhdlConcat(dest, parts):
                val dest_name_result = self.local_to_vhdl(dest)
                if dest_name_result.is_err():
                    return Err(dest_name_result.unwrap_err())
                val dest_name = dest_name_result.unwrap()
                var part_names: [text] = []
                for p in parts:
                    val part_name_result = self.operand_to_vhdl(p)
                    if part_name_result.is_err():
                        return Err(part_name_result.unwrap_err())
                    part_names = part_names.push(part_name_result.unwrap())
                builder.emit_concat(dest_name, part_names)

            case Nop:
                ()

            case Call(dest, func, args):
                val call_result = self.emit_entity_helper_call(builder, dest, func, args)
                if call_result.is_err():
                    return Err(call_result.unwrap_err())

            case _:
                return Err(self.unsupported_vhdl_instruction_error(inst))

        Ok(())

    fn compile_terminator(builder: VhdlBuilder, terminator: MirTerminator) -> Result<(), CompileError>:
        """Compile a MIR terminator that has direct combinational VHDL meaning."""
        match terminator:
            case Return(value):
                if value.?:
                    val assign_result = self.emit_return_assign(builder, value.unwrap())
                    if assign_result.is_err():
                        return Err(assign_result.unwrap_err())
                Ok(())
            case Goto(target):
                val value_result = self.compile_return_block(builder, target)
                if value_result.is_err():
                    return Err(value_result.unwrap_err())
                val assign_result = self.emit_return_expr(builder, value_result.unwrap())
                if assign_result.is_err():
                    return Err(assign_result.unwrap_err())
                Ok(())
            case Unreachable:
                Ok(())
            case _:
                Err(self.backend_error("Unsupported VHDL terminator: {terminator}"))

    fn compile_if_return_terminator(builder: VhdlBuilder, cond: MirOperand, then_: BlockId, else_: BlockId) -> Result<(), CompileError>:
        """Compile if/else return blocks as one VHDL conditional result assignment."""
        val cond_name_result = self.operand_to_vhdl(cond)
        if cond_name_result.is_err():
            return Err(cond_name_result.unwrap_err())
        val then_value_result = self.compile_return_block(builder, then_)
        if then_value_result.is_err():
            return Err(then_value_result.unwrap_err())
        val else_value_result = self.compile_return_block(builder, else_)
        if else_value_result.is_err():
            return Err(else_value_result.unwrap_err())
        val cond_name = cond_name_result.unwrap()
        val then_value = then_value_result.unwrap()
        val else_value = else_value_result.unwrap()
        if self.active_return_abi.is_tuple:
            for field in self.active_return_abi.fields:
                builder.emit_signal_assign(field.name, "{then_value}.f{field.index} when {cond_name} = '1' else {else_value}.f{field.index}")
            return Ok(())
        builder.emit_signal_assign("result_out", "{then_value} when {cond_name} = '1' else {else_value}")
        Ok(())

    fn compile_switch_return_terminator(builder: VhdlBuilder, value: MirOperand, targets: [SwitchCase], default: BlockId) -> Result<(), CompileError>:
        """Compile a switch whose reachable targets resolve to return values."""
        val value_expr_result = self.switch_value_expr_to_vhdl(value, false)
        if value_expr_result.is_err():
            return Err(value_expr_result.unwrap_err())
        val value_type_result = self.operand_type(value)
        if value_type_result.is_err():
            return Err(value_type_result.unwrap_err())
        val default_expr_result = self.compile_return_block(builder, default)
        if default_expr_result.is_err():
            return Err(default_expr_result.unwrap_err())
        var expr = default_expr_result.unwrap()
        val value_expr = value_expr_result.unwrap()
        val value_type = value_type_result.unwrap()
        var idx = targets.len() - 1
        while idx >= 0:
            val target = targets[idx]
            val target_expr_result = self.compile_return_block(builder, target.target)
            if target_expr_result.is_err():
                return Err(target_expr_result.unwrap_err())
            val literal_result = self.switch_case_value_to_vhdl(target.value, value_type)
            if literal_result.is_err():
                return Err(literal_result.unwrap_err())
            expr = "{target_expr_result.unwrap()} when {value_expr} = {literal_result.unwrap()} else {expr}"
            idx = idx - 1
        if self.active_return_abi.is_tuple:
            return Err(self.backend_error("VHDL tuple return switch lowering is not implemented in the pure Simple backend"))
        builder.emit_signal_assign("result_out", expr)
        Ok(())

    fn switch_case_value_to_vhdl(value: i64, ty: MirType) -> Result<text, CompileError>:
        match ty.kind:
            case Bool:
                Ok(if value == 0: "'0'" else: "'1'")
            case Enum(symbol):
                self.enum_variant_literal_for_discriminant(symbol, value)
            case _:
                self.const_value_to_vhdl(MirConstValue.Int(value), ty)

    fn switch_value_expr_to_vhdl(value: MirOperand, in_process: bool) -> Result<text, CompileError>:
        val expr_result = if in_process: self.process_operand_to_vhdl(value) else: self.operand_to_vhdl(value)
        if expr_result.is_err():
            return Err(expr_result.unwrap_err())
        val type_result = self.operand_type(value)
        if type_result.is_err():
            return Err(type_result.unwrap_err())
        match type_result.unwrap().kind:
            case Enum(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                match type_def_result.unwrap().kind:
                    case Enum(variants):
                        if self.enum_has_payload(variants):
                            Ok("{expr_result.unwrap()}.tag")
                        else:
                            Ok(expr_result.unwrap())
                    case _:
                        Err(self.backend_error("Switch target symbol {symbol.id} is not an enum type"))
            case _:
                Ok(expr_result.unwrap())

    fn enum_variant_literal_for_discriminant(symbol: SymbolId, discriminant: i64) -> Result<text, CompileError>:
        val type_def_result = self.type_def_by_symbol(symbol)
        if type_def_result.is_err():
            return Err(type_def_result.unwrap_err())
        val type_def = type_def_result.unwrap()
        match type_def.kind:
            case Enum(variants):
                for variant in variants:
                    if variant.discriminant == discriminant:
                        return Ok(self.sanitize_vhdl_identifier(variant.name))
                Err(self.backend_error("Enum switch discriminant {discriminant} is not a variant of `{type_def.name}`"))
            case _:
                Err(self.backend_error("Switch target symbol {symbol.id} is not an enum type"))

    fn compile_return_block(builder: VhdlBuilder, block_id: BlockId) -> Result<text, CompileError>:
        self.compile_return_block_seen(builder, block_id, [])

    fn compile_return_block_seen(builder: VhdlBuilder, block_id: BlockId, seen: [i64]) -> Result<text, CompileError>:
        for prior in seen:
            if prior == block_id.id:
                return Err(self.backend_error("VHDL backend does not support cyclic control flow"))
        val block_result = self.block_by_id(block_id)
        if block_result.is_err():
            return Err(block_result.unwrap_err())
        val block = block_result.unwrap()
        val inst_result = self.compile_block_instructions(builder, block)
        if inst_result.is_err():
            return Err(inst_result.unwrap_err())
        match block.terminator:
            case Return(value):
                if value.?:
                    self.operand_to_vhdl(value.unwrap())
                else:
                    Err(self.backend_error("VHDL if/else return block BB{block_id.id} returns no value"))
            case Goto(target):
                var next_seen = seen
                next_seen = next_seen.push(block_id.id)
                self.compile_return_block_seen(builder, target, next_seen)
            case _:
                Err(self.backend_error("VHDL if/else branch BB{block_id.id} must terminate with return"))

    fn integer_width(ty: MirType) -> i64?:
        match ty.kind:
            case I64 | U64: Some(64)
            case I32 | U32: Some(32)
            case I16 | U16: Some(16)
            case I8 | U8: Some(8)
            case Bits(width, _): Some(width)
            case _: nil

    fn validate_concrete_bit_width(width: i64) -> Result<(), CompileError>:
        val diagnostic = self.type_mapper.fixed_width_diagnostic(width)
        if diagnostic.?:
            return Err(self.backend_error(diagnostic.unwrap()))
        Ok(())

    fn is_signed_integer_type(ty: MirType) -> bool:
        match ty.kind:
            case I64 | I32 | I16 | I8: true
            case Bits(_, signed): signed
            case _: false

    fn is_unsigned_integer_type(ty: MirType) -> bool:
        match ty.kind:
            case U64 | U32 | U16 | U8: true
            case Bits(_, signed): not signed
            case _: false

    fn resize_expr_to_vhdl(operand: text, signed: bool, new_width: i64) -> Result<text, CompileError>:
        val width_result = self.validate_concrete_bit_width(new_width)
        if width_result.is_err():
            return Err(width_result.unwrap_err())
        if signed:
            Ok("resize(signed({operand}), {new_width})")
        else:
            Ok("resize(unsigned({operand}), {new_width})")

    fn require_matching_fixed_integer_widths(op: MirBinOp, left_ty: MirType, right_ty: MirType) -> Result<(), CompileError>:
        val left_width = self.integer_width(left_ty)
        val right_width = self.integer_width(right_ty)
        if left_width.?:
            val left_width_result = self.validate_concrete_bit_width(left_width.unwrap())
            if left_width_result.is_err():
                return Err(left_width_result.unwrap_err())
        if right_width.?:
            val right_width_result = self.validate_concrete_bit_width(right_width.unwrap())
            if right_width_result.is_err():
                return Err(right_width_result.unwrap_err())
        if left_width.? and right_width.?:
            if left_width.unwrap() != right_width.unwrap():
                return Err(self.backend_error("Ambiguous VHDL integer width mismatch for {op}: left {left_ty.kind} is {left_width.unwrap()} bits, right {right_ty.kind} is {right_width.unwrap()} bits; insert an explicit cast or VhdlResize"))
        Ok(())

    fn binop_with_matching_integer_widths(op: MirBinOp, left: text, left_ty: MirType, right: text, right_ty: MirType, expr: text) -> Result<text, CompileError>:
        val width_result = self.require_matching_fixed_integer_widths(op, left_ty, right_ty)
        if width_result.is_err():
            Err(width_result.unwrap_err())
        else:
            Ok(expr)

    fn mir_type_to_vhdl(ty: MirType) -> Result<text, CompileError>:
        """Convert MIR type to VHDL type string."""
        self.mir_type_to_vhdl_at(ty, nil)

    fn mir_type_to_vhdl_at(ty: MirType, span: Span?) -> Result<text, CompileError>:
        """Convert MIR type to VHDL type string with an optional diagnostic span."""
        val unsupported = self.unsupported_type_error(ty, "type emission", span)
        if unsupported.?:
            return Err(unsupported.unwrap())
        match ty.kind:
            case I64: Ok("signed(63 downto 0)")
            case I32: Ok("signed(31 downto 0)")
            case I16: Ok("signed(15 downto 0)")
            case I8: Ok("signed(7 downto 0)")
            case U64: Ok("unsigned(63 downto 0)")
            case U32: Ok("unsigned(31 downto 0)")
            case U16: Ok("unsigned(15 downto 0)")
            case U8: Ok("unsigned(7 downto 0)")
            case Bits(width, signed):
                val width_result = self.validate_concrete_bit_width(width)
                if width_result.is_err():
                    Err(width_result.unwrap_err())
                else:
                    Ok(self.type_mapper.map_fixed_bits(width, signed))
            case Bool:
                if self.use_resolved:
                    Ok("std_logic")
                else:
                    Ok("bit")
            case Array(elem, size):
                val elem_type_result = self.mir_type_to_vhdl_at(elem, span)
                if elem_type_result.is_err():
                    Err(elem_type_result.unwrap_err())
                else:
                    Ok("array (0 to {size - 1}) of {elem_type_result.unwrap()}")
            case Tuple(elements):
                if elements.len() == 0:
                    return Err(self.backend_error("Empty tuple types are not supported by the VHDL backend"))
                val tuple_key = self.tuple_type_key(ty)
                val tuple_name = self.active_tuple_type_names.get(tuple_key)
                if tuple_name.?:
                    Ok(tuple_name.unwrap())
                else:
                    Err(self.backend_error("Tuple type {ty.kind} was not registered before VHDL type emission"))
            case Struct(symbol) | Enum(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    Err(type_def_result.unwrap_err())
                else:
                    Ok(type_def_result.unwrap().name)
            case _:
                Err(self.backend_error_at("Unsupported VHDL type: {ty.kind}", span))

    fn aggregate_to_vhdl(kind: AggregateKind, operands: [MirOperand], dest_type: MirType, span: Span?) -> Result<text, CompileError>:
        match kind:
            case Tuple:
                match dest_type.kind:
                    case Tuple(elements):
                        if elements.len() != operands.len():
                            return Err(self.backend_error("Tuple aggregate expects {elements.len()} operands, got {operands.len()}"))
                        if elements.len() == 0:
                            return Err(self.backend_error("Empty tuple aggregates are not supported by the VHDL backend"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("f{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Tuple aggregate destination is not a tuple type: {dest_type.kind}"))
            case Struct(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Struct(fields):
                        if operands.len() != fields.len():
                            return Err(self.backend_error("Struct aggregate {type_def.name} expects {fields.len()} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{fields[idx].name} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Aggregate Struct target {type_def.name} is not a struct type"))
            case Array(_):
                match dest_type.kind:
                    case Array(_, size):
                        if operands.len() != size:
                            return Err(self.backend_error("Array aggregate expects {size} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Array aggregate destination is not an array type: {dest_type.kind}"))
            case Enum(symbol, variant):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Enum(variants):
                        self.enum_aggregate_literal_to_vhdl(type_def, variants, variant, operands, "aggregate", span)
                    case _:
                        Err(self.backend_error("Aggregate Enum target {type_def.name} is not an enum type"))
            case _:
                Err(self.backend_error("Unsupported VHDL aggregate kind: {kind}"))

    fn aggregate_to_vhdl_process(kind: AggregateKind, operands: [MirOperand], dest_type: MirType, span: Span?) -> Result<text, CompileError>:
        match kind:
            case Tuple:
                match dest_type.kind:
                    case Tuple(elements):
                        if elements.len() != operands.len():
                            return Err(self.backend_error("Tuple aggregate expects {elements.len()} operands, got {operands.len()}"))
                        if elements.len() == 0:
                            return Err(self.backend_error("Empty tuple aggregates are not supported by the VHDL backend"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.process_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("f{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Tuple aggregate destination is not a tuple type: {dest_type.kind}"))
            case Struct(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Struct(fields):
                        if operands.len() != fields.len():
                            return Err(self.backend_error("Struct aggregate {type_def.name} expects {fields.len()} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.process_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{fields[idx].name} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Aggregate Struct target {type_def.name} is not a struct type"))
            case Array(_):
                match dest_type.kind:
                    case Array(_, size):
                        if operands.len() != size:
                            return Err(self.backend_error("Array aggregate expects {size} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.process_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Array aggregate destination is not an array type: {dest_type.kind}"))
            case Enum(symbol, variant):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Enum(variants):
                        self.enum_aggregate_literal_to_vhdl(type_def, variants, variant, operands, "process aggregate", span)
                    case _:
                        Err(self.backend_error("Aggregate Enum target {type_def.name} is not an enum type"))
            case _:
                Err(self.backend_error("Unsupported VHDL process aggregate kind: {kind}"))

    fn aggregate_to_vhdl_helper(kind: AggregateKind, operands: [MirOperand], dest_type: MirType, span: Span?) -> Result<text, CompileError>:
        match kind:
            case Tuple:
                match dest_type.kind:
                    case Tuple(elements):
                        if elements.len() != operands.len():
                            return Err(self.backend_error("Tuple aggregate expects {elements.len()} operands, got {operands.len()}"))
                        if elements.len() == 0:
                            return Err(self.backend_error("Empty tuple aggregates are not supported by the VHDL backend"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.helper_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("f{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Tuple aggregate destination is not a tuple type: {dest_type.kind}"))
            case Struct(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Struct(fields):
                        if operands.len() != fields.len():
                            return Err(self.backend_error("Struct aggregate {type_def.name} expects {fields.len()} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.helper_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{fields[idx].name} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Aggregate Struct target {type_def.name} is not a struct type"))
            case Array(_):
                match dest_type.kind:
                    case Array(_, size):
                        if operands.len() != size:
                            return Err(self.backend_error("Array aggregate expects {size} operands, got {operands.len()}"))
                        var entries: [text] = []
                        var idx = 0
                        for operand in operands:
                            val value_result = self.helper_operand_to_vhdl(operand)
                            if value_result.is_err():
                                return Err(value_result.unwrap_err())
                            entries = entries.push("{idx} => {value_result.unwrap()}")
                            idx = idx + 1
                        Ok("({entries.join(\", \")})")
                    case _:
                        Err(self.backend_error("Array aggregate destination is not an array type: {dest_type.kind}"))
            case Enum(symbol, variant):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Enum(variants):
                        self.enum_aggregate_literal_to_vhdl(type_def, variants, variant, operands, "helper aggregate", span)
                    case _:
                        Err(self.backend_error("Aggregate Enum target {type_def.name} is not an enum type"))
            case _:
                Err(self.backend_error("Unsupported VHDL helper aggregate kind: {kind}"))

    fn enum_aggregate_literal_to_vhdl(type_def: MirTypeDef, variants: [MirVariantDef], variant: i64, operands: [MirOperand], lowering_context: text, span: Span?) -> Result<text, CompileError>:
        if variant < 0 or variant >= variants.len():
            return Err(self.backend_error("Enum aggregate variant index {variant} out of range for {type_def.name}"))
        if variants.len() == 0:
            return Err(self.backend_error("Enum aggregate destination {type_def.name} has no variants"))
        if self.enum_has_payload(variants):
            return self.payload_enum_aggregate_to_vhdl(type_def, variants, variant, operands, lowering_context, span)
        if operands.len() != 0:
            return Err(self.backend_error_at("Payload-free enum `{type_def.name}.{variants[variant].name}` expects 0 payload operands, got {operands.len()} in {lowering_context} lowering", span))
        Ok(self.sanitize_vhdl_identifier(variants[variant].name))

    fn payload_enum_aggregate_to_vhdl(type_def: MirTypeDef, variants: [MirVariantDef], variant: i64, operands: [MirOperand], lowering_context: text, span: Span?) -> Result<text, CompileError>:
        val selected = variants[variant]
        if selected.payload.?:
            if operands.len() != 1:
                return Err(self.backend_error_at("Payload enum `{type_def.name}.{selected.name}` expects 1 payload operand, got {operands.len()} in {lowering_context} lowering", span))
        elif operands.len() != 0:
            return Err(self.backend_error_at("Payload-free enum `{type_def.name}.{selected.name}` expects 0 payload operands, got {operands.len()} in {lowering_context} lowering", span))

        var entries: [text] = ["tag => {self.sanitize_vhdl_identifier(selected.name)}"]
        var payload_operand_used = false
        for candidate in variants:
            if candidate.payload.?:
                val field_name = self.payload_enum_field_name(candidate)
                val default_result = self.default_vhdl_value(candidate.payload.unwrap(), span)
                if default_result.is_err():
                    return Err(default_result.unwrap_err())
                var value = default_result.unwrap()
                if candidate.discriminant == selected.discriminant and selected.payload.?:
                    val payload_value_result = self.payload_operand_to_vhdl_for_context(operands[0], lowering_context)
                    if payload_value_result.is_err():
                        return Err(payload_value_result.unwrap_err())
                    value = payload_value_result.unwrap()
                    payload_operand_used = true
                entries = entries.push("{field_name} => {value}")
        if selected.payload.? and not payload_operand_used:
            return Err(self.backend_error_at("Payload enum `{type_def.name}.{selected.name}` did not lower a payload operand", span))
        Ok("({entries.join(\", \")})")

    fn enum_has_payload(variants: [MirVariantDef]) -> bool:
        for variant in variants:
            if variant.payload.?:
                return true
        false

    fn payload_enum_field_name(variant: MirVariantDef) -> text:
        self.sanitize_vhdl_identifier(variant.name) + "_payload"

    fn payload_operand_to_vhdl_for_context(operand: MirOperand, lowering_context: text) -> Result<text, CompileError>:
        if lowering_context == "process aggregate":
            return self.process_operand_to_vhdl(operand)
        if lowering_context == "helper aggregate":
            return self.helper_operand_to_vhdl(operand)
        self.operand_to_vhdl(operand)

    fn default_vhdl_value(ty: MirType, span: Span?) -> Result<text, CompileError>:
        match ty.kind:
            case I64:
                Ok("to_signed(0, 64)")
            case I32:
                Ok("to_signed(0, 32)")
            case I16:
                Ok("to_signed(0, 16)")
            case I8:
                Ok("to_signed(0, 8)")
            case U64:
                Ok("to_unsigned(0, 64)")
            case U32:
                Ok("to_unsigned(0, 32)")
            case U16:
                Ok("to_unsigned(0, 16)")
            case U8:
                Ok("to_unsigned(0, 8)")
            case Bool:
                if self.use_resolved:
                    Ok("'0'")
                else:
                    Ok("'0'")
            case Bits(width, signed):
                if signed:
                    Ok("to_signed(0, {width})")
                else:
                    Ok("to_unsigned(0, {width})")
            case _:
                Err(self.backend_error_at("Payload enum default value is not defined for payload type `{ty.kind}`", span))

    fn field_name_for_operand(base: MirOperand, field: i64) -> Result<text, CompileError>:
        val type_result = self.operand_type(base)
        if type_result.is_err():
            return Err(type_result.unwrap_err())
        match type_result.unwrap().kind:
            case Struct(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Struct(fields):
                        if field < 0 or field >= fields.len():
                            return Err(self.backend_error("Struct field index {field} out of range for {type_def.name}"))
                        Ok(fields[field].name)
                    case _:
                        Err(self.backend_error("Field access target {type_def.name} is not a struct type"))
            case Enum(symbol):
                val type_def_result = self.type_def_by_symbol(symbol)
                if type_def_result.is_err():
                    return Err(type_def_result.unwrap_err())
                val type_def = type_def_result.unwrap()
                match type_def.kind:
                    case Enum(variants):
                        if field == 0:
                            return Ok("tag")
                        var payload_index = 1
                        for variant in variants:
                            if variant.payload.?:
                                if field == payload_index:
                                    return Ok(self.payload_enum_field_name(variant))
                                payload_index = payload_index + 1
                        Err(self.backend_error("Enum payload field index {field} out of range for {type_def.name}"))
                    case _:
                        Err(self.backend_error("Field access target {type_def.name} is not an enum type"))
            case _:
                Err(self.backend_error("VHDL field access requires a struct operand"))

    fn const_value_to_vhdl(value: MirConstValue, ty: MirType) -> Result<text, CompileError>:
        """Convert a constant value to VHDL literal."""
        self.const_value_to_vhdl_at(value, ty, nil)

    fn const_value_to_vhdl_at(value: MirConstValue, ty: MirType, span: Span?) -> Result<text, CompileError>:
        """Convert a constant value to VHDL literal with an optional diagnostic span."""
        val unsupported = self.unsupported_type_error(ty, "constant emission", span)
        if unsupported.?:
            return Err(unsupported.unwrap())
        match value:
            case Int(v):
                val width = self.integer_width(ty)
                if not width.?:
                    return Err(self.backend_error_at("Integer constant requires fixed-width integer type, got {ty.kind}", span))
                val width_result = self.validate_concrete_bit_width(width.unwrap())
                if width_result.is_err():
                    return Err(width_result.unwrap_err())
                match ty.kind:
                    case I64 | I32 | I16 | I8:
                        Ok("to_signed({v}, {width.unwrap()})")
                    case U64 | U32 | U16 | U8:
                        Ok("to_unsigned({v}, {width.unwrap()})")
                    case Bits(_, signed):
                        if signed:
                            Ok("to_signed({v}, {width.unwrap()})")
                        else:
                            Ok("to_unsigned({v}, {width.unwrap()})")
                    case _:
                        Err(self.backend_error_at("Unsupported integer literal target type: {ty.kind}", span))
            case Float(v):
                Err(self.backend_error_at("Floating-point constant {v} is not synthesizable for the VHDL backend", span))
            case Bool(v):
                Ok(if v: "'1'" else: "'0'")
            case Str(v):
                Ok("\"{v}\"")
            case Zero:
                Ok("(others => '0')")
            case _:
                Err(self.backend_error_at("Unsupported VHDL constant: {value}", span))

    fn binop_to_vhdl(op: MirBinOp, left: text, left_ty: MirType, right: text, right_ty: MirType, right_operand: MirOperand) -> Result<text, CompileError>:
        """Convert binary operation to VHDL expression."""
        match op:
            case Add: Ok("{left} + {right}")
            case Sub: Ok("{left} - {right}")
            case Mul: Ok("{left} * {right}")
            case Div: Ok("{left} / {right}")
            case Rem: Ok("{left} mod {right}")
            case Eq: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} = {right} else '0'")
            case Ne: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} /= {right} else '0'")
            case Lt: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} < {right} else '0'")
            case Le: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} <= {right} else '0'")
            case Gt: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} > {right} else '0'")
            case Ge: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "'1' when {left} >= {right} else '0'")
            case BitAnd: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "{left} and {right}")
            case BitOr: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "{left} or {right}")
            case BitXor: self.binop_with_matching_integer_widths(op, left, left_ty, right, right_ty, "{left} xor {right}")
            case Shl:
                val shift_count_result = self.shift_count_to_vhdl(right, right_ty, right_operand)
                if shift_count_result.is_err():
                    Err(shift_count_result.unwrap_err())
                else:
                    Ok("shift_left({left}, {shift_count_result.unwrap()})")
            case Shr:
                val shift_count_result = self.shift_count_to_vhdl(right, right_ty, right_operand)
                if shift_count_result.is_err():
                    Err(shift_count_result.unwrap_err())
                else:
                    Ok("shift_right({left}, {shift_count_result.unwrap()})")
            case _:
                Err(self.backend_error("Unsupported VHDL binary operator: {op}"))

    fn shift_count_to_vhdl(expr: text, ty: MirType, operand: MirOperand) -> Result<text, CompileError>:
        match operand.kind:
            case Const(value, _):
                match value:
                    case Int(v):
                        Ok("{v}")
                    case _:
                        Err(self.backend_error("VHDL shift count must be an integer value"))
            case _:
                match ty.kind:
                    case U64 | U32 | U16 | U8:
                        Ok("to_integer({expr})")
                    case I64 | I32 | I16 | I8:
                        Ok("to_integer(unsigned({expr}))")
                    case _:
                        Err(self.backend_error("Unsupported VHDL shift count type: {ty.kind}"))

    fn cast_to_vhdl(operand: text, source: MirType, target: MirType) -> Result<text, CompileError>:
        """Convert a MIR cast/bitcast to a synthesizable VHDL expression."""
        val source_width = self.integer_width(source)
        val target_width = self.integer_width(target)
        if target_width.?:
            val target_width_result = self.validate_concrete_bit_width(target_width.unwrap())
            if target_width_result.is_err():
                return Err(target_width_result.unwrap_err())
            match target.kind:
                case I64 | I32 | I16 | I8:
                    match source.kind:
                        case Bool:
                            Ok("to_signed(1, {target_width.unwrap()}) when {operand} = '1' else to_signed(0, {target_width.unwrap()})")
                        case _:
                            self.resize_expr_to_vhdl(operand, true, target_width.unwrap())
                case U64 | U32 | U16 | U8:
                    match source.kind:
                        case Bool:
                            Ok("to_unsigned(1, {target_width.unwrap()}) when {operand} = '1' else to_unsigned(0, {target_width.unwrap()})")
                        case _:
                            self.resize_expr_to_vhdl(operand, false, target_width.unwrap())
                case Bits(_, signed):
                    match source.kind:
                        case Bool:
                            if signed:
                                Ok("to_signed(1, {target_width.unwrap()}) when {operand} = '1' else to_signed(0, {target_width.unwrap()})")
                            else:
                                Ok("to_unsigned(1, {target_width.unwrap()}) when {operand} = '1' else to_unsigned(0, {target_width.unwrap()})")
                        case _:
                            self.resize_expr_to_vhdl(operand, signed, target_width.unwrap())
                case _:
                    Err(self.backend_error("Unsupported VHDL cast target: {target.kind}"))
        else:
            match target.kind:
                case Bool:
                    if source_width.?:
                        val source_width_result = self.validate_concrete_bit_width(source_width.unwrap())
                        if source_width_result.is_err():
                            return Err(source_width_result.unwrap_err())
                        if self.is_unsigned_integer_type(source):
                            Ok("'1' when {operand} /= to_unsigned(0, {source_width.unwrap()}) else '0'")
                        elif self.is_signed_integer_type(source):
                            Ok("'1' when {operand} /= to_signed(0, {source_width.unwrap()}) else '0'")
                        else:
                            Err(self.backend_error("Unsupported VHDL bool cast source: {source.kind}"))
                    else:
                        match source.kind:
                            case Bool:
                                Ok(operand)
                            case _:
                                Err(self.backend_error("Unsupported VHDL bool cast source: {source.kind}"))
                case _:
                    Err(self.backend_error("Unsupported VHDL cast target: {target.kind}"))

    fn unaryop_to_vhdl(op: MirUnaryOp, operand: text) -> Result<text, CompileError>:
        """Convert unary operation to VHDL expression."""
        match op:
            case Neg: Ok("-{operand}")
            case Not | BitNot: Ok("not {operand}")
            case _:
                Err(self.backend_error("Unsupported VHDL unary operator: {op}"))

# ============================================================================
# VHDL Compilation Results
# ============================================================================

struct VhdlCompiledModule:
    """Result of VHDL compilation."""
    name: text
    vhdl: text
    package_vhdl: text?
    entities: [VhdlEntity]

struct VhdlEntity:
    """Compiled VHDL entity."""
    name: text
    port_count: i64

# ============================================================================
# Codegen Trait Implementation
# ============================================================================

impl Codegen for VhdlBackend:
    fn backend_kind() -> BackendKind: BackendKind.Vhdl
    fn backend_name() -> text: "vhdl"
    fn supports_target(target: CodegenTarget) -> bool:
        val _ = target
        true
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.TextSource

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        val result = self.compile(module)
        match result:
            case Ok(vhdl_module):
                var output = vhdl_module.vhdl
                if vhdl_module.package_vhdl.?:
                    output = vhdl_module.package_vhdl.unwrap() + "\n\n" + output
                Ok(CodegenOutput.text(module.name, output))
            case Err(e):
                Err(e)

# ============================================================================
# HardwareCodegen Trait Implementation
# ============================================================================

impl HardwareCodegen for VhdlBackend:
    fn compile_entity(func_name: text, body: MirBody) -> Result<text, CompileError>:
        val builder = VhdlBuilder.create(func_name)
        builder.emit_library_header()
        var params: [MirType] = []
        for local in body.locals:
            match local.kind:
                case Arg(_):
                    params = params.push(local.type_)
                case _:
                    ()
        val func = MirFunction(
            symbol: SymbolId(id: 0),
            name: func_name,
            signature: MirSignature(params: params, return_type: body.return_ty, is_variadic: false),
            locals: body.locals,
            blocks: body.blocks,
            entry_block: BlockId.entry(),
            span: VhdlBackend.empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )
        val result = self.compile_function(builder, func)
        match result:
            case Ok(_):
                Ok(builder.build())
            case Err(e):
                Err(e)

    fn compile_package(module: MirModule) -> Result<text, CompileError>:
        val builder = VhdlBuilder.create(module.name)
        builder.emit_library_header()
        self.active_type_defs = {}
        for symbol in module.types.keys():
            self.active_type_defs = self.active_type_defs.set(symbol.id, module.types[symbol])
        self.prepare_tuple_types_for_module(module)
        val result = self.compile_package_into(builder, module)
        if result.is_err():
            return Err(result.unwrap_err())
        Ok(builder.build())

    fn compile_process(kind: compiler.backend.hardware_codegen_types.VhdlProcessKind, body_block: MirBlock) -> Result<text, CompileError>:
        val builder = VhdlBuilder.create("process")
        match kind:
            case Combinational:
                builder.emit_process_begin(Some(builder.alloc_label()), [])
                builder.emit_process_body_begin()
                for inst in body_block.instructions:
                    val result = self.compile_instruction(builder, inst)
                    if result.is_err():
                        return Err(result.unwrap_err())
                builder.emit_process_end(nil)
                Ok(builder.build())
            case Clocked:
                builder.emit_clocked_process_begin(Some(builder.alloc_label()), "clk", nil)
                builder.emit_process_body_begin()
                builder.emit_rising_edge_check("clk")
                for inst in body_block.instructions:
                    val result = self.compile_instruction(builder, inst)
                    if result.is_err():
                        return Err(result.unwrap_err())
                builder.emit_if_end()
                builder.emit_process_end(nil)
                Ok(builder.build())
            case AsyncReset:
                builder.emit_clocked_process_begin(Some(builder.alloc_label()), "clk", Some("rst"))
                builder.emit_process_body_begin()
                builder.emit_if_begin("rst = '1'")
                builder.emit_comment("reset: default signal values applied")
                builder.emit_else()
                builder.emit_rising_edge_check("clk")
                for inst in body_block.instructions:
                    val result = self.compile_instruction(builder, inst)
                    if result.is_err():
                        return Err(result.unwrap_err())
                builder.emit_if_end()
                builder.emit_if_end()
                builder.emit_process_end(nil)
                Ok(builder.build())

