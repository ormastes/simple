# WASM Runtime Imports - WASI Preview 1 and Simple Runtime imports
#
# Generates WAT import declarations for:
# - WASI Preview 1 syscalls (fd_write, fd_read, proc_exit, etc.)
# - Simple runtime functions (rt_alloc, rt_print, rt_strlen, etc.)
#
# Usage:
#   var builder = WatBuilder.create()
#   emit_wasi_imports(builder)
#   emit_runtime_imports(builder)

use compiler.backend.wasm_backend.{WatBuilder, WasmType, WasmImport, WasmImportKind}

# ============================================================================
# WASI Preview 1 Imports
# ============================================================================

fn emit_wasi_imports(builder: WatBuilder):
    """Emit WASI Preview 1 function imports.

    These provide basic system interface: I/O, process control, clocks.
    """
    # fd_write(fd: i32, iovs: i32, iovs_len: i32, nwritten: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"fd_write\" (func $fd_write (param i32 i32 i32 i32) (result i32)))")

    # fd_read(fd: i32, iovs: i32, iovs_len: i32, nread: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"fd_read\" (func $fd_read (param i32 i32 i32 i32) (result i32)))")

    # fd_close(fd: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"fd_close\" (func $fd_close (param i32) (result i32)))")

    # fd_seek(fd: i32, offset: i64, whence: i32, newoffset: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"fd_seek\" (func $fd_seek (param i32 i64 i32 i32) (result i32)))")

    # proc_exit(code: i32)
    builder.emit("(import \"wasi_snapshot_preview1\" \"proc_exit\" (func $proc_exit (param i32)))")

    # args_get(argv: i32, argv_buf: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"args_get\" (func $args_get (param i32 i32) (result i32)))")

    # args_sizes_get(argc: i32, argv_buf_size: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"args_sizes_get\" (func $args_sizes_get (param i32 i32) (result i32)))")

    # clock_time_get(clock_id: i32, precision: i64, time: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"clock_time_get\" (func $clock_time_get (param i32 i64 i32) (result i32)))")

    # environ_get(environ: i32, environ_buf: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"environ_get\" (func $environ_get (param i32 i32) (result i32)))")

    # environ_sizes_get(environc: i32, environ_buf_size: i32) -> i32
    builder.emit("(import \"wasi_snapshot_preview1\" \"environ_sizes_get\" (func $environ_sizes_get (param i32 i32) (result i32)))")

# ============================================================================
# Simple Runtime Imports
# ============================================================================

fn emit_runtime_imports(builder: WatBuilder):
    """Emit Simple runtime function imports.

    These are provided by the host environment (JavaScript or WASI runtime).
    All use i32 for pointers (wasm32 linear memory offsets).
    """
    # Memory operations
    builder.emit("(import \"simple\" \"rt_alloc\" (func $rt_alloc (param i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_free\" (func $rt_free (param i32)))")
    builder.emit("(import \"simple\" \"rt_realloc\" (func $rt_realloc (param i32 i32) (result i32)))")

    # I/O operations
    builder.emit("(import \"simple\" \"rt_print\" (func $rt_print (param i32)))")
    builder.emit("(import \"simple\" \"rt_println\" (func $rt_println (param i32)))")
    builder.emit("(import \"simple\" \"rt_readline\" (func $rt_readline (result i32)))")

    # String operations
    builder.emit("(import \"simple\" \"rt_strlen\" (func $rt_strlen (param i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_strcat\" (func $rt_strcat (param i32 i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_strcmp\" (func $rt_strcmp (param i32 i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_substr\" (func $rt_substr (param i32 i32 i32) (result i32)))")

    # Array operations
    builder.emit("(import \"simple\" \"rt_array_new\" (func $rt_array_new (param i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_array_len\" (func $rt_array_len (param i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_array_get\" (func $rt_array_get (param i32 i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_array_set\" (func $rt_array_set (param i32 i32 i32)))")
    builder.emit("(import \"simple\" \"rt_array_push\" (func $rt_array_push (param i32 i32) (result i32)))")

    # Dict operations
    builder.emit("(import \"simple\" \"rt_dict_new\" (func $rt_dict_new (result i32)))")
    builder.emit("(import \"simple\" \"rt_dict_get\" (func $rt_dict_get (param i32 i32) (result i32)))")
    builder.emit("(import \"simple\" \"rt_dict_set\" (func $rt_dict_set (param i32 i32 i32)))")

    # Error handling
    builder.emit("(import \"simple\" \"rt_panic\" (func $rt_panic (param i32)))")

# ============================================================================
# Game Engine Imports (for game3d WASM target)
# ============================================================================

fn emit_engine_imports(builder: WatBuilder):
    """Emit game engine function imports from the "engine" module.

    These are implemented by the engine bridge (Unity/Godot/Unreal).
    Entity handles are opaque i32, complex data via out-pointers.
    """
    # Entity Management (8)
    builder.emit("(import \"engine\" \"engine_entity_create\" (func $engine_entity_create (result i32)))")
    builder.emit("(import \"engine\" \"engine_entity_create_named\" (func $engine_entity_create_named (param i32 i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_entity_destroy\" (func $engine_entity_destroy (param i32)))")
    builder.emit("(import \"engine\" \"engine_entity_set_active\" (func $engine_entity_set_active (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_entity_is_active\" (func $engine_entity_is_active (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_entity_set_parent\" (func $engine_entity_set_parent (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_entity_set_name\" (func $engine_entity_set_name (param i32 i32 i32)))")
    builder.emit("(import \"engine\" \"engine_entity_find_by_name\" (func $engine_entity_find_by_name (param i32 i32) (result i32)))")

    # Transform (12)
    builder.emit("(import \"engine\" \"engine_transform_get_position\" (func $engine_transform_get_position (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_transform_set_position\" (func $engine_transform_set_position (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_get_rotation\" (func $engine_transform_get_rotation (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_transform_set_rotation\" (func $engine_transform_set_rotation (param i32 f32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_get_scale\" (func $engine_transform_get_scale (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_transform_set_scale\" (func $engine_transform_set_scale (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_look_at\" (func $engine_transform_look_at (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_translate\" (func $engine_transform_translate (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_rotate\" (func $engine_transform_rotate (param i32 f32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_transform_get_forward\" (func $engine_transform_get_forward (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_transform_get_up\" (func $engine_transform_get_up (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_transform_get_right\" (func $engine_transform_get_right (param i32 i32)))")

    # Rendering (14)
    builder.emit("(import \"engine\" \"engine_render_set_mesh\" (func $engine_render_set_mesh (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_mesh_asset\" (func $engine_render_set_mesh_asset (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_material\" (func $engine_render_set_material (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_render_create_material\" (func $engine_render_create_material (result i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_material_color\" (func $engine_render_set_material_color (param i32 f32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_render_set_material_texture\" (func $engine_render_set_material_texture (param i32 i32 i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_material_float\" (func $engine_render_set_material_float (param i32 i32 f32)))")
    builder.emit("(import \"engine\" \"engine_render_create_light\" (func $engine_render_create_light (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_light_color\" (func $engine_render_set_light_color (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_render_set_light_intensity\" (func $engine_render_set_light_intensity (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_render_create_camera\" (func $engine_render_create_camera (result i32)))")
    builder.emit("(import \"engine\" \"engine_render_set_camera_fov\" (func $engine_render_set_camera_fov (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_render_set_camera_active\" (func $engine_render_set_camera_active (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_render_create_primitive\" (func $engine_render_create_primitive (param i32) (result i32)))")

    # Input (8)
    builder.emit("(import \"engine\" \"engine_input_is_key_pressed\" (func $engine_input_is_key_pressed (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_input_is_key_just_pressed\" (func $engine_input_is_key_just_pressed (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_input_is_key_just_released\" (func $engine_input_is_key_just_released (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_input_get_mouse_position\" (func $engine_input_get_mouse_position (param i32)))")
    builder.emit("(import \"engine\" \"engine_input_get_mouse_delta\" (func $engine_input_get_mouse_delta (param i32)))")
    builder.emit("(import \"engine\" \"engine_input_is_mouse_button_pressed\" (func $engine_input_is_mouse_button_pressed (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_input_get_axis\" (func $engine_input_get_axis (param i32 i32) (result f32)))")
    builder.emit("(import \"engine\" \"engine_input_is_action_pressed\" (func $engine_input_is_action_pressed (param i32 i32) (result i32)))")

    # Physics (12)
    builder.emit("(import \"engine\" \"engine_physics_add_rigidbody\" (func $engine_physics_add_rigidbody (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_physics_set_mass\" (func $engine_physics_set_mass (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_set_velocity\" (func $engine_physics_set_velocity (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_get_velocity\" (func $engine_physics_get_velocity (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_physics_add_force\" (func $engine_physics_add_force (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_add_impulse\" (func $engine_physics_add_impulse (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_add_collider_box\" (func $engine_physics_add_collider_box (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_add_collider_sphere\" (func $engine_physics_add_collider_sphere (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_add_collider_capsule\" (func $engine_physics_add_collider_capsule (param i32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_raycast\" (func $engine_physics_raycast (param f32 f32 f32 f32 f32 f32 f32 i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_physics_set_gravity\" (func $engine_physics_set_gravity (param f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_physics_set_collision_layer\" (func $engine_physics_set_collision_layer (param i32 i32 i32)))")

    # Audio (8)
    builder.emit("(import \"engine\" \"engine_audio_load\" (func $engine_audio_load (param i32 i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_audio_play\" (func $engine_audio_play (param i32)))")
    builder.emit("(import \"engine\" \"engine_audio_stop\" (func $engine_audio_stop (param i32)))")
    builder.emit("(import \"engine\" \"engine_audio_set_volume\" (func $engine_audio_set_volume (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_audio_set_pitch\" (func $engine_audio_set_pitch (param i32 f32)))")
    builder.emit("(import \"engine\" \"engine_audio_set_spatial\" (func $engine_audio_set_spatial (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_audio_set_position\" (func $engine_audio_set_position (param i32 f32 f32 f32)))")
    builder.emit("(import \"engine\" \"engine_audio_is_playing\" (func $engine_audio_is_playing (param i32) (result i32)))")

    # Asset Management (4)
    builder.emit("(import \"engine\" \"engine_asset_load\" (func $engine_asset_load (param i32 i32 i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_asset_is_loaded\" (func $engine_asset_is_loaded (param i32) (result i32)))")
    builder.emit("(import \"engine\" \"engine_asset_unload\" (func $engine_asset_unload (param i32)))")
    builder.emit("(import \"engine\" \"engine_asset_load_texture\" (func $engine_asset_load_texture (param i32 i32) (result i32)))")

    # Debug (2)
    builder.emit("(import \"engine\" \"engine_debug_log\" (func $engine_debug_log (param i32 i32)))")
    builder.emit("(import \"engine\" \"engine_debug_draw_line\" (func $engine_debug_draw_line (param f32 f32 f32 f32 f32 f32 f32 f32 f32)))")

# ============================================================================
# Combined Import Generation
# ============================================================================

fn emit_all_wasm_imports(builder: WatBuilder, use_wasi: bool):
    """Emit all required imports for a WASM module.

    Args:
        builder: WAT builder to emit to
        use_wasi: If true, include WASI Preview 1 imports
    """
    if use_wasi:
        emit_wasi_imports(builder)
    emit_runtime_imports(builder)

fn emit_game_engine_wasm_imports(builder: WatBuilder):
    """Emit imports for game engine WASM target (no WASI, engine provides all).

    Uses "engine" module for game API + "simple" module for runtime.
    """
    emit_runtime_imports(builder)
    emit_engine_imports(builder)

