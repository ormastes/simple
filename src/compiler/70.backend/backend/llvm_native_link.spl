# LLVM Native Link Orchestrator
#
# Orchestrates the full native executable linking pipeline for LLVM backend:
# 1. Compile C runtime sources to .o files
# 2. Generate entry point LLVM IR and compile to .o
# 3. Combine user objects + runtime objects + entry point
# 4. Link everything into a native executable
#
# Usage:
#   val result = link_llvm_native(user_objects, output, config, verbose)

use app.io.sysinfo_ops.{getpid}
use compiler.common.mir_target_context.{mir_target_context_normalize_arch}
use compiler.backend.backend.entry_point.{generate_entry_point_ir}
use compiler.backend.backend.llvm_target.{LlvmTargetConfig}
use compiler.backend.backend.llvm_backend_tools.{compile_ir_to_object, extract_symbols_nm, llc_available}
use compiler.backend.backend.llvm_capability.{find_archive_portable, find_nm_portable, find_objcopy_portable, find_objdump_portable}
use compiler.backend.backend.backend_types.{CodegenTarget, OptimizationLevel}
use compiler.backend.backend.runtime_compiler.{compile_runtime_objects, cleanup_runtime_objects, find_c_compiler, hosted_c_compiler_plan, _get_temp_dir, _obj_ext, _is_windows, _is_mingw, _is_msvc_cc}
use compiler.backend.linker.linker_wrapper.{link_to_native, NativeLinkConfig, hosted_native_link_arch_supported, hosted_native_link_unsupported_arch_error}
use compiler.backend.backend.stage4_symbol_closure.{stage4_compiler_backfill_archive_file, stage4_compiler_backfill_object_format, stage4_derive_compiler_backfill_manifest, stage4_compiler_backfill_localization_symbols, stage4_validate_compiler_backfill_symbol_envelope, stage4_compiler_backfill_symbol_table_fingerprint, stage4_validate_compiler_backfill_provider_disjoint, stage4_projection_localization_symbols, stage4_validate_projection_symbol_contract, stage4_runtime_native_archive_file, stage4_runtime_native_object_format, stage4_runtime_native_localization_symbols, stage4_validate_runtime_native_core_symbol_contract, stage4_runtime_legacy_compat_archive_file, stage4_runtime_legacy_compat_object_format, stage4_runtime_legacy_compat_localization_symbols, stage4_validate_runtime_legacy_compat_symbol_contract, stage4_process_provider_archive_file, stage4_process_provider_object_format, stage4_validate_process_provider_symbol_contract, stage4_dynload_provider_archive_file, stage4_dynload_provider_object_format, stage4_font_provider_archive_file, stage4_font_provider_object_format, stage4_memtrack_provider_archive_file, stage4_memtrack_provider_object_format, stage4_time_provider_archive_file, stage4_time_provider_object_format, stage4_sqlite_provider_archive_file, stage4_sqlite_provider_object_format, stage4_validate_sqlite_provider_symbol_contract, stage4_fork_provider_archive_file, stage4_fork_provider_object_format, stage4_windows_c_object_uses_msvc_abi, stage4_runtime_provider_object_matches, stage4_forbidden_archive_sections, stage4_requested_from_nm_output, stage4_resolve_requested_archive_owners, stage4_validate_candidate_archive_inputs_for_platform, stage4_validate_dynload_provider_symbol_contract, stage4_validate_font_provider_symbol_contract, stage4_validate_memtrack_provider_symbol_contract, stage4_validate_time_provider_symbol_contract, stage4_validate_fork_provider_symbol_contract}
use std.platform.{host_arch, host_os, is_macos}
# Routed through the canonical std.nogc_sync_mut.io_runtime facade (same
# facade already used by the sibling llvm_backend_tools.spl for process_run);
# resolves doc/08_tracking/bug/compiler_native_link_direct_runtime_facade_2026-07-12.md.
use std.nogc_sync_mut.io_runtime.{env_get, file_copy, file_delete, file_exists, file_write, remove_file_if_exists, process_run, dir_create_all, dir_exists, dir_remove_all}

fn llvm_link_trace_enabled() -> bool:
    (env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

fn llvm_stage4_final_requested_symbols(objects: [text]) -> Result<[text], text>:
    if objects.len() == 0:
        return Err("Stage4 final object closure is empty")
    val nm = find_nm_portable()
    if nm == "":
        return Err("Stage4 final object symbol scan requires llvm-nm or nm")
    var args: [text] = ["-g"]
    for object in objects:
        args = args.push(object)
    val (nm_out, nm_err, nm_code) = process_run(nm, args)
    if nm_code != 0:
        return Err("Stage4 final object symbol scan failed: {nm_err}")
    val requested = stage4_requested_from_nm_output(nm_out, is_macos())
    if requested.len() == 0:
        return Err("Stage4 final runtime symbol request closure is empty")
    Ok(requested)

pub fn llvm_stage4_candidate_archive_inventory(labels: [text], paths: [text]) -> Result<[text], text>:
    match stage4_validate_candidate_archive_inputs_for_platform(labels, paths, host_os() == "windows"):
        case Err(err): return Err(err)
        case Ok(()): ()
    val nm = find_nm_portable()
    if nm == "":
        return Err("Stage4 candidate archive scan requires llvm-nm or nm")
    val section_reader = find_objdump_portable()
    if section_reader == "":
        return Err("Stage4 candidate archive scan requires llvm-objdump, readelf, or objdump")
    var scans: [text] = []
    var i = 0
    while i < paths.len():
        val label = labels[i]
        val path = paths[i]
        if not file_exists(path):
            return Err("Stage4 candidate archive '" + label + "' is missing at '" + path + "'")
        val section_flag = if section_reader.lower().contains("readelf"): "-S" else: "-h"
        val (section_out, section_err, section_code) = process_run(section_reader, [section_flag, path])
        if section_code != 0:
            return Err("Stage4 candidate archive '" + label + "' section scan failed at '" + path + "': " + section_err)
        if section_err.trim() != "":
            return Err("Stage4 candidate archive '" + label + "' section scan reported diagnostics despite exit 0 at '" + path + "': " + section_err.trim())
        if section_out.trim() == "":
            return Err("Stage4 candidate archive '" + label + "' section scan was empty at '" + path + "'")
        val forbidden_sections = stage4_forbidden_archive_sections(section_out)
        if forbidden_sections.len() > 0:
            return Err("Stage4 candidate archive '" + label + "' retained constructor/destructor sections at '" + path + "': " + forbidden_sections.join(", "))
        val (nm_out, nm_err, nm_code) = process_run(nm, ["-g", path])
        if nm_code != 0:
            return Err("Stage4 candidate archive '" + label + "' scan failed at '" + path + "': " + nm_err)
        if nm_out.trim() == "":
            return Err("Stage4 candidate archive '" + label + "' scan was empty at '" + path + "'")
        scans = scans.push(nm_out)
        i = i + 1
    Ok(scans)

fn llvm_stage4_projection_failure(stage_dir: text, message: text) -> Result<(text, text), text>:
    if not dir_remove_all(stage_dir):
        return Err(message + "; Stage4 projection cleanup also failed")
    Err(message)

fn llvm_stage4_project_selected_archives(candidate_labels: [text], candidate_paths: [text], selected_indices: [i64], requested_symbols: [text], target_os_name: text, hosted_cc: text, pid: i64, output_path: text) -> Result<(text, text), text>:
    """Partial-link selected exact archives and export only the original requested roots."""
    if target_os_name != "linux" and target_os_name != "macos":
        return Err("Stage4 selected-archive projection requires native Linux or macOS")
    match stage4_validate_candidate_archive_inputs_for_platform(candidate_labels, candidate_paths, false):
        case Err(err): return Err(err)
        case Ok(()): ()
    if selected_indices.len() == 0:
        return Err("Stage4 selected-archive projection requires at least one owner")
    if requested_symbols.len() == 0:
        return Err("Stage4 selected-archive projection requires at least one requested root")
    if hosted_cc.trim() == "":
        return Err("Stage4 selected-archive projection requires a hosted C compiler")

    var selected_paths: [text] = []
    var previous_index = -1
    for index in selected_indices:
        if index < 0 or index >= candidate_paths.len():
            return Err("Stage4 selected-archive projection index is out of bounds")
        if index <= previous_index:
            return Err("Stage4 selected-archive projection indices must be unique and in candidate order")
        previous_index = index
        selected_paths = selected_paths.push(candidate_paths[index])

    val nm = find_nm_portable()
    val objcopy = find_objcopy_portable()
    val section_reader = find_objdump_portable()
    val archiver = find_archive_portable()
    if nm == "" or objcopy == "" or section_reader == "" or archiver == "":
        return Err("Stage4 selected-archive projection requires nm, objcopy, section-reader, and archive tools")
    val object_format = match stage4_compiler_backfill_object_format(target_os_name, false):
        case Ok(format): format
        case Err(err): return Err(err)
    val stage_dir = "{_get_temp_dir()}/simple_stage4_selected_projection_{pid}_{output_path.hash()}"
    val closure_object = stage_dir + "/stage4_selected_closure.o"
    val localized_object = stage_dir + "/stage4_selected_local.o"
    val localize_path = stage_dir + "/stage4_selected_localize.syms"
    val capsule_path = stage_dir + "/libsimple_stage4_selected.a"
    if dir_exists(stage_dir):
        if not dir_remove_all(stage_dir):
            return Err("Stage4 selected-archive projection stale transaction cleanup failed")
    if not dir_create_all(stage_dir):
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive projection directory creation failed")

    var closure_args: [text] = ["-nostdlib", "-Wl,-r"]
    if target_os_name == "linux":
        closure_args = closure_args.push("-no-pie")
        closure_args = closure_args.push("-Wl,--gc-sections")
        for symbol in requested_symbols:
            closure_args = closure_args.push("-Wl,--undefined={symbol}")
        closure_args = closure_args.push("-Wl,--start-group")
        for path in selected_paths:
            closure_args = closure_args.push(path)
        closure_args = closure_args.push("-Wl,--end-group")
    else:
        for symbol in requested_symbols:
            closure_args = closure_args.push("-Wl,-u,_{symbol}")
        for path in selected_paths:
            closure_args = closure_args.push("-Wl,-force_load," + path)
    closure_args = closure_args.push("-o")
    closure_args = closure_args.push(closure_object)
    val (_, closure_err, closure_code) = process_run(hosted_cc, closure_args)
    if closure_code != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive closure link failed: " + closure_err.trim())

    val (closure_nm_out, closure_nm_err, closure_nm_code) = process_run(nm, ["-g", "-p", closure_object])
    if closure_nm_code != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive closure scan failed: " + closure_nm_err.trim())
    val localize_symbols = match stage4_projection_localization_symbols(closure_nm_out, object_format, requested_symbols):
        case Ok(symbols): symbols
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    var localize_text = localize_symbols.join("\n")
    if localize_text != "":
        localize_text = localize_text + "\n"
    if not file_write(localize_path, localize_text):
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive localization-list write failed")
    val objcopy_args = [
        "--localize-symbols=" + localize_path,
        "--remove-section=.init_array", "--remove-section=.init_array.*",
        "--remove-section=.ctors", "--remove-section=.ctors.*",
        "--remove-section=.fini_array", "--remove-section=.fini_array.*",
        "--remove-section=.dtors", "--remove-section=.dtors.*",
        "--remove-section=__mod_init_func", "--remove-section=__mod_term_func",
        "--remove-section=__DATA,__mod_init_func", "--remove-section=__DATA,__mod_term_func",
        closure_object, localized_object
    ]
    val (_, objcopy_err, objcopy_code) = process_run(objcopy, objcopy_args)
    if objcopy_code != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive localization failed: " + objcopy_err.trim())
    val (localized_nm_out, localized_nm_err, localized_nm_code) = process_run(nm, ["-g", "-p", localized_object])
    if localized_nm_code != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive localized scan failed: " + localized_nm_err.trim())
    match stage4_validate_projection_symbol_contract(localized_nm_out, object_format, requested_symbols):
        case Ok(()): ()
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    val localized_fingerprint = match stage4_compiler_backfill_symbol_table_fingerprint(localized_nm_out):
        case Ok(fingerprint): fingerprint
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    val section_flag = if section_reader.lower().contains("readelf"): "-S" else: "-h"
    val (section_out, section_err, section_code) = process_run(section_reader, [section_flag, localized_object])
    if section_code != 0 or section_err.trim() != "" or section_out.trim() == "":
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive section scan was not clean: " + section_err.trim())
    val forbidden_sections = stage4_forbidden_archive_sections(section_out)
    if forbidden_sections.len() != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive projection retained constructor/destructor sections: " + forbidden_sections.join(", "))

    val (_, archive_err, archive_code) = process_run(archiver, ["rcsD", capsule_path, localized_object])
    if archive_code != 0:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive capsule creation failed: " + archive_err.trim())
    val (members_out, members_err, members_code) = process_run(archiver, ["t", capsule_path])
    if members_code != 0 or members_out.replace("\r", "").trim() != "stage4_selected_local.o":
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive capsule must contain exactly 'stage4_selected_local.o': " + members_err.trim())
    val scans = match llvm_stage4_candidate_archive_inventory(["stage4_selected"], [capsule_path]):
        case Ok(outputs): outputs
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    match stage4_validate_projection_symbol_contract(scans[0], object_format, requested_symbols):
        case Ok(()): ()
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    val capsule_fingerprint = match stage4_compiler_backfill_symbol_table_fingerprint(scans[0]):
        case Ok(fingerprint): fingerprint
        case Err(err): return llvm_stage4_projection_failure(stage_dir, err)
    if capsule_fingerprint != localized_fingerprint:
        return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive capsule changed the localized symbol table")
    for path in [closure_object, localized_object, localize_path]:
        if not remove_file_if_exists(path):
            return llvm_stage4_projection_failure(stage_dir, "Stage4 selected-archive temporary cleanup failed")
    Ok((capsule_path, stage_dir))

fn llvm_stage4_cleanup_compiler_backfill_capsule(stage_dir: text, output_path: text, remove_output: bool) -> bool:
    var clean = true
    for path in [
        stage_dir + "/compiler_backfill_closure.o",
        stage_dir + "/compiler_backfill_local.o",
        stage_dir + "/compiler_backfill_localize.syms"
    ]:
        if not remove_file_if_exists(path):
            clean = false
    if remove_output:
        if not remove_file_if_exists(output_path):
            clean = false
        if not dir_remove_all(stage_dir):
            clean = false
    clean

fn llvm_stage4_compiler_backfill_failure(stage_dir: text, output_path: text, message: text) -> Result<text, text>:
    if not llvm_stage4_cleanup_compiler_backfill_capsule(stage_dir, output_path, true):
        return Err(message + "; compiler backfill cleanup also failed")
    Err(message)

fn llvm_stage4_build_compiler_backfill_capsule(runtime_path: text, target_os_name: text, hosted_cc: text, msvc_objects: bool, msvc_linker: bool, pid: i64, output_path: text) -> Result<text, text>:
    if runtime_path.trim() == "":
        return Err("Stage4 compiler backfill capsule requires SIMPLE_RUNTIME_PATH")
    if output_path.trim() == "":
        return Err("Stage4 compiler backfill capsule requires a final output path")
    if target_os_name == "windows":
        return Err("Stage4 compiler backfill capsule requires Windows projection support")
    val archive_file = match stage4_compiler_backfill_archive_file(target_os_name, msvc_linker):
        case Ok(file): file
        case Err(err): return Err(err)
    val object_format = match stage4_compiler_backfill_object_format(target_os_name, msvc_objects):
        case Ok(format): format
        case Err(err): return Err(err)
    val raw_archive = runtime_path + "/" + archive_file
    if not file_exists(raw_archive):
        return Err("Stage4 compiler backfill source archive is missing at '" + raw_archive + "'")
    if hosted_cc.trim() == "":
        return Err("Stage4 compiler backfill closure requires a hosted C compiler")
    val nm = find_nm_portable()
    if nm == "":
        return Err("Stage4 compiler backfill closure requires llvm-nm or nm")
    val objcopy = find_objcopy_portable()
    if objcopy == "":
        return Err("Stage4 compiler backfill closure requires llvm-objcopy or objcopy")
    val section_reader = find_objdump_portable()
    if section_reader == "":
        return Err("Stage4 compiler backfill closure requires llvm-objdump, readelf, or objdump")
    val archiver = find_archive_portable()
    if archiver == "":
        return Err("Stage4 compiler backfill closure requires llvm-ar or ar")

    val (raw_nm_out, raw_nm_err, raw_nm_code) = process_run(nm, ["-g", "-p", raw_archive])
    if raw_nm_code != 0:
        return Err("Stage4 compiler backfill source symbol scan failed: " + raw_nm_err.trim())
    val manifest = match stage4_derive_compiler_backfill_manifest(raw_nm_out, object_format):
        case Ok(symbols): symbols
        case Err(err): return Err(err)

    val stage_dir = "{_get_temp_dir()}/simple_stage4_compiler_backfill_{pid}_{output_path.hash()}"
    val closure_object = stage_dir + "/compiler_backfill_closure.o"
    val localized_object = stage_dir + "/compiler_backfill_local.o"
    val localize_path = stage_dir + "/compiler_backfill_localize.syms"
    val capsule_path = stage_dir + "/" + archive_file
    if raw_archive == capsule_path:
        return Err("Stage4 compiler backfill input and output archives must differ")
    dir_remove_all(stage_dir)
    if dir_exists(stage_dir):
        return Err("Stage4 compiler backfill stale transaction cleanup failed: '" + stage_dir + "'")
    if not dir_create_all(stage_dir):
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill staging directory creation failed")

    var closure_args: [text] = ["-nostdlib", "-Wl,-r"]
    if target_os_name == "linux":
        closure_args = closure_args.push("-no-pie")
        closure_args = closure_args.push("-Wl,--gc-sections")
        for symbol in manifest:
            closure_args = closure_args.push("-Wl,--undefined={symbol}")
    else:
        for symbol in manifest:
            closure_args = closure_args.push("-Wl,-u,_{symbol}")
    closure_args = closure_args.push("-o")
    closure_args = closure_args.push(closure_object)
    closure_args = closure_args.push(raw_archive)
    val (_, closure_err, closure_code) = process_run(hosted_cc, closure_args)
    if closure_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill closure link failed: " + closure_err.trim())

    val (closure_nm_out, closure_nm_err, closure_nm_code) = process_run(nm, ["-g", "-p", closure_object])
    if closure_nm_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill closure symbol scan failed: " + closure_nm_err.trim())
    val localize_symbols = match stage4_compiler_backfill_localization_symbols(closure_nm_out, object_format, manifest):
        case Ok(symbols): symbols
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
    var localize_text = localize_symbols.join("\n")
    if localize_text != "":
        localize_text = localize_text + "\n"
    if not file_write(localize_path, localize_text):
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill localization-list write failed")

    val objcopy_args = [
        "--localize-symbols=" + localize_path,
        "--remove-section=.init_array",
        "--remove-section=.init_array.*",
        "--remove-section=.ctors",
        "--remove-section=.ctors.*",
        "--remove-section=.fini_array",
        "--remove-section=.fini_array.*",
        "--remove-section=.dtors",
        "--remove-section=.dtors.*",
        "--remove-section=__mod_init_func",
        "--remove-section=__mod_term_func",
        "--remove-section=__DATA,__mod_init_func",
        "--remove-section=__DATA,__mod_term_func",
        closure_object,
        localized_object
    ]
    val (_, objcopy_err, objcopy_code) = process_run(objcopy, objcopy_args)
    if objcopy_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill localization failed: " + objcopy_err.trim())

    val (localized_nm_out, localized_nm_err, localized_nm_code) = process_run(nm, ["-g", "-p", localized_object])
    if localized_nm_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 localized compiler backfill symbol scan failed: " + localized_nm_err.trim())
    val localized_extra = match stage4_compiler_backfill_localization_symbols(localized_nm_out, object_format, manifest):
        case Ok(symbols): symbols
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
    if localized_extra.len() != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill retained unexpected global definitions: " + localized_extra.join(", "))
    match stage4_validate_compiler_backfill_symbol_envelope(localized_nm_out, object_format):
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
        case Ok(()): ()
    val localized_symbol_fingerprint = match stage4_compiler_backfill_symbol_table_fingerprint(localized_nm_out):
        case Ok(fingerprint): fingerprint
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)

    val section_flag = if section_reader.lower().contains("readelf"): "-S" else: "-h"
    val (section_out, section_err, section_code) = process_run(section_reader, [section_flag, localized_object])
    if section_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 localized compiler backfill section scan failed: " + section_err.trim())
    if section_err.trim() != "" or section_out.trim() == "":
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 localized compiler backfill section scan was not clean")
    val forbidden_sections = stage4_forbidden_archive_sections(section_out)
    if forbidden_sections.len() != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill retained constructor/destructor sections: " + forbidden_sections.join(", "))

    val (_, archive_err, archive_code) = process_run(archiver, ["rcsD", capsule_path, localized_object])
    if archive_code != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill archive creation failed: " + archive_err.trim())
    val (members_out, members_err, members_code) = process_run(archiver, ["t", capsule_path])
    val members = members_out.replace("\r", "").trim()
    if members_code != 0 or members != "compiler_backfill_local.o":
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill archive must contain exactly 'compiler_backfill_local.o': " + members_err.trim())

    val scans = match llvm_stage4_candidate_archive_inventory(["compiler_backfill"], [capsule_path]):
        case Ok(outputs): outputs
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
    val final_extra = match stage4_compiler_backfill_localization_symbols(scans[0], object_format, manifest):
        case Ok(symbols): symbols
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
    if final_extra.len() != 0:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill archive retained unexpected global definitions: " + final_extra.join(", "))
    match stage4_validate_compiler_backfill_symbol_envelope(scans[0], object_format):
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
        case Ok(()): ()
    val final_symbol_fingerprint = match stage4_compiler_backfill_symbol_table_fingerprint(scans[0]):
        case Ok(fingerprint): fingerprint
        case Err(err): return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, err)
    if final_symbol_fingerprint != localized_symbol_fingerprint:
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill archive changed the localized symbol table")
    if not llvm_stage4_cleanup_compiler_backfill_capsule(stage_dir, capsule_path, false):
        return llvm_stage4_compiler_backfill_failure(stage_dir, capsule_path, "Stage4 compiler backfill temporary cleanup failed")
    Ok(capsule_path)

fn llvm_stage4_build_single_object_provider_archive(runtime_objects: [text], object_stem: text, provider: text, archive_file: text, object_ext: text, windows_paths: bool, pid: i64) -> Result<text, text>:
    var provider_objects: [text] = []
    for object in runtime_objects:
        if stage4_runtime_provider_object_matches(object, object_stem, object_ext, windows_paths):
            provider_objects = provider_objects.push(object)
    if provider_objects.len() != 1:
        return Err("Stage4 " + provider + " provider requires exactly one fresh " + object_stem + object_ext + " object")
    val archiver = find_archive_portable()
    if archiver == "":
        return Err("Stage4 " + provider + " provider requires llvm-ar or ar")

    val stage_dir = "{_get_temp_dir()}/simple_stage4_{provider}_{pid}"
    dir_remove_all(stage_dir)
    if not dir_create_all(stage_dir):
        return Err("Stage4 " + provider + " provider staging directory creation failed")
    val expected_member = object_stem + object_ext
    val staged_object = stage_dir + "/" + expected_member
    if not file_copy(provider_objects[0], staged_object):
        dir_remove_all(stage_dir)
        return Err("Stage4 " + provider + " provider canonical object staging failed")

    val archive_path = _get_temp_dir() + "/simple_stage4_{pid}_" + archive_file
    if file_exists(archive_path):
        file_delete(archive_path)
    val (_, archive_err, archive_code) = process_run(archiver, ["rcsD", archive_path, staged_object])
    if archive_code != 0:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 " + provider + " provider archive creation failed: " + archive_err.trim())

    val (members_out, members_err, members_code) = process_run(archiver, ["t", archive_path])
    val members = members_out.replace("\r", "").trim()
    if members_code != 0 or members != expected_member:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 " + provider + " provider archive must contain exactly '" + expected_member + "': " + members_err.trim())
    if not dir_remove_all(stage_dir):
        file_delete(archive_path)
        return Err("Stage4 " + provider + " provider staging cleanup failed")

    Ok(archive_path)

fn llvm_stage4_build_runtime_native_archive(runtime_objects: [text], target_os_name: text, msvc_objects: bool, msvc_linker: bool, pid: i64) -> Result<text, text>:
    """Localize legacy dynload exports and stage the runtime-native core owner."""
    val object_ext = if msvc_objects: ".obj" else: ".o"
    val windows_paths = target_os_name == "windows"
    val archive_file = match stage4_runtime_native_archive_file(target_os_name, msvc_linker):
        case Ok(name): name
        case Err(err): return Err(err)
    val object_format = match stage4_runtime_native_object_format(target_os_name, msvc_objects):
        case Ok(format): format
        case Err(err): return Err(err)
    var matches: [text] = []
    for object in runtime_objects:
        if stage4_runtime_provider_object_matches(object, "runtime_native", object_ext, windows_paths):
            matches = matches.push(object)
    if matches.len() != 1:
        return Err("Stage4 runtime-native core requires exactly one fresh runtime_native" + object_ext + " object")

    val archiver = find_archive_portable()
    val objcopy = find_objcopy_portable()
    val nm = find_nm_portable()
    if archiver == "" or objcopy == "" or nm == "":
        return Err("Stage4 runtime-native core requires archive, objcopy, and nm tools")
    val stage_dir = "{_get_temp_dir()}/simple_stage4_runtime_native_{pid}"
    if dir_exists(stage_dir):
        if not dir_remove_all(stage_dir):
            return Err("Stage4 runtime-native stale staging cleanup failed")
    if not dir_create_all(stage_dir):
        return Err("Stage4 runtime-native staging directory creation failed")
    val raw_object = stage_dir + "/runtime_native_raw" + object_ext
    val localized_object = stage_dir + "/runtime_native" + object_ext
    val localize_path = stage_dir + "/runtime_native_localize.syms"
    if not file_copy(matches[0], raw_object):
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime-native canonical object staging failed")
    val (raw_nm_out, raw_nm_err, raw_nm_code) = process_run(nm, ["-g", "-p", raw_object])
    if raw_nm_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime-native source scan failed: " + raw_nm_err.trim())
    val localize_symbols = match stage4_runtime_native_localization_symbols(raw_nm_out, object_format):
        case Ok(symbols): symbols
        case Err(err):
            dir_remove_all(stage_dir)
            return Err(err)
    if not file_write(localize_path, localize_symbols.join("\n") + "\n"):
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime-native localization-list write failed")
    val (_, objcopy_err, objcopy_code) = process_run(objcopy, ["--localize-symbols=" + localize_path, raw_object, localized_object])
    if objcopy_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime-native localization failed: " + objcopy_err.trim())
    val (localized_nm_out, localized_nm_err, localized_nm_code) = process_run(nm, ["-g", "-p", localized_object])
    if localized_nm_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime-native localized scan failed: " + localized_nm_err.trim())
    match stage4_validate_runtime_native_core_symbol_contract(localized_nm_out, object_format):
        case Ok(()): ()
        case Err(err):
            dir_remove_all(stage_dir)
            return Err(err)

    val archive_path = _get_temp_dir() + "/simple_stage4_{pid}_" + archive_file
    if file_exists(archive_path):
        if not file_delete(archive_path):
            dir_remove_all(stage_dir)
            return Err("Stage4 runtime-native stale archive cleanup failed")
    val (_, archive_err, archive_code) = process_run(archiver, ["rcsD", archive_path, localized_object])
    if archive_code != 0:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 runtime-native archive creation failed: " + archive_err.trim())
    val (members_out, members_err, members_code) = process_run(archiver, ["t", archive_path])
    val members = members_out.replace("\r", "").trim()
    if members_code != 0 or members != "runtime_native" + object_ext:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 runtime-native archive must contain exactly 'runtime_native" + object_ext + "': " + members_err.trim())
    if not dir_remove_all(stage_dir):
        file_delete(archive_path)
        return Err("Stage4 runtime-native staging cleanup failed")
    val scans = match llvm_stage4_candidate_archive_inventory(["runtime_native"], [archive_path]):
        case Ok(outputs): outputs
        case Err(err):
            file_delete(archive_path)
            return Err(err)
    if scans.len() != 1 or scans[0].trim() == "":
        file_delete(archive_path)
        return Err("Stage4 runtime-native archive inventory is empty")
    Ok(archive_path)

fn llvm_stage4_build_runtime_legacy_compat_archive(runtime_objects: [text], target_os_name: text, msvc_objects: bool, msvc_linker: bool, pid: i64) -> Result<text, text>:
    """Localize the broad legacy object to the exact 18-symbol compatibility ABI."""
    val object_ext = if msvc_objects: ".obj" else: ".o"
    val windows_paths = target_os_name == "windows"
    val archive_file = match stage4_runtime_legacy_compat_archive_file(target_os_name, msvc_linker):
        case Ok(name): name
        case Err(err): return Err(err)
    val object_format = match stage4_runtime_legacy_compat_object_format(target_os_name, msvc_objects):
        case Ok(format): format
        case Err(err): return Err(err)
    var matches: [text] = []
    for object in runtime_objects:
        if stage4_runtime_provider_object_matches(object, "runtime_legacy_core", object_ext, windows_paths):
            matches = matches.push(object)
    if matches.len() != 1:
        return Err("Stage4 runtime legacy compatibility requires exactly one fresh runtime_legacy_core" + object_ext + " object")

    val archiver = find_archive_portable()
    val objcopy = find_objcopy_portable()
    val nm = find_nm_portable()
    if archiver == "" or objcopy == "" or nm == "":
        return Err("Stage4 runtime legacy compatibility requires archive, objcopy, and nm tools")
    val stage_dir = "{_get_temp_dir()}/simple_stage4_runtime_legacy_compat_{pid}"
    if dir_exists(stage_dir):
        if not dir_remove_all(stage_dir):
            return Err("Stage4 runtime legacy compatibility stale staging cleanup failed")
    if not dir_create_all(stage_dir):
        return Err("Stage4 runtime legacy compatibility staging directory creation failed")
    val raw_object = stage_dir + "/runtime_legacy_core_raw" + object_ext
    val localized_object = stage_dir + "/runtime_legacy_compat" + object_ext
    val localize_path = stage_dir + "/runtime_legacy_compat_localize.syms"
    if not file_copy(matches[0], raw_object):
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime legacy compatibility canonical object staging failed")
    val (raw_nm_out, raw_nm_err, raw_nm_code) = process_run(nm, ["-g", "-p", raw_object])
    if raw_nm_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime legacy compatibility source scan failed: " + raw_nm_err.trim())
    val localize_symbols = match stage4_runtime_legacy_compat_localization_symbols(raw_nm_out, object_format):
        case Ok(symbols): symbols
        case Err(err):
            dir_remove_all(stage_dir)
            return Err(err)
    if not file_write(localize_path, localize_symbols.join("\n") + "\n"):
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime legacy compatibility localization-list write failed")
    val (_, objcopy_err, objcopy_code) = process_run(objcopy, ["--localize-symbols=" + localize_path, raw_object, localized_object])
    if objcopy_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime legacy compatibility localization failed: " + objcopy_err.trim())
    val (localized_nm_out, localized_nm_err, localized_nm_code) = process_run(nm, ["-g", "-p", localized_object])
    if localized_nm_code != 0:
        dir_remove_all(stage_dir)
        return Err("Stage4 runtime legacy compatibility localized scan failed: " + localized_nm_err.trim())
    match stage4_validate_runtime_legacy_compat_symbol_contract(localized_nm_out, object_format):
        case Ok(()): ()
        case Err(err):
            dir_remove_all(stage_dir)
            return Err(err)

    val archive_path = _get_temp_dir() + "/simple_stage4_{pid}_" + archive_file
    if file_exists(archive_path):
        if not file_delete(archive_path):
            dir_remove_all(stage_dir)
            return Err("Stage4 runtime legacy compatibility stale archive cleanup failed")
    val (_, archive_err, archive_code) = process_run(archiver, ["rcsD", archive_path, localized_object])
    if archive_code != 0:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 runtime legacy compatibility archive creation failed: " + archive_err.trim())
    val (members_out, members_err, members_code) = process_run(archiver, ["t", archive_path])
    val members = members_out.replace("\r", "").trim()
    if members_code != 0 or members != "runtime_legacy_compat" + object_ext:
        dir_remove_all(stage_dir)
        file_delete(archive_path)
        return Err("Stage4 runtime legacy compatibility archive must contain exactly 'runtime_legacy_compat" + object_ext + "': " + members_err.trim())
    if not dir_remove_all(stage_dir):
        file_delete(archive_path)
        return Err("Stage4 runtime legacy compatibility staging cleanup failed")
    val scans = match llvm_stage4_candidate_archive_inventory(["runtime_legacy_compat"], [archive_path]):
        case Ok(outputs): outputs
        case Err(err):
            file_delete(archive_path)
            return Err(err)
    if scans.len() != 1 or scans[0].trim() == "":
        file_delete(archive_path)
        return Err("Stage4 runtime legacy compatibility archive inventory is empty")
    match stage4_validate_runtime_legacy_compat_symbol_contract(scans[0], object_format):
        case Ok(()): Ok(archive_path)
        case Err(err):
            file_delete(archive_path)
            Err(err)

