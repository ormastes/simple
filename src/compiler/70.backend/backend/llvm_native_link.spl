# LLVM Native Link Orchestrator
#
# Orchestrates the full native executable linking pipeline for LLVM backend:
# 1. Compile C runtime sources to .o files
# 2. Generate entry point LLVM IR and compile to .o
# 3. Combine user objects + runtime objects + entry point
# 4. Link everything into a native executable
#
# Usage:
#   val result = link_llvm_native(user_objects, output, config, verbose)

use app.io.mod (shell, file_write, file_delete, file_exists, getpid)
use compiler.backend.backend.entry_point.{generate_entry_point_ir}
use compiler.backend.backend.llvm_target.{LlvmTargetConfig}
use compiler.backend.backend.llvm_backend_tools.{compile_ir_to_object, llc_available}
use compiler.backend.backend.backend_types.{CodegenTarget, OptimizationLevel}
use compiler.backend.backend.runtime_compiler.{compile_runtime_objects, cleanup_runtime_objects, find_c_compiler, _get_temp_dir, _obj_ext, _is_windows, _is_msvc_cc}
use compiler.backend.linker.linker_wrapper.{link_to_native, NativeLinkConfig}

extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# ============================================================================
# Configuration
# ============================================================================

struct NativeLinkOptions:
    """Options for LLVM native linking."""
    debug: bool
    verbose: bool
    pie: bool
    bare_metal: bool

impl NativeLinkOptions:
    static fn default() -> NativeLinkOptions:
        NativeLinkOptions(
            debug: false,
            verbose: false,
            pie: true,
            bare_metal: false
        )

# ============================================================================
# C-Based Entry Point Compiler (no llc needed)
# ============================================================================

fn compile_entry_point_c(pid: i64, verbose: bool) -> Result<text, text>:
    """Compile entry point as C source (no llc needed)."""
    val cc = find_c_compiler()
    if cc == "":
        return Err("No C compiler found")
    val tmp_dir = _get_temp_dir()
    val ext = _obj_ext()
    val entry_c = "{tmp_dir}/simple_entry_{pid}.c"
    val entry_o = "{tmp_dir}/simple_entry_{pid}{ext}"
    val c_source = "extern void spl_init_args(int argc, char** argv);\n" +
        "extern void __simple_runtime_init(void);\n" +
        "extern long long __simple_main(void);\n" +
        "extern void __simple_runtime_shutdown(void);\n" +
        "int main(int argc, char** argv) {\n" +
        "    spl_init_args(argc, argv);\n" +
        "    __simple_runtime_init();\n" +
        "    long long result = __simple_main();\n" +
        "    __simple_runtime_shutdown();\n" +
        "    return (int)result;\n" +
        "}\n"
    rt_file_write_text(entry_c, c_source)

    val use_msvc = _is_msvc_cc(cc)
    var comp_args: [text] = []
    if use_msvc:
        comp_args = ["/c", "/O2", "/Gy", "/Fo{entry_o}", entry_c]
    else:
        comp_args = ["-c"]
        if not _is_windows():
            comp_args.push("-fPIC")
        comp_args.push("-O2")
        comp_args.push("-ffunction-sections")
        comp_args.push("-fdata-sections")
        comp_args.push("-o")
        comp_args.push(entry_o)
        comp_args.push(entry_c)

    val (ep_out, ep_err, ep_code) = rt_process_run(cc, comp_args)
    rt_file_delete(entry_c)
    if ep_code != 0:
        return Err("Entry point compilation failed: {ep_out}{ep_err}")
    Ok(entry_o)

# ============================================================================
# Main Orchestrator
# ============================================================================

fn link_llvm_native(user_objects: [text], output: text, options: NativeLinkOptions) -> Result<text, text>:
    """Link LLVM-compiled user objects with C runtime into a native executable.

    Pipeline:
    1. Compile C runtime (runtime.c, runtime_native.c, etc.) to .o files
    2. Generate and compile entry point IR to .o (via llc, or C fallback)
    3. Combine all objects and link with system linker

    Returns Ok(output_path) on success, Err(message) on failure.
    """
    print "[LLVM-LINK] enter link_llvm_native"
    val verbose = options.verbose
    print "[LLVM-LINK] verbose={verbose}"
    val pid = getpid()
    print "[LLVM-LINK] pid={pid}"

    # Step 1: Compile C runtime to object files
    print "[LLVM-LINK] step 1: compile_runtime_objects..."
    val rt_result = compile_runtime_objects(verbose, false)
    print "[LLVM-LINK] compile_runtime_objects returned"
    val runtime_objects = match rt_result:
        case Ok(paths):
            paths
        case Err(err):
            return Err("Runtime compilation failed: {err}")
    print "[LLVM-LINK] got {runtime_objects.len()} runtime objects"

    # Step 2: Generate and compile entry point
    print "[LLVM-LINK] step 2: compile entry point..."
    val c_result = compile_entry_point_c(pid, verbose)
    print "[LLVM-LINK] entry point compiled"
    val entry_obj_path = match c_result:
        case Ok(path):
            path
        case Err(err):
            cleanup_runtime_objects(runtime_objects)
            return Err("Entry point compilation failed: {err}")

    # Step 3: Combine all objects and link
    print "[LLVM-LINK] step 3: combining objects..."
    var all_objects: [text] = []
    for obj in user_objects:
        all_objects.push(obj)
    for obj in runtime_objects:
        all_objects.push(obj)
    all_objects.push(entry_obj_path)
    print "[LLVM-LINK] total objects: {all_objects.len()}"

    print "[LLVM-LINK] creating NativeLinkConfig..."
    var link_config = NativeLinkConfig(
        libraries: [],
        library_paths: [],
        runtime_path: "none",
        pie: options.pie,
        debug: options.debug,
        verbose: options.verbose,
        extra_flags: []
    )
    print "[LLVM-LINK] calling link_to_native..."

    val link_result = link_to_native(all_objects, output, link_config)
    print "[LLVM-LINK] link_to_native returned"

    # Cleanup temp files
    cleanup_runtime_objects(runtime_objects)
    rt_file_delete(entry_obj_path)

    match link_result:
        case Ok(path):
            if verbose:
                print "[llvm-link] Native executable: {path}"
            Ok(path)
        case Err(e):
            Err("Linking failed: {e}")

