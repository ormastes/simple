# Cranelift Runtime Import Calls
#
# Shared helpers for declaring and calling imported i64-handle runtime symbols.

use std.sffi.codegen.*

val CL_TYPE_I64_FOR_RUNTIME_IMPORT: i64 = 4
val CL_TYPE_F64_FOR_RUNTIME_IMPORT: i64 = 6
val CL_CC_PLATFORM_FOR_RUNTIME_IMPORT: i64 = -1
val CL_LINKAGE_IMPORT_FOR_RUNTIME_IMPORT: i64 = 1

fn translate_runtime_import_call_i64(ctx: i64, cl_module: i64, name: text, args: [i64]) -> i64:
    val sig = cranelift_new_signature(CL_CC_PLATFORM_FOR_RUNTIME_IMPORT)
    for _arg in args:
        cranelift_sig_add_param(sig, CL_TYPE_I64_FOR_RUNTIME_IMPORT)
    cranelift_sig_set_return(sig, CL_TYPE_I64_FOR_RUNTIME_IMPORT)
    val handle = cranelift_declare_function(cl_module, name, sig, CL_LINKAGE_IMPORT_FOR_RUNTIME_IMPORT)
    val func_ref = cranelift_import_function(ctx, handle)
    return cranelift_call(ctx, func_ref, args)

fn translate_runtime_import_call_void(ctx: i64, cl_module: i64, name: text, args: [i64]):
    val sig = cranelift_new_signature(CL_CC_PLATFORM_FOR_RUNTIME_IMPORT)
    for _arg in args:
        cranelift_sig_add_param(sig, CL_TYPE_I64_FOR_RUNTIME_IMPORT)
    val handle = cranelift_declare_function(cl_module, name, sig, CL_LINKAGE_IMPORT_FOR_RUNTIME_IMPORT)
    val func_ref = cranelift_import_function(ctx, handle)
    cranelift_call(ctx, func_ref, args)

fn translate_runtime_import_call_f64_i64(ctx: i64, cl_module: i64, name: text, arg: i64) -> i64:
    val sig = cranelift_new_signature(CL_CC_PLATFORM_FOR_RUNTIME_IMPORT)
    cranelift_sig_add_param(sig, CL_TYPE_F64_FOR_RUNTIME_IMPORT)
    cranelift_sig_set_return(sig, CL_TYPE_I64_FOR_RUNTIME_IMPORT)
    val handle = cranelift_declare_function(cl_module, name, sig, CL_LINKAGE_IMPORT_FOR_RUNTIME_IMPORT)
    val func_ref = cranelift_import_function(ctx, handle)
    return cranelift_call(ctx, func_ref, [arg])

fn translate_runtime_import_call_i64_f64(ctx: i64, cl_module: i64, name: text, arg: i64) -> i64:
    val sig = cranelift_new_signature(CL_CC_PLATFORM_FOR_RUNTIME_IMPORT)
    cranelift_sig_add_param(sig, CL_TYPE_I64_FOR_RUNTIME_IMPORT)
    cranelift_sig_set_return(sig, CL_TYPE_F64_FOR_RUNTIME_IMPORT)
    val handle = cranelift_declare_function(cl_module, name, sig, CL_LINKAGE_IMPORT_FOR_RUNTIME_IMPORT)
    val func_ref = cranelift_import_function(ctx, handle)
    return cranelift_call(ctx, func_ref, [arg])
