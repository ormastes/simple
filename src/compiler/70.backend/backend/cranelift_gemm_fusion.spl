# Cranelift GEMM-add Fusion Detection
#
# Pure MIR pattern recognition for the bounded FR-PLUG-0004 fusion:
#   tmp = A @ B
#   out = tmp broadcast_add C

use compiler.mir.mir_data.{MirFunction}
use compiler.mir.mir_instructions.{MirInst, MirInstKind, MirOperand, MirOperandKind, MirTerminator}
use compiler.mir.mir_types.{LocalId}

extern fn rt_enum_discriminant(value: Any) -> i64
extern fn rt_enum_payload(value: Any) -> i64
extern fn rt_tuple_get(tuple: i64, index: i64) -> i64

struct GemmAddFusion:
    dest: LocalId
    matmul_left: MirOperand
    matmul_right: MirOperand
    addend: MirOperand

fn operand_copy_local_id(operand: MirOperand) -> i64:
    val kind = operand.kind
    val placeholder = LocalId(id: -1)
    val disc = rt_enum_discriminant(kind)
    val copy_disc = rt_enum_discriminant(MirOperandKind.Copy(placeholder))
    val move_disc = rt_enum_discriminant(MirOperandKind.Move(placeholder))
    if disc != copy_disc and disc != move_disc:
        return -1
    val payload = rt_enum_payload(kind)
    if payload <= 3:
        return -1
    val local: LocalId = payload
    local.id

fn operand_uses_local(operand: MirOperand, local_id: i64) -> bool:
    operand_copy_local_id(operand) == local_id

fn local_is_temp(func: MirFunction, local_id: i64) -> bool:
    for local in func.locals:
        if local.id.id == local_id:
            match local.kind:
                case Temp: return true
                case _: return false
    false

fn instruction_operand_use_count(inst: MirInst, local_id: i64) -> i64:
    match inst.kind:
        case Copy(_, src) | Move(_, src):
            if src.id == local_id: 1 else: 0
        case BinOp(_, _, left, right) | CheckedBinOp(_, _, left, right):
            var count = 0
            if operand_uses_local(left, local_id): count = count + 1
            if operand_uses_local(right, local_id): count = count + 1
            count
        case UnaryOp(_, _, operand) | Load(_, operand) | Cast(_, operand, _) | Bitcast(_, operand, _):
            if operand_uses_local(operand, local_id): 1 else: 0
        case Store(ptr, value):
            var count = 0
            if operand_uses_local(ptr, local_id): count = count + 1
            if operand_uses_local(value, local_id): count = count + 1
            count
        case GetElementPtr(_, base, indices):
            var count = if operand_uses_local(base, local_id): 1 else: 0
            for idx in indices:
                if operand_uses_local(idx, local_id):
                    count = count + 1
            count
        case Aggregate(_, _, operands) | Intrinsic(_, _, operands):
            var count = 0
            for operand in operands:
                if operand_uses_local(operand, local_id):
                    count = count + 1
            count
        case GetField(_, base, _):
            if operand_uses_local(base, local_id): 1 else: 0
        case SetField(base, _, value):
            var count = 0
            if operand_uses_local(base, local_id): count = count + 1
            if operand_uses_local(value, local_id): count = count + 1
            count
        case Call(_, func_op, args):
            var count = if operand_uses_local(func_op, local_id): 1 else: 0
            for arg in args:
                if operand_uses_local(arg, local_id):
                    count = count + 1
            count
        case CallIndirect(_, ptr, args, _):
            var count = if operand_uses_local(ptr, local_id): 1 else: 0
            for arg in args:
                if operand_uses_local(arg, local_id):
                    count = count + 1
            count
        case _:
            0

fn terminator_operand_use_count(term: MirTerminator, local_id: i64) -> i64:
    match term:
        case Ret(value):
            if value.? and operand_uses_local(value.unwrap(), local_id): 1 else: 0
        case If(cond, _, _) | Switch(cond, _, _):
            if operand_uses_local(cond, local_id): 1 else: 0
        case CallTerminator(_, func_op, args, _, _):
            var count = if operand_uses_local(func_op, local_id): 1 else: 0
            for arg in args:
                if operand_uses_local(arg, local_id):
                    count = count + 1
            count
        case _:
            0

fn local_use_count_in_function(func: MirFunction, local_id: i64) -> i64:
    var count = 0
    for block in func.blocks:
        for inst in block.instructions:
            count = count + instruction_operand_use_count(inst, local_id)
        count = count + terminator_operand_use_count(block.terminator, local_id)
    count

fn detect_gemm_add_pair(func: MirFunction, matmul_inst: MirInst, add_inst: MirInst) -> GemmAddFusion?:
    val matmul_kind = matmul_inst.kind
    val add_kind = add_inst.kind
    # Stage2 native mode can misbind multi-field enum source patterns from the
    # enum header. Decode BinOp payloads explicitly, as the codegen path does.
    if rt_enum_discriminant(matmul_kind) != 0x3d5f86a0 or rt_enum_discriminant(add_kind) != 0x3d5f86a0:
        return nil
    val matmul_payload = rt_enum_payload(matmul_kind)
    val add_payload = rt_enum_payload(add_kind)
    if matmul_payload <= 3 or add_payload <= 3:
        return nil
    val matmul_dest: LocalId = rt_tuple_get(matmul_payload, 0)
    val matmul_op: MirBinOp = rt_tuple_get(matmul_payload, 1)
    val matmul_left: MirOperand = rt_tuple_get(matmul_payload, 2)
    val matmul_right: MirOperand = rt_tuple_get(matmul_payload, 3)
    val add_dest: LocalId = rt_tuple_get(add_payload, 0)
    val add_op: MirBinOp = rt_tuple_get(add_payload, 1)
    val add_left: MirOperand = rt_tuple_get(add_payload, 2)
    val add_right: MirOperand = rt_tuple_get(add_payload, 3)
    if rt_enum_discriminant(matmul_op) != rt_enum_discriminant(MirBinOp.MatMul):
        return nil
    if rt_enum_discriminant(add_op) != rt_enum_discriminant(MirBinOp.BroadcastAdd):
        return nil
    if not local_is_temp(func, matmul_dest.id):
        return nil
    if local_use_count_in_function(func, matmul_dest.id) != 1:
        return nil
    if operand_uses_local(add_left, matmul_dest.id):
        return Some(GemmAddFusion(dest: add_dest, matmul_left: matmul_left, matmul_right: matmul_right, addend: add_right))
    if operand_uses_local(add_right, matmul_dest.id):
        return Some(GemmAddFusion(dest: add_dest, matmul_left: matmul_left, matmul_right: matmul_right, addend: add_left))
    nil
