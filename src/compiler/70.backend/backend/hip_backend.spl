# HIP Backend Contract
#
# First-class compiler-side HIP target contract. Generic MIR-to-HIP lowering is
# a later compiler slice; generated Engine2D HIP kernels share the portable
# CUDA/HIP/OpenCL source generator so the public backend surface is honest.

use compiler.mir.mir_data.{MirModule}
use compiler.mir.mir_instructions.{MirFunction}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, CompileError, compileerror_backend_error}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.gpu_backend_metadata.{GpuBackendKernelPlan, gpu_backend_accepts_kernel, gpu_backend_plan_module_kernels, gpu_backend_supports_target}
use compiler.backend.gpu_generated_2d_contract.{GpuGenerated2DBackendCompileContract, hip_generated_2d_compile_contract}
use compiler.backend.gpu_portable_compute.{
    PortableComputeCompilePlan,
    PortableComputeCompiledArtifactEvidence
}

class HipBackendCompileContract:
    source: text
    plan: PortableComputeCompilePlan
    evidence: PortableComputeCompiledArtifactEvidence
    ready: bool
    status: text
    diagnostic: text

    static fn create(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> HipBackendCompileContract:
        val contract = hip_generated_2d_compile_contract(output_stem, artifact_magic, exported_symbols, byte_count)
        HipBackendCompileContract.from_shared(contract)

    static fn from_shared(contract: GpuGenerated2DBackendCompileContract) -> HipBackendCompileContract:
        HipBackendCompileContract(
            source: contract.source,
            plan: contract.plan,
            evidence: contract.evidence,
            ready: contract.ready,
            status: contract.status,
            diagnostic: contract.diagnostic
        )

    fn summary() -> text:
        "HipBackendCompileContract[source={self.plan.source_format} binary={self.plan.binary_format} entry={self.plan.entry_name} ready={self.ready.to_text()} status={self.status}]"

class HipBackend:
    options: CompileOptions

    static fn create(options: CompileOptions) -> HipBackend:
        HipBackend(options: options)

    static fn generated_2d_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> HipBackendCompileContract:
        HipBackendCompileContract.create(output_stem, artifact_magic, exported_symbols, byte_count)

    static fn accepts_gpu_kernel(func: MirFunction) -> bool:
        gpu_backend_accepts_kernel(BackendKind.Hip, func)

    static fn plan_module_kernels(module: MirModule) -> GpuBackendKernelPlan:
        gpu_backend_plan_module_kernels(BackendKind.Hip, module)

impl Codegen for HipBackend:
    fn backend_kind() -> BackendKind:
        BackendKind.Hip

    fn backend_name() -> text:
        "hip"

    fn supports_target(target: CodegenTarget) -> bool:
        gpu_backend_supports_target(BackendKind.Hip, target)

    fn output_kind() -> CodegenOutputKind:
        CodegenOutputKind.GpuCode

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        Err(compileerror_backend_error(
            BackendKind.Hip,
            "HIP MIR lowering is not implemented yet; use generated portable compute HIP/HSACO contracts for Engine2D offload"
        ))

fn hip_backend_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> HipBackendCompileContract:
    HipBackend.generated_2d_contract(output_stem, artifact_magic, exported_symbols, byte_count)
