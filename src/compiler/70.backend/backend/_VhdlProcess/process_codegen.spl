# VHDL process/control-block instruction codegen (impl VhdlBackend extension)
use compiler.backend.backend.vhdl_process.*
# VHDL Backend - Process and Instruction Codegen (impl VhdlBackend extension)

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, MirTerminator, VhdlProcessKind}
use compiler.backend.backend_api.*
use compiler.backend.vhdl.vhdl_builder.{VhdlBuilder}
use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{VhdlResetPolarity, VhdlResetSynchrony}
use compiler.backend.backend.vhdl_backend.{VhdlBackend, VhdlReturnAbi}
use compiler.backend.vhdl.vhdl_helpers.{vhdl_sanitize_identifier, vhdl_helper_is_procedure}

impl VhdlBackend:
    fn block_chain_has_instructions(id: BlockId, seen: [i64]) -> bool:
        for prior in seen:
            if prior == id.id:
                return false
        if not self.active_blocks.has(id.id):
            return false
        val current = self.active_blocks[id.id]
        if current.instructions.len() > 0:
            return true
        var next_seen = seen
        next_seen = next_seen.push(id.id)
        match current.terminator:
            case Goto(target):
                self.block_chain_has_instructions(target, next_seen)
            case If(_, then_, else_):
                self.block_chain_has_instructions(then_, next_seen) or self.block_chain_has_instructions(else_, next_seen)
            case _:
                false

    fn process_local_name(local: LocalId) -> Result<text, CompileError>:
        # Clocked entities declare Var/Temp locals as process variables;
        # combinational control processes retain architecture-level signals.
        # Both use the same resolved local name.
        self.local_to_vhdl(local)

    fn process_operand_to_vhdl(operand: MirOperand) -> Result<text, CompileError>:
        match operand.kind:
            case Copy(local) | Move(local):
                self.local_operand_expr(local)
            case Const(value, ty):
                self.const_value_to_vhdl(value, ty)

    fn control_operand_to_vhdl(operand: MirOperand, helper: MirFunction?) -> Result<text, CompileError>:
        match helper:
            case Some(_): self.helper_operand_to_vhdl(operand)
            case None: self.process_operand_to_vhdl(operand)

    fn local_kind(local: LocalId) -> Result<LocalKind, CompileError>:
        if self.active_local_kinds.has(local.id):
            Ok(self.active_local_kinds[local.id])
        else:
            Err(self.backend_error("No active MIR local kind for local {local.id}"))

    fn emit_process_dest_assign(builder: VhdlBuilder, dest: LocalId, expr: text) -> Result<(), CompileError>:
        val kind = match self.local_kind(dest):
            case Ok(result): result
            case Err(err): return Err(err)
        match kind:
            case Return:
                if self.active_return_abi.is_tuple:
                    builder.emit_var_assign("return_value", expr)
                else:
                    builder.emit_signal_assign("result_out", expr)
            case Var | Temp:
                val dest_name = match self.process_local_name(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                if self.active_process_locals_are_variables:
                    builder.emit_var_assign(dest_name, expr)
                else:
                    builder.emit_signal_assign(dest_name, expr)
            case Arg(_):
                return Err(self.backend_error("Synthesizable VHDL process cannot assign function argument local {dest.id}"))
        Ok(())

    fn emit_local_record_field_assign(builder: VhdlBuilder, base: MirOperand, field: i64, value: MirOperand, in_helper: bool) -> Result<(), CompileError>:
        val field_name = match self.field_name_for_operand(base, field):
            case Ok(result): result
            case Err(err): return Err(err)
        val value_name = match if in_helper: self.helper_operand_to_vhdl(value) else: self.process_operand_to_vhdl(value):
            case Ok(result): result
            case Err(err): return Err(err)
        match base.kind:
            case Copy(local) | Move(local):
                val kind = match self.local_kind(local):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val base_name = match if in_helper: self.helper_operand_to_vhdl(base) else: self.process_operand_to_vhdl(base):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val target = "{base_name}.{field_name}"
                match kind:
                    case Var | Temp:
                        builder.emit_var_assign(target, value_name)
                    case Return:
                        if in_helper or self.active_process_locals_are_variables:
                            builder.emit_var_assign(target, value_name)
                        else:
                            builder.emit_signal_assign(target, value_name)
                    case Arg(_):
                        return Err(self.backend_error("Synthesizable VHDL helper/process cannot set field on argument local {local.id}"))
            case _:
                return Err(self.backend_error("Synthesizable VHDL helper/process field set requires a mutable local base"))
        Ok(())

    fn compile_function_control_process(builder: VhdlBuilder, func: MirFunction) -> Result<(), CompileError>:
        builder.emit_process_begin(Some("comb"), ["all"])
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    if self.active_inline_exprs.has(local.id.id):
                        continue
                    if self.type_has_general_memory(local.type_):
                        return Err(self.backend_error("VHDL combinational local `{self.default_local_name(local)}` must be a fixed scalar or record"))
                    val local_type = match self.mir_type_to_vhdl_at(local.type_, Some(func.span)):
                        case Ok(value): value
                        case Err(err): return Err(err)
                    builder.emit_process_var(self.default_local_name(local), local_type, nil)
                case Return:
                    if self.active_return_abi.is_tuple:
                        val local_type = match self.mir_type_to_vhdl_at(local.type_, Some(func.span)):
                            case Ok(value): value
                            case Err(err): return Err(err)
                        builder.emit_process_var("return_value", local_type, nil)
                case _: ()
        builder.emit_process_body_begin()
        match self.compile_control_block(builder, func.entry_block, []):
            case Ok(_): pass
            case Err(err): return Err(err)
        builder.emit_process_end(Some("comb"))
        Ok(())

    fn compile_metadata_clocked_function(builder: VhdlBuilder, func: MirFunction) -> Result<(), CompileError>:
        val clocked = func.vhdl_metadata.clocked
        if not clocked.is_valid:
            return Err(self.backend_error("Invalid @clocked metadata on `{func.name}`"))
        val domain = vhdl_clock_domain_from_metadata(clocked)
        val async_reset = if domain.reset_synchrony == VhdlResetSynchrony.Async: domain.reset_signal else: nil
        val label = "p_{vhdl_sanitize_identifier(domain.name)}"
        builder.emit_clocked_process_begin(Some(label), domain.clock_signal, async_reset)
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    if self.active_inline_exprs.has(local.id.id):
                        continue
                    if self.type_has_general_memory(local.type_):
                        return Err(self.backend_error("VHDL clocked local `{self.default_local_name(local)}` must be a fixed scalar or record"))
                    val local_type = match self.mir_type_to_vhdl_at(local.type_, Some(func.span)):
                        case Ok(value): value
                        case Err(err): return Err(err)
                    builder.emit_process_var(self.default_local_name(local), local_type, nil)
                case Return:
                    if self.active_return_abi.is_tuple:
                        val local_type = match self.mir_type_to_vhdl_at(local.type_, Some(func.span)):
                            case Ok(value): value
                            case Err(err): return Err(err)
                        builder.emit_process_var("return_value", local_type, nil)
                case _:
                    ()
        builder.emit_process_body_begin()
        match domain.reset_signal:
            case Some(reset_signal):
                if domain.reset_synchrony == VhdlResetSynchrony.Async:
                    builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
                    builder.emit_line("null;")
                    builder.emit_else()
            case None:
                ()
        match domain.edge:
            case Rising: builder.emit_rising_edge_check(domain.clock_signal)
            case Falling: builder.emit_falling_edge_check(domain.clock_signal)
        if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Sync:
            val reset_signal = domain.reset_signal.unwrap()
            builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
            builder.emit_line("null;")
            builder.emit_else()
        match self.compile_control_block(builder, func.entry_block, []):
            case Ok(_): pass
            case Err(err): return Err(err)
        if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Sync:
            builder.emit_if_end()
        builder.emit_if_end()
        if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Async:
            builder.emit_if_end()
        builder.emit_process_end(Some(label))
        Ok(())

    fn compile_control_block(builder: VhdlBuilder, block_id: BlockId, seen: [i64]) -> Result<(), CompileError>:
        self.compile_acyclic_control_block(builder, block_id, seen, nil)

    fn compile_helper_control_block(builder: VhdlBuilder, func: MirFunction, block_id: BlockId, seen: [i64]) -> Result<(), CompileError>:
        self.compile_acyclic_control_block(builder, block_id, seen, Some(func))

    fn compile_acyclic_control_block(builder: VhdlBuilder, block_id: BlockId, seen: [i64], helper: MirFunction?) -> Result<(), CompileError>:
        for prior in seen:
            if prior == block_id.id:
                return Err(self.backend_error("Synthesizable VHDL control flow cannot lower a cycle at BB{block_id.id}"))
        val block = match self.block_by_id(block_id):
            case Ok(result): result
            case Err(err): return Err(err)
        var next_seen = seen
        next_seen = next_seen.push(block_id.id)
        for inst in block.instructions:
            val result = match helper:
                case Some(_): self.compile_helper_instruction(builder, inst)
                case None: self.compile_process_instruction(builder, inst)
            match result:
                case Ok(_): pass
                case Err(err): return Err(err)
        if block.terminator != nil:
            match block.terminator:
                case Ret(value):
                    match helper:
                        case Some(func):
                            if vhdl_helper_is_procedure(func):
                                builder.emit_line("return;")
                            else:
                                val value_expr = match value:
                                    case Some(operand):
                                        match self.helper_operand_to_vhdl(operand):
                                            case Ok(result): result
                                            case Err(err): return Err(err)
                                    case None: "return_value"
                                builder.emit_line("return {value_expr};")
                        case None:
                            match value:
                                case Some(operand):
                                    val value_expr = match self.process_operand_to_vhdl(operand):
                                        case Ok(result): result
                                        case Err(err): return Err(err)
                                    match self.emit_return_expr(builder, value_expr):
                                        case Ok(_): pass
                                        case Err(err): return Err(err)
                                case None: ()
                    Ok(())
                case Goto(target):
                    self.compile_acyclic_control_block(builder, target, next_seen, helper)
                case If(cond, then_, else_):
                    val cond_expr = match self.control_operand_to_vhdl(cond, helper):
                        case Ok(result): result
                        case Err(err): return Err(err)
                    builder.emit_if_begin("{cond_expr} = '1'")
                    match self.compile_acyclic_control_block(builder, then_, next_seen, helper):
                        case Ok(_): pass
                        case Err(err): return Err(err)
                    builder.emit_else()
                    match self.compile_acyclic_control_block(builder, else_, next_seen, helper):
                        case Ok(_): pass
                        case Err(err): return Err(err)
                    builder.emit_if_end()
                    Ok(())
                case Switch(value, targets, default):
                    val in_process = match helper:
                        case Some(_): false
                        case None: true
                    val value_expr = match self.switch_value_expr_to_vhdl(value, in_process):
                        case Ok(result): result
                        case Err(err): return Err(err)
                    val value_type = match self.operand_type(value):
                        case Ok(result): result
                        case Err(err): return Err(err)
                    var emitted_case = false
                    for target_raw in targets:
                        val target: SwitchCase = target_raw
                        val case_literal = match self.switch_case_value_to_vhdl(target.value, value_type):
                            case Ok(result): result
                            case Err(err): return Err(err)
                        val condition = "{value_expr} = {case_literal}"
                        if emitted_case:
                            builder.emit_elsif(condition)
                        else:
                            builder.emit_if_begin(condition)
                            emitted_case = true
                        match self.compile_acyclic_control_block(builder, target.target, next_seen, helper):
                            case Ok(_): pass
                            case Err(err): return Err(err)
                    if emitted_case:
                        builder.emit_else()
                        match self.compile_acyclic_control_block(builder, default, next_seen, helper):
                            case Ok(_): pass
                            case Err(err): return Err(err)
                        builder.emit_if_end()
                    else:
                        match self.compile_acyclic_control_block(builder, default, next_seen, helper):
                            case Ok(_): pass
                            case Err(err): return Err(err)
                    Ok(())
                case Unreachable:
                    Ok(())
                case _:
                    Err(self.backend_error("Unsupported VHDL process terminator: {block.terminator}"))
        else:
            Ok(())

    fn compile_process_instruction(builder: VhdlBuilder, inst: MirInst) -> Result<(), CompileError>:
        match inst.kind:
            case Const(dest, value, ty):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val value_expr = match self.const_value_to_vhdl_at(value, ty, inst.span):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, value_expr)

            case Copy(dest, src) | Move(dest, src):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val value_expr = match self.process_operand_to_vhdl(MirOperand(kind: MirOperandKind.Copy(src))):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, value_expr)

            case Load(dest, ptr):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span))

            case Store(ptr, value):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span))

            case LoadGlobal(dest, symbol):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val static_ = match self.clocked_static(symbol):
                    case Ok(value): value
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, self.clocked_static_name(static_))

            case StoreGlobal(symbol, value):
                val static_ = match self.clocked_static(symbol):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.process_operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(self.clocked_static_name(static_), value_name)

            case BinOp(dest, op, left, right) | CheckedBinOp(dest, op, left, right):
                val left_name = match self.process_operand_to_vhdl(left):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val right_name = match self.process_operand_to_vhdl(right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val left_type = match self.operand_type(left):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val right_type = match self.operand_type(right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.binop_to_vhdl(op, left_name, left_type, right_name, right_type, right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, expr)

            case Cast(dest, operand, target) | Bitcast(dest, operand, target):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val src_name = match self.process_operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_type = match self.operand_type(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.cast_to_vhdl(src_name, src_type, target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, expr)

            case Aggregate(dest, kind, operands):
                val dest_type = match self.local_type(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val aggregate = match self.aggregate_to_vhdl_process(kind, operands, dest_type, inst.span):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, aggregate)

            case GetField(dest, base, field):
                val base_name = match self.process_operand_to_vhdl(base):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val field_name = match self.field_name_for_operand(base, field):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, "{base_name}.{field_name}")

            case SetField(base, field, value):
                self.emit_local_record_field_assign(builder, base, field, value, false)

            case VhdlResize(dest, operand, new_width, signed):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val src_name = match self.process_operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.resize_expr_to_vhdl(src_name, signed, new_width):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, expr)

            case VhdlSlice(dest, signal, hi, lo):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val src_name = match self.process_operand_to_vhdl(signal):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = "{src_name}({hi} downto {lo})"
                val dest_type = match self.local_type(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val slice_width = hi - lo + 1
                val cast = match self.cast_to_vhdl(expr, MirType.bits(slice_width), dest_type):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, cast)

            case VhdlConcat(dest, parts):
                val joined = match self.concat_parts_to_vhdl(parts):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, joined)

            case VhdlSignalAssign(target, value, delay_ns):
                if delay_ns.?:
                    return Err(self.backend_error("Synthesizable VHDL process signal assignment does not support delayed assignment"))
                val target_name = match self.process_operand_to_vhdl(target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.process_operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(target_name, value_name)

            case VhdlVarAssign(target, value):
                val target_name = match self.process_operand_to_vhdl(target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.process_operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_var_assign(target_name, value_name)

            case UnaryOp(dest, op, operand):
                val src_name = match self.process_operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.unaryop_to_vhdl(op, src_name):
                    case Ok(result): result
                    case Err(err): return Err(err)
                self.emit_process_dest_assign(builder, dest, expr)

            case Nop:
                ()

            case Call(dest, func, args):
                if self.call_is_lowered_hardware_entity(func):
                    return Ok(())
                match dest:
                    case Some(dest_id):
                        if self.active_inline_exprs.has(dest_id.id):
                            return Ok(())
                    case None: ()
                val expr = match self.helper_call_expr(func, args, true):
                    case Ok(value): value
                    case Err(err): return Err(err)
                match dest:
                    case Some(dest_id):
                        match self.emit_process_dest_assign(builder, dest_id, expr):
                            case Ok(_): pass
                            case Err(err): return Err(err)
                    case None:
                        builder.emit_line("{expr};")

            case _:
                return Err(self.unsupported_vhdl_instruction_error(inst))
        Ok(())

    fn mark_return_chain_handled(id: BlockId, handled: Dict<i64, bool>) -> Dict<i64, bool>:
        var next_handled = handled
        next_handled[id.id] = true
        if self.active_blocks.has(id.id):
            match self.active_blocks[id.id].terminator:
                case Goto(target):
                    if not next_handled.get(target.id).?:
                        next_handled = self.mark_return_chain_handled(target, next_handled)
                case _:
                    ()
        next_handled

    fn mark_process_body_chain_handled(id: BlockId, handled: Dict<i64, bool>) -> Dict<i64, bool>:
        """Mark a VhdlProcess instruction's body block, and every block
        transitively reachable from it via Goto/If/Switch, as already
        compiled -- so compile_function's top-level block loop (which walks
        every entry in func.blocks) does not also try to recompile them
        through the entity-level (non-process) instruction/terminator
        codegen. Without this, blocks owned by a wrapped combinational/
        clocked process were silently visited a second time, incorrectly,
        by the plain block loop. See
        doc/08_tracking/bug/vhdl_backend_spec_remaining_failures_2026-07-02.md.
        """
        if handled.get(id.id).?:
            return handled
        var next_handled = handled
        next_handled[id.id] = true
        if not self.active_blocks.has(id.id):
            return next_handled
        match self.active_blocks[id.id].terminator:
            case Goto(target):
                next_handled = self.mark_process_body_chain_handled(target, next_handled)
            case If(_, then_, else_):
                next_handled = self.mark_process_body_chain_handled(then_, next_handled)
                next_handled = self.mark_process_body_chain_handled(else_, next_handled)
            case Switch(_, targets, default):
                for target in targets:
                    next_handled = self.mark_process_body_chain_handled(target.target, next_handled)
                next_handled = self.mark_process_body_chain_handled(default, next_handled)
            case _:
                ()
        next_handled

    fn compile_block_instructions(builder: VhdlBuilder, block: MirBlock) -> Result<(), CompileError>:
        for inst in block.instructions:
            match self.compile_instruction(builder, inst):
                case Ok(_): pass
                case Err(err): return Err(err)
        Ok(())

    fn reset_asserted_literal(domain: VhdlClockDomain) -> text:
        match domain.reset_polarity:
            case ActiveLow:
                "'0'"
            case ActiveHigh:
                "'1'"

    fn compile_process_into(builder: VhdlBuilder, kind: VhdlProcessKind, block: MirBlock) -> Result<(), CompileError>:
        val label = builder.alloc_label()
        match kind:
            case Combinational(sensitivity):
                builder.emit_process_begin(Some(label), sensitivity)
                builder.emit_process_body_begin()
                match self.compile_control_block(builder, block.id, []):
                    case Ok(_): pass
                    case Err(err): return Err(err)
                builder.emit_process_end(Some(label))
            case Clocked(domain):
                val sensitivity_reset: text? = if domain.reset_synchrony == VhdlResetSynchrony.Async: domain.reset_signal else: nil
                builder.emit_clocked_process_begin(Some(label), domain.clock_signal, sensitivity_reset)
                builder.emit_process_body_begin()
                match domain.edge:
                    case Rising:
                        builder.emit_rising_edge_check(domain.clock_signal)
                    case Falling:
                        builder.emit_falling_edge_check(domain.clock_signal)
                match domain.reset_signal:
                    case Some(reset_signal):
                        if domain.reset_synchrony == VhdlResetSynchrony.Sync:
                            builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
                            builder.emit_comment("sync reset branch")
                            builder.emit_else()
                    case None: ()
                match self.compile_block_instructions(builder, block):
                    case Ok(_): pass
                    case Err(err): return Err(err)
                if domain.reset_signal.? and domain.reset_synchrony == VhdlResetSynchrony.Sync:
                    builder.emit_if_end()
                builder.emit_if_end()
                builder.emit_process_end(Some(label))
            case AsyncReset(domain):
                builder.emit_clocked_process_begin(Some(label), domain.clock_signal, domain.reset_signal)
                builder.emit_process_body_begin()
                match domain.reset_signal:
                    case Some(reset_signal):
                        builder.emit_if_begin("{reset_signal} = {self.reset_asserted_literal(domain)}")
                        builder.emit_comment("async reset branch")
                        builder.emit_else()
                    case None: ()
                match domain.edge:
                    case Rising:
                        builder.emit_rising_edge_check(domain.clock_signal)
                    case Falling:
                        builder.emit_falling_edge_check(domain.clock_signal)
                match self.compile_block_instructions(builder, block):
                    case Ok(_): pass
                    case Err(err): return Err(err)
                builder.emit_if_end()
                if domain.reset_signal.?:
                    builder.emit_if_end()
                builder.emit_process_end(Some(label))
        Ok(())
