# VHDL instruction/terminator codegen (impl VhdlBackend extension)
use compiler.backend.backend.vhdl_process.*
# VHDL Backend - Process and Instruction Codegen (impl VhdlBackend extension)

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, MirTerminator}
use compiler.backend.backend_api.*
use compiler.backend.vhdl.vhdl_builder.{VhdlBuilder}
use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{VhdlResetPolarity, VhdlResetSynchrony}
use compiler.backend.backend.vhdl_backend.{VhdlBackend, VhdlReturnAbi}

impl VhdlBackend:
    fn compile_instruction(builder: VhdlBuilder, inst: MirInst) -> Result<(), CompileError>:
        """Compile a single MIR instruction to VHDL."""
        match inst.kind:
            case Const(dest, value, ty):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val vhdl_value = match self.const_value_to_vhdl_at(value, ty, inst.span):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, vhdl_value)

            case Copy(dest, src) | Move(dest, src):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_name = match self.local_to_vhdl(src):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, src_name)

            case Load(dest, ptr):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span))

            case Store(ptr, value):
                return Err(self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span))

            case BinOp(dest, op, left, right) | CheckedBinOp(dest, op, left, right):
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val left_name = match self.operand_to_vhdl(left):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val right_name = match self.operand_to_vhdl(right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val left_type = match self.operand_type(left):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val right_type = match self.operand_type(right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.binop_to_vhdl(op, left_name, left_type, right_name, right_type, right):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, expr)

            case Cast(dest, operand, target) | Bitcast(dest, operand, target):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_name = match self.operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_type = match self.operand_type(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.cast_to_vhdl(src_name, src_type, target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, expr)

            case Aggregate(dest, kind, operands):
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val dest_type = match self.local_type(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val aggregate = match self.aggregate_to_vhdl(kind, operands, dest_type, inst.span):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, aggregate)

            case GetField(dest, base, field):
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val base_name = match self.operand_to_vhdl(base):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val field_name = match self.field_name_for_operand(base, field):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, "{base_name}.{field_name}")

            case SetField(base, field, value):
                val base_name = match self.operand_to_vhdl(base):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val field_name = match self.field_name_for_operand(base, field):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign("{base_name}.{field_name}", value_name)

            case UnaryOp(dest, op, operand):
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_name = match self.operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.unaryop_to_vhdl(op, src_name):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, expr)

            # VHDL-specific instructions
            case VhdlProcess(kind, body_block):
                val block = match self.block_by_id(body_block):
                    case Ok(result): result
                    case Err(err): return Err(err)
                match self.compile_process_into(builder, kind, block):
                    case Ok(_): pass
                    case Err(err): return Err(err)

            case VhdlSignalAssign(target, value, delay_ns):
                val target_name = match self.operand_to_vhdl(target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                match delay_ns:
                    case Some(delay): builder.emit_signal_assign_delay(target_name, value_name, delay)
                    case None: builder.emit_signal_assign(target_name, value_name)

            case VhdlVarAssign(target, value):
                val target_name = match self.operand_to_vhdl(target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val value_name = match self.operand_to_vhdl(value):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_var_assign(target_name, value_name)

            case VhdlPortMap(entity, instance, connections):
                builder.emit_instance_begin(instance, entity)
                builder.emit_port_map_begin()
                var idx = 0
                for conn in connections:
                    val actual = match self.operand_to_vhdl(conn.1):
                        case Ok(result): result
                        case Err(err): return Err(err)
                    val is_last = idx == connections.len() - 1
                    builder.emit_port_map_entry(conn.0, actual, is_last)
                    idx = idx + 1
                builder.emit_port_map_end()

            case VhdlResize(dest, operand, new_width, signed):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_name = match self.operand_to_vhdl(operand):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val expr = match self.resize_expr_to_vhdl(src_name, signed, new_width):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, expr)

            case VhdlSlice(dest, signal, hi, lo):
                if self.active_inline_exprs.has(dest.id):
                    return Ok(())
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val src_name = match self.operand_to_vhdl(signal):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val dest_type = match self.local_type(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val slice_width = hi - lo + 1
                val expr = "{src_name}({hi} downto {lo})"
                val cast = match self.cast_to_vhdl(expr, MirType.bits(slice_width), dest_type):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, cast)

            case VhdlConcat(dest, parts):
                val dest_name = match self.local_to_vhdl(dest):
                    case Ok(result): result
                    case Err(err): return Err(err)
                val joined = match self.concat_parts_to_vhdl(parts):
                    case Ok(result): result
                    case Err(err): return Err(err)
                builder.emit_signal_assign(dest_name, joined)

            case Nop:
                ()

            case Call(dest, func, args):
                if not self.call_is_lowered_hardware_entity(func):
                    match dest:
                        case Some(dest_id):
                            if self.active_inline_exprs.has(dest_id.id):
                                return Ok(())
                        case None: ()
                    match self.emit_entity_helper_call(builder, dest, func, args):
                        case Ok(_): pass
                        case Err(err): return Err(err)

            case _:
                return Err(self.unsupported_vhdl_instruction_error(inst))

        Ok(())

    fn compile_terminator(builder: VhdlBuilder, terminator: MirTerminator) -> Result<(), CompileError>:
        """Compile a MIR terminator that has direct combinational VHDL meaning."""
        match terminator:
            case Ret(value):
                match value:
                    case Some(operand):
                        match self.emit_return_assign(builder, operand):
                            case Ok(_): pass
                            case Err(err): return Err(err)
                    case None: ()
                Ok(())
            case Goto(target):
                val value_expr = match self.compile_return_block(builder, target):
                    case Ok(result): result
                    case Err(err): return Err(err)
                match self.emit_return_expr(builder, value_expr):
                    case Ok(_): pass
                    case Err(err): return Err(err)
                Ok(())
            case Unreachable:
                Ok(())
            case _:
                Err(self.backend_error("Unsupported VHDL terminator: {terminator}"))

    fn compile_if_return_terminator(builder: VhdlBuilder, cond: MirOperand, then_: BlockId, else_: BlockId) -> Result<(), CompileError>:
        """Compile if/else return blocks as one VHDL conditional result assignment."""
        val cond_name = match self.operand_to_vhdl(cond):
            case Ok(result): result
            case Err(err): return Err(err)
        val then_value = match self.compile_return_block(builder, then_):
            case Ok(result): result
            case Err(err): return Err(err)
        val else_value = match self.compile_return_block(builder, else_):
            case Ok(result): result
            case Err(err): return Err(err)
        if self.active_return_abi.is_tuple:
            for field in self.active_return_abi.fields:
                builder.emit_signal_assign(field.name, "{then_value}.{field.selector} when {cond_name} = '1' else {else_value}.{field.selector}")
            return Ok(())
        builder.emit_signal_assign("result_out", "{then_value} when {cond_name} = '1' else {else_value}")
        Ok(())

    me compile_switch_return_terminator(builder: VhdlBuilder, value: MirOperand, targets: [SwitchCase], default: BlockId) -> Result<(), CompileError>:
        """Compile a switch whose reachable targets resolve to return values."""
        val value_expr = match self.switch_value_expr_to_vhdl(value, false):
            case Ok(result): result
            case Err(err): return Err(err)
        val value_type = match self.operand_type(value):
            case Ok(result): result
            case Err(err): return Err(err)
        var expr = match self.compile_return_block(builder, default):
            case Ok(result): result
            case Err(err): return Err(err)
        var idx = targets.len() - 1
        while idx >= 0:
            val target: SwitchCase = targets[idx]
            val target_expr = match self.compile_return_block(builder, target.target):
                case Ok(result): result
                case Err(err): return Err(err)
            val case_literal = match self.switch_case_value_to_vhdl(target.value, value_type):
                case Ok(result): result
                case Err(err): return Err(err)
            expr = "{target_expr} when {value_expr} = {case_literal} else {expr}"
            idx = idx - 1
        if self.active_return_abi.is_tuple:
            return Err(self.backend_error("VHDL tuple return switch lowering is not implemented in the pure Simple backend"))
        builder.emit_signal_assign("result_out", expr)
        Ok(())

    me switch_case_value_to_vhdl(value: i64, ty: MirType) -> Result<text, CompileError>:
        match ty.kind:
            case Bool:
                Ok(if value == 0: "'0'" else: "'1'")
            case Enum(symbol):
                self.enum_variant_literal_for_discriminant(symbol, value)
            case _:
                self.const_value_to_vhdl(MirConstValue.Int(value), ty)

    me switch_value_expr_to_vhdl(value: MirOperand, in_process: bool) -> Result<text, CompileError>:
        val expr = match if in_process: self.process_operand_to_vhdl(value) else: self.operand_to_vhdl(value):
            case Ok(result): result
            case Err(err): return Err(err)
        val value_type = match self.operand_type(value):
            case Ok(result): result
            case Err(err): return Err(err)
        match value_type.kind:
            case Enum(symbol):
                val type_def = match self.type_def_by_symbol(symbol):
                    case Ok(result): result
                    case Err(err): return Err(err)
                match type_def.kind:
                    case Enum(variants):
                        if self.enum_has_payload(variants):
                            Ok("{expr}.tag")
                        else:
                            Ok(expr)
                    case _:
                        Err(self.backend_error("Switch target symbol {symbol.id} is not an enum type"))
            case _:
                Ok(expr)

    fn enum_variant_literal_for_discriminant(symbol: SymbolId, discriminant: i64) -> Result<text, CompileError>:
        val type_def = match self.type_def_by_symbol(symbol):
            case Ok(result): result
            case Err(err): return Err(err)
        match type_def.kind:
            case Enum(variants):
                for variant in variants:
                    if variant.discriminant == discriminant:
                        return Ok(self.sanitize_vhdl_identifier(variant.name))
                Err(self.backend_error("Enum switch discriminant {discriminant} is not a variant of `{type_def.name}`"))
            case _:
                Err(self.backend_error("Switch target symbol {symbol.id} is not an enum type"))

    fn compile_return_block(builder: VhdlBuilder, block_id: BlockId) -> Result<text, CompileError>:
        self.compile_return_block_seen(builder, block_id, [])

    fn compile_return_block_seen(builder: VhdlBuilder, block_id: BlockId, seen: [i64]) -> Result<text, CompileError>:
        for prior in seen:
            if prior == block_id.id:
                return Err(self.backend_error("VHDL backend does not support cyclic control flow"))
        val block = match self.block_by_id(block_id):
            case Ok(result): result
            case Err(err): return Err(err)
        match self.compile_block_instructions(builder, block):
            case Ok(_): pass
            case Err(err): return Err(err)
        match block.terminator:
            case Ret(value):
                match value:
                    case Some(operand): self.operand_to_vhdl(operand)
                    case None: Err(self.backend_error("VHDL if/else return block BB{block_id.id} returns no value"))
            case Goto(target):
                var next_seen = seen
                next_seen = next_seen.push(block_id.id)
                self.compile_return_block_seen(builder, target, next_seen)
            case _:
                Err(self.backend_error("VHDL if/else branch BB{block_id.id} must terminate with return"))
