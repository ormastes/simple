use std.nogc_sync_mut.io.process_ops.{process_run}
use std.nogc_sync_mut.io.env_ops.{env_get}
use std.common.types.{ExitCode}

fn backend_shell_tuple(command: text) -> (text, text, ExitCode):
    val os_env = env_get("OS")
    val is_windows = if os_env == nil:
        false
    else:
        os_env.lower().contains("windows")
    val (shell_path, shell_args) = if is_windows:
        ("cmd.exe", ["/c", command])
    else:
        ("/bin/sh", ["-c", command])
    val (out, err, code) = process_run(shell_path, shell_args)
    (out, err, ExitCode(value: code))
