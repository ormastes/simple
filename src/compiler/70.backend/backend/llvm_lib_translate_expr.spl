# LLVM Lib Translate Expr — Instruction Translation
#
# Translates individual MIR instructions and terminators to LLVM C API calls.
# Called from llvm_lib_translate.spl for each instruction in a basic block.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirInst, MirOperand, MirPlace, MirBinOp, MirUnaryOp, AggregateKind}
use compiler.mir.mir_types.{LocalId, MirConstValue, MirType, MirTypeKind}
use compiler.backend.backend.llvm_lib_type_mapper.{LlvmLibTypeMapper}
use std.sffi.llvm.*

extern fn rt_array_push_i64_raw(values: [i64], value: i64) -> i8

extern fn rt_enum_payload(value: Any) -> i64
extern fn rt_enum_discriminant(value: Any) -> i64
extern fn rt_tuple_get(tuple: i64, index: i64) -> i64
extern fn rt_text_eq_any(left: i64, right: i64) -> i64
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
extern fn rt_dict_get_i64_raw(dict: i64, key: i64) -> i64
extern fn rt_dict_set_i64_raw(dict: i64, key: i64, value: i64) -> bool

# ============================================================================
# Instruction Translation
# ============================================================================

fn translate_instruction(
    ctx: i64,
    mod_: i64,
    builder: i64,
    tm: LlvmLibTypeMapper,
    inst: MirInst,
    value_map: {i64: i64},
    local_types: {i64: i64},
    local_unsigned: {i64: bool},
    block_map: {i64: i64},
    func_map: {text: i64}
) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val inst_kind = inst.kind
    val inst_disc = rt_enum_discriminant(inst_kind)

    # Native bootstrap can treat variant names that collide with in-scope type
    # names as struct patterns. Pre-dispatch the hot affected variants by
    # their stable runtime discriminants before entering the source match.
    if inst_disc == 0x0b55abba:  # hash("Const")
        val payload = rt_enum_payload(inst_kind)
        val dest: LocalId = rt_tuple_get(payload, 0)
        return translate_const(
            ctx, mod_, builder, tm, dest.id,
            rt_tuple_get(payload, 1), rt_tuple_get(payload, 2),
            local_value_map, local_types
        )
    if inst_disc == 0x3d5f86a0:  # hash("BinOp")
        val payload = rt_enum_payload(inst_kind)
        val dest: LocalId = rt_tuple_get(payload, 0)
        return translate_binop(
            ctx, mod_, builder, tm, dest.id,
            rt_tuple_get(payload, 1), rt_tuple_get(payload, 2), rt_tuple_get(payload, 3),
            local_value_map, local_types, func_map
        )
    if inst_disc == 0x311b931f:  # hash("Call")
        val payload = rt_enum_payload(inst_kind)
        return translate_call(
            ctx, mod_, builder, tm,
            rt_tuple_get(payload, 0), rt_tuple_get(payload, 1), rt_tuple_get(payload, 2),
            local_value_map, local_types, func_map
        )

    match inst_kind:
        case Const(_, _, _):
            # Native bootstrap matches the discriminant correctly, but can bind
            # a multi-field enum arm from the enum header instead of its payload.
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            local_value_map = translate_const(
                ctx, mod_, builder, tm, dest.id,
                rt_tuple_get(payload, 1), rt_tuple_get(payload, 2),
                local_value_map, local_types
            )

        case Copy(_, _):
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            val src: LocalId = rt_tuple_get(payload, 1)
            val src_val = get_value(local_value_map, src.id)
            set_raw_handle(local_value_map, dest.id, src_val)

        case Move(_, _):
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            val src: LocalId = rt_tuple_get(payload, 1)
            val src_val = get_value(local_value_map, src.id)
            set_raw_handle(local_value_map, dest.id, src_val)

        case BinOp(_, _, _, _):
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            local_value_map = translate_binop(
                ctx, mod_, builder, tm, dest.id,
                rt_tuple_get(payload, 1), rt_tuple_get(payload, 2), rt_tuple_get(payload, 3),
                local_value_map, local_types, func_map
            )

        case UnaryOp(dest, op, operand):
            local_value_map = translate_unaryop(ctx, mod_, builder, tm, dest, op, operand, local_value_map, local_types, func_map)

        case Alloc(dest, ty):
            val llvm_ty = tm.map_type(ty)
            val alloca = llvm_build_alloca(builder, llvm_ty, "alloc")
            set_raw_handle(local_value_map, dest.id, alloca)

        case Load(dest, ptr):
            val ptr_val = translate_operand(ctx, mod_, builder, tm, ptr, local_value_map, local_types, func_map)
            val dest_ty = get_local_type(local_types, tm, dest.id)
            val load_val = llvm_build_load2(builder, dest_ty, ptr_val, "load")
            set_raw_handle(local_value_map, dest.id, load_val)

        case Store(ptr, value):
            val ptr_val = translate_operand(ctx, mod_, builder, tm, ptr, local_value_map, local_types, func_map)
            val store_val = translate_operand(ctx, mod_, builder, tm, value, local_value_map, local_types, func_map)
            llvm_build_store(builder, store_val, ptr_val)

        case GetElementPtr(dest, base, indices):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, local_value_map, local_types, func_map)
            var idx_vals: [i64] = []
            for idx in indices:
                rt_array_push_i64_raw(idx_vals, translate_operand(ctx, mod_, builder, tm, idx, local_value_map, local_types, func_map))
            val i8_ty = llvm_int8_type_in_context(ctx)
            val gep = llvm_build_gep2(builder, i8_ty, base_val, idx_vals, "gep")
            set_raw_handle(local_value_map, dest.id, gep)

        case Aggregate(dest, kind, operands):
            local_value_map = translate_aggregate(ctx, mod_, builder, tm, dest, kind, operands, local_value_map, local_types, func_map)

        case GetField(dest, base, field):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, local_value_map, local_types, func_map)
            val result = llvm_build_extract_value(builder, base_val, field, "field")
            set_raw_handle(local_value_map, dest.id, result)

        case SetField(base, field, value):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, local_value_map, local_types, func_map)
            val new_val = translate_operand(ctx, mod_, builder, tm, value, local_value_map, local_types, func_map)
            val result = llvm_build_insert_value(builder, base_val, new_val, field, "setfield")
            # SetField modifies in place — update the base local in value_map
            match base.kind:
                case Copy(local): set_raw_handle(local_value_map, local.id, result)
                case Move(local): set_raw_handle(local_value_map, local.id, result)
                case _: ()

        case Cast(dest, operand, target):
            local_value_map = translate_cast(ctx, mod_, builder, tm, dest, operand, target, local_value_map, local_types, local_unsigned, func_map)

        case Bitcast(dest, operand, target):
            val op_val = translate_operand(ctx, mod_, builder, tm, operand, local_value_map, local_types, func_map)
            val target_ty = tm.map_type(target)
            val result = llvm_build_bitcast(builder, op_val, target_ty, "bitcast")
            set_raw_handle(local_value_map, dest.id, result)

        case CheckedBinOp(_, _, _, _):
            # Treat as unchecked BinOp for bootstrap (overflow traps not needed)
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            local_value_map = translate_binop(
                ctx, mod_, builder, tm, dest.id,
                rt_tuple_get(payload, 1), rt_tuple_get(payload, 2), rt_tuple_get(payload, 3),
                local_value_map, local_types, func_map
            )

        case PipeForward(_, _, _):
            # |> operator: call func(value)
            val payload = rt_enum_payload(inst.kind)
            val dest: LocalId = rt_tuple_get(payload, 0)
            val value: MirOperand = rt_tuple_get(payload, 1)
            val func: MirOperand = rt_tuple_get(payload, 2)
            val dest_opt: LocalId? = Some(dest)
            val call_args: [MirOperand] = [value]
            local_value_map = translate_call(
                ctx, mod_, builder, tm, dest_opt as i64, func as i64, call_args as i64,
                local_value_map, local_types, func_map
            )

        case Call(_, _, _):
            val payload = rt_enum_payload(inst.kind)
            local_value_map = translate_call(
                ctx, mod_, builder, tm,
                rt_tuple_get(payload, 0), rt_tuple_get(payload, 1), rt_tuple_get(payload, 2),
                local_value_map, local_types, func_map
            )

        case CallIndirect(dest, ptr, args, sig):
            local_value_map = translate_call_indirect(ctx, mod_, builder, tm, dest, ptr, args, sig, local_value_map, local_types, func_map)

        case Intrinsic(dest, name, args):
            local_value_map = translate_intrinsic(ctx, mod_, builder, tm, dest, name, args, local_value_map, local_types, block_map, func_map)

        case Ref(dest, kind, place):
            val place_val = get_value(local_value_map, place.local.id)
            set_raw_handle(local_value_map, dest.id, place_val)

        case DebugValue(_, _): ()
        case Nop: ()

        # Pipeline operators — partially supported (PipeForward handled above)
        case Compose(dest, _, _):
            print "[llvm-lib] warning: Compose (>>) not yet supported, producing zero"
            set_raw_handle(local_value_map, dest.id, llvm_const_null(get_local_type(local_types, tm, dest.id)))
        case Parallel(dest, _, _):
            print "[llvm-lib] warning: Parallel (//) not yet supported, producing zero"
            set_raw_handle(local_value_map, dest.id, llvm_const_null(get_local_type(local_types, tm, dest.id)))
        case LayerConnect(dest, _, _):
            print "[llvm-lib] warning: LayerConnect (~>) not yet supported, producing zero"
            set_raw_handle(local_value_map, dest.id, llvm_const_null(get_local_type(local_types, tm, dest.id)))

        case InlineAsm(_, _, _, _, _):
            print "[llvm-lib] error: inline assembly not supported by llvm-lib backend"

        # Remaining: SIMD, GPU, VHDL, Async — warn instead of silent
        case _:
            print "[llvm-lib] warning: unhandled MIR instruction kind (skipped)"
    local_value_map

# ============================================================================
# Constant Translation
# ============================================================================

fn translate_const(
    ctx: i64,
    mod_: i64,
    builder: i64,
    tm: LlvmLibTypeMapper,
    dest_id: i64,
    raw_value: i64,
    raw_ty: i64,
    value_map: {i64: i64},
    local_types: {i64: i64}
) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val value: MirConstValue = raw_value
    val ty: MirType = raw_ty
    val llvm_ty = tm.map_type(ty)
    match value:
        case Int(v):
            val result = llvm_const_int(llvm_ty, v, true)
            set_raw_handle(local_value_map, dest_id, result)
        case Float(v):
            val result = llvm_const_real_of_string(llvm_ty, "{v}")
            set_raw_handle(local_value_map, dest_id, result)
        case Bool(v):
            val bval = if v: 1 else: 0
            val result = llvm_const_int(llvm_ty, bval, false)
            set_raw_handle(local_value_map, dest_id, result)
        case Str(v):
            # Create global string constant
            val str_val = llvm_const_string_in_context(ctx, v, false)
            val str_ty = llvm_array_type2(llvm_int8_type_in_context(ctx), v.len() + 1)
            val global = llvm_add_global(mod_, str_ty, ".str")
            llvm_set_initializer(global, str_val)
            llvm_set_global_constant(global, true)
            llvm_set_linkage(global, LLVM_PRIVATE_LINKAGE)
            llvm_set_unnamed_addr(global, true)
            # GEP to get ptr to first element
            val zero = llvm_const_int(llvm_int64_type_in_context(ctx), 0, false)
            val gep = llvm_build_in_bounds_gep2(builder, str_ty, global, [zero, zero], "str")
            set_raw_handle(local_value_map, dest_id, gep)
        case Zero:
            if tm.is_void_mir_type(ty):
                ()
            else:
                val result = llvm_const_null(llvm_ty)
                set_raw_handle(local_value_map, dest_id, result)
        case Array(_):
            val result = llvm_const_null(llvm_ty)
            set_raw_handle(local_value_map, dest_id, result)
        case Tuple(_):
            val result = llvm_const_null(llvm_ty)
            set_raw_handle(local_value_map, dest_id, result)
        case Struct(_):
            val result = llvm_const_null(llvm_ty)
            set_raw_handle(local_value_map, dest_id, result)
    local_value_map

# ============================================================================
# Binary Operation Translation
# ============================================================================

fn translate_binop(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                   dest_id: i64, raw_op: i64, raw_left: i64, raw_right: i64,
                   value_map: {i64: i64}, local_types: {i64: i64},
                   func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val op: MirBinOp = raw_op
    val left: MirOperand = raw_left
    val right: MirOperand = raw_right
    var lhs = translate_operand(ctx, mod_, builder, tm, left, value_map, local_types, func_map)
    var rhs = translate_operand(ctx, mod_, builder, tm, right, value_map, local_types, func_map)
    # Harmonize i1 operands (icmp results held in Bool-typed locals) with a
    # wider integer partner: LLVM rejects mixed-width binops/icmps
    # ("Both operands ... are not of the same type", e.g. add i64 x, i1 y).
    if lhs == 0 or rhs == 0:
        # A null operand segfaults inside LLVMBuild*/FoldCmp. Name the source
        # operand loudly and substitute i64 0 so the failure stays diagnosable
        # (build still fails; nothing is silently passed).
        val left_desc = match left.kind:
            case Copy(local): "Copy#" + local.id.to_text()
            case Move(local): "Move#" + local.id.to_text()
            case Const(_, _): "Const"
        val right_desc = match right.kind:
            case Copy(local): "Copy#" + local.id.to_text()
            case Move(local): "Move#" + local.id.to_text()
            case Const(_, _): "Const"
        eprint("[llvm-lib] ERROR: binop operand translated to null (lhs=" + lhs.to_text() + " " + left_desc + ", rhs=" + rhs.to_text() + " " + right_desc + ") — substituting i64 0")
        if lhs == 0:
            lhs = llvm_const_int(llvm_int64_type_in_context(ctx), 0, true)
        if rhs == 0:
            rhs = llvm_const_int(llvm_int64_type_in_context(ctx), 0, true)
    if lhs != 0 and rhs != 0:
        # (guard: LLVMTypeOf(NULL) segfaults; an unmapped operand stays 0 here
        # and is left for the IR verifier to report)
        val i1_ty_h = llvm_int1_type_in_context(ctx)
        val lhs_ty_h = llvm_type_of(lhs)
        val rhs_ty_h = llvm_type_of(rhs)
        if lhs_ty_h == i1_ty_h and rhs_ty_h != i1_ty_h and is_int_type_ref(ctx, rhs_ty_h):
            lhs = llvm_build_zext(builder, lhs, rhs_ty_h, "bzext")
        elif rhs_ty_h == i1_ty_h and lhs_ty_h != i1_ty_h and is_int_type_ref(ctx, lhs_ty_h):
            rhs = llvm_build_zext(builder, rhs, lhs_ty_h, "bzext")
    val dest_ty = get_local_type(local_types, tm, dest_id)
    val is_float = is_float_type_ref(ctx, dest_ty)
    val left_ty = get_operand_type_ref(left, local_types, tm)
    val left_is_float = is_float_type_ref(ctx, left_ty)

    val result = match op:
        case Add:
            if is_float: llvm_build_fadd(builder, lhs, rhs, "add")
            else: llvm_build_nsw_add(builder, lhs, rhs, "add")
        case Sub:
            if is_float: llvm_build_fsub(builder, lhs, rhs, "sub")
            else: llvm_build_nsw_sub(builder, lhs, rhs, "sub")
        case Mul:
            if is_float: llvm_build_fmul(builder, lhs, rhs, "mul")
            else: llvm_build_nsw_mul(builder, lhs, rhs, "mul")
        case Div:
            if is_float: llvm_build_fdiv(builder, lhs, rhs, "div")
            else: llvm_build_sdiv(builder, lhs, rhs, "div")
        case Rem:
            if is_float: llvm_build_frem(builder, lhs, rhs, "rem")
            else: llvm_build_srem(builder, lhs, rhs, "rem")
        case Pow:
            # Call __simple_pow for integer, llvm.pow for float
            if is_float:
                val pow_fn = llvm_get_named_function(mod_, "llvm.pow.f64")
                if pow_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(pow_fn), pow_fn, [lhs, rhs], "pow")
                else:
                    val rt_pow = llvm_get_named_function(mod_, "rt_pow")
                    if rt_pow != 0:
                        llvm_build_call2(builder, llvm_global_get_value_type(rt_pow), rt_pow, [lhs, rhs], "pow")
                    else:
                        print "[llvm-lib] warning: float pow (**) function not found, producing zero"
                        llvm_const_null(dest_ty)
            else:
                val pow_fn = llvm_get_named_function(mod_, "__simple_pow")
                if pow_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(pow_fn), pow_fn, [lhs, rhs], "pow")
                else:
                    print "[llvm-lib] warning: integer pow (**) function not found, producing zero"
                    llvm_const_null(dest_ty)

        case BitAnd: llvm_build_and(builder, lhs, rhs, "and")
        case BitOr: llvm_build_or(builder, lhs, rhs, "or")
        case BitXor: llvm_build_xor(builder, lhs, rhs, "xor")
        case Shl: llvm_build_shl(builder, lhs, rhs, "shl")
        case Shr: llvm_build_ashr(builder, lhs, rhs, "shr")

        case Eq:
            if left_is_float:
                val cmp = llvm_build_fcmp(builder, LLVM_REAL_OEQ, lhs, rhs, "eq")
                maybe_zext(builder, ctx, cmp, dest_ty)
            elif llvm_get_type_kind(left_ty) == 12:  # 12=Pointer (was 10=Struct — wrong kind, branch never fired)
                val cmp = llvm_build_icmp(builder, LLVM_INT_EQ, lhs, rhs, "eq")
                maybe_zext(builder, ctx, cmp, dest_ty)
            else:
                # Use rt_native_eq for proper equality of all types (int + string).
                # Native icmp only compares raw i64 values; tagged string pointers
                # with the same content but different allocations would compare as not-equal.
                val eq_fn = llvm_get_named_function(mod_, "rt_native_eq")
                if eq_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(eq_fn), eq_fn, [lhs, rhs], "eq")
                else:
                    val cmp = llvm_build_icmp(builder, LLVM_INT_EQ, lhs, rhs, "eq")
                    maybe_zext(builder, ctx, cmp, dest_ty)
        case Ne:
            if left_is_float:
                val cmp = llvm_build_fcmp(builder, LLVM_REAL_ONE, lhs, rhs, "ne")
                maybe_zext(builder, ctx, cmp, dest_ty)
            elif llvm_get_type_kind(left_ty) == 12:  # 12=Pointer (was 10=Struct — wrong kind, branch never fired)
                val cmp = llvm_build_icmp(builder, LLVM_INT_NE, lhs, rhs, "ne")
                maybe_zext(builder, ctx, cmp, dest_ty)
            else:
                val neq_fn = llvm_get_named_function(mod_, "rt_native_neq")
                if neq_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(neq_fn), neq_fn, [lhs, rhs], "ne")
                else:
                    val cmp = llvm_build_icmp(builder, LLVM_INT_NE, lhs, rhs, "ne")
                    maybe_zext(builder, ctx, cmp, dest_ty)
        case Lt:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OLT, lhs, rhs, "lt")
            else:
                llvm_build_icmp(builder, LLVM_INT_SLT, lhs, rhs, "lt")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Le:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OLE, lhs, rhs, "le")
            else:
                llvm_build_icmp(builder, LLVM_INT_SLE, lhs, rhs, "le")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Gt:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OGT, lhs, rhs, "gt")
            else:
                llvm_build_icmp(builder, LLVM_INT_SGT, lhs, rhs, "gt")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Ge:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OGE, lhs, rhs, "ge")
            else:
                llvm_build_icmp(builder, LLVM_INT_SGE, lhs, rhs, "ge")
            maybe_zext(builder, ctx, cmp, dest_ty)

        case Offset:
            val i8_ty = llvm_int8_type_in_context(ctx)
            llvm_build_gep2(builder, i8_ty, lhs, [rhs], "offset")

        case _:
            # MatMul, BroadcastOps — warn instead of silent zero
            print "[llvm-lib] warning: unhandled binary op (MatMul/Broadcast), producing zero"
            llvm_const_null(dest_ty)

    set_raw_handle(local_value_map, dest_id, result)
    local_value_map

fn maybe_zext(builder: i64, ctx: i64, cmp_val: i64, dest_ty: i64) -> i64:
    val i1_ty = llvm_int1_type_in_context(ctx)
    if dest_ty == i1_ty:
        cmp_val
    else:
        llvm_build_zext(builder, cmp_val, dest_ty, "zext")

# ============================================================================
# Unary Operation Translation
# ============================================================================

fn translate_unaryop(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                     dest: LocalId, op: MirUnaryOp, operand: MirOperand,
                     value_map: {i64: i64}, local_types: {i64: i64},
                     func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val op_val = translate_operand(ctx, mod_, builder, tm, operand, value_map, local_types, func_map)
    val dest_ty = get_local_type(local_types, tm, dest.id)
    val operand_ty = get_operand_type_ref(operand, local_types, tm)
    val is_float = is_float_type_ref(ctx, dest_ty)

    val result = match op:
        case Neg:
            if is_float: llvm_build_fneg(builder, op_val, "neg")
            else: llvm_build_neg(builder, op_val, "neg")
        case Not:
            val zero = if llvm_get_type_kind(operand_ty) == 12:  # 12=Pointer (was 14=Metadata)
                llvm_const_null(operand_ty)
            else:
                llvm_const_int(operand_ty, 0, false)
            llvm_build_icmp(builder, LLVM_INT_EQ, op_val, zero, "not")
        case BitNot:
            llvm_build_not(builder, op_val, "bitnot")
        case _:
            print "[llvm-lib] warning: unhandled unary op (Transpose), producing zero"
            llvm_const_null(dest_ty)

    set_raw_handle(local_value_map, dest.id, result)
    local_value_map

# ============================================================================
# Aggregate Translation
# ============================================================================

fn translate_aggregate(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                       dest: LocalId, kind: AggregateKind, operands: [MirOperand],
                       value_map: {i64: i64}, local_types: {i64: i64},
                       func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val dest_ty = get_local_type(local_types, tm, dest.id)
    var agg = llvm_get_undef(dest_ty)
    for i in 0..operands.len():
        val elem_val = translate_operand(ctx, mod_, builder, tm, operands[i], value_map, local_types, func_map)
        agg = llvm_build_insert_value(builder, agg, elem_val, i, "agg")
    set_raw_handle(local_value_map, dest.id, agg)
    local_value_map

# ============================================================================
# Cast Translation
# ============================================================================

fn translate_cast(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                  dest: LocalId, operand: MirOperand, target: MirType,
                  value_map: {i64: i64}, local_types: {i64: i64},
                  local_unsigned: {i64: bool},
                  func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val op_val = translate_operand(ctx, mod_, builder, tm, operand, value_map, local_types, func_map)
    val target_ty = tm.map_type(target)
    val source_unsigned = get_operand_unsigned(operand, local_unsigned)
    set_raw_handle(local_value_map, dest.id, coerce_llvm_cast_value(builder, op_val, target_ty, source_unsigned))
    local_value_map

# ============================================================================
# Call Translation
# ============================================================================

fn coerce_llvm_value(builder: i64, value: i64, target_ty: i64) -> i64:
    val source_ty = llvm_type_of(value)
    if source_ty == target_ty:
        return value

    val source_kind = llvm_get_type_kind(source_ty)
    val target_kind = llvm_get_type_kind(target_ty)
    if source_kind == 8 and target_kind == 8:
        val source_bits = llvm_get_int_type_width(source_ty)
        val target_bits = llvm_get_int_type_width(target_ty)
        if source_bits > target_bits:
            return llvm_build_trunc(builder, value, target_ty, "coerce")
        if source_bits == 1:
            return llvm_build_zext(builder, value, target_ty, "coerce")
        return llvm_build_sext(builder, value, target_ty, "coerce")
    if source_kind == 8 and (target_kind == 2 or target_kind == 3):
        return llvm_build_si_to_fp(builder, value, target_ty, "coerce")
    if (source_kind == 2 or source_kind == 3) and target_kind == 8:
        return llvm_build_fp_to_si(builder, value, target_ty, "coerce")
    if (source_kind == 2 or source_kind == 3) and (target_kind == 2 or target_kind == 3):
        if source_kind == 2 and target_kind == 3:
            return llvm_build_fpext(builder, value, target_ty, "coerce")
        if source_kind == 3 and target_kind == 2:
            return llvm_build_fptrunc(builder, value, target_ty, "coerce")
        return value
    if source_kind == 8 and target_kind == 12:
        return llvm_build_int_to_ptr(builder, value, target_ty, "coerce")
    if source_kind == 12 and target_kind == 8:
        return llvm_build_ptr_to_int(builder, value, target_ty, "coerce")
    llvm_build_bitcast(builder, value, target_ty, "coerce")

fn coerce_llvm_cast_value(builder: i64, value: i64, target_ty: i64, source_unsigned: bool) -> i64:
    val source_kind = llvm_get_type_kind(llvm_type_of(value))
    val target_kind = llvm_get_type_kind(target_ty)
    if source_unsigned and source_kind == 8 and (target_kind == 2 or target_kind == 3):
        return llvm_build_ui_to_fp(builder, value, target_ty, "coerce")
    coerce_llvm_value(builder, value, target_ty)

fn translate_call(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                  raw_dest: i64, raw_func: i64, raw_args: i64,
                  value_map: {i64: i64}, local_types: {i64: i64},
                  func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    var has_dest = false
    var dest_id = 0
    if rt_enum_discriminant(raw_dest) == 0xf1987159:  # hash("Some")
        val dest_local: LocalId = rt_enum_payload(raw_dest)
        dest_id = dest_local.id
        has_dest = true
    val func: MirOperand = raw_func
    val args: [MirOperand] = raw_args
    # Resolve function
    var func_ref = 0
    var fn_name = ""
    val func_kind = func.kind
    if rt_enum_discriminant(func_kind) == 0x0b55abba:  # hash("Const")
        val const_payload = rt_enum_payload(func_kind)
        val raw_value = rt_tuple_get(const_payload, 0)
        if rt_enum_discriminant(raw_value) == 0xd43c7eb8:  # hash("Str")
            val name: text = rt_enum_payload(raw_value)
            fn_name = if name == "main": "__simple_main" elif name == "get_args" or name == "get_cli_args" or name == "sys_get_args": "rt_get_args" elif name == "print": "rt_println" else: name
            func_ref = llvm_get_named_function(mod_, fn_name)
    else:
        match func_kind:
            case Copy(local):
                func_ref = get_value(value_map, local.id)
            case Move(local):
                func_ref = get_value(value_map, local.id)
            case _: ()

    if func_ref == 0:
        val callee_desc = if fn_name != "": "'" + fn_name + "'" else: "<indirect>"
        eprint("[llvm-lib] ERROR: unresolved function call to " + callee_desc + ", skipping instruction — generated code will be broken")
        return local_value_map
    val actual_param_count = llvm_count_params(func_ref)
    if actual_param_count != args.len():
        eprint("[llvm-lib] ERROR: call arity mismatch for '" + fn_name + "': MIR args=" + args.len().to_text() + " LLVM params=" + actual_param_count.to_text() + ", skipping instruction")
        return local_value_map

    # Build args
    var arg_vals: [i64] = []
    var arg_i = 0
    for arg in args:
        var arg_val = translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map)
        if arg_val == 0:
            # A null LLVMValueRef argument segfaults inside LLVMBuildCall2 (or
            # fails verification as "Operand is null"). Name the operand kind so
            # the producing translation path is identifiable from the log.
            val arg_desc = match arg.kind:
                case Copy(local): "Copy#" + local.id.to_text()
                case Move(local): "Move#" + local.id.to_text()
                case Const(_, _): "Const"
            eprint("[llvm-lib] ERROR: call arg translated to null (" + arg_desc + ") for callee '" + fn_name + "' — substituting i64 0 to avoid segfault")
            arg_val = llvm_const_int(llvm_int64_type_in_context(ctx), 0, true)
        if arg_i < llvm_count_params(func_ref):
            arg_val = coerce_llvm_value(builder, arg_val, llvm_type_of(llvm_get_param(func_ref, arg_i)))
        rt_array_push_i64_raw(arg_vals, arg_val)
        arg_i = arg_i + 1

    # Get function type — use LLVMGlobalGetValueType for opaque pointers (LLVM 15+)
    val fn_ty = llvm_global_get_value_type(func_ref)

    # Void-returning calls must be unnamed ("Instruction has a name, but
    # provides a void value!" fails IR verification).
    val ret_is_void = llvm_get_type_kind(llvm_get_return_type(fn_ty)) == 0
    val call_name = if has_dest and not ret_is_void: "call" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, func_ref, arg_vals, call_name)

    if has_dest:
        set_raw_handle(local_value_map, dest_id, call_val)
    local_value_map

fn translate_call_indirect(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                           dest: LocalId?, ptr: MirOperand, args: [MirOperand],
                           sig: MirSignature,
                           value_map: {i64: i64}, local_types: {i64: i64},
                           func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    val fn_ptr = translate_operand(ctx, mod_, builder, tm, ptr, value_map, local_types, func_map)
    if fn_ptr == 0:
        eprint("[llvm-lib] ERROR: indirect call target translated to null, skipping instruction — generated code will be broken")
        return local_value_map

    # Build function type from signature
    val ret_ty = if dest.?:
        get_local_type(local_types, tm, dest.unwrap().id)
    else:
        if sig.return_type == nil: llvm_void_type_in_context(ctx) else: tm.map_type(sig.return_type)
    var param_types: [i64] = []
    for param in sig.params:
        val param_type: MirType = param
        rt_array_push_i64_raw(param_types, tm.map_type(param_type))
    val fn_ty = llvm_function_type(ret_ty, param_types, false)

    # Build args
    var arg_vals: [i64] = []
    var arg_i = 0
    for arg in args:
        var arg_val = translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map)
        if arg_val == 0:
            # A null LLVMValueRef argument segfaults inside LLVMBuildCall2.
            # Name the operand kind so the producing translation path is
            # identifiable from the log.
            val arg_desc = match arg.kind:
                case Copy(local): "Copy#" + local.id.to_text()
                case Move(local): "Move#" + local.id.to_text()
                case Const(_, _): "Const"
            eprint("[llvm-lib] ERROR: indirect call arg translated to null (" + arg_desc + ") — substituting i64 0 to avoid segfault")
            arg_val = llvm_const_int(llvm_int64_type_in_context(ctx), 0, true)
        if arg_i < param_types.len():
            arg_val = coerce_llvm_value(builder, arg_val, param_types[arg_i])
        rt_array_push_i64_raw(arg_vals, arg_val)
        arg_i = arg_i + 1

    val call_name = if dest.?: "icall" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, fn_ptr, arg_vals, call_name)

    if dest.?:
        set_raw_handle(local_value_map, dest.unwrap().id, call_val)
    local_value_map

fn translate_intrinsic(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                       dest: LocalId?, name: text, args: [MirOperand],
                       value_map: {i64: i64}, local_types: {i64: i64},
                       block_map: {i64: i64}, func_map: {text: i64}) -> {i64: i64}:
    var local_value_map: Dict<i64, i64> = value_map
    if name == "__simple_ssa_phi":
        # bug #135 (opus review Finding 3): this consumer only ever reads
        # args[0..3] (one then/else pair). var_reassign_ssa.spl can emit an
        # N-ary phi (more than one incoming pair, e.g. an elif-ladder join),
        # which this path would silently truncate -- dropping every arm past
        # the first two with no diagnostic. No caller currently routes an
        # N-ary plan through the llvm-lib backend, so this is latent; guard
        # it loudly instead of miscompiling silently if that ever changes.
        if args.len() > 4:
            eprint("[llvm-lib] ERROR: __simple_ssa_phi has {args.len()} args (N-ary join); this backend only supports a single then/else pair")
            return local_value_map
        if dest.? and args.len() >= 4:
            # NOTE: explicit match, not `if then_block.? and else_block.?:` --
            # a const block-id operand can legitimately be 0 (the entry block
            # id); truthiness on the boxed i64? here would falsely report
            # "malformed" for a phi whose then/else predecessor is block 0.
            val then_block = ssa_phi_const_block_arg(args[0])
            val else_block = ssa_phi_const_block_arg(args[2])
            var matched = false
            match then_block:
                case Some(then_id):
                    match else_block:
                        case Some(else_id):
                            if block_map.has(then_id) and block_map.has(else_id):
                                matched = true
                                val dest_id = dest.unwrap().id
                                val phi_ty = get_local_type(local_types, tm, dest_id)
                                val phi = llvm_build_phi(builder, phi_ty, "ssa_phi")
                                val then_val = translate_operand(ctx, mod_, builder, tm, args[1], value_map, local_types, func_map)
                                val else_val = translate_operand(ctx, mod_, builder, tm, args[3], value_map, local_types, func_map)
                                llvm_add_incoming(phi, [then_val, else_val], [get_raw_handle(block_map, then_id), get_raw_handle(block_map, else_id)])
                                set_raw_handle(local_value_map, dest_id, phi)
                        case nil:
                            pass_do_nothing
                case nil:
                    pass_do_nothing
            if not matched:
                eprint("[llvm-lib] ERROR: malformed __simple_ssa_phi intrinsic")
        else:
            eprint("[llvm-lib] ERROR: malformed __simple_ssa_phi intrinsic")
        return local_value_map

    val intrinsic_name = "__simple_intrinsic_{name}"
    val func_ref = llvm_get_named_function(mod_, intrinsic_name)
    if func_ref == 0:
        eprint("[llvm-lib] ERROR: unresolved intrinsic call, skipping instruction — generated code will be broken")
        return local_value_map

    var arg_vals: [i64] = []
    var arg_i = 0
    for arg in args:
        var arg_val = translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map)
        if arg_val == 0:
            # A null LLVMValueRef argument segfaults inside LLVMBuildCall2.
            # Name the operand kind so the producing translation path is
            # identifiable from the log.
            val arg_desc = match arg.kind:
                case Copy(local): "Copy#" + local.id.to_text()
                case Move(local): "Move#" + local.id.to_text()
                case Const(_, _): "Const"
            eprint("[llvm-lib] ERROR: intrinsic call arg translated to null (" + arg_desc + ") for '" + name + "' — substituting i64 0 to avoid segfault")
            arg_val = llvm_const_int(llvm_int64_type_in_context(ctx), 0, true)
        if arg_i < llvm_count_params(func_ref):
            arg_val = coerce_llvm_value(builder, arg_val, llvm_type_of(llvm_get_param(func_ref, arg_i)))
        rt_array_push_i64_raw(arg_vals, arg_val)
        arg_i = arg_i + 1

    val fn_ty = llvm_global_get_value_type(func_ref)
    val call_name = if dest.?: "intrinsic" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, func_ref, arg_vals, call_name)

    if dest.?:
        set_raw_handle(local_value_map, dest.unwrap().id, call_val)
    local_value_map

# ============================================================================
# Pseudo SSA Phi Translation
# ============================================================================

fn ssa_phi_const_block_arg(arg: MirOperand) -> i64?:
    match arg.kind:
        case Const(value, _):
            match value:
                case Int(v): Some(v)
                case _: nil
        case _: nil

# ============================================================================
# Operand Translation
# ============================================================================

fn translate_operand(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                     operand: MirOperand, value_map: {i64: i64},
                     local_types: {i64: i64}, func_map: {text: i64}) -> i64:
    val operand_kind = operand.kind
    val operand_disc = rt_enum_discriminant(operand_kind)
    if operand_disc == 0x40dd4f6f:  # hash("Copy")
        return get_value(value_map, operand_local_id(operand_kind))
    if operand_disc == 0x23191922:  # hash("Move")
        return get_value(value_map, operand_local_id(operand_kind))
    if operand_disc == 0x0b55abba:  # hash("Const")
        val payload = rt_enum_payload(operand_kind)
        val value: MirConstValue = rt_tuple_get(payload, 0)
        val const_type: MirType = rt_tuple_get(payload, 1)
        return translate_const_value(ctx, mod_, builder, tm, value, const_type)

    eprint("[llvm-lib] ERROR: invalid MIR operand discriminant " + operand_disc.to_text())
    0

fn translate_const_value(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                         value: MirConstValue, ty: MirType) -> i64:
    val llvm_ty = tm.map_type(ty)
    match value:
        case Int(v):
            if v == 0 and llvm_get_type_kind(llvm_ty) == 12:  # 12=Pointer (was 14=Metadata — Int(0)-as-ptr built an invalid ConstInt instead of const_null)
                llvm_const_null(llvm_ty)
            else:
                llvm_const_int(llvm_ty, v, true)
        case Float(v): llvm_const_real_of_string(llvm_ty, "{v}")
        case Bool(v):
            val bval = if v: 1 else: 0
            llvm_const_int(llvm_ty, bval, false)
        case Str(name):
            # Check if it's a function reference
            val ty_kind: MirTypeKind = ty.kind
            match ty_kind:
                case FuncPtr(_):
                    val fn_name = if name == "main": "__simple_main" else: name
                    val func_ref = llvm_get_named_function(mod_, fn_name)
                    if func_ref != 0:
                        func_ref
                    else:
                        llvm_const_null(llvm_ty)
                case _:
                    # String constant
                    val str_val = llvm_const_string_in_context(ctx, name, false)
                    val str_ty = llvm_array_type2(llvm_int8_type_in_context(ctx), name.len() + 1)
                    val global = llvm_add_global(mod_, str_ty, ".str")
                    llvm_set_initializer(global, str_val)
                    llvm_set_global_constant(global, true)
                    llvm_set_linkage(global, LLVM_PRIVATE_LINKAGE)
                    llvm_set_unnamed_addr(global, true)
                    val zero = llvm_const_int(llvm_int64_type_in_context(ctx), 0, false)
                    llvm_build_in_bounds_gep2(builder, str_ty, global, [zero, zero], "str")
        case Zero: llvm_const_null(llvm_ty)
        case Array(_): llvm_const_null(llvm_ty)
        case Tuple(_): llvm_const_null(llvm_ty)
        case Struct(_): llvm_const_null(llvm_ty)

# ============================================================================
# Helpers
# ============================================================================

fn operand_local_id(operand_kind: MirOperandKind) -> i64:
    val payload = rt_enum_payload(operand_kind)
    # Native lowering normally carries LocalId as a tagged heap struct. The
    # all-zero newtype edge case can remain scalar zero instead.
    if payload >= 4096 and (payload & 7) == 1:
        val local: LocalId = payload
        return local.id
    payload

fn get_value(value_map: {i64: i64}, local_id: i64) -> i64:
    val value = get_raw_handle(value_map, local_id)
    if value == 0:
        eprint("[llvm-lib] ERROR: read of undefined local _" + local_id.to_text() + " (no def reached value_map) — IR will fail verification")
    value

fn get_local_type(local_types: {i64: i64}, tm: LlvmLibTypeMapper, local_id: i64) -> i64:
    val type_ref = get_raw_handle(local_types, local_id)
    if type_ref != 0:
        type_ref
    else:
        tm.native_int_type()

fn set_raw_handle(map: {i64: i64}, key: i64, value: i64):
    rt_dict_set_i64_raw(map as i64, key, value)

fn get_raw_handle(map: {i64: i64}, key: i64) -> i64:
    rt_dict_get_i64_raw(map as i64, key)

fn get_operand_value(operand: MirOperand, value_map: {i64: i64}) -> i64:
    match operand.kind:
        case Copy(local): get_value(value_map, local.id)
        case Move(local): get_value(value_map, local.id)
        case _: 0

fn get_operand_type_ref(operand: MirOperand, local_types: {i64: i64}, tm: LlvmLibTypeMapper) -> i64:
    match operand.kind:
        case Copy(local):
            get_local_type(local_types, tm, local.id)
        case Move(local):
            get_local_type(local_types, tm, local.id)
        case Const(_, type_):
            tm.map_type(type_)

fn get_operand_unsigned(operand: MirOperand, local_unsigned: {i64: bool}) -> bool:
    match operand.kind:
        case Copy(local): local_unsigned.get(local.id) ?? false
        case Move(local): local_unsigned.get(local.id) ?? false
        case Const(_, type_):
            match type_.kind:
                case U8 | U16 | U32 | U64: true
                case _: false

fn is_float_type_ref(ctx: i64, ty: i64) -> bool:
    val kind = llvm_get_type_kind(ty)
    kind == 2 or kind == 3  # 2=Float, 3=Double

fn is_int_type_ref(ctx: i64, ty: i64) -> bool:
    llvm_get_type_kind(ty) == 8  # 8=Integer

# ============================================================================
# Exports
# ============================================================================
