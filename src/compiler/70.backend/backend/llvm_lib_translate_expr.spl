# LLVM Lib Translate Expr — Instruction Translation
#
# Translates individual MIR instructions and terminators to LLVM C API calls.
# Called from llvm_lib_translate.spl for each instruction in a basic block.

use compiler.mir.mir_data.*
use compiler.backend.llvm_lib_type_mapper.{LlvmLibTypeMapper}
use std.ffi.llvm.*

# ============================================================================
# Instruction Translation
# ============================================================================

fn translate_instruction(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                         inst: MirInst, value_map: {i64: i64}, local_types: {i64: i64},
                         func_map: {text: i64}):
    match inst.kind:
        case Const(dest, value, ty):
            translate_const(ctx, mod_, builder, tm, dest, value, ty, value_map, local_types)

        case Copy(dest, src):
            val src_val = get_value(value_map, src.id)
            value_map[dest.id] = src_val

        case Move(dest, src):
            val src_val = get_value(value_map, src.id)
            value_map[dest.id] = src_val

        case BinOp(dest, op, left, right):
            translate_binop(ctx, mod_, builder, tm, dest, op, left, right, value_map, local_types)

        case UnaryOp(dest, op, operand):
            translate_unaryop(ctx, builder, tm, dest, op, operand, value_map, local_types)

        case Alloc(dest, ty):
            val llvm_ty = tm.map_type(ty)
            val alloca = llvm_build_alloca(builder, llvm_ty, "alloc")
            value_map[dest.id] = alloca

        case Load(dest, ptr):
            val ptr_val = translate_operand(ctx, mod_, builder, tm, ptr, value_map, local_types, func_map)
            val dest_ty = get_local_type(local_types, tm, dest.id)
            val load_val = llvm_build_load2(builder, dest_ty, ptr_val, "load")
            value_map[dest.id] = load_val

        case Store(ptr, value):
            val ptr_val = translate_operand(ctx, mod_, builder, tm, ptr, value_map, local_types, func_map)
            val store_val = translate_operand(ctx, mod_, builder, tm, value, value_map, local_types, func_map)
            llvm_build_store(builder, store_val, ptr_val)

        case GetElementPtr(dest, base, indices):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, value_map, local_types, func_map)
            var idx_vals: [i64] = []
            for idx in indices:
                idx_vals.push(translate_operand(ctx, mod_, builder, tm, idx, value_map, local_types, func_map))
            val i8_ty = llvm_int8_type_in_context(ctx)
            val gep = llvm_build_gep2(builder, i8_ty, base_val, idx_vals, "gep")
            value_map[dest.id] = gep

        case Aggregate(dest, kind, operands):
            translate_aggregate(ctx, mod_, builder, tm, dest, kind, operands, value_map, local_types, func_map)

        case GetField(dest, base, field):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, value_map, local_types, func_map)
            val result = llvm_build_extract_value(builder, base_val, field, "field")
            value_map[dest.id] = result

        case SetField(base, field, value):
            val base_val = translate_operand(ctx, mod_, builder, tm, base, value_map, local_types, func_map)
            val new_val = translate_operand(ctx, mod_, builder, tm, value, value_map, local_types, func_map)
            val result = llvm_build_insert_value(builder, base_val, new_val, field, "setfield")
            # SetField modifies in place — update the base local in value_map
            match base.kind:
                case Copy(local): value_map[local] = result
                case Move(local): value_map[local] = result
                case _: ()

        case Cast(dest, operand, target):
            translate_cast(ctx, builder, tm, dest, operand, target, value_map, local_types, func_map)

        case Bitcast(dest, operand, target):
            val op_val = translate_operand(ctx, mod_, builder, tm, operand, value_map, local_types, func_map)
            val target_ty = tm.map_type(target)
            val result = llvm_build_bitcast(builder, op_val, target_ty, "bitcast")
            value_map[dest.id] = result

        case CheckedBinOp(dest, op, left, right):
            # Treat as unchecked BinOp for bootstrap (overflow traps not needed)
            translate_binop(ctx, mod_, builder, tm, dest, op, left, right, value_map, local_types)

        case PipeForward(dest, value, func):
            # |> operator: call func(value)
            translate_call(ctx, mod_, builder, tm, Some(dest), func, [value], value_map, local_types, func_map)

        case Call(dest, func, args):
            translate_call(ctx, mod_, builder, tm, dest, func, args, value_map, local_types, func_map)

        case CallIndirect(dest, ptr, args, sig):
            translate_call_indirect(ctx, mod_, builder, tm, dest, ptr, args, sig, value_map, local_types, func_map)

        case Intrinsic(dest, name, args):
            translate_intrinsic(ctx, mod_, builder, tm, dest, name, args, value_map, local_types, func_map)

        case Ref(dest, kind, place):
            val place_val = get_value(value_map, place.local.id)
            value_map[dest.id] = place_val

        case DebugValue(_, _): ()
        case Nop: ()

        # Stubs for GPU/VHDL/SIMD/Pipeline/Async — produce zero value
        case _:
            ()

# ============================================================================
# Constant Translation
# ============================================================================

fn translate_const(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                   dest: LocalId, value: MirConstValue, ty: MirType,
                   value_map: {i64: i64}, local_types: {i64: i64}):
    val llvm_ty = tm.map_type(ty)
    match value:
        case Int(v):
            val result = llvm_const_int(llvm_ty, v, true)
            value_map[dest.id] = result
        case Float(v):
            val result = llvm_const_real_of_string(llvm_ty, "{v}")
            value_map[dest.id] = result
        case Bool(v):
            val bval = if v: 1 else: 0
            val result = llvm_const_int(llvm_ty, bval, false)
            value_map[dest.id] = result
        case Str(v):
            # Create global string constant
            val str_val = llvm_const_string_in_context(ctx, v, false)
            val str_ty = llvm_array_type2(llvm_int8_type_in_context(ctx), v.len() + 1)
            val global = llvm_add_global(mod_, str_ty, ".str")
            llvm_set_initializer(global, str_val)
            llvm_set_global_constant(global, true)
            llvm_set_linkage(global, LLVM_PRIVATE_LINKAGE)
            llvm_set_unnamed_addr(global, true)
            # GEP to get ptr to first element
            val zero = llvm_const_int(llvm_int64_type_in_context(ctx), 0, false)
            val gep = llvm_build_in_bounds_gep2(builder, str_ty, global, [zero, zero], "str")
            value_map[dest.id] = gep
        case Zero:
            if tm.is_void_mir_type(ty):
                ()
            else:
                val result = llvm_const_null(llvm_ty)
                value_map[dest.id] = result
        case Array(_):
            val result = llvm_const_null(llvm_ty)
            value_map[dest.id] = result
        case Tuple(_):
            val result = llvm_const_null(llvm_ty)
            value_map[dest.id] = result
        case Struct(_):
            val result = llvm_const_null(llvm_ty)
            value_map[dest.id] = result

# ============================================================================
# Binary Operation Translation
# ============================================================================

fn translate_binop(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                   dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand,
                   value_map: {i64: i64}, local_types: {i64: i64}):
    val lhs = get_operand_value(left, value_map)
    val rhs = get_operand_value(right, value_map)
    val dest_ty = get_local_type(local_types, tm, dest.id)
    val is_float = is_float_type_ref(ctx, dest_ty)
    val left_ty = get_operand_type_ref(left, local_types, tm)
    val left_is_float = is_float_type_ref(ctx, left_ty)

    val result = match op:
        case Add:
            if is_float: llvm_build_fadd(builder, lhs, rhs, "add")
            else: llvm_build_nsw_add(builder, lhs, rhs, "add")
        case Sub:
            if is_float: llvm_build_fsub(builder, lhs, rhs, "sub")
            else: llvm_build_nsw_sub(builder, lhs, rhs, "sub")
        case Mul:
            if is_float: llvm_build_fmul(builder, lhs, rhs, "mul")
            else: llvm_build_nsw_mul(builder, lhs, rhs, "mul")
        case Div:
            if is_float: llvm_build_fdiv(builder, lhs, rhs, "div")
            else: llvm_build_sdiv(builder, lhs, rhs, "div")
        case Rem:
            if is_float: llvm_build_frem(builder, lhs, rhs, "rem")
            else: llvm_build_srem(builder, lhs, rhs, "rem")
        case Pow:
            # Call __simple_pow for integer, llvm.pow for float
            if is_float:
                val pow_fn = llvm_get_named_function(mod_, "llvm.pow.f64")
                if pow_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(pow_fn), pow_fn, [lhs, rhs], "pow")
                else:
                    val rt_pow = llvm_get_named_function(mod_, "rt_pow")
                    if rt_pow != 0:
                        llvm_build_call2(builder, llvm_global_get_value_type(rt_pow), rt_pow, [lhs, rhs], "pow")
                    else:
                        llvm_const_null(dest_ty)
            else:
                val pow_fn = llvm_get_named_function(mod_, "__simple_pow")
                if pow_fn != 0:
                    llvm_build_call2(builder, llvm_global_get_value_type(pow_fn), pow_fn, [lhs, rhs], "pow")
                else:
                    llvm_const_null(dest_ty)

        case BitAnd: llvm_build_and(builder, lhs, rhs, "and")
        case BitOr: llvm_build_or(builder, lhs, rhs, "or")
        case BitXor: llvm_build_xor(builder, lhs, rhs, "xor")
        case Shl: llvm_build_shl(builder, lhs, rhs, "shl")
        case Shr: llvm_build_ashr(builder, lhs, rhs, "shr")

        case Eq:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OEQ, lhs, rhs, "eq")
            else:
                llvm_build_icmp(builder, LLVM_INT_EQ, lhs, rhs, "eq")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Ne:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_ONE, lhs, rhs, "ne")
            else:
                llvm_build_icmp(builder, LLVM_INT_NE, lhs, rhs, "ne")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Lt:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OLT, lhs, rhs, "lt")
            else:
                llvm_build_icmp(builder, LLVM_INT_SLT, lhs, rhs, "lt")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Le:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OLE, lhs, rhs, "le")
            else:
                llvm_build_icmp(builder, LLVM_INT_SLE, lhs, rhs, "le")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Gt:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OGT, lhs, rhs, "gt")
            else:
                llvm_build_icmp(builder, LLVM_INT_SGT, lhs, rhs, "gt")
            maybe_zext(builder, ctx, cmp, dest_ty)
        case Ge:
            val cmp = if left_is_float:
                llvm_build_fcmp(builder, LLVM_REAL_OGE, lhs, rhs, "ge")
            else:
                llvm_build_icmp(builder, LLVM_INT_SGE, lhs, rhs, "ge")
            maybe_zext(builder, ctx, cmp, dest_ty)

        case Offset:
            val i8_ty = llvm_int8_type_in_context(ctx)
            llvm_build_gep2(builder, i8_ty, lhs, [rhs], "offset")

        case _:
            # MatMul, BroadcastOps — stub to zero
            llvm_const_null(dest_ty)

    value_map[dest.id] = result

fn maybe_zext(builder: i64, ctx: i64, cmp_val: i64, dest_ty: i64) -> i64:
    val i1_ty = llvm_int1_type_in_context(ctx)
    if dest_ty == i1_ty:
        cmp_val
    else:
        llvm_build_zext(builder, cmp_val, dest_ty, "zext")

# ============================================================================
# Unary Operation Translation
# ============================================================================

fn translate_unaryop(ctx: i64, builder: i64, tm: LlvmLibTypeMapper,
                     dest: LocalId, op: MirUnaryOp, operand: MirOperand,
                     value_map: {i64: i64}, local_types: {i64: i64}):
    val op_val = get_operand_value(operand, value_map)
    val dest_ty = get_local_type(local_types, tm, dest.id)
    val is_float = is_float_type_ref(ctx, dest_ty)

    val result = match op:
        case Neg:
            if is_float: llvm_build_fneg(builder, op_val, "neg")
            else: llvm_build_neg(builder, op_val, "neg")
        case Not:
            val zero = llvm_const_int(dest_ty, 0, false)
            llvm_build_icmp(builder, LLVM_INT_EQ, op_val, zero, "not")
        case BitNot:
            llvm_build_not(builder, op_val, "bitnot")
        case _:
            llvm_const_null(dest_ty)

    value_map[dest.id] = result

# ============================================================================
# Aggregate Translation
# ============================================================================

fn translate_aggregate(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                       dest: LocalId, kind: AggregateKind, operands: [MirOperand],
                       value_map: {i64: i64}, local_types: {i64: i64},
                       func_map: {text: i64}):
    val dest_ty = get_local_type(local_types, tm, dest.id)
    var agg = llvm_get_undef(dest_ty)
    for i in 0..operands.len():
        val elem_val = translate_operand(ctx, mod_, builder, tm, operands[i], value_map, local_types, func_map)
        agg = llvm_build_insert_value(builder, agg, elem_val, i, "agg")
    value_map[dest.id] = agg

# ============================================================================
# Cast Translation
# ============================================================================

fn translate_cast(ctx: i64, builder: i64, tm: LlvmLibTypeMapper,
                  dest: LocalId, operand: MirOperand, target: MirType,
                  value_map: {i64: i64}, local_types: {i64: i64},
                  func_map: {text: i64}):
    val op_val = get_operand_value(operand, value_map)
    val src_ty_ref = get_operand_type_ref(operand, local_types, tm)
    val target_ty = tm.map_type(target)
    val src_ty_kind = llvm_get_type_kind(src_ty_ref)
    val dst_ty_kind = llvm_get_type_kind(target_ty)

    # Type kind constants (from LLVM)
    # 0=Void, 2=Float, 3=Double, 7=Label, 10=Integer, 11=Function, 12=Struct, 14=Pointer
    val TK_FLOAT = 2
    val TK_DOUBLE = 3
    val TK_INTEGER = 10
    val TK_POINTER = 14

    val src_is_int = src_ty_kind == TK_INTEGER
    val src_is_float = src_ty_kind == TK_FLOAT or src_ty_kind == TK_DOUBLE
    val src_is_ptr = src_ty_kind == TK_POINTER
    val dst_is_int = dst_ty_kind == TK_INTEGER
    val dst_is_float = dst_ty_kind == TK_FLOAT or dst_ty_kind == TK_DOUBLE
    val dst_is_ptr = dst_ty_kind == TK_POINTER

    val result = if src_is_int and dst_is_int:
        # Int-to-int: sext, trunc, or zext depending on sizes
        # Use sext for signed widening, trunc for narrowing
        val src_bits = get_int_type_width(src_ty_ref)
        val dst_bits = get_int_type_width(target_ty)
        if src_bits < dst_bits:
            if src_bits == 1:
                llvm_build_zext(builder, op_val, target_ty, "cast")
            else:
                llvm_build_sext(builder, op_val, target_ty, "cast")
        elif src_bits > dst_bits:
            llvm_build_trunc(builder, op_val, target_ty, "cast")
        else:
            op_val
    elif src_is_int and dst_is_float:
        llvm_build_si_to_fp(builder, op_val, target_ty, "cast")
    elif src_is_float and dst_is_int:
        llvm_build_fp_to_si(builder, op_val, target_ty, "cast")
    elif src_is_float and dst_is_float:
        val src_bits = if src_ty_kind == TK_FLOAT: 32 else: 64
        val dst_bits = if dst_ty_kind == TK_FLOAT: 32 else: 64
        if src_bits < dst_bits:
            llvm_build_fpext(builder, op_val, target_ty, "cast")
        elif src_bits > dst_bits:
            llvm_build_fptrunc(builder, op_val, target_ty, "cast")
        else:
            op_val
    elif src_is_ptr and dst_is_int:
        llvm_build_ptr_to_int(builder, op_val, target_ty, "cast")
    elif src_is_int and dst_is_ptr:
        llvm_build_int_to_ptr(builder, op_val, target_ty, "cast")
    else:
        llvm_build_bitcast(builder, op_val, target_ty, "cast")

    value_map[dest.id] = result

fn get_int_type_width(ty: i64) -> i64:
    llvm_get_int_type_width(ty)

# ============================================================================
# Call Translation
# ============================================================================

fn translate_call(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                  dest: LocalId?, func: MirOperand, args: [MirOperand],
                  value_map: {i64: i64}, local_types: {i64: i64},
                  func_map: {text: i64}):
    # Resolve function
    var func_ref = 0
    var fn_name = ""
    match func.kind:
        case Const(value, type_):
            match value:
                case Str(name):
                    fn_name = if name == "main": "__simple_main" else: name
                    func_ref = llvm_get_named_function(mod_, fn_name)
                    if func_ref == 0 and func_map.contains(name):
                        func_ref = func_map[name]
                case _: ()
        case Copy(local):
            func_ref = get_value(value_map, local)
        case Move(local):
            func_ref = get_value(value_map, local)

    if func_ref == 0:
        return

    # Build args
    var arg_vals: [i64] = []
    for arg in args:
        arg_vals.push(translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map))

    # Get function type — use LLVMGlobalGetValueType for opaque pointers (LLVM 15+)
    val fn_ty = llvm_global_get_value_type(func_ref)

    val call_name = if dest.?: "call" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, func_ref, arg_vals, call_name)

    if dest.?:
        value_map[dest.unwrap().id] = call_val

fn translate_call_indirect(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                           dest: LocalId?, ptr: MirOperand, args: [MirOperand],
                           sig: MirSignature,
                           value_map: {i64: i64}, local_types: {i64: i64},
                           func_map: {text: i64}):
    val fn_ptr = translate_operand(ctx, mod_, builder, tm, ptr, value_map, local_types, func_map)

    # Build function type from signature
    val ret_ty = tm.map_type(sig.return_type)
    var param_types: [i64] = []
    for param in sig.params:
        param_types.push(tm.map_type(param.type_))
    val fn_ty = llvm_function_type(ret_ty, param_types, false)

    # Build args
    var arg_vals: [i64] = []
    for arg in args:
        arg_vals.push(translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map))

    val call_name = if dest.?: "icall" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, fn_ptr, arg_vals, call_name)

    if dest.?:
        value_map[dest.unwrap().id] = call_val

fn translate_intrinsic(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                       dest: LocalId?, name: text, args: [MirOperand],
                       value_map: {i64: i64}, local_types: {i64: i64},
                       func_map: {text: i64}):
    val intrinsic_name = "__simple_intrinsic_{name}"
    val func_ref = llvm_get_named_function(mod_, intrinsic_name)
    if func_ref == 0:
        return

    var arg_vals: [i64] = []
    for arg in args:
        arg_vals.push(translate_operand(ctx, mod_, builder, tm, arg, value_map, local_types, func_map))

    val fn_ty = llvm_global_get_value_type(func_ref)
    val call_name = if dest.?: "intrinsic" else: ""
    val call_val = llvm_build_call2(builder, fn_ty, func_ref, arg_vals, call_name)

    if dest.?:
        value_map[dest.unwrap().id] = call_val

# ============================================================================
# Terminator Translation
# ============================================================================

fn translate_terminator(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                        term: MirTerminator,
                        value_map: {i64: i64}, local_types: {i64: i64},
                        block_map: {i64: i64}, func_map: {text: i64}):
    match term:
        case Return(value):
            if value.?:
                val ret_val = translate_operand(ctx, mod_, builder, tm, value.unwrap(), value_map, local_types, func_map)
                llvm_build_ret(builder, ret_val)
            else:
                llvm_build_ret_void(builder)

        case Goto(target):
            val dest_bb = block_map[target]
            llvm_build_br(builder, dest_bb)

        case If(cond, then_, else_):
            val cond_val = translate_operand(ctx, mod_, builder, tm, cond, value_map, local_types, func_map)
            val then_bb = block_map[then_]
            val else_bb = block_map[else_]
            # Ensure condition is i1
            val i1_ty = llvm_int1_type_in_context(ctx)
            val cond_ty = llvm_type_of(cond_val)
            var final_cond = cond_val
            if cond_ty != i1_ty:
                val zero = llvm_const_int(cond_ty, 0, false)
                final_cond = llvm_build_icmp(builder, LLVM_INT_NE, cond_val, zero, "tobool")
            llvm_build_cond_br(builder, final_cond, then_bb, else_bb)

        case Switch(value, targets, default):
            val discr_val = translate_operand(ctx, mod_, builder, tm, value, value_map, local_types, func_map)
            val default_bb = block_map[default]
            val switch_inst = llvm_build_switch(builder, discr_val, default_bb, targets.len())
            for switch_case in targets:
                val case_val = llvm_const_int(tm.native_int_type(), switch_case.value, false)
                val case_bb = block_map[switch_case.target]
                llvm_add_case(switch_inst, case_val, case_bb)

        case Unreachable:
            llvm_build_unreachable(builder)

        case Abort(message):
            val abort_fn = llvm_get_named_function(mod_, "abort")
            if abort_fn != 0:
                val fn_ty = llvm_global_get_value_type(abort_fn)
                llvm_build_call2(builder, fn_ty, abort_fn, [], "")
            llvm_build_unreachable(builder)

        case CallTerminator(dest, func, args, normal, unwind):
            # Translate as regular call + branch to normal successor
            translate_call(ctx, mod_, builder, tm, dest, func, args, value_map, local_types, func_map)
            val normal_bb = block_map[normal]
            llvm_build_br(builder, normal_bb)

# ============================================================================
# Operand Translation
# ============================================================================

fn translate_operand(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                     operand: MirOperand, value_map: {i64: i64},
                     local_types: {i64: i64}, func_map: {text: i64}) -> i64:
    match operand.kind:
        case Copy(local):
            get_value(value_map, local)
        case Move(local):
            get_value(value_map, local)
        case Const(value, type_):
            translate_const_value(ctx, mod_, builder, tm, value, type_)

fn translate_const_value(ctx: i64, mod_: i64, builder: i64, tm: LlvmLibTypeMapper,
                         value: MirConstValue, ty: MirType) -> i64:
    val llvm_ty = tm.map_type(ty)
    match value:
        case Int(v): llvm_const_int(llvm_ty, v, true)
        case Float(v): llvm_const_real_of_string(llvm_ty, "{v}")
        case Bool(v):
            val bval = if v: 1 else: 0
            llvm_const_int(llvm_ty, bval, false)
        case Str(name):
            # Check if it's a function reference
            match ty.kind:
                case FuncPtr(_) | Function(_, _):
                    val fn_name = if name == "main": "__simple_main" else: name
                    val func_ref = llvm_get_named_function(mod_, fn_name)
                    if func_ref != 0:
                        func_ref
                    else:
                        llvm_const_null(llvm_ty)
                case _:
                    # String constant
                    val str_val = llvm_const_string_in_context(ctx, name, false)
                    val str_ty = llvm_array_type2(llvm_int8_type_in_context(ctx), name.len() + 1)
                    val global = llvm_add_global(mod_, str_ty, ".str")
                    llvm_set_initializer(global, str_val)
                    llvm_set_global_constant(global, true)
                    llvm_set_linkage(global, LLVM_PRIVATE_LINKAGE)
                    llvm_set_unnamed_addr(global, true)
                    val zero = llvm_const_int(llvm_int64_type_in_context(ctx), 0, false)
                    llvm_build_in_bounds_gep2(builder, str_ty, global, [zero, zero], "str")
        case Zero: llvm_const_null(llvm_ty)
        case Array(_): llvm_const_null(llvm_ty)
        case Tuple(_): llvm_const_null(llvm_ty)
        case Struct(_): llvm_const_null(llvm_ty)

# ============================================================================
# Helpers
# ============================================================================

fn get_value(value_map: {i64: i64}, local_id: i64) -> i64:
    if value_map.contains(local_id):
        value_map[local_id]
    else:
        0

fn get_local_type(local_types: {i64: i64}, tm: LlvmLibTypeMapper, local_id: i64) -> i64:
    if local_types.contains(local_id):
        local_types[local_id]
    else:
        tm.native_int_type()

fn get_operand_value(operand: MirOperand, value_map: {i64: i64}) -> i64:
    match operand.kind:
        case Copy(local): get_value(value_map, local)
        case Move(local): get_value(value_map, local)
        case _: 0

fn get_operand_type_ref(operand: MirOperand, local_types: {i64: i64}, tm: LlvmLibTypeMapper) -> i64:
    match operand.kind:
        case Copy(local):
            get_local_type(local_types, tm, local)
        case Move(local):
            get_local_type(local_types, tm, local)
        case Const(_, type_):
            tm.map_type(type_)

fn is_float_type_ref(ctx: i64, ty: i64) -> bool:
    val kind = llvm_get_type_kind(ty)
    kind == 2 or kind == 3  # 2=Float, 3=Double

# ============================================================================
# Exports
# ============================================================================

export translate_instruction, translate_terminator
