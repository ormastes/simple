# Vulkan Backend - Vulkan/SPIR-V Code Generation
#
# Compiles MIR to SPIR-V assembly code for Vulkan compute shaders.
# SPIR-V can be assembled to binary using spirv-as or validated with spirv-val.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.backend.backend_api.*
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.gpu_codegen_types.{GpuCodegen, GpuBarrierScope}
use compiler.backend.gpu_backend_metadata.{gpu_backend_supports_target}
use compiler.backend.vulkan_type_mapper.*
use compiler.backend.vulkan.spirv_builder.{SpirvBuilder}
use compiler.hir.hir_types.{MemorySpace, SymbolId}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}

# ============================================================================
# Vulkan Backend
# ============================================================================

class VulkanBackend:
    """
    Vulkan backend for GPU code generation.

    Compiles MIR modules to SPIR-V assembly code for Vulkan compute shaders.
    SPIR-V is a binary intermediate representation that gets executed
    by Vulkan-compatible GPU drivers.

    Supported subset:
    - Compute entry-point generation
    - Global, local, and workgroup invocation IDs
    - Void return and unreachable terminators

    All other MIR operations fail with a typed Vulkan backend error. This is
    intentionally narrower than emitting SPIR-V comments or unresolved IDs
    that an assembler could mistake for a usable shader.

    Usage:
        val _tup_0 = [1, 3]
        val backend = VulkanBackend.create(_tup_0)  # Vulkan 1[3]
        val result = backend_compile(backend, mir_module)
    """

    type_mapper: VulkanTypeMapper
    vulkan_version: [i64]
    options: BackendCompileOptions

    static fn create(vk_version: [i64]) -> VulkanBackend:
        """Create Vulkan backend for specific Vulkan version."""
        VulkanBackend(
            type_mapper: VulkanTypeMapper.create_version(vk_version[0], vk_version[1], 1, 6),
            vulkan_version: vk_version,
            options: compileoptions_default_options()
        )

    static fn create_with_options(vk_version: [i64], opts: BackendCompileOptions) -> VulkanBackend:
        """Create Vulkan backend with custom options."""
        VulkanBackend(
            type_mapper: VulkanTypeMapper.create_version(vk_version[0], vk_version[1], 1, 6),
            vulkan_version: vk_version,
            options: opts
        )

    static fn for_target(target: CodegenTarget) -> Result<VulkanBackend, CompileError>:
        """Create Vulkan backend from target."""
        if target == CodegenTarget.VulkanSpirv:
            return Ok(VulkanBackend.create([1, 3]))
        Err(compileerror_backend_error(
            BackendKind.Vulkan,
            "Target is not a Vulkan target"
        ))

    fn compile(module: MirModule) -> text:
        """Compile MIR module to SPIR-V."""
        val builder = SpirvBuilder.create(self.vulkan_version)

        # Emit module header
        builder.emit_header()
        builder.emit_capabilities()
        builder.emit_extensions()
        builder.emit_memory_model()

        # Collect shaders
        var shaders: [VulkanComputeShader] = []

        for _item_0 in module.functions:
            val symbol = _item_0[0]
            val func = _item_0[1]
            if self.is_compute_shader(func):
                if shaders.len() > 0:
                    return Err(compileerror_backend_error(
                        BackendKind.Vulkan,
                        "Vulkan SPIR-V currently supports one compute entry point per module"
                    ))
                val result = self.compile_compute_shader(builder, func)
                match result:
                    case Ok(shader):
                        shaders = shaders.push(shader)
                    case Err(e):
                        return Err(e)

        val spirv_assembly = builder.build()

        Ok(VulkanCompiledModule(
            name: module.name,
            spirv_assembly: spirv_assembly,
            shaders: shaders,
            vulkan_version: self.vulkan_version
        ))

    fn is_compute_shader(func: MirFunction) -> bool:
        """Check if function should be compiled as a compute shader."""
        # Functions with GPU instructions are compute shaders
        for block in func.blocks:
            for inst in block.instructions:
                match inst.kind:
                    case GpuGlobalId(_, _) | GpuLocalId(_, _) | GpuBlockId(_, _) | GpuBarrier(_) | GpuSharedAlloc(_, _, _) | GpuAtomicOp(_, _, _, _) | GpuAtomicCas(_, _, _, _):
                        return true
                    case _:
                        ()
        false

    fn compile_compute_shader(builder: SpirvBuilder, func: MirFunction) -> text:
        """Compile a compute shader."""

        if func.blocks.len() != 1 or func.blocks[0].id.id != 0:
            return Err(compileerror_backend_error(
                BackendKind.Vulkan,
                "Vulkan SPIR-V currently supports exactly one entry block"
            ))

        # Allocate IDs first so the module can follow SPIR-V logical layout:
        # entry points and annotations must precede types and global variables.
        val void_type = builder.alloc_id()
        val u32_type = builder.alloc_id()
        # Scalar lowering is rejected below; keep tuple aliases without
        # declaring unused capability-bearing scalar types in the module.
        val bool_type = u32_type
        val i32_type = u32_type
        val i64_type = u32_type
        val f32_type = u32_type
        val uvec3_type = builder.alloc_id()
        val uvec3_input_ptr = builder.alloc_id()
        val func_type = builder.alloc_id()
        val global_invocation_id = builder.alloc_id()
        val local_invocation_id = builder.alloc_id()
        val workgroup_id = builder.alloc_id()
        val func_id = builder.alloc_id()

        val interface_ids = [global_invocation_id, local_invocation_id, workgroup_id]
        builder.emit_entry_point(func.name, func_id, interface_ids)

        # Default workgroup size (can be overridden)
        val workgroup_size = [256, 1, 1]
        builder.emit_execution_mode(func_id, workgroup_size)

        builder.emit_decorate_builtin(global_invocation_id, SpirvBuiltin.GlobalInvocationId)
        builder.emit_decorate_builtin(local_invocation_id, SpirvBuiltin.LocalInvocationId)
        builder.emit_decorate_builtin(workgroup_id, SpirvBuiltin.WorkgroupId)

        # Decorations section complete
        builder.emit_comment("--- End Decorations ---")
        builder.emit("")

        builder.emit("{builder.id_str(void_type)} = OpTypeVoid")
        builder.emit("{builder.id_str(u32_type)} = OpTypeInt 32 0")
        builder.emit("{builder.id_str(uvec3_type)} = OpTypeVector {builder.id_str(u32_type)} 3")
        builder.emit("{builder.id_str(uvec3_input_ptr)} = OpTypePointer Input {builder.id_str(uvec3_type)}")
        builder.emit("{builder.id_str(func_type)} = OpTypeFunction {builder.id_str(void_type)}")
        builder.emit("{builder.id_str(global_invocation_id)} = OpVariable {builder.id_str(uvec3_input_ptr)} Input")
        builder.emit("{builder.id_str(local_invocation_id)} = OpVariable {builder.id_str(uvec3_input_ptr)} Input")
        builder.emit("{builder.id_str(workgroup_id)} = OpVariable {builder.id_str(uvec3_input_ptr)} Input")
        builder.emit("")

        # Emit function
        builder.emit("{builder.id_str(func_id)} = OpFunction {builder.id_str(void_type)} None {builder.id_str(func_type)}")

        # Emit entry block
        val entry_label = builder.emit_label()

        # Compile function body
        for block in func.blocks:
            if block.id.id != 0:  # Skip entry block (already emitted)
                builder.emit_label()

            for inst in block.instructions:
                val result = self.compile_instruction(builder, inst, (i32_type, u32_type, i64_type, f32_type, bool_type, uvec3_type, global_invocation_id, local_invocation_id, workgroup_id))
                match result:
                    case Ok(_):
                        ()
                    case Err(e):
                        return Err(e)

            val terminator_result = self.compile_terminator(builder, block.terminator)
            if terminator_result.is_err():
                return Err(terminator_result.unwrap_err())

        builder.emit_function_end()

        Ok(VulkanComputeShader(
            name: func.name,
            entry_point: func.name,
            workgroup_size: workgroup_size
        ))

    fn compile_instruction(
        builder: SpirvBuilder,
        inst: MirInst,
        types: (i64, i64, i64, i64, i64, i64, i64, i64, i64)  # (i32, u32, i64, f32, bool, uvec3, global_id, local_id, workgroup_id)
    ) -> Result<(), CompileError>:
        """Compile a single MIR instruction to SPIR-V."""
        val _destruct_1 = types
        val i32_type = _destruct_1[0]
        val u32_type = _destruct_1[1]
        val i64_type = _destruct_1[2]
        val f32_type = _destruct_1[3]
        val bool_type = _destruct_1[4]
        val uvec3_type = _destruct_1[5]
        val global_id_var = _destruct_1[6]
        val local_id_var = _destruct_1[7]
        val workgroup_id_var = _destruct_1[8]

        match inst.kind:
            case Const(dest, value, ty):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V constant lowering is not implemented"))

            case Copy(dest, src):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V copy lowering is not implemented"))

            case Move(dest, src):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V move lowering is not implemented"))

            case BinOp(dest, op, left, right):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V binary operation lowering is not implemented: {op}"))

            case UnaryOp(dest, op, operand):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V unary operation lowering is not implemented: {op}"))

            case Load(dest, ptr):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V host/device load lowering is not implemented"))

            case Store(ptr, value):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V host/device store lowering is not implemented"))

            # GPU-specific instructions
            case GpuGlobalId(dest, dim):
                # Load from GlobalInvocationId and extract component
                val loaded = builder.emit_load(uvec3_type, global_id_var)
                val component = builder.emit_composite_extract(u32_type, loaded, [dim])
                builder.emit_comment("global_id[{dim}] -> _l{dest.id}")

            case GpuLocalId(dest, dim):
                val loaded = builder.emit_load(uvec3_type, local_id_var)
                val component = builder.emit_composite_extract(u32_type, loaded, [dim])
                builder.emit_comment("local_id[{dim}] -> _l{dest.id}")

            case GpuBlockId(dest, dim):
                val loaded = builder.emit_load(uvec3_type, workgroup_id_var)
                val component = builder.emit_composite_extract(u32_type, loaded, [dim])
                builder.emit_comment("workgroup_id[{dim}] -> _l{dest.id}")

            case GpuBarrier(scope):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V barrier lowering is not implemented"))

            case GpuMemFence(scope):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V memory fence lowering is not implemented"))

            case GpuSharedAlloc(dest, ty, size):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V shared memory lowering is not implemented"))

            case GpuAtomicOp(dest, op, ptr, value):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V atomic operation lowering is not implemented: {op}"))

            case GpuAtomicCas(dest, ptr, expected, desired):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V atomic compare-exchange lowering is not implemented"))

            case Nop:
                ()

            case _:
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan backend does not support instruction: {inst.kind}"))

        Ok(())

    fn compile_terminator(builder: SpirvBuilder, term: MirTerminator) -> Result<(), CompileError>:
        """Compile block terminator."""
        match term:
            case Ret(_):
                builder.emit_return()
            case Goto(target):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V loop/goto lowering is not implemented"))
            case Branch(cond, true_target, false_target):
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan SPIR-V if/branch lowering is not implemented"))
            case Unreachable:
                builder.emit("OpUnreachable")
            case _:
                return Err(compileerror_backend_error(BackendKind.Vulkan, "Vulkan backend does not support terminator: {term}"))
        Ok(())

# ============================================================================
# Vulkan Compilation Results
# ============================================================================

struct VulkanCompiledModule:
    """Result of Vulkan compilation."""
    name: text
    spirv_assembly: text
    shaders: [VulkanComputeShader]
    vulkan_version: [i64]

struct VulkanComputeShader:
    """Compiled Vulkan compute shader."""
    name: text
    entry_point: text
    workgroup_size: [i64]

# ============================================================================
# Codegen Trait Implementation
# ============================================================================

impl Codegen for VulkanBackend:
    fn backend_kind() -> BackendKind: BackendKind.Vulkan
    fn backend_name() -> text: "vulkan"
    fn supports_target(target: CodegenTarget) -> bool:
        gpu_backend_supports_target(BackendKind.Vulkan, target)
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.GpuCode

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        val result = self.compile(module)
        match result:
            case Ok(vk_module):
                Ok(CodegenOutput.gpu_output(module.name, vk_module.spirv_assembly))
            case Err(e):
                Err(e)

# ============================================================================
# GpuCodegen Trait Implementation
# ============================================================================

impl GpuCodegen for VulkanBackend:
    fn compile_kernel(func_name: text, body: MirBody) -> Result<text, CompileError>:
        val builder = SpirvBuilder.create(self.vulkan_version)
        builder.emit_header()
        builder.emit_capabilities()
        builder.emit_extensions()
        builder.emit_memory_model()
        val mir_body: MirBody = body
        var vk_param_types: [MirType] = []
        var vk_pi = 0
        while vk_pi < mir_body.arg_count:
            val vk_loc: MirLocal = mir_body.locals[vk_pi]
            vk_param_types = vk_param_types.push(vk_loc.type_)
            vk_pi = vk_pi + 1
        val vk_sig = MirSignature(params: vk_param_types, return_type: mir_body.return_ty, is_variadic: false)
        val func = MirFunction(
            symbol: SymbolId(id: 0), name: func_name, signature: vk_sig,
            locals: mir_body.locals, blocks: mir_body.blocks, entry_block: BlockId.entry(), span: Span.empty(),
            generic_params: [], is_generic_template: false, specialization_of: nil,
            type_bindings: {}, layout_phase: nil, is_kernel: true,
            gpu_target: "vulkan", gpu_backend_order: "vulkan", is_export_c: false,
            export_name: "", has_driver_manifest_attr: false, driver_manifest_attr: nil,
            has_vhdl_metadata: false, vhdl_metadata: vhdl_hardware_metadata_default(), has_fast_math: false
        )
        val result = self.compile_compute_shader(builder, func)
        match result:
            case Ok(_):
                Ok(builder.build())
            case Err(e):
                Err(e)

    fn compile_device_function(func_name: text, body: MirBody) -> Result<text, CompileError>:
        Err(compileerror_backend_error(
            BackendKind.Vulkan,
            "Vulkan does not support device functions; use compute shaders instead"
        ))

    fn compile_gpu_instruction(inst: MirInst) -> text:
        panic("Vulkan compile_gpu_instruction cannot propagate CompileError; use compile_kernel")

    fn compile_barrier(scope: GpuBarrierScope) -> text:
        panic("Vulkan compile_barrier cannot propagate CompileError; use compile_kernel")

    fn compile_atomic(op: GpuAtomicOpKind, dest: LocalId, ptr: MirOperand, value: MirOperand) -> text:
        panic("Vulkan compile_atomic cannot propagate CompileError; use compile_kernel")

    fn gpu_memory_model() -> text:
        "SPIR-V GLSL450"

    fn is_kernel_function(body: MirBody) -> bool:
        val _ = body
        false

# ============================================================================
# Export
# ============================================================================
