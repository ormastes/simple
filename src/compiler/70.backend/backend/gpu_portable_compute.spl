# Portable GPU compute source emission.
#
# This is the first shared surface for CUDA/HIP-like Simple kernels that can be
# emitted as CUDA, HIP, OpenCL C, or Metal Shading Language without duplicating
# each kernel body in backend-specific modules.

enum PortableComputeTarget:
    Cuda
    Hip
    OpenCl
    Metal

enum PortableComputeValueType:
    U32
    F32

class PortableComputeArtifact:
    target: PortableComputeTarget
    entry_name: text
    source: text
    binary_format: text

    fn target_name() -> text:
        portable_compute_target_name(self.target)

    fn is_source_only() -> bool:
        self.binary_format == "source"

class PortableComputeCompilePlan:
    target: PortableComputeTarget
    entry_name: text
    required_symbols: text
    source_format: text
    binary_format: text
    tool_hint: text
    artifact_path_suffix: text

    fn target_name() -> text:
        portable_compute_target_name(self.target)

    fn produces_binary() -> bool:
        self.binary_format != "source"

class PortableComputeCompiledArtifactEvidence:
    plan: PortableComputeCompilePlan
    artifact_magic: text
    exported_symbols: text
    byte_count: i64
    artifact_valid: bool
    status_code: text
    reason: text

    static fn create(plan: PortableComputeCompilePlan, artifact_magic: text, exported_symbols: text, byte_count: i64) -> PortableComputeCompiledArtifactEvidence:
        val reason = portable_compute_compiled_artifact_reason(plan, artifact_magic, exported_symbols, byte_count)
        PortableComputeCompiledArtifactEvidence(
            plan: plan,
            artifact_magic: artifact_magic,
            exported_symbols: exported_symbols,
            byte_count: byte_count,
            artifact_valid: reason == "pass",
            status_code: if reason == "pass": "valid" else: "invalid",
            reason: reason
        )

    fn summary() -> text:
        "PortableComputeCompiledArtifactEvidence[target={self.plan.target_name()} entry={self.plan.entry_name} format={self.plan.binary_format} bytes={self.byte_count} valid={self.artifact_valid.to_text()} reason={self.reason}]"

class PortableComputeToolchainInvocation:
    plan: PortableComputeCompilePlan
    source_path: text
    output_path: text
    primary_tool_path: text
    secondary_tool_path: text
    command_line: text
    ready: bool
    reason: text

    static fn create(plan: PortableComputeCompilePlan, source_path: text, output_path: text, primary_tool_path: text, secondary_tool_path: text) -> PortableComputeToolchainInvocation:
        val reason = portable_compute_toolchain_invocation_reason(plan, source_path, output_path, primary_tool_path, secondary_tool_path)
        PortableComputeToolchainInvocation(
            plan: plan,
            source_path: source_path,
            output_path: output_path,
            primary_tool_path: primary_tool_path,
            secondary_tool_path: secondary_tool_path,
            command_line: portable_compute_toolchain_command_line(plan, source_path, output_path, primary_tool_path, secondary_tool_path),
            ready: reason == "ready_to_invoke",
            reason: reason
        )

    fn summary() -> text:
        "PortableComputeToolchainInvocation[target={self.plan.target_name()} entry={self.plan.entry_name} output={self.output_path} ready={self.ready.to_text()} reason={self.reason} command={self.command_line}]"

class PortableComputeCompileResult:
    invocation: PortableComputeToolchainInvocation
    exit_code: i64
    evidence: PortableComputeCompiledArtifactEvidence
    ready: bool
    status: text
    diagnostic: text

    static fn create(invocation: PortableComputeToolchainInvocation, exit_code: i64, evidence: PortableComputeCompiledArtifactEvidence) -> PortableComputeCompileResult:
        val status = portable_compute_compile_result_status(invocation, exit_code, evidence)
        PortableComputeCompileResult(
            invocation: invocation,
            exit_code: exit_code,
            evidence: evidence,
            ready: status == "compiled_artifact_verified",
            status: status,
            diagnostic: portable_compute_compile_result_diagnostic(invocation, exit_code, evidence, status)
        )

    fn summary() -> text:
        "PortableComputeCompileResult[target={self.invocation.plan.target_name()} entry={self.invocation.plan.entry_name} status={self.status} ready={self.ready.to_text()} diagnostic={self.diagnostic}]"

fn portable_compute_target_name(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "cuda"
        case Hip: "hip"
        case OpenCl: "opencl"
        case Metal: "metal"

fn portable_compute_binary_format(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "ptx"
        case Hip: "hsaco"
        case OpenCl: "spirv"
        case Metal: "metallib"

fn portable_compute_source_format(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "cuda-c"
        case Hip: "hip-cpp"
        case OpenCl: "opencl-c"
        case Metal: "metal-shading-language"

fn portable_compute_tool_hint(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "nvrtc-or-nvcc"
        case Hip: "hiprtc-or-hipcc"
        case OpenCl: "opencl-c-to-spirv"
        case Metal: "metal-and-metallib"

fn portable_compute_expected_artifact_magic(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: ".version"
        case Hip: "ELF"
        case OpenCl: "SPIR-V"
        case Metal: "MTLB"

fn portable_compute_u32_type(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "unsigned int"
        case Hip: "unsigned int"
        case OpenCl: "uint"
        case Metal: "uint"

fn portable_compute_global_ptr(target: PortableComputeTarget, ty: text, name: text) -> text:
    match target:
        case Cuda: "{ty}* {name}"
        case Hip: "{ty}* {name}"
        case OpenCl: "__global {ty}* {name}"
        case Metal: "device {ty}* {name} [[buffer(0)]]"

fn portable_compute_global_ptr_at(target: PortableComputeTarget, ty: text, name: text, binding: i64) -> text:
    match target:
        case Metal: "device {ty}* {name} [[buffer({binding})]]"
        case _: portable_compute_global_ptr(target, ty, name)

fn portable_compute_const_ptr(target: PortableComputeTarget, ty: text, name: text, binding: i64) -> text:
    match target:
        case Cuda: "const {ty}* {name}"
        case Hip: "const {ty}* {name}"
        case OpenCl: "__global const {ty}* {name}"
        case Metal: "device const {ty}* {name} [[buffer({binding})]]"

fn portable_compute_index_expr(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "blockIdx.x * blockDim.x + threadIdx.x"
        case Hip: "blockIdx.x * blockDim.x + threadIdx.x"
        case OpenCl: "get_global_id(0)"
        case Metal: "gid"

fn portable_compute_kernel_prefix(target: PortableComputeTarget, name: text, params: text) -> text:
    match target:
        case Cuda: "extern \"C\" __global__ void {name}({params})"
        case Hip: "extern \"C\" __global__ void {name}({params})"
        case OpenCl: "__kernel void {name}({params})"
        case Metal: "kernel void {name}({params}, uint gid [[thread_position_in_grid]])"

fn emit_portable_u32_fill_kernel(target: PortableComputeTarget, name: text) -> PortableComputeArtifact:
    val ty = portable_compute_u32_type(target)
    val dst = portable_compute_global_ptr(target, ty, "dst")
    val params = "{dst}, {ty} value, uint count"
    val prefix = portable_compute_kernel_prefix(target, name, params)
    val idx = portable_compute_index_expr(target)
    val source = "{prefix} {\n    uint i = {idx};\n    if (i >= count) {\n        return;\n    }\n    dst[i] = value;\n}\n"
    PortableComputeArtifact(
        target: target,
        entry_name: name,
        source: source,
        binary_format: portable_compute_binary_format(target)
    )

fn emit_portable_u32_add_kernel(target: PortableComputeTarget, name: text) -> PortableComputeArtifact:
    val ty = portable_compute_u32_type(target)
    val a = portable_compute_const_ptr(target, ty, "a", 0)
    val b = portable_compute_const_ptr(target, ty, "b", 1)
    val out_binding = if target == PortableComputeTarget.Metal: 2 else: 0
    val out = portable_compute_global_ptr(target, ty, "out")
    val params = match target:
        case Metal: "{a}, {b}, device {ty}* out [[buffer({out_binding})]], uint count"
        case _: "{a}, {b}, {out}, uint count"
    val prefix = portable_compute_kernel_prefix(target, name, params)
    val idx = portable_compute_index_expr(target)
    val source = "{prefix} {\n    uint i = {idx};\n    if (i >= count) {\n        return;\n    }\n    out[i] = a[i] + b[i];\n}\n"
    PortableComputeArtifact(
        target: target,
        entry_name: name,
        source: source,
        binary_format: portable_compute_binary_format(target)
    )

fn portable_compute_compile_plan(artifact: PortableComputeArtifact, output_stem: text) -> PortableComputeCompilePlan:
    PortableComputeCompilePlan(
        target: artifact.target,
        entry_name: artifact.entry_name,
        required_symbols: artifact.entry_name,
        source_format: portable_compute_source_format(artifact.target),
        binary_format: artifact.binary_format,
        tool_hint: portable_compute_tool_hint(artifact.target),
        artifact_path_suffix: "{output_stem}.{artifact.binary_format}"
    )

fn portable_compute_compile_plan_with_required_symbols(artifact: PortableComputeArtifact, output_stem: text, required_symbols: text) -> PortableComputeCompilePlan:
    PortableComputeCompilePlan(
        target: artifact.target,
        entry_name: artifact.entry_name,
        required_symbols: required_symbols,
        source_format: portable_compute_source_format(artifact.target),
        binary_format: artifact.binary_format,
        tool_hint: portable_compute_tool_hint(artifact.target),
        artifact_path_suffix: "{output_stem}.{artifact.binary_format}"
    )

fn portable_compute_required_symbols_reason(required_symbols: text, exported_symbols: text) -> text:
    if required_symbols == "":
        return "missing-required-symbols"
    if required_symbols.contains("simple_2d_fill_u32") and not exported_symbols.contains("simple_2d_fill_u32"):
        return "missing-entry-symbol:simple_2d_fill_u32"
    if required_symbols.contains("simple_2d_copy_u32") and not exported_symbols.contains("simple_2d_copy_u32"):
        return "missing-entry-symbol:simple_2d_copy_u32"
    if required_symbols.contains("simple_2d_alpha_u32") and not exported_symbols.contains("simple_2d_alpha_u32"):
        return "missing-entry-symbol:simple_2d_alpha_u32"
    if required_symbols.contains("simple_2d_scroll_u32") and not exported_symbols.contains("simple_2d_scroll_u32"):
        return "missing-entry-symbol:simple_2d_scroll_u32"
    if required_symbols.contains("simple_2d_fill_u32") or required_symbols.contains("simple_2d_copy_u32") or required_symbols.contains("simple_2d_alpha_u32") or required_symbols.contains("simple_2d_scroll_u32"):
        return "pass"
    if not exported_symbols.contains(required_symbols):
        return "missing-entry-symbol"
    "pass"

fn portable_compute_compiled_artifact_reason(plan: PortableComputeCompilePlan, artifact_magic: text, exported_symbols: text, byte_count: i64) -> text:
    if plan.entry_name == "":
        return "missing-entry-name"
    if not plan.produces_binary():
        return "source-only-plan"
    if byte_count <= 0:
        return "missing-artifact-bytes"
    if artifact_magic == "":
        return "missing-artifact-magic"
    if not artifact_magic.contains(portable_compute_expected_artifact_magic(plan.target)):
        return "artifact-magic-mismatch"
    if exported_symbols == "":
        return "missing-exported-symbols"
    portable_compute_required_symbols_reason(plan.required_symbols, exported_symbols)

fn portable_compute_compiled_artifact_evidence(plan: PortableComputeCompilePlan, artifact_magic: text, exported_symbols: text, byte_count: i64) -> PortableComputeCompiledArtifactEvidence:
    PortableComputeCompiledArtifactEvidence.create(plan, artifact_magic, exported_symbols, byte_count)

fn portable_compute_default_source_suffix(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: ".cu"
        case Hip: ".hip.cpp"
        case OpenCl: ".cl"
        case Metal: ".metal"

fn portable_compute_toolchain_invocation_reason(plan: PortableComputeCompilePlan, source_path: text, output_path: text, primary_tool_path: text, secondary_tool_path: text) -> text:
    if plan.entry_name == "":
        return "missing-entry-name"
    if source_path == "":
        return "missing-source-path"
    if output_path == "":
        return "missing-output-path"
    if primary_tool_path == "":
        return "missing-primary-tool"
    if plan.target == PortableComputeTarget.Metal and secondary_tool_path == "":
        return "missing-metallib-tool"
    "ready_to_invoke"

fn portable_compute_toolchain_command_line(plan: PortableComputeCompilePlan, source_path: text, output_path: text, primary_tool_path: text, secondary_tool_path: text) -> text:
    if plan.target == PortableComputeTarget.Cuda:
        return "{primary_tool_path} --ptx --device-c --entry {plan.entry_name} -o {output_path} {source_path}"
    if plan.target == PortableComputeTarget.Hip:
        return "{primary_tool_path} --genco --offload-arch=gfx1100 -o {output_path} {source_path}"
    if plan.target == PortableComputeTarget.OpenCl:
        return "{primary_tool_path} -cl-std=CL2.0 -emit-spirv -o {output_path} {source_path}"
    if plan.target == PortableComputeTarget.Metal:
        return "{primary_tool_path} -c {source_path} -o {output_path}.air && {secondary_tool_path} {output_path}.air -o {output_path}"
    ""

fn portable_compute_toolchain_invocation(plan: PortableComputeCompilePlan, source_path: text, output_path: text, primary_tool_path: text, secondary_tool_path: text) -> PortableComputeToolchainInvocation:
    PortableComputeToolchainInvocation.create(plan, source_path, output_path, primary_tool_path, secondary_tool_path)

fn portable_compute_compile_result_status(invocation: PortableComputeToolchainInvocation, exit_code: i64, evidence: PortableComputeCompiledArtifactEvidence) -> text:
    if not invocation.ready:
        return invocation.reason
    if exit_code != 0:
        return "toolchain_failed"
    if not evidence.artifact_valid:
        return evidence.reason
    "compiled_artifact_verified"

fn portable_compute_compile_result_diagnostic(invocation: PortableComputeToolchainInvocation, exit_code: i64, evidence: PortableComputeCompiledArtifactEvidence, status: text) -> text:
    if status == "compiled_artifact_verified":
        return ""
    if status == "toolchain_failed":
        return "toolchain exited with code {exit_code}: {invocation.command_line}"
    if not invocation.ready:
        return "cannot invoke {invocation.plan.target_name()} compiler: {invocation.reason}"
    "compiled artifact rejected: {evidence.reason}"

fn portable_compute_compile_result(invocation: PortableComputeToolchainInvocation, exit_code: i64, evidence: PortableComputeCompiledArtifactEvidence) -> PortableComputeCompileResult:
    PortableComputeCompileResult.create(invocation, exit_code, evidence)

fn emit_portable_2d_fill_u32_kernel(target: PortableComputeTarget) -> PortableComputeArtifact:
    emit_portable_u32_fill_kernel(target, "simple_2d_fill_u32")

fn emit_portable_2d_copy_u32_kernel(target: PortableComputeTarget) -> PortableComputeArtifact:
    val ty = portable_compute_u32_type(target)
    val src = portable_compute_const_ptr(target, ty, "src", 0)
    val dst = portable_compute_global_ptr_at(target, ty, "dst", 1)
    val params = "{src}, {dst}, uint count"
    val prefix = portable_compute_kernel_prefix(target, "simple_2d_copy_u32", params)
    val idx = portable_compute_index_expr(target)
    val source = "{prefix} {\n    uint i = {idx};\n    if (i >= count) {\n        return;\n    }\n    dst[i] = src[i];\n}\n"
    PortableComputeArtifact(
        target: target,
        entry_name: "simple_2d_copy_u32",
        source: source,
        binary_format: portable_compute_binary_format(target)
    )

fn emit_portable_2d_alpha_u32_kernel(target: PortableComputeTarget) -> PortableComputeArtifact:
    val ty = portable_compute_u32_type(target)
    val src = portable_compute_const_ptr(target, ty, "src", 0)
    val dst = portable_compute_global_ptr_at(target, ty, "dst", 1)
    val params = "{src}, {dst}, uint alpha, uint count"
    val prefix = portable_compute_kernel_prefix(target, "simple_2d_alpha_u32", params)
    val idx = portable_compute_index_expr(target)
    val source = "{prefix} {\n    uint i = {idx};\n    if (i >= count) {\n        return;\n    }\n    uint s = src[i];\n    uint d = dst[i];\n    uint inv = 255u - alpha;\n    uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;\n    uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;\n    dst[i] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);\n}\n"
    PortableComputeArtifact(
        target: target,
        entry_name: "simple_2d_alpha_u32",
        source: source,
        binary_format: portable_compute_binary_format(target)
    )

fn emit_portable_2d_scroll_u32_kernel(target: PortableComputeTarget) -> PortableComputeArtifact:
    val ty = portable_compute_u32_type(target)
    val src = portable_compute_const_ptr(target, ty, "src", 0)
    val dst = portable_compute_global_ptr_at(target, ty, "dst", 1)
    val params = "{src}, {dst}, uint width, uint height, int delta_y"
    val prefix = portable_compute_kernel_prefix(target, "simple_2d_scroll_u32", params)
    val idx = portable_compute_index_expr(target)
    val source = "{prefix} {\n    uint i = {idx};\n    uint count = width * height;\n    if (i >= count) {\n        return;\n    }\n    uint x = i % width;\n    uint y = i / width;\n    int sy = int(y) - delta_y;\n    if (sy < 0 || sy >= int(height)) {\n        dst[i] = 0u;\n        return;\n    }\n    dst[i] = src[uint(sy) * width + x];\n}\n"
    PortableComputeArtifact(
        target: target,
        entry_name: "simple_2d_scroll_u32",
        source: source,
        binary_format: portable_compute_binary_format(target)
    )

fn emit_portable_2d_optimization_kernels(target: PortableComputeTarget) -> [PortableComputeArtifact]:
    [
        emit_portable_2d_fill_u32_kernel(target),
        emit_portable_2d_copy_u32_kernel(target),
        emit_portable_2d_alpha_u32_kernel(target),
        emit_portable_2d_scroll_u32_kernel(target)
    ]

fn portable_compute_2d_required_symbols() -> text:
    "simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32"

fn emit_portable_2d_optimization_module(target: PortableComputeTarget) -> PortableComputeArtifact:
    val fill = emit_portable_2d_fill_u32_kernel(target)
    val copy = emit_portable_2d_copy_u32_kernel(target)
    val alpha = emit_portable_2d_alpha_u32_kernel(target)
    val scroll = emit_portable_2d_scroll_u32_kernel(target)
    PortableComputeArtifact(
        target: target,
        entry_name: "simple_2d_fill_u32",
        source: "{fill.source}\n{copy.source}\n{alpha.source}\n{scroll.source}",
        binary_format: portable_compute_binary_format(target)
    )

fn portable_compute_2d_optimization_compile_plan(target: PortableComputeTarget, output_stem: text) -> PortableComputeCompilePlan:
    portable_compute_compile_plan_with_required_symbols(
        emit_portable_2d_optimization_module(target),
        output_stem,
        portable_compute_2d_required_symbols()
    )

fn emit_portable_compute_smoke_matrix() -> [PortableComputeArtifact]:
    [
        emit_portable_2d_optimization_module(PortableComputeTarget.Cuda),
        emit_portable_2d_optimization_module(PortableComputeTarget.Hip),
        emit_portable_2d_optimization_module(PortableComputeTarget.OpenCl),
        emit_portable_2d_optimization_module(PortableComputeTarget.Metal)
    ]
