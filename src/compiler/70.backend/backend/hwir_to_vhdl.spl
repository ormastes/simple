# HWIR to VHDL Bridge — non-invasive bridge to the existing VHDL backend.

use compiler.mir.hwir.types.{HwModule, HwPort}

class HwirVhdlBridgeResult:
    """Result of translating or deferring an HWIR module."""
    used_hwir: bool
    module_name: text
    vhdl: text
    fallback_function: text
    diagnostic: text

    me uses_existing_path() -> bool:
        return not self.used_hwir

    static fn fallback(module: HwModule, diagnostic: text) -> HwirVhdlBridgeResult:
        return HwirVhdlBridgeResult(used_hwir: false, module_name: module.name, vhdl: "", fallback_function: module.fallback_function, diagnostic: diagnostic)

    static fn emitted(module: HwModule, vhdl: text) -> HwirVhdlBridgeResult:
        return HwirVhdlBridgeResult(used_hwir: true, module_name: module.name, vhdl: vhdl, fallback_function: module.fallback_function, diagnostic: "")

fn hwir_bridge_preserve_existing_vhdl(module: HwModule) -> HwirVhdlBridgeResult:
    """Return a fallback bridge result for callers that have not opted into HWIR."""
    return HwirVhdlBridgeResult.fallback(module, "HWIR bridge not selected; preserve existing VHDL compile path")

fn render_hwir_port(port: HwPort) -> text:
    """Render one HWIR port declaration using VHDL-2008 syntax."""
    return "        " + port.name + " : " + port.direction + " " + port.vhdl_type()

fn render_empty_hwir_entity(module: HwModule) -> HwirVhdlBridgeResult:
    """Render a minimal entity for smoke tests of the HWIR bridge.

    Production code emission still routes through the existing VHDL builder once
    the compiler selects HWIR lowering for a concrete function.
    """
    val vhdl = "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\n\nentity " + module.name + " is\nend entity " + module.name + ";\n\narchitecture rtl of " + module.name + " is\nbegin\nend architecture rtl;\n"
    return HwirVhdlBridgeResult.emitted(module, vhdl)
