# src/compiler/70.backend/backend/native/encode_rvv_mask.spl
#
# RVV v1.0 Mask Logic Byte-Emit Encoder — Pure Simple
#
# Produces exact 4-byte little-endian instruction words for RISC-V Vector
# mask-register logical instructions and mask population/find-first ops
# per RVV v1.0.
#
# Reference: RISC-V Vector Extension v1.0
#   §11.15 Vector Mask-Register Logical Instructions
#   §11.16 Vector count population in mask / find-first set mask bit
#
# Instruction format (all 32-bit, OP-V major opcode 0x57):
#   bits[31:26] = funct6
#   bit[25]     = vm   (0=mask-mask ops have no governing mask)
#   bits[24:20] = vs2
#   bits[19:15] = vs1 (or sub-op code for VWXUNARY0)
#   bits[14:12] = funct3 (OPMVV=010=2)
#   bits[11:7]  = vd (or rd for vcpop/vfirst which write integer registers)
#   bits[6:0]   = opcode 0x57
#
# funct6/funct3 values (RVV v1.0 §11.15):
#   vmand.mm   0x19 (011001)  OPMVV funct3=2  vm=0  mask AND
#   vmnand.mm  0x1D (011101)  OPMVV funct3=2  vm=0  mask NAND
#   vmandn.mm  0x18 (011000)  OPMVV funct3=2  vm=0  mask AND-NOT
#   vmor.mm    0x1A (011010)  OPMVV funct3=2  vm=0  mask OR
#   vmnor.mm   0x1E (011110)  OPMVV funct3=2  vm=0  mask NOR
#   vmorn.mm   0x1C (011100)  OPMVV funct3=2  vm=0  mask OR-NOT
#   vmxor.mm   0x1B (011011)  OPMVV funct3=2  vm=0  mask XOR
#   vmxnor.mm  0x1F (011111)  OPMVV funct3=2  vm=0  mask XNOR
#
# funct6/vs1 values for VWXUNARY0 (RVV v1.0 §11.16):
#   vcpop.m    funct6=0x10 (010000)  OPMVV funct3=2  vm=1  vs1=16 (10000)
#   vfirst.m   funct6=0x10 (010000)  OPMVV funct3=2  vm=1  vs1=17 (10001)
#
# Encoding convention: multiplication/division only (avoids negative-bit-op
# hazards in interpreter mode). Consistent with encode_rvv_zvk.spl and
# encode_rvv_widen.spl.
#
# Return type: [i64] (4 bytes, little-endian).
#
# ALL byte goldens derived from RVV v1.0 spec table + manual derivation formula
# (llvm-mc unavailable on build host).
# ============================================================================
# Internal helpers (independent copy; encode_rvv_zvk.spl is a separate module)
# ============================================================================

fn _rvv_mask_word_to_le4(word: i64) -> [i64]:
    """
    Convert a 32-bit mask instruction word to 4 little-endian bytes.
    Uses division/modulo to avoid negative bit-op hazards in interpreter.
    """
    var w = word
    if w < 0:
        w = w + 4294967296
    val b0 = w % 256
    val b1 = (w / 256) % 256
    val b2 = (w / 65536) % 256
    val b3 = (w / 16777216) % 256
    [b0, b1, b2, b3]

fn _encode_rvv_mask(funct6: i64, vm: i64, vs2: i64, vs1: i64, vd: i64) -> [i64]:
    """
    Encode an OP-V mask instruction (opcode=0x57=87, funct3=OPMVV=2).

    funct6: 6-bit function code (bits[31:26])
    vm:     bit[25] (0 for mask-mask ops, 1 for vcpop/vfirst)
    vs2:    source register 2 (bits[24:20])
    vs1:    source register 1 or sub-op (bits[19:15])
    vd:     destination register or rd (bits[11:7])
    """
    val word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576) + (vs1 * 32768) + (2 * 4096) + (vd * 128) + 87
    _rvv_mask_word_to_le4(word)

# ============================================================================
# Mask-Register Logical Instructions (RVV v1.0 §11.15)
# ============================================================================

# RVV v1.0 §11.15 vmand.mm; funct6=0x19 (011001); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x6421A0D7 LE [0xD7,0xA0,0x21,0x64]
fn emit_vmand_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask AND: vd.mask = vs2.mask AND vs1.mask."""
    _encode_rvv_mask(0x19, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmnand.mm; funct6=0x1D (011101); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x7421A0D7 LE [0xD7,0xA0,0x21,0x74]
fn emit_vmnand_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask NAND: vd.mask = NOT (vs2.mask AND vs1.mask)."""
    _encode_rvv_mask(0x1D, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmandn.mm; funct6=0x18 (011000); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x6021A0D7 LE [0xD7,0xA0,0x21,0x60]
fn emit_vmand_not_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask AND-NOT: vd.mask = vs2.mask AND NOT vs1.mask."""
    _encode_rvv_mask(0x18, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmor.mm; funct6=0x1A (011010); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x6821A0D7 LE [0xD7,0xA0,0x21,0x68]
fn emit_vmor_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask OR: vd.mask = vs2.mask OR vs1.mask."""
    _encode_rvv_mask(0x1A, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmnor.mm; funct6=0x1E (011110); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x7821A0D7 LE [0xD7,0xA0,0x21,0x78]
fn emit_vmnor_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask NOR: vd.mask = NOT (vs2.mask OR vs1.mask)."""
    _encode_rvv_mask(0x1E, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmorn.mm; funct6=0x1C (011100); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x7021A0D7 LE [0xD7,0xA0,0x21,0x70]
fn emit_vmor_not_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask OR-NOT: vd.mask = vs2.mask OR NOT vs1.mask."""
    _encode_rvv_mask(0x1C, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmxor.mm; funct6=0x1B (011011); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x6C21A0D7 LE [0xD7,0xA0,0x21,0x6C]
fn emit_vmxor_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask XOR: vd.mask = vs2.mask XOR vs1.mask."""
    _encode_rvv_mask(0x1B, 0, vs2, vs1, vd)

# RVV v1.0 §11.15 vmxnor.mm; funct6=0x1F (011111); OPMVV funct3=2; vm=0
# Canonical (vd=1, vs2=2, vs1=3): word=0x7C21A0D7 LE [0xD7,0xA0,0x21,0x7C]
fn emit_vmxnor_mm(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    """Mask XNOR: vd.mask = NOT (vs2.mask XOR vs1.mask)."""
    _encode_rvv_mask(0x1F, 0, vs2, vs1, vd)

# ============================================================================
# Mask Population / Find-First (RVV v1.0 §11.16, VWXUNARY0)
# ============================================================================

# RVV v1.0 §11.16 vcpop.m; funct6=0x10 (010000); OPMVV funct3=2; vm=1; vs1=16
# Canonical (rd=1, vs2=2): word=0x422820D7 LE [0xD7,0x20,0x28,0x42]
fn emit_vcpop_m(rd: i64, vs2: i64) -> [i64]:
    """Count population of mask: rd = popcount(vs2.mask)."""
    _encode_rvv_mask(0x10, 1, vs2, 16, rd)

# RVV v1.0 §11.16 vfirst.m; funct6=0x10 (010000); OPMVV funct3=2; vm=1; vs1=17
# Canonical (rd=1, vs2=2): word=0x4228A0D7 LE [0xD7,0xA0,0x28,0x42]
fn emit_vfirst_m(rd: i64, vs2: i64) -> [i64]:
    """Find first set mask bit: rd = index of lowest set bit in vs2.mask (-1 if none)."""
    _encode_rvv_mask(0x10, 1, vs2, 17, rd)

# ============================================================================
# Exports
# ============================================================================

export emit_vmand_mm
export emit_vmnand_mm
export emit_vmand_not_mm
export emit_vmor_mm
export emit_vmnor_mm
export emit_vmor_not_mm
export emit_vmxor_mm
export emit_vmxnor_mm
export emit_vcpop_m
export emit_vfirst_m
