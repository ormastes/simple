# AArch64 NEON Comparison and Bitwise-Select Byte Emitter — Pure Simple
#
# Emits 4-byte little-endian instruction words for AArch64 Advanced SIMD
# comparison and BSL operations (ARMv8-A NEON).
#
# All return [i64] of length 4 (LE bytes, byte0=bits[7:0]).
#
# Register encoding: Vd (rd) in bits[4:0], Vn (rn) in bits[9:5], Vm (rm) in bits[20:16].
#
# Reference: ARM Architecture Reference Manual, ARMv8-A, §C7.2.
# SIMD three-same format: 0_Q_U_01110_size_1_Rm_opcode_1_Rn_Rd

# ============================================================================
# Helper — pack a 32-bit word into 4 LE bytes
# ============================================================================

"""Pack a 32-bit instruction word into a 4-element little-endian [i64] array.

Bit 0 of w goes into index 0 (lowest address), bit 31 into index 3.
"""
fn _neon_cmp_word_to_bytes(w: i64) -> [i64]:
    [w & 0xFF, (w >> 8) & 0xFF, (w >> 16) & 0xFF, (w >> 24) & 0xFF]

# ============================================================================
# Comparison — three-register V.4S (128-bit, 4x32-bit lanes)
# ============================================================================

"""Emit CMEQ Vd.4S, Vn.4S, Vm.4S — compare equal, 4x32-bit lanes.

Opcode base: 0x6EA08C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=10_1_Rm_10001_1_Rn_Rd
ARMv8-A ARM §C7.2.27 CMEQ (register).
"""
fn emit_cmeq_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6EA08C00 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

"""Emit CMGT Vd.4S, Vn.4S, Vm.4S — compare signed greater-than, 4x32-bit lanes.

Opcode base: 0x4EA03400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_00110_1_Rn_Rd
ARMv8-A ARM §C7.2.33 CMGT (register).
"""
fn emit_cmgt_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA03400 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

"""Emit CMGE Vd.4S, Vn.4S, Vm.4S — compare signed greater-than-or-equal, 4x32-bit lanes.

Opcode base: 0x4EA03C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_00111_1_Rn_Rd
ARMv8-A ARM §C7.2.30 CMGE (register).
"""
fn emit_cmge_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA03C00 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

"""Emit CMHI Vd.4S, Vn.4S, Vm.4S — compare unsigned higher, 4x32-bit lanes.

Opcode base: 0x6EA03400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=10_1_Rm_00110_1_Rn_Rd
ARMv8-A ARM §C7.2.36 CMHI (register).
"""
fn emit_cmhi_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6EA03400 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

# ============================================================================
# Floating-point comparison — three-register V.4S (128-bit, 4x32-bit lanes)
# ============================================================================

"""Emit FCMEQ Vd.4S, Vn.4S, Vm.4S — floating-point compare equal, 4x32-bit lanes.

Opcode base: 0x4E20E400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_a=0_sz=0_1_Rm_11100_1_Rn_Rd
ARMv8-A ARM §C7.2.79 FCMEQ (register).
"""
fn emit_fcmeq_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4E20E400 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

"""Emit FCMGT Vd.4S, Vn.4S, Vm.4S — floating-point compare greater-than, 4x32-bit lanes.

Opcode base: 0x6EA0E400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_a=1_sz=0_1_Rm_11100_1_Rn_Rd
ARMv8-A ARM §C7.2.85 FCMGT (register).
"""
fn emit_fcmgt_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6EA0E400 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

"""Emit FCMGE Vd.4S, Vn.4S, Vm.4S — floating-point compare greater-than-or-equal, 4x32-bit lanes.

Opcode base: 0x6E20E400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_a=0_sz=0_1_Rm_11100_1_Rn_Rd
ARMv8-A ARM §C7.2.82 FCMGE (register).
"""
fn emit_fcmge_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6E20E400 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)

# ============================================================================
# Bitwise select — three-register V.16B (128-bit)
# ============================================================================

"""Emit BSL Vd.16B, Vn.16B, Vm.16B — bitwise select 128-bit.

Opcode base: 0x6E601C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=01_1_Rm_00011_1_Rn_Rd
ARMv8-A ARM §C7.2.22 BSL.
"""
fn emit_bsl_16b(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6E601C00 | (rm << 16) | (rn << 5) | rd
    _neon_cmp_word_to_bytes(w)
