# AArch64 NEON Integer Arithmetic Byte Emitter — Pure Simple
#
# Emits 4-byte little-endian instruction words for AArch64 Advanced SIMD
# integer arithmetic operations (ARMv8-A NEON).
#
# All return [i64] of length 4 (LE bytes, byte0=bits[7:0]).
#
# Register encoding: Vd (rd) in bits[4:0], Vn (rn) in bits[9:5], Vm (rm) in bits[20:16].
# Immediate shift: imm encoded in bits[20:16] per instruction format.
#
# NOTE: ADD and MUL corrected vs naive copy: ADD V.4S base is 0x4EA08400 (opcode=10000,
# size=10, U=0, Q=1); MUL V.4S base is 0x4EA09C00 (opcode=10011, size=10, U=0, Q=1).
# The "4E20xxxx" pattern encodes size=00 (8-bit elements), not 32-bit.
#
# Reference: ARM Architecture Reference Manual, ARMv8-A, §C7.2.
# SIMD three-same format: 0_Q_U_01110_size_1_Rm_opcode_1_Rn_Rd

# ============================================================================
# Helper — pack a 32-bit word into 4 LE bytes
# ============================================================================

"""Pack a 32-bit instruction word into a 4-element little-endian [i64] array.

Bit 0 of w goes into index 0 (lowest address), bit 31 into index 3.
"""
fn _aarch64_word_to_bytes(w: i64) -> [i64]:
    [w & 0xFF, (w >> 8) & 0xFF, (w >> 16) & 0xFF, (w >> 24) & 0xFF]

# ============================================================================
# Integer arithmetic — three-register V.4S (128-bit, 4x32-bit lanes)
# ============================================================================

"""Emit ADD Vd.4S, Vn.4S, Vm.4S — integer add 4x32-bit lanes.

Opcode base: 0x4EA08400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_10000_1_Rn_Rd
ARMv8-A ARM §C7.2.2 ADD (vector).
"""
fn emit_addv_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA08400 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit SUB Vd.4S, Vn.4S, Vm.4S — integer subtract 4x32-bit lanes.

Opcode base: 0x6EA08400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=10_1_Rm_10000_1_Rn_Rd (U=1 sets bit 29)
ARMv8-A ARM §C7.2.318 SUB (vector).
"""
fn emit_subv_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6EA08400 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit MUL Vd.4S, Vn.4S, Vm.4S — integer multiply 4x32-bit lanes.

Opcode base: 0x4EA09C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_10011_1_Rn_Rd
ARMv8-A ARM §C7.2.192 MUL (vector).
"""
fn emit_mulv_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA09C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# Logical — three-register V.16B (128-bit, bitwise)
# ============================================================================

"""Emit AND Vd.16B, Vn.16B, Vm.16B — bitwise AND 128-bit.

Opcode base: 0x4E201C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=00_1_Rm_00011_1_Rn_Rd
ARMv8-A ARM §C7.2.7 AND (vector).
"""
fn emit_andv_16b(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4E201C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit ORR Vd.16B, Vn.16B, Vm.16B — bitwise OR 128-bit.

Opcode base: 0x4EA01C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_00011_1_Rn_Rd
ARMv8-A ARM §C7.2.197 ORR (vector register).
"""
fn emit_orrv_16b(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA01C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit EOR Vd.16B, Vn.16B, Vm.16B — bitwise XOR 128-bit.

Opcode base: 0x6E201C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=00_1_Rm_00011_1_Rn_Rd
ARMv8-A ARM §C7.2.75 EOR (vector).
"""
fn emit_eorv_16b(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6E201C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# Shift immediates — V.4S (128-bit, 4x32-bit lanes)
# ============================================================================

"""Emit SHL Vd.4S, Vn.4S, #imm — left shift by immediate, 4x32-bit lanes.

Opcode base: 0x4F205400 | ((imm & 0x1F) << 16) | (Rn << 5) | Rd
imm range: 0..31. Encoded as (immh:immb) = 32 + imm; bit 21 (immh[0]) already set in base.
ARMv8-A ARM §C7.2.269 SHL.
"""
fn emit_shlv_4s(rd: i64, rn: i64, imm: i64) -> [i64]:
    var w = 0x4F205400 | ((imm & 0x1F) << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit SSHR Vd.4S, Vn.4S, #imm — signed right shift by immediate, 4x32-bit lanes.

Opcode base: 0x4F200400 | (((32 - imm) & 0x1F) << 16) | (Rn << 5) | Rd
imm range: 1..32. Encoded as (immh:immb) = 64 - imm; bits 20:16 = (32 - imm).
ARMv8-A ARM §C7.2.279 SSHR.
"""
fn emit_sshrv_4s(rd: i64, rn: i64, imm: i64) -> [i64]:
    var w = 0x4F200400 | (((32 - imm) & 0x1F) << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# Comparison — three-register V.4S (128-bit, 4x32-bit lanes)
# ============================================================================

"""Emit CMEQ Vd.4S, Vn.4S, Vm.4S — compare equal, 4x32-bit lanes.

Opcode base: 0x6EA08C00 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=1_01110_size=10_1_Rm_10001_1_Rn_Rd
ARMv8-A ARM §C7.2.27 CMEQ (register).
"""
fn emit_cmpeqv_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x6EA08C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit CMGT Vd.4S, Vn.4S, Vm.4S — compare signed greater-than, 4x32-bit lanes.

Opcode base: 0x4EA03400 | (Rm << 16) | (Rn << 5) | Rd
Format: 0_Q=1_U=0_01110_size=10_1_Rm_00110_1_Rn_Rd
ARMv8-A ARM §C7.2.33 CMGT (register).
"""
fn emit_cmgtv_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EA03400 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)
