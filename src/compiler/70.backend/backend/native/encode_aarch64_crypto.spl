# AArch64 Crypto Byte Emitter — Pure Simple
#
# Emits 4-byte little-endian instruction words for AArch64 crypto ISA extensions:
# AES (ARMv8 Cryptography Extension), SHA-256 (SHA2), PMULL (carry-less multiply),
# CRC32 (ARMv8.1 CRC32 extension).
#
# All return [i64] of length 4 (LE bytes, byte0=bits[7:0]).
#
# Register encoding:
#   AESE/AESD/AESMC/AESIMC: Vd (rd), Vn (rn)  — 2-reg, rn in bits[9:5], rd in bits[4:0]
#   SHA256H/H2/SU0/SU1:     Qd (rd), Qn (rn), Vm (rm)
#   PMULL/PMULL2:           Vd (rd), Vn (rn), Vm (rm)
#   CRC32B/H/W/X:           Wd (rd), Wn (rn), Wm/Xm (rm)
#
# Reference: ARM Architecture Reference Manual, ARMv8-A, C3.6/C7.2.

# ============================================================================
# Helper — pack a 32-bit word into 4 LE bytes
# ============================================================================

"""Pack a 32-bit instruction word into a 4-element little-endian [i64] array.

Bit 0 of w goes into index 0 (lowest address), bit 31 into index 3.
"""
fn _aarch64_word_to_bytes(w: i64) -> [i64]:
    [w & 0xFF, (w >> 8) & 0xFF, (w >> 16) & 0xFF, (w >> 24) & 0xFF]

# ============================================================================
# AES instructions (ARMv8 Cryptography Extension)
# ============================================================================

"""Emit AESE Vd.16B, Vn.16B — AES single-round encryption.

Opcode base: 0x4E284800 | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.5 AESE.
"""
fn emit_aese(rd: i64, rn: i64) -> [i64]:
    var w = 0x4E284800 | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit AESD Vd.16B, Vn.16B — AES single-round decryption.

Opcode base: 0x4E285800 | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.3 AESD.
"""
fn emit_aesd(rd: i64, rn: i64) -> [i64]:
    var w = 0x4E285800 | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit AESMC Vd.16B, Vn.16B — AES mix columns.

Opcode base: 0x4E286800 | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.7 AESMC.
"""
fn emit_aesmc(rd: i64, rn: i64) -> [i64]:
    var w = 0x4E286800 | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit AESIMC Vd.16B, Vn.16B — AES inverse mix columns.

Opcode base: 0x4E287800 | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.6 AESIMC.
"""
fn emit_aesimc_a64(rd: i64, rn: i64) -> [i64]:
    var w = 0x4E287800 | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# SHA-256 instructions (ARMv8 SHA2 extension)
# ============================================================================

"""Emit SHA256H Qd, Qn, Vm.4S — SHA-256 hash update part 1.

Opcode base: 0x5E004000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.231 SHA256H.
"""
fn emit_sha256h(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x5E004000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit SHA256H2 Qd, Qn, Vm.4S — SHA-256 hash update part 2.

Opcode base: 0x5E005000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.232 SHA256H2.
"""
fn emit_sha256h2(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x5E005000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit SHA256SU0 Vd.4S, Vn.4S — SHA-256 schedule update 0.

Opcode base: 0x5E282800 | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.233 SHA256SU0.
"""
fn emit_sha256su0(rd: i64, rn: i64) -> [i64]:
    var w = 0x5E282800 | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit SHA256SU1 Vd.4S, Vn.4S, Vm.4S — SHA-256 schedule update 1.

Opcode base: 0x5E006000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.234 SHA256SU1.
"""
fn emit_sha256su1(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x5E006000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# PMULL / PMULL2 (carry-less multiply — ARMv8 Cryptography Extension)
# ============================================================================

"""Emit PMULL Vd.1Q, Vn.1D, Vm.1D — polynomial multiply (lower halves).

Opcode base: 0x0EE0E000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.200 PMULL, PMULL2.
"""
fn emit_pmull(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x0EE0E000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit PMULL2 Vd.1Q, Vn.2D, Vm.2D — polynomial multiply (upper halves).

Opcode base: 0x4EE0E000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.200 PMULL, PMULL2.
"""
fn emit_pmull2(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x4EE0E000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

# ============================================================================
# CRC32 instructions (ARMv8.1 CRC32 extension)
# ============================================================================

"""Emit CRC32B Wd, Wn, Wm — CRC32 byte accumulate.

Opcode base: 0x1AC04000 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.37 CRC32B.
"""
fn emit_crc32b(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x1AC04000 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit CRC32H Wd, Wn, Wm — CRC32 halfword accumulate.

Opcode base: 0x1AC04400 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.38 CRC32H.
"""
fn emit_crc32h(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x1AC04400 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit CRC32W Wd, Wn, Wm — CRC32 word accumulate.

Opcode base: 0x1AC04800 | (Rm << 16) | (Rn << 5) | Rd
ARMv8-A ARM §C7.2.39 CRC32W.
"""
fn emit_crc32w(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x1AC04800 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)

"""Emit CRC32X Wd, Wn, Xm — CRC32 doubleword accumulate.

Opcode base: 0x9AC04C00 | (Rm << 16) | (Rn << 5) | Rd  (sf=1 form)
ARMv8-A ARM §C7.2.40 CRC32X.
"""
fn emit_crc32x(rd: i64, rn: i64, rm: i64) -> [i64]:
    var w = 0x9AC04C00 | (rm << 16) | (rn << 5) | rd
    _aarch64_word_to_bytes(w)
