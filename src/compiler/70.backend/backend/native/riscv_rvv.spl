# RVV (RISC-V Vector) Instruction Encoding — Widening Reductions
#
# Widening reduction emit helpers for RVV v1.0 §15.2.
# All instructions use OP-V format (opcode 0x57).
#
# Encoding (little-endian 4 bytes, 32-bit OP-V):
#   bits[31:26] = funct6
#   bit[25]     = vm  (1 = unmasked, 0 = masked with v0)
#   bits[24:20] = vs2
#   bits[19:15] = vs1
#   bits[14:12] = funct3  (0=OPIVV, 1=OPFVV)
#   bits[11:7]  = vd
#   bits[6:0]   = 0x57   (OP-V opcode)

use compiler.backend.native.riscv_encoding.{riscv_emit_u32_le}

# ============================================================================
# Core OP-V widening-reduction word encoder
# ============================================================================

# Encode an OP-V widening-reduction instruction word.
# RVV v1.0 §15.2: funct6[31:26] vm[25] vs2[24:20] vs1[19:15] funct3[14:12] vd[11:7] opcode[6:0]
fn _rvv_encode_widening_reduction(funct6: i64, funct3: i64, vm: i64, vd: i64, vs2: i64, vs1: i64) -> i64:
    val f6  = (funct6 and 0x3F) << 26
    val vm_ = (vm and 0x1) << 25
    val s2  = (vs2 and 0x1F) << 20
    val s1  = (vs1 and 0x1F) << 15
    val f3  = (funct3 and 0x7) << 12
    val d   = (vd and 0x1F) << 7
    val op  = 0x57
    f6 or vm_ or s2 or s1 or f3 or d or op

# ============================================================================
# Widening integer reductions (§15.2, OPIVV funct3=0)
# ============================================================================

# vwredsumu.vs vd, vs2, vs1  — funct6=0x30, OPIVV
# RVV v1.0 §15.2: unsigned widening reduction sum
fn emit_rvv_vwredsumu_vs(buf: [i64], vd: i64, vs2: i64, vs1: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_widening_reduction(0x30, 0, vm, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vwredsum.vs vd, vs2, vs1   — funct6=0x31, OPIVV
# RVV v1.0 §15.2: signed widening reduction sum
fn emit_rvv_vwredsum_vs(buf: [i64], vd: i64, vs2: i64, vs1: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_widening_reduction(0x31, 0, vm, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# ============================================================================
# Widening floating-point reductions (§15.2, OPFVV funct3=1)
# ============================================================================

# vfwredusum.vs vd, vs2, vs1 — funct6=0x31, OPFVV
# RVV v1.0 §15.2: ordered widening FP reduction sum
fn emit_rvv_vfwredusum_vs(buf: [i64], vd: i64, vs2: i64, vs1: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_widening_reduction(0x31, 1, vm, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vfwredosum.vs vd, vs2, vs1 — funct6=0x33, OPFVV
# RVV v1.0 §15.2: ordered widening FP reduction sum (ordered)
fn emit_rvv_vfwredosum_vs(buf: [i64], vd: i64, vs2: i64, vs1: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_widening_reduction(0x33, 1, vm, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# ============================================================================
# RVV indexed memory — gather (load) / scatter (store)
# RVV v1.0 §7.6: vluxei{8,16,32,64}.v / vsuxei{8,16,32,64}.v
# ============================================================================
#
# Encoding (32-bit LE):
#   bits[31:29] = nf  (0 for single segment)
#   bits[28:26] = mop (001 = unordered indexed)
#   bit[25]     = vm  (1 = unmasked, 0 = masked with v0)
#   bits[24:20] = vs2 (index register)
#   bits[19:15] = rs1 (base address register)
#   bits[14:12] = eew (index element width: 000=8, 101=16, 110=32, 111=64)
#   bits[11:7]  = vd/vs3 (destination / source data register)
#   bits[6:0]   = opcode (0x07 = load, 0x27 = store)

# Encode an indexed-memory instruction word (vluxei / vsuxei).
fn _rvv_encode_indexed(opcode: i64, eew: i64, vm: i64, vd: i64, vs2: i64, rs1: i64) -> i64:
    val mop  = (0x1 and 0x7) << 26   # mop=001 unordered indexed
    val vm_  = (vm and 0x1) << 25
    val s2   = (vs2 and 0x1F) << 20
    val r1   = (rs1 and 0x1F) << 15
    val ew   = (eew and 0x7) << 12
    val d    = (vd and 0x1F) << 7
    mop or vm_ or s2 or r1 or ew or d or (opcode and 0x7F)

# vluxei8.v vd, (rs1), vs2 — unordered indexed load, index eew=8
# RVV v1.0 §7.6: eew=000
fn emit_rvv_vluxei8_v(buf: [i64], vd: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x07, 0x0, vm, vd, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vluxei16.v vd, (rs1), vs2 — unordered indexed load, index eew=16
# RVV v1.0 §7.6: eew=101
fn emit_rvv_vluxei16_v(buf: [i64], vd: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x07, 0x5, vm, vd, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vluxei32.v vd, (rs1), vs2 — unordered indexed load, index eew=32
# RVV v1.0 §7.6: eew=110
fn emit_rvv_vluxei32_v(buf: [i64], vd: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x07, 0x6, vm, vd, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vluxei64.v vd, (rs1), vs2 — unordered indexed load, index eew=64
# RVV v1.0 §7.6: eew=111
fn emit_rvv_vluxei64_v(buf: [i64], vd: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x07, 0x7, vm, vd, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vsuxei8.v vs3, (rs1), vs2 — unordered indexed store, index eew=8
# RVV v1.0 §7.6: eew=000
fn emit_rvv_vsuxei8_v(buf: [i64], vs3: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x27, 0x0, vm, vs3, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vsuxei16.v vs3, (rs1), vs2 — unordered indexed store, index eew=16
# RVV v1.0 §7.6: eew=101
fn emit_rvv_vsuxei16_v(buf: [i64], vs3: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x27, 0x5, vm, vs3, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vsuxei32.v vs3, (rs1), vs2 — unordered indexed store, index eew=32
# RVV v1.0 §7.6: eew=110
fn emit_rvv_vsuxei32_v(buf: [i64], vs3: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x27, 0x6, vm, vs3, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# vsuxei64.v vs3, (rs1), vs2 — unordered indexed store, index eew=64
# RVV v1.0 §7.6: eew=111
fn emit_rvv_vsuxei64_v(buf: [i64], vs3: i64, rs1: i64, vs2: i64, vm: i64) -> [i64]:
    val word = _rvv_encode_indexed(0x27, 0x7, vm, vs3, vs2, rs1)
    riscv_emit_u32_le(buf, word)

# ============================================================================
# Mask logical ops (OPMVV funct3=2, vm=1 unmasked)
# RVV v1.0 §11.1: vmand/vmor/vmxor/vmnand/vmnor/vmxnor
# Encoding: funct6[31:26] 1[25] vs2[24:20] vs1[19:15] 010[14:12] vd[11:7] 0x57
# ============================================================================

# Encode a mask-logical instruction word.
fn _rvv_encode_mask_logical(funct6: i64, vd: i64, vs2: i64, vs1: i64) -> i64:
    val f6 = (funct6 and 0x3F) << 26
    val vm_ = 1 << 25
    val s2 = (vs2 and 0x1F) << 20
    val s1 = (vs1 and 0x1F) << 15
    val f3 = 2 << 12
    val d  = (vd and 0x1F) << 7
    val op = 0x57
    f6 or vm_ or s2 or s1 or f3 or d or op

# vmand.mm vd, vs2, vs1 — funct6=0x19
# RVV v1.0 §11.1: mask AND
pub fn emit_rvv_vmand_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x19, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vmor.mm vd, vs2, vs1 — funct6=0x1A
# RVV v1.0 §11.1: mask OR
pub fn emit_rvv_vmor_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x1A, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vmxor.mm vd, vs2, vs1 — funct6=0x1B
# RVV v1.0 §11.1: mask XOR
pub fn emit_rvv_vmxor_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x1B, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vmnand.mm vd, vs2, vs1 — funct6=0x1D
# RVV v1.0 §11.1: mask NAND
pub fn emit_rvv_vmnand_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x1D, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vmnor.mm vd, vs2, vs1 — funct6=0x1E
# RVV v1.0 §11.1: mask NOR
pub fn emit_rvv_vmnor_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x1E, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# vmxnor.mm vd, vs2, vs1 — funct6=0x1F
# RVV v1.0 §11.1: mask XNOR
pub fn emit_rvv_vmxnor_mm(buf: [i64], vd: i64, vs2: i64, vs1: i64) -> [i64]:
    val word = _rvv_encode_mask_logical(0x1F, vd, vs2, vs1)
    riscv_emit_u32_le(buf, word)

# ============================================================================
# Mask scan ops (OPMVV funct3=2, vm=1 unmasked, funct6=0x14)
# RVV v1.0 §16.5: vmsbf.m / vmsof.m / vmsif.m
# Encoding: funct6[31:26]=0x14, bit[25]=1(vm), vs2[24:20], vs1_op[19:15],
#           funct3[14:12]=010, vd[11:7], opcode[6:0]=0x57
# vs1_op selects op: 1=vmsbf, 2=vmsof, 3=vmsif
# ============================================================================

# Encode a mask-scan instruction word.
fn _rvv_encode_mask_scan(vs1_op: i64, vd: i64, vs2: i64) -> i64:
    val f6 = (0x14 and 0x3F) << 26
    val vm_ = 1 << 25
    val s2 = (vs2 and 0x1F) << 20
    val s1 = (vs1_op and 0x1F) << 15
    val f3 = 2 << 12
    val d  = (vd and 0x1F) << 7
    val op = 0x57
    f6 or vm_ or s2 or s1 or f3 or d or op

# vmsbf.m vd, vs2 — vs1_op=1
# RVV v1.0 §16.5: set-before-first mask bit
pub fn emit_rvv_vmsbf_m(buf: [i64], vd: i64, vs2: i64) -> [i64]:
    val word = _rvv_encode_mask_scan(1, vd, vs2)
    riscv_emit_u32_le(buf, word)

# vmsof.m vd, vs2 — vs1_op=2
# RVV v1.0 §16.5: set-only-first mask bit
pub fn emit_rvv_vmsof_m(buf: [i64], vd: i64, vs2: i64) -> [i64]:
    val word = _rvv_encode_mask_scan(2, vd, vs2)
    riscv_emit_u32_le(buf, word)

# vmsif.m vd, vs2 — vs1_op=3
# RVV v1.0 §16.5: set-including-first mask bit
pub fn emit_rvv_vmsif_m(buf: [i64], vd: i64, vs2: i64) -> [i64]:
    val word = _rvv_encode_mask_scan(3, vd, vs2)
    riscv_emit_u32_le(buf, word)
