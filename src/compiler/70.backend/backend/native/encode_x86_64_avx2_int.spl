# src/compiler/70.backend/backend/native/encode_x86_64_avx2_int.spl
#
# AVX2 Integer Instruction Byte-Emit Encoder — Pure Simple
#
# Produces exact byte sequences for AVX2 YMM packed-integer instructions:
#   VPADDD   (packed 32-bit add,           VEX.256.66.0F.WIG  FE /r)
#   VPSUBD   (packed 32-bit subtract,      VEX.256.66.0F.WIG  FA /r)
#   VPMULLD  (packed 32-bit multiply low,  VEX.256.66.0F38.WIG 40 /r)
#   VPAND    (packed bitwise AND,          VEX.256.66.0F.WIG  DB /r)
#   VPOR     (packed bitwise OR,           VEX.256.66.0F.WIG  EB /r)
#   VPXOR    (packed bitwise XOR,          VEX.256.66.0F.WIG  EF /r)
#   VPSRLD   (packed shift-right-logical,  VEX.256.66.0F.WIG  72 /2 ib)
#   VPSLLD   (packed shift-left-logical,   VEX.256.66.0F.WIG  72 /6 ib)
#
# VEX 3-byte prefix (C4h) for YMM (256-bit) register forms:
#   Byte 0: 0xC4
#   Byte 1: ~R  ~X  ~B  m4 m3 m2 m1 m0
#     ~R   = 1 when ModRM.reg operand < 8,  else 0
#     ~X   = 1 (no SIB; register-direct only)
#     ~B   = 1 when ModRM.rm  operand < 8,  else 0
#     mmmmm= 00001 (1) for 0F map
#     mmmmm= 00010 (2) for 0F38 map
#   Byte 2: W  ~v3 ~v2 ~v1 ~v0  L  p1 p0
#     W    = 0 (WIG — ignored for these instructions)
#     ~vvvv= inverted 4-bit vvvv index: (15 - vvvv_reg)
#     L    = 1 (256-bit YMM)
#     pp   = 01 (66 prefix)
#
# /r three-operand forms (VPADDD/VPSUBD/VPMULLD/VPAND/VPOR/VPXOR):
#   ModRM.reg = rd (destination)
#   VEX.vvvv  = rn (first source, inverted in byte2)
#   ModRM.rm  = rm (second source)
#
# /N ib immediate forms (VPSRLD /2, VPSLLD /6):
#   ModRM.reg = N (opcode extension: 2 for VPSRLD, 6 for VPSLLD)
#   VEX.vvvv  = rd (destination, inverted in byte2)
#   ModRM.rm  = rn (source operand)
#   imm8      = shift count
#
# Arithmetic for byte1 (no SIB, register-direct):
#   0F  map: byte1 = 225 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32
#   0F38 map: byte1 = 226 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32
#   (225 = 0xE1, mmmmm=1; 226 = 0xE2, mmmmm=2)
#
# Arithmetic for byte2 (W=0, L=1, pp=01):
#   byte2 = (15 - vvvv) * 8 + 5
#   (L=1 contributes 4; pp=01 contributes 1; W=0 contributes 0)
#
# ALL byte goldens verified by formula cross-check against Intel SDM.
# Reference: Intel SDM Vol 2C VPADDD/VPSUBD/VPMULLD/VPAND/VPOR/VPXOR/VPSRLD/VPSLLD;
#            Intel SDM Vol 2A §2.3.5 (VEX prefix).

# ============================================================================
# Internal helpers
# ============================================================================

fn _modrm_direct(reg: i64, rm: i64) -> i64:
    """
    ModRM byte for register-direct operands (mod=11).
    mod=11 → 192; reg field uses low 3 bits of reg; rm field uses low 3 bits of rm.
    """
    192 + ((reg % 8) * 8) + (rm % 8)

fn _avx2_vex_byte1_0f(modrm_reg: i64, modrm_rm: i64) -> i64:
    """
    VEX Byte 1 for 0F map (mmmmm=1), register-register, no SIB.
    ~R=1 when modrm_reg<8, ~X=1, ~B=1 when modrm_rm<8, mmmmm=1.
    byte1 = 225 - (modrm_reg/8)*128 - (modrm_rm/8)*32
    (225 = 0xE1 = ~R=1 ~X=1 ~B=1 mmmmm=1)
    """
    225 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32

fn _avx2_vex_byte1_0f38(modrm_reg: i64, modrm_rm: i64) -> i64:
    """
    VEX Byte 1 for 0F38 map (mmmmm=2), register-register, no SIB.
    ~R=1 when modrm_reg<8, ~X=1, ~B=1 when modrm_rm<8, mmmmm=2.
    byte1 = 226 - (modrm_reg/8)*128 - (modrm_rm/8)*32
    (226 = 0xE2 = ~R=1 ~X=1 ~B=1 mmmmm=2)
    """
    226 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32

fn _avx2_vex_byte2_ymm(vvvv: i64) -> i64:
    """
    VEX Byte 2 for YMM (256-bit) forms: W=0, ~vvvv=(15-vvvv), L=1, pp=01.
    byte2 = (15 - vvvv) * 8 + 5
    (L=1 contributes 4; pp=01 contributes 1; W=0 contributes 0)
    """
    (15 - vvvv) * 8 + 5

fn _pack_vex3_ymm_66_0f(rd: i64, rn: i64, rm: i64, opcode: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F.WIG /r forms (5 bytes total).
    rd → ModRM.reg (destination), rn → VEX.vvvv (src1), rm → ModRM.rm (src2).
    Used by: VPADDD, VPSUBD, VPAND, VPOR, VPXOR.
    """
    val b1    = _avx2_vex_byte1_0f(rd, rm)
    val b2    = _avx2_vex_byte2_ymm(rn)
    val modrm = _modrm_direct(rd, rm)
    [0xC4, b1, b2, opcode, modrm]

fn _pack_vex3_ymm_66_0f38(rd: i64, rn: i64, rm: i64, opcode: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F38.WIG /r forms (5 bytes total).
    rd → ModRM.reg (destination), rn → VEX.vvvv (src1), rm → ModRM.rm (src2).
    Used by: VPMULLD.
    """
    val b1    = _avx2_vex_byte1_0f38(rd, rm)
    val b2    = _avx2_vex_byte2_ymm(rn)
    val modrm = _modrm_direct(rd, rm)
    [0xC4, b1, b2, opcode, modrm]

fn _pack_vex3_ymm_66_0f_imm(rd: i64, rn: i64, opcode_ext: i64, opcode: i64, imm8: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F.WIG /N ib immediate forms (6 bytes total).
    rd → VEX.vvvv (destination), rn → ModRM.rm (source), opcode_ext → ModRM.reg.
    ~R is always 1 because opcode_ext < 8 always; ~B from rn.
    byte1 = 225 - (rn/8)*32  (opcode_ext/8=0 so ~R term = 0)
    Used by: VPSRLD (/2), VPSLLD (/6).
    """
    val b1    = 225 - (rn / 8) * 32
    val b2    = _avx2_vex_byte2_ymm(rd)
    val modrm = _modrm_direct(opcode_ext, rn)
    [0xC4, b1, b2, opcode, modrm, imm8]

# ============================================================================
# VPADDD — Packed 32-bit Add  (VEX.256.66.0F.WIG FE /r)
# VPADDD rd, rn, rm
#   rd ← rn + rm  (element-wise 32-bit wraparound)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPADDD" — VEX.256.66.0F.WIG FE /r
# ============================================================================

fn emit_vpaddd_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPADDD ymm, ymm, ymm — packed 32-bit add (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG FE /r
    rd, rn, rm: YMM register indices 0..15 (ymm0=0, ymm1=1, ...).
    Example: emit_vpaddd_ymm(0, 1, 2) → [0xC4, 0xE1, 0x75, 0xFE, 0xC2]
      byte1: ~R=1,~X=1,~B=1,mmmmm=1 → 225
      byte2: W=0,~vvvv=14(rn=1),L=1,pp=01 → 14*8+5=117
      ModRM: mod=11,reg=0,rm=2 → 194
    Reference: Intel SDM Vol 2C VPADDD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f(rd, rn, rm, 0xFE)

# ============================================================================
# VPSUBD — Packed 32-bit Subtract  (VEX.256.66.0F.WIG FA /r)
# VPSUBD rd, rn, rm
#   rd ← rn - rm  (element-wise 32-bit wraparound)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPSUBD" — VEX.256.66.0F.WIG FA /r
# ============================================================================

fn emit_vpsubd_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPSUBD ymm, ymm, ymm — packed 32-bit subtract (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG FA /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpsubd_ymm(0, 1, 2) → [0xC4, 0xE1, 0x75, 0xFA, 0xC2]
    Reference: Intel SDM Vol 2C VPSUBD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f(rd, rn, rm, 0xFA)

# ============================================================================
# VPMULLD — Packed 32-bit Multiply Low  (VEX.256.66.0F38.WIG 40 /r)
# VPMULLD rd, rn, rm
#   rd ← low 32 bits of (rn * rm)  (element-wise)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPMULLD" — VEX.256.66.0F38.WIG 40 /r
# ============================================================================

fn emit_vpmulld_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPMULLD ymm, ymm, ymm — packed 32-bit multiply low (YMM 256-bit form).
    Encoding: VEX.256.66.0F38.WIG 40 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpmulld_ymm(0, 1, 2) → [0xC4, 0xE2, 0x75, 0x40, 0xC2]
      byte1: ~R=1,~X=1,~B=1,mmmmm=2 → 226
      byte2: W=0,~vvvv=14,L=1,pp=01 → 117
    Reference: Intel SDM Vol 2C VPMULLD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f38(rd, rn, rm, 0x40)

# ============================================================================
# VPAND — Packed Bitwise AND  (VEX.256.66.0F.WIG DB /r)
# VPAND rd, rn, rm
#   rd ← rn AND rm  (bitwise)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPAND" — VEX.256.66.0F.WIG DB /r
# ============================================================================

fn emit_vpand_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPAND ymm, ymm, ymm — packed bitwise AND (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG DB /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpand_ymm(0, 1, 2) → [0xC4, 0xE1, 0x75, 0xDB, 0xC2]
    Reference: Intel SDM Vol 2C VPAND; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f(rd, rn, rm, 0xDB)

# ============================================================================
# VPOR — Packed Bitwise OR  (VEX.256.66.0F.WIG EB /r)
# VPOR rd, rn, rm
#   rd ← rn OR rm  (bitwise)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPOR" — VEX.256.66.0F.WIG EB /r
# ============================================================================

fn emit_vpor_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPOR ymm, ymm, ymm — packed bitwise OR (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG EB /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpor_ymm(0, 1, 2) → [0xC4, 0xE1, 0x75, 0xEB, 0xC2]
    Reference: Intel SDM Vol 2C VPOR; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f(rd, rn, rm, 0xEB)

# ============================================================================
# VPXOR — Packed Bitwise XOR  (VEX.256.66.0F.WIG EF /r)
# VPXOR rd, rn, rm
#   rd ← rn XOR rm  (bitwise)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPXOR" — VEX.256.66.0F.WIG EF /r
# ============================================================================

fn emit_vpxor_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPXOR ymm, ymm, ymm — packed bitwise XOR (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG EF /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpxor_ymm(0, 1, 2) → [0xC4, 0xE1, 0x75, 0xEF, 0xC2]
    Reference: Intel SDM Vol 2C VPXOR; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f(rd, rn, rm, 0xEF)

# ============================================================================
# VPSRLD — Packed Shift Right Logical Doubleword Immediate
#          (VEX.256.66.0F.WIG 72 /2 ib)
# VPSRLD rd, rn, imm8
#   rd ← rn >> imm8  (element-wise 32-bit logical right shift)
#   Routing (imm form): ModRM.reg=2 (opcode ext), VEX.vvvv=rd, ModRM.rm=rn
# Reference: Intel SDM Vol 2C "VPSRLD" — VEX.NDD.256.66.0F.WIG 72 /2 ib
# ============================================================================

fn emit_vpsrld_ymm_imm(rd: i64, rn: i64, imm8: i64) -> [i64]:
    """
    VPSRLD ymm, ymm, imm8 — packed 32-bit logical shift right by immediate (YMM form).
    Encoding: VEX.256.66.0F.WIG 72 /2 ib  (6 bytes)
    rd: destination YMM register index 0..15.
    rn: source YMM register index 0..15.
    imm8: shift count 0..31.
    VEX operand routing: vvvv=rd (dest), ModRM.r/m=rn (src), ModRM.reg=2 (opcode ext).
    Example: emit_vpsrld_ymm_imm(0, 1, 8) → [0xC4, 0xE1, 0x7D, 0x72, 0xD1, 0x08]
      byte1: ~R=1,~X=1,~B=1(rn=1<8),mmmmm=1 → 225
      byte2: W=0,~vvvv=15(rd=0),L=1,pp=01 → 15*8+5=125
      ModRM: mod=11,reg=2,rm=1 → 192+2*8+1=209
    Reference: Intel SDM Vol 2C VPSRLD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_imm(rd, rn, 2, 0x72, imm8)

# ============================================================================
# VPSLLD — Packed Shift Left Logical Doubleword Immediate
#          (VEX.256.66.0F.WIG 72 /6 ib)
# VPSLLD rd, rn, imm8
#   rd ← rn << imm8  (element-wise 32-bit logical left shift)
#   Routing (imm form): ModRM.reg=6 (opcode ext), VEX.vvvv=rd, ModRM.rm=rn
# Reference: Intel SDM Vol 2C "VPSLLD" — VEX.NDD.256.66.0F.WIG 72 /6 ib
# ============================================================================

fn emit_vpslld_ymm_imm(rd: i64, rn: i64, imm8: i64) -> [i64]:
    """
    VPSLLD ymm, ymm, imm8 — packed 32-bit logical shift left by immediate (YMM form).
    Encoding: VEX.256.66.0F.WIG 72 /6 ib  (6 bytes)
    rd: destination YMM register index 0..15.
    rn: source YMM register index 0..15.
    imm8: shift count 0..31.
    VEX operand routing: vvvv=rd (dest), ModRM.r/m=rn (src), ModRM.reg=6 (opcode ext).
    Example: emit_vpslld_ymm_imm(0, 1, 3) → [0xC4, 0xE1, 0x7D, 0x72, 0xF1, 0x03]
      byte1: ~R=1,~X=1,~B=1(rn=1<8),mmmmm=1 → 225
      byte2: W=0,~vvvv=15(rd=0),L=1,pp=01 → 15*8+5=125
      ModRM: mod=11,reg=6,rm=1 → 192+6*8+1=241
    Reference: Intel SDM Vol 2C VPSLLD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_imm(rd, rn, 6, 0x72, imm8)

# ============================================================================
# Exports
# ============================================================================

export emit_vpaddd_ymm
export emit_vpsubd_ymm
export emit_vpmulld_ymm
export emit_vpand_ymm
export emit_vpor_ymm
export emit_vpxor_ymm
export emit_vpsrld_ymm_imm
export emit_vpslld_ymm_imm
