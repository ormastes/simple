# ARM NEON Code Generation
#
# Generates ARM NEON SIMD instructions for vector operations.
# Supports ARMv8-A NEON (128-bit Q registers, 32-bit opcodes).
#
# NEON Instructions use fixed 32-bit encoding:
#   FADD.4S Vd, Vn, Vm (add 4 single-precision floats)
#
# Instruction structure (32-bit):
#   [cond(4)] [opcode bits(24)] [Rd(4)] [Rn(4)] [Rm(4)]
#   For NEON: fixed encoding with register fields in specific positions
#
# Q registers (128-bit): Q0-Q15 (encoded as V0-V15 in ARMv8-A)
# D registers (64-bit): D0-D31 (lower half of Q registers)
#
# ARMv8-A NEON uses "Advanced SIMD" encoding with:
#   - Fixed 32-bit instruction size
#   - Vector registers V0-V31 (we use V0-V15 for Q register compatibility)
#   - Scalar and vector forms

use compiler.backend.native.mach_inst.{MachReg, MachRegKind, physical_reg, reg_id, Operand, OperandKind, MachInst, MachBlock, MachFunction, MachModule}
use compiler.backend.native.mach_inst.{AARCH64_Q0, AARCH64_Q1, AARCH64_Q2, AARCH64_Q3, AARCH64_Q4, AARCH64_Q5, AARCH64_Q6, AARCH64_Q7}
use compiler.backend.native.mach_inst.{AARCH64_Q8, AARCH64_Q9, AARCH64_Q10, AARCH64_Q11, AARCH64_Q12, AARCH64_Q13, AARCH64_Q14, AARCH64_Q15}
use compiler.backend.native.mach_inst.{AARCH64_Q_ALLOCATABLE}

# ============================================================================
# ARM NEON Register IDs (Re-export mach_inst constants for compatibility)
# ============================================================================

val ARM_Q0 = AARCH64_Q0
val ARM_Q1 = AARCH64_Q1
val ARM_Q2 = AARCH64_Q2
val ARM_Q3 = AARCH64_Q3
val ARM_Q4 = AARCH64_Q4
val ARM_Q5 = AARCH64_Q5
val ARM_Q6 = AARCH64_Q6
val ARM_Q7 = AARCH64_Q7
val ARM_Q8 = AARCH64_Q8
val ARM_Q9 = AARCH64_Q9
val ARM_Q10 = AARCH64_Q10
val ARM_Q11 = AARCH64_Q11
val ARM_Q12 = AARCH64_Q12
val ARM_Q13 = AARCH64_Q13
val ARM_Q14 = AARCH64_Q14
val ARM_Q15 = AARCH64_Q15

val ARM_Q_ALLOCATABLE = AARCH64_Q_ALLOCATABLE

fn arm_neon_reg_name(id: i64) -> text:
    if id >= 64 and id <= 79:
        val q_num = id - 64
        "q{q_num}"
    else:
        "q?"

# ============================================================================
# Register Encoding
# ============================================================================

fn q_to_index(q_id: i64) -> i64:
    """Convert Q register ID to index (0-15)."""
    if q_id >= 64 and q_id <= 79:
        q_id - 64
    else:
        0

# ============================================================================
# ARM NEON Instruction Encoding Helpers
# ============================================================================

fn neon_encode_f32x4_3reg(opcode_bits: i64, qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode 3-register NEON instruction (Vd, Vn, Vm format).
    ARMv8-A Advanced SIMD encoding for f32x4 operations.

    Format (32-bit little-endian):
    31-24: opcode high bits
    23-16: Rn field (4 bits) + opcode mid bits
    15-8:  Rd field (4 bits) + opcode low bits
    7-0:   Rm field (4 bits) + size/Q bits

    Example FADD.4S: 0x4E20D400 base + register fields
    """
    val d_idx = q_to_index(qd)
    val n_idx = q_to_index(qn)
    val m_idx = q_to_index(qm)

    # Build 32-bit instruction (stored as 4 bytes, little-endian)
    # Base opcode contains operation and size encoding
    var inst = opcode_bits

    # Insert register fields
    # Rd in bits 0-4
    inst = inst + d_idx

    # Rn in bits 5-9
    inst = inst + (n_idx * 32)

    # Rm in bits 16-20
    inst = inst + (m_idx * 65536)

    # Convert 32-bit value to 4 bytes (little-endian)
    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256

    [byte0, byte1, byte2, byte3]

fn neon_encode_f64x2_3reg(opcode_bits: i64, qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode 3-register NEON instruction for f64x2 (double precision).
    Same structure as f32x4 but with different size encoding.
    """
    neon_encode_f32x4_3reg(opcode_bits, qd, qn, qm)

fn neon_encode_i32x4_3reg(opcode_bits: i64, qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode 3-register NEON instruction for i32x4 (integer).
    Same structure as f32x4 but with different opcode.
    """
    neon_encode_f32x4_3reg(opcode_bits, qd, qn, qm)

# ============================================================================
# NEON f32x4 (128-bit Float) Instructions
# ============================================================================

fn encode_fadd_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FADD.4S Vd.4S, Vn.4S, Vm.4S (128-bit float add).
    ARMv8-A encoding: 0 Q 0 01110 0 Sz 1 Rm 110101 Rn Rd
    Q=1 (128-bit), Sz=0 (single precision)
    Base opcode: 0x4E20D400
    """
    # FADD.4S base encoding:
    # 0100 1110 0010 0000 1101 0100 0000 0000
    # = 0x4E20D400
    encode_neon_f32x4_3reg(0x4E20D400, qd, qn, qm)

fn encode_fsub_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FSUB.4S Vd.4S, Vn.4S, Vm.4S (128-bit float subtract).
    Base opcode: 0x4EA0D400
    """
    # FSUB.4S: bit 23 set (0x00800000) compared to FADD
    encode_neon_f32x4_3reg(0x4EA0D400, qd, qn, qm)

fn encode_fmul_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMUL.4S Vd.4S, Vn.4S, Vm.4S (128-bit float multiply).
    Base opcode: 0x6E20DC00
    """
    encode_neon_f32x4_3reg(0x6E20DC00, qd, qn, qm)

fn encode_fdiv_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FDIV.4S Vd.4S, Vn.4S, Vm.4S (128-bit float divide).
    Base opcode: 0x6E20FC00
    """
    encode_neon_f32x4_3reg(0x6E20FC00, qd, qn, qm)

fn encode_fmla_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMLA.4S Vd.4S, Vn.4S, Vm.4S (fused multiply-add: Vd = Vd + Vn * Vm).
    Base opcode: 0x4E20CC00
    """
    encode_neon_f32x4_3reg(0x4E20CC00, qd, qn, qm)

# ============================================================================
# NEON f64x2 (128-bit Double) Instructions
# ============================================================================

fn encode_fadd_2d(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FADD.2D Vd.2D, Vn.2D, Vm.2D (128-bit double add).
    Base opcode: 0x4E60D400 (Sz=1 for double precision)
    """
    encode_neon_f64x2_3reg(0x4E60D400, qd, qn, qm)

fn encode_fsub_2d(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FSUB.2D Vd.2D, Vn.2D, Vm.2D (128-bit double subtract).
    Base opcode: 0x4EE0D400
    """
    encode_neon_f64x2_3reg(0x4EE0D400, qd, qn, qm)

fn encode_fmul_2d(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMUL.2D Vd.2D, Vn.2D, Vm.2D (128-bit double multiply).
    Base opcode: 0x6E60DC00
    """
    encode_neon_f64x2_3reg(0x6E60DC00, qd, qn, qm)

fn encode_fdiv_2d(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FDIV.2D Vd.2D, Vn.2D, Vm.2D (128-bit double divide).
    Base opcode: 0x6E60FC00
    """
    encode_neon_f64x2_3reg(0x6E60FC00, qd, qn, qm)

fn encode_fmla_2d(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMLA.2D Vd.2D, Vn.2D, Vm.2D (fused multiply-add double).
    Base opcode: 0x4E60CC00
    """
    encode_neon_f64x2_3reg(0x4E60CC00, qd, qn, qm)

# ============================================================================
# NEON i32x4 (128-bit Integer) Instructions
# ============================================================================

fn encode_add_4s_int(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode ADD.4S Vd.4S, Vn.4S, Vm.4S (128-bit int32 add).
    Base opcode: 0x4EA08400
    """
    encode_neon_i32x4_3reg(0x4EA08400, qd, qn, qm)

fn encode_sub_4s_int(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode SUB.4S Vd.4S, Vn.4S, Vm.4S (128-bit int32 subtract).
    Base opcode: 0x6EA08400
    """
    encode_neon_i32x4_3reg(0x6EA08400, qd, qn, qm)

fn encode_mul_4s_int(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode MUL.4S Vd.4S, Vn.4S, Vm.4S (128-bit int32 multiply).
    Base opcode: 0x4EA09C00
    """
    encode_neon_i32x4_3reg(0x4EA09C00, qd, qn, qm)

# ============================================================================
# Load/Store Instructions
# ============================================================================

fn encode_ldr_q(qd: i64, base_reg: i64, offset: i64) -> [i64]:
    """
    Encode LDR Qd, [Xn, #offset] (load 128-bit from memory).
    ARMv8-A encoding: 0x3DC00000 base + Rt + Rn<<5 + imm12<<10
    offset must be multiple of 16, encoded as offset/16 in imm12 field.
    """
    val d_idx = q_to_index(qd)

    # Base encoding for LDR Q (128-bit load)
    # 00 111 1 01 01 imm12 Rn Rt
    var inst = 0x3DC00000

    # Rt (destination register, bits 0-4)
    inst = inst + d_idx

    # Rn (base register, bits 5-9)
    inst = inst + ((base_reg % 32) * 32)

    # imm12 (offset/16, bits 10-21)
    val imm12 = (offset / 16) % 4096
    inst = inst + (imm12 * 1024)

    # Convert to little-endian bytes
    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256

    [byte0, byte1, byte2, byte3]

fn encode_str_q(qs: i64, base_reg: i64, offset: i64) -> [i64]:
    """
    Encode STR Qd, [Xn, #offset] (store 128-bit to memory).
    ARMv8-A encoding: 0x3D800000 base + Rt + Rn<<5 + imm12<<10
    """
    val s_idx = q_to_index(qs)

    # Base encoding for STR Q (128-bit store)
    var inst = 0x3D800000

    # Rt (source register, bits 0-4)
    inst = inst + s_idx

    # Rn (base register, bits 5-9)
    inst = inst + ((base_reg % 32) * 32)

    # imm12 (offset/16, bits 10-21)
    val imm12 = (offset / 16) % 4096
    inst = inst + (imm12 * 1024)

    # Convert to little-endian bytes
    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256

    [byte0, byte1, byte2, byte3]

fn encode_ld1_4s(qd: i64, base_reg: i64) -> [i64]:
    """
    Encode LD1 {Vd.4S}, [Xn] (load 4 single-precision floats, structure load).
    Base opcode: 0x4C407000
    Used for interleaved/structure-of-arrays loads.
    """
    val d_idx = q_to_index(qd)

    # LD1 single structure encoding
    var inst = 0x4C407000

    # Rt (destination, bits 0-4)
    inst = inst + d_idx

    # Rn (base register, bits 5-9)
    inst = inst + ((base_reg % 32) * 32)

    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256

    [byte0, byte1, byte2, byte3]

fn encode_st1_4s(qs: i64, base_reg: i64) -> [i64]:
    """
    Encode ST1 {Vd.4S}, [Xn] (store 4 single-precision floats, structure store).
    Base opcode: 0x4C007000
    Used for interleaved/structure-of-arrays stores.
    """
    val s_idx = q_to_index(qs)

    # ST1 single structure encoding
    var inst = 0x4C007000

    # Rt (source, bits 0-4)
    inst = inst + s_idx

    # Rn (base register, bits 5-9)
    inst = inst + ((base_reg % 32) * 32)

    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256

    [byte0, byte1, byte2, byte3]

# ============================================================================
# Horizontal Operations
# ============================================================================

fn encode_faddp_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FADDP.4S Vd.4S, Vn.4S, Vm.4S (pairwise add).
    Base opcode: 0x4E20D400
    Similar to FADD but with pairwise operation bit set.
    """
    encode_neon_f32x4_3reg(0x6E20D400, qd, qn, qm)

fn encode_fmaxnm_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMAXNM.4S Vd.4S, Vn.4S, Vm.4S (max of floats, NaN-aware).
    Base opcode: 0x4E20C400
    """
    encode_neon_f32x4_3reg(0x4E20C400, qd, qn, qm)

fn encode_fminnm_4s(qd: i64, qn: i64, qm: i64) -> [i64]:
    """
    Encode FMINNM.4S Vd.4S, Vn.4S, Vm.4S (min of floats, NaN-aware).
    Base opcode: 0x4EA0C400
    """
    encode_neon_f32x4_3reg(0x4EA0C400, qd, qn, qm)

# ============================================================================
# Helper function name compatibility
# ============================================================================

fn encode_neon_f32x4_3reg(opcode: i64, qd: i64, qn: i64, qm: i64) -> [i64]:
    """Wrapper for neon_encode_f32x4_3reg (name compatibility)."""
    neon_encode_f32x4_3reg(opcode, qd, qn, qm)

# ============================================================================
# Strict-Emit Encoder Helpers (H2 pilot — ARMv8 ARM §C7.2)
# ============================================================================
#
# These helpers accept raw register indices (0-31 for V0-V31) directly —
# NOT the mach_inst ID range (64-79). Call sites must convert with q_to_index
# if passing mach_inst IDs, or pass the raw index directly.
#
# All return [i64] (4 bytes, little-endian) per ARMv8 ABI fixed 32-bit instruction.

fn neon_encode_3reg_4s_arith(opcode_base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode a 3-register NEON Advanced SIMD arithmetic instruction for .4S (f32x4).
    Raw register indices 0-31. Dispatches to the existing neon_encode_f32x4_3reg
    layout: Rd in bits[4:0], Rn in bits[9:5], Rm in bits[20:16].

    # C1 §2.2: ARMv8 NEON Advanced SIMD 3-register same-type format
    # ARMv8 ARM §C7.2: FADD/FMUL/FMLA vector encoding
    """
    var inst = opcode_base
    inst = inst + rd
    inst = inst + (rn * 32)
    inst = inst + (rm * 65536)
    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256
    [byte0, byte1, byte2, byte3]

fn neon_encode_3reg_4s_fma(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FMLA Vd.4S, Vn.4S, Vm.4S (fused multiply-add: Vd += Vn * Vm).
    Base opcode 0x4E20CC00: Q=1 (128-bit), U=0, size=00 (f32), opcode=11001.
    Raw register indices 0-31.

    # C1 §2.2: NEON 3-same FMLA encoding
    # ARMv8 ARM §C7.2.110 FMLA (vector)
    """
    neon_encode_3reg_4s_arith(0x4E20CC00, rd, rn, rm)

fn neon_encode_3reg_16b_bsl(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode BSL Vd.16B, Vn.16B, Vm.16B (bitwise select: Vd = (Vd & Vn) | (~Vd & Vm)).
    Base opcode 0x6E601C00: Q=1 (128-bit), U=1, size=01 (BSL group), opcode=00011.
    Raw register indices 0-31.

    # C1 §2.2: NEON BSL/BIT/BIF bitwise select encoding (U=1 distinguishes BSL)
    # ARMv8 ARM §C7.2.22 BSL
    # V-25 NOTE: when used to lower cmp_lt(a,b), the mask input must come from
    # FCMGT(b, a) — operands swapped at call site, NOT in this encoder.
    """
    neon_encode_3reg_4s_arith(0x6E601C00, rd, rn, rm)

# ============================================================================
# Strict-Emit Wrapper Bodies (H2 pilot)
# ============================================================================
#
# These wrappers accept raw register indices (0-31 for V0-V31) directly.

fn emit_neon_vaddq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FADD Vd.4S, Vn.4S, Vm.4S — add 4 single-precision floats (128-bit).
    Base opcode 0x4E20D400: Q=1, U=0, size=00 (f32), opcode=11010.
    Raw register indices 0-31.

    # C1 §2.2: NEON FADD .4S encoding
    # ARMv8 ARM §C7.2.94 FADD (vector)
    # Canonical bytes (V0,V0,V0): 0x00 0xD4 0x20 0x4E
    """
    neon_encode_3reg_4s_arith(0x4E20D400, rd, rn, rm)

fn emit_neon_vmulq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMUL Vd.4S, Vn.4S, Vm.4S — multiply 4 single-precision floats (128-bit).
    Base opcode 0x6E20DC00: Q=1, U=1, size=00 (f32), opcode=11011.
    Raw register indices 0-31.

    # C1 §2.2: NEON FMUL .4S encoding
    # ARMv8 ARM §C7.2.136 FMUL (vector)
    # Canonical bytes (V0,V0,V0): 0x00 0xDC 0x20 0x6E
    """
    neon_encode_3reg_4s_arith(0x6E20DC00, rd, rn, rm)

fn emit_neon_vfmaq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMLA Vd.4S, Vn.4S, Vm.4S — fused multiply-add (Vd accumulates: Vd += Vn * Vm).
    Raw register indices 0-31.

    # C1 §2.2: NEON FMLA .4S encoding
    # ARMv8 ARM §C7.2.110 FMLA (vector)
    # Canonical bytes (V0,V0,V0): 0x00 0xCC 0x20 0x4E
    """
    neon_encode_3reg_4s_fma(rd, rn, rm)

fn emit_neon_vbslq_u8(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit BSL Vd.16B, Vn.16B, Vm.16B — bitwise select (mask blend for 128-bit).
    Raw register indices 0-31.

    # C1 §2.2: NEON BSL encoding
    # ARMv8 ARM §C7.2.22 BSL
    # Canonical bytes (V0,V0,V0): 0x00 0x1C 0x60 0x6E  [UNVERIFIED vs primary spec]
    # V-25: for cmp_lt(a,b), pass mask from FCMGT(b,a) — operands swapped by caller
    """
    neon_encode_3reg_16b_bsl(rd, rn, rm)

# ============================================================================
# Strict-Emit Load/Store Helpers (N4 — ARMv8 ARM §C7.2)
# ============================================================================
#
# These helpers accept raw register indices directly:
#   rt: vector register index 0-31 (Vt)
#   rn: GP base register index 0-30 (Xn); 31 = SP
# All return [i64] (4 bytes, little-endian).
#
# Encoding reference: ARMv8 ARM Advanced SIMD load/store multiple structures.
# No-offset (base-register only) form:
#   0 Q 001100 0 L 000000 opcode[3:0] size[1:0] Rn[4:0] Rt[4:0]
# Post-index immediate form (offset encoded as 11111 in Rm field):
#   0 Q 001100 1 L 11111  opcode[3:0] size[1:0] Rn[4:0] Rt[4:0]

fn neon_encode_load_store_multi(opcode_base: i64, rt: i64, rn: i64) -> [i64]:
    """
    Encode an LD1/ST1/LD2/ST2 multiple-structures instruction.
    opcode_base: pre-computed base with all fixed bits set (Q, L, opcode, size).
    rt: vector register index 0-31 (placed in bits[4:0]).
    rn: GP base register index 0-31 (placed in bits[9:5]).
    Returns 4 bytes little-endian.

    # ARMv8 ARM §C7.2 Advanced SIMD load/store multiple structures base encoding.
    """
    var inst = opcode_base
    inst = inst + (rt % 32)
    inst = inst + ((rn % 32) * 32)
    val byte0 = inst % 256
    val byte1 = (inst / 256) % 256
    val byte2 = (inst / 65536) % 256
    val byte3 = (inst / 16777216) % 256
    [byte0, byte1, byte2, byte3]

fn emit_neon_ld1q_16b_immoff(rt: i64, rn: i64) -> [i64]:
    """
    Emit LD1 {Vt.16B}, [Xn] — load one 128-bit register, 16-byte (byte) arrangement.
    Raw vector register index rt (0-31), GP base register rn (0-31).
    Base opcode 0x4C407000: Q=1, L=1, opcode=0111 (1-reg), size=00 (B).

    # ARMv8 ARM §C7.2.219 LD1 (multiple structures, no offset variant)
    # Encoding: 0_Q_001100_0_L_000000_opcode_size_Rn_Rt
    # Q=1 (128-bit), L=1 (load), opcode=0111 (1 register), size=00 (8-bit/B)
    # Base word: 0x4C407000 → LE bytes: 0x00 0x70 0x40 0x4C
    # Canonical: LD1 V0.16B, [X0] → 0x00 0x70 0x40 0x4C
    # Fields: bits[4:0]=Rt, bits[9:5]=Rn, bits[11:10]=size=00, bits[15:12]=opcode=0111
    """
    neon_encode_load_store_multi(0x4C407000, rt, rn)

fn emit_neon_st1q_16b_immoff(rt: i64, rn: i64) -> [i64]:
    """
    Emit ST1 {Vt.16B}, [Xn] — store one 128-bit register, 16-byte arrangement.
    Base opcode 0x4C007000: Q=1, L=0, opcode=0111 (1-reg), size=00 (B).

    # ARMv8 ARM §C7.2.385 ST1 (multiple structures, no offset variant)
    # Q=1, L=0 (store), opcode=0111, size=00
    # Base word: 0x4C007000 → LE bytes: 0x00 0x70 0x00 0x4C
    # Canonical: ST1 V0.16B, [X0] → 0x00 0x70 0x00 0x4C
    """
    neon_encode_load_store_multi(0x4C007000, rt, rn)

fn emit_neon_ld1q_4s_immoff(rt: i64, rn: i64) -> [i64]:
    """
    Emit LD1 {Vt.4S}, [Xn] — load one 128-bit register, 4×32-bit (S) arrangement.
    Base opcode 0x4C407800: Q=1, L=1, opcode=0111 (1-reg), size=10 (S/32-bit).

    # ARMv8 ARM §C7.2.219 LD1 (multiple structures, no offset variant)
    # Q=1, L=1, opcode=0111, size=10 (S = 32-bit element)
    # Base word: 0x4C407800 → LE bytes: 0x00 0x78 0x40 0x4C
    # Canonical: LD1 V0.4S, [X0] → 0x00 0x78 0x40 0x4C
    # Fields: bits[11:10]=10 (size=S), bits[15:12]=0111 (1 register)
    """
    neon_encode_load_store_multi(0x4C407800, rt, rn)

fn emit_neon_st1q_4s_immoff(rt: i64, rn: i64) -> [i64]:
    """
    Emit ST1 {Vt.4S}, [Xn] — store one 128-bit register, 4×32-bit arrangement.
    Base opcode 0x4C007800: Q=1, L=0, opcode=0111 (1-reg), size=10 (S).

    # ARMv8 ARM §C7.2.385 ST1 (multiple structures, no offset variant)
    # Q=1, L=0 (store), opcode=0111, size=10
    # Base word: 0x4C007800 → LE bytes: 0x00 0x78 0x00 0x4C
    # Canonical: ST1 V0.4S, [X0] → 0x00 0x78 0x00 0x4C
    """
    neon_encode_load_store_multi(0x4C007800, rt, rn)

fn emit_neon_ld2_4s_post(rt: i64, rn: i64) -> [i64]:
    """
    Emit LD2 {Vt.4S, Vt2.4S}, [Xn], #32 — load two 128-bit registers, 4S, post-index #32.
    Base opcode 0x4CDF8800: Q=1, L=1, Rm=11111 (imm post-index), opcode=1000 (2-reg), size=10 (S).

    # ARMv8 ARM §C7.2.222 LD2 (multiple structures)
    # Post-index immediate form: bits[23]=1 (post-index), bits[21:16]=11111 (imm offset, not register)
    # Q=1, L=1, opcode=1000 (2 registers), size=10 (S), post-index offset=#32 (Rm=11111)
    # Base word: 0x4CDF8800 → LE bytes: 0x00 0x88 0xDF 0x4C
    # Canonical: LD2 {V0.4S, V1.4S}, [X0], #32 → 0x00 0x88 0xDF 0x4C
    # Fields: bits[23]=1 (post), bits[22]=L=1, bits[21:16]=111111→ wait: Rm=11111 in bits[20:16]
    # bits[23]=1 (post-index enable), bits[21:16]=011111 (imm); final: 0x4CDF8800
    """
    neon_encode_load_store_multi(0x4CDF8800, rt, rn)

fn emit_neon_st2_4s_post(rt: i64, rn: i64) -> [i64]:
    """
    Emit ST2 {Vt.4S, Vt2.4S}, [Xn], #32 — store two 128-bit registers, 4S, post-index #32.
    Base opcode 0x4C9F8800: Q=1, L=0, Rm=11111 (imm post-index), opcode=1000 (2-reg), size=10 (S).

    # ARMv8 ARM §C7.2.388 ST2 (multiple structures)
    # Post-index immediate form: Q=1, L=0 (store), opcode=1000, size=10, Rm=11111
    # Base word: 0x4C9F8800 → LE bytes: 0x00 0x88 0x9F 0x4C
    # Canonical: ST2 {V0.4S, V1.4S}, [X0], #32 → 0x00 0x88 0x9F 0x4C
    """
    neon_encode_load_store_multi(0x4C9F8800, rt, rn)

# ============================================================================
# Strict-Emit Arithmetic Extras (O2 — ARMv8 ARM §C7.2)
# ============================================================================
#
# FSUB, FMIN, FMAX, FCMGT, FCMGE helpers for Vec::sub, min, max, and mask ops.
# All helpers accept raw register indices 0-31 and return [i64] (4 bytes, LE).
# Opcodes verified via llvm-mc -triple=aarch64-none-linux-gnu --show-encoding.

fn neon_encode_3reg_4s_fsub(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FSUB Vd.4S, Vn.4S, Vm.4S (128-bit float subtract, 4 lanes).
    Base opcode 0x4EA0D400: Q=1, U=0, sz=1 (bit23), size=00→f32, opcode=11010.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.183 FSUB (vector, .4S form)
    # Encoding: 0_1_0_01110_1_0_1_Rm_110101_Rn_Rd
    # Base word: 0x4EA0D400 → LE: 0x00 0xD4 0xA0 0x4E
    # Canonical: FSUB V0.4S, V0.4S, V0.4S → [0x00, 0xD4, 0xA0, 0x4E] (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_arith(0x4EA0D400, rd, rn, rm)

fn neon_encode_3reg_4s_fmin(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FMIN Vd.4S, Vn.4S, Vm.4S (128-bit float min, NaN-propagating, 4 lanes).
    Base opcode 0x4EA0F400: Q=1, U=0, sz=1 (bit23), size=00→f32, opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.135 FMIN (vector, .4S form)
    # NaN behaviour: FMIN propagates NaN (IEEE-754 minNum NOT applied here).
    # For IEEE minNum (non-NaN result when one operand is NaN) use FMINNM §C7.2.137.
    # Base word: 0x4EA0F400 → LE: 0x00 0xF4 0xA0 0x4E
    # Canonical: FMIN V0.4S, V0.4S, V0.4S → [0x00, 0xF4, 0xA0, 0x4E] (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_arith(0x4EA0F400, rd, rn, rm)

fn neon_encode_3reg_4s_fmax(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FMAX Vd.4S, Vn.4S, Vm.4S (128-bit float max, NaN-propagating, 4 lanes).
    Base opcode 0x4E20F400: Q=1, U=0, sz=0 (bit23), size=00→f32, opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.136 FMAX (vector, .4S form)
    # NaN behaviour: FMAX propagates NaN. For IEEE maxNum use FMAXNM §C7.2.138.
    # Base word: 0x4E20F400 → LE: 0x00 0xF4 0x20 0x4E
    # Canonical: FMAX V0.4S, V0.4S, V0.4S → [0x00, 0xF4, 0x20, 0x4E] (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_arith(0x4E20F400, rd, rn, rm)

fn neon_encode_3reg_4s_fcmgt(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FCMGT Vd.4S, Vn.4S, Vm.4S — floating-point compare greater-than, 4 lanes.
    Result lanes are all-ones (0xFFFFFFFF) where Vn > Vm, all-zeros otherwise.
    Base opcode 0x6EA0E400: Q=1, U=1, sz=1 (bit23), size=00→f32, opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.111 FCMGT (vector, register form, .4S)
    # V-25 POLARITY NOTE (per E4-verified GCC source, doc/01_research/simd_spec_verification):
    #   To compute cmp_lt(a, b) use FCMGT(b, a) — swap Vn/Vm at the call site.
    #   This encoder takes (rn, rm) literally as the assembly operand order FCMGT Vd, Vn, Vm.
    #   Caller responsibility: for a<b, call emit_neon_vcgtq_f32(rd, b_reg, a_reg).
    # Base word: 0x6EA0E400 → LE: 0x00 0xE4 0xA0 0x6E
    # Canonical: FCMGT V0.4S, V0.4S, V0.4S → [0x00, 0xE4, 0xA0, 0x6E] (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_arith(0x6EA0E400, rd, rn, rm)

fn neon_encode_3reg_4s_fcmge(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Encode FCMGE Vd.4S, Vn.4S, Vm.4S — floating-point compare greater-or-equal, 4 lanes.
    Result lanes are all-ones (0xFFFFFFFF) where Vn >= Vm, all-zeros otherwise.
    Base opcode 0x6E20E400: Q=1, U=1, sz=0 (bit23), size=00→f32, opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.110 FCMGE (vector, register form, .4S)
    # V-25 NOTE: to compute cmp_le(a, b) use FCMGE(b, a) — swap Vn/Vm at call site.
    # Base word: 0x6E20E400 → LE: 0x00 0xE4 0x20 0x6E
    # Canonical: FCMGE V0.4S, V0.4S, V0.4S → [0x00, 0xE4, 0x20, 0x6E] (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_arith(0x6E20E400, rd, rn, rm)

# ============================================================================
# Strict-Emit Wrapper Bodies (O2 arithmetic extras)
# ============================================================================

fn emit_neon_vsubq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FSUB Vd.4S, Vn.4S, Vm.4S — subtract 4 single-precision floats (128-bit).
    Base opcode 0x4EA0D400: Q=1, U=0, sz=1, size=00 (f32), opcode=11010.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.183 FSUB (vector)
    # Canonical bytes (V0,V0,V0): 0x00 0xD4 0xA0 0x4E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fsub(rd, rn, rm)

fn emit_neon_vminq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMIN Vd.4S, Vn.4S, Vm.4S — minimum of 4 single-precision floats (NaN-propagating).
    Base opcode 0x4EA0F400: Q=1, U=0, sz=1, size=00 (f32), opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.135 FMIN (vector) — NaN-propagating per §C7.2.135
    # For IEEE minimumNumber (non-NaN preference) use FMINNM §C7.2.137 (follow-up).
    # Canonical bytes (V0,V0,V0): 0x00 0xF4 0xA0 0x4E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fmin(rd, rn, rm)

fn emit_neon_vmaxq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMAX Vd.4S, Vn.4S, Vm.4S — maximum of 4 single-precision floats (NaN-propagating).
    Base opcode 0x4E20F400: Q=1, U=0, sz=0, size=00 (f32), opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.136 FMAX (vector) — NaN-propagating per §C7.2.136
    # For IEEE maximumNumber (non-NaN preference) use FMAXNM §C7.2.138 (follow-up).
    # Canonical bytes (V0,V0,V0): 0x00 0xF4 0x20 0x4E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fmax(rd, rn, rm)

fn emit_neon_vcgtq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FCMGT Vd.4S, Vn.4S, Vm.4S — compare greater-than for 4 f32 lanes.
    Produces all-ones mask per lane where Vn > Vm.
    Base opcode 0x6EA0E400: Q=1, U=1, sz=1, size=00 (f32), opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.111 FCMGT (vector, register form)
    # V-25 POLARITY: for cmp_lt(a, b), call emit_neon_vcgtq_f32(rd, b_reg, a_reg).
    #   The encoder passes (rn, rm) to hardware as Vn, Vm — operand swap is caller's job.
    # Canonical bytes (V0,V0,V0): 0x00 0xE4 0xA0 0x6E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fcmgt(rd, rn, rm)

fn emit_neon_vcgeq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FCMGE Vd.4S, Vn.4S, Vm.4S — compare greater-or-equal for 4 f32 lanes.
    Produces all-ones mask per lane where Vn >= Vm.
    Base opcode 0x6E20E400: Q=1, U=1, sz=0, size=00 (f32), opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.110 FCMGE (vector, register form)
    # V-25 NOTE: for cmp_le(a, b), call emit_neon_vcgeq_f32(rd, b_reg, a_reg).
    # Canonical bytes (V0,V0,V0): 0x00 0xE4 0x20 0x6E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fcmge(rd, rn, rm)

# ============================================================================
# CRC32/CRC32C — ARMv8.1 Scalar CRC Instructions
# ============================================================================

fn _crc32_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode CRC32 instruction: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_crc32b(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32B Wd, Wn, Wm — CRC-32 on byte input.
    # ARMv8 ARM §C7.2.36 CRC32B; base 0x1AC04000
    # Canonical (W0,W0,W0): 0x00 0x40 0xC0 0x1A
    """
    _crc32_encode(0x1AC04000, rd, rn, rm)

fn emit_neon_crc32h(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32H Wd, Wn, Wm — CRC-32 on halfword input.
    # ARMv8 ARM §C7.2.36 CRC32H; base 0x1AC04400
    # Canonical (W0,W0,W0): 0x00 0x44 0xC0 0x1A
    """
    _crc32_encode(0x1AC04400, rd, rn, rm)

fn emit_neon_crc32w(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32W Wd, Wn, Wm — CRC-32 on word input.
    # ARMv8 ARM §C7.2.36 CRC32W; base 0x1AC04800
    # Canonical (W0,W0,W0): 0x00 0x48 0xC0 0x1A
    """
    _crc32_encode(0x1AC04800, rd, rn, rm)

fn emit_neon_crc32x(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32X Wd, Wn, Xm — CRC-32 on doubleword input.
    # ARMv8 ARM §C7.2.36 CRC32X; base 0x9AC04C00
    # Canonical (W0,W0,X0): 0x00 0x4C 0xC0 0x9A
    """
    _crc32_encode(0x9AC04C00, rd, rn, rm)

fn emit_neon_crc32cb(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CB Wd, Wn, Wm — CRC-32C (Castagnoli) on byte input.
    # ARMv8 ARM §C7.2.37 CRC32CB; base 0x1AC05000
    # Canonical (W0,W0,W0): 0x00 0x50 0xC0 0x1A
    """
    _crc32_encode(0x1AC05000, rd, rn, rm)

fn emit_neon_crc32ch(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CH Wd, Wn, Wm — CRC-32C on halfword input.
    # ARMv8 ARM §C7.2.37 CRC32CH; base 0x1AC05400
    # Canonical (W0,W0,W0): 0x00 0x54 0xC0 0x1A
    """
    _crc32_encode(0x1AC05400, rd, rn, rm)

fn emit_neon_crc32cw(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CW Wd, Wn, Wm — CRC-32C on word input.
    # ARMv8 ARM §C7.2.37 CRC32CW; base 0x1AC05800
    # Canonical (W0,W0,W0): 0x00 0x58 0xC0 0x1A
    """
    _crc32_encode(0x1AC05800, rd, rn, rm)

fn emit_neon_crc32cx(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CX Wd, Wn, Xm — CRC-32C on doubleword input.
    # ARMv8 ARM §C7.2.37 CRC32CX; base 0x9AC05C00
    # Canonical (W0,W0,X0): 0x00 0x5C 0xC0 0x9A
    """
    _crc32_encode(0x9AC05C00, rd, rn, rm)

# ============================================================================
# SDOT / UDOT — Integer Dot Product (ARMv8.2-DotProd)
# ============================================================================

fn _dot_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode SDOT/UDOT: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_sdot_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SDOT Vd.4S, Vn.16B, Vm.16B — signed int8 dot product, 4 lanes.
    # ARMv8 ARM §C7.2.258 SDOT (vector); Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x4E  [llvm-mc VERIFIED]
    """
    _dot_encode(0x4E809400, rd, rn, rm)

fn emit_neon_udot_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UDOT Vd.4S, Vn.16B, Vm.16B — unsigned int8 dot product, 4 lanes.
    # ARMv8 ARM §C7.2.363 UDOT (vector); Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x6E  [llvm-mc VERIFIED]
    """
    _dot_encode(0x6E809400, rd, rn, rm)

fn emit_neon_sdot_2s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SDOT Vd.2S, Vn.8B, Vm.8B — signed int8 dot product, 2 lanes (64-bit).
    # ARMv8 ARM §C7.2.258 SDOT (vector); Q=0, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x0E
    """
    _dot_encode(0x0E809400, rd, rn, rm)

fn emit_neon_udot_2s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UDOT Vd.2S, Vn.8B, Vm.8B — unsigned int8 dot product, 2 lanes (64-bit).
    # ARMv8 ARM §C7.2.363 UDOT (vector); Q=0, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x2E
    """
    _dot_encode(0x2E809400, rd, rn, rm)

# ============================================================================
# SQADD / UQADD / SQSUB / UQSUB — Saturating Arithmetic (NEON)
# ============================================================================

fn _sat_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode saturating op: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_sqadd_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SQADD Vd.4S, Vn.4S, Vm.4S — signed saturating add, 4×32-bit.
    # ARMv8 ARM §C7.2.274 SQADD; Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x0C 0xA0 0x4E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x4EA00C00, rd, rn, rm)

fn emit_neon_uqadd_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UQADD Vd.4S, Vn.4S, Vm.4S — unsigned saturating add, 4×32-bit.
    # ARMv8 ARM §C7.2.363 UQADD; Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x0C 0xA0 0x6E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x6EA00C00, rd, rn, rm)

fn emit_neon_sqsub_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SQSUB Vd.4S, Vn.4S, Vm.4S — signed saturating subtract, 4×32-bit.
    # ARMv8 ARM §C7.2.277 SQSUB; Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x2C 0xA0 0x4E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x4EA02C00, rd, rn, rm)

fn emit_neon_uqsub_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UQSUB Vd.4S, Vn.4S, Vm.4S — unsigned saturating subtract, 4×32-bit.
    # ARMv8 ARM §C7.2.366 UQSUB; Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x2C 0xA0 0x6E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x6EA02C00, rd, rn, rm)

# ============================================================================
# BFDOT / BFMMLA / BFCVTN / BFCVTN2 — BFloat16 Instructions (ARMv8.6-A)
# ============================================================================
#
# BF16 register arguments are raw vector register indices 0-31.
# All return [i64] (4 bytes, little-endian).
#
# Encodings verified from ARMv8 ARM §C7.2.19-21.

fn _bf16_3reg_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode 3-register BF16 op: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn _bf16_2reg_encode(base: i64, rd: i64, rn: i64) -> [i64]:
    """Encode 2-register BF16 op: base + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_bfdot_v4bf16(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit BFDOT Vd.2S, Vn.4H, Vm.4H — BF16 dot product accumulate, 64-bit (Q=0).
    # ARMv8 ARM §C7.2.20 BFDOT (vector); Q=0, size=01
    # Base 0x2E40FC00
    # Canonical (V0,V0,V0): 0x00 0xFC 0x40 0x2E
    """
    _bf16_3reg_encode(0x2E40FC00, rd, rn, rm)

fn emit_bfmmla_v4bf16(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit BFMMLA Vd.4S, Vn.8H, Vm.8H — BF16 matrix multiply-accumulate, 128-bit (Q=1).
    # ARMv8 ARM §C7.2.21 BFMMLA; Q=1, size=01
    # Base 0x6E40EC00
    # Canonical (V0,V0,V0): 0x00 0xEC 0x40 0x6E
    """
    _bf16_3reg_encode(0x6E40EC00, rd, rn, rm)

fn emit_bfcvtn_v4bf16(rd: i64, rn: i64) -> [i64]:
    """
    Emit BFCVTN Vd.4H, Vn.4S — narrow float32→bfloat16 into lower half (Q=0).
    # ARMv8 ARM §C7.2.19 BFCVTN; Q=0
    # Base 0x0EA16800
    # Canonical (V0,V0): 0x00 0x68 0xA1 0x0E
    """
    _bf16_2reg_encode(0x0EA16800, rd, rn)

fn emit_bfcvtn2_v8bf16(rd: i64, rn: i64) -> [i64]:
    """
    Emit BFCVTN2 Vd.8H, Vn.4S — narrow float32→bfloat16 into upper half (Q=1).
    # ARMv8 ARM §C7.2.19 BFCVTN2; Q=1
    # Base 0x4EA16800
    # Canonical (V0,V0): 0x00 0x68 0xA1 0x4E
    """
    _bf16_2reg_encode(0x4EA16800, rd, rn)

# ============================================================================
# FCVTN / FCVTL / FCVTZS / FCVTZU — FP16 Conversion Instructions (ARMv8.2-A)
# ============================================================================
#
# These are 2-register (Vd, Vn) Advanced SIMD instructions.
# Encoding: base + (rn % 32) * 32 + (rd % 32) → 4 LE bytes.
# All accept raw register indices 0-31 and return [i64] (4 bytes, little-endian).
#
# ARMv8.2-A FP16 extension required for FCVTN/FCVTL .4H/.8H variants.
# FCVTZS/FCVTZU operate on .4S (f32→int32) and do not require FP16 extension.

fn _fp16_2reg_encode(base: i64, rd: i64, rn: i64) -> [i64]:
    """Encode 2-register FP16 conversion: base + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_fcvtn_4h(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTN Vd.4H, Vn.4S — narrow float32→float16 into lower half (Q=0).
    Base opcode 0x0E216800: Q=0, U=0, sz=0, opcode=10110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.67 FCVTN (vector, .4H form)
    # Encoding: 0_Q_0_01110_0_sz_10001_11010_00_Rn_Rd
    # Q=0 (64-bit result), sz=0 (fp16 output from fp32 input)
    # Base word: 0x0E216800 → LE: 0x00 0x68 0x21 0x0E
    # Canonical: FCVTN V0.4H, V0.4S → [0x00, 0x68, 0x21, 0x0E]
    """
    _fp16_2reg_encode(0x0E216800, rd, rn)

fn emit_fcvtn2_8h(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTN2 Vd.8H, Vn.4S — narrow float32→float16 into upper half (Q=1).
    Base opcode 0x4E216800: Q=1, U=0, sz=0, opcode=10110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.67 FCVTN (vector, .8H form, FCVTN2)
    # Q=1 (128-bit, writes upper half of Vd.8H)
    # Base word: 0x4E216800 → LE: 0x00 0x68 0x21 0x4E
    # Canonical: FCVTN2 V0.8H, V0.4S → [0x00, 0x68, 0x21, 0x4E]
    """
    _fp16_2reg_encode(0x4E216800, rd, rn)

fn emit_fcvtl_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTL Vd.4S, Vn.4H — widen float16→float32 from lower half (Q=0).
    Base opcode 0x0E217800: Q=0, U=0, sz=0, opcode=10111.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.66 FCVTL (vector, .4S form)
    # Q=0 (reads lower 4 lanes of Vn.4H, widens to Vd.4S)
    # Base word: 0x0E217800 → LE: 0x00 0x78 0x21 0x0E
    # Canonical: FCVTL V0.4S, V0.4H → [0x00, 0x78, 0x21, 0x0E]
    """
    _fp16_2reg_encode(0x0E217800, rd, rn)

fn emit_fcvtl2_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTL2 Vd.4S, Vn.8H — widen float16→float32 from upper half (Q=1).
    Base opcode 0x4E217800: Q=1, U=0, sz=0, opcode=10111.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.66 FCVTL (vector, .4S form, FCVTL2)
    # Q=1 (reads upper 4 lanes of Vn.8H, widens to Vd.4S)
    # Base word: 0x4E217800 → LE: 0x00 0x78 0x21 0x4E
    # Canonical: FCVTL2 V0.4S, V0.8H → [0x00, 0x78, 0x21, 0x4E]
    """
    _fp16_2reg_encode(0x4E217800, rd, rn)

fn emit_fcvtzs_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTZS Vd.4S, Vn.4S — float32→signed int32, truncate toward zero, 4 lanes.
    Base opcode 0x4EA1B800: Q=1, U=0, sz=1 (f32), opcode=11011.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.68 FCVTZS (vector, integer, .4S form)
    # Q=1 (128-bit), U=0 (signed), sz=1 (single-precision input)
    # Base word: 0x4EA1B800 → LE: 0x00 0xB8 0xA1 0x4E
    # Canonical: FCVTZS V0.4S, V0.4S → [0x00, 0xB8, 0xA1, 0x4E]
    """
    _fp16_2reg_encode(0x4EA1B800, rd, rn)

fn emit_fcvtzu_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTZU Vd.4S, Vn.4S — float32→unsigned int32, truncate toward zero, 4 lanes.
    Base opcode 0x6EA1B800: Q=1, U=1, sz=1 (f32), opcode=11011.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.69 FCVTZU (vector, integer, .4S form)
    # Q=1 (128-bit), U=1 (unsigned), sz=1 (single-precision input)
    # Base word: 0x6EA1B800 → LE: 0x00 0xB8 0xA1 0x6E
    # Canonical: FCVTZU V0.4S, V0.4S → [0x00, 0xB8, 0xA1, 0x6E]
    """
    _fp16_2reg_encode(0x6EA1B800, rd, rn)

