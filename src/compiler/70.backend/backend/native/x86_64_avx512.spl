    []

fn encode_avx512_scatter_f32x16(base_reg: i64, idx_zmm: i64, scale: i64, src: i64, kmask: i64) -> [i64]:
    """
    Scaffold: VSCATTERDPS [base_reg + zmm_idx * scale]{kmask}, zmm_src
    MachOpcode: SimdZmmScatter
    M1 fills per simd_backend_strict_emit_detail_part1.md §3 (VSIB + write mask).
    PRECONDITION: kmask != k0 (G-01 §8.2; k0 guard required).
    """
    # @allow unimplemented_placeholder
    []

