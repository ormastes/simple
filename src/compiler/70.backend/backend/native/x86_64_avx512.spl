# ============================================================================
# Diagnostic Helper
# ============================================================================

fn avx512_zmm_reg_name(id: i64) -> text:
    """Convert ZMM register ID to name string for diagnostics and ICE messages."""
    val idx = zmm_to_index(id)
    "zmm{idx}"

