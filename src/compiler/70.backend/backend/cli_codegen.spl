# C Backend — CLI Keyword Code Generation
#
# Generates C code for `cli Name:` declarations:
# 1. typedef struct for parsed args
# 2. O(1) switch(len){switch(s[0]){memcmp}} argument parser
# 3. Static help text string from docstrings
#
# The generated C functions are:
#   - spl_cli_parse(argc, argv) -> struct
#   - spl_cli_help() -> const char*
#
# This module is called by the C backend when it encounters DECL_CLI nodes.

# ===== Help Text Generation =====

fn cli_codegen_help_text(fields: [text], directives: [text]) -> text:
    # Generate a static C string containing formatted help text
    var help = ""

    # Extract top-level docstring
    for dir in directives:
        if dir.starts_with("doc:"):
            help = help + dir[4:] + "\\n\\n"

    help = help + "Usage: [options] [command] [args...]\\n\\n"
    help = help + "Options:\\n"

    for meta in fields:
        val name = cli_cg_meta_name(meta)
        val type_char = cli_cg_meta_type(meta)
        val default_str = cli_cg_meta_default(meta)
        val short = cli_cg_meta_short(meta)
        val doc = cli_cg_meta_doc(meta)
        val flag = cli_cg_name_to_flag(name)

        var line = "  "
        if short != "":
            line = line + "-" + short + ", "
        else:
            line = line + "    "
        line = line + flag
        if type_char != "b":
            line = line + "=<" + name + ">"
        # Pad to 30 chars
        while line.len() < 30:
            line = line + " "
        if doc != "":
            line = line + doc
        help = help + line + "\\n"

    help = help + "  -h, --help                  Show this help message\\n"
    help

# ===== C Struct Generation =====

fn cli_codegen_struct(struct_name: text, fields: [text]) -> text:
    var code = "typedef struct {\n"
    for meta in fields:
        val name = cli_cg_meta_name(meta)
        val type_char = cli_cg_meta_type(meta)
        if type_char == "b":
            code = code + "    bool " + name + ";\n"
        elif type_char == "s":
            code = code + "    const char* " + name + ";\n"
        elif type_char == "i":
            code = code + "    int64_t " + name + ";\n"
        elif type_char == "f":
            code = code + "    double " + name + ";\n"
        elif type_char == "a":
            code = code + "    SplArray* " + name + ";\n"
    # Built-in fields
    code = code + "    const char* command;\n"
    code = code + "    const char* file_path;\n"
    code = code + "    int help_requested;\n"
    code = code + "} " + struct_name + ";\n\n"
    code

# ===== O(1) Switch-Tree Parser =====

fn cli_codegen_parser(struct_name: text, fields: [text], directives: [text]) -> text:
    var code = "static " + struct_name + " spl_cli_parse(int argc, const char** argv) {\n"
    code = code + "    " + struct_name + " args;\n"
    code = code + "    memset(&args, 0, sizeof(args));\n\n"

    # Set defaults
    for meta in fields:
        val name = cli_cg_meta_name(meta)
        val type_char = cli_cg_meta_type(meta)
        val default_str = cli_cg_meta_default(meta)
        if type_char == "b":
            if default_str == "true":
                code = code + "    args." + name + " = true;\n"
        elif type_char == "s":
            code = code + "    args." + name + " = \"" + default_str + "\";\n"
        elif type_char == "i":
            code = code + "    args." + name + " = " + default_str + ";\n"
        elif type_char == "f":
            code = code + "    args." + name + " = " + default_str + ";\n"

    code = code + "    args.command = \"\";\n"
    code = code + "    args.file_path = \"\";\n"
    code = code + "    args.help_requested = 0;\n\n"

    # Parse loop
    code = code + "    for (int i = 1; i < argc; i++) {\n"
    code = code + "        const char* arg = argv[i];\n"
    code = code + "        size_t len = strlen(arg);\n\n"

    # Help check
    code = code + "        if (len == 2 && arg[0] == '-' && arg[1] == 'h') { args.help_requested = 1; continue; }\n"
    code = code + "        if (len == 6 && memcmp(arg, \"--help\", 6) == 0) { args.help_requested = 1; continue; }\n\n"

    # Generate O(1) switch tree for --long-name flags
    code = code + "        if (len > 2 && arg[0] == '-' && arg[1] == '-') {\n"
    code = code + "            const char* key = arg + 2;\n"
    code = code + "            size_t klen = len - 2;\n"

    # Check for --key=value
    code = code + "            const char* eq = strchr(key, '=');\n"
    code = code + "            const char* val_str = NULL;\n"
    code = code + "            if (eq) { klen = eq - key; val_str = eq + 1; }\n\n"

    # Group options by flag length for switch tree
    var max_len = 0
    for meta in fields:
        val flag_name = cli_cg_name_to_hyphen(cli_cg_meta_name(meta))
        if flag_name.len() > max_len:
            max_len = flag_name.len()

    code = code + "            switch (klen) {\n"

    # For each possible length, emit cases
    var target_len = 1
    while target_len <= max_len:
        var has_match = false
        for meta in fields:
            val flag_name = cli_cg_name_to_hyphen(cli_cg_meta_name(meta))
            if flag_name.len() == target_len:
                has_match = true
                break
        if has_match:
            code = code + "                case " + "{target_len}" + ":\n"
            for meta in fields:
                val name = cli_cg_meta_name(meta)
                val type_char = cli_cg_meta_type(meta)
                val flag_name = cli_cg_name_to_hyphen(name)
                if flag_name.len() == target_len:
                    code = code + "                    if (memcmp(key, \"" + flag_name + "\", " + "{target_len}" + ") == 0) {\n"
                    if type_char == "b":
                        code = code + "                        args." + name + " = val_str ? (val_str[0] == 't' || val_str[0] == '1') : true;\n"
                    elif type_char == "s":
                        code = code + "                        args." + name + " = val_str ? val_str : (i+1 < argc ? argv[++i] : \"\");\n"
                    elif type_char == "i":
                        code = code + "                        args." + name + " = val_str ? atoll(val_str) : (i+1 < argc ? atoll(argv[++i]) : 0);\n"
                    elif type_char == "f":
                        code = code + "                        args." + name + " = val_str ? atof(val_str) : (i+1 < argc ? atof(argv[++i]) : 0.0);\n"
                    code = code + "                        continue;\n"
                    code = code + "                    }\n"
            code = code + "                    break;\n"
        target_len = target_len + 1

    code = code + "            }\n"
    code = code + "        }\n\n"

    # Short flag handling
    code = code + "        if (len == 2 && arg[0] == '-') {\n"
    for meta in fields:
        val name = cli_cg_meta_name(meta)
        val type_char = cli_cg_meta_type(meta)
        val short = cli_cg_meta_short(meta)
        if short != "":
            code = code + "            if (arg[1] == '" + short + "') {\n"
            if type_char == "b":
                code = code + "                args." + name + " = true;\n"
            elif type_char == "s":
                code = code + "                args." + name + " = (i+1 < argc) ? argv[++i] : \"\";\n"
            elif type_char == "i":
                code = code + "                args." + name + " = (i+1 < argc) ? atoll(argv[++i]) : 0;\n"
            elif type_char == "f":
                code = code + "                args." + name + " = (i+1 < argc) ? atof(argv[++i]) : 0.0;\n"
            code = code + "                continue;\n"
            code = code + "            }\n"
    code = code + "        }\n\n"

    # File detection
    for dir in directives:
        if dir.starts_with("file:"):
            val ext = dir[5:]
            val ext_len = ext.len()
            code = code + "        // File detection: *" + ext + "\n"
            code = code + "        if (len > " + "{ext_len}" + " && memcmp(arg + len - " + "{ext_len}" + ", \"" + ext + "\", " + "{ext_len}" + ") == 0) {\n"
            code = code + "            args.file_path = arg;\n"
            code = code + "            continue;\n"
            code = code + "        }\n\n"

    # Remaining args treated as command or positional
    code = code + "        // First non-flag arg is command\n"
    code = code + "        if (args.command[0] == '\\0') {\n"
    code = code + "            args.command = arg;\n"
    code = code + "        }\n"

    code = code + "    }\n\n"

    # Apply default command
    for dir in directives:
        if dir.starts_with("default:"):
            val default_cmd = dir[8:]
            code = code + "    if (args.command[0] == '\\0') args.command = \"" + default_cmd + "\";\n"

    code = code + "    return args;\n"
    code = code + "}\n\n"
    code

# ===== Full Codegen =====

fn cli_codegen_full(struct_name: text, fields: [text], directives: [text]) -> text:
    var code = "/* Generated by Simple CLI codegen */\n"
    code = code + "#include <string.h>\n"
    code = code + "#include <stdlib.h>\n"
    code = code + "#include <stdio.h>\n"
    code = code + "#include <stdbool.h>\n"
    code = code + "#include <stdint.h>\n\n"

    code = code + cli_codegen_struct(struct_name, fields)

    # Help text
    val help_text = cli_codegen_help_text(fields, directives)
    code = code + "static const char* spl_cli_help_text = \"" + help_text + "\";\n\n"

    code = code + "static void spl_cli_print_help(void) {\n"
    code = code + "    fputs(spl_cli_help_text, stdout);\n"
    code = code + "}\n\n"

    code = code + cli_codegen_parser(struct_name, fields, directives)
    code

# ===== Metadata Helpers =====

fn cli_cg_meta_name(meta: text) -> text:
    var i = 0
    while i < meta.len():
        if meta[i] == "|":
            return meta[0:i]
        i = i + 1
    meta

fn cli_cg_meta_type(meta: text) -> text:
    var pipe_count = 0
    var start = 0
    var i = 0
    while i < meta.len():
        if meta[i] == "|":
            pipe_count = pipe_count + 1
            if pipe_count == 1:
                start = i + 1
            if pipe_count == 2:
                return meta[start:i]
        i = i + 1
    if pipe_count >= 1:
        return meta[start:]
    "s"

fn cli_cg_meta_default(meta: text) -> text:
    var pipe_count = 0
    var start = 0
    var i = 0
    while i < meta.len():
        if meta[i] == "|":
            pipe_count = pipe_count + 1
            if pipe_count == 2:
                start = i + 1
            if pipe_count == 3:
                return meta[start:i]
        i = i + 1
    if pipe_count >= 2:
        return meta[start:]
    ""

fn cli_cg_meta_short(meta: text) -> text:
    var pipe_count = 0
    var start = 0
    var i = 0
    while i < meta.len():
        if meta[i] == "|":
            pipe_count = pipe_count + 1
            if pipe_count == 3:
                start = i + 1
            if pipe_count == 4:
                return meta[start:i]
        i = i + 1
    if pipe_count >= 3:
        return meta[start:]
    ""

fn cli_cg_meta_doc(meta: text) -> text:
    var pipe_count = 0
    var start = 0
    var i = 0
    while i < meta.len():
        if meta[i] == "|":
            pipe_count = pipe_count + 1
            if pipe_count == 4:
                start = i + 1
        i = i + 1
    if pipe_count >= 4:
        return meta[start:]
    ""

fn cli_cg_name_to_flag(name: text) -> text:
    # Convert option_name to --option-name
    var result = "--"
    var i = 0
    while i < name.len():
        if name[i] == "_":
            result = result + "-"
        else:
            result = result + name[i]
        i = i + 1
    result

fn cli_cg_name_to_hyphen(name: text) -> text:
    # Convert option_name to option-name (without --)
    var result = ""
    var i = 0
    while i < name.len():
        if name[i] == "_":
            result = result + "-"
        else:
            result = result + name[i]
        i = i + 1
    result

export cli_codegen_full, cli_codegen_struct, cli_codegen_parser, cli_codegen_help_text
