# Lua Backend - MIR to Lua 5.2+/LuaJIT Source Translation
#
# Translates MIR to Lua source code using goto-per-block lowering.
# Each MirBlock becomes a ::bbN:: label; terminators lower to goto/if/return.
# ALL locals declared upfront so LuaJIT goto cannot jump over a local's scope.
#
# ponytail: goto-per-block lowering; relooper for readability if needed
#
# Output format:
#   local M = {}
#   function M.func_name(params) ... end
#   return M
#
# Usage: bin/simple run src/app/compile/lua_mir_backend.spl <source.spl> -o <out.lua>

use compiler.mir.mir_data.{
    MirModule, MirFunction, MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind, MirBinOp, MirUnaryOp,
    AggregateKind, BlockId, SwitchCase,
    MirType, MirTypeKind, MirConstValue, MirLocal, LocalId, LocalKind
}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, BackendCompileOptions}

# ============================================================================
# MirToLua - Core translator class
# ============================================================================

class MirToLua:
    """Translates a MirModule to Lua 5.2+/LuaJIT source text."""
    module_name: text
    output: text

    static fn create(module_name: text) -> MirToLua:
        MirToLua(module_name: module_name, output: "")

    me emit(s: text):
        self.output = self.output + s

    me emit_line(s: text):
        self.output = self.output + s + "\n"

    fn local_name(id: i64) -> text:
        "_v{id}"

    fn operand_text(op: MirOperand) -> text:
        match op.kind:
            case Copy(local):
                self.local_name(local.id)
            case Move(local):
                self.local_name(local.id)
            case Const(value, _):
                self.const_value_text(value)

    fn const_value_text(value: MirConstValue) -> text:
        match value:
            case Int(n): "{n}"
            case Float(f): "{f}"
            case Bool(b): if b: "true" else: "false"
            case Str(s): self.lua_quoted(s)
            case Zero: "nil"
            case Array(_): "{}"
            case Tuple(_): "{}"
            case Struct(_): "{}"

    fn lua_quoted(s: text) -> text:
        # Basic Lua string quoting: escape backslash, double-quote, newline, nul
        var r = "\""
        var i = 0
        while i < s.len():
            val c = s.char_at(i)
            if c == "\\":
                r = r + "\\\\"
            else:
                if c == "\"":
                    r = r + "\\\""
                else:
                    if c == "\n":
                        r = r + "\\n"
                    else:
                        if c == "\r":
                            r = r + "\\r"
                        else:
                            r = r + c
            i = i + 1
        r + "\""

    fn binop_text(op: MirBinOp) -> text:
        match op:
            case Add: "+"
            case Sub: "-"
            case Mul: "*"
            case Div: "/"
            case Rem: "%"
            case Pow: "^"
            case Eq: "=="
            case Ne: "~="
            case Lt: "<"
            case Le: "<="
            case Gt: ">"
            case Ge: ">="
            case BitAnd: "&"
            case BitOr: "|"
            case BitXor: "~"
            case Shl: "<<"
            case Shr: ">>"
            case _: error("lua backend: unsupported binop")

    me translate_module(module: MirModule) -> text:
        self.emit_line("-- Generated by Simple Lua backend (ponytail: goto-per-block lowering)")
        self.emit_line("-- Module: {module.name}")
        self.emit_line("local M = {}")
        self.emit_line("")

        for sym_id in module.functions.keys():
            val func = module.functions[sym_id]
            if not func.is_generic_template:
                self.translate_function(func)

        self.emit_line("return M")
        self.output

    me translate_function(func: MirFunction):
        # Build parameter list from locals with LocalKind.Arg
        var params = ""
        for local in func.locals:
            match local.kind:
                case Arg(_):
                    val lname = self.local_name(local.id.id)
                    if params == "":
                        params = lname
                    else:
                        params = params + ", " + lname
                case _: ()

        self.emit_line("function M.{func.name}({params})")

        # Declare ALL non-param locals upfront (LuaJIT goto scope rule)
        var has_locals = false
        for local in func.locals:
            match local.kind:
                case Arg(_): ()
                case _:
                    if not has_locals:
                        self.emit("  local ")
                        has_locals = true
                    else:
                        self.emit(", ")
                    self.emit(self.local_name(local.id.id))
        if has_locals:
            self.emit_line("")

        # Emit each block
        var block_idx = 0
        while block_idx < func.blocks.len():
            val block = func.blocks[block_idx]
            self.translate_block(block)
            block_idx = block_idx + 1

        self.emit_line("end")
        self.emit_line("")

    me translate_block(block: MirBlock):
        self.emit_line("  ::bb{block.id.id}::")
        for inst in block.instructions:
            self.translate_instruction(inst)
        self.translate_terminator(block.terminator)

    me translate_instruction(inst: MirInst):
        match inst.kind:
            case Const(dest, value, _):
                val lname = self.local_name(dest.id)
                val vtext = self.const_value_text(value)
                self.emit_line("  {lname} = {vtext}")

            case Copy(dest, src):
                self.emit_line("  {self.local_name(dest.id)} = {self.local_name(src.id)}")

            case Move(dest, src):
                self.emit_line("  {self.local_name(dest.id)} = {self.local_name(src.id)}")

            case BinOp(dest, op, left, right):
                val lname = self.local_name(dest.id)
                val ltext = self.operand_text(left)
                val rtext = self.operand_text(right)
                val optext = self.binop_text(op)
                self.emit_line("  {lname} = {ltext} {optext} {rtext}")

            case CheckedBinOp(dest, op, left, right):
                val lname = self.local_name(dest.id)
                val ltext = self.operand_text(left)
                val rtext = self.operand_text(right)
                val optext = self.binop_text(op)
                self.emit_line("  {lname} = {ltext} {optext} {rtext}")

            case UnaryOp(dest, op, operand):
                val lname = self.local_name(dest.id)
                val otext = self.operand_text(operand)
                val optext = match op:
                    case Neg: "-"
                    case Not: "not "
                    case BitNot: "~"
                    case Transpose: error("lua backend: unsupported unary op Transpose")
                self.emit_line("  {lname} = {optext}{otext}")

            case Call(dest, func, args):
                val ftext = self.operand_text(func)
                var arg_text = ""
                for arg in args:
                    val atext = self.operand_text(arg)
                    if arg_text == "":
                        arg_text = atext
                    else:
                        arg_text = arg_text + ", " + atext
                if dest.?:
                    val lname = self.local_name(dest.unwrap().id)
                    self.emit_line("  {lname} = {ftext}({arg_text})")
                else:
                    self.emit_line("  {ftext}({arg_text})")

            case Aggregate(dest, kind, ops):
                val lname = self.local_name(dest.id)
                var fields = ""
                for op in ops:
                    val otext = self.operand_text(op)
                    if fields == "":
                        fields = otext
                    else:
                        fields = fields + ", " + otext
                self.emit_line("  {lname} = {{{fields}}}")

            case GetField(dest, base, field):
                val lname = self.local_name(dest.id)
                val btext = self.operand_text(base)
                # Lua tables are 1-indexed; MIR fields are 0-indexed
                val lua_idx = field + 1
                self.emit_line("  {lname} = {btext}[{lua_idx}]")

            case SetField(base, field, value):
                val btext = self.operand_text(base)
                val vtext = self.operand_text(value)
                val lua_idx = field + 1
                self.emit_line("  {btext}[{lua_idx}] = {vtext}")

            case GetElementPtr(dest, base, indices):
                # Array index with 1-based conversion for first index
                val lname = self.local_name(dest.id)
                val btext = self.operand_text(base)
                if indices.len() > 0:
                    val idx_text = self.operand_text(indices[0])
                    self.emit_line("  {lname} = {btext}[{idx_text} + 1]")
                else:
                    self.emit_line("  {lname} = {btext}")

            case Load(dest, ptr):
                val lname = self.local_name(dest.id)
                val ptext = self.operand_text(ptr)
                self.emit_line("  {lname} = {ptext}")

            case Store(ptr, value):
                val ptext = self.operand_text(ptr)
                val vtext = self.operand_text(value)
                self.emit_line("  {ptext} = {vtext}")

            case Cast(dest, op, _):
                val lname = self.local_name(dest.id)
                val otext = self.operand_text(op)
                self.emit_line("  {lname} = {otext}")

            case Bitcast(dest, op, _):
                val lname = self.local_name(dest.id)
                val otext = self.operand_text(op)
                self.emit_line("  {lname} = {otext}")

            case Alloc(dest, _):
                val lname = self.local_name(dest.id)
                self.emit_line("  {lname} = {{}}")

            case CallIndirect(dest, ptr, args, _):
                val ftext = self.operand_text(ptr)
                var arg_text = ""
                for arg in args:
                    val atext = self.operand_text(arg)
                    if arg_text == "":
                        arg_text = atext
                    else:
                        arg_text = arg_text + ", " + atext
                if dest.?:
                    val lname = self.local_name(dest.unwrap().id)
                    self.emit_line("  {lname} = {ftext}({arg_text})")
                else:
                    self.emit_line("  {ftext}({arg_text})")

            case Intrinsic(dest, name, args):
                var arg_text = ""
                for arg in args:
                    val atext = self.operand_text(arg)
                    if arg_text == "":
                        arg_text = atext
                    else:
                        arg_text = arg_text + ", " + atext
                if dest.?:
                    val lname = self.local_name(dest.unwrap().id)
                    self.emit_line("  {lname} = __intrinsic_{name}({arg_text})")
                else:
                    self.emit_line("  __intrinsic_{name}({arg_text})")

            case DebugValue(_, _): ()
            case Nop: ()

            case _:
                self.emit_line("  error(\"lua backend: unsupported instruction\")")

    me translate_terminator(term: MirTerminator):
        match term:
            case Goto(target):
                self.emit_line("  goto bb{target.id}")

            case Ret(value):
                if value.?:
                    val vtext = self.operand_text(value.unwrap())
                    self.emit_line("  return {vtext}")
                else:
                    self.emit_line("  return")

            case If(cond, then_, else_):
                val ctext = self.operand_text(cond)
                self.emit_line("  if {ctext} then goto bb{then_.id} else goto bb{else_.id} end")

            case Switch(value, targets, default):
                val vtext = self.operand_text(value)
                var first = true
                for sc in targets:
                    if first:
                        self.emit_line("  if {vtext} == {sc.value} then goto bb{sc.target.id}")
                        first = false
                    else:
                        self.emit_line("  elseif {vtext} == {sc.value} then goto bb{sc.target.id}")
                self.emit_line("  else goto bb{default.id} end")

            case Unreachable:
                self.emit_line("  error(\"lua backend: unreachable\")")

            case Abort(message):
                self.emit_line("  error({self.lua_quoted(message)})")

            case CallTerminator(dest, func, args, normal, unwind):
                val ftext = self.operand_text(func)
                var arg_text = ""
                for arg in args:
                    val atext = self.operand_text(arg)
                    if arg_text == "":
                        arg_text = atext
                    else:
                        arg_text = arg_text + ", " + atext
                if dest.?:
                    val lname = self.local_name(dest.unwrap().id)
                    self.emit_line("  {lname} = {ftext}({arg_text})")
                else:
                    self.emit_line("  {ftext}({arg_text})")
                self.emit_line("  goto bb{normal.id}")

# ============================================================================
# LuaBackend - Backend interface for BackendFactory
# ============================================================================

class LuaBackend:
    """Backend wrapper for BackendFactory.create_specific()."""
    target: CodegenTarget
    options: BackendCompileOptions

    static fn create(target: CodegenTarget, options: BackendCompileOptions) -> LuaBackend:
        LuaBackend(target: target, options: options)

# ============================================================================
# Exports
# ============================================================================

export MirToLua, LuaBackend
