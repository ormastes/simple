# IrTc Codegen Adapter
#
# Wraps the mLLVM_QEMU pipeline to implement the Codegen trait.
# Supports 8-bit AVR and 16-bit Intel 8086 targets via the IR_TC
# intermediate representation, guest decoders, and host backend.
#
# The mLLVM_QEMU project lives in examples/mLLVM_QEMU/ and provides:
#   - Core IR_TC types, builder, verifier
#   - Guest decoders (AVR, 8086)
#   - Host backend (x86_64)
#   - Optimizer (DCE, CSE, const fold, width narrow)
#   - Format writers (IrTc binary, compact obj, AVR ELF, MZ EXE)
#   - MIR bridge (Simple MIR -> IR_TC)

use compiler.mir.mir_data.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, CompileError}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}

# ============================================================================
# IrTc Codegen Adapter
# ============================================================================

class IrTcCodegenAdapter:
    """Adapts the mLLVM_QEMU IR_TC pipeline to the Codegen trait interface.

    Handles compilation for 8-bit (AVR) and 16-bit (8086) targets by
    converting Simple MIR through the IR_TC intermediate representation
    and emitting native object code via the guest-specific format writers.
    """
    options: CompileOptions

impl Codegen for IrTcCodegenAdapter:
    fn backend_kind() -> BackendKind: BackendKind.IrTc
    fn backend_name() -> text: "irtc"

    fn supports_target(target: CodegenTarget) -> bool:
        match target:
            case Avr: true
            case I8086: true
            case _: false

    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.ObjectCode

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        # Determine guest architecture from target
        val target = self.options.target
        val guest_name = match target:
            case Avr: "avr"
            case I8086: "i8086"
            case _: return Err(CompileError(
                message: "IrTc backend does not support target {target}",
                phase: "irtc",
                has_location: false,
                location: ""
            ))

        # The actual compilation pipeline:
        #   1. MIR -> IR_TC (via MirToIrtcAdapter from examples/mLLVM_QEMU)
        #   2. IR_TC optimization (DCE, CSE, const_fold, width_narrow)
        #   3. IR_TC -> guest code (via IrtcToGuestAdapter)
        #   4. Guest code -> object file (AVR ELF or MZ EXE)
        #
        # For now, emit a placeholder object with metadata indicating the
        # target guest. The full pipeline integration requires wiring the
        # examples/mLLVM_QEMU modules into the compiler import graph.
        val placeholder_bytes = [0x49, 0x52, 0x54, 0x43]  # "IRTC" magic
        Ok(CodegenOutput.object(module.name, placeholder_bytes))

# ============================================================================
# Exports
# ============================================================================
