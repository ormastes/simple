# LLVM Version Compatibility
#
# Centralized version parsing, supported range policy, and diagnostics.
# Single source of truth for LLVM version handling across all backends.
#
# Supported range: LLVM 16-19
# Policy: warn on too-new, error on too-old, error on mismatch

use app.io.mod (shell)

# ============================================================================
# Version Constants
# ============================================================================

val LLVM_VERSION_MIN = 16
val LLVM_VERSION_MAX = 19
val LLVM_VERSION_PRIMARY = 18

# ============================================================================
# Version Info
# ============================================================================

struct LlvmVersionInfo:
    """Parsed LLVM version information."""
    major: i64
    minor: i64
    patch: i64
    raw: text

impl LlvmVersionInfo:
    static fn unknown() -> LlvmVersionInfo:
        LlvmVersionInfo(major: 0, minor: 0, patch: 0, raw: "unknown")

    fn is_known() -> bool:
        self.major > 0

    fn to_text() -> text:
        if self.major == 0:
            return "unknown"
        "{self.major}.{self.minor}.{self.patch}"

# ============================================================================
# Version Parsing
# ============================================================================

fn parse_llvm_version(version_text: text) -> LlvmVersionInfo:
    """Parse LLVM version string from tool output.

    Handles formats like:
    - "18.1.3"
    - "LLVM version 18.1.3"
    - "Ubuntu LLVM version 18.1.3-1ubuntu1"
    - "clang version 18.1.3 (Ubuntu 18.1.3-1ubuntu1)"

    sdoctest:
        val ver = parse_llvm_version("18.1.3")
        expect(ver.major).to_equal(18)
        expect(ver.minor).to_equal(1)
        expect(ver.patch).to_equal(3)
    """
    val trimmed = version_text.trim()
    if trimmed == "":
        return LlvmVersionInfo.unknown()

    # Find the version number pattern (digits.digits.digits)
    var version_str = ""
    val lines = trimmed.split("\n")
    for line in lines:
        val parts = line.split(" ")
        for part in parts:
            val cleaned = part.trim()
            if cleaned == "":
                continue
            # Check if this part looks like a version number
            if cleaned.contains(".") and cleaned.len() >= 3:
                val first_char = cleaned.substring(0, 1)
                if (first_char == "0" or first_char == "1" or first_char == "2" or
                    first_char == "3" or first_char == "4" or first_char == "5" or
                    first_char == "6" or first_char == "7" or first_char == "8" or
                    first_char == "9"):
                    version_str = cleaned
                    break
        if version_str != "":
            break

    if version_str == "":
        return LlvmVersionInfo.unknown()

    # Split on dots and parse
    val segments = version_str.split(".")
    if segments.len() < 2:
        return LlvmVersionInfo.unknown()

    # Parse major — strip any trailing non-digit chars
    val major_str = strip_non_digits(segments[0])
    val minor_str = strip_non_digits(segments[1])
    var patch_str = "0"
    if segments.len() >= 3:
        patch_str = strip_non_digits(segments[2])

    val major = parse_int_safe(major_str)
    val minor = parse_int_safe(minor_str)
    val patch = parse_int_safe(patch_str)

    LlvmVersionInfo(major: major, minor: minor, patch: patch, raw: version_str)

fn strip_non_digits(s: text) -> text:
    """Strip trailing non-digit characters from a string."""
    var result = ""
    for ch in s.chars():
        val is_digit = ch >= '0' and ch <= '9'
        if is_digit:
            result = result + ch
        else: break
    result

fn parse_int_safe(s: text) -> i64:
    """Parse an integer, returning 0 on failure."""
    if s == "":
        return 0
    var result: i64 = 0
    for ch in s.chars():
        val d = _digit_value(ch)
        if d < 0:
            break
        result = result * 10 + d
    result

fn _digit_value(ch: text) -> i64:
    """Return digit value 0-9, or -1 if not a digit."""
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

# ============================================================================
# Version Detection
# ============================================================================

fn detect_llc_version() -> LlvmVersionInfo:
    """Detect LLVM version from llc --version output."""
    # Try versioned binaries first (match tool discovery order)
    val candidates = ["llc-19", "llc-18", "llc-17", "llc-16", "llc"]
    for candidate in candidates:
        val (out, err, code) = shell("{candidate} --version 2>&1")
        if code == 0:
            return parse_llvm_version(out)
    LlvmVersionInfo.unknown()

fn detect_opt_version() -> LlvmVersionInfo:
    """Detect LLVM version from opt --version output."""
    val candidates = ["opt-19", "opt-18", "opt-17", "opt-16", "opt"]
    for candidate in candidates:
        val (out, err, code) = shell("{candidate} --version 2>&1")
        if code == 0:
            return parse_llvm_version(out)
    LlvmVersionInfo.unknown()

fn detect_clang_version() -> LlvmVersionInfo:
    """Detect clang version from clang --version output."""
    val candidates = ["clang-19", "clang-18", "clang-17", "clang-16", "clang"]
    for candidate in candidates:
        val (out, err, code) = shell("{candidate} --version 2>&1")
        if code == 0:
            return parse_llvm_version(out)
    LlvmVersionInfo.unknown()

fn detect_libllvm_version() -> LlvmVersionInfo:
    """Detect libLLVM version if available.

    Uses llvm-config or probes shared library naming.
    """
    # Try llvm-config variants
    val candidates = ["llvm-config-19", "llvm-config-18", "llvm-config-17", "llvm-config-16", "llvm-config"]
    for candidate in candidates:
        val (out, err, code) = shell("{candidate} --version 2>&1")
        if code == 0:
            return parse_llvm_version(out)
    LlvmVersionInfo.unknown()

# ============================================================================
# Version Compatibility Checks
# ============================================================================

enum LlvmVersionStatus:
    """Compatibility status for a detected LLVM version."""
    Supported        # Within supported range (16-19)
    TooOld           # Below minimum (< 16)
    TooNew           # Above maximum (> 19), best-effort
    Unknown          # Could not detect version

fn check_version_compatibility(version: LlvmVersionInfo) -> LlvmVersionStatus:
    """Check if a detected LLVM version is within the supported range.

    sdoctest:
        val ver = LlvmVersionInfo(major: 18, minor: 0, patch: 0, raw: "18.0.0")
        expect(check_version_compatibility(ver)).to_equal(LlvmVersionStatus.Supported)
    """
    if not version.is_known():
        return LlvmVersionStatus.Unknown
    if version.major < LLVM_VERSION_MIN:
        return LlvmVersionStatus.TooOld
    if version.major > LLVM_VERSION_MAX:
        return LlvmVersionStatus.TooNew
    LlvmVersionStatus.Supported

fn version_diagnostic(version: LlvmVersionInfo, tool_name: text) -> text:
    """Generate a human-readable diagnostic for version compatibility.

    sdoctest:
        val ver = LlvmVersionInfo(major: 18, minor: 1, patch: 0, raw: "18.1.0")
        expect(version_diagnostic(ver, "llc")).to_contain("supported")
    """
    val status = check_version_compatibility(version)
    match status:
        case Supported:
            "{tool_name} {version.to_text()}: supported"
        case TooOld:
            "{tool_name} {version.to_text()}: too old (minimum LLVM {LLVM_VERSION_MIN} required). " +
            "Upgrade: apt install llvm-{LLVM_VERSION_PRIMARY} (Ubuntu) or brew install llvm (macOS)"
        case TooNew:
            "{tool_name} {version.to_text()}: newer than tested range (LLVM {LLVM_VERSION_MIN}-{LLVM_VERSION_MAX}). " +
            "May work but not officially supported. Report issues if you encounter problems."
        case Unknown:
            "{tool_name}: version unknown"

fn check_version_mismatch(llc_ver: LlvmVersionInfo, lib_ver: LlvmVersionInfo) -> text?:
    """Check for mismatched versions between CLI tools and libLLVM.

    Returns a warning message if versions differ, nil if they match or
    one is unknown.
    """
    if not llc_ver.is_known() or not lib_ver.is_known():
        return nil
    if llc_ver.major != lib_ver.major:
        return Some(
            "WARNING: LLVM version mismatch detected!\n" +
            "  llc version:     {llc_ver.to_text()}\n" +
            "  libLLVM version: {lib_ver.to_text()}\n" +
            "  This may cause inconsistent behavior between llvm and llvm-lib backends.\n" +
            "  Recommendation: install matching versions (e.g., both LLVM {LLVM_VERSION_PRIMARY})"
        )
    nil

# ============================================================================
# Exports
# ============================================================================
