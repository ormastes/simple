# VHDL Kernel Entity Bridge — W3.1
#
# Routes @gpu_kernel MIR functions with gpu_target="vhdl" into the VHDL backend
# as synthesizable entities with a counter-driven loop process (one work-item
# per clock cycle).
#
# Supported v1 subset (fail-closed — anything else returns a diagnostic):
#   - 1D ndrange: gpu_thread_id_x() / gpu_block_id_x() * gpu_block_dim_x()
#     patterns map to a loop counter signal.
#   - Scalar params (I8/I16/I32/I64/U8/U16/U32/U64/Bool): become input ports.
#   - Pointer params: become memory-interface ports (addr_out/data_in/data_out/
#     we_out per array argument).
#   - Return type must be Unit.
#
# Rejected with diagnostics (never emits placeholder comments):
#   - gpu_shared_mem, gpu_syncthreads, gpu_barrier (atomics, 2D/3D ranges, etc.)
#   - Non-scalar, non-pointer param types
#   - Non-unit return type

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirFunction, MirBlock, MirInst, MirInstKind, MirTerminator, GpuBarrierScope, GpuAtomicOpKind}
use compiler.mir.mir_types.{MirLocal, MirType, MirTypeKind, LocalKind}
use compiler.backend.backend.backend_types.{BackendKind, CompileError, compileerror_backend_error}
use compiler.backend.backend.gpu_backend_metadata.{GpuBackendKernelPlan, gpu_backend_accepts_kernel, gpu_backend_plan_module_kernels}
use compiler.backend.vhdl.vhdl_builder.{VhdlBuilder}
use compiler.backend.backend.vhdl_backend.{VhdlEntity}

# ============================================================================
# Acceptance helpers
# ============================================================================

fn vhdl_kernel_accepts(func: MirFunction) -> bool:
    """Return true when this MIR function is a GPU kernel targeting VHDL."""
    if not func.is_kernel:
        return false
    gpu_backend_accepts_kernel(BackendKind.Vhdl, func)

fn vhdl_kernel_plan_module(module: MirModule) -> GpuBackendKernelPlan:
    """Return the VHDL kernel acceptance plan for a module."""
    gpu_backend_plan_module_kernels(BackendKind.Vhdl, module)

# ============================================================================
# Per-instruction unsupported check (fail-closed)
# ============================================================================

fn vhdl_kernel_check_instruction(inst: MirInst) -> text:
    """Return empty string if inst is supported in v1 kernel lane; diagnostic otherwise."""
    match inst.kind:
        case GpuBarrier(_):
            "VHDL-KERNEL-UNSUPPORTED: gpu_syncthreads / gpu_barrier is not supported in the v1 VHDL kernel lane (use stage-boundary pipeline attributes in W3.2)"
        case GpuSharedAlloc(_, _, _):
            "VHDL-KERNEL-UNSUPPORTED: gpu_shared_mem / GpuSharedAlloc is not supported in the v1 VHDL kernel lane (use @memory(banks=n) BRAM templates in W3.2)"
        case GpuAtomicOp(_, _, _, _):
            "VHDL-KERNEL-UNSUPPORTED: GPU atomic operations are not supported in the v1 VHDL kernel lane"
        case GpuAtomicCas(_, _, _, _):
            "VHDL-KERNEL-UNSUPPORTED: GPU atomic CAS operations are not supported in the v1 VHDL kernel lane"
        case GpuMemFence(_):
            "VHDL-KERNEL-UNSUPPORTED: GPU memory fence is not supported in the v1 VHDL kernel lane"
        case GpuGlobalId(_, dim):
            if dim == 0:
                ""
            else:
                "VHDL-KERNEL-UNSUPPORTED: gpu_thread_id for dim {dim} is not supported in the v1 VHDL kernel lane (only 1D ndrange)"
        case GpuLocalId(_, dim):
            if dim == 0:
                ""
            else:
                "VHDL-KERNEL-UNSUPPORTED: gpu_local_id for dim {dim} is not supported in the v1 VHDL kernel lane (only 1D ndrange)"
        case GpuBlockId(_, dim):
            if dim == 0:
                ""
            else:
                "VHDL-KERNEL-UNSUPPORTED: gpu_block_id for dim {dim} is not supported in the v1 VHDL kernel lane (only 1D ndrange)"
        case GpuBlockDim(_, dim):
            if dim == 0:
                ""
            else:
                "VHDL-KERNEL-UNSUPPORTED: gpu_block_dim for dim {dim} is not supported in the v1 VHDL kernel lane (only 1D ndrange)"
        case GpuGridDim(_, dim):
            if dim == 0:
                ""
            else:
                "VHDL-KERNEL-UNSUPPORTED: gpu_grid_dim for dim {dim} is not supported in the v1 VHDL kernel lane (only 1D ndrange)"
        case _:
            ""

fn vhdl_kernel_validate_instructions(func: MirFunction) -> text:
    """Return first unsupported instruction diagnostic, or empty string if all clear."""
    for block in func.blocks:
        for inst in block.instructions:
            val diag = vhdl_kernel_check_instruction(inst)
            if diag.len() > 0:
                return diag
    ""

# ============================================================================
# Parameter type classification
# ============================================================================

fn vhdl_kernel_scalar_type_name(ty: MirType) -> text:
    """Return VHDL type string for a supported scalar type, empty if unsupported."""
    match ty.kind:
        case I8: "signed(7 downto 0)"
        case I16: "signed(15 downto 0)"
        case I32: "signed(31 downto 0)"
        case I64: "signed(63 downto 0)"
        case U8: "unsigned(7 downto 0)"
        case U16: "unsigned(15 downto 0)"
        case U32: "unsigned(31 downto 0)"
        case U64: "unsigned(63 downto 0)"
        case Bool: "bit"
        case _: ""

fn vhdl_kernel_is_scalar_param(ty: MirType) -> bool:
    vhdl_kernel_scalar_type_name(ty).len() > 0

fn vhdl_kernel_is_pointer_param(ty: MirType) -> bool:
    match ty.kind:
        case Ptr(_, _): true
        case _: false

fn vhdl_kernel_validate_params(func: MirFunction) -> text:
    """Return diagnostic if any param type is unsupported, else empty string."""
    for param_type in func.signature.params:
        if not vhdl_kernel_is_scalar_param(param_type) and not vhdl_kernel_is_pointer_param(param_type):
            return "VHDL-KERNEL-UNSUPPORTED: parameter type {param_type.kind} is not supported in the v1 VHDL kernel lane (only scalar integers, booleans, and pointer/array args)"
    ""

fn vhdl_kernel_validate_return(func: MirFunction) -> text:
    """Return diagnostic if return type is non-unit, else empty string."""
    match func.signature.return_type.kind:
        case Unit: ""
        case _: "VHDL-KERNEL-UNSUPPORTED: GPU kernel must have unit return type for VHDL emission (got {func.signature.return_type.kind})"

# ============================================================================
# Port name helpers
# ============================================================================

fn vhdl_kernel_param_name(func: MirFunction, idx: i64) -> text:
    """Return VHDL port name for the idx-th parameter."""
    for local in func.locals:
        match local.kind:
            case Arg(i):
                if i == idx:
                    if local.name.?:
                        return local.name.unwrap()
                    return "arg{idx}"
            case _:
                ()
    "arg{idx}"

# ============================================================================
# Main emission: emit_vhdl_kernel_entity
# ============================================================================

fn emit_vhdl_kernel_entity(func: MirFunction) -> Result<text, CompileError>:
    """
    Emit a synthesizable VHDL entity/architecture for a GPU kernel function.

    The entity has:
    - Standard clock/reset ports (clk : in bit; rst : in bit)
    - ndrange_size : in unsigned(31 downto 0) — total work-item count
    - One input port per scalar kernel parameter
    - For each pointer param: addr_out, data_in, data_out, we_out ports
    - A counter-driven process: one work-item per rising clock edge
    - done_out : out bit — asserted when counter reaches ndrange_size

    Fails with a diagnostic for any unsupported construct.
    """
    val ret_diag = vhdl_kernel_validate_return(func)
    if ret_diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, ret_diag))

    val param_diag = vhdl_kernel_validate_params(func)
    if param_diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, param_diag))

    val inst_diag = vhdl_kernel_validate_instructions(func)
    if inst_diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, inst_diag))

    val entity_name = func.name
    val builder: VhdlBuilder = VhdlBuilder.create(entity_name)
    builder.emit_library_header()

    # --- Entity declaration ---
    builder.emit_entity_begin(entity_name)
    builder.emit_port_begin()

    # Fixed control ports
    builder.emit_port("clk", "in", "bit", false)
    builder.emit_port("rst", "in", "bit", false)
    builder.emit_port("ndrange_size", "in", "unsigned(31 downto 0)", false)

    # Scalar parameter ports + pointer memory-interface ports
    var idx = 0
    while idx < func.signature.params.len():
        val param_type = func.signature.params[idx]
        val param_name = vhdl_kernel_param_name(func, idx)
        val is_last_param = idx == func.signature.params.len() - 1
        if vhdl_kernel_is_pointer_param(param_type):
            # Memory interface: addr_out, data_in, data_out, we_out
            builder.emit_port("{param_name}_addr_out", "out", "unsigned(31 downto 0)", false)
            builder.emit_port("{param_name}_data_in", "in", "unsigned(31 downto 0)", false)
            builder.emit_port("{param_name}_data_out", "out", "unsigned(31 downto 0)", false)
            builder.emit_port("{param_name}_we_out", "out", "bit", is_last_param)
        else:
            val vhdl_type = vhdl_kernel_scalar_type_name(param_type)
            builder.emit_port(param_name, "in", vhdl_type, is_last_param)
        idx = idx + 1

    # done_out: asserted when all work-items are processed (always last port)
    if func.signature.params.len() == 0:
        builder.emit_port("done_out", "out", "bit", true)
    else:
        # Re-emit done_out — the last param port already had is_last=false in the loop above.
        # We need done_out as the true last port. To avoid modifying a built line,
        # emit it explicitly now (params loop uses is_last_param=true on last param to skip
        # the semicolon, so we need an extra emit here with is_last=true).
        # WORKAROUND: Always emit done_out after params; params loop uses is_last=false.
        builder.emit_port("done_out", "out", "bit", true)

    builder.emit_port_end()
    builder.emit_entity_end(entity_name)

    # --- Architecture ---
    builder.emit_architecture_begin(entity_name, "rtl")
    builder.emit_signal_decl("work_counter", "unsigned(31 downto 0)", Some("(others => '0')"))
    builder.emit_signal_decl("done_reg", "bit", Some("'0'"))
    builder.emit_architecture_body_begin()

    # Counter-driven loop process: one work-item per rising clock edge
    builder.emit_clocked_process_begin(Some("kernel_loop"), "clk", Some("rst"))
    builder.emit_process_body_begin()
    # Async reset branch
    builder.emit_if_begin("rst = '1'")
    builder.emit_signal_assign("work_counter", "(others => '0')")
    builder.emit_signal_assign("done_reg", "'0'")
    builder.emit_else()
    # Rising-edge branch
    builder.emit_rising_edge_check("clk")
    builder.emit_if_begin("done_reg = '0'")
    builder.emit_if_begin("work_counter < ndrange_size")
    builder.emit_comment("Work item: thread_id = work_counter")
    builder.emit_signal_assign("work_counter", "work_counter + 1")
    builder.emit_else()
    builder.emit_signal_assign("done_reg", "'1'")
    builder.emit_if_end()
    builder.emit_if_end()
    builder.emit_if_end()
    builder.emit_if_end()
    builder.emit_process_end(Some("kernel_loop"))

    # done_out assignment
    builder.emit_signal_assign("done_out", "done_reg")

    builder.emit_architecture_end("rtl")

    Ok(builder.build())

# ============================================================================
# Module-level emission
# ============================================================================

fn emit_vhdl_kernel_entities_for_module(module: MirModule) -> Result<text, CompileError>:
    """
    Emit VHDL kernel entities for all @gpu_kernel functions in module
    that have gpu_target=vhdl.  Returns concatenated VHDL source, or
    the first diagnostic for any rejected kernel.
    """
    val plan = vhdl_kernel_plan_module(module)
    if not plan.ready:
        return Err(compileerror_backend_error(BackendKind.Vhdl, plan.diagnostic))

    var parts: [text] = []
    for symbol in module.functions.keys():
        val func: MirFunction = module.functions[symbol]
        if vhdl_kernel_accepts(func):
            val result = emit_vhdl_kernel_entity(func)
            if result.is_err():
                return Err(result.unwrap_err())
            parts = parts.push(result.unwrap())

    Ok(parts.join("\n\n"))

export vhdl_kernel_accepts
export vhdl_kernel_plan_module
export emit_vhdl_kernel_entity
export emit_vhdl_kernel_entities_for_module
