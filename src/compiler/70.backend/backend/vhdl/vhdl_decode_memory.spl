class AluControl:
    op_name: text
    funct3: i32
    funct7_bit: bool
    is_immediate: bool
    result_width: i32

    me is_add():
        return op_name == "ADD" or op_name == "ADDI"

    me is_shift():
        return op_name == "SLL" or op_name == "SRL" or op_name == "SRA" or op_name == "SLLI" or op_name == "SRLI" or op_name == "SRAI"

    me is_branch():
        return op_name == "BEQ" or op_name == "BNE" or op_name == "BLT" or op_name == "BGE"

    static fn add() -> AluControl:
        return AluControl(op_name: "ADD", funct3: 0, funct7_bit: false, is_immediate: false, result_width: 32)

    static fn addi() -> AluControl:
        return AluControl(op_name: "ADDI", funct3: 0, funct7_bit: false, is_immediate: true, result_width: 32)

    static fn sub() -> AluControl:
        return AluControl(op_name: "SUB", funct3: 0, funct7_bit: true, is_immediate: false, result_width: 32)


class DecodeResult:
    format_name: text
    alu_op: text
    has_writeback: bool
    mem_read: bool
    mem_write: bool
    branch: bool
    jump: bool
    imm_value: i32

    me is_memory():
        return mem_read or mem_write

    me is_control_flow():
        return branch or jump

    me needs_alu():
        return has_writeback or mem_read or mem_write or branch

    static fn alu_decode(op: text) -> DecodeResult:
        return DecodeResult(format_name: "R", alu_op: op, has_writeback: true, mem_read: false, mem_write: false, branch: false, jump: false, imm_value: 0)

    static fn load_decode(imm: i32) -> DecodeResult:
        return DecodeResult(format_name: "I", alu_op: "ADD", has_writeback: true, mem_read: true, mem_write: false, branch: false, jump: false, imm_value: imm)

    static fn store_decode(imm: i32) -> DecodeResult:
        return DecodeResult(format_name: "S", alu_op: "ADD", has_writeback: false, mem_read: false, mem_write: true, branch: false, jump: false, imm_value: imm)


class RegisterFile:
    depth: i32
    width: i32
    read_ports: i32
    write_ports: i32
    has_zero_reg: bool
    is_synchronous: bool

    me total_bits():
        return depth * width

    me is_rv32():
        return depth == 32 and width == 32 and has_zero_reg

    me is_synthesizable():
        return read_ports <= 2 and write_ports <= 1

    static fn rv32i() -> RegisterFile:
        return RegisterFile(depth: 32, width: 32, read_ports: 2, write_ports: 1, has_zero_reg: true, is_synchronous: true)

    static fn rv32e() -> RegisterFile:
        return RegisterFile(depth: 16, width: 32, read_ports: 2, write_ports: 1, has_zero_reg: true, is_synchronous: true)


class MemoryInference:
    kind: text
    depth: i32
    width: i32
    is_readonly: bool
    init_data: text
    is_synchronous: bool

    me is_rom():
        return kind == "rom" and is_readonly

    me is_ram():
        return kind == "ram" and is_readonly == false

    me size_bytes():
        return (depth * width) / 8

    me is_synthesizable():
        return is_synchronous or is_readonly

    static fn boot_rom(depth: i32, width: i32) -> MemoryInference:
        return MemoryInference(kind: "rom", depth: depth, width: width, is_readonly: true, init_data: "boot", is_synchronous: false)

    static fn data_ram(depth: i32, width: i32) -> MemoryInference:
        return MemoryInference(kind: "ram", depth: depth, width: width, is_readonly: false, init_data: "", is_synchronous: true)


fn main():
    print("vhdl_decode_memory loaded")
