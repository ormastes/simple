class TestbenchCandidate:
    test_name: text
    dut_symbol: text
    port_count: int
    is_supported: bool
    reject_reason: text

    me is_rejected() -> bool:
        return self.is_supported == false

    me reject(reason: text) -> TestbenchCandidate:
        return TestbenchCandidate(
            test_name: self.test_name,
            dut_symbol: self.dut_symbol,
            port_count: self.port_count,
            is_supported: false,
            reject_reason: reason
        )

    me to_text() -> text:
        return "tb-candidate:" + self.test_name + " dut=" + self.dut_symbol + " ports=" + self.port_count.to_text()

    static fn create(name: text, dut: text, ports: int) -> TestbenchCandidate:
        return TestbenchCandidate(
            test_name: name,
            dut_symbol: dut,
            port_count: ports,
            is_supported: true,
            reject_reason: ""
        )


class DutPort:
    port_name: text
    direction: text
    bit_width: int
    vhdl_name: text

    me is_input() -> bool:
        return self.direction == "in"

    me is_output() -> bool:
        return self.direction == "out"

    me is_single_bit() -> bool:
        return self.bit_width == 1

    me to_text() -> text:
        return self.vhdl_name + " : " + self.direction + " " + self.bit_width.to_text() + "-bit"

    static fn input(name: text, width: int) -> DutPort:
        return DutPort(
            port_name: name,
            direction: "in",
            bit_width: width,
            vhdl_name: name
        )

    static fn output(name: text, width: int) -> DutPort:
        return DutPort(
            port_name: name,
            direction: "out",
            bit_width: width,
            vhdl_name: name
        )


class StimulusStep:
    step_index: int
    port_target: text
    value: int
    wait_cycles: int

    me has_wait() -> bool:
        return self.wait_cycles > 0

    me is_immediate() -> bool:
        return self.wait_cycles == 0

    me to_text() -> text:
        return "step[" + self.step_index.to_text() + "] " + self.port_target + " <= " + self.value.to_text()

    static fn create(idx: int, port: text, v: int, wait: int) -> StimulusStep:
        return StimulusStep(
            step_index: idx,
            port_target: port,
            value: v,
            wait_cycles: wait
        )

    static fn immediate(idx: int, port: text, v: int) -> StimulusStep:
        return StimulusStep(
            step_index: idx,
            port_target: port,
            value: v,
            wait_cycles: 0
        )


class TestAssertion:
    assertion_index: int
    expected_value: int
    actual_port: text
    source_line: int

    me to_text() -> text:
        return "assert[" + self.assertion_index.to_text() + "] " + self.actual_port + " == " + self.expected_value.to_text()

    me matches(actual: int) -> bool:
        return actual == self.expected_value

    static fn create(idx: int, expected: int, port: text, line: int) -> TestAssertion:
        return TestAssertion(
            assertion_index: idx,
            expected_value: expected,
            actual_port: port,
            source_line: line
        )
