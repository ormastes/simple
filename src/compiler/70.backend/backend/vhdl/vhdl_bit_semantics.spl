class BitWidth:
    width: i32
    is_signed: bool
    name: text

    me vhdl_type():
        if self.width == 1:
            return "std_logic"
        if self.is_signed:
            return "signed(" + (self.width - 1).to_text() + " downto 0)"
        return "unsigned(" + (self.width - 1).to_text() + " downto 0)"

    me max_unsigned():
        return self.width

    me fits_in(target_width: i32):
        return self.width <= target_width

    static fn unsigned(w: i32) -> BitWidth:
        return BitWidth(width: w, is_signed: false, name: "u" + w.to_text())

    static fn signed(w: i32) -> BitWidth:
        return BitWidth(width: w, is_signed: true, name: "s" + w.to_text())


class BitSlice:
    source_width: i32
    high_bit: i32
    low_bit: i32
    result_width: i32

    me is_valid():
        return self.high_bit >= self.low_bit and self.high_bit < self.source_width and self.low_bit >= 0

    me vhdl_expr(signal: text):
        return signal + "(" + self.high_bit.to_text() + " downto " + self.low_bit.to_text() + ")"

    me width_matches():
        return self.result_width == (self.high_bit - self.low_bit + 1)

    static fn extract(src_w: i32, hi: i32, lo: i32) -> BitSlice:
        return BitSlice(source_width: src_w, high_bit: hi, low_bit: lo, result_width: hi - lo + 1)

    static fn opcode() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 6, low_bit: 0, result_width: 7)

    static fn rd() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 11, low_bit: 7, result_width: 5)

    static fn funct3() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 14, low_bit: 12, result_width: 3)

    static fn rs1() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 19, low_bit: 15, result_width: 5)

    static fn rs2() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 24, low_bit: 20, result_width: 5)

    static fn funct7() -> BitSlice:
        return BitSlice(source_width: 32, high_bit: 31, low_bit: 25, result_width: 7)


class InstructionFormat:
    format_name: text
    opcode_width: i32
    has_rd: bool
    has_rs1: bool
    has_rs2: bool
    imm_width: i32
    imm_signed: bool

    me is_r_type():
        return self.format_name == "R"

    me is_i_type():
        return self.format_name == "I"

    me is_branch():
        return self.format_name == "B"

    me has_immediate():
        return self.imm_width > 0

    static fn r_type() -> InstructionFormat:
        return InstructionFormat(format_name: "R", opcode_width: 7, has_rd: true, has_rs1: true, has_rs2: true, imm_width: 0, imm_signed: false)

    static fn i_type() -> InstructionFormat:
        return InstructionFormat(format_name: "I", opcode_width: 7, has_rd: true, has_rs1: true, has_rs2: false, imm_width: 12, imm_signed: true)

    static fn s_type() -> InstructionFormat:
        return InstructionFormat(format_name: "S", opcode_width: 7, has_rd: false, has_rs1: true, has_rs2: true, imm_width: 12, imm_signed: true)

    static fn b_type() -> InstructionFormat:
        return InstructionFormat(format_name: "B", opcode_width: 7, has_rd: false, has_rs1: true, has_rs2: true, imm_width: 13, imm_signed: true)

    static fn u_type() -> InstructionFormat:
        return InstructionFormat(format_name: "U", opcode_width: 7, has_rd: true, has_rs1: false, has_rs2: false, imm_width: 20, imm_signed: false)

    static fn j_type() -> InstructionFormat:
        return InstructionFormat(format_name: "J", opcode_width: 7, has_rd: true, has_rs1: false, has_rs2: false, imm_width: 21, imm_signed: true)


class BitDiagnostic:
    kind: text
    expected_width: i32
    actual_width: i32
    message: text
    is_error: bool

    me is_width_mismatch():
        return self.kind == "width_mismatch"

    me is_sign_ambiguity():
        return self.kind == "sign_ambiguity"

    me width_diff():
        return self.actual_width - self.expected_width

    static fn width_mismatch(expected: i32, actual: i32) -> BitDiagnostic:
        return BitDiagnostic(kind: "width_mismatch", expected_width: expected, actual_width: actual, message: "expected " + expected.to_text() + " bits, got " + actual.to_text(), is_error: true)

    static fn sign_ambiguity(width: i32) -> BitDiagnostic:
        return BitDiagnostic(kind: "sign_ambiguity", expected_width: width, actual_width: width, message: "signedness ambiguous for " + width.to_text() + "-bit value", is_error: true)


fn main():
    print("vhdl_bit_semantics loaded")
