class ClockConfig:
    period_ns: int
    edge: text
    domain_name: text
    is_default: bool

    me is_rising() -> bool:
        return self.edge == "rising"

    me half_period() -> int:
        return self.period_ns / 2

    me to_text() -> text:
        return "clock:" + self.domain_name + " " + self.period_ns.to_text() + "ns " + self.edge

    static fn default_clock() -> ClockConfig:
        return ClockConfig(period_ns: 10, edge: "rising", domain_name: "clk", is_default: true)

    static fn custom(name: text, period: int, e: text) -> ClockConfig:
        return ClockConfig(period_ns: period, edge: e, domain_name: name, is_default: false)


class ResetSequence:
    reset_type: text
    polarity: text
    duration_cycles: int
    signal_name: text

    me is_sync() -> bool:
        return self.reset_type == "sync"

    me is_async() -> bool:
        return self.reset_type == "async"

    me is_active_low() -> bool:
        return self.polarity == "active_low"

    me to_text() -> text:
        return "reset:" + self.signal_name + " " + self.reset_type + " " + self.polarity + " " + self.duration_cycles.to_text() + " cycles"

    static fn async_low(name: text, cycles: int) -> ResetSequence:
        return ResetSequence(reset_type: "async", polarity: "active_low", duration_cycles: cycles, signal_name: name)

    static fn sync_high(name: text, cycles: int) -> ResetSequence:
        return ResetSequence(reset_type: "sync", polarity: "active_high", duration_cycles: cycles, signal_name: name)


class CycleAdvance:
    cycle_count: int
    from_step: int
    to_step: int
    is_final: bool

    me span() -> int:
        return self.to_step - self.from_step

    me to_text() -> text:
        return "advance " + self.cycle_count.to_text() + " cycles [" + self.from_step.to_text() + "->" + self.to_step.to_text() + "]"

    static fn create(cycles: int, from: int, to: int) -> CycleAdvance:
        return CycleAdvance(cycle_count: cycles, from_step: from, to_step: to, is_final: false)

    static fn final_advance(cycles: int, from: int, to: int) -> CycleAdvance:
        return CycleAdvance(cycle_count: cycles, from_step: from, to_step: to, is_final: true)


class TimingConstraint:
    min_cycles: int
    max_cycles: int
    constraint_name: text
    is_met: bool

    me in_range(cycles: int) -> bool:
        return cycles >= self.min_cycles and cycles <= self.max_cycles

    me check(cycles: int) -> TimingConstraint:
        return TimingConstraint(min_cycles: self.min_cycles, max_cycles: self.max_cycles, constraint_name: self.constraint_name, is_met: self.in_range(cycles))

    me to_text() -> text:
        return "timing:" + self.constraint_name + " [" + self.min_cycles.to_text() + "-" + self.max_cycles.to_text() + "]"

    static fn create(name: text, min: int, max: int) -> TimingConstraint:
        return TimingConstraint(min_cycles: min, max_cycles: max, constraint_name: name, is_met: false)
