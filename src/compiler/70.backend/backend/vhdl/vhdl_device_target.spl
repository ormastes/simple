# VHDL Device Target Configuration
#
# Defines target device families and their properties for
# synthesis tool selection and constraint generation.

# ============================================================================
# Device Family
# ============================================================================

enum VhdlDeviceFamily:
    Generic
    XilinxArtix
    XilinxZynq
    IntelCyclone
    IntelMax
    Lattice

# ============================================================================
# Device Target
# ============================================================================

struct VhdlDeviceTarget:
    family: VhdlDeviceFamily
    part_number: text?
    clock_freq_mhz: f64

    static fn generic() -> VhdlDeviceTarget:
        """Create a generic device target (GHDL simulation)."""
        VhdlDeviceTarget(
            family: VhdlDeviceFamily.Generic,
            part_number: nil,
            clock_freq_mhz: 100.0
        )

    static fn xilinx_artix7(part: text, freq: f64) -> VhdlDeviceTarget:
        """Create a Xilinx Artix-7 target."""
        VhdlDeviceTarget(
            family: VhdlDeviceFamily.XilinxArtix,
            part_number: Some(part),
            clock_freq_mhz: freq
        )

    static fn xilinx_zynq(part: text, freq: f64) -> VhdlDeviceTarget:
        """Create a Xilinx Zynq target."""
        VhdlDeviceTarget(
            family: VhdlDeviceFamily.XilinxZynq,
            part_number: Some(part),
            clock_freq_mhz: freq
        )

    static fn intel_cyclone(part: text, freq: f64) -> VhdlDeviceTarget:
        """Create an Intel Cyclone target."""
        VhdlDeviceTarget(
            family: VhdlDeviceFamily.IntelCyclone,
            part_number: Some(part),
            clock_freq_mhz: freq
        )

    fn synthesis_tool() -> text:
        """Return the appropriate synthesis tool for this device family."""
        if self.family == VhdlDeviceFamily.Generic:
            return "yosys"
        elif self.family == VhdlDeviceFamily.XilinxArtix:
            return "vivado"
        elif self.family == VhdlDeviceFamily.XilinxZynq:
            return "vivado"
        elif self.family == VhdlDeviceFamily.IntelCyclone:
            return "quartus"
        elif self.family == VhdlDeviceFamily.IntelMax:
            return "quartus"
        elif self.family == VhdlDeviceFamily.Lattice:
            return "yosys"
        else:
            return "yosys"

    fn clock_period_ns() -> f64:
        """Compute clock period in nanoseconds from frequency."""
        if self.clock_freq_mhz > 0.0:
            return 1000.0 / self.clock_freq_mhz
        return 10.0

    fn family_name() -> text:
        """Human-readable device family name."""
        if self.family == VhdlDeviceFamily.Generic:
            return "Generic (Simulation)"
        elif self.family == VhdlDeviceFamily.XilinxArtix:
            return "Xilinx Artix-7"
        elif self.family == VhdlDeviceFamily.XilinxZynq:
            return "Xilinx Zynq"
        elif self.family == VhdlDeviceFamily.IntelCyclone:
            return "Intel Cyclone"
        elif self.family == VhdlDeviceFamily.IntelMax:
            return "Intel MAX"
        elif self.family == VhdlDeviceFamily.Lattice:
            return "Lattice"
        else:
            return "Unknown"
