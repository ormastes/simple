# VHDL Subprogram Model — Function/procedure lowering models for VHDL subprogram emission.
#
# Implements subprogram kind selection and lowering decisions for VHDL emission.
#
# Classes:
#   SubprogramKind      — kind selection with combinational/entity classification
#   FunctionLower       — pure-function lowering descriptor
#   ProcedureLower      — procedure lowering descriptor (multi-output support)
#   SubprogramDecision  — accept/reject decision for subprogram lowering

# ============================================================================
# SubprogramKind — kind selection with combinational/entity classification
# ============================================================================

class SubprogramKind:
    """Kind selection metadata for a VHDL subprogram emission target."""
    kind: text
    reason: text
    is_combinational: bool
    helper_name: text

    me is_function() -> bool:
        """Returns true when kind is function."""
        return kind == "function"

    me is_procedure() -> bool:
        """Returns true when kind is procedure."""
        return kind == "procedure"

    me is_entity() -> bool:
        """Returns true when kind is entity."""
        return kind == "entity"

    me to_text() -> text:
        """Returns a readable summary of this kind choice."""
        return kind + ":" + helper_name + " (" + reason + ")"

    static fn function(name: text, r: text) -> SubprogramKind:
        """Factory for a combinational function subprogram kind."""
        return SubprogramKind(
            kind: "function",
            reason: r,
            is_combinational: true,
            helper_name: name
        )

    static fn procedure(name: text, r: text) -> SubprogramKind:
        """Factory for a combinational procedure subprogram kind."""
        return SubprogramKind(
            kind: "procedure",
            reason: r,
            is_combinational: true,
            helper_name: name
        )

    static fn entity(name: text, r: text) -> SubprogramKind:
        """Factory for an entity subprogram kind (not combinational)."""
        return SubprogramKind(
            kind: "entity",
            reason: r,
            is_combinational: false,
            helper_name: name
        )

# ============================================================================
# FunctionLower — pure-function lowering descriptor
# ============================================================================

class FunctionLower:
    """Lowering descriptor for a VHDL function subprogram."""
    helper_name: text
    return_type: text
    param_count: int
    is_pure: bool
    vhdl_signature: text

    me to_text() -> text:
        """Returns a readable summary of this function lowering."""
        return "function " + helper_name + "(" + param_count.to_text() + " params) return " + return_type

    me is_single_return() -> bool:
        """Returns true — functions always have a single return."""
        return true

    static fn create(name: text, ret: text, params: int, pure: bool) -> FunctionLower:
        """Factory that builds the vhdl_signature automatically."""
        return FunctionLower(
            helper_name: name,
            return_type: ret,
            param_count: params,
            is_pure: pure,
            vhdl_signature: "function " + name + " return " + ret
        )

# ============================================================================
# ProcedureLower — procedure lowering descriptor (multi-output support)
# ============================================================================

class ProcedureLower:
    """Lowering descriptor for a VHDL procedure subprogram."""
    helper_name: text
    out_count: int
    in_count: int
    total_params: int
    uses_record: bool

    me is_multi_output() -> bool:
        """Returns true when procedure has more than one output parameter."""
        return out_count > 1

    me to_text() -> text:
        """Returns a readable summary of this procedure lowering."""
        return "procedure " + helper_name + "(" + in_count.to_text() + " in, " + out_count.to_text() + " out)"

    static fn create(name: text, ins: int, outs: int) -> ProcedureLower:
        """Factory for a procedure without record bundling."""
        return ProcedureLower(
            helper_name: name,
            out_count: outs,
            in_count: ins,
            total_params: ins + outs,
            uses_record: false
        )

    static fn with_record(name: text, ins: int, outs: int) -> ProcedureLower:
        """Factory for a procedure that bundles outputs into a record."""
        return ProcedureLower(
            helper_name: name,
            out_count: outs,
            in_count: ins,
            total_params: ins + outs,
            uses_record: true
        )

# ============================================================================
# SubprogramDecision — accept/reject decision for subprogram lowering
# ============================================================================

class SubprogramDecision:
    """Accept or reject decision for lowering a subprogram to VHDL."""
    helper_ref: text
    chosen_kind: text
    reject_reason: text
    fallback_to_entity: bool

    me is_accepted() -> bool:
        """Returns true when the subprogram was accepted for lowering."""
        return reject_reason == ""

    me is_fallback() -> bool:
        """Returns true when the decision falls back to entity emission."""
        return fallback_to_entity

    me to_text() -> text:
        """Returns a readable summary of the lowering decision."""
        if reject_reason == "":
            return chosen_kind + " for " + helper_ref
        return "REJECTED " + helper_ref + ": " + reject_reason

    static fn accept(ref: text, kind: text) -> SubprogramDecision:
        """Factory for an accepted lowering decision."""
        return SubprogramDecision(
            helper_ref: ref,
            chosen_kind: kind,
            reject_reason: "",
            fallback_to_entity: false
        )

    static fn reject(ref: text, reason: text) -> SubprogramDecision:
        """Factory for a rejected lowering decision that falls back to entity."""
        return SubprogramDecision(
            helper_ref: ref,
            chosen_kind: "entity",
            reject_reason: reason,
            fallback_to_entity: true
        )
