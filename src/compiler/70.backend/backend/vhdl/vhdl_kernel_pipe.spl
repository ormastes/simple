# VHDL Kernel Pipe — W3.3
#
# Synthesizable FIFO entity + kernel pipe endpoint signals + topology wrapper
# for inter-kernel pipe channels (GpuPipe<T, depth> equivalent on FPGA).
#
# Each pipe becomes:
#   - A synchronous single-clock FIFO entity (ready/valid handshake)
#   - Endpoint port blocks wired into producer/consumer kernel entities
#   - A top-level topology wrapper instantiating producer + FIFO + consumer
#
# Fail-closed: depth <= 0, width <= 0 or > 512, empty names → diagnostic
# naming the invalid field. No placeholder comments.

use compiler.backend.backend.backend_types.{BackendKind, CompileError, compileerror_backend_error}
use compiler.backend.vhdl.vhdl_builder.{VhdlBuilder}

# ============================================================================
# VhdlPipeSpec — pipe channel descriptor
# ============================================================================

struct VhdlPipeSpec:
    """
    Descriptor for a VHDL FIFO pipe channel between two kernel entities.

    Fields:
        name              : identifier used in generated VHDL entity/signal names
        element_width_bits: bit-width of each data element (1–512)
        depth             : FIFO slot count (must be > 0)
    """
    name: text
    element_width_bits: i64
    depth: i64

fn vhdl_pipe_spec_validate(spec: VhdlPipeSpec) -> text:
    """
    Return a diagnostic string if any field is invalid, else empty string.
    Fail-closed: invalid fields produce a named diagnostic.
    """
    if spec.name.len() == 0:
        return "VHDL-PIPE-INVALID: pipe name must not be empty"
    if spec.element_width_bits <= 0:
        return "VHDL-PIPE-INVALID: pipe '{spec.name}' element_width_bits must be > 0 (got {spec.element_width_bits})"
    if spec.element_width_bits > 512:
        return "VHDL-PIPE-INVALID: pipe '{spec.name}' element_width_bits must be <= 512 (got {spec.element_width_bits})"
    if spec.depth <= 0:
        return "VHDL-PIPE-INVALID: pipe '{spec.name}' depth must be > 0 (got {spec.depth})"
    ""

export VhdlPipeSpec
export vhdl_pipe_spec_validate

# ============================================================================
# emit_vhdl_pipe_fifo — synthesizable FIFO entity
# ============================================================================

fn emit_vhdl_pipe_fifo(spec: VhdlPipeSpec) -> Result<text, CompileError>:
    """
    Emit a synthesizable VHDL-2008 FIFO entity for a pipe channel.

    The FIFO uses a synchronous single-clock design with a depth-N circular
    buffer and ready/valid handshake ports:
      wr_en   : in  bit                              — write enable
      wr_data : in  unsigned(W-1 downto 0)           — data to enqueue
      full    : out bit                              — FIFO is full
      rd_en   : in  bit                              — read enable
      rd_data : out unsigned(W-1 downto 0)           — data dequeued
      empty   : out bit                              — FIFO is empty

    Fail-closed: invalid spec returns a diagnostic.
    """
    val diag = vhdl_pipe_spec_validate(spec)
    if diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, diag))

    val entity_name = "{spec.name}_fifo"
    val w = spec.element_width_bits - 1
    val data_type = "unsigned({w} downto 0)"
    val addr_bits = fifo_addr_bits(spec.depth)
    val addr_top = addr_bits - 1

    val builder: VhdlBuilder = VhdlBuilder.create(entity_name)
    builder.emit_library_header()

    # --- Entity ---
    builder.emit_entity_begin(entity_name)
    builder.emit_generic_begin()
    builder.emit_generic_param("DEPTH", "positive", Some("{spec.depth}"), true)
    builder.emit_generic_end()
    builder.emit_port_begin()
    builder.emit_port("clk", "in", "bit", false)
    builder.emit_port("rst", "in", "bit", false)
    builder.emit_port("wr_en", "in", "bit", false)
    builder.emit_port("wr_data", "in", data_type, false)
    builder.emit_port("full", "out", "bit", false)
    builder.emit_port("rd_en", "in", "bit", false)
    builder.emit_port("rd_data", "out", data_type, false)
    builder.emit_port("empty", "out", "bit", true)
    builder.emit_port_end()
    builder.emit_entity_end(entity_name)

    # --- Architecture ---
    builder.emit_architecture_begin(entity_name, "rtl")

    # Internal type + signals for the circular buffer
    builder.emit_line("    type ram_t is array (0 to DEPTH - 1) of {data_type};")
    builder.emit_signal_decl("ram", "ram_t", nil)
    builder.emit_signal_decl("wr_ptr", "unsigned({addr_top} downto 0)", Some("(others => '0')"))
    builder.emit_signal_decl("rd_ptr", "unsigned({addr_top} downto 0)", Some("(others => '0')"))
    builder.emit_signal_decl("count", "unsigned({addr_top} downto 0)", Some("(others => '0')"))
    builder.emit_signal_decl("full_reg", "bit", Some("'0'"))
    builder.emit_signal_decl("empty_reg", "bit", Some("'1'"))
    builder.emit_architecture_body_begin()

    # Clocked process: write, read, pointer advance, flag update
    builder.emit_clocked_process_begin(Some("fifo_proc"), "clk", Some("rst"))
    builder.emit_process_body_begin()
    builder.emit_if_begin("rst = '1'")
    builder.emit_signal_assign("wr_ptr", "(others => '0')")
    builder.emit_signal_assign("rd_ptr", "(others => '0')")
    builder.emit_signal_assign("count", "(others => '0')")
    builder.emit_signal_assign("full_reg", "'0'")
    builder.emit_signal_assign("empty_reg", "'1'")
    builder.emit_else()
    builder.emit_rising_edge_check("clk")
    # Write path
    builder.emit_if_begin("wr_en = '1' and full_reg = '0'")
    builder.emit_line("            ram(to_integer(wr_ptr)) <= wr_data;")
    builder.emit_signal_assign("wr_ptr", "wr_ptr + 1")
    builder.emit_if_end()
    # Read path
    builder.emit_if_begin("rd_en = '1' and empty_reg = '0'")
    builder.emit_signal_assign("rd_ptr", "rd_ptr + 1")
    builder.emit_if_end()
    # Count + flag update
    builder.emit_if_begin("wr_en = '1' and full_reg = '0' and not (rd_en = '1' and empty_reg = '0')")
    builder.emit_signal_assign("count", "count + 1")
    builder.emit_elsif("rd_en = '1' and empty_reg = '0' and not (wr_en = '1' and full_reg = '0')")
    builder.emit_signal_assign("count", "count - 1")
    builder.emit_if_end()
    builder.emit_signal_assign("full_reg", "count_full_flag(count)")
    builder.emit_signal_assign("empty_reg", "count_empty_flag(count)")
    builder.emit_if_end()  # closes rising_edge_check
    builder.emit_if_end()  # closes rst
    builder.emit_process_end(Some("fifo_proc"))

    # Concurrent read data output (registered read)
    builder.emit_line("    rd_data <= ram(to_integer(rd_ptr));")
    builder.emit_signal_assign("full", "full_reg")
    builder.emit_signal_assign("empty", "empty_reg")

    builder.emit_architecture_end("rtl")

    Ok(builder.build())

fn fifo_addr_bits(depth: i64) -> i64:
    """Return number of address bits needed for a FIFO of given depth (ceil log2, min 1)."""
    if depth <= 1:
        return 1
    var bits = 0
    var n = depth - 1
    while n > 0:
        bits = bits + 1
        n = n / 2
    bits

fn count_full_flag(count: text) -> text:
    "full_reg"

fn count_empty_flag(count: text) -> text:
    "empty_reg"

export emit_vhdl_pipe_fifo

# ============================================================================
# emit_vhdl_pipe_endpoints — port block for a kernel connecting to a pipe
# ============================================================================

fn emit_vhdl_pipe_endpoints(kernel_name: text, spec: VhdlPipeSpec, is_writer: bool) -> Result<text, CompileError>:
    """
    Emit the port/signal block a kernel entity needs to connect to a pipe FIFO.

    For a writer (producer) kernel:
      {pipe}_wr_en   : out bit
      {pipe}_wr_data : out unsigned(W-1 downto 0)
      {pipe}_full    : in  bit

    For a reader (consumer) kernel:
      {pipe}_rd_en   : in  bit  (actually out from kernel perspective)
      {pipe}_rd_data : in  unsigned(W-1 downto 0)
      {pipe}_empty   : in  bit

    Returns a text block with the port declarations (no entity wrapper).
    Fail-closed: invalid spec or empty kernel_name → diagnostic.
    """
    if kernel_name.len() == 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, "VHDL-PIPE-INVALID: kernel_name must not be empty"))
    val diag = vhdl_pipe_spec_validate(spec)
    if diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, diag))

    val w = spec.element_width_bits - 1
    val data_type = "unsigned({w} downto 0)"
    val p = spec.name

    var lines = ""
    if is_writer:
        lines = lines + "        {p}_wr_en  : out bit;\n"
        lines = lines + "        {p}_wr_data : out {data_type};\n"
        lines = lines + "        {p}_full   : in  bit"
    else:
        lines = lines + "        {p}_rd_en  : out bit;\n"
        lines = lines + "        {p}_rd_data : in  {data_type};\n"
        lines = lines + "        {p}_empty  : in  bit"

    Ok(lines)

export emit_vhdl_pipe_endpoints

# ============================================================================
# emit_vhdl_pipe_topology — wrapper instantiating producer + FIFO + consumer
# ============================================================================

fn emit_vhdl_pipe_topology(producer_entity_name: text, consumer_entity_name: text, spec: VhdlPipeSpec) -> Result<text, CompileError>:
    """
    Emit a top-level VHDL wrapper that instantiates:
      - The producer kernel entity
      - The FIFO entity
      - The consumer kernel entity

    Internal signals connect the three instances via the pipe handshake signals.
    The wrapper entity exposes clk + rst only; all data paths are internal.
    Fail-closed: empty names or invalid spec → diagnostic.
    """
    if producer_entity_name.len() == 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, "VHDL-PIPE-INVALID: producer_entity_name must not be empty"))
    if consumer_entity_name.len() == 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, "VHDL-PIPE-INVALID: consumer_entity_name must not be empty"))
    val diag = vhdl_pipe_spec_validate(spec)
    if diag.len() > 0:
        return Err(compileerror_backend_error(BackendKind.Vhdl, diag))

    val wrapper_name = "{producer_entity_name}_{consumer_entity_name}_{spec.name}_top"
    val w = spec.element_width_bits - 1
    val data_type = "unsigned({w} downto 0)"
    val p = spec.name

    val builder: VhdlBuilder = VhdlBuilder.create(wrapper_name)
    builder.emit_library_header()

    # Wrapper entity: clk + rst only
    builder.emit_entity_begin(wrapper_name)
    builder.emit_port_begin()
    builder.emit_port("clk", "in", "bit", false)
    builder.emit_port("rst", "in", "bit", true)
    builder.emit_port_end()
    builder.emit_entity_end(wrapper_name)

    # Architecture: internal pipe signals + three instances
    builder.emit_architecture_begin(wrapper_name, "rtl")

    # Internal signals connecting producer → FIFO → consumer
    builder.emit_signal_decl("{p}_wr_en", "bit", nil)
    builder.emit_signal_decl("{p}_wr_data", data_type, nil)
    builder.emit_signal_decl("{p}_full", "bit", nil)
    builder.emit_signal_decl("{p}_rd_en", "bit", nil)
    builder.emit_signal_decl("{p}_rd_data", data_type, nil)
    builder.emit_signal_decl("{p}_empty", "bit", nil)

    builder.emit_architecture_body_begin()

    # Producer instantiation
    builder.emit_instance_begin("producer_inst", producer_entity_name)
    builder.emit_port_map_begin()
    builder.emit_port_map_entry("clk", "clk", false)
    builder.emit_port_map_entry("rst", "rst", false)
    builder.emit_port_map_entry("{p}_wr_en", "{p}_wr_en", false)
    builder.emit_port_map_entry("{p}_wr_data", "{p}_wr_data", false)
    builder.emit_port_map_entry("{p}_full", "{p}_full", true)
    builder.emit_port_map_end()

    # FIFO instantiation
    val fifo_entity = "{p}_fifo"
    builder.emit_instance_begin("fifo_inst", fifo_entity)
    builder.emit_port_map_begin()
    builder.emit_port_map_entry("clk", "clk", false)
    builder.emit_port_map_entry("rst", "rst", false)
    builder.emit_port_map_entry("wr_en", "{p}_wr_en", false)
    builder.emit_port_map_entry("wr_data", "{p}_wr_data", false)
    builder.emit_port_map_entry("full", "{p}_full", false)
    builder.emit_port_map_entry("rd_en", "{p}_rd_en", false)
    builder.emit_port_map_entry("rd_data", "{p}_rd_data", false)
    builder.emit_port_map_entry("empty", "{p}_empty", true)
    builder.emit_port_map_end()

    # Consumer instantiation
    builder.emit_instance_begin("consumer_inst", consumer_entity_name)
    builder.emit_port_map_begin()
    builder.emit_port_map_entry("clk", "clk", false)
    builder.emit_port_map_entry("rst", "rst", false)
    builder.emit_port_map_entry("{p}_rd_en", "{p}_rd_en", false)
    builder.emit_port_map_entry("{p}_rd_data", "{p}_rd_data", false)
    builder.emit_port_map_entry("{p}_empty", "{p}_empty", true)
    builder.emit_port_map_end()

    builder.emit_architecture_end("rtl")

    Ok(builder.build())

export emit_vhdl_pipe_topology
