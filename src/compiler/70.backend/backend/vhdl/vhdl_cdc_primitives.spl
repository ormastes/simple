# VHDL CDC Primitives — clock-domain crossing metadata and diagnostics.

struct VhdlCdcPrimitive:
    name: text
    primitive_kind: text
    source_domain: text
    destination_domain: text
    stages: i32
    depth: i32

struct VhdlCdcDiagnostic:
    code: text
    message: text
    signal_name: text

fn vhdl_cdc_sync(name: text, source_domain: text, destination_domain: text, stages: i32) -> VhdlCdcPrimitive:
    VhdlCdcPrimitive(name: name, primitive_kind: "@cdc_sync", source_domain: source_domain, destination_domain: destination_domain, stages: stages, depth: 0)

fn vhdl_async_fifo(name: text, source_domain: text, destination_domain: text, depth: i32) -> VhdlCdcPrimitive:
    VhdlCdcPrimitive(name: name, primitive_kind: "@async_fifo", source_domain: source_domain, destination_domain: destination_domain, stages: 0, depth: depth)

fn vhdl_gray_counter(name: text, source_domain: text, destination_domain: text, width: i32) -> VhdlCdcPrimitive:
    VhdlCdcPrimitive(name: name, primitive_kind: "@gray_counter", source_domain: source_domain, destination_domain: destination_domain, stages: width, depth: 0)

fn vhdl_pulse_crossing(name: text, source_domain: text, destination_domain: text) -> VhdlCdcPrimitive:
    VhdlCdcPrimitive(name: name, primitive_kind: "@pulse_crossing", source_domain: source_domain, destination_domain: destination_domain, stages: 2, depth: 0)

fn vhdl_cdc_unannotated_error(signal_name: text, source_domain: text, destination_domain: text) -> VhdlCdcDiagnostic:
    VhdlCdcDiagnostic(
        code: "VHDL-CDC-UNANNOTATED",
        message: "signal " + signal_name + " crosses from " + source_domain + " to " + destination_domain + " without a CDC primitive",
        signal_name: signal_name
    )

fn vhdl_cdc_requires_annotation(source_domain: text, destination_domain: text) -> bool:
    source_domain != destination_domain
