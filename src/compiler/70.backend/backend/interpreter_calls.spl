# Interpreter Backend - Function Calls and Builtins
#
# Extracted from interpreter.spl. Contains InterpreterBackendImpl methods for:
# - call_function, call_hir_function, call_function_by_id, call_closure
# - apply_assign_op
# - try_call_builtin (SFFI dispatch)
# - value_to_runtime_ptr, runtime_ptr_to_value, value_to_string

use compiler.hir.hir.*
use compiler.common.diagnostics.span.{Span}
use compiler.backend.backend_types.*
use compiler.backend.backend.env.{EvalContext, Environment}
use compiler.backend.backend.interpreter.{InterpreterBackendImpl}
use std.nogc_sync_mut.io.process_ops.{eprint}

enum ValueType:
    Nil
    Bool
    Int
    Float
    String
    Array
    Dict
    Object
    Function

extern fn rt_value_print(value: i64)
extern fn rt_value_println(value: i64)
extern fn rt_value_type(value: i64) -> ValueType
extern fn rt_value_int(value: i64) -> i64
extern fn rt_value_float(value: f64) -> i64
extern fn rt_value_bool(value: bool) -> i64
extern fn rt_value_nil() -> i64
extern fn rt_value_string(ptr: i64, len: i64) -> i64
extern fn rt_value_is_int(value: i64) -> bool
extern fn rt_value_is_float(value: i64) -> bool
extern fn rt_value_is_bool(value: i64) -> bool
extern fn rt_value_is_nil(value: i64) -> bool
extern fn rt_value_as_int(value: i64) -> i64
extern fn rt_value_as_float(value: i64) -> f64
extern fn rt_value_as_bool(value: i64) -> bool
extern fn rt_file_exists(path_ptr: i64, path_len: i64) -> bool
extern fn rt_file_read_text(path_ptr: i64, path_len: i64) -> i64
extern fn rt_file_write_text(path_ptr: i64, path_len: i64, content_ptr: i64, content_len: i64) -> bool
extern fn rt_file_delete(path_ptr: i64, path_len: i64) -> bool
extern fn rt_env_get(name_ptr: i64, name_len: i64) -> i64
extern fn rt_env_set(name_ptr: i64, name_len: i64, value_ptr: i64, value_len: i64) -> bool

# Env-gated interpreter trace probe (SIMPLE_INTERP_TRACE=1). Mirrors itrace in
# interpreter.spl; uses this module's ptr-based rt_env_get.
fn itrace(msg: text) -> ():
    val key = "SIMPLE_INTERP_TRACE"
    val ptr = rt_env_get(key.ptr(), key.len())
    if ptr != 0:
        eprint(msg)

# ============================================================================
# Builtin dispatch table (optimization: avoid per-call string comparison chain)
# D-6: linear scan of a small static table to get a tag; then match tag.
# D-6b: HIR-level tag caching is a follow-up; this pass eliminates the nested
#        if-chain that existed before the match, keeping a single linear scan.
# ============================================================================

enum BuiltinTag:
    Print
    Println
    ToString
    TypeOf
    Clone
    FileExists
    FileRead
    FileWrite
    FileDelete
    EnvGet
    EnvSet
    Unknown

extern fn rt_enum_discriminant(value: HirBinOp) -> i64
fn interp_binop_disc(op: HirBinOp) -> i64:
    """Iteration 18 probe helper (remove with probes)."""
    rt_enum_discriminant(op)

fn lookup_builtin_tag(name: text) -> BuiltinTag:
    """Map a function name to its BuiltinTag."""
    if name == "print":
        return BuiltinTag.Print
    if name == "println":
        return BuiltinTag.Println
    if name == "to_string":
        return BuiltinTag.ToString
    if name == "type_of":
        return BuiltinTag.TypeOf
    if name == "clone":
        return BuiltinTag.Clone
    if name == "file_exists":
        return BuiltinTag.FileExists
    if name == "file_read":
        return BuiltinTag.FileRead
    if name == "file_write":
        return BuiltinTag.FileWrite
    if name == "file_delete":
        return BuiltinTag.FileDelete
    if name == "env_get":
        return BuiltinTag.EnvGet
    if name == "env_set":
        return BuiltinTag.EnvSet
    BuiltinTag.Unknown

impl InterpreterBackendImpl:
    fn call_function(fn_value: Value, args: [Value], ctx: EvalContext, span: Span) -> Result<Value, BackendError>:
        itrace("[CF] call_function enter")
        match fn_value:
            case Value.Function(f):
                # Typed rebind (stage4 extracted-payload hazard, iteration 18).
                val f_t: FunctionValue = f
                # Check for builtin functions first
                val builtin_result = self.try_call_builtin(f_t.name, args)
                if builtin_result.?:
                    return builtin_result.unwrap()

                # Look up function in module
                if not ctx.module.functions.has(f_t.symbol):
                    return Err(BackendError.runtime_error("function '{f_t.name}' not found", Some(span)))

                val fn_: HirFunction = ctx.module.functions[f_t.symbol]
                self.call_hir_function(fn_, args, ctx)

            case Value.Closure(c):
                val c_t: ClosureValue = c
                self.call_closure(c_t, args, ctx)

            case _:
                Err(BackendError.type_error("value is not callable", Some(span)))

    fn call_hir_function(fn_: HirFunction, args: [Value], ctx: EvalContext) -> Result<Value, BackendError>:
        ctx.env.push_scope()

        # Bind parameters
        for i in 0..fn_.params.len():
            val param = fn_.params[i]
            val value = if i < args.len():
                args[i]
            elif param.default.?:
                self.eval_expr(param.default.unwrap(), ctx)?
            else:
                return Err(BackendError.runtime_error("missing argument for parameter {param.name}", Some(fn_.span)))

            ctx.env.define(param.symbol, value)

        # Execute body
        val result = self.eval_block(fn_.body, ctx)?

        ctx.env.pop_scope()
        Ok(result)

    fn call_function_by_id(method_id: SymbolId, args: [Value], ctx: EvalContext, span: Span) -> Result<Value, BackendError>:
        """Look up function by symbol ID and call it."""
        # Look up function definition in module
        if not ctx.module.functions.has(method_id):
            return Err(BackendError.runtime_error("function not found by symbol ID", Some(span)))

        val fn_ = ctx.module.functions[method_id]
        self.call_hir_function(fn_, args, ctx)

    fn call_closure(closure: ClosureValue, args: [Value], ctx: EvalContext) -> Result<Value, BackendError>:
        ctx.env.push_scope()

        # Bind captured variables
        for symbol in closure.captures.keys():
            val value = closure.captures[symbol]
            ctx.env.define(symbol, value)

        # Bind parameters
        for i in 0..closure.params.len():
            val param = closure.params[i]
            val value = if i < args.len():
                args[i]
            else:
                return Err(BackendError.runtime_error("missing argument for parameter", nil))

            ctx.env.define(param.symbol, value)

        # Evaluate body
        val result = self.eval_expr(closure.body, ctx)?

        ctx.env.pop_scope()
        Ok(result)

    fn apply_assign_op(op: HirAssignOp, left: Value, right: Value, span: Span) -> Result<Value, BackendError>:
        match op:
            case HirAssignOp.Add: self.eval_binop(HirBinOp.Add, left, right, span)
            case HirAssignOp.Sub: self.eval_binop(HirBinOp.Sub, left, right, span)
            case HirAssignOp.Mul: self.eval_binop(HirBinOp.Mul, left, right, span)
            case HirAssignOp.Div: self.eval_binop(HirBinOp.Div, left, right, span)
            case HirAssignOp.Mod: self.eval_binop(HirBinOp.Mod, left, right, span)
            case _: Err(BackendError.not_implemented("assignment operator not implemented"))

    fn try_call_builtin(name: text, args: [Value]) -> Option<Result<Value, BackendError>>:
        """Try to call a builtin function. Returns None if not a builtin.
        Optimization D-6: resolves name to BuiltinTag via lookup_builtin_tag (one linear
        scan of BUILTIN_TABLE), then dispatches via match tag — avoids per-call string
        comparison chain in the common path.
        """
        itrace("[TCB0] try_call_builtin enter")
        val tag = lookup_builtin_tag(name)
        itrace("[TCB] try_call_builtin name={name}")
        match tag:
            case BuiltinTag.Print:
                itrace("[BUILTIN] Print reached")
                if args.len() > 0:
                    val arg = args[0]
                    match arg:
                        case Value.RuntimeValue(ptr):
                            rt_value_print(ptr)
                        case Value.Int(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_print(ptr)
                        case Value.Float(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_print(ptr)
                        case Value.Bool(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_print(ptr)
                        case Value.Nil:
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_print(ptr)
                        case _:
                            val msg = self.value_to_string(arg)
                            print msg
                else:
                    print ""
                Some(Ok(Value.Nil))
            case BuiltinTag.Println:
                if args.len() > 0:
                    val arg = args[0]
                    match arg:
                        case Value.RuntimeValue(ptr):
                            rt_value_println(ptr)
                        case Value.Int(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_println(ptr)
                        case Value.Float(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_println(ptr)
                        case Value.Bool(_):
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_println(ptr)
                        case Value.Nil:
                            val ptr = self.value_to_runtime_ptr(arg)
                            rt_value_println(ptr)
                        case _:
                            val msg = self.value_to_string(arg)
                            print msg
                else:
                    print ""
                Some(Ok(Value.Nil))
            case BuiltinTag.ToString:
                if args.len() > 0:
                    Some(Ok(Value.string(self.value_to_string(args[0]))))
                else:
                    Some(Ok(Value.string("")))

            case BuiltinTag.TypeOf:
                if args.len() > 0:
                    val arg = args[0]
                    match arg:
                        case Value.RuntimeValue(ptr):
                            val type_tag = rt_value_type(ptr)
                            val type_name = match type_tag:
                                case ValueType.Nil: "nil"
                                case ValueType.Bool: "bool"
                                case ValueType.Int: "int"
                                case ValueType.Float: "float"
                                case ValueType.String: "string"
                                case ValueType.Array: "array"
                                case ValueType.Dict: "dict"
                                case ValueType.Object: "object"
                                case ValueType.Function: "function"
                                case _: "unknown"
                            Some(Ok(Value.string(type_name)))
                        case _:
                            Some(Ok(Value.string(arg.type_name())))
                else:
                    Some(Err(BackendError.runtime_error("type_of requires value argument", nil)))

            case BuiltinTag.Clone:
                if args.len() > 0:
                    val arg = args[0]
                    match arg:
                        case Value.RuntimeValue(ptr):
                            # Bootstrap interpreter fallback treats the runtime
                            # pointer as an opaque refcounted handle.
                            Some(Ok(Value.RuntimeValue(ptr)))
                        case _:
                            Some(Ok(arg))
                else:
                    Some(Err(BackendError.runtime_error("clone requires value argument", nil)))

            # File I/O operations
            case BuiltinTag.FileExists:
                if args.len() > 0:
                    match args[0]:
                        case Value.String(path):
                            val result = rt_file_exists(path.ptr(), path.len())
                            Some(Ok(Value.bool(result)))
                        case _:
                            Some(Err(BackendError.type_error("file_exists requires string path", nil)))
                else:
                    Some(Err(BackendError.runtime_error("file_exists requires path argument", nil)))

            case BuiltinTag.FileRead:
                if args.len() > 0:
                    match args[0]:
                        case Value.String(path):
                            val ptr = rt_file_read_text(path.ptr(), path.len())
                            if ptr == 0:
                                Some(Ok(Value.string("")))
                            else:
                                val result = self.runtime_ptr_to_value(ptr)
                                Some(Ok(result))
                        case _:
                            Some(Err(BackendError.type_error("file_read requires string path", nil)))
                else:
                    Some(Err(BackendError.runtime_error("file_read requires path argument", nil)))

            case BuiltinTag.FileWrite:
                if args.len() >= 2:
                    match args[0]:
                        case Value.String(path):
                            match args[1]:
                                case Value.String(content):
                                    val result = rt_file_write_text(path.ptr(), path.len(), content.ptr(), content.len())
                                    Some(Ok(Value.bool(result)))
                                case _:
                                    Some(Err(BackendError.type_error("file_write requires string path and content", nil)))
                        case _:
                            Some(Err(BackendError.type_error("file_write requires string path and content", nil)))
                else:
                    Some(Err(BackendError.runtime_error("file_write requires path and content arguments", nil)))

            case BuiltinTag.FileDelete:
                if args.len() > 0:
                    match args[0]:
                        case Value.String(path):
                            val result = rt_file_delete(path.ptr(), path.len())
                            Some(Ok(Value.bool(result)))
                        case _:
                            Some(Err(BackendError.type_error("file_delete requires string path", nil)))
                else:
                    Some(Err(BackendError.runtime_error("file_delete requires path argument", nil)))

            # Environment variable operations
            case BuiltinTag.EnvGet:
                if args.len() > 0:
                    match args[0]:
                        case Value.String(name):
                            val ptr = rt_env_get(name.ptr(), name.len())
                            if ptr == 0:
                                Some(Ok(Value.string("")))
                            else:
                                val result = self.runtime_ptr_to_value(ptr)
                                Some(Ok(result))
                        case _:
                            Some(Err(BackendError.type_error("env_get requires string name", nil)))
                else:
                    Some(Err(BackendError.runtime_error("env_get requires name argument", nil)))

            case BuiltinTag.EnvSet:
                if args.len() >= 2:
                    match args[0]:
                        case Value.String(name):
                            match args[1]:
                                case Value.String(value):
                                    val result = rt_env_set(name.ptr(), name.len(), value.ptr(), value.len())
                                    Some(Ok(Value.bool(result)))
                                case _:
                                    Some(Err(BackendError.type_error("env_set requires string name and value", nil)))
                        case _:
                            Some(Err(BackendError.type_error("env_set requires string name and value", nil)))
                else:
                    Some(Err(BackendError.runtime_error("env_set requires name and value arguments", nil)))

            case BuiltinTag.Unknown:
                nil

    # ========================================================================
    # SFFI RuntimeValue Conversion Helpers
    # ========================================================================

    fn value_to_runtime_ptr(value: Value) -> i64:
        """Convert Simple Value to RuntimeValue pointer for SFFI operations."""
        match value:
            case Value.Int(i): rt_value_int(i)
            case Value.Float(f): rt_value_float(f)
            case Value.Bool(b): rt_value_bool(b)
            case Value.Nil: rt_value_nil()
            case Value.RuntimeValue(ptr): ptr  # Already a pointer
            case Value.String(s):
                rt_value_string(s.ptr(), s.len())
            case _:
                rt_value_nil()

    fn runtime_ptr_to_value(ptr: i64) -> Value:
        """Convert RuntimeValue pointer to Simple Value."""
        if rt_value_is_int(ptr):
            val i = rt_value_as_int(ptr)
            Value.int(i)
        elif rt_value_is_float(ptr):
            val f = rt_value_as_float(ptr)
            Value.float(f)
        elif rt_value_is_bool(ptr):
            val b = rt_value_as_bool(ptr)
            Value.bool(b)
        elif rt_value_is_nil(ptr):
            Value.Nil
        else:
            Value.RuntimeValue(ptr)

    fn value_to_string(value: Value) -> text:
        """Convert a Value to its string representation."""
        match value:
            case Value.Nil: "nil"
            case Value.Unit: "()"
            case Value.Bool(b): if b: "true" else: "false"
            case Value.Int(i): "{i}"
            case Value.Float(f): "{f}"
            case Value.Char(c): "{c}"
            case Value.String(s): s
            case Value.Array(elements):
                var parts: [text] = []
                for elem in elements:
                    parts = parts.push(self.value_to_string(elem))
                "[{parts.join(\", \")}]"
            case Value.RuntimeValue(_): "<runtime_value>"
            case _: "<{value.type_name()}>"
