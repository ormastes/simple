# Lua Codegen Adapter
#
# Wraps MirToLua translator to implement the Codegen trait.
# Produces Lua 5.2+/LuaJIT source for bin/simple run / nvim require().

use compiler.mir.mir_data.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, BackendCompileOptions, CompileError}
use compiler.backend.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.lua_backend.{MirToLua}

# ============================================================================
# Lua Codegen Adapter
# ============================================================================

class LuaCodegenAdapter:
    """Adapts MirToLua translator to the Codegen trait interface."""
    options: BackendCompileOptions

impl Codegen for LuaCodegenAdapter:
    fn backend_kind() -> BackendKind: BackendKind.Lua
    fn backend_name() -> text: "lua"
    fn supports_target(target: CodegenTarget) -> bool: true
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.TextSource

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        var translator = MirToLua.create(module.name)
        val lua_source = translator.translate_module(module)
        Ok(CodegenOutput.text(module.name, lua_source))

# ============================================================================
# Exports
# ============================================================================

export LuaCodegenAdapter
