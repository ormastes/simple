# LLVM Codegen Adapter
#
# Wraps MirToLlvm translator to implement the Codegen trait.
# Delegates to existing LLVM IR generation and llc compilation pipeline.

use compiler.mir.mir_instructions.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, CompileError, CompiledModule, compileerror_backend_error}
use compiler.backend.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.mir_to_llvm.{MirToLlvm}
use compiler.backend.llvm_target.{LlvmTargetConfig}
use compiler.backend.backend.llvm_backend_tools.{LlvmObjectCode, compile_ir_to_object}
use compiler.backend.llvm_ir_builder.{llvm_ir_builder_set_simpleos_header}
use compiler.common.mir_target_context.{mir_target_context_os_from}
extern fn rt_env_get(key: text) -> text

fn llvm_codegen_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

fn llvm_codegen_bare_metal_requested() -> bool:
    val requested_target = rt_env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? ""
    mir_target_context_os_from(requested_target, "") == "baremetal"

fn llvm_codegen_target_config(options: CompileOptions) -> LlvmTargetConfig:
    if llvm_codegen_bare_metal_requested():
        return LlvmTargetConfig.for_target_portable_numeric_baremetal(options.target, nil)
    LlvmTargetConfig.for_target_portable_numeric(options.target, nil)

fn llvm_codegen_translator(module_name: text, target: CodegenTarget) -> MirToLlvm:
    if llvm_codegen_bare_metal_requested():
        return MirToLlvm.create_baremetal(module_name, target, nil)
    MirToLlvm.create(module_name, target, nil)

# ============================================================================
# LLVM Codegen Adapter
# ============================================================================

class LlvmCodegenAdapter:
    """Adapts MirToLlvm translator to the Codegen trait interface."""
    options: CompileOptions

pub fn llvm_translate_module_direct_ir(options: CompileOptions, module: MirModule) -> text:
    val simpleos_header = match options.target:
        case CodegenTarget.SimpleOS_X86_64: true
        case _: false
    llvm_ir_builder_set_simpleos_header(simpleos_header)
    var translator = llvm_codegen_translator(module.name, options.target)
    val ir = translator.translate_module(module)
    llvm_ir_builder_set_simpleos_header(false)
    ir

pub fn llvm_compile_module_direct(options: CompileOptions, module: MirModule) -> Result<CodegenOutput, CompileError>:
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] start"
        print "[llvm-direct] module-name {module.name}"
        print "[llvm-direct] function-count {module.functions.len()}"
        for fn_ in module.functions.values():
            print "[llvm-direct] function-name {fn_.name}"
    # Translate MIR to LLVM IR
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] config"
    val config = llvm_codegen_target_config(options)
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] translator"
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] translate"
    val llvm_ir = llvm_translate_module_direct_ir(options, module)

    # Compile IR to object code via llc
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] llc"
    val result = compile_ir_to_object(llvm_ir, config, options.opt_level)
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] result"
    match result:
        Ok(object_code):
            if llvm_codegen_trace_enabled():
                print "[llvm-direct] bytes"
            val bytes = object_code.bytes
            if llvm_codegen_trace_enabled():
                print "[llvm-direct] done"
            Ok(CodegenOutput.object(module.name, bytes))
        Err(err_msg):
            Err(compileerror_backend_error(BackendKind.Llvm, err_msg))

pub fn llvm_compile_module_direct_compiled(options: CompileOptions, module: MirModule) -> Result<CompiledModule, CompileError>:
    if llvm_codegen_trace_enabled():
        print "[llvm-direct] compiled:start"
    val config = llvm_codegen_target_config(options)
    var translator = llvm_codegen_translator("app.cli.bootstrap_main", options.target)
    val llvm_ir = translator.translate_module(module)
    val result = compile_ir_to_object(llvm_ir, config, options.opt_level)
    match result:
        Ok(object_code):
            if llvm_codegen_trace_enabled():
                print "[llvm-direct] compiled:bytes"
            Ok(CompiledModule(
                name: "app.cli.bootstrap_main",
                object_code: object_code.bytes,
                has_assembly: false,
                assembly: "",
                has_llvm_ir: false,
                llvm_ir: "",
                symbols: [],
                compile_time_ms: 0
            ))
        Err(err_msg):
            Err(compileerror_backend_error(BackendKind.Llvm, err_msg))

impl Codegen for LlvmCodegenAdapter:
    fn backend_kind() -> BackendKind: BackendKind.Llvm
    fn backend_name() -> text: "llvm"
    fn supports_target(target: CodegenTarget) -> bool:
        match target:
            case X86_64 | SimpleOS_X86_64: true
            case AArch64: true
            case Riscv64: true
            case X86: true
            case Arm32: true
            case Riscv32: true
            case Wasm32: false
            case Wasm64: false
            case C: false
            case CudaPtx: false
            case VulkanSpirv: false
            case Metal: false
            case OpenCL: false
            case Avr: false
            case I8086: false
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.ObjectCode

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        llvm_compile_module_direct(self.options, module)

# ============================================================================
# Exports
# ============================================================================
