#![allow(unnamed_duplicate_typed_args)]
# Shared RISC-V backend target contracts

use compiler.backend.backend.backend_types.{CodegenTarget}
use hardware.riscv_common.pkg.riscv_linux_pkg.{RiscvTargetAbi}

struct RiscvTargetContract:
    target: CodegenTarget
    arch: text
    vendor: text
    os: text
    env: text?
    abi: RiscvTargetAbi
    cpu: text
    features: [text]
    march: text
    linker: text
    sysroot: text
    crt_dir: text
    pointer_bits: i64
    stack_align_bytes: i64
    arg_register_count: i64
    call_plt_reloc: i64

impl RiscvTargetContract:
    fn triple() -> text:
        var result = "{self.arch}-{self.vendor}-{self.os}"
        if self.env.?:
            result = "{result}-{self.env.unwrap()}"
        result

    fn abi_flag() -> text:
        "-mabi={self.abi.to_text()}"

    fn march_flag() -> text:
        "-march={self.march}"

fn riscv_linux_target_contract(target: CodegenTarget) -> RiscvTargetContract:
    if target == CodegenTarget.Riscv32:
        return RiscvTargetContract(
            target: target,
            arch: "riscv32",
            vendor: "unknown",
            os: "linux",
            env: Some("gnu"),
            abi: RiscvTargetAbi.ILP32D,
            cpu: "generic-rv32",
            features: ["+m", "+a", "+f", "+d", "+c"],
            march: "rv32gc",
            linker: "riscv64-linux-gnu-ld",
            sysroot: "/usr/riscv64-linux-gnu",
            crt_dir: "/usr/lib/riscv64-linux-gnu",
            pointer_bits: 32,
            stack_align_bytes: 16,
            arg_register_count: 8,
            call_plt_reloc: 19
        )
    RiscvTargetContract(
        target: CodegenTarget.Riscv64,
        arch: "riscv64",
        vendor: "unknown",
        os: "linux",
        env: Some("gnu"),
        abi: RiscvTargetAbi.LP64D,
        cpu: "generic-rv64",
        features: ["+m", "+a", "+f", "+d", "+c"],
        march: "rv64gc",
        linker: "riscv64-linux-gnu-ld",
        sysroot: "/usr/riscv64-linux-gnu",
        crt_dir: "/usr/lib/riscv64-linux-gnu",
        pointer_bits: 64,
        stack_align_bytes: 16,
        arg_register_count: 8,
        call_plt_reloc: 19
    )

fn riscv_baremetal_target_contract(target: CodegenTarget) -> RiscvTargetContract:
    if target == CodegenTarget.Riscv32:
        return RiscvTargetContract(
            target: target,
            arch: "riscv32",
            vendor: "unknown",
            os: "none",
            env: Some("elf"),
            abi: RiscvTargetAbi.ILP32D,
            cpu: "generic-rv32",
            features: ["+m", "+a", "+f", "+d", "+c"],
            march: "rv32gc",
            linker: "ld",
            sysroot: "",
            crt_dir: "",
            pointer_bits: 32,
            stack_align_bytes: 16,
            arg_register_count: 8,
            call_plt_reloc: 19
        )
    RiscvTargetContract(
        target: CodegenTarget.Riscv64,
        arch: "riscv64",
        vendor: "unknown",
        os: "none",
        env: Some("elf"),
        abi: RiscvTargetAbi.LP64D,
        cpu: "generic-rv64",
        features: ["+m", "+a", "+f", "+d", "+c"],
        march: "rv64gc",
        linker: "ld",
        sysroot: "",
        crt_dir: "",
        pointer_bits: 64,
        stack_align_bytes: 16,
        arg_register_count: 8,
        call_plt_reloc: 19
    )
