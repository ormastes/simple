enum MoldCompatibilityRole:
    LinkerDetection
    LinkerExecution
    UserOverride
    BundledBinaryDiscovery
    CrtDiscovery
    RuntimeLinking
    PureSimpleLinker

impl MoldCompatibilityRole:
    fn to_string() -> text:
        match self:
            case LinkerDetection: "linker-detection"
            case LinkerExecution: "linker-execution"
            case UserOverride: "user-override"
            case BundledBinaryDiscovery: "bundled-binary-discovery"
            case CrtDiscovery: "crt-discovery"
            case RuntimeLinking: "runtime-linking"
            case PureSimpleLinker: "pure-simple-linker"

struct MoldCompatibilityFeature:
    """Documented mold compatibility feature exposed to tests and docs."""
    role: MoldCompatibilityRole
    artifact: text
    status: text
    note: text

fn mold_default_linker_order() -> [text]:
    """Return the default host linker preference order."""
    ["mold", "lld", "ld"]

fn mold_supported_override_aliases() -> [text]:
    """Return SIMPLE_LINKER aliases accepted by the mold linker wrapper."""
    ["mold", "lld", "ld.lld", "lld-link", "ld", "gnu", "bfd"]

fn mold_bundled_search_suffixes() -> [text]:
    """Return repo-relative bundled mold paths checked before PATH."""
    [
        "bin/mold/mold",
        "bin/mold/mold-linux-x86_64",
        "bin/mold/mold-linux-aarch64",
        "bin/mold/mold-macos-x86_64",
        "bin/mold/mold-macos-aarch64",
        "bin/mold/mold-freebsd-x86_64",
        "bin/mold/mold-freebsd-aarch64",
        "bin/mold-linux-x86_64",
        "bin/mold-linux-aarch64",
        "bin/mold-macos-x86_64",
        "bin/mold-macos-aarch64",
        "bin/mold-freebsd-x86_64",
        "bin/mold-freebsd-aarch64",
        "bin/mold",
        "lib/simple/mold",
        "lib/simple/mold-linux-x86_64",
        "lib/simple/mold-linux-aarch64",
        "lib/simple/mold-macos-x86_64",
        "lib/simple/mold-macos-aarch64",
        "lib/simple/mold-freebsd-x86_64",
        "lib/simple/mold-freebsd-aarch64"
    ]

fn mold_compatibility_features() -> [MoldCompatibilityFeature]:
    """Return the current mold role/feature compatibility surface."""
    [
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.LinkerDetection,
            artifact: "find_mold_path/find_lld_path/find_ld_path/find_linker",
            status: "implemented",
            note: "Detects bundled mold first, then system mold, ld.lld/lld, then ld."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.UserOverride,
            artifact: "SIMPLE_LINKER/find_requested_linker",
            status: "implemented",
            note: "Supports mold, lld, ld.lld, lld-link, ld, gnu, and bfd aliases."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.BundledBinaryDiscovery,
            artifact: "mold_bundled_search_suffixes",
            status: "implemented",
            note: "Covers repo bin and lib/simple bundled binary layouts."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.CrtDiscovery,
            artifact: "mold_find_crt_files/mold_find_dynamic_linker",
            status: "implemented",
            note: "Discovers host CRT objects and dynamic linker for direct ELF linking."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.LinkerExecution,
            artifact: "MoldBackend.link",
            status: "wrapper",
            note: "Builds direct linker arguments and executes mold/lld/ld as an external process."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.RuntimeLinking,
            artifact: "MoldBackend.link_with_runtime",
            status: "partial",
            note: "Routes through the same external linker path; runtime object integration is still constrained by object representation."
        ),
        MoldCompatibilityFeature(
            role: MoldCompatibilityRole.PureSimpleLinker,
            artifact: "ELF/Mach-O/COFF linker implementation",
            status: "missing",
            note: "No in-process mold-compatible linker implementation exists yet."
        )
    ]

fn mold_is_pure_simple_linker_complete() -> bool:
    """Return whether this module is a complete in-process mold reimplementation."""
    false

export MoldCompatibilityRole
export MoldCompatibilityFeature
export mold_default_linker_order
export mold_supported_override_aliases
export mold_bundled_search_suffixes
export mold_compatibility_features
export mold_is_pure_simple_linker_complete
