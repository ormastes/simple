# Unified abstraction for SMF module source
#
# Provides a common interface for file-backed and in-memory SMF modules,
# allowing downstream code (generic instantiation, template loading,
# metadata reading) to work without knowing the module origin.

extern fn rt_file_read_bytes(path: text) -> [u8]

enum SmfSource:
    FileSmf(path: text)
    MemorySmf(bytes: [u8], logical_name: text)

fn smf_source_get_name(source: SmfSource) -> text:
    match source:
        FileSmf(path): path
        MemorySmf(bytes, logical_name): logical_name

fn smf_source_is_file(source: SmfSource) -> bool:
    match source:
        FileSmf(path): true
        MemorySmf(bytes, name): false

fn smf_source_is_memory(source: SmfSource) -> bool:
    match source:
        FileSmf(path): false
        MemorySmf(bytes, name): true

fn smf_source_file_path(source: SmfSource) -> text:
    match source:
        FileSmf(path): path
        MemorySmf(bytes, name): ""

fn smf_source_get_bytes(source: SmfSource) -> [u8]:
    match source:
        FileSmf(path): rt_file_read_bytes(path)
        MemorySmf(bytes, name): bytes

fn smf_source_describe(source: SmfSource) -> text:
    match source:
        FileSmf(path): "file:" + path
        MemorySmf(bytes, name): "memory:" + name
