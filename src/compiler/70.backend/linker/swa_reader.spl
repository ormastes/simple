# SWA Reader - Read modules and assets from SWA archives
#
# This module provides functionality to read compiled modules and static
# assets from Simple Web Archive (.swa) files using the location indices.
#
# Usage:
#   val archive = SwaArchive.open("myapp.swa")?
#   val asset = archive.get_asset("css/style.css")?
#   val module = archive.get_module("app/controllers/home")?
#   val descriptor = archive.get_descriptor()

use app.io.{file_read, file_exists}
use compiler.backend.linker.swa.{SwaHeader, AssetIndexEntry, SWA_HEADER_SIZE, SWA_ASSET_ENTRY_SIZE, SWA_MAGIC}
use compiler.backend.linker.lib_smf.{ModuleIndexEntry, LSMF_INDEX_ENTRY_SIZE, bytes_to_u32, bytes_to_u64, fnv1a_hash, char_from_byte}

# ============================================================================
# SWA Archive Reader
# ============================================================================

"""Reader for Simple Web Archive files.

Example:
    val archive = SwaArchive.open("myapp.swa")?
    val assets = archive.list_assets()
    val css = archive.get_asset("css/style.css")?
    val modules = archive.list_modules()
    val descriptor = archive.get_descriptor()
"""
struct SwaArchive:
    path: text
    header: SwaHeader
    module_entries: [ModuleIndexEntry]
    asset_entries: [AssetIndexEntry]
    descriptor: text
    file_data: [u8]

impl SwaArchive:
    """Open a SWA file for reading.

    Args:
        path: Path to .swa file

    Returns:
        SwaArchive instance or error
    """
    static fn open(path: text) -> Result<SwaArchive, text>:
        # Check if file exists
        if not file_exists(path):
            return Err("SWA file not found: {path}")

        # Read entire file into memory
        val file_result = file_read(path)
        if file_result.is_err():
            return Err("Failed to read SWA file: {path}")

        val file_text = file_result.unwrap()
        val file_data = text_to_bytes(file_text)

        # Read header
        if file_data.len() < SWA_HEADER_SIZE:
            return Err("File too small to be SWA archive")

        var header_bytes: [u8] = []
        var i = 0
        while i < SWA_HEADER_SIZE:
            header_bytes.push(file_data[i])
            i = i + 1

        val header_result = SwaHeader.from_bytes(header_bytes)
        if header_result.is_err():
            return Err(header_result.unwrap_err())

        val header = header_result.unwrap()

        # Validate magic
        if not header.is_valid():
            return Err("Invalid SWA magic number")

        # Read module index table
        var module_entries: [ModuleIndexEntry] = []
        val module_index_start = header.module_index_offset as i64
        val module_count = header.module_count as i64

        i = 0
        while i < module_count:
            val entry_offset = module_index_start + (i * LSMF_INDEX_ENTRY_SIZE)
            val entry_result = ModuleIndexEntry.from_bytes(file_data, entry_offset)
            if entry_result.is_err():
                return Err("Failed to read module index entry {i}: {entry_result.unwrap_err()}")

            module_entries.push(entry_result.unwrap())
            i = i + 1

        # Read asset index table
        var asset_entries: [AssetIndexEntry] = []
        val asset_index_start = header.asset_index_offset as i64
        val asset_count = header.asset_count as i64

        i = 0
        while i < asset_count:
            val entry_offset = asset_index_start + (i * SWA_ASSET_ENTRY_SIZE)
            val entry_result = AssetIndexEntry.from_bytes(file_data, entry_offset)
            if entry_result.is_err():
                return Err("Failed to read asset index entry {i}: {entry_result.unwrap_err()}")

            asset_entries.push(entry_result.unwrap())
            i = i + 1

        # Extract descriptor
        var descriptor = ""
        val desc_offset = header.descriptor_offset as i64
        val desc_size = header.descriptor_size as i64

        if desc_size > 0 and desc_offset + desc_size <= file_data.len():
            var desc_bytes = slice_bytes(file_data, desc_offset, desc_offset + desc_size)
            var desc_chars: [text] = []
            for b in desc_bytes:
                desc_chars.push(char_from_byte(b))
            descriptor = desc_chars.join("")

        Ok(SwaArchive(
            path: path,
            header: header,
            module_entries: module_entries,
            asset_entries: asset_entries,
            descriptor: descriptor,
            file_data: file_data
        ))

    """Get SMF data for a module.

    Args:
        name: Module path (e.g., "app/controllers/home")

    Returns:
        SMF file data as bytes or error
    """
    fn get_module(name: text) -> Result<[u8], text>:
        # Find module in index
        var found_entry: ModuleIndexEntry? = nil
        for entry in self.module_entries:
            if entry.get_name() == name:
                found_entry = entry
                break

        if not found_entry.?:
            return Err("Module not found in archive: {name}")

        val entry = found_entry ?? ModuleIndexEntry.new("", 0, 0, 0)

        # Extract module data
        val offset = entry.offset as i64
        val size = entry.size as i64

        if offset + size > self.file_data.len():
            return Err("Module data extends beyond file: {name}")

        var module_data = slice_bytes(self.file_data, offset, offset + size)

        # Verify hash
        val computed_hash = fnv1a_hash(module_data)
        if computed_hash != entry.hash:
            return Err("Hash mismatch for module {name}: expected {entry.hash}, got {computed_hash}")

        Ok(module_data)

    """Get asset data by path.

    Args:
        path: Relative asset path (e.g., "css/style.css")

    Returns:
        Asset file data as bytes or error
    """
    fn get_asset(path: text) -> Result<[u8], text>:
        # Find asset in index
        var found_entry: AssetIndexEntry? = nil
        for entry in self.asset_entries:
            if entry.get_path() == path:
                found_entry = entry
                break

        if not found_entry.?:
            return Err("Asset not found in archive: {path}")

        val entry = found_entry ?? AssetIndexEntry.new("", 0, 0, 0, "")

        # Extract asset data
        val offset = entry.offset as i64
        val size = entry.size as i64

        if offset + size > self.file_data.len():
            return Err("Asset data extends beyond file: {path}")

        var asset_data = slice_bytes(self.file_data, offset, offset + size)

        # Verify hash
        val computed_hash = fnv1a_hash(asset_data)
        if computed_hash != entry.hash:
            return Err("Hash mismatch for asset {path}: expected {entry.hash}, got {computed_hash}")

        Ok(asset_data)

    """Get deployment descriptor text."""
    fn get_descriptor() -> text:
        self.descriptor

    """List all module names in the archive."""
    fn list_modules() -> [text]:
        var names: [text] = []
        for entry in self.module_entries:
            names.push(entry.get_name())
        names

    """List all asset paths in the archive."""
    fn list_assets() -> [text]:
        var paths: [text] = []
        for entry in self.asset_entries:
            paths.push(entry.get_path())
        paths

    """Get the number of modules in the archive."""
    fn module_count() -> i64:
        self.module_entries.len()

    """Get the number of assets in the archive."""
    fn asset_count() -> i64:
        self.asset_entries.len()

    """Get mime type for an asset by path.

    Args:
        path: Relative asset path (e.g., "css/style.css")

    Returns:
        Mime type string (e.g., "text/css") or "application/octet-stream" if not found
    """
    fn get_asset_mime_type(path: text) -> text:
        for entry in self.asset_entries:
            if entry.get_path() == path:
                return entry.get_mime_type()
        "application/octet-stream"

    """Check if a module exists in the archive.

    Args:
        name: Module path

    Returns:
        true if module exists, false otherwise
    """
    fn has_module(name: text) -> bool:
        for entry in self.module_entries:
            if entry.get_name() == name:
                return true
        false

    """Check if an asset exists in the archive.

    Args:
        path: Relative asset path

    Returns:
        true if asset exists, false otherwise
    """
    fn has_asset(path: text) -> bool:
        for entry in self.asset_entries:
            if entry.get_path() == path:
                return true
        false

    """Get archive header information."""
    fn get_header() -> SwaHeader:
        self.header

    """Get the default port from the header."""
    fn get_default_port() -> i64:
        self.header.default_port as i64

# ============================================================================
# Helper Functions
# ============================================================================

"""Convert text to bytes."""
fn text_to_bytes(text: text) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < text.len():
        bytes.push(text[i] as u8)
        i = i + 1
    bytes

"""Extract a byte range from a byte array."""
fn slice_bytes(data: [u8], start: i64, end: i64) -> [u8]:
    var result: [u8] = []
    var i = start
    while i < end:
        result.push(data[i])
        i = i + 1
    result

# ============================================================================
# Exports
# ============================================================================
