# Object Provider - Unified object file and module access
#
# Wraps SmfGetter to provide a consistent API for accessing object files,
# module bytes, and exported code units from SMF files and libraries.

use std.io_runtime.{file_exists, file_read_bytes}
use compiler.backend.linker.smf_header.{SmfHeader}
use compiler.backend.linker.smf_getter.{SmfGetter, SmfLocation, SmfSourceType}
use compiler.backend.linker.smf_reader.{SmfReaderImpl}
use compiler.backend.linker.smf_reader_memory.{SmfReaderMemory}
use compiler.backend.linker.object_code_unit.{ObjectCodeUnit}

struct ObjectProviderConfig:
    search_paths: [text]
    libraries: [text]
    enable_cache: bool
    verbose: bool
    prefer_backend: text

struct ObjectProvider:
    getter: SmfGetter
    verbose: bool
    config: ObjectProviderConfig

fn objectprovider_normalize_backend_name(backend: text) -> text:
    if backend == nil:
        return ""
    backend.trim()

fn objectprovider_backend_text_to_kind(backend: text) -> u8:
    match objectprovider_normalize_backend_name(backend):
        case "llvm": 1
        case "cranelift": 2
        case "c" | "cpp": 3
        case "wasm": 4
        case "vhdl": 5
        case "native": 6
        case _: 0

fn objectprovider_backend_kind_to_text(kind: u8) -> text:
    match kind:
        case 0: "auto"
        case 1: "llvm"
        case 2: "cranelift"
        case 3: "c"
        case 4: "wasm"
        case 5: "vhdl"
        case 6: "native"
        case _: "unknown"

fn objectprovider_extract_backend_kind(bytes: [u8]) -> u8:
    if bytes.len() < 9:
        return 0
    bytes[8]

fn objectprovider_load_source_bytes(self: ObjectProvider, module_name: text) -> Result<[u8], text>:
    if file_exists(module_name):
        return Ok(file_read_bytes(module_name))
    self.getter.get(module_name)

fn objectprovider_validate_preference(self: ObjectProvider, module_name: text, header: SmfHeader) -> Result<(), text>:
    val prefer_backend = objectprovider_normalize_backend_name(self.config.prefer_backend)
    if prefer_backend == "":
        return Ok(())

    if not header.has_compile_options_hash():
        return Err("ObjectProvider prefer_backend={prefer_backend} rejected {module_name}: missing compile options hash")

    if not header.is_pic():
        return Err("ObjectProvider prefer_backend={prefer_backend} rejected {module_name}: module is not PIC")

    val compile_backend = objectprovider_extract_backend_kind(header.get_compile_options_bytes())
    val requested_backend = objectprovider_backend_text_to_kind(prefer_backend)
    if requested_backend == 0:
        return Err("ObjectProvider prefer_backend={prefer_backend} rejected {module_name}: unsupported backend preference")

    if compile_backend != requested_backend:
        return Err("ObjectProvider prefer_backend={prefer_backend} rejected {module_name}: module backend is {objectprovider_backend_kind_to_text(compile_backend)}")

    Ok(())

impl ObjectProvider:
    static fn new(config: ObjectProviderConfig) -> ObjectProvider:
        var getter = SmfGetter.new()
        if config.verbose:
            getter.set_verbose(true)

        # Add search paths
        for path in config.search_paths:
            getter.add_search_path(path)

        # Pre-load any configured libraries
        for lib in config.libraries:
            if file_exists(lib):
                _ = getter.add_library(lib)

        ObjectProvider(
            getter: getter,
            verbose: config.verbose,
            config: config
        )
    # Add a library (.lsm) file to the provider
    me add_library(lib_path: text) -> Result<(), text>:
        self.getter.add_library(lib_path)

    # List all known module names
    fn list_modules() -> [text]:
        self.getter.list_modules()

    # Get raw SMF module bytes
    fn get_module_bytes(module_name: text) -> Result<[u8], text>:
        objectprovider_load_source_bytes(self, module_name)

    # Get object file bytes for a module (from library archive)
    fn get_object(module_name: text) -> Result<[u8], text>:
        val source_result = objectprovider_load_source_bytes(self, module_name)
        if source_result.is_err():
            return Err(source_result.unwrap_err())

        val source_bytes = source_result.unwrap()
        val header_result = SmfHeader.from_bytes(source_bytes)
        if header_result.is_err():
            return Err(header_result.unwrap_err())

        val header = header_result.unwrap()
        val preference_result = objectprovider_validate_preference(self, module_name, header)
        if preference_result.is_err():
            return Err(preference_result.unwrap_err())

        val mem_result = SmfReaderMemory.from_data(source_bytes)
        if mem_result.is_ok():
            val mem_reader = mem_result.unwrap()
            if mem_reader.has_elf_object():
                return mem_reader.read_elf_object()
        elif file_exists(module_name):
            return Err("Single SMF file has no ELF object: {module_name}")

        if self.getter.has_module(module_name):
            val object_result = self.getter.get_object(module_name)
            if object_result.is_ok():
                return object_result
            return Err(object_result.unwrap_err())

        Err("Module has no object data: {module_name}")

    # Get exported code units for a module
    fn get_exported_code(module_name: text) -> Result<[ObjectCodeUnit], text>:
        # Get module data
        val data_result = objectprovider_load_source_bytes(self, module_name)
        if data_result.is_err():
            return Err(data_result.unwrap_err())

        val data = data_result.unwrap()
        val header_result = SmfHeader.from_bytes(data)
        if header_result.is_err():
            return Err(header_result.unwrap_err())

        val header = header_result.unwrap()
        val preference_result = objectprovider_validate_preference(self, module_name, header)
        if preference_result.is_err():
            return Err(preference_result.unwrap_err())

        # Build a code unit from the raw module data
        val unit = ObjectCodeUnit(
            name: module_name,
            bytes: data,
            size: data.len()
        )
        Ok([unit])

    # Get an SMF reader for a module path
    fn get_reader(path: text) -> Result<SmfReaderImpl, text>:
        # Try opening as a direct file first
        if file_exists(path):
            return SmfReaderImpl.open(path)

        # Try as a module name via getter
        self.getter.get_reader(path)

    # Check if a module exists
    fn has_module(module_name: text) -> bool:
        self.getter.has_module(module_name)
