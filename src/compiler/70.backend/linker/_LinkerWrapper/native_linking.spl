# Native + SMF-bundle linking — link_to_native and cc/windows/msvc backends.
use compiler.backend.linker.linker_wrapper.*
# Linker Wrapper - Unified Linking API
#
# This module provides a single entry point for all linking operations,
# replacing the hardcoded `cc` calls in driver.spl with platform-aware
# linker selection and adding self-contained executable SMF support.
#
# Three linking modes:
#   link_to_native()         - Platform-detected native binary (mold/lld/ld)
#   link_to_smf()            - SMF module file
#   link_to_self_contained() - Runtime + SMF data in one executable
#
# Self-contained binary format (trailer-based):
#   [Runtime Binary] [SMF Data] [32-byte Trailer]
#   Trailer: "SMFE"(4) + smf_offset(8) + smf_size(8) + checksum(8) + version(4)
#
# Interpreter-safe: no generics (<>) used.
#
# Split into modules:
#   linker_wrapper_helpers.spl — SMF linking, self-contained linking, binary helpers

use std.io_runtime.{ShellResult, shell, shell_output, file_exists, file_copy, file_delete, file_size_raw, file_read_bytes, env_get, process_run, cwd}
use std.platform.{host_os, host_arch}
use std.log.{debug, info}
use std.string_builder.{StringBuilder}

use compiler.backend.linker.lld_sffi.{LldResult, lld_elf_link}
use compiler.backend.linker.mold.{MoldBackend, MoldConfig, find_linker, LinkerType, execute_linker, create_temp_dir, cleanup_temp_dir, linker_file_size}
use compiler.backend.linker.object_provider.{ObjectProvider, ObjectProviderConfig}
use compiler.backend.linker.object_code_unit.{ObjectCodeUnit}
use compiler.backend.linker.object_emitter.{assemble_code_units}
use compiler.backend.linker.smf_getter.{SmfGetter}
use compiler.backend.linker.smf_enums.{Platform, Arch}
use compiler.backend.linker.obj_taker.{ObjTaker, ObjTakeResult, objtaker_with_defaults, objtaker_take_object}
use compiler.backend.linker.platform_defaults.{elf_emulation}
use compiler.backend.backend.runtime_compiler.{find_c_compiler, hosted_c_compiler_plan}

# Re-export CRT discovery (extracted to crt_discovery.spl)
use compiler.backend.linker.crt_discovery.*

# Import helpers (SMF linking, self-contained, binary utils)
use compiler.backend.linker.linker_wrapper_helpers.{SelfContainedConfig}
use compiler.backend.linker.msvc.{MsvcConfig, MsvcLinker, find_visual_studio, find_link_exe, find_msvc_crt_paths}
use compiler.backend.linker.linker_wrapper_helpers.{SMFE_MAGIC, SMFE_TRAILER_SIZE, SMFE_VERSION}
use compiler.backend.linker.linker_wrapper_helpers.{link_to_smf, link_to_self_contained}
use compiler.backend.linker.linker_wrapper_helpers.{detect_self_contained, find_runtime_binary, find_runtime_lib_dir}
use compiler.backend.linker.linker_wrapper_helpers.{build_trailer, fnv1a_hash}
use compiler.backend.linker.linker_wrapper_helpers.{write_bytes_to_file, write_elf_bytes_to_file}

# ============================================================================
# Configuration Structs
# ============================================================================

struct NativeLinkConfig:
    libraries: [text]
    library_paths: [text]
    runtime_path: text       # Path to libsimple_compiler (empty = auto-detect)
    pie: bool
    debug: bool
    verbose: bool
    extra_flags: [text]

impl NativeLinkConfig:
    static fn default() -> NativeLinkConfig:
        NativeLinkConfig(
            libraries: [],
            library_paths: [],
            runtime_path: "",
            pie: true,
            debug: false,
            verbose: false,
            extra_flags: []
        )

struct CrtFiles:
    crt1: text           # crt1.o or Scrt1.o (PIE)
    crti: text           # crti.o
    crtn: text           # crtn.o
    crtbegin: text       # crtbegin.o or crtbeginS.o (PIE)
    crtend: text         # crtend.o or crtendS.o (PIE)
    dynamic_linker: text # e.g., /lib64/ld-linux-x86-64.so[2]
    lib_dirs: [text]     # System library search paths
    found: bool

fn is_simpleos_target() -> bool:
    val t = env_get("SIMPLE_TARGET")
    if t == nil:
        return false
    t.ends_with("-simpleos")

fn detect_preferred_backend(extra_flags: [text]) -> text:
    for flag in extra_flags:
        if flag == "--fixed-be":
            return "llvm"
        elif flag.starts_with("--fixed-be="):
            val backend = flag.substring(11)
            if backend != "":
                return backend
    ""

fn unresolved_symbol_flags_for_unix_linker(os: text) -> [text]:
    if os == "linux" or os == "freebsd":
        return ["--allow-multiple-definition"]
    []

fn unresolved_symbol_flags_for_cc(os_name: text) -> [text]:
    if os_name == "Linux" or os_name == "FreeBSD":
        return ["-Wl,--allow-multiple-definition"]
    []

fn msvc_duplicate_symbol_flag() -> text:
    "/FORCE:MULTIPLE"

fn macos_homebrew_prefix(configured: text, arch: text) -> text:
    if configured != "":
        return configured
    if arch == "aarch64":
        return "/opt/homebrew"
    "/usr/local"

fn linker_trace_enabled() -> bool:
    (env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

fn hosted_native_link_os_supported(os: text) -> bool:
    os == "linux" or os == "macos" or os == "darwin" or os == "windows" or os == "freebsd"

fn hosted_native_link_arch_supported(os: text, arch: text) -> bool:
    val x64 = arch == "x86_64" or arch == "amd64"
    val arm64 = arch == "aarch64" or arch == "arm64"
    if os == "windows":
        return x64
    if os == "macos" or os == "darwin" or os == "freebsd":
        return x64 or arm64
    if os == "linux":
        return x64 or arm64 or arch == "riscv64" or arch == "rv64"
    false

fn hosted_native_link_unsupported_error(os: text) -> text:
    "Native linking is unsupported on host OS '" + os + "'"

fn hosted_native_link_unsupported_arch_error(os: text, arch: text) -> text:
    if os == "windows" and (arch == "aarch64" or arch == "arm64"):
        return "Windows ARM64 native linking unsupported: MSVC linker and CRT discovery are x64-only"
    "Native linking is unsupported on host architecture '" + arch + "' for OS '" + os + "'"

# ============================================================================
# Native Linking
# ============================================================================

fn link_to_native(object_files: [text], output: text, config: NativeLinkConfig) -> Result:
    val trace = linker_trace_enabled()
    if trace:
        print "[LINKER] link_to_native: {object_files.len()} files, output={output}"
    if object_files.len() == 0:
        return Err("No object files to link")

    val os = host_os()
    if trace:
        print "[LINKER] os={os}"
    if not hosted_native_link_os_supported(os):
        return Err(hosted_native_link_unsupported_error(os))
    val arch = host_arch()
    if not hosted_native_link_arch_supported(os, arch):
        return Err(hosted_native_link_unsupported_arch_error(os, arch))

    # If inputs are SMF/LSM, build a self-contained binary instead of raw native link.
    val smf_inputs = filter_smf_inputs(object_files)
    if trace:
        print "[LINKER] smf_inputs={smf_inputs.len()}"
    if smf_inputs.len() > 0:
        val mixed = smf_inputs.len() != object_files.len()
        if mixed:
            return Err("Cannot mix SMF and object inputs; convert all to SMF or all to objects")
        return link_smf_bundle(smf_inputs, output, config)

    # Platform-specific linking
    if os == "windows":
        return link_native_windows(object_files, output, config)

    # Unix-like: Linux, macOS, FreeBSD
    if trace:
        print "[LINKER] calling link_native_unix..."
    link_native_unix(object_files, output, config)

fn link_native_unix(object_files: [text], output: text, config: NativeLinkConfig) -> Result:
    val os = host_os()
    val arch = host_arch()
    val trace = linker_trace_enabled()
    if trace:
        print "[LINKER] link_native_unix: os={os}, arch={arch}"

    # Try to find platform linker (mold > lld > ld)
    if trace:
        print "[LINKER] calling find_linker..."
    val linker_result = find_linker()
    if trace:
        print "[LINKER] find_linker returned, is_err={linker_result.is_err()}"
    if linker_result.is_err():
        if trace:
            print "[LINKER] No direct linker found, falling back to cc"
        return link_native_cc(object_files, output, config)

    val linker_info = linker_result.unwrap()
    if trace:
        print "[LINKER] linker_info unwrapped"
    val linker_path = linker_info[0]
    if trace:
        print "[LINKER] got linker_path={linker_path}"
    val linker_type = linker_info[1]
    if trace:
        print "[LINKER] got linker_type"

    # Discover CRT files needed for direct linker invocation
    if trace:
        print "[LINKER] calling find_crt_files..."
    val crt = find_crt_files(config.pie, config.verbose)
    if trace:
        print "[LINKER] crt.found={crt.found}"
    if not crt.found:
        debug("linker", "CRT files not found, falling back to cc")
        if config.verbose:
            print "[linker-wrapper] CRT files not found, falling back to cc"
        return link_native_cc(object_files, output, config)

    if config.verbose:
        print "[linker-wrapper] Using {linker_type.to_string()} at {linker_path}"

    # Build linker arguments in correct order
    var args: [text] = []

    # Output file
    args.push("-o")
    args.push(output)

    # Emulation mode
    if os == "linux":
        val emulation = elf_emulation(arch)
        if emulation != "":
            args.push("-m")
            args.push(emulation)

    # Dynamic linker
    if crt.dynamic_linker != "":
        args.push("-dynamic-linker")
        args.push(crt.dynamic_linker)

    # Hardening flags (ELF-only — macOS ld64 doesn't recognize these)
    if os != "macos" and os != "darwin":
        args.push("--eh-frame-hdr")
        args.push("--build-id")
        args.push("--hash-style=gnu")
        args.push("-z")
        args.push("relro")
        args.push("-z")
        args.push("now")
        for flag in unresolved_symbol_flags_for_unix_linker(os):
            args.push(flag)

    # Dead code elimination + deduplication (per-platform)
    if os == "macos" or os == "darwin":
        args.push("-dead_strip")
        # Do not pass `-no_uuid`: current macOS dyld rejects executable Mach-O
        # images with a missing LC_UUID load command before Stage 3 can run.
    else:
        args.push("--gc-sections")
        # ICF: mold and lld support --icf=all, gold supports --icf=safe
        val lt = linker_type.to_string()
        if lt == "mold" or lt == "lld":
            args.push("--icf=all")
        elif lt == "gold":
            args.push("--icf=safe")

    # PIE
    if config.pie:
        args.push("-pie")

    # CRT prologue: crt1.o, crti.o, crtbegin.o (before user objects)
    args.push(crt.crt1)
    args.push(crt.crti)
    args.push(crt.crtbegin)

    # User object files
    for obj in object_files:
        args.push(obj)

    # Library search paths from CRT discovery
    for dir in crt.lib_dirs:
        args.push("-L")
        args.push(dir)

    # Library paths from config
    for lp in config.library_paths:
        args.push("-L")
        args.push(lp)

    # Auto-detect runtime library if not specified
    # "none" means skip runtime library entirely (e.g., LLVM pipeline provides runtime objects directly)
    var runtime_dir = config.runtime_path
    if runtime_dir == "":
        runtime_dir = find_runtime_lib_dir()
    if runtime_dir != "" and runtime_dir != "none":
        args.push("-L")
        args.push(runtime_dir)
        args.push("-lsimple_compiler")
        args.push("-rpath")
        args.push(runtime_dir)

    # Standard libraries (no -lgcc/-lgcc_s — clang provides compiler-rt)
    # On Linux/FreeBSD wrap optional libs with --as-needed so they are only
    # recorded in DT_NEEDED when actually referenced by the linked objects.
    if os == "linux":
        args.push("-lc")
        args.push("-lpthread")
        args.push("-ldl")
        args.push("--as-needed")
        args.push("-lm")
        args.push("-lSDL2")
        args.push("--no-as-needed")
    elif os == "macos":
        args.push("-lc")
        args.push("-lpthread")
        args.push("-lm")
        args.push("-lSystem")
        args.push("-lSDL2")
    elif os == "freebsd":
        args.push("-lc")
        args.push("-lpthread")
        args.push("--as-needed")
        args.push("-lm")
        args.push("-lSDL2")
        args.push("--no-as-needed")

    val brew_prefix = macos_homebrew_prefix(env_get("HOMEBREW_PREFIX") ?? "", host_arch())
    for flag in native_all_gnu_support_args(object_files, os, brew_prefix):
        args.push(flag)

    # Libraries from config
    for lib in config.libraries:
        args.push("-l")
        args.push(lib)

    # Debug info
    if config.debug:
        args.push("-g")

    # Extra flags
    for flag in config.extra_flags:
        args.push(flag)

    # CRT epilogue: crtend.o, crtn.o (after libs)
    args.push(crt.crtend)
    args.push(crt.crtn)

    # SimpleOS: link in-process via LLD SFFI — no fork/exec available on guest.
    if is_simpleos_target():
        var lld_args: [text] = ["ld.lld"]
        for a in args:
            lld_args.push(a)
        val lld_res = lld_elf_link(lld_args)
        if lld_res.exit_code != 0:
            return Err("in-process lld failed: {lld_res.stderr_text}")
        if config.verbose:
            val size = linker_file_size(output)
            print "[linker-wrapper] Native binary (in-process lld): {output} ({size} bytes)"
        return Ok(output)

    # Execute linker
    val exec_result = execute_linker(linker_path, args)
    if exec_result.is_err():
        # Fallback to cc on failure
        if config.verbose:
            print "[linker-wrapper] Direct linker failed, falling back to cc: {exec_result.unwrap_err()}"
        return link_native_cc(object_files, output, config)

    if config.verbose:
        val size = linker_file_size(output)
        print "[linker-wrapper] Native binary: {output} ({size} bytes)"

    Ok(output)

# Build self-contained binary when given SMF inputs
fn link_smf_bundle(smf_inputs: [text], output: text, config: NativeLinkConfig) -> Result:
    if smf_inputs.len() == 0:
        return Err("No SMF inputs")

    val verbose = config.verbose
    val prefer_backend = detect_preferred_backend(config.extra_flags)
    val provider = create_default_provider(verbose, prefer_backend)
    val strict_preference = prefer_backend != nil and prefer_backend != ""

    # Create shared ObjTaker for extraction/instantiation across all inputs
    var obj_taker = objtaker_with_defaults()

    # Support multiple SMF inputs
    if smf_inputs.len() > 1 or smf_inputs[0].ends_with(".lsm"):
        # Multi-SMF or .lsm library mode
        val tmp_dir = create_temp_dir()
        if tmp_dir == "":
            return Err("Failed to create temp dir for SMF objects")

        var objs: [text] = []

        for path in smf_inputs:
            if path.ends_with(".lsm"):
                # .lsm library: extract objects and link
                val add_res = provider.add_library(path)
                if add_res.is_err():
                    cleanup_temp_dir(tmp_dir)
                    return Err(add_res.unwrap_err())

                val modules = provider.list_modules()
                for m in modules:
                    val obj_res = provider.get_object(m)
                    if obj_res.is_ok():
                        val obj_bytes = obj_res.unwrap()
                        val safe = m.replace("/", "_")
                        val obj_path = "{tmp_dir}/{safe}.o"
                        if write_bytes_to_file(obj_path, obj_bytes):
                            objs.push(obj_path)
                        continue

                    val code_res = provider.get_exported_code(m)
                    if code_res.is_err():
                        if strict_preference:
                            cleanup_temp_dir(tmp_dir)
                            return Err(code_res.unwrap_err())
                        if verbose:
                            print "[linker-wrapper] missing object for {m}: {code_res.unwrap_err()}"
                        continue
                    val obj_paths = materialize_code_units(code_res.unwrap(), tmp_dir, verbose)
                    for p in obj_paths:
                        objs.push(p)
            else:
                # Single SMF file: try ObjectProvider extraction
                val obj_res = provider.get_object(path)
                if obj_res.is_ok():
                    val safe = path.replace("/", "_").replace(".smf", "")
                    val obj_path = "{tmp_dir}/{safe}.o"
                    if write_bytes_to_file(obj_path, obj_res.unwrap()):
                        objs.push(obj_path)
                    continue

                val code_res = provider.get_exported_code(path)
                if code_res.is_ok():
                    val code_objs = materialize_code_units(code_res.unwrap(), tmp_dir, verbose)
                    for p in code_objs:
                        objs.push(p)
                elif strict_preference:
                    cleanup_temp_dir(tmp_dir)
                    return Err(code_res.unwrap_err())

        if objs.len() == 0:
            cleanup_temp_dir(tmp_dir)
            return Err("No object data available in SMF inputs")

        val link_res = link_native_unix(objs, output, config)
        cleanup_temp_dir(tmp_dir)
        return link_res

    # Single SMF file path
    val path = smf_inputs[0]

    # Try to convert single SMF to object via ObjectProvider
    val obj_result = provider.get_object(path)
    if obj_result.is_ok():
        val tmp_dir = create_temp_dir()
        if tmp_dir == "":
            return Err("Failed to create temp dir for SMF objects")
        val obj_path = "{tmp_dir}/input.o"
        val write_ok = write_bytes_to_file(obj_path, obj_result.unwrap())
        if not write_ok:
            cleanup_temp_dir(tmp_dir)
            return Err("Failed to write object from SMF")
        val link_res = link_native_unix([obj_path], output, config)
        cleanup_temp_dir(tmp_dir)
        return link_res

    # Fallback: generate objects from exported code
    val code_result = provider.get_exported_code(path)
    if code_result.is_ok():
        val tmp_dir = create_temp_dir()
        if tmp_dir == "":
            return Err("Failed to create temp dir for SMF code")
        val obj_paths = materialize_code_units(code_result.unwrap(), tmp_dir, verbose)
        if obj_paths.len() > 0:
            val link_res = link_native_unix(obj_paths, output, config)
            cleanup_temp_dir(tmp_dir)
            return link_res
        cleanup_temp_dir(tmp_dir)
    elif strict_preference:
        return Err(code_result.unwrap_err())

    # Fallback: self-contained binary
    val data = file_read_bytes(path)
    if data.len() == 0:
        return Err("Failed to read SMF data from {path}")

    val sc_config = SelfContainedConfig(
        runtime_binary: config.runtime_path,
        verbose: config.verbose,
        strip: false
    )
    link_to_self_contained(data, output, sc_config)

fn create_default_provider(verbose: bool, prefer_backend: text) -> ObjectProvider:
    ObjectProvider.new(ObjectProviderConfig(
        search_paths: ["/usr/lib/simple", "/usr/local/lib/simple"],
        libraries: [],
        enable_cache: true,
        verbose: verbose,
        prefer_backend: prefer_backend
    ))

fn materialize_code_units(units: [ObjectCodeUnit], tmp_dir: text, verbose: bool) -> [text]:
    """Convert exported code units into temporary .o files."""
    var paths: [text] = []
    for code_unit in units:
        val safe = code_unit.name.replace("/", "_")
        val obj_path = "{tmp_dir}/{safe}.o"
        val asm_res = assemble_code_units([code_unit], obj_path, verbose)
        if asm_res.is_ok():
            paths.push(obj_path)
        elif verbose:
            print "[linker-wrapper] failed to assemble {code_unit.name}: {asm_res.unwrap_err()}"
    paths

fn filter_smf_inputs(files: [text]) -> [text]:
    var smfs: [text] = []
    for f in files:
        if f.ends_with(".smf") or f.ends_with(".lsm"):
            smfs.push(f)
    smfs

fn _cc_fallback_runtime_lib_args(config: NativeLinkConfig) -> [text]:
    """Runtime library link args for the cc fallback path.

    The direct-linker path links -lsimple_compiler for runtime symbols
    (rt_getpid, rt_cli_get_args, rt_platform_name, ...); the fallback must
    stay complete too or entry closures referencing io_runtime externs fail
    with undefined rt_* symbols. Prefer the static archive: the shared
    library's dynamic export list is incomplete (e.g. rt_time_now_unix_micros
    is absent) and static linking avoids an rpath into the build tree."""
    var runtime_dir = config.runtime_path
    if runtime_dir == "":
        runtime_dir = find_runtime_lib_dir()
    if runtime_dir == "" or runtime_dir == "none":
        return []
    var args: [text] = ["-L", runtime_dir]
    if file_exists("{runtime_dir}/libsimple_compiler.a"):
        args.push("-l:libsimple_compiler.a")
    else:
        args.push("-lsimple_compiler")
        args.push("-Wl,-rpath,{runtime_dir}")
    args

fn cc_fallback_object_args(object_files: [text]) -> [text]:
    var args: [text] = []
    for obj in object_files:
        args.push(obj)
    args

fn hosted_cross_cc_required(target: text, os: text, arch: text) -> bool:
    val plan = hosted_c_compiler_plan(target, os, arch)
    plan.requires_cross and plan.supported

fn link_native_cc(object_files: [text], output: text, config: NativeLinkConfig) -> Result:
    # SimpleOS targets must NEVER reach this function. SimpleOS has no
    # fork/exec, so subprocess cc is unavailable — in-process LLD is the
    # only supported path. Reaching here means find_linker() or
    # find_crt_files() failed upstream; surface a hard error rather than
    # silently shelling out (which would ENOSYS on the guest).
    if is_simpleos_target():
        print "[linker-wrapper] ERROR: CC fallback path reached on SimpleOS target."
        print "[linker-wrapper] This usually means find_linker() or find_crt_files() failed."
        print "[linker-wrapper] SimpleOS builds must use in-process LLD — subprocess cc is unavailable."
        return Err("SimpleOS target: cc subprocess fallback unsupported (check sysroot + CRT files)")
    # Fallback: use cc (gcc/clang) for linking.
    # Avoid structured logging here: stage1-generated compilers can crash in
    # the log backend before the fallback command is assembled.
    if object_files.len() == 0:
        return Err("cc fallback requires at least one object file")

    val target = env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? ""
    val os_name = host_os()
    val arch_name = host_arch()
    val compiler_plan = hosted_c_compiler_plan(target, os_name, arch_name)
    if not compiler_plan.supported:
        return Err("hosted C target '" + target + "' is unsupported on '" + arch_name + "-" + os_name + "'")
    val hosted_cross = compiler_plan.requires_cross
    var cc = env_get("SIMPLE_CC") ?? ""
    if cc == "":
        if hosted_cross:
            cc = find_c_compiler()
            if cc == "":
                return Err("required cross C compiler '" + compiler_plan.command + "' was not found")
        else:
            cc = "cc"

    # Keep the fallback complete: native-build links user objects, runtime
    # objects, and a generated entry object. Truncating this list produces a
    # binary with an unresolved main.
    if os_name == "macos" or os_name == "darwin":
        # External libs/frameworks referenced by libsimple_native_all.a (see
        # link_native macos branch). Respect the bootstrap-exported Homebrew
        # prefix so Intel and custom installations resolve zstd.
        # Link ALL object files (user objects + compiled runtime objects +
        # generated entry shim). Passing only obj0 dropped the entry-point
        # object -> "Undefined symbols: _main" on Mach-O.
        var args = cc_fallback_object_args(object_files)
        val brew_prefix = macos_homebrew_prefix(env_get("HOMEBREW_PREFIX") ?? "", host_arch())
        for flag in ["-lc", "-lpthread", "-lm", "-lSystem", "-lSDL2"]:
            args.push(flag)
        for flag in native_all_gnu_support_args(object_files, os_name, brew_prefix):
            args.push(flag)
        for flag in ["-Wl,-dead_strip", "-o", output]:
            args.push(flag)
        val (stdout, stderr, code) = process_run(cc, args)
        if code == 0:
            return Ok(output)
        val err_msg = if stderr != "": stderr else: "Unknown linking error"
        return Err("cc linking failed: {err_msg}")
    elif os_name == "freebsd":
        var args = cc_fallback_object_args(object_files)
        if not config.pie:
            args.push("-no-pie")
        for flag in _cc_fallback_runtime_lib_args(config):
            args.push(flag)
        args.push("-lc")
        args.push("-lpthread")
        args.push("-Wl,--as-needed")
        args.push("-lm")
        args.push("-lSDL2")
        args.push("-Wl,--no-as-needed")
        for flag in native_all_gnu_support_args(object_files, os_name, ""):
            args.push(flag)
        args.push("-Wl,--allow-multiple-definition")
        args.push("-Wl,--gc-sections")
        args.push("-o")
        args.push(output)
        val (stdout, stderr, code) = process_run(cc, args)
        if code == 0:
            return Ok(output)
        val err_msg = if stderr != "": stderr else: "Unknown linking error"
        return Err("cc linking failed: {err_msg}")
    else:
        var args: [text] = []
        if not hosted_cross:
            args.push("-fuse-ld=lld")
        if not config.pie:
            args.push("-no-pie")
        for obj in object_files:
            args.push(obj)
        for flag in _cc_fallback_runtime_lib_args(config):
            args.push(flag)
        args.push("-lc")
        args.push("-lpthread")
        args.push("-ldl")
        for flag in native_all_gnu_support_args(object_files, os_name, ""):
            args.push(flag)
        args.push("-Wl,--as-needed")
        args.push("-lm")
        if not hosted_cross:
            args.push("-lSDL2")
        args.push("-Wl,--no-as-needed")
        args.push("-Wl,--allow-multiple-definition")
        args.push("-Wl,--gc-sections")
        if not hosted_cross:
            args.push("-Wl,--icf=safe")
        args.push("-o")
        args.push(output)
        val (stdout, stderr, code) = process_run(cc, args)
        if code == 0:
            return Ok(output)
        val err_msg = if stderr != "": stderr else: "Unknown linking error"
        return Err("cc linking failed: {err_msg}")

fn _is_mingw_env() -> bool:
    """Check if running under MinGW/MSYS2.
    SIMPLE_LINKER_FLAVOR=msvc overrides MSYSTEM detection so that
    MSVC toolchain is used even inside MSYS2/Git Bash."""
    val linker_flavor = env_get("SIMPLE_LINKER_FLAVOR")
    if linker_flavor == "msvc":
        return false
    val msystem = env_get("MSYSTEM")
    if msystem != "" and msystem != nil:
        return true
    linker_flavor == "gnu"

fn link_native_windows(object_files: [text], output: text, config: NativeLinkConfig) -> Result:
    # MinGW: use gcc driver (Unix-style linking)
    if _is_mingw_env():
        return _link_native_mingw(object_files, output, config)

    # MSVC: delegate to MsvcLinker with proper CRT paths
    return _link_native_msvc(object_files, output, config)

fn _link_native_msvc(object_files: [text], output: text, config: NativeLinkConfig) -> Result:
    """Link using MSVC toolchain (link.exe or lld-link)."""
    var msvc_config: MsvcConfig = MsvcConfig.default()
    msvc_config.debug = config.debug

    # Populate CRT library paths from VS/SDK detection
    val crt_paths = _find_msvc_lib_paths()
    for p in crt_paths:
        msvc_config.lib_paths.push(p)

    # Add user library paths
    for lp in config.library_paths:
        msvc_config.lib_paths.push(lp)

    # Add user libraries
    for lib in config.libraries:
        if lib.ends_with(".lib"):
            msvc_config.libs.push(lib)
        else:
            msvc_config.libs.push("{lib}.lib")

    # Add essential Windows libraries
    val win_libs = ["kernel32.lib", "ws2_32.lib", "bcrypt.lib", "userenv.lib", "ntdll.lib", "advapi32.lib", "d3d11.lib", "dxgi.lib", "SDL2.lib"]
    for wlib in win_libs:
        if not msvc_config.libs.contains(wlib):
            msvc_config.libs.push(wlib)
    for wlib in native_all_msvc_support_libraries(object_files):
        if not msvc_config.libs.contains(wlib):
            msvc_config.libs.push(wlib)

    # Auto-detect runtime library
    var runtime_dir = config.runtime_path
    if runtime_dir == "":
        runtime_dir = find_runtime_lib_dir()
    if runtime_dir != "" and runtime_dir != "none":
        msvc_config.lib_paths.push(runtime_dir)
        msvc_config.libs.push("simple_compiler.lib")

    # Extra flags
    var extra = config.extra_flags
    # Size optimization: remove unreferenced data + fold identical COMDATs
    if not config.debug:
        extra.push("/OPT:REF,ICF")
    # Runtime library and compiled objects may define the same symbol.
    # Missing symbols remain fatal.
    extra.push(msvc_duplicate_symbol_flag())
    msvc_config.extra_args = extra

    if config.verbose:
        print "[linker-wrapper] MSVC linking: {object_files.len()} objects -> {output}"
        print "[linker-wrapper] lib_paths: {msvc_config.lib_paths.join(', ')}"

    val linker = MsvcLinker.new(msvc_config)
    val result = linker.link(output, object_files)
    match result:
        case Ok(_):
            Ok(output)
        case Err(e):
            Err("Windows MSVC linking failed: {e}")

fn _find_msvc_lib_paths() -> [text]:
    """Find MSVC CRT and Windows SDK library paths."""
    use compiler.backend.linker.msvc.{find_msvc_crt_paths}
    find_msvc_crt_paths()
