# SWA ZIP Reader - Read ZIP-based Simple Web Archive files
#
# Wraps ZipArchive to provide SWA-aware access to modules, assets,
# i18n bundles, and metadata from a ZIP-based SWA archive.
#
# SWA ZIP Layout:
#   META-SWA/
#     descriptor.sdn     # Deployment descriptor
#     manifest.sdn       # Package metadata
#   modules/
#     {name}.smf          # Compiled modules
#   public/
#     {path}              # Static assets
#   i18n/
#     messages.sdn        # Default locale
#     messages_{locale}.sdn  # Locale-specific
#
# Usage:
#   val archive = SwaZipArchive.open("myapp.swa")?
#   val descriptor = archive.get_descriptor()
#   val module_data = archive.get_module("app/controllers/home")?
#   val asset_data = archive.get_asset("css/style.css")?
#   val greeting = archive.get_i18n("en")?
#   val modules = archive.list_modules()
#   val assets = archive.list_assets()
#   val locales = archive.list_locales()

use std.archive.{ZipArchive}

# ============================================================================
# SWA ZIP Archive Reader
# ============================================================================

# Reader for ZIP-based Simple Web Archive files.
#
# Provides SWA-aware accessors that map between logical names and
# the well-known ZIP directory structure.
struct SwaZipArchive:
    zip: ZipArchive
    descriptor: text
    manifest: text

impl SwaZipArchive:
    # Open a ZIP-based SWA file for reading.
    #
    # Reads the ZIP archive and extracts the META-SWA metadata files.
    #
    # Args:
    #   path: Path to the .swa file on disk
    #
    # Returns:
    #   Ok(SwaZipArchive) on success, Err with message on failure
    static fn open(path: text) -> Result<SwaZipArchive, text>:
        val zip_result = ZipArchive.open(path)
        if zip_result.is_err():
            return Err(zip_result.unwrap_err())

        val zip = zip_result.unwrap()

        # Read descriptor if present
        var descriptor = ""
        if zip.has_file("META-SWA/descriptor.sdn"):
            val desc_result = zip.read_file("META-SWA/descriptor.sdn")
            if desc_result.is_ok():
                descriptor = bytes_to_text(desc_result.unwrap())

        # Read manifest if present
        var manifest = ""
        if zip.has_file("META-SWA/manifest.sdn"):
            val manifest_result = zip.read_file("META-SWA/manifest.sdn")
            if manifest_result.is_ok():
                manifest = bytes_to_text(manifest_result.unwrap())

        Ok(SwaZipArchive(
            zip: zip,
            descriptor: descriptor,
            manifest: manifest
        ))

    # Read a compiled module by name.
    # Looks up modules/{name}.smf in the archive.
    #
    # Args:
    #   name: Module path (e.g., "app/controllers/home")
    #
    # Returns:
    #   Ok(bytes) containing the SMF data, or Err with message
    fn get_module(name: text) -> Result<[u8], text>:
        val zip_path = "modules/{name}.smf"
        if not self.zip.has_file(zip_path):
            return Err("Module not found in SWA archive: {name}")
        self.zip.read_file(zip_path)

    # Read a static asset by path.
    # Looks up public/{path} in the archive.
    #
    # Args:
    #   path: Relative asset path (e.g., "css/style.css")
    #
    # Returns:
    #   Ok(bytes) containing the asset data, or Err with message
    fn get_asset(path: text) -> Result<[u8], text>:
        val zip_path = "public/{path}"
        if not self.zip.has_file(zip_path):
            return Err("Asset not found in SWA archive: {path}")
        self.zip.read_file(zip_path)

    # Read an i18n resource bundle for a locale.
    # Looks up i18n/messages_{locale}.sdn (or i18n/messages.sdn for default).
    #
    # Args:
    #   locale: Locale code (e.g., "en", "ko", or "" for default)
    #
    # Returns:
    #   Ok(text) containing the i18n content, or Err with message
    fn get_i18n(locale: text) -> Result<text, text>:
        var zip_path = "i18n/messages.sdn"
        if locale.len() > 0:
            zip_path = "i18n/messages_{locale}.sdn"

        if not self.zip.has_file(zip_path):
            return Err("i18n bundle not found: {zip_path}")

        val data_result = self.zip.read_file(zip_path)
        if data_result.is_err():
            return Err(data_result.unwrap_err())

        Ok(bytes_to_text(data_result.unwrap()))

    # Get the deployment descriptor content.
    fn get_descriptor() -> text:
        self.descriptor

    # Get the manifest content.
    fn get_manifest() -> text:
        self.manifest

    # List all module names in the archive.
    # Returns names without the "modules/" prefix and ".smf" suffix.
    fn list_modules() -> [text]:
        var names: [text] = []
        val all_files = self.zip.list_files()
        for file in all_files:
            if file.starts_with("modules/") and file.ends_with(".smf"):
                # Strip "modules/" prefix (8 chars) and ".smf" suffix (4 chars)
                val name = file.slice(8, file.len() - 4)
                if name.len() > 0:
                    names.push(name)
        names

    # List all asset paths in the archive.
    # Returns paths without the "public/" prefix.
    fn list_assets() -> [text]:
        var paths: [text] = []
        val all_files = self.zip.list_files()
        for file in all_files:
            if file.starts_with("public/") and not file.ends_with("/"):
                # Strip "public/" prefix (7 chars)
                val path = file.slice(7, file.len())
                if path.len() > 0:
                    paths.push(path)
        paths

    # List all locale codes available in the archive.
    # Returns locale codes extracted from i18n/messages_{locale}.sdn filenames.
    # The default bundle (messages.sdn) is represented by "" (empty string).
    fn list_locales() -> [text]:
        var locales: [text] = []
        val all_files = self.zip.list_files()
        for file in all_files:
            if file.starts_with("i18n/messages") and file.ends_with(".sdn"):
                if file == "i18n/messages.sdn":
                    locales.push("")
                else:
                    # Extract locale from "i18n/messages_{locale}.sdn"
                    # Strip "i18n/messages_" prefix (14 chars) and ".sdn" suffix (4 chars)
                    val locale = file.slice(14, file.len() - 4)
                    if locale.len() > 0:
                        locales.push(locale)
        locales

    # Check if a module exists.
    fn has_module(name: text) -> bool:
        val zip_path = "modules/{name}.smf"
        self.zip.has_file(zip_path)

    # Check if an asset exists.
    fn has_asset(path: text) -> bool:
        val zip_path = "public/{path}"
        self.zip.has_file(zip_path)

    # Check if an i18n bundle exists for a locale.
    fn has_i18n(locale: text) -> bool:
        var zip_path = "i18n/messages.sdn"
        if locale.len() > 0:
            zip_path = "i18n/messages_{locale}.sdn"
        self.zip.has_file(zip_path)

    # Get total number of entries in the underlying ZIP.
    fn entry_count() -> i64:
        self.zip.file_count()

# ============================================================================
# Helper Functions
# ============================================================================

# Convert bytes to text.
fn bytes_to_text(bytes: [u8]) -> text:
    var chars: [text] = []
    for b in bytes:
        chars.push(char_from_byte(b))
    chars.join("")

# Convert a byte to a single-character text.
fn char_from_byte(b: u8) -> text:
    val c = b as i64
    "{c}"

# ============================================================================
# Exports
# ============================================================================
