# Specialization Constant Registry
#
# Module-level table for gpu_spec_const_i64 late-bound constant folding.
# The key is the constant name; the value overrides the kernel default at emit time.
# Set bindings before calling compile_module_to_opencl_source / CudaBackend compile.
#
# Usage:
#   spec_const_set("tile", 32)
#   val src = OpenClBackend.compile_module_to_opencl_source(module)

var _spec_const_table: Dict<text, i64> = {}

"""Set a specialization-constant binding (name -> value)."""
fn spec_const_set(name: text, value: i64):
    _spec_const_table[name] = value

"""Clear all specialization-constant bindings."""
fn spec_const_clear():
    _spec_const_table = {}

"""
Resolve gpu_spec_const_i64(name, default).
Returns the bound value if set, otherwise the default.
"""
fn spec_const_resolve(name: text, default_val: i64) -> i64:
    val bound = _spec_const_table.get(name)
    if bound.?:
        bound.unwrap()
    else:
        default_val

export spec_const_set
export spec_const_clear
export spec_const_resolve
