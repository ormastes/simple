# Specialization Constant Registry
#
# Module-level table for gpu_spec_const_i64 late-bound constant folding.
# The key is the constant name; the value overrides the kernel default at emit time.
# Set bindings before calling compile_module_to_opencl_source / CudaBackend compile.
#
# Usage:
#   spec_const_set("tile", 32)
#   val src = OpenClBackend.compile_module_to_opencl_source(module)
#
# Note: The registry is a class instance held as a module-level var. Setting
# bindings on the class instance works correctly across modules because
# me-method field mutations persist on the heap object.

class SpecConstRegistry:
    """Registry for specialization constant bindings."""
    table: Dict<text, i64>

    static fn create() -> SpecConstRegistry:
        SpecConstRegistry(table: {})

    me set(name: text, value: i64):
        self.table[name] = value

    me clear():
        self.table = {}

    me resolve(name: text, default_val: i64) -> i64:
        # Use .? to check existence; then direct subscript to get value (no .unwrap() on i64)
        val present = self.table.get(name).?
        if present:
            self.table[name]
        else:
            default_val

var _registry: SpecConstRegistry = SpecConstRegistry.create()

"""Set a specialization-constant binding (name -> value)."""
fn spec_const_set(name: text, value: i64):
    _registry.set(name, value)

"""Clear all specialization-constant bindings."""
fn spec_const_clear():
    _registry.clear()

"""
Resolve gpu_spec_const_i64(name, default).
Returns the bound value if set, otherwise the default.
"""
fn spec_const_resolve(name: text, default_val: i64) -> i64:
    _registry.resolve(name, default_val)

export SpecConstRegistry
export spec_const_set
export spec_const_clear
export spec_const_resolve
