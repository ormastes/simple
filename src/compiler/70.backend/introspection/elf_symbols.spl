# ELF64 symbol table parser
#
# Minimal reader for Stage2==Stage3 convergence verification.
# Parses ELF64 .symtab / .strtab to count symbols whose name matches a substring.

struct ElfSymbol:
    name: text
    addr: u64
    size: u64
    binding: u8
    type_: u8
    section: u16

fn _read_u16_le(buf: [u8], off: i64) -> u32:
    (buf[off] as u32) | ((buf[off + 1] as u32) << 8)

fn _read_u32_le(buf: [u8], off: i64) -> u32:
    (buf[off] as u32)
        | ((buf[off + 1] as u32) << 8)
        | ((buf[off + 2] as u32) << 16)
        | ((buf[off + 3] as u32) << 24)

fn _read_u64_le(buf: [u8], off: i64) -> u64:
    (buf[off] as u64)
        | ((buf[off + 1] as u64) << 8)
        | ((buf[off + 2] as u64) << 16)
        | ((buf[off + 3] as u64) << 24)
        | ((buf[off + 4] as u64) << 32)
        | ((buf[off + 5] as u64) << 40)
        | ((buf[off + 6] as u64) << 48)
        | ((buf[off + 7] as u64) << 56)

fn _read_cstring(buf: [u8], off: i64) -> text:
    var end: i64 = off
    while end < buf.len() and buf[end] != 0:
        end = end + 1
    text.from_utf8(buf[off..end])

fn _is_elf64(buf: [u8]) -> bool:
    if buf.len() < 20:
        return false
    buf[0] == 0x7F and buf[1] == 0x45 and buf[2] == 0x4C and buf[3] == 0x46 and buf[4] == 2

fn parse_elf64_symbols(bytes: [u8]) -> List<ElfSymbol>:
    """Parse .symtab from an ELF64 buffer. Returns [] on any structural error."""
    val out: List<ElfSymbol> = []
    if not _is_elf64(bytes):
        return out

    val shoff = _read_u64_le(bytes, 0x28) as i64
    val shentsize = _read_u16_le(bytes, 0x3A) as i64
    val shnum = _read_u16_le(bytes, 0x3C) as i64

    if shoff <= 0 or shnum <= 0 or shentsize < 64:
        return out

    var symtab_off: i64 = -1
    var symtab_size: i64 = 0
    var symtab_entsize: i64 = 0
    var symtab_link: i64 = -1
    var i: i64 = 0
    while i < shnum:
        val sh = shoff + i * shentsize
        val sh_type = _read_u32_le(bytes, sh + 0x04)
        if sh_type == 2:
            symtab_off = _read_u64_le(bytes, sh + 0x18) as i64
            symtab_size = _read_u64_le(bytes, sh + 0x20) as i64
            symtab_link = _read_u32_le(bytes, sh + 0x28) as i64
            symtab_entsize = _read_u64_le(bytes, sh + 0x38) as i64
            break
        i = i + 1

    if symtab_off < 0 or symtab_entsize < 24 or symtab_link < 0 or symtab_link >= shnum:
        return out

    val strtab_sh = shoff + symtab_link * shentsize
    val strtab_off = _read_u64_le(bytes, strtab_sh + 0x18) as i64

    var sym_i: i64 = 0
    val nsyms = symtab_size / symtab_entsize
    while sym_i < nsyms:
        val sym = symtab_off + sym_i * symtab_entsize
        val name_off = _read_u32_le(bytes, sym) as i64
        val info = bytes[sym + 0x04]
        val other = bytes[sym + 0x05]
        val shndx = _read_u16_le(bytes, sym + 0x06)
        val value = _read_u64_le(bytes, sym + 0x08)
        val size = _read_u64_le(bytes, sym + 0x10)
        val name = _read_cstring(bytes, strtab_off + name_off)
        out.push(ElfSymbol(
            name: name,
            addr: value,
            size: size,
            binding: (info >> 4) as u8,
            type_: (info & 0x0F) as u8,
            section: shndx as u16,
        ))
        sym_i = sym_i + 1
    out

fn count_symbols_matching(bytes: [u8], pattern: text) -> i64:
    """Count symbols whose name contains `pattern`. Used for auto_stub_ counting."""
    val syms = parse_elf64_symbols(bytes)
    var count: i64 = 0
    var i: i64 = 0
    while i < syms.len():
        if syms[i].name.contains(pattern):
            count = count + 1
        i = i + 1
    count
