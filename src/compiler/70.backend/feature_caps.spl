# Target Capability Interface — Re-export Shim
#
# This file re-exports all symbols from the split modules so that existing
# `use compiler.backend.feature_caps.{...}` imports continue to resolve.
#
# Actual implementations live in:
#   feature_caps_types.spl  — abstract types + 64-bit arches (X86, AArch64, RV64)
#   feature_caps_arch32.spl — 32-bit arches (ARM32, RV32, IA-32) + TargetFamilyRow + TargetCapsKind

# --- From feature_caps_types.spl (abstract types + 64-bit architectures) ---
export use compiler.backend.feature_caps_types.{
    TargetIdiom, TargetCaps,
    TargetFeatureClass,
    idiom_feature_class,
    InstructionCost,
    instruction_cost_new, instruction_cost_unsupported, instruction_cost_from_latency,
    preferred_lane_count_for_bits,
    X86Caps, x86_caps_from_target, x86_caps_default,
    x86_supports_feature_class, x86_instruction_cost, preferred_lane_count_x86,
    Aarch64Caps, aarch64_caps_from_target, aarch64_caps_default,
    aarch64_supports_feature_class, aarch64_instruction_cost, preferred_lane_count_aarch64,
    Rv64Caps, rv64_caps_from_target, rv64_caps_default,
    rv64_supports_feature_class, rv64_instruction_cost, preferred_lane_count_rv64
}

# --- From feature_caps_arch32.spl (32-bit architectures + matrix + dispatch) ---
export use compiler.backend.feature_caps_arch32.{
    ArmCaps, arm_caps_from_target, arm_caps_default,
    arm_supports_feature_class, arm_instruction_cost, preferred_lane_count_arm,
    Rv32Caps, rv32_caps_from_target, rv32_caps_default,
    rv32_supports_feature_class, rv32_instruction_cost, preferred_lane_count_rv32,
    X86_32Caps, x86_32_caps_from_target, x86_32_caps_default,
    x86_32_supports_feature_class, preferred_lane_count_x86_32,
    TargetFamilyRow,
    target_family_row_x86_64, target_family_row_x86_32,
    target_family_row_aarch64, target_family_row_arm32,
    target_family_row_rv64, target_family_row_rv32,
    all_target_family_rows,
    target_family_row_supports_class, target_family_row_disabled_reason,
    TargetCapsKind,
    caps_kind_supports, caps_kind_cost,
    caps_kind_preferred_vector_width_bits, caps_kind_target_name,
    caps_kind_from_triple, caps_kind_for_family
}
