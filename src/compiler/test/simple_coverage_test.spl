# Simple Branch Coverage Tests
#
# Comprehensive tests to maximize branch coverage in the Simple interpreter
# and core language features.


describe "Boolean operations":
    it "tests true":
        val x = true
        expect(x).to_equal(true)

    it "tests false":
        val x = false
        expect(x).to_equal(false)

    it "tests and operator - both true":
        expect(true and true).to_equal(true)

    it "tests and operator - one false":
        expect(true and false).to_equal(false)

    it "tests or operator - one true":
        expect(true or false).to_equal(true)

    it "tests or operator - both false":
        expect(false or false).to_equal(false)

    it "tests not operator":
        expect(not false).to_equal(true)
        expect(not true).to_equal(false)

    it "tests complex boolean expression":
        expect(true and (false or true)).to_equal(true)
        expect((true or false) and (true and true)).to_equal(true)

describe "Integer operations":
    it "tests addition":
        expect(1 + 2).to_equal(3)

    it "tests subtraction":
        expect(5 - 3).to_equal(2)

    it "tests multiplication":
        expect(4 * 3).to_equal(12)

    it "tests division":
        expect(10 / 2).to_equal(5)

    it "tests modulo":
        expect(10 % 3).to_equal(1)

    it "tests negative numbers":
        expect(-5 + 3).to_equal(-2)

    it "tests comparison - equal":
        val result = 5 == 5
        expect(result).to_equal(true)

    it "tests comparison - not equal":
        val result = 5 != 3
        expect(result).to_equal(true)

    it "tests comparison - less than":
        val result = 3 < 5
        expect(result).to_equal(true)

    it "tests comparison - greater than":
        val result = 5 > 3
        expect(result).to_equal(true)

    it "tests comparison - less than or equal":
        val equal_result = 5 <= 5
        val lower_result = 3 <= 5
        expect(equal_result).to_equal(true)
        expect(lower_result).to_equal(true)

    it "tests comparison - greater than or equal":
        val equal_result = 5 >= 5
        val higher_result = 5 >= 3
        expect(equal_result).to_equal(true)
        expect(higher_result).to_equal(true)

    it "tests integer overflow handling":
        val big = 1000000
        expect(big * 2).to_equal(2000000)

describe "String operations":
    it "tests string equality":
        expect("hello").to_equal("hello")

    it "tests string inequality":
        val result = "hello" != "world"
        expect(result).to_equal(true)

    it "tests string concatenation":
        val s = "hello" + " world"
        expect(s).to_equal("hello world")

    it "tests string length":
        expect("hello".len()).to_equal(5)

    it "tests empty string":
        val s = ""
        expect(s.len()).to_equal(0)
        expect(s.is_empty()).to_equal(true)

    it "tests string interpolation":
        val name = "Alice"
        val greeting = "Hello, {name}!"
        expect(greeting).to_equal("Hello, Alice!")

    it "tests string with numbers":
        val num = 42
        val msg = "The answer is {num}"
        expect(msg).to_equal("The answer is 42")

    it "tests string with newline escape":
        val text = "line1\nline2"
        expect(text.contains("line1")).to_equal(true)
        expect(text.contains("line2")).to_equal(true)

describe "Option type operations":
    it "tests Some construction":
        val opt = Some(42)
        expect(opt.is_some()).to_equal(true)
        expect(opt.is_none()).to_equal(false)

    it "tests None construction":
        val opt: Option<i32> = nil
        expect(opt.is_some()).to_equal(false)
        expect(opt.is_none()).to_equal(true)

    it "tests unwrap on Some":
        val opt = Some(42)
        expect(opt.unwrap()).to_equal(42)

    it "tests unwrap_or on Some":
        val opt = Some(42)
        expect(opt.unwrap_or(99)).to_equal(42)

    it "tests unwrap_or on None":
        val opt: Option<i32> = nil
        expect(opt.unwrap_or(99)).to_equal(99)

    it "tests map on Some":
        val opt = Some(5)
        val doubled = opt.map(\x: x * 2)
        expect(doubled.unwrap()).to_equal(10)

    it "tests map on None":
        val opt: Option<i32> = nil
        val doubled = opt.map(\x: x * 2)
        expect(doubled.is_none()).to_equal(true)

describe "Result type operations":
    it "tests Ok construction":
        val res: Result<i32, text> = Ok(42)
        expect(res.is_ok()).to_equal(true)
        expect(res.is_err()).to_equal(false)

    it "tests Err construction":
        val res: Result<i32, text> = Err("error")
        expect(res.is_ok()).to_equal(false)
        expect(res.is_err()).to_equal(true)

    it "tests unwrap_or on Ok":
        val res: Result<i32, text> = Ok(42)
        expect(res.unwrap_or(99)).to_equal(42)

    it "tests unwrap_or on Err":
        val res: Result<i32, text> = Err("error")
        expect(res.unwrap_or(99)).to_equal(99)

describe "List operations":
    it "tests empty list literal":
        val lst: [i32] = []
        expect(lst.len()).to_equal(0)
        expect(lst.is_empty()).to_equal(true)

    it "tests list literal with elements":
        val lst = [1, 2, 3]
        expect(lst.len()).to_equal(3)
        expect(lst.is_empty()).to_equal(false)

    it "tests list indexing":
        val lst = [10, 20, 30]
        expect(lst[0]).to_equal(10)
        expect(lst[1]).to_equal(20)
        expect(lst[2]).to_equal(30)

    it "tests list contains":
        val lst = [10, 20]
        expect(lst.contains(&10)).to_equal(true)
        expect(lst.contains(&99)).to_equal(false)

    it "tests list map":
        val lst = [1, 2, 3]
        val doubled = lst.map(\x: x * 2)
        expect(doubled[0]).to_equal(2)
        expect(doubled[1]).to_equal(4)
        expect(doubled[2]).to_equal(6)

    it "tests list filter":
        val lst = [1, 2, 3, 4]
        val evens = lst.filter(\x: x % 2 == 0)
        expect(evens[0]).to_equal(2)
        expect(evens.len()).to_equal(2)
        expect(evens[1]).to_equal(4)

describe "Control flow":
    it "tests if-else with true condition":
        val x = 5
        val result = if x > 0:
            "positive"
        else:
            "negative"
        expect(result).to_equal("positive")

    it "tests if-else with false condition":
        val x = -5
        val result = if x > 0:
            "positive"
        else:
            "negative"
        expect(result).to_equal("negative")

    it "tests nested if-else":
        val x = 5
        val result = if x > 10:
            "big"
        elif x > 0:
            "small"
        else:
            "negative"
        expect(result).to_equal("small")

    it "tests match with literal":
        val x = 2
        val result = match x:
            1 => "one"
            2 => "two"
            _ => "other"
        expect(result).to_equal("two")

    it "tests match with default":
        val x = 99
        val result = match x:
            1 => "one"
            2 => "two"
            _ => "other"
        expect(result).to_equal("other")

describe "Pattern matching":
    it "tests match on Option Some":
        val opt = Some(42)
        val result = match opt:
            Some(x) => x * 2
            nil => 0
        expect(result).to_equal(84)

    it "tests match on Option None":
        val opt: Option<i32> = nil
        val result = match opt:
            Some(x) => x * 2
            nil => 0
        expect(result).to_equal(0)

    it "tests match on Result Ok":
        val res: Result<i32, text> = Ok(42)
        val result = match res:
            Ok(x) => x
            Err(_) => 0
        expect(result).to_equal(42)

    it "tests match on Result Err":
        val res: Result<i32, text> = Err("error")
        val result = match res:
            Ok(x) => x
            Err(_) => 0
        expect(result).to_equal(0)

describe "Loops":
    it "tests for loop over range":
        var sum = 0
        for i in 0..5:
            sum = sum + i
        expect(sum).to_equal(10)  # 0+1+2+3+4

    it "tests for loop over list":
        val lst = [10, 20, 30]
        var sum = 0
        for x in lst:
            sum = sum + x
        expect(sum).to_equal(60)

    it "tests while loop":
        var count = 0
        var sum = 0
        while count < 5:
            sum = sum + count
            count = count + 1
        expect(sum).to_equal(10)

describe "Functions and lambdas":
    it "tests simple function call":
        fn add(a: i32, b: i32) -> i32:
            a + b
        expect(add(3, 4)).to_equal(7)

    it "tests lambda expression":
        val double = \x: x * 2
        expect(double(5)).to_equal(10)

    it "tests lambda with multiple arguments":
        val add = \a, b: a + b
        expect(add(3, 4)).to_equal(7)

    it "tests higher-order function":
        fn apply(f: fn(i32) -> i32, x: i32) -> i32:
            f(x)
        val double = \x: x * 2
        expect(apply(double, 5)).to_equal(10)

describe "Ranges":
    it "tests exclusive range":
        val r = 0..5
        var count = 0
        for _ in r:
            count = count + 1
        expect(count).to_equal(5)

    it "tests inclusive range":
        val r = 0..=5
        var count = 0
        for _ in r:
            count = count + 1
        expect(count).to_equal(6)

describe "Array literals":
    it "tests array literal creation":
        val arr = [1, 2, 3, 4, 5]
        expect(arr.len()).to_equal(5)

    it "tests array indexing":
        val arr = [10, 20, 30]
        expect(arr[0]).to_equal(10)
        expect(arr[1]).to_equal(20)
        expect(arr[2]).to_equal(30)

    it "tests array negative indexing":
        val arr = [10, 20, 30]
        expect(arr[-1]).to_equal(30)
        expect(arr[-2]).to_equal(20)

describe "Type conversions":
    it "tests int to string conversion":
        val num = 42
        val s = num.to_string()
        expect(s).to_equal("42")

    it "tests negative int to string":
        val num = -42
        val s = num.to_string()
        expect(s).to_equal("-42")

describe "Edge cases":
    it "tests empty string operations":
        val s = ""
        expect(s.len()).to_equal(0)
        expect(s + "hello").to_equal("hello")

    it "tests zero in arithmetic":
        expect(0 + 5).to_equal(5)
        expect(5 * 0).to_equal(0)

    it "tests empty list operations":
        val lst: [i32] = []
        expect(lst.len()).to_equal(0)
        expect(lst.is_empty()).to_equal(true)

    it "tests boolean short-circuit evaluation - and":
        var called = false
        fn side_effect() -> bool:
            called = true
            true
        val result = false and side_effect()
        expect(result).to_equal(false)
        expect(called).to_equal(false)

    it "tests boolean short-circuit evaluation - or":
        var called = false
        fn side_effect() -> bool:
            called = true
            false
        val result = true or side_effect()
        expect(result).to_equal(true)
        expect(called).to_equal(false)
