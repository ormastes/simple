# Monomorphization Cache
#
# Caches specialized function/struct/class definitions by specialization key.
# Content-based keys derived from definition hash + type arguments + mtime.
# Supports LRU eviction and optional disk persistence.
#
# Port of rust/compiler/src/monomorphize/cache.rs (100+ lines)

use std.common.sdn.value.{SdnValue}
use std.common.sdn.parser (parse)

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

fn mono_cache_file_read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn mono_cache_parse_file(path: text) -> Result<SdnValue, text>:
    parse(mono_cache_file_read_text(path))

fn mono_cache_render_value(value: SdnValue, indent: i64) -> text:
    match value:
        case Null:
            "null"
        case Bool(b):
            if b: "true" else: "false"
        case Int(i):
            i.to_text()
        case Float(f):
            f.to_text()
        case String(s):
            "\"" + s + "\""
        case Array(items):
            var parts: [text] = []
            for item in items:
                parts = parts.push(mono_cache_render_value(item, indent + 2))
            "[" + parts.join(", ") + "]"
        case Dict(entries):
            var parts: [text] = []
            for key in entries.keys():
                parts = parts.push(key + ": " + mono_cache_render_value(entries[key], indent + 2))
            "{ " + parts.join(", ") + " }"
        case Table(_, _):
            "[]"

# ============================================================================
# Configuration
# ============================================================================

struct MonoCacheConfig:
    max_entries: i64
    validate_timestamps: bool
    persist_to_disk: bool
    cache_dir: text?

impl MonoCacheConfig:
    static fn default_config() -> MonoCacheConfig:
        MonoCacheConfig(max_entries: 10000, validate_timestamps: true,
                        persist_to_disk: false, cache_dir: nil)

    static fn memory_only() -> MonoCacheConfig:
        MonoCacheConfig(max_entries: 10000, validate_timestamps: true,
                        persist_to_disk: false, cache_dir: nil)

    static fn persistent(cache_dir: text) -> MonoCacheConfig:
        MonoCacheConfig(max_entries: 50000, validate_timestamps: true,
                        persist_to_disk: true, cache_dir: Some(cache_dir))

# ============================================================================
# Statistics
# ============================================================================

struct MonoCacheStats:
    hits: i64
    misses: i64
    evictions: i64
    invalidations: i64
    function_entries: i64
    struct_entries: i64
    class_entries: i64

impl MonoCacheStats:
    static fn empty() -> MonoCacheStats:
        MonoCacheStats(hits: 0, misses: 0, evictions: 0, invalidations: 0,
                       function_entries: 0, struct_entries: 0, class_entries: 0)

    fn hit_ratio() -> f64:
        val total = self.hits + self.misses
        if total == 0: 0.0
        else: self.hits.to_f64() / total.to_f64()

    fn total_entries() -> i64:
        self.function_entries + self.struct_entries + self.class_entries

# ============================================================================
# Cache Entry
# ============================================================================

struct CacheEntry:
    key: text
    value: Any
    last_access: i64
    content_hash: i64

# ============================================================================
# Mono Cache
# ============================================================================

class MonoCache:
    """Cache for monomorphization results."""
    config: MonoCacheConfig
    entries: {text: CacheEntry}
    stats: MonoCacheStats
    oldest_key: text

impl MonoCache:
    static fn create(config: MonoCacheConfig) -> MonoCache:
        MonoCache(config: config, entries: {}, stats: MonoCacheStats.empty(), oldest_key: "")

    me lookup(key: text) -> Any?:
        if self.entries.has(key):
            self.stats.hits = self.stats.hits + 1
            Some(self.entries[key].value)
        else:
            self.stats.misses = self.stats.misses + 1
            nil

    me store(key: text, value: Any, content_hash: i64):
        if self.entries.len() >= self.config.max_entries:
            self.evict_oldest()
        val now = self.stats.hits + self.stats.misses + self.stats.evictions + (self.entries.len() as i64) + 1
        self.entries[key] = CacheEntry(key: key, value: value,
            last_access: now, content_hash: content_hash)
        # Track oldest: if cache was empty or this is older than current oldest
        if self.oldest_key == "" or not self.entries.has(self.oldest_key):
            self.oldest_key = key
        else:
            if now < self.entries[self.oldest_key].last_access:
                self.oldest_key = key

    me evict_oldest():
        """Evict the least recently accessed entry (O(1) amortized)."""
        if not self.entries.?:
            return
        # Use tracked oldest_key for O(1) eviction
        if self.oldest_key != "" and self.entries.has(self.oldest_key):
            self.entries = self.entries.remove(self.oldest_key)
            self.stats.evictions = self.stats.evictions + 1
        else:
            # Fallback: scan for oldest (only if tracked key was invalidated)
            var scan_key = ""
            var scan_time: i64 = 9223372036854775807
            # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
            for k in self.entries.keys():
                val entry = self.entries[k]
                if entry.last_access < scan_time:
                    scan_time = entry.last_access
                    scan_key = k
            if scan_key.?:
                self.entries = self.entries.remove(scan_key)
                self.stats.evictions = self.stats.evictions + 1
        # Find new oldest after eviction
        var new_oldest_key = ""
        var new_oldest_time: i64 = 9223372036854775807
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for k in self.entries.keys():
            val entry = self.entries[k]
            if entry.last_access < new_oldest_time:
                new_oldest_time = entry.last_access
                new_oldest_key = k
        self.oldest_key = new_oldest_key

    me clear():
        self.entries = {}

    fn get_stats() -> MonoCacheStats:
        self.stats

    me save_to_disk(cache_dir: text):
        """Serialize current cache entries to disk as SDN."""
        if not self.config.persist_to_disk:
            return

        rt_mkdir_p(cache_dir)

        var sdn_entries: [SdnValue] = []
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for key in self.entries.keys():
            val entry = self.entries[key]
            val entry_dict = SdnValue.Dict({
                "key": SdnValue.String(entry.key),
                "content_hash": SdnValue.Int(entry.content_hash),
                "last_access": SdnValue.Int(entry.last_access)
            })
            sdn_entries = sdn_entries.push(entry_dict)

        val sdn_doc = SdnValue.Dict({
            "max_entries": SdnValue.Int(self.config.max_entries),
            "entry_count": SdnValue.Int(self.entries.len()),
            "entries": SdnValue.Array(sdn_entries)
        })

        val sdn_text = mono_cache_render_value(sdn_doc, 0)
        val index_path = "{cache_dir}/mono_cache_index.sdn"
        rt_file_write_text(index_path, sdn_text)

    static fn load_from_disk(cache_dir: text) -> MonoCache:
        """Load a persistent mono cache from disk."""
        val config = MonoCacheConfig.persistent(cache_dir)
        val index_path = "{cache_dir}/mono_cache_index.sdn"

        if not rt_file_exists(index_path):
            return MonoCache.create(config)

        match mono_cache_parse_file(index_path):
            case Ok(sdn_value):
                var cache = MonoCache.create(config)

                val entries_val = sdn_value.get("entries")
                if val Some(entries_node) = entries_val:
                    val arr = entries_node.as_array()
                    if val Some(items) = arr:
                        for item in items:
                            var key = ""
                            var content_hash: i64 = 0
                            var last_access: i64 = 0

                            val k = item.get("key")
                            if val Some(key_node) = k:
                                val ks = key_node.as_str()
                                if val Some(key_text) = ks:
                                    key = key_text

                            val h = item.get("content_hash")
                            if val Some(hash_node) = h:
                                val hi = hash_node.as_i64()
                                if val Some(hash_value) = hi:
                                    content_hash = hash_value

                            val la = item.get("last_access")
                            if val Some(access_node) = la:
                                val lai = access_node.as_i64()
                                if val Some(access_value) = lai:
                                    last_access = access_value

                            if key != "":
                                cache.entries[key] = CacheEntry(
                                    key: key, value: nil,
                                    last_access: last_access,
                                    content_hash: content_hash)

                cache
            case Err(_):
                MonoCache.create(config)
