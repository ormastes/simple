        specialized.classes.push(c.clone())

        if not metadata.classes.has(base_name):
            metadata.classes[base_name] = GenericClassMeta.new(base_name, [])

        val meta: GenericClassMeta = metadata.classes[base_name]

        # Extract type args
        var type_args: [ConcreteType] = []
        for param in c.type_bindings.keys():
            val ast_type = c.type_bindings[param]
            type_args = type_args.push(ConcreteType.Named(ast_type.to_string()))

        # Convert bindings
        var concrete_bindings: {text: ConcreteType} = {}
