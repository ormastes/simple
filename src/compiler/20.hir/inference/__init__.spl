# Shared Type Inference Module
#
# Shared by compiler, loader, and linker for consistent type inference
# across compile-time, load-time, and link-time.
#
# See: doc/design/shared_type_inference_architecture.md

export types.*
export unify.*
export infer.*
export constraints.*
export deferred.*
export serialize.*

# Re-exported from constraints.spl
export ConstraintSet

# Re-exported from deferred.spl
export DeferredStore

# Re-exported from infer.spl
export InferenceEngine, DeferredHint

# Re-exported from serialize.spl
export hints_to_sdn, hints_from_sdn
export type_to_text, type_from_text, constraints_to_text

# Re-exported from types.spl
export Type, TypeVarId, SkolemId, DeferredTypeId
export Field, Variant, Constraint, TypeScheme, TypeEnv
export UnifyError, InferError

# Re-exported from unify.spl
export Unifier
