# HIR Lowering - Statement Lowering
#
# This module handles lowering of statements from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.expressions.*

extern fn rt_enum_payload(value: StmtKind) -> Expr
extern fn rt_enum_discriminant(value: StmtKind) -> i64

fn hir_stmt_kind_disc(k: StmtKind) -> i64:
    rt_enum_discriminant(k)

# Statement Lowering
# ============================================================================

impl HirLowering:
    # Nested-field-access support (native --entry path bug -- see
    # struct_field_types_by_name / local_struct_types doc comments in
    # types.spl). `val/var x = StructName(...)` is the only local-declared-
    # type shape this lane can recover without a full inference pass: the
    # callee name is a compile-time-static struct name IF it is already
    # registered in struct_field_types_by_name (structs are lowered in a
    # up-front pass before function bodies, so this dict is fully populated
    # by the time any function body -- and thus any Let -- is lowered).
    # Deliberately narrow: only a bare `Ident(...)` call callee: qualified
    # constructors, method calls, etc. are left untracked (Field-expr
    # lowering then falls back to its pre-existing untyped i64 default,
    # same as today -- this is additive, never a regression).
    me try_register_local_struct_type(sym: SymbolId, init_expr: Expr):
        match init_expr.kind:
            case ExprKind.Call(callee, call_args):
                match callee.kind:
                    case ExprKind.Ident(callee_name):
                        if self.struct_field_types_by_name.has(callee_name):
                            self.local_struct_types[sym.id] = callee_name
                            # Struct field type ANNOTATIONS are unreliable here
                            # (`arr: [i64]` parses to TypeKind.Infer on this
                            # path, both parser- and HIR-level -- a documented
                            # pre-existing limitation, see bug #156's
                            # method_calls_literals.spl comment). CallArg's
                            # has_name/name are ALSO unreliable (observed false
                            # /empty for every arg regardless of source syntax)
                            # -- MIR's own lower_struct_construct has the same
                            # gap and falls back to POSITIONAL order against
                            # the struct's declared field order, so mirror that
                            # here: learn each field's shape from the
                            # CONSTRUCTION SITE argument at its position. An
                            # ArrayLit argument means the field is array-typed.
                            # All instances of a struct share layout, so
                            # recording this once (first construction site
                            # seen) is globally valid for the struct name.
                            if self.struct_field_order_by_name.has(callee_name):
                                val field_order = self.struct_field_order_by_name[callee_name]
                                var known_fields = self.struct_field_types_by_name[callee_name]
                                var arg_i = 0
                                while arg_i < call_args.len() and arg_i < field_order.len():
                                    val field_name_at_i = field_order[arg_i]
                                    match call_args[arg_i].value.kind:
                                        case ExprKind.ArrayLit(_):
                                            val elem_i64 = HirType(kind: HirTypeKind.Int(64, true), span: call_args[arg_i].span)
                                            known_fields[field_name_at_i] = HirType(kind: HirTypeKind.Array(elem_i64, nil), span: call_args[arg_i].span)
                                        case _: ()
                                    arg_i = arg_i + 1
                                self.struct_field_types_by_name[callee_name] = known_fields
                    case _: ()
            case _: ()

    # Tuple analogue of try_register_local_struct_type (see local_tuple_types
    # doc comment in types.spl). Only handles the simple `val/var t =
    # (lit0, lit1, ...)` shape: element types are read straight off each
    # literal element's own AST kind (there is no general inference pass on
    # this path). A non-literal element (a call, a variable, ...) records nil
    # for that slot -- callers fall back to the pre-existing untyped i64
    # default, same as if this tracking did not exist (additive only).
    me try_register_local_tuple_type(sym: SymbolId, init_expr: Expr):
        match init_expr.kind:
            case ExprKind.TupleLit(elements):
                var elem_types: [HirType] = []
                for elem in elements:
                    val elem_hir_type = match elem.kind:
                        case ExprKind.IntLit(_):
                            Some(HirType(kind: HirTypeKind.Int(64, true), span: elem.span))
                        case ExprKind.FloatLit(_):
                            Some(HirType(kind: HirTypeKind.Float(64), span: elem.span))
                        case ExprKind.StringLit(_, _):
                            Some(HirType(kind: HirTypeKind.Str, span: elem.span))
                        case ExprKind.BoolLit(_):
                            Some(HirType(kind: HirTypeKind.Bool, span: elem.span))
                        case _:
                            nil
                    if val known_elem_type = elem_hir_type:
                        elem_types = elem_types.push(known_elem_type)
                    else:
                        elem_types = elem_types.push(HirType(kind: HirTypeKind.Int(64, true), span: elem.span))
                self.local_tuple_types[sym.id] = elem_types
            case _: ()

    fn lower_hir_assign_op(assign_op: AssignOp) -> HirAssignOp:
        match assign_op:
            case AssignOp.Add: HirAssignOp.Add
            case AssignOp.Sub: HirAssignOp.Sub
            case AssignOp.Mul: HirAssignOp.Mul
            case AssignOp.Div: HirAssignOp.Div
            case AssignOp.Mod: HirAssignOp.Mod

    me lower_hir_assign_op_opt(op: AssignOp?) -> HirAssignOp?:
        if op.?:
            Some(self.lower_hir_assign_op(op.unwrap()))
        else:
            nil

    me lower_hir_with_items(items: [WithItem]) -> [HirWithItem]:
        var result: [HirWithItem] = []
        for item in items:
            val hir_context = self.lower_hir_expr(item.context_expr)
            val hir_target: SymbolId? = if item.target.?:
                val symbol = self.symbols.define(item.target ?? "", SymbolKind.Variable, nil, item.span, false, false, nil)
                Some(symbol)
            else:
                nil
            val hir_item = HirWithItem(
                context_expr: hir_context,
                target: hir_target,
                span: item.span
            )
            result = result.push(hir_item)
        result

    # Lower a single source statement to zero-or-more HIR statements. Almost
    # every statement is 1:1 -- the exception is literal-tuple destructuring
    # (`val (a, b) = (x, y)`), which the parser encodes as a single
    # StmtKind.Val whose `name` is the literal text "(a,b)" (see
    # parse_tuple_destructure_val in parser_stmts.spl). That single source
    # statement desugars into N ordinary `Let` bindings here, so callers that
    # iterate over a block's statements must call this instead of
    # `lower_hir_stmt` and splice the results (see lower_hir_block /
    # lower_hir_block_unit in expressions.spl).
    me lower_hir_stmt_multi(s: Stmt) -> [HirStmt]:
        val stmt_kind_value: StmtKind = s.kind
        val sk_disc: i64 = hir_stmt_kind_disc(stmt_kind_value)
        val sk_dummy: Expr = Expr(kind: ExprKind.NilLit, span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Val("", nil, sk_dummy)):
            val v_name: text = match stmt_kind_value:
                case StmtKind.Val(vname, _, _):
                    vname
                case _:
                    ""
            if v_name.len() > 1 and v_name[0:1] == "(":
                val v_init = match stmt_kind_value:
                    case StmtKind.Val(_, _, vinit):
                        vinit
                    case _:
                        sk_dummy
                return self.lower_hir_tuple_destructure_val(v_name, v_init, s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Var("", nil, nil)):
            val vr_name = match stmt_kind_value:
                case StmtKind.Var(vrname, _, _):
                    vrname
                case _:
                    ""
            if vr_name.len() > 1 and vr_name[0:1] == "(":
                val vr_init = match stmt_kind_value:
                    case StmtKind.Var(_, _, vrinit):
                        vrinit
                    case _:
                        nil
                val vr_init_expr = vr_init ?? sk_dummy
                return self.lower_hir_tuple_destructure_var(vr_name, vr_init_expr, s.span)
        [self.lower_hir_stmt(s)]

    # Desugar `val (a, b, ...) = <literal tuple expr>` into N `Let` bindings,
    # evaluating each element expression exactly once, left to right. Only a
    # LITERAL tuple initializer (`ExprKind.TupleLit`) is supported -- anything
    # else (a variable, a function call returning a tuple, ...) is a loud HIR
    # error so a non-literal initializer never silently produces a wrong
    # answer.
    me lower_hir_tuple_destructure_val(joined_name: text, init: Expr, span: Span) -> [HirStmt]:
        val inner = joined_name[1:joined_name.len() - 1]
        val names = inner.split(",")
        match init.kind:
            case ExprKind.TupleLit(elements):
                if elements.len() != names.len():
                    # Ordinary lowering errors are fatal by default.
                    self.error("tuple destructure arity mismatch for `val (" + inner + ")`: " + names.len().to_text() + " name(s) on the left vs " + elements.len().to_text() + " value(s) on the right", span)
                    [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
                else:
                    var result: [HirStmt] = []
                    var i = 0
                    while i < names.len():
                        val nm = names[i]
                        val hir_init = self.lower_hir_expr(elements[i])
                        val symbol = self.symbols.define(nm, SymbolKind.Variable, nil, span, false, false, nil)
                        result = result.push(HirStmt(kind: HirStmtKind.Let(symbol, nil, hir_init), span: span))
                        i = i + 1
                    result
            case _:
                # Non-literal initializer (variable, function call returning a
                # tuple, e.g. `val (out, err, code) = rt_process_run(...)`):
                # general desugar via lower_tuple_destructure below — binds a
                # temp to the tuple value ONCE, then binds each name to
                # temp[i] (rt_array_get; tuples are rt_arrays at runtime).
                # Correct, not silent-wrong: element order/evaluation match
                # the interpreter's eval_tuple_destructure.
                [self.lower_tuple_destructure(joined_name, self.lower_hir_expr(init), false, span)]

    # Desugar `var (a, b, ...) = <literal tuple expr>` into N mutable `Let`
    # bindings, mirroring lower_hir_tuple_destructure_val above but marking
    # each symbol mutable so a later `a = 5` reassignment is legal (a `val`
    # binding would loud-fail reassignment instead).
    me lower_hir_tuple_destructure_var(joined_name: text, init: Expr, span: Span) -> [HirStmt]:
        val inner = joined_name[1:joined_name.len() - 1]
        val names = inner.split(",")
        match init.kind:
            case ExprKind.TupleLit(elements):
                if elements.len() != names.len():
                    # Ordinary lowering errors are fatal by default.
                    self.error("tuple destructure arity mismatch for `var (" + inner + ")`: " + names.len().to_text() + " name(s) on the left vs " + elements.len().to_text() + " value(s) on the right", span)
                    [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
                else:
                    var result: [HirStmt] = []
                    var i = 0
                    while i < names.len():
                        val nm = names[i]
                        val hir_init = self.lower_hir_expr(elements[i])
                        val symbol = self.symbols.define(nm, SymbolKind.Variable, nil, span, false, true, nil)
                        result = result.push(HirStmt(kind: HirStmtKind.Let(symbol, nil, hir_init), span: span))
                        i = i + 1
                    result
            case _:
                # Non-literal initializer: general desugar (see the val
                # variant above) with mutable bindings.
                [self.lower_tuple_destructure(joined_name, self.lower_hir_expr(init), true, span)]

    # General tuple destructure for NON-LITERAL initializers: `val/var
    # (a, b, c) = expr` where expr is a variable or a call returning a tuple
    # (e.g. `val (out, err, code) = rt_process_run(...)`). Binds a temp to
    # the init tuple ONCE (evaluating the RHS exactly once), then binds each
    # name to temp[i]. Tuples are rt_arrays at runtime (rt_tuple_new ->
    # rt_array_new), and under SIMPLE_BOOTSTRAP an Index lowers to
    # rt_array_get, so temp[i] extracts element i. Emitted as a Block; MIR
    # keys local_map by symbol_id function-wide (no scope dealloc), so the
    # bindings stay visible to later statements. Literal initializers take
    # the per-element fast path in lower_hir_tuple_destructure_val/var above.
    # Element types: resolved from local_tuple_types (see types.spl doc
    # comment) when `hir_init` is a plain variable bound to a tracked tuple
    # literal (`val t = (1, "hi"); val (a, b) = t`); nil (i64 default,
    # unchanged pre-existing behavior) otherwise -- e.g. a call result like
    # `rt_process_run(...)`, which this lane cannot statically type. Without
    # this, every element previously defaulted to i64 downstream, silently
    # printing garbage for a mixed-type tuple's non-i64 elements (a text
    # field read back as raw i64 bits).
    # Isolated single-arm extraction helpers for lower_tuple_destructure's
    # call-init typing (same idiom as lower_type / lower_hir_stmt's
    # disc-dispatch): a NESTED match expression mis-propagates its payload on
    # the seed (observed: callee SymbolId.id read as 0 for every destructure),
    # and `var` mutation inside nested match arms is dropped outright (the
    # arm_get_body env-storage landmine). One match per function boundary
    # with an explicit return per arm is the reliable shape.
    fn td_callee_expr_name(callee: HirExpr) -> text:
        match callee.kind:
            case HirExprKind.Var(td_cs):
                return self.symbols.symbol_display_name(td_cs, "")
            case HirExprKind.NamedVar(_, td_cs2_name):
                return td_cs2_name
            case _:
                return ""

    fn td_init_callee_name(hir_init: HirExpr) -> text:
        match hir_init.kind:
            case HirExprKind.Call(td_callee, _, _):
                return self.td_callee_expr_name(td_callee)
            case _:
                return ""

    me lower_tuple_destructure(name: text, hir_init: HirExpr, is_mut: bool, span: Span) -> HirStmt:
        val inner = name.slice(1, name.len() - 1)
        val parts = inner.split(",")
        var stmts: [HirStmt] = []
        val tmp_sym = self.symbols.define("__tuple_destr", SymbolKind.Variable, nil, span, false, false, nil)
        stmts = stmts.push(HirStmt(kind: HirStmtKind.Let(tmp_sym, nil, hir_init), span: span))
        var td_elem_types: [HirType] = []
        var td_base_sym: SymbolId? = nil
        match hir_init.kind:
            case HirExprKind.Var(td_sym):
                td_base_sym = td_sym
            case HirExprKind.NamedVar(td_sym2, _):
                td_base_sym = td_sym2
            case _: ()
        if val td_bs = td_base_sym:
            if self.local_tuple_types.has(td_bs.id):
                td_elem_types = self.local_tuple_types[td_bs.id]
        # Call init: `val (a, b, c) = f(...)` where f's declared return type
        # is a tuple. Without this, every destructured element's Let has a
        # nil type, so downstream consumers default the locals to i64 --
        # e.g. `val (out, err, code) = rt_process_run_timeout(...)` (declared
        # `-> (text, text, i32)`) typed out/err as i64, which made the native
        # print lowering (lower_bootstrap_print_call's explicit-numeric
        # coercion) render the text HANDLES as decimal integers and broke
        # every text method on them (parity case process_run_timeout).
        # Element types come from the by-NAME fn_tuple_returns registry
        # (module_lowering's signature pass) -- deliberately NOT from the
        # callee symbol's stored Function type: reading that Tuple payload
        # back out of the symbol table here yields garbage on the seed
        # interpreter (see fn_tuple_returns doc comment in types.spl), and
        # symbols.get_symbol itself mis-dispatches from this layer (see
        # symbol_display_name's docstring in hir_types.spl).
        if td_elem_types.len() == 0:
            val td_callee_name: text = self.td_init_callee_name(hir_init)
            if td_callee_name != "" and self.fn_tuple_returns.has(td_callee_name):
                td_elem_types = self.fn_tuple_returns[td_callee_name]
        var i = 0
        while i < parts.len():
            val pname = parts[i]
            if pname != "_":
                var td_idx_type: HirType? = nil
                if i < td_elem_types.len():
                    td_idx_type = td_elem_types[i]
                val idx_expr = HirExpr(kind: HirExprKind.Index(
                    HirExpr(kind: HirExprKind.Var(tmp_sym), type_: nil, span: span),
                    HirExpr(kind: HirExprKind.IntLit(i, nil), type_: nil, span: span)
                ), type_: td_idx_type, span: span)
                val psym = self.symbols.define(pname, SymbolKind.Variable, nil, span, false, is_mut, nil)
                stmts = stmts.push(HirStmt(kind: HirStmtKind.Let(psym, nil, idx_expr), span: span))
            i = i + 1
        HirStmt(kind: HirStmtKind.Block(HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: span), span: span)), span: span)

    me lower_hir_stmt(s: Stmt) -> HirStmt:
        # DIRECT typed field read, NOT `match s: case Stmt(k, _): k` — the
        # struct-pattern destructure hazard (bug doc iteration 17).
        val stmt_kind_value: StmtKind = s.kind

        # DISC-DISPATCH for value-carrying non-Expr statements (bug doc iteration
        # 20 #86): the multi-arm `match stmt_kind_value` MIS-ROUTES on stage4 — a
        # genuine StmtKind.Val/Var/Return/Assign matches NONE of the qualified
        # arms and falls to `case _` -> HirExprKind.Error. So `val n = 5` (and
        # every non-Expr statement) lowered to Error and SIGILL'd the interpreter;
        # only Expr-statement bodies (print(...)) were ever exercised on the
        # unstub path. Pre-dispatch by discriminant + isolated single-arm
        # extraction (same idiom as lower_type). Reference discs come from freshly
        # constructed values (construction is always correct on stage4).
        val sk_disc: i64 = hir_stmt_kind_disc(stmt_kind_value)
        val sk_dummy: Expr = Expr(kind: ExprKind.NilLit, span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Val("", nil, sk_dummy)):
            val v_name: text = match stmt_kind_value:
                case StmtKind.Val(vname, _, _):
                    vname
                case _:
                    ""
            val v_type: Type? = match stmt_kind_value:
                case StmtKind.Val(_, vtype, _):
                    vtype
                case _:
                    nil
            val v_init: Expr = match stmt_kind_value:
                case StmtKind.Val(_, _, vinit):
                    vinit
                case _:
                    sk_dummy
            val v_hir_type = if v_type.?:
                Some(self.lower_type(v_type ?? Type(kind: TypeKind.Infer, span: s.span)))
            else:
                nil
            val v_hir_init = self.lower_hir_expr(v_init)
            val v_symbol = self.symbols.define(v_name, SymbolKind.Variable, v_hir_type, s.span, false, false, nil)
            self.try_register_local_struct_type(v_symbol, v_init)
            self.try_register_local_tuple_type(v_symbol, v_init)
            return HirStmt(kind: HirStmtKind.Let(v_symbol, v_hir_type, v_hir_init), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Var("", nil, nil)):
            val vr_name = match stmt_kind_value:
                case StmtKind.Var(vrname, _, _):
                    vrname
                case _:
                    ""
            val vr_type = match stmt_kind_value:
                case StmtKind.Var(_, vrtype, _):
                    vrtype
                case _:
                    nil
            val vr_init: Expr? = match stmt_kind_value:
                case StmtKind.Var(_, _, vrinit):
                    vrinit
                case _:
                    nil
            val vr_hir_type = if vr_type.?:
                Some(self.lower_type(vr_type ?? Type(kind: TypeKind.Infer, span: s.span)))
            else:
                nil
            val vr_hir_init = if vr_init.?:
                self.lower_hir_expr(vr_init ?? sk_dummy)
            else:
                HirExpr(kind: HirExprKind.NilLit, type_: nil, span: s.span)
            val vr_symbol = self.symbols.define(vr_name, SymbolKind.Variable, vr_hir_type, s.span, false, true, nil)
            if val vr_init_present = vr_init:
                self.try_register_local_struct_type(vr_symbol, vr_init_present)
                self.try_register_local_tuple_type(vr_symbol, vr_init_present)
            return HirStmt(kind: HirStmtKind.Let(vr_symbol, vr_hir_type, vr_hir_init), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Return(nil)):
            val rt_val: Expr? = match stmt_kind_value:
                case StmtKind.Return(rvalue):
                    rvalue
                case _:
                    nil
            # Bare-lift + if-val: explicit Some(...) here built the heap box
            # MIR lower_expr saw as <value:0x100000004>. This fast path
            # SHADOWS the StmtKind.Return arm below (bug doc 2026-07-23).
            var rt_hir: HirExpr? = nil
            if val rt_val_e = rt_val:
                rt_hir = self.lower_hir_expr(rt_val_e)
            return HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Return(rt_hir), type_: nil, span: s.span)), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Assign(sk_dummy, nil, sk_dummy)):
            val as_target: Expr = match stmt_kind_value:
                case StmtKind.Assign(atarget, _, _):
                    atarget
                case _:
                    sk_dummy
            val as_op: AssignOp? = match stmt_kind_value:
                case StmtKind.Assign(_, aop, _):
                    aop
                case _:
                    nil
            val as_value: Expr = match stmt_kind_value:
                case StmtKind.Assign(_, _, avalue):
                    avalue
                case _:
                    sk_dummy
            val as_hir_op = self.lower_hir_assign_op_opt(as_op)
            return HirStmt(kind: HirStmtKind.Assign(self.lower_hir_expr(as_target), as_hir_op, self.lower_hir_expr(as_value)), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Expr(sk_dummy)):
            # ROOT FIX (stage2 gate: StmtKind.Expr misroute): the multi-arm
            # `match stmt_kind_value` below mis-routes on stage4/native-build
            # worker execution exactly like Val/Var/Return/Assign did (bug
            # doc iteration 20 #86) — a genuine StmtKind.Expr matched NONE
            # of the qualified arms and fell through to the `case _`
            # catch-all -> "unsupported statement kind", failing HIR
            # lowering for every bare-expression-statement body (confirmed
            # via disc-dispatch trace on a minimal native-build repro).
            # Pre-dispatch by discriminant + single-arm pattern-extraction,
            # same idiom Val/Var/Assign above already use successfully for
            # their own Expr-typed fields (rt_enum_payload -- Return's
            # idiom -- comes back nil for Expr's payload specifically; see
            # bug doc hir_stmt_expr_payload_extraction_nil_2026-07-17.md).
            val expr_t: Expr = match stmt_kind_value:
                case StmtKind.Expr(einner):
                    einner
                case _:
                    sk_dummy
            # The flat parser emits `target = value` as an EXPRESSION
            # statement (expr_assign), never StmtKind.Assign. Route it
            # into HirStmtKind.Assign so MIR's assignment lowering
            # (including bitfield field-write synthesis) sees it.
            match expr_t.kind:
                case ExprKind.Assign(assign_target, assign_op, assign_value):
                    val hir_assign_op = self.lower_hir_assign_op_opt(assign_op)
                    return HirStmt(kind: HirStmtKind.Assign(
                        self.lower_hir_expr(assign_target),
                        hir_assign_op,
                        self.lower_hir_expr(assign_value)
                    ), span: s.span)
                case _:
                    return HirStmt(kind: HirStmtKind.Expr(self.lower_hir_expr(expr_t)), span: s.span)

        val kind: HirStmtKind = match stmt_kind_value:
            case StmtKind.Val(name, type_, init):
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                val hir_init = self.lower_hir_expr(init)
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, false, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Var(name, type_, init):
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                val hir_init = if init.?:
                    self.lower_hir_expr(init ?? Expr(kind: ExprKind.NilLit, span: s.span))
                else:
                    HirExpr(kind: HirExprKind.NilLit, type_: nil, span: s.span)
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, true, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Assign(target, op, value):
                val hir_op = self.lower_hir_assign_op_opt(op)
                HirStmtKind.Assign(self.lower_hir_expr(target), hir_op, self.lower_hir_expr(value))

            case StmtKind.For(var_, iter, body):
                self.symbols.push_scope(ScopeKind.Loop)
                self.loop_depth = self.loop_depth + 1
                val hir_iter = self.lower_hir_expr(iter)
                # Tuple destructuring: `for (k, v) in pairs:` -- the parser
                # (parse_for_stmt, G40) encodes the pattern as the joined
                # string "(k,v)" in `var_`, mirroring the `val (a, b) = ...`
                # convention. Without this desugar, `var_` was defined
                # VERBATIM as a single symbol literally named "(k,v)" and the
                # loop body's real `k`/`v` references were never bound at
                # all -- "unresolved name: k" / "unresolved name: v" (loud
                # HIR fatal, no binary; this replaces that with working
                # bindings). Mirrors lower_tuple_destructure above: bind the
                # raw per-iteration element to a fresh loop symbol, then
                # prepend one `Let name = __elem[i]` per destructured name to
                # the (already-lowered) loop body so they're in scope for
                # every statement in it.
                val for_is_tuple = var_.len() >= 2 and var_.slice(0, 1) == "(" and var_.slice(var_.len() - 1, var_.len()) == ")"
                val hir_body_kind = if for_is_tuple:
                    val for_inner = var_.slice(1, var_.len() - 1)
                    val for_parts = for_inner.split(",")
                    val for_elem_sym = self.symbols.define("__for_tuple_elem", SymbolKind.Variable, nil, s.span, false, false, nil)
                    var for_prefix: [HirStmt] = []
                    var for_pi = 0
                    while for_pi < for_parts.len():
                        val for_pname = for_parts[for_pi]
                        if for_pname != "_":
                            val for_idx_expr = HirExpr(kind: HirExprKind.Index(
                                HirExpr(kind: HirExprKind.Var(for_elem_sym), type_: nil, span: s.span),
                                HirExpr(kind: HirExprKind.IntLit(for_pi, nil), type_: nil, span: s.span)
                            ), type_: nil, span: s.span)
                            val for_psym = self.symbols.define(for_pname, SymbolKind.Variable, nil, s.span, false, false, nil)
                            for_prefix = for_prefix.push(HirStmt(kind: HirStmtKind.Let(for_psym, nil, for_idx_expr), span: s.span))
                        for_pi = for_pi + 1
                    val for_hir_body_raw = self.lower_hir_block(body)
                    val for_hir_body = HirBlock(
                        stmts: for_prefix.concat(for_hir_body_raw.stmts),
                        has: for_hir_body_raw.has,
                        value: for_hir_body_raw.value,
                        span: for_hir_body_raw.span
                    )
                    HirExprKind.For(for_elem_sym, hir_iter, for_hir_body, nil)
                else:
                    val symbol = self.symbols.define(var_, SymbolKind.Variable, nil, s.span, false, false, nil)
                    val hir_body = self.lower_hir_block(body)
                    HirExprKind.For(symbol, hir_iter, hir_body, nil)
                self.loop_depth = self.loop_depth - 1
                self.symbols.pop_scope()
                # Desugar to loop
                HirStmtKind.Expr(HirExpr(
                    kind: hir_body_kind,
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.While(cond, body):
                self.loop_depth = self.loop_depth + 1
                val hir_cond = self.lower_hir_expr(cond)
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.While(hir_cond, hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Loop(body):
                self.loop_depth = self.loop_depth + 1
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Loop(hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Return(value):
                # Bare-lift: explicit Some(...) builds a heap Option box on the
                # stage4 native lane; MIR lower_expr then sees the box header
                # (<value:0x100000004>) instead of the expr (bug doc 2026-07-23).
                var return_value: HirExpr? = nil
                return_value = self.lower_hir_expr(value)
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Return(return_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Break(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Break(label, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Continue(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Continue(label),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Yield(value):
                val yield_value = Some(self.lower_hir_expr(value))
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Yield(yield_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Throw(value):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Throw(self.lower_hir_expr(value)),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.AsmAssert(spec):
                HirStmtKind.AsmAssert(spec)

            case StmtKind.With(items, body):
                val hir_items = self.lower_hir_with_items(items)
                val hir_body = self.lower_hir_block(body)

                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.With(hir_items, hir_body),
                    type_: nil,
                    span: s.span
                ))

            case _:
                self.error("unsupported statement kind", s.span)
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Error,
                    type_: nil,
                    span: s.span
                ))

        HirStmt(kind: kind, span: s.span)
