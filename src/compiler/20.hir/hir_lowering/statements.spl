# HIR Lowering - Statement Lowering
#
# This module handles lowering of statements from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.expressions.*
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text
extern fn rt_enum_payload(value: StmtKind) -> Expr
extern fn rt_enum_discriminant(value: StmtKind) -> i64

fn hir_stmt_env_get(key: text) -> text:
    rt_env_get(key)

fn hir_stmt_kind_disc(k: StmtKind) -> i64:
    rt_enum_discriminant(k)

# Statement Lowering
# ============================================================================

impl HirLowering:
    fn lower_hir_assign_op(assign_op: AssignOp) -> HirAssignOp:
        match assign_op:
            case AssignOp.Add: HirAssignOp.Add
            case AssignOp.Sub: HirAssignOp.Sub
            case AssignOp.Mul: HirAssignOp.Mul
            case AssignOp.Div: HirAssignOp.Div
            case AssignOp.Mod: HirAssignOp.Mod

    me lower_hir_assign_op_opt(op: AssignOp?) -> HirAssignOp?:
        if op.?:
            Some(self.lower_hir_assign_op(op.unwrap()))
        else:
            nil

    me lower_hir_with_items(items: [WithItem]) -> [HirWithItem]:
        var result: [HirWithItem] = []
        for item in items:
            val hir_context = self.lower_hir_expr(item.context_expr)
            val hir_target: SymbolId? = if item.target.?:
                val symbol = self.symbols.define(item.target ?? "", SymbolKind.Variable, nil, item.span, false, false, nil)
                Some(symbol)
            else:
                nil
            val hir_item = HirWithItem(
                context_expr: hir_context,
                target: hir_target,
                span: item.span
            )
            result = result.push(hir_item)
        result

    # Lower a single source statement to zero-or-more HIR statements. Almost
    # every statement is 1:1 -- the exception is literal-tuple destructuring
    # (`val (a, b) = (x, y)`), which the parser encodes as a single
    # StmtKind.Val whose `name` is the literal text "(a,b)" (see
    # parse_tuple_destructure_val in parser_stmts.spl). That single source
    # statement desugars into N ordinary `Let` bindings here, so callers that
    # iterate over a block's statements must call this instead of
    # `lower_hir_stmt` and splice the results (see lower_hir_block /
    # lower_hir_block_unit in expressions.spl).
    me lower_hir_stmt_multi(s: Stmt) -> [HirStmt]:
        val stmt_kind_value: StmtKind = s.kind
        val sk_disc: i64 = hir_stmt_kind_disc(stmt_kind_value)
        val sk_dummy: Expr = Expr(kind: ExprKind.NilLit, span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Val("", nil, sk_dummy)):
            val v_name = match stmt_kind_value:
                case StmtKind.Val(vname, _, _):
                    vname
                case _:
                    ""
            if v_name.len() > 1 and v_name[0:1] == "(":
                val v_init = match stmt_kind_value:
                    case StmtKind.Val(_, _, vinit):
                        vinit
                    case _:
                        sk_dummy
                return self.lower_hir_tuple_destructure_val(v_name, v_init, s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Var("", nil, nil)):
            val vr_name = match stmt_kind_value:
                case StmtKind.Var(vrname, _, _):
                    vrname
                case _:
                    ""
            if vr_name.len() > 1 and vr_name[0:1] == "(":
                val vr_init = match stmt_kind_value:
                    case StmtKind.Var(_, _, vrinit):
                        vrinit
                    case _:
                        nil
                val vr_init_expr = vr_init ?? sk_dummy
                return self.lower_hir_tuple_destructure_var(vr_name, vr_init_expr, s.span)
        [self.lower_hir_stmt(s)]

    # Desugar `val (a, b, ...) = <literal tuple expr>` into N `Let` bindings,
    # evaluating each element expression exactly once, left to right. Only a
    # LITERAL tuple initializer (`ExprKind.TupleLit`) is supported -- anything
    # else (a variable, a function call returning a tuple, ...) is a loud HIR
    # error so a non-literal initializer never silently produces a wrong
    # answer.
    me lower_hir_tuple_destructure_val(joined_name: text, init: Expr, span: Span) -> [HirStmt]:
        val inner = joined_name[1:joined_name.len() - 1]
        val names = inner.split(",")
        match init.kind:
            case ExprKind.TupleLit(elements):
                if elements.len() != names.len():
                    # The "unresolved name:" prefix is REQUIRED for loudness:
                    # driver.spl's _hir_lowering_error_is_fatal only promotes
                    # HIR lowering errors with that prefix to fatal build
                    # errors -- anything else is silently downgraded to a
                    # warning and never surfaces.
                    self.error("unresolved name: tuple destructure arity mismatch for `val (" + inner + ")`: " + names.len().to_text() + " name(s) on the left vs " + elements.len().to_text() + " value(s) on the right", span)
                    [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
                else:
                    var result: [HirStmt] = []
                    var i = 0
                    while i < names.len():
                        val nm = names[i]
                        val hir_init = self.lower_hir_expr(elements[i])
                        val symbol = self.symbols.define(nm, SymbolKind.Variable, nil, span, false, false, nil)
                        result = result.push(HirStmt(kind: HirStmtKind.Let(symbol, nil, hir_init), span: span))
                        i = i + 1
                    result
            case _:
                # Non-literal initializer (variable, function call returning a
                # tuple, e.g. `val (out, err, code) = rt_process_run(...)`):
                # general desugar via lower_tuple_destructure below — binds a
                # temp to the tuple value ONCE, then binds each name to
                # temp[i] (rt_array_get; tuples are rt_arrays at runtime).
                # Correct, not silent-wrong: element order/evaluation match
                # the interpreter's eval_tuple_destructure.
                [self.lower_tuple_destructure(joined_name, self.lower_hir_expr(init), false, span)]

    # Desugar `var (a, b, ...) = <literal tuple expr>` into N mutable `Let`
    # bindings, mirroring lower_hir_tuple_destructure_val above but marking
    # each symbol mutable so a later `a = 5` reassignment is legal (a `val`
    # binding would loud-fail reassignment instead).
    me lower_hir_tuple_destructure_var(joined_name: text, init: Expr, span: Span) -> [HirStmt]:
        val inner = joined_name[1:joined_name.len() - 1]
        val names = inner.split(",")
        match init.kind:
            case ExprKind.TupleLit(elements):
                if elements.len() != names.len():
                    # The "unresolved name:" prefix is REQUIRED for loudness:
                    # driver.spl's _hir_lowering_error_is_fatal only promotes
                    # HIR lowering errors with that prefix to fatal build
                    # errors -- anything else is silently downgraded to a
                    # warning and never surfaces.
                    self.error("unresolved name: tuple destructure arity mismatch for `var (" + inner + ")`: " + names.len().to_text() + " name(s) on the left vs " + elements.len().to_text() + " value(s) on the right", span)
                    [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
                else:
                    var result: [HirStmt] = []
                    var i = 0
                    while i < names.len():
                        val nm = names[i]
                        val hir_init = self.lower_hir_expr(elements[i])
                        val symbol = self.symbols.define(nm, SymbolKind.Variable, nil, span, false, true, nil)
                        result = result.push(HirStmt(kind: HirStmtKind.Let(symbol, nil, hir_init), span: span))
                        i = i + 1
                    result
            case _:
                # Non-literal initializer: general desugar (see the val
                # variant above) with mutable bindings.
                [self.lower_tuple_destructure(joined_name, self.lower_hir_expr(init), true, span)]

    # General tuple destructure for NON-LITERAL initializers: `val/var
    # (a, b, c) = expr` where expr is a variable or a call returning a tuple
    # (e.g. `val (out, err, code) = rt_process_run(...)`). Binds a temp to
    # the init tuple ONCE (evaluating the RHS exactly once), then binds each
    # name to temp[i]. Tuples are rt_arrays at runtime (rt_tuple_new ->
    # rt_array_new), and under SIMPLE_BOOTSTRAP an Index lowers to
    # rt_array_get, so temp[i] extracts element i. Emitted as a Block; MIR
    # keys local_map by symbol_id function-wide (no scope dealloc), so the
    # bindings stay visible to later statements. Literal initializers take
    # the per-element fast path in lower_hir_tuple_destructure_val/var above.
    # NOTE(verify-later): element types are nil, so the bootstrap Index path
    # defaults elements to text; genuinely-i64 elements (a shell exit code)
    # are text-typed — bits are i64-repr so it compiles, but confirm integer
    # uses once the redeploy builds.
    me lower_tuple_destructure(name: text, hir_init: HirExpr, is_mut: bool, span: Span) -> HirStmt:
        val inner = name.slice(1, name.len() - 1)
        val parts = inner.split(",")
        var stmts: [HirStmt] = []
        val tmp_sym = self.symbols.define("__tuple_destr", SymbolKind.Variable, nil, span, false, false, nil)
        stmts = stmts.push(HirStmt(kind: HirStmtKind.Let(tmp_sym, nil, hir_init), span: span))
        var i = 0
        while i < parts.len():
            val pname = parts[i]
            if pname != "_":
                val idx_expr = HirExpr(kind: HirExprKind.Index(
                    HirExpr(kind: HirExprKind.Var(tmp_sym), type_: nil, span: span),
                    HirExpr(kind: HirExprKind.IntLit(i, nil), type_: nil, span: span)
                ), type_: nil, span: span)
                val psym = self.symbols.define(pname, SymbolKind.Variable, nil, span, false, is_mut, nil)
                stmts = stmts.push(HirStmt(kind: HirStmtKind.Let(psym, nil, idx_expr), span: span))
            i = i + 1
        HirStmt(kind: HirStmtKind.Block(HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: span), span: span)), span: span)

    me lower_hir_stmt(s: Stmt) -> HirStmt:
        if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_stmt:start")
        # DIRECT typed field read, NOT `match s: case Stmt(k, _): k` — the
        # struct-pattern destructure hazard (bug doc iteration 17).
        val stmt_kind_value: StmtKind = s.kind
        if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_stmt:kind")

        # DISC-DISPATCH for value-carrying non-Expr statements (bug doc iteration
        # 20 #86): the multi-arm `match stmt_kind_value` MIS-ROUTES on stage4 — a
        # genuine StmtKind.Val/Var/Return/Assign matches NONE of the qualified
        # arms and falls to `case _` -> HirExprKind.Error. So `val n = 5` (and
        # every non-Expr statement) lowered to Error and SIGILL'd the interpreter;
        # only Expr-statement bodies (print(...)) were ever exercised on the
        # unstub path. Pre-dispatch by discriminant + isolated single-arm
        # extraction (same idiom as lower_type). Reference discs come from freshly
        # constructed values (construction is always correct on stage4).
        val sk_disc: i64 = hir_stmt_kind_disc(stmt_kind_value)
        val sk_dummy: Expr = Expr(kind: ExprKind.NilLit, span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Val("", nil, sk_dummy)):
            val v_name = match stmt_kind_value:
                case StmtKind.Val(vname, _, _):
                    vname
                case _:
                    ""
            val v_type = match stmt_kind_value:
                case StmtKind.Val(_, vtype, _):
                    vtype
                case _:
                    nil
            val v_init = match stmt_kind_value:
                case StmtKind.Val(_, _, vinit):
                    vinit
                case _:
                    sk_dummy
            val v_hir_type = if v_type.?:
                Some(self.lower_type(v_type ?? Type(kind: TypeKind.Infer, span: s.span)))
            else:
                nil
            val v_hir_init = self.lower_hir_expr(v_init)
            val v_symbol = self.symbols.define(v_name, SymbolKind.Variable, v_hir_type, s.span, false, false, nil)
            return HirStmt(kind: HirStmtKind.Let(v_symbol, v_hir_type, v_hir_init), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Var("", nil, nil)):
            val vr_name = match stmt_kind_value:
                case StmtKind.Var(vrname, _, _):
                    vrname
                case _:
                    ""
            val vr_type = match stmt_kind_value:
                case StmtKind.Var(_, vrtype, _):
                    vrtype
                case _:
                    nil
            val vr_init = match stmt_kind_value:
                case StmtKind.Var(_, _, vrinit):
                    vrinit
                case _:
                    nil
            val vr_hir_type = if vr_type.?:
                Some(self.lower_type(vr_type ?? Type(kind: TypeKind.Infer, span: s.span)))
            else:
                nil
            val vr_hir_init = if vr_init.?:
                self.lower_hir_expr(vr_init ?? sk_dummy)
            else:
                HirExpr(kind: HirExprKind.NilLit, type_: nil, span: s.span)
            val vr_symbol = self.symbols.define(vr_name, SymbolKind.Variable, vr_hir_type, s.span, false, true, nil)
            return HirStmt(kind: HirStmtKind.Let(vr_symbol, vr_hir_type, vr_hir_init), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Return(nil)):
            val rt_val: Expr = rt_enum_payload(stmt_kind_value)
            val rt_hir = if rt_val.?:
                Some(self.lower_hir_expr(rt_val ?? sk_dummy))
            else:
                nil
            return HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Return(rt_hir), type_: nil, span: s.span)), span: s.span)
        if sk_disc == hir_stmt_kind_disc(StmtKind.Assign(sk_dummy, nil, sk_dummy)):
            val as_target = match stmt_kind_value:
                case StmtKind.Assign(atarget, _, _):
                    atarget
                case _:
                    sk_dummy
            val as_op = match stmt_kind_value:
                case StmtKind.Assign(_, aop, _):
                    aop
                case _:
                    nil
            val as_value = match stmt_kind_value:
                case StmtKind.Assign(_, _, avalue):
                    avalue
                case _:
                    sk_dummy
            val as_hir_op = self.lower_hir_assign_op_opt(as_op)
            return HirStmt(kind: HirStmtKind.Assign(self.lower_hir_expr(as_target), as_hir_op, self.lower_hir_expr(as_value)), span: s.span)

        val kind: HirStmtKind = match stmt_kind_value:
            case StmtKind.Expr(_):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:expr")
                # Pattern-extracted payload is GARBAGE on stage4 (iteration 17,
                # disc=823890719). Extract via rt_enum_payload directly and
                # compare (UNGATED probes, Trap D).
                val expr_t: Expr = rt_enum_payload(stmt_kind_value)
                # The flat parser emits `target = value` as an EXPRESSION
                # statement (expr_assign), never StmtKind.Assign. Route it
                # into HirStmtKind.Assign so MIR's assignment lowering
                # (including bitfield field-write synthesis) sees it.
                match expr_t.kind:
                    case ExprKind.Assign(assign_target, assign_op, assign_value):
                        val hir_assign_op = self.lower_hir_assign_op_opt(assign_op)
                        HirStmtKind.Assign(
                            self.lower_hir_expr(assign_target),
                            hir_assign_op,
                            self.lower_hir_expr(assign_value)
                        )
                    case _:
                        HirStmtKind.Expr(self.lower_hir_expr(expr_t))

            case StmtKind.Val(name, type_, init):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:val {name}")
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                val hir_init = self.lower_hir_expr(init)
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, false, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Var(name, type_, init):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var {name}")
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var:type {name}")
                val hir_init = if init.?:
                    if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                        eprint("[hir-lower] lower_stmt:var:init {name}")
                    self.lower_hir_expr(init ?? Expr(kind: ExprKind.NilLit, span: s.span))
                else:
                    HirExpr(kind: HirExprKind.NilLit, type_: nil, span: s.span)
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var:init-done {name}")
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, true, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Assign(target, op, value):
                val hir_op = self.lower_hir_assign_op_opt(op)
                HirStmtKind.Assign(self.lower_hir_expr(target), hir_op, self.lower_hir_expr(value))

            case StmtKind.For(var_, iter, body):
                self.symbols.push_scope(ScopeKind.Loop)
                self.loop_depth = self.loop_depth + 1
                val symbol = self.symbols.define(var_, SymbolKind.Variable, nil, s.span, false, false, nil)
                val hir_iter = self.lower_hir_expr(iter)
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                self.symbols.pop_scope()
                # Desugar to loop
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.For(symbol, hir_iter, hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.While(cond, body):
                self.loop_depth = self.loop_depth + 1
                val hir_cond = self.lower_hir_expr(cond)
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.While(hir_cond, hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Loop(body):
                self.loop_depth = self.loop_depth + 1
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Loop(hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Return(value):
                val return_value = Some(self.lower_hir_expr(value))
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Return(return_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Break(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Break(label, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Continue(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Continue(label),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Yield(value):
                val yield_value = Some(self.lower_hir_expr(value))
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Yield(yield_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Throw(value):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Throw(self.lower_hir_expr(value)),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.AsmAssert(spec):
                HirStmtKind.AsmAssert(spec)

            case StmtKind.With(items, body):
                val hir_items = self.lower_hir_with_items(items)
                val hir_body = self.lower_hir_block(body)

                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.With(hir_items, hir_body),
                    type_: nil,
                    span: s.span
                ))

            case _:
                self.error("unsupported statement kind", s.span)
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Error,
                    type_: nil,
                    span: s.span
                ))

        HirStmt(kind: kind, span: s.span)
