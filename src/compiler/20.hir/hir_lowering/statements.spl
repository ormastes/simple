# HIR Lowering - Statement Lowering
#
# This module handles lowering of statements from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.expressions.*
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text
extern fn rt_enum_discriminant(value: ExprKind) -> i64
extern fn rt_enum_payload(value: StmtKind) -> Expr

fn hir_stmt_env_get(key: text) -> text:
    rt_env_get(key)

fn hir_stmt_expr_disc(k: ExprKind) -> i64:
    rt_enum_discriminant(k)

# Statement Lowering
# ============================================================================

impl HirLowering:
    fn lower_hir_assign_op(assign_op: AssignOp) -> HirAssignOp:
        match assign_op:
            case AssignOp.Add: HirAssignOp.Add
            case AssignOp.Sub: HirAssignOp.Sub
            case AssignOp.Mul: HirAssignOp.Mul
            case AssignOp.Div: HirAssignOp.Div
            case AssignOp.Mod: HirAssignOp.Mod

    me lower_hir_assign_op_opt(op: AssignOp?) -> HirAssignOp?:
        if op.?:
            Some(self.lower_hir_assign_op(op.unwrap()))
        else:
            nil

    me lower_hir_with_items(items: [WithItem]) -> [HirWithItem]:
        var result: [HirWithItem] = []
        for item in items:
            val hir_context = self.lower_hir_expr(item.context_expr)
            val hir_target: SymbolId? = if item.target.?:
                val symbol = self.symbols.define(item.target ?? "", SymbolKind.Variable, nil, item.span, false, false, nil)
                Some(symbol)
            else:
                nil
            val hir_item = HirWithItem(
                context_expr: hir_context,
                target: hir_target,
                span: item.span
            )
            result = result.push(hir_item)
        result

    me lower_hir_stmt(s: Stmt) -> HirStmt:
        if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_stmt:start")
        # DIRECT typed field read, NOT `match s: case Stmt(k, _): k` — the
        # struct-pattern destructure hazard (bug doc iteration 17).
        val stmt_kind_value: StmtKind = s.kind
        if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_stmt:kind")
        val kind = match stmt_kind_value:
            case StmtKind.Expr(expr):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:expr")
                # Pattern-extracted payload is GARBAGE on stage4 (iteration 17,
                # disc=823890719). Extract via rt_enum_payload directly and
                # compare (UNGATED probes, Trap D).
                val expr_p: Expr = rt_enum_payload(stmt_kind_value)
                eprint("[LSTP] rt_enum_payload disc={hir_stmt_expr_disc(expr_p.kind)}")
                val expr_t: Expr = expr
                eprint("[LST] stmt-expr payload disc={hir_stmt_expr_disc(expr_t.kind)}")
                # The flat parser emits `target = value` as an EXPRESSION
                # statement (expr_assign), never StmtKind.Assign. Route it
                # into HirStmtKind.Assign so MIR's assignment lowering
                # (including bitfield field-write synthesis) sees it.
                match expr_t.kind:
                    case ExprKind.Assign(assign_target, assign_op, assign_value):
                        val hir_assign_op = self.lower_hir_assign_op_opt(assign_op)
                        HirStmtKind.Assign(
                            self.lower_hir_expr(assign_target),
                            hir_assign_op,
                            self.lower_hir_expr(assign_value)
                        )
                    case _:
                        HirStmtKind.Expr(self.lower_hir_expr(expr_t))

            case StmtKind.Val(name, type_, init):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:val {name}")
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                val hir_init = self.lower_hir_expr(init)
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, false, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Var(name, type_, init):
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var {name}")
                val hir_type = if type_.?:
                    Some(self.lower_type(type_ ?? Type(kind: TypeKind.Infer, span: s.span)))
                else:
                    nil
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var:type {name}")
                val hir_init = if init.?:
                    if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                        eprint("[hir-lower] lower_stmt:var:init {name}")
                    self.lower_hir_expr(init ?? Expr(kind: ExprKind.NilLit, span: s.span))
                else:
                    HirExpr(kind: HirExprKind.NilLit, type_: nil, span: s.span)
                if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_stmt:var:init-done {name}")
                val symbol = self.symbols.define(name, SymbolKind.Variable, hir_type, s.span, false, true, nil)
                HirStmtKind.Let(symbol, hir_type, hir_init)

            case StmtKind.Assign(target, op, value):
                val hir_op = self.lower_hir_assign_op_opt(op)
                HirStmtKind.Assign(self.lower_hir_expr(target), hir_op, self.lower_hir_expr(value))

            case StmtKind.For(var_, iter, body):
                self.symbols.push_scope(ScopeKind.Loop)
                self.loop_depth = self.loop_depth + 1
                val symbol = self.symbols.define(var_, SymbolKind.Variable, nil, s.span, false, false, nil)
                val hir_iter = self.lower_hir_expr(iter)
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                self.symbols.pop_scope()
                # Desugar to loop
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.For(symbol, hir_iter, hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.While(cond, body):
                self.loop_depth = self.loop_depth + 1
                val hir_cond = self.lower_hir_expr(cond)
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.While(hir_cond, hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Loop(body):
                self.loop_depth = self.loop_depth + 1
                val hir_body = self.lower_hir_block(body)
                self.loop_depth = self.loop_depth - 1
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Loop(hir_body, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Return(value):
                val return_value = Some(self.lower_hir_expr(value))
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Return(return_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Break(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Break(label, nil),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Continue(label):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Continue(label),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Yield(value):
                val yield_value = Some(self.lower_hir_expr(value))
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Yield(yield_value),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.Throw(value):
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Throw(self.lower_hir_expr(value)),
                    type_: nil,
                    span: s.span
                ))

            case StmtKind.AsmAssert(spec):
                HirStmtKind.AsmAssert(spec)

            case StmtKind.With(items, body):
                val hir_items = self.lower_hir_with_items(items)
                val hir_body = self.lower_hir_block(body)

                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.With(hir_items, hir_body),
                    type_: nil,
                    span: s.span
                ))

            case _:
                self.error("unsupported statement kind", s.span)
                HirStmtKind.Expr(HirExpr(
                    kind: HirExprKind.Error,
                    type_: nil,
                    span: s.span
                ))

        HirStmt(kind: kind, span: s.span)
