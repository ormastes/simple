# Part 2 of src/compiler/20.hir/hir_lowering/items_part2.spl
use compiler.hir.hir_lowering.items_part2.*
# Part 2 of src/compiler/20.hir/hir_lowering/items.spl
use compiler.hir.hir_lowering.items.*
# HIR Lowering - Item Lowering
#
# This module handles lowering of top-level items (functions, classes, structs, enums, traits, impls) from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types.{Module as ParserModule, Function, ImportItem, Param}
use compiler.frontend.flat_ast_bridge.{flat_bootstrap_function_count, flat_bootstrap_function_at, flat_bootstrap_function_decl_at}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.expressions.*
use compiler.common.attributes.{parse_layout_attrs, parse_function_attrs, parse_export_attrs, parse_driver_manifest_attrs, parse_platform_attrs, parse_vhdl_hardware_attrs, vhdl_hardware_metadata_default, FunctionAttr, ExportAttr, DriverManifestAttr, DriverManifestAttrKind, VhdlHardwareMetadata}
use compiler.types.type_layout.{LayoutAttr, LayoutKind, PlatformParseResult, PlatformDiagnosticLevel, PlatformLayoutDiagnostic}
use compiler.common.dependency.visibility.{Visibility}
use compiler.core.ast.{decl_get_body, decl_get_name, decl_get_param_names, decl_get_param_types, decl_get_ret_type}
use compiler.core.ast_stmt.{STMT_EXPR, STMT_VAL_DECL, STMT_VAR_DECL, STMT_RETURN, stmt_get_tag, stmt_get_expr, stmt_get_name, stmt_get_type}
use compiler.core.ast_expr.{EXPR_INT_LIT, EXPR_STRING_LIT, EXPR_BOOL_LIT, EXPR_NIL_LIT, EXPR_IDENT, EXPR_BINARY, EXPR_CALL, EXPR_FIELD_ACCESS, EXPR_METHOD_CALL, EXPR_BLOCK, EXPR_RETURN, expr_get_tag, expr_get_int, expr_get_str, expr_get_left, expr_get_right, expr_get_args, expr_get_stmts}
use compiler.core.tokens.{TOK_MINUS, TOK_STAR, TOK_SLASH, TOK_PERCENT, TOK_EQ, TOK_NOT_EQ, TOK_LT, TOK_LT_EQ, TOK_GT, TOK_GT_EQ}
use compiler.core.types.{TYPE_VOID, TYPE_BOOL, TYPE_I64, TYPE_TEXT, custom_primitive_bind_symbol, custom_primitive_is_name}
use compiler.core.types.{primitive_integer_bit_width_from_name, custom_primitive_integer_bit_width_by_name}
use compiler.core.types.{int_to_str}
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text

impl HirLowering:
    me lower_bootstrap_flat_function(decl_idx: i64) -> HirFunction:
        val span = Span.empty()
        val name = decl_get_name(decl_idx)
        eprint("[hir-lower] flat_function:start {name}")
        val symbol = bootstrap_hir_symbol_for_name(name)
        self.current_function = Some(symbol)
        self.symbols.push_scope(ScopeKind.Function)
        eprint("[hir-lower] flat_function:params:start {name}")
        val param_count = 0
        eprint("[hir-lower] flat_function:params:count {name} {param_count}")
        var params: [HirParam] = []
        var pi = 0
        while pi < param_count:
            eprint("[hir-lower] flat_function:param {name} {pi}")
            val p_type = HirType(kind: HirTypeKind.Infer(0, 0), span: span)
            val p_sym = self.symbols.define("", SymbolKind.Parameter, Some(p_type), span, Visibility.Private, false, nil)
            params.push(HirParam(symbol: p_sym, name: "", type_: p_type, has_default: false, default: HirExpr(kind: HirExprKind.NilLit, has_type_: true, type_: HirType(kind: HirTypeKind.Unit, span: span), span: span), span: span))
            pi = pi + 1
        eprint("[hir-lower] flat_function:body:start {name}")
        val body_ids = decl_get_body(decl_idx)
        eprint("[hir-lower] flat_function:body:count {name} {body_ids.len()}")
        val body = self.lower_bootstrap_flat_block(body_ids)
        eprint("[hir-lower] flat_function:body:done {name}")
        self.symbols.pop_scope()
        self.current_function = nil
        eprint("[hir-lower] flat_function:done {name}")
        HirFunction(
            symbol: symbol,
            name: name,
            type_params: [],
            params: params,
            return_type: bootstrap_hir_type_from_tag(decl_get_ret_type(decl_idx)),
            body: body,
            effects: [],
            visibility: Visibility.Public,
            is_async: false,
            is_static: false,
            is_public: true,
            is_method: false,
            is_mutable: false,
            is_const: false,
            is_extern: false,
            func_attr: nil,
            has_export_attr: false,
            export_attr: nil,
            has_driver_manifest_attr: false,
            driver_manifest_attr: DriverManifestAttr(kind: DriverManifestAttrKind.Driver, driver_class: 0, vendor: 0, device_ids: [], version: "", abi: ""),
            has_suspension: false,
            has_vhdl_metadata: false,
            vhdl_metadata: vhdl_hardware_metadata_default(),
            has_doc_comment: false,
            doc_comment: "",
            span: span
        )

    me lower_function(fn_: Function) -> HirFunction:
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:start {fn_.name}")
        var fn_symbol_id = SymbolId(id: -1)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            fn_symbol_id = bootstrap_hir_symbol_for_name(fn_.name)
        else:
            val fn_symbol_lookup = self.symbols.lookup(fn_.name)
            if fn_symbol_lookup.?:
                fn_symbol_id = fn_symbol_lookup.unwrap()
            else:
                fn_symbol_id = self.symbols.define(fn_.name, SymbolKind.Function, nil, fn_.span, fn_.visibility, false, nil)
        self.current_function = Some(fn_symbol_id)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            self.symbols.push_scope(ScopeKind.Function)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:scope {fn_.name}")

        # Lower type parameters
        var type_params: [HirTypeParam] = []
        var tpi = 0
        while tpi < fn_.type_params.len():
            type_params = type_params.push(self.lower_type_param(fn_.type_params[tpi]))
            tpi = tpi + 1
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:type_params {fn_.name}")

        # Lower parameters
        var params: [HirParam] = []
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            val fn_params = function_params(fn_)
            if fn_.is_method and not fn_.is_static and self.current_method_self_type.? and (fn_params.len() == 0 or fn_params[0].name != "self"):
                val self_type = self.current_method_self_type.unwrap()
                val self_symbol = self.symbols.define("self", SymbolKind.Parameter, Some(self_type), fn_.span, Visibility.Private, false, nil)
                params = params.push(HirParam(
                    symbol: self_symbol,
                    name: "self",
                    type_: self_type,
                    has_default: false,
                    default: HirExpr(kind: HirExprKind.NilLit, has_type_: false, type_: HirType(kind: HirTypeKind.Unit, span: fn_.span), span: fn_.span),
                    span: fn_.span
                ))
            var pi = 0
            while pi < fn_params.len():
                params = params.push(self.lower_param(fn_params[pi]))
                pi = pi + 1
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:params {fn_.name}")

        # Lower return type — use explicit check instead of .map() ?? default
        # to avoid crash with null coalescing on Option.map result
        var return_type = HirType(kind: HirTypeKind.Unit, span: fn_.span)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            if fn_.return_type.?:
                val mapped = fn_.return_type.map(self.lower_type(_))
                if mapped.?:
                    return_type = mapped.unwrap()
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:return_type {fn_.name}")

        # Lower body
        val body = self.lower_hir_block(fn_.body)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_function:body {fn_.name}")

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            self.symbols.pop_scope()
        self.current_function = nil

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(fn_.name, fn_.visibility)

        # Parse function attributes (@entry, @naked, @noreturn, @section, @interrupt)
        val fa: FunctionAttr = parse_function_attrs(fn_.attributes)
        val func_attr_opt: FunctionAttr? = if fa.is_entry or fa.is_naked or fa.is_noreturn or fa.section.? or fa.is_interrupt or fa.is_alloc or fa.is_no_alloc or fa.is_gpu_kernel or fa.is_simd or fa.has_fast_math or fa.simd_enable or fa.simd_disable or fa.simd_prefer_scalable:
            Some(fa)
        else:
            nil

        # Parse export attributes (@export("C"))
        val parsed_export_attr: ExportAttr? = parse_export_attrs(fn_.attributes)
        val driver_manifest: DriverManifestAttr? = parse_driver_manifest_attrs(fn_.attributes)
        val vhdl_metadata: VhdlHardwareMetadata = parse_vhdl_hardware_attrs(fn_.attributes)

        # Seed effects from is_async annotation.
        # The full effect pass (effect_pass.spl) will refine these later.
        var initial_effects: [Effect] = []
        if fn_.is_async:
            initial_effects = initial_effects.push(Effect(kind: EffectKind.Async, span: fn_.span))

        val hir_func = HirFunction(
            symbol: fn_symbol_id,
            name: fn_.name,
            type_params: type_params,
            params: params,
            return_type: return_type,
            body: body,
            effects: initial_effects,
            visibility: effective_visibility,
            is_async: fn_.is_async,
            is_static: fn_.is_static,
            is_public: effective_visibility.is_public(),
            is_method: fn_.is_method,
            is_mutable: fn_.is_mutable,
            is_const: fn_.is_const,
            is_extern: fn_.is_extern,
            func_attr: func_attr_opt,
            export_attr: parsed_export_attr,
            driver_manifest_attr: driver_manifest,
            has_suspension: false,
            vhdl_metadata: vhdl_metadata,
            doc_comment: fn_.doc_comment,
            span: fn_.span
        )

        # Validate async functions
        if fn_.is_async:
            self.validate_async_function(hir_func)

        hir_func

    me lower_param(p: Param) -> HirParam:
        val type_ = p.type_.map(self.lower_type(_)) ?? HirType(kind: HirTypeKind.Infer(0, 0), span: p.span)
        val symbol = self.symbols.define(p.name, SymbolKind.Parameter, Some(type_), p.span, Visibility.Private, false, nil)

        HirParam(
            symbol: symbol,
            name: p.name,
            type_: type_,
            default: p.default.map(self.lower_hir_expr(_)),
            span: p.span
        )

    me lower_class(class_: Class) -> HirClass:
        val class_name: text
        val class_type_params: [TypeParam]
        val class_fields: [Field]
        val class_methods: Dict<text, Function>
        val class_visibility: Visibility
        val class_attributes: [Attribute]
        val class_doc_comment: text
        val class_span: Span
        match class_:
            case Class(name, type_params, fields, methods, visibility, _, _, doc_comment, attributes, span):
                class_name = name
                class_type_params = type_params
                class_fields = fields
                class_methods = methods
                class_visibility = visibility
                class_attributes = attributes
                class_doc_comment = doc_comment
                class_span = span

        val symbol = self.symbols.lookup(class_name).unwrap()
        self.symbols.push_scope(ScopeKind.Class)

        var type_params: [HirTypeParam] = []
        for tp in class_type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in class_fields:
            fields = fields.push(self.lower_field(f))

        var methods: Dict<text, SymbolId> = {}
        val previous_self_type = self.current_method_self_type
        self.current_method_self_type = Some(HirType(kind: HirTypeKind.Named(symbol, []), span: class_span))
        for name in class_methods.keys():
            val fn_: Function = class_methods[name]
            val hir_fn = self.lower_function(fn_)
            methods[name] = hir_fn.symbol
        self.current_method_self_type = previous_self_type

        self.symbols.pop_scope()

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(class_name, class_visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout: LayoutAttr = parse_layout_attrs(class_attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != LayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil

        # Parse export attributes (@export("C"))
        val parsed_export_attr: ExportAttr? = parse_export_attrs(class_attributes)
        val platform: PlatformParseResult = parse_platform_attrs(class_attributes)
        val has_platform = platform.variants.len() > 0 or platform.diagnostics.len() > 0

        HirClass(
            symbol: symbol,
            name: class_name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: class_doc_comment,
            span: class_span,
            layout_attr: layout_opt,
            export_attr: parsed_export_attr,
            has_platform_attr: has_platform,
            platform_has_error: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Error),
            platform_has_warning: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Warning),
            platform_diagnostic_message: platform_first_diagnostic_message(platform),
            platform_diagnostic_line: platform_first_diagnostic_line(platform),
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_struct(struct_: Struct) -> HirStruct:
        val struct_name: text
        val struct_type_params: [TypeParam]
        val struct_fields: [Field]
        val struct_visibility: Visibility
        val struct_attributes: [Attribute]
        val struct_doc_comment: text
        val struct_span: Span
        match struct_:
            case Struct(name, type_params, fields, visibility, _, _, doc_comment, attributes, span):
                struct_name = name
                struct_type_params = type_params
                struct_fields = fields
                struct_visibility = visibility
                struct_attributes = attributes
                struct_doc_comment = doc_comment
                struct_span = span

        val symbol = self.symbols.lookup(struct_name).unwrap()
        if custom_primitive_is_name(struct_name):
            custom_primitive_bind_symbol(struct_name, symbol.id)

        var type_params: [HirTypeParam] = []
        for tp in struct_type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in struct_fields:
            fields = fields.push(self.lower_field(f))

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(struct_name, struct_visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout: LayoutAttr = parse_layout_attrs(struct_attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != LayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil
        val platform: PlatformParseResult = parse_platform_attrs(struct_attributes)
        val has_platform = platform.variants.len() > 0 or platform.diagnostics.len() > 0

        HirStruct(
            symbol: symbol,
            name: struct_name,
            type_params: type_params,
            fields: fields,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: struct_doc_comment,
            span: struct_span,
            layout_attr: layout_opt,
            has_platform_attr: has_platform,
            platform_has_error: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Error),
            platform_has_warning: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Warning),
            platform_diagnostic_message: platform_first_diagnostic_message(platform),
            platform_diagnostic_line: platform_first_diagnostic_line(platform),
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_field(f: Field) -> HirField:
        val type_ = self.lower_type(f.type_)
        val symbol = self.symbols.define(f.name, SymbolKind.Field, Some(type_), f.span, f.visibility, false, nil)

        # Lower default without closures to avoid bootstrap SSA issues
        val lowered_default = if f.default.?:
            Some(self.lower_hir_expr(f.default.unwrap()))
        else:
            nil

        HirField(
            symbol: symbol,
            name: f.name,
            type_: type_,
            default: lowered_default,
            visibility: f.visibility,
            is_public: f.visibility.is_public(),
            is_volatile: f.is_volatile,
            has_bits_attr: f.has_bits,
            bits_width: f.bits,
            fixed_address: f.fixed_address,
            span: f.span
        )

    me lower_enum(enum_: Enum) -> HirEnum:
        val enum_name: text
        val enum_type_params: [TypeParam]
        val enum_variants: [Variant]
        val enum_visibility: Visibility
        val enum_doc_comment: text
        val enum_span: Span
        match enum_:
            case Enum(name, type_params, variants, visibility, _, _, doc_comment, span):
                enum_name = name
                enum_type_params = type_params
                enum_variants = variants
                enum_visibility = visibility
                enum_doc_comment = doc_comment
                enum_span = span

        val symbol = self.symbols.lookup(enum_name).unwrap()

        var type_params: [HirTypeParam] = []
        for tp in enum_type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var variants: [HirVariant] = []
        for v in enum_variants:
            variants = variants.push(self.lower_variant(v))

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(enum_name, enum_visibility)

        HirEnum(
            symbol: symbol,
            name: enum_name,
            type_params: type_params,
            variants: variants,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: enum_doc_comment,
            span: enum_span,
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_variant(v: Variant) -> HirVariant:
        val symbol = self.symbols.define(v.name, SymbolKind.EnumVariant, nil, v.span, Visibility.Public, false, nil)

        val kind = match v.kind:
            case Unit:
                HirVariantKind.Unit
            case Tuple(types):
                var hir_types: [HirType] = []
                for t in types:
                    hir_types = hir_types.push(self.lower_type(t))
                HirVariantKind.Tuple(hir_types)
            case Struct(fields):
                var hir_fields: [HirField] = []
                for f in fields:
                    hir_fields = hir_fields.push(self.lower_field(f))
                HirVariantKind.Struct(hir_fields)

        HirVariant(
            symbol: symbol,
            name: v.name,
            kind: kind,
            span: v.span
        )

    me lower_bitfield(bf: Bitfield) -> HirBitfield:
        val symbol = self.symbols.lookup(bf.name).unwrap()

        val backing = self.lower_type(bf.backing_type)
        val layout_attr = parse_layout_attrs(bf.attributes)

        # Pre-compute bit widths for all fields
        var widths: [i64] = []
        for f in bf.fields:
            val w = if f.bits.?:
                f.bits.unwrap()
            elif f.is_reserved:
                0
            else:
                self.infer_bit_width(f.type_)
            widths.push(w)

        # Build index array for field ordering
        var indices: [i64] = []
        var idx: i64 = 0
        while idx < bf.fields.len():
            indices.push(idx)
            idx = idx + 1

        # Sort by bit width descending unless @preserve_order
        if not layout_attr.is_preserve_order:
            var i: i64 = 1
            while i < indices.len():
                var j = i
                while j > 0 and widths[indices[j - 1]] < widths[indices[j]]:
                    val tmp = indices[j]
                    indices[j] = indices[j - 1]
                    indices[j - 1] = tmp
                    j = j - 1
                i = i + 1

        # Lower fields in sorted order with word-straddle avoidance
        var fields: [HirBitfieldField] = []
        var bit_offset: i64 = 0
        val word_bits: i64 = 32
        for sorted_idx in indices:
            val f = bf.fields[sorted_idx]
            val w = widths[sorted_idx]

            if not layout_attr.is_compactq and w > 0 and w < word_bits:
                val word_end = ((bit_offset / word_bits) + 1) * word_bits
                if (bit_offset + w) > word_end:
                    bit_offset = word_end

            val hir_field = self.lower_bitfield_field(f, bit_offset)
            fields = fields.push(hir_field)
            bit_offset = bit_offset + w

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(bf.name, bf.visibility)

        HirBitfield(
            symbol: symbol,
            name: bf.name,
            backing_type: backing,
            fields: fields,
            total_bits: bit_offset,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: bf.doc_comment,
            span: bf.span
        )
