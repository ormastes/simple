# HIR item lowering - function, class, struct, enum, and field lowering.
use compiler.hir.hir_lowering.items.*
# HIR Lowering - Item Lowering
#
# This module handles lowering of top-level items (functions, classes, structs, enums, traits, impls) from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types.{Function, ImportItem, Param}
use compiler.frontend.flat_ast_bridge.{flat_bootstrap_function_count, flat_bootstrap_function_at, flat_bootstrap_function_decl_at}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.expressions.*
use compiler.common.attributes.{parse_layout_attrs, parse_function_attrs, parse_export_attrs, parse_driver_manifest_attrs, parse_platform_attrs, parse_vhdl_hardware_attrs, vhdl_hardware_metadata_default, FunctionAttr, ExportAttr, DriverManifestAttr, DriverManifestAttrKind, VhdlHardwareMetadata}
use compiler.types.type_layout.{LayoutAttr, TypeLayoutKind, PlatformParseResult, PlatformDiagnosticLevel, PlatformLayoutDiagnostic}
use compiler.common.dependency.visibility.{Visibility}
use compiler.core.{decl_get_body, decl_get_name, decl_get_param_names, decl_get_param_types, decl_get_ret_type}
use compiler.core.{decl_is_gpu_kernel, decl_get_gpu_target_text, decl_get_gpu_backends_text}
use compiler.core.{STMT_EXPR, STMT_VAL_DECL, STMT_VAR_DECL, STMT_RETURN, stmt_get_tag, stmt_get_expr, stmt_get_name, stmt_get_type}
use compiler.core.{EXPR_INT_LIT, EXPR_STRING_LIT, EXPR_BOOL_LIT, EXPR_NIL_LIT, EXPR_IDENT, EXPR_BINARY, EXPR_CALL, EXPR_FIELD_ACCESS, EXPR_METHOD_CALL, EXPR_BLOCK, EXPR_RETURN, expr_get_tag, expr_get_int, expr_get_str, expr_get_left, expr_get_right, expr_get_args, expr_get_stmts}
use compiler.core.{TOK_MINUS, TOK_STAR, TOK_SLASH, TOK_PERCENT, TOK_EQ, TOK_NOT_EQ, TOK_LT, TOK_LT_EQ, TOK_GT, TOK_GT_EQ}
use compiler.frontend.core.types.{TYPE_VOID, TYPE_BOOL, TYPE_I64, TYPE_TEXT, custom_primitive_bind_symbol, custom_primitive_is_name}
use compiler.frontend.core.types.{primitive_integer_bit_width_from_name, custom_primitive_integer_bit_width_by_name}
use compiler.core.{int_to_str}
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text

fn hir_lower_env_get(key: text) -> text:
    rt_env_get(key)

fn hir_lower_diag_enabled() -> bool:
    val phase = hir_lower_env_get("SIMPLE_COMPILER_PHASE_PROFILE") ?? ""
    val trace = hir_lower_env_get("SIMPLE_COMPILER_TRACE") ?? ""
    val diag = hir_lower_env_get("SIMPLE_BOOTSTRAP_DIAG") ?? ""
    if phase == "1":
        return true
    if trace == "1":
        return true
    diag == "1"

impl HirLowering:
    me lower_bootstrap_flat_function(decl_idx: i64) -> HirFunction:
        val span = Span.empty()
        val name = decl_get_name(decl_idx)
        eprint("[hir-lower] flat_function:start {name}")
        val symbol = bootstrap_hir_symbol_for_name(name)
        self.current_function = Some(symbol)
        self.symbols.push_scope(ScopeKind.Function)
        eprint("[hir-lower] flat_function:params:start {name}")
        val param_count = 0
        eprint("[hir-lower] flat_function:params:count {name} {param_count}")
        var params: [HirParam] = []
        var pi = 0
        while pi < param_count:
            eprint("[hir-lower] flat_function:param {name} {pi}")
            val p_type = HirType(kind: HirTypeKind.Infer(0, 0), span: span)
            val p_sym = self.symbols.define("", SymbolKind.Parameter, Some(p_type), span, Visibility.Private, false, nil)
            params.push(HirParam(symbol: p_sym, name: "", type_: p_type, has_default: false, default: HirExpr(kind: HirExprKind.NilLit, has_type_: true, type_: HirType(kind: HirTypeKind.Unit, span: span), span: span), span: span, is_mutable: false))
            pi = pi + 1
        eprint("[hir-lower] flat_function:body:start {name}")
        val body_ids = decl_get_body(decl_idx)
        eprint("[hir-lower] flat_function:body:count {name} {body_ids.len()}")
        val body = self.lower_bootstrap_flat_block(body_ids)
        eprint("[hir-lower] flat_function:body:done {name}")
        self.symbols.pop_scope()
        self.current_function = nil
        eprint("[hir-lower] flat_function:done {name}")
        val func_attr_opt: FunctionAttr? = if decl_is_gpu_kernel[decl_idx] != 0:
            var fa = FunctionAttr.default()
            fa.is_gpu_kernel = true
            fa.gpu_target = decl_get_gpu_target_text(decl_idx)
            fa.gpu_backends = decl_get_gpu_backends_text(decl_idx)
            Some(fa)
        else:
            nil
        HirFunction(
            symbol: symbol,
            name: name,
            type_params: [],
            params: params,
            return_type: self.bootstrap_hir_type_from_tag(decl_get_ret_type(decl_idx)),
            body: body,
            effects: [],
            visibility: Visibility.Public,
            is_async: false,
            is_static: false,
            is_public: true,
            is_method: false,
            is_mutable: false,
            is_const: false,
            is_extern: false,
            func_attr: func_attr_opt,
            has_export_attr: false,
            export_attr: nil,
            has_driver_manifest_attr: false,
            driver_manifest_attr: DriverManifestAttr(kind: DriverManifestAttrKind.Driver, driver_class: 0, vendor: 0, device_ids: [], version: "", abi: ""),
            has_suspension: false,
            has_vhdl_metadata: false,
            vhdl_metadata: vhdl_hardware_metadata_default(),
            has_doc_comment: false,
            doc_comment: "",
            span: span
        )

    me lower_function(fn_: Function) -> HirFunction:
        val bootstrap_diag = (hir_lower_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and hir_lower_diag_enabled()
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:start {fn_.name}")
        var fn_symbol_id = SymbolId(id: -1)
        var fn_symbol_name = fn_.name
        if fn_.is_method and self.current_method_self_type.?:
            match self.current_method_self_type.unwrap().kind:
                case Named(owner_symbol, _):
                    fn_symbol_name = self.symbols.method_symbol_name(owner_symbol, fn_.name)
                case _: ()
        val fn_symbol_kind = if fn_.is_method and not fn_.is_static: SymbolKind.Method else: SymbolKind.Function
        if (hir_lower_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and not fn_.is_method:
            fn_symbol_id = bootstrap_hir_symbol_for_name(fn_.name)
        else:
            val fn_symbol_lookup = self.symbols.lookup(fn_symbol_name)
            if val found_symbol = fn_symbol_lookup:
                # `if val` can still bind nil on the seed interpreter when the
                # lookup fails. Guard the payload explicitly so we never stash
                # `Some(nil)` in current_function or emit a nil symbol id into
                # downstream `.id` consumers.
                if found_symbol == nil:
                    fn_symbol_id = self.symbols.define(fn_symbol_name, fn_symbol_kind, nil, fn_.span, fn_.visibility, false, nil)
                else:
                    fn_symbol_id = found_symbol
            else:
                fn_symbol_id = self.symbols.define(fn_symbol_name, fn_symbol_kind, nil, fn_.span, fn_.visibility, false, nil)
        self.current_function = Some(fn_symbol_id)
        # NOTE(#133): push the function scope unconditionally, including under
        # SIMPLE_BOOTSTRAP. Bug #133: params were never lowered under bootstrap
        # (see below), so the `define` emitted zero params while callers passed
        # real args (`call ... (nil, nil)`) and the body's own identifier
        # references (e.g. `args`, `i`) resolved to `i64 undef` because no
        # scope/symbol existed for them. Body identifiers resolve through
        # `self.symbols.lookup(name)` (expressions.spl Ident arm) regardless of
        # bootstrap mode -- only the function's OWN symbol uses the name-based
        # `bootstrap_hir_symbol_for_name` scheme. Pushing the scope here and
        # lowering params below (via the existing `lower_param`, which calls
        # `self.symbols.define`) makes `args`/`i` resolve to real param locals
        # under bootstrap too.
        self.symbols.push_scope(ScopeKind.Function)
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:scope {fn_.name}")

        # Lower type parameters
        var type_params: [HirTypeParam] = []
        var tpi = 0
        while tpi < fn_.type_params.len():
            type_params = type_params.push(self.lower_type_param(fn_.type_params[tpi]))
            tpi = tpi + 1
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:type_params {fn_.name}")

        # Phase A gate (#158): generic functions (`fn id<T>(x: T) -> T`) are
        # NOT monomorphized on the native --entry build path -- the erased
        # `T` parameter/return type silently degrades to `Infer`/ANY, which
        # previously made calls to generic functions return 0 instead of the
        # real argument (silent-wrong, no diagnostic). Now that
        # `Function.type_params` is threaded through from the frontend
        # (convert_decl_fn in the flat-AST bridge), fail loudly here instead
        # of proceeding into codegen with an unmonomorphized generic. Real
        # monomorphization is tracked separately (#158 Phase B) -- this is a
        # deliberate hard stop, not a workaround.
        if fn_.type_params.len() > 0:
            self.error("generic functions are not supported on the native build path yet: fn '{fn_.name}' declares type parameter(s); monomorphization is not implemented (#158 Phase B)", fn_.span)

        # Lower parameters
        # NOTE(#133): lowered unconditionally, including under SIMPLE_BOOTSTRAP.
        # Previously this whole block was skipped under bootstrap, so `params`
        # stayed empty for every bootstrap entry function -- the MIR `define`
        # emitted zero params while callers passed real args (mismatched arity,
        # `call ... (nil, nil)`), and the body's references to those params
        # (e.g. `args`, `i` in bootstrap_output_from_args) resolved to `i64
        # undef` since no symbol/local existed for them. `lower_param` (below)
        # calls `self.symbols.define`, and the body's Ident lowering resolves
        # names via `self.symbols.lookup` (scope-based, not bootstrap's
        # name-based function-symbol scheme) -- so lowering params the same way
        # as non-bootstrap, now that the function scope above is always pushed,
        # makes the body's param references bind correctly under bootstrap too.
        var params: [HirParam] = []
        val fn_params = function_params(fn_)
        # Compute the implicit-`self` condition with nested checks + an
        # intermediate bool rather than one compound `A and B and C and
        # (D or E)` expression: the cranelift backend mis-lowered the fused
        # form, nil-checking the boolean result of the `(len()==0 or
        # [0].name != ...)` sub-expression as if it were a heap pointer,
        # trapping with "field access on nil receiver" (SIGILL) even for a
        # plain non-method `fn main()`. Short-circuiting via nested ifs keeps
        # the array-indexing operand out of the fused boolean entirely.
        # `me` is Simple's explicit MUTABLE receiver written in the parameter
        # list (`fn selfset(me): me.x = 41`) -- the by-reference counterpart of
        # `self`. The frontend (parser_decls_use.spl parse_class_body_method)
        # already recognizes a leading `me` as the receiver: it backfills its
        # struct type and marks the method mutable, so it arrives here as
        # fn_params[0] named "me" and typed. Treating it like a plain param
        # (name != "self") wrongly SYNTHESIZED a second implicit `self`,
        # demoting the real `me` to slot 1 where it received no call argument --
        # `c.getx()` read `me` as undef (garbage pointer) and `me.x = 41` stored
        # into nothing (Bug native_me_receiver_no_mutate). Exclude "me" here so
        # it stays the sole receiver, exactly like an explicit `self`.
        var needs_implicit_self = false
        if fn_.is_method and not fn_.is_static and self.current_method_self_type.?:
            if fn_params.len() == 0:
                needs_implicit_self = true
            elif fn_params[0].name != "self" and fn_params[0].name != "me":
                needs_implicit_self = true
        if needs_implicit_self:
            val self_type = self.current_method_self_type.unwrap()
            val self_symbol = self.symbols.define("self", SymbolKind.Parameter, Some(self_type), fn_.span, Visibility.Private, false, nil)
            params = params.push(HirParam(
                symbol: self_symbol,
                name: "self",
                type_: self_type,
                has_default: false,
                default: HirExpr(kind: HirExprKind.NilLit, has_type_: false, type_: HirType(kind: HirTypeKind.Unit, span: fn_.span), span: fn_.span),
                span: fn_.span,
                is_mutable: false
            ))
        var pi = 0
        while pi < fn_params.len():
            params = params.push(self.lower_param(fn_params[pi]))
            pi = pi + 1
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:params {fn_.name}")

        # Lower return type — use explicit check instead of .map() ?? default
        # to avoid crash with null coalescing on Option.map result
        var return_type = HirType(kind: HirTypeKind.Unit, span: fn_.span)
        if (hir_lower_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            return_type = bootstrap_builtin_return_type(fn_.name, fn_.span)
        else:
            # Gate on has_return_type, not `return_type.?`: return_type is a
            # non-optional Type whose placeholder for an omitted annotation is a
            # bare `Infer` node, so `.?` is always true and we would lower that
            # Infer placeholder — which segfaults in lower_type_list. A function
            # without an explicit return type keeps the default Unit result.
            if fn_.has_return_type:
                return_type = self.lower_type(fn_.return_type)
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:return_type {fn_.name}")

        # Lower body. A function WITHOUT an explicit return type returns Unit, so
        # its body is not in value position — use `lower_hir_block_unit`, which
        # keeps a trailing expression-statement (`fn main(): print(...)`) IN
        # `stmts` and never extracts a trailing value. This sidesteps the seed's
        # ANY-erased `case Expr(expr)` mis-extraction that stored a garbage
        # HirExpr as `block.value` (iteration 14), which made the interpreter's
        # trailing-value eval silently no-op (or SIGSEGV on a typed rebind). A
        # value IS needed only when the function returns a real type, so the
        # value-extracting path is kept for `has_return_type`.
        val body = if fn_.has_return_type:
            self.lower_hir_block(fn_.body)
        else:
            self.lower_hir_block_unit(fn_.body)
        if bootstrap_diag:
            eprint("[hir-lower] lower_function:body {fn_.name}")

        # Untyped-return inference (native --entry path). A function with NO
        # declared return type defaults to Unit above -- but if its body has
        # an explicit `return <value>`, that default is wrong: the backend
        # still emits `void`, yet MIR carries a real value out of the
        # `return`, producing invalid LLVM IR (`ret void %t0` after a bogus
        # bitcast) that llc rejects with a cryptic, far-from-the-cause error.
        # The actual inference (and, when it can't agree on one simple type,
        # the fatal route-(b) error) already ran BEFORE this function's body
        # was lowered, in the module's up-front signature-declaration pass
        # (`infer_untyped_return_type` in module_lowering.spl) -- it has to
        # run that early so CALLERS of this function see the right type too,
        # not just this function's own `ret` instruction. Here we just pick
        # up whatever that pass decided, by reading it back off this
        # function's own symbol. Gated out of SIMPLE_BOOTSTRAP: that path
        # computes return_type via `bootstrap_builtin_return_type` above and
        # is owned by the parallel bootstrap-redeploy lane (module_lowering's
        # inference pass is itself skipped entirely under plain bootstrap).
        # `and fn_.name != "main"`: the synthesized entry `main` (bare-statement
        # program) is not registered like a normal function, so `lookup("main")`
        # binds a nil `fn_symbol_id` that no `== nil`/`.?` check rejects (seed
        # nil-representation limit); passing it to get_symbol_type destructures the
        # nil and traps "field access on nil receiver", dropping the in-guest
        # interpreter's main. main's untyped body returns Unit (defaulted above),
        # so it needs none of this user-function return inference.
        if (not fn_.has_return_type) and (hir_lower_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1" and fn_.name != "main":
            val fn_sym_type = self.symbols.get_symbol_type(fn_symbol_id)
            if fn_sym_type.?:
                match fn_sym_type.unwrap().kind:
                    case HirTypeKind.Function(_, ret, _):
                        return_type = ret
                    case _:
                        pass

        # NOTE(#133): pop unconditionally, matching the unconditional push above.
        self.symbols.pop_scope()
        self.current_function = nil

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(fn_.name, fn_.visibility)

        # Parse function attributes (@entry, @naked, @noreturn, @section, @interrupt)
        var fa: FunctionAttr = parse_function_attrs(fn_.attributes)
        if fn_.is_kernel:
            fa.is_gpu_kernel = true
        val func_attr_opt: FunctionAttr? = if fa.is_entry or fa.is_naked or fa.is_noreturn or fa.section.? or fa.is_interrupt or fa.is_alloc or fa.is_no_alloc or fa.is_gpu_kernel or fa.gpu_target.len() > 0 or fa.gpu_backends.len() > 0 or fa.is_simd or fa.has_fast_math or fa.simd_enable or fa.simd_disable or fa.simd_prefer_scalable:
            Some(fa)
        else:
            nil

        # Parse export attributes (@export("C"))
        val parsed_export_attr: ExportAttr? = parse_export_attrs(fn_.attributes)
        val driver_manifest: DriverManifestAttr? = parse_driver_manifest_attrs(fn_.attributes)
        val vhdl_metadata: VhdlHardwareMetadata = parse_vhdl_hardware_attrs(fn_.attributes)

        # Seed effects from is_async annotation.
        # The full effect pass (effect_pass.spl) will refine these later.
        var initial_effects: [Effect] = []
        if fn_.is_async:
            initial_effects = initial_effects.push(Effect(kind: EffectKind.Async, span: fn_.span))

        val hir_func = HirFunction(
            symbol: fn_symbol_id,
            name: fn_.name,
            type_params: type_params,
            params: params,
            return_type: return_type,
            body: body,
            effects: initial_effects,
            visibility: effective_visibility,
            is_async: fn_.is_async,
            is_static: fn_.is_static,
            is_public: fn_.is_public,
            is_method: fn_.is_method,
            is_mutable: fn_.is_mutable,
            is_const: fn_.is_const,
            is_extern: fn_.is_extern,
            func_attr: func_attr_opt,
            # ALL desugared has_* flags passed explicitly, in declaration
            # order: the seed fills partial named constructions POSITIONALLY,
            # shifting every later field one slot (same bug class as
            # HirCallArg.value — bug doc iteration 18).
            has_export_attr: parsed_export_attr.?,
            export_attr: parsed_export_attr,
            has_driver_manifest_attr: driver_manifest.?,
            driver_manifest_attr: driver_manifest,
            has_suspension: false,
            has_vhdl_metadata: vhdl_metadata.is_hardware,
            vhdl_metadata: vhdl_metadata,
            has_doc_comment: fn_.has_doc_comment,
            doc_comment: fn_.doc_comment,
            span: fn_.span
        )

        # Validate async functions
        if fn_.is_async:
            self.validate_async_fn(hir_func)

        hir_func

    me lower_param(p: Param) -> HirParam:
        val type_ = self.lower_type(p.type_)
        val symbol = self.symbols.define(p.name, SymbolKind.Parameter, Some(type_), p.span, Visibility.Private, false, nil)
        val default_ = if p.default.?: self.lower_hir_expr(p.default) else: nil

        HirParam(
            symbol: symbol,
            name: p.name,
            type_: type_,
            default: default_,
            span: p.span,
            is_mutable: p.is_mutable
        )

    me lower_class(class_: Class) -> HirClass:
        # DIRECT field access, NOT `match class_: case Class(...)` — struct
        # destructure yields garbage positional fields on stage4 (same hazard as
        # lower_struct; bug doc iteration 17/20 #86).
        val class_name: text = class_.name
        val class_type_params: [TypeParam] = class_.type_params
        val class_fields: [Field] = class_.fields
        val class_methods: Dict<text, Function> = class_.methods
        val class_visibility: Visibility = class_.visibility
        val class_is_public: bool = class_.is_public
        val class_attributes: [Attribute] = class_.attributes
        val class_doc_comment: text = class_.doc_comment
        val class_span: Span = class_.span

        val symbol = self.symbols.lookup_or_invalid(class_name)
        self.symbols.push_scope(ScopeKind.Class)

        var type_params: [HirTypeParam] = []
        for tp in class_type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in class_fields:
            val cf: Field = f
            fields = fields.push(self.lower_field(cf))

        var methods: Dict<text, SymbolId> = {}
        val previous_self_type = self.current_method_self_type
        self.current_method_self_type = Some(HirType(kind: HirTypeKind.Named(symbol, []), span: class_span))
        for name in class_methods.keys():
            val fn_: Function = class_methods[name]
            val hir_fn = self.lower_function(fn_)
            methods[name] = hir_fn.symbol
        self.current_method_self_type = previous_self_type

        self.symbols.pop_scope()

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(class_name, class_visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout: LayoutAttr = parse_layout_attrs(class_attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != TypeLayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil

        # Parse export attributes (@export("C"))
        val parsed_export_attr: ExportAttr? = parse_export_attrs(class_attributes)
        val platform: PlatformParseResult = parse_platform_attrs(class_attributes)
        val has_platform = platform.variants.len() > 0 or platform.diagnostics.len() > 0

        HirClass(
            symbol: symbol,
            name: class_name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            visibility: effective_visibility,
            is_public: class_is_public,
            doc_comment: class_doc_comment,
            span: class_span,
            layout_attr: layout_opt,
            export_attr: parsed_export_attr,
            has_platform_attr: has_platform,
            platform_has_error: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Error),
            platform_has_warning: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Warning),
            platform_diagnostic_message: platform_first_diagnostic_message(platform),
            platform_diagnostic_line: platform_first_diagnostic_line(platform),
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_struct(struct_: Struct) -> HirStruct:
        # DIRECT field access, NOT `match struct_: case Struct(...)`: the struct
        # destructure yields GARBAGE positional fields on stage4 (struct-pattern
        # destructure hazard, bug doc iteration 17/20 #86). The garbage `fields`
        # array then flows into lower_field -> lower_type where the corrupt
        # field-type Type pointer crashes the TypeKind match (SIGSEGV on any
        # struct/class run file). A typed receiver's direct field access
        # resolves correct offsets.
        val struct_name: text = struct_.name
        val struct_type_params: [TypeParam] = struct_.type_params
        val struct_fields: [Field] = struct_.fields
        val struct_visibility: Visibility = struct_.visibility
        val struct_is_public: bool = struct_.is_public
        val struct_attributes: [Attribute] = struct_.attributes
        val struct_doc_comment: text = struct_.doc_comment
        val struct_span: Span = struct_.span

        val symbol = self.symbols.lookup_or_invalid(struct_name)
        if custom_primitive_is_name(struct_name):
            custom_primitive_bind_symbol(struct_name, symbol.id)

        var type_params: [HirTypeParam] = []
        for tp in struct_type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in struct_fields:
            val sf: Field = f
            fields = fields.push(self.lower_field(sf))

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(struct_name, struct_visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout: LayoutAttr = parse_layout_attrs(struct_attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != TypeLayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil
        val platform: PlatformParseResult = parse_platform_attrs(struct_attributes)
        val has_platform = platform.variants.len() > 0 or platform.diagnostics.len() > 0

        HirStruct(
            symbol: symbol,
            name: struct_name,
            type_params: type_params,
            fields: fields,
            visibility: effective_visibility,
            is_public: struct_is_public,
            doc_comment: struct_doc_comment,
            span: struct_span,
            layout_attr: layout_opt,
            has_platform_attr: has_platform,
            platform_has_error: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Error),
            platform_has_warning: platform_has_diagnostic_level(platform, PlatformDiagnosticLevel.Warning),
            platform_diagnostic_message: platform_first_diagnostic_message(platform),
            platform_diagnostic_line: platform_first_diagnostic_line(platform),
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_field(f: Field) -> HirField:
        # Typed rebind before any field access. On the stage4 unstub path the
        # `f` param arrives ANY-erased (callers iterate `for f in struct_fields`
        # / `class_fields` on an ANY-typed [Field]); reading `f.type_`/`f.name`
        # off an ANY receiver hits the seed's most-fields-wins field resolver ->
        # WRONG field index -> nil -> SIGSEGV inside lower_type. Binding to a
        # `Field`-typed local restores correct field-index resolution (same
        # idiom as interpreter process_module; bug: struct/class run file
        # SIGSEGVs on the unstub path, iteration 19).
        val fld: Field = f
        val fld_type: Type = fld.type_
        val type_ = self.lower_type(fld_type)
        val symbol = self.symbols.define(fld.name, SymbolKind.Field, Some(type_), fld.span, fld.visibility, false, nil)

        # Lower default without closures to avoid bootstrap SSA issues.
        # `Field.default` is a DESUGARED plain Expr field gated by `has_default`
        # (NOT an Optional): the old `fld.default.?` / `.unwrap()` applied Option
        # semantics to a plain field, which on stage4 mis-evaluates to true and
        # unwraps a nil Expr -> lower_hir_expr(nil) -> "field access on nil
        # receiver" SIGILL (bug doc iteration 20 #86; same class as the iter14
        # eval_block trailing-value fix). Gate on has_default + use default
        # directly.
        val lowered_default = if fld.has_default:
            Some(self.lower_hir_expr(fld.default))
        else:
            nil

        HirField(
            symbol: symbol,
            name: fld.name,
            type_: type_,
            default: lowered_default,
            visibility: fld.visibility,
            is_public: fld.is_public,
            is_volatile: fld.is_volatile,
            has_bits_attr: fld.has_bits,
            bits_width: fld.bits,
            fixed_address: fld.fixed_address,
            span: fld.span
        )

    me lower_enum(enum_: Enum) -> HirEnum:
        match enum_:
            case Enum(name, type_params, variants, visibility, is_public, _, doc_comment, span):
                val symbol = self.symbols.lookup_or_invalid(name)
                var hir_type_params: [HirTypeParam] = []
                for tp in type_params:
                    hir_type_params = hir_type_params.push(self.lower_type_param(tp))
                var hir_variants: [HirVariant] = []
                for v in variants:
                    hir_variants = hir_variants.push(self.lower_variant(v))
                HirEnum(
                    symbol: symbol,
                    name: name,
                    type_params: hir_type_params,
                    variants: hir_variants,
                    visibility: self.compute_visibility(name, visibility),
                    is_public: is_public,
                    doc_comment: doc_comment,
                    span: span,
                    is_generic_template: false,
                    specialization_of: nil,
                    type_bindings: {}
                )

    me lower_variant(v: Variant) -> HirVariant:
        val symbol = self.symbols.define(v.name, SymbolKind.EnumVariant, nil, v.span, Visibility.Public, false, nil)

        val kind = match v.kind:
            case Unit:
                HirVariantKind.Unit
            case Tuple(types):
                var hir_types: [HirType] = []
                for t in types:
                    hir_types = hir_types.push(self.lower_type(t))
                HirVariantKind.Tuple(hir_types)
            case Struct(fields):
                var hir_fields: [HirField] = []
                for f in fields:
                    hir_fields = hir_fields.push(self.lower_field(f))
                HirVariantKind.Struct(hir_fields)

        HirVariant(
            symbol: symbol,
            name: v.name,
            kind: kind,
            span: v.span
        )

    me lower_bitfield(bf: Bitfield) -> HirBitfield:
        # NOTE: previously destructured via `val x: T` pre-declarations
        # assigned inside a `match bf: case Bitfield(...)` arm -- the same
        # interpreter defect documented for MirLowering.lower_stmt (values
        # bind to unresolved placeholders; see doc/08_tracking/bug/
        # vhdl_backend_spec_remaining_failures_2026-07-02.md, "Interpreter
        # defects" #2). Bitfield is a plain struct: read fields directly.
        val bitfield_name = bf.name
        val bitfield_backing_type = bf.backing_type
        val bitfield_fields = bf.fields
        val bitfield_visibility = bf.visibility
        val bitfield_is_public = bf.is_public
        val bitfield_attributes = bf.attributes
        val bitfield_doc_comment = bf.doc_comment
        val bitfield_span = bf.span

        val symbol = self.symbols.lookup_or_invalid(bitfield_name)

        val backing = self.lower_type(bitfield_backing_type)
        val layout_attr = parse_layout_attrs(bitfield_attributes)

        # Pre-compute bit widths for all fields
        var widths: [i64] = []
        for f in bitfield_fields:
            val w = if f.bits.?:
                f.bits.unwrap()
            elif f.is_reserved:
                0
            else:
                self.infer_bit_width(f.type_)
            widths.push(w)

        # Build index array for field ordering
        var indices: [i64] = []
        var idx: i64 = 0
        while idx < bitfield_fields.len():
            indices.push(idx)
            idx = idx + 1

        # Sort by bit width descending unless @preserve_order
        if not layout_attr.is_preserve_order:
            var i: i64 = 1
            while i < indices.len():
                var j = i
                while j > 0 and widths[indices[j - 1]] < widths[indices[j]]:
                    val tmp = indices[j]
                    indices[j] = indices[j - 1]
                    indices[j - 1] = tmp
                    j = j - 1
                i = i + 1

        # Lower fields in sorted order with word-straddle avoidance
        var fields: [HirBitfieldField] = []
        var bit_offset: i64 = 0
        val word_bits: i64 = 32
        for sorted_idx in indices:
            val f = bitfield_fields[sorted_idx]
            val w = widths[sorted_idx]

            if not layout_attr.is_compactq and w > 0 and w < word_bits:
                val word_end = ((bit_offset / word_bits) + 1) * word_bits
                if (bit_offset + w) > word_end:
                    bit_offset = word_end

            val hir_field = self.lower_bitfield_field(f, bit_offset)
            fields = fields.push(hir_field)
            bit_offset = bit_offset + w

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(bitfield_name, bitfield_visibility)

        HirBitfield(
            symbol: symbol,
            name: bitfield_name,
            backing_type: backing,
            fields: fields,
            total_bits: bit_offset,
            visibility: effective_visibility,
            is_public: bitfield_is_public,
            doc_comment: bitfield_doc_comment,
            span: bitfield_span
        )
