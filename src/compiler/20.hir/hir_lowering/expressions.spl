# HIR Lowering - Expression Lowering
#
# This module handles lowering of expressions from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.statements.*
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text

fn hir_expr_env_get(key: text) -> text:
    rt_env_get(key)

fn hir_expr_kind_disc(k: ExprKind) -> i64:
    match k:
        case ExprKind.Block(_):
            1138084884  # hash("Block")
        case ExprKind.Field(_, _):
            21232742  # hash("Field")
        case _:
            0

fn is_interp_builtin_fn(name: text) -> bool:
    """Free-function builtins dispatched by NAME in the HIR interpreter
    (70.backend/backend/interpreter_calls.spl lookup_builtin_tag)."""
    (name == "print" or name == "println" or name == "to_string" or
     name == "type_of" or name == "clone" or name == "file_exists" or
     name == "file_read" or name == "file_write" or name == "file_delete" or
     name == "env_get" or name == "env_set")

fn is_bootstrap_builtin_fn(name: text) -> bool:
    name == "get_args" or
    name == "eprint" or
    name == "bootstrap_version" or
    name == "native_build_help" or
    name == "compile_result_exit" or
    name == "bootstrap_output_from_args" or
    name == "run_native_build_bootstrap" or
    name == "get_cli_args" or
    name == "main"

fn hir_bootstrap_i64_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Int(64, true), span: span)

fn hir_bootstrap_text_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Str, span: span)

fn hir_bootstrap_text_array_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Array(hir_bootstrap_text_type(span), nil), span: span)

fn hir_bootstrap_unit_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Unit, span: span)

fn bootstrap_builtin_return_type(name: text, span: Span) -> HirType:
    if name == "get_args" or name == "get_cli_args":
        return hir_bootstrap_text_array_type(span)
    if name == "bootstrap_version" or name == "bootstrap_output_from_args":
        return hir_bootstrap_text_type(span)
    if name == "eprint":
        return hir_bootstrap_unit_type(span)
    hir_bootstrap_i64_type(span)

fn bootstrap_builtin_signature(name: text, span: Span) -> HirType:
    HirType(kind: HirTypeKind.Function([], bootstrap_builtin_return_type(name, span), []), span: span)

# Expression Lowering
# ============================================================================

impl HirLowering:
    me lower_host_gpu_lane_payload(marker: Expr) -> i64:
        match marker.kind:
            case ExprKind.MethodCall(_receiver, method, args):
                if method != "later":
                    return 0
                for arg in args:
                    if arg.has_name and arg.name == "max_packet":
                        match arg.value.kind:
                            case ExprKind.IntLit(value):
                                if value > 0:
                                    return value
                                return 0
                            case _:
                                pass
                if args.len() == 1:
                    match args[0].value.kind:
                        case ExprKind.IntLit(value):
                            if value > 0:
                                return value
                            return 0
                        case _:
                            pass
                0
            case _:
                0

    me lower_host_gpu_lane_body(body_expr: Expr) -> HirBlock:
        match body_expr.kind:
            case ExprKind.Block(block):
                self.lower_hir_block(block)
            case _:
                HirBlock(stmts: [], value: Some(self.lower_hir_expr(body_expr)), span: body_expr.span)

    me try_lower_host_gpu_lane_expr(e: Expr) -> HirExpr?:
        match e.kind:
            case ExprKind.Call(callee, args):
                # Typed rebinds of extracted pattern payloads: reading `.kind`
                # directly off the extracted ANY-ish payload misreads on stage4
                # (most-fields-wins), making `name == "host"` pass on garbage
                # and misrouting print(1+1) into HostGpuLane → mono scan SEGV
                # (bug doc iteration 17/18).
                val callee_t: Expr = callee
                val args_t: [CallArg] = args
                var lane_code: i64 = 0
                val callee_kind_t: ExprKind = callee_t.kind
                match callee_kind_t:
                    case ExprKind.Ident(name):
                        val name_t: text = name
                        if name_t == "host":
                            lane_code = 1
                        elif name_t == "gpu":
                            lane_code = 2
                    case _:
                        pass
                if lane_code == 0:
                    return nil
                if args_t.len() != 2:
                    return nil
                val arg1_t: Expr = args_t[1].value
                val arg1_kind_t: ExprKind = arg1_t.kind
                match arg1_kind_t:
                    case ExprKind.Lambda(_params, lambda_body):
                        val lambda_body_t: Expr = lambda_body
                        val arg0_t: Expr = args_t[0].value
                        val marker = self.lower_hir_expr(arg0_t)
                        val payload_size = self.lower_host_gpu_lane_payload(arg0_t)
                        val body = self.lower_host_gpu_lane_body(lambda_body_t)
                        Some(HirExpr(
                            kind: HirExprKind.HostGpuLane(lane_code, payload_size, marker, body),
                            type_: nil,
                            span: e.span
                        ))
                    case _:
                        nil
            case _:
                nil

    me lower_unresolved_ident(name: text, span: Span) -> HirExprKind:
        """Unresolved identifier: known interpreter builtins (print, ...) are
        not in the symbol table on the single-file/-c unstub path — define
        them on first use and emit NamedVar so the HIR interpreter can
        dispatch by name (process_module registers every table symbol as a
        global Function value). Everything else stays an error."""
        val is_bootstrap_builtin = (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and is_bootstrap_builtin_fn(name)
        if is_interp_builtin_fn(name) or is_bootstrap_builtin:
            val symbol_type = if is_bootstrap_builtin:
                bootstrap_builtin_signature(name, span)
            else:
                nil
            val bsym = self.symbols.define(name, SymbolKind.Function, symbol_type, span, false, false, nil)
            HirExprKind.NamedVar(bsym, name)
        else:
            self.error("unresolved name: {name}", span)
            HirExprKind.Error

    me lower_hir_expr(e: Expr) -> HirExpr:
        # Probes UNGATED: Trap D (iteration 17) — env-gated probes are mute in
        # hir_lowering modules. Remove before deploy.
        # DIRECT typed field read, NOT `match e: case Expr(k, _): k`: the struct
        # pattern "matches" on stage4 but destructures a GARBAGE payload (observed
        # kind_disc=823890719) — and the direct read shows the same garbage, so
        # `e` itself is corrupted upstream (bug doc iteration 17).
        val expr_kind_value: ExprKind = e.kind
        val host_gpu_lane = self.try_lower_host_gpu_lane_expr(e)
        if val lowered_host_gpu_lane = host_gpu_lane:
            return lowered_host_gpu_lane
        if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_expr:kind")
        # SEED PATTERN HAZARD (bug doc iteration 18): when a variant pattern's
        # name is ALSO a struct name in scope (`struct Field` in
        # parser_types.spl, `struct Block` in parser_types_expr.spl), the seed
        # compiles the `case ExprKind.Field(...)` TEST as a struct pattern =
        # ALWAYS TRUE (compiler_rust codegen/instr/pattern.rs struct/tuple
        # fallback is `iconst 1`), while payload bindings still extract enum
        # payloads. Such an arm swallows every value that reaches it in the big
        # match below (proven: a Call landed in the Field arm, [LHE-ARMX]
        # Field). Pre-dispatch these variants by explicit discriminant
        # (rt_enum_discriminant = DefaultHasher(variant name) truncated to u32)
        # and keep them OUT of the big match.
        val kind_disc_v: i64 = hir_expr_kind_disc(expr_kind_value)
        if kind_disc_v == 21232742:  # hash("Field")
            match expr_kind_value:
                case ExprKind.Field(base, field):
                    val fld_base_t: Expr = base
                    val fld_name_t: text = field
                    return HirExpr(kind: HirExprKind.Field(self.lower_hir_expr(fld_base_t), fld_name_t, nil), type_: nil, span: e.span)
                case _:
                    pass
        if kind_disc_v == 1138084884:  # hash("Block")
            match expr_kind_value:
                case ExprKind.Block(block):
                    return HirExpr(kind: HirExprKind.Block(self.lower_hir_block(block)), type_: nil, span: e.span)
                case _:
                    pass
        val kind = match expr_kind_value:
            case ExprKind.IntLit(value):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:int")
                HirExprKind.IntLit(value, nil)

            case ExprKind.FloatLit(value):
                HirExprKind.FloatLit(value, nil)

            case ExprKind.StringLit(value, interps):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:string")
                val hir_interps = if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    nil
                elif interps.?:
                    self.lower_interpolation_list(interps)
                else:
                    nil
                HirExprKind.StringLit(value, hir_interps)

            case ExprKind.BoolLit(value):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:bool")
                HirExprKind.BoolLit(value)

            # QUALIFIED no-payload patterns required: a bare `case NilLit:` whose
            # variant name exists in MULTIPLE enums (ExprKind AND HirExprKind)
            # compiles as an IRREFUTABLE binding on stage4 — it matched a Call
            # value and swallowed every expression into HirExprKind.NilLit, making
            # all programs silent no-ops (bug doc iteration 17, decisive repro:
            # [FBC] call=823890719 valid, yet [LHE-ARM] NilLit fired).
            case ExprKind.NilLit:
                HirExprKind.NilLit

            case ExprKind.ArrayLit(elements):
                val hir_elements = self.lower_expr_list(elements)
                # For empty arrays, use configured default element type
                val elem_type = if hir_elements.is_empty():
                    if self.is_strict_empty_collections():
                        self.error("empty array requires explicit type annotation", e.span)
                        nil
                    else:
                        Some(self.get_empty_array_default())
                else:
                    nil  # Type will be inferred from elements
                HirExprKind.ArrayLit(hir_elements, elem_type)

            case ExprKind.TupleLit(elements):
                HirExprKind.TupleLit(self.lower_expr_list(elements))

            case ExprKind.DictLit(entries):
                HirExprKind.DictLit(self.lower_dict_entries(entries), nil, nil)

            case ExprKind.SetLit(elements):
                HirExprKind.SetLit(self.lower_expr_list(elements), nil)

            case ExprKind.Ident(name):
                # Typed rebind: extracted ANY-ish payload misreads on stage4
                # when consumed directly (bug doc iteration 18).
                val ident_name_t: text = name
                val symbol = self.symbols.lookup(ident_name_t)
                if val found_symbol = symbol:
                    # NOTE: `if val found_symbol = symbol:` is not sufficient
                    # here -- same class of bug fixed in 413d121a011 for MIR
                    # `if val ... .type_:` sites: the seed interpreter's
                    # `if val` presence check can still enter this true
                    # branch with `found_symbol` bound to nil when the
                    # lookup actually failed. Downstream consumers of
                    # HirExprKind.NamedVar (e.g. MIR lowering's `symbol.id`
                    # access) assume `symbol` is never nil, so a redundant
                    # explicit nil re-check here avoids constructing a
                    # NamedVar with a nil symbol and crashing later with
                    # "undefined field 'id': cannot access field on value
                    # of type 'nil'".
                    if found_symbol == nil:
                        self.lower_unresolved_ident(ident_name_t, e.span)
                    else:
                        HirExprKind.NamedVar(found_symbol, ident_name_t)
                else:
                    self.lower_unresolved_ident(ident_name_t, e.span)

            # NOTE: ExprKind.Field and ExprKind.Block arms are handled by the
            # discriminant pre-dispatch above (seed always-true struct-pattern
            # hazard) and MUST NOT appear in this match.
            case ExprKind.Index(base, index):
                val index_base_t: Expr = base
                val index_t: Expr = index
                match index_base_t.kind:
                    case ExprKind.ExistsCheck(exists_base):
                        val exists_base_t: Expr = exists_base
                        val indexed = HirExpr(
                            kind: HirExprKind.Index(self.lower_hir_expr(exists_base_t), self.lower_hir_expr(index_t)),
                            type_: nil,
                            span: e.span
                        )
                        HirExprKind.ExistsCheck(indexed)
                    case _:
                        HirExprKind.Index(self.lower_hir_expr(index_base_t), self.lower_hir_expr(index_t))

            case ExprKind.OptionalChain(base, field):
                HirExprKind.OptionalChain(self.lower_hir_expr(base), field)

            case ExprKind.NullCoalesce(left, right):
                HirExprKind.NullCoalesce(self.lower_hir_expr(left), self.lower_hir_expr(right))

            case ExprKind.ExistsCheck(base):
                HirExprKind.ExistsCheck(self.lower_hir_expr(base))

            case ExprKind.ForceUnwrap(base):
                HirExprKind.Unwrap(self.lower_hir_expr(base))

            case ExprKind.Cast(operand, target_type):
                HirExprKind.Cast(self.lower_hir_expr(operand), self.lower_type(target_type))

            case ExprKind.Binary(op, left, right):
                # Typed rebinds: extracted ANY-ish payloads misread on stage4
                # when consumed directly (bug doc iteration 18).
                val bin_op_t: BinOp = op
                val bin_left_t: Expr = left
                val bin_right_t: Expr = right
                val hir_op = self.lower_binop(bin_op_t)
                HirExprKind.Binary(hir_op, self.lower_hir_expr(bin_left_t), self.lower_hir_expr(bin_right_t))

            case ExprKind.Unary(op, operand):
                val un_op_t: UnaryOp = op
                val un_operand_t: Expr = operand
                val hir_op = self.lower_unaryop(un_op_t)
                HirExprKind.Unary(hir_op, self.lower_hir_expr(un_operand_t))

            case ExprKind.Call(callee, args):
                # Typed rebinds: extracted ANY-ish payloads misread on stage4
                # when consumed directly (bug doc iteration 18).
                val call_callee_t: Expr = callee
                val call_args_t: [CallArg] = args
                # NOTE: a former SIMPLE_BOOTSTRAP branch here wiped the argument
                # list to `[]` (commit 050209d9b "speed up bootstrap"), so under
                # bootstrap EVERY call lost ALL args — print(x) became
                # rt_println("") and nested-call args like print(canary()) were
                # never lowered (#130). Always run the safe all-four-field loop.
                var hir_args: [HirCallArg] = []
                for arg in call_args_t:
                    val arg_t: CallArg = arg
                    # Pass ALL FOUR fields in declaration order: HirCallArg
                    # has a hand-desugared `has_name` field; a 3-field
                    # named construction is filled POSITIONALLY by the seed
                    # (value landed in the `name` slot, .value read the
                    # span → disc=-1 garbage; bug doc iteration 18).
                    hir_args = hir_args.push(HirCallArg(
                        has_name: arg_t.has_name,
                        name: arg_t.name,
                        value: self.lower_hir_expr(arg_t.value),
                        span: arg_t.span
                    ))
                HirExprKind.Call(self.lower_hir_expr(call_callee_t), hir_args, [])

            case ExprKind.MethodCall(receiver, method, args):
                # Same #130 fix as the Call arm: the former SIMPLE_BOOTSTRAP branch
                # wiped method-call args to `[]`. Always run the safe loop.
                var hir_args: [HirCallArg] = []
                for arg in args:
                    val marg_t: CallArg = arg
                    # All-four-fields construction: see Call arm above.
                    hir_args = hir_args.push(HirCallArg(
                        has_name: marg_t.has_name,
                        name: marg_t.name,
                        value: self.lower_hir_expr(marg_t.value),
                        span: marg_t.span
                    ))
                HirExprKind.MethodCall(self.lower_hir_expr(receiver), method, hir_args, MethodResolution.Unresolved)

            case ExprKind.If(cond, then_, else_):
                val else_block = if else_.?: self.lower_hir_block(else_) else: nil
                HirExprKind.If(
                    self.lower_hir_expr(cond),
                    self.lower_hir_block(then_),
                    else_block
                )

            case ExprKind.MatchCase(scrutinee, arms):
                var hir_arms: [HirMatchArm] = []
                for arm in arms:
                    val guard_ = if arm.guard.?: self.lower_hir_expr(arm.guard) else: nil
                    hir_arms = hir_arms.push(HirMatchArm(
                        pattern: self.lower_pattern(arm.pattern),
                        guard: guard_,
                        body: self.lower_hir_block(arm.body),
                        span: arm.span
                    ))
                HirExprKind.MatchCase(self.lower_hir_expr(scrutinee), hir_arms)

            case ExprKind.Lambda(params, body):
                self.symbols.push_scope(ScopeKind.Function)
                var hir_params: [HirParam] = []
                for p in params:
                    val type_ = if p.type_.?: self.lower_type(p.type_) else: HirType(kind: HirTypeKind.Infer(0, 0), span: p.span)
                    val symbol = self.symbols.define(p.name, SymbolKind.Parameter, Some(type_), p.span, false, false, nil)
                    hir_params = hir_params.push(HirParam(
                        symbol: symbol,
                        name: p.name,
                        type_: type_,
                        default: nil,
                        span: p.span
                    ))
                val hir_body = self.lower_hir_expr(body)
                self.symbols.pop_scope()
                HirExprKind.Lambda(hir_params, hir_body, [])

            case ExprKind.Return(value):
                val rv = self.lower_hir_expr(value)
                HirExprKind.Return(rv)

            case ExprKind.Break(label):
                HirExprKind.Break(label, nil)

            case ExprKind.Continue(label):
                HirExprKind.Continue(label)

            case ExprKind.Yield(value):
                val yv = if value.?: self.lower_hir_expr(value) else: nil
                HirExprKind.Yield(yv)

            case ExprKind.Throw(value):
                HirExprKind.Throw(self.lower_hir_expr(value))

            case ExprKind.Await(expr):
                HirExprKind.Await(self.lower_hir_expr(expr))

            case ExprKind.Try(expr):
                HirExprKind.Try(self.lower_hir_expr(expr))

            case ExprKind.Range(start, end, inclusive, step):
                val rstart = if start.?: self.lower_hir_expr(start) else: nil
                val rend = if end.?: self.lower_hir_expr(end) else: nil
                val rstep = if step.?: self.lower_hir_expr(step) else: nil
                HirExprKind.Range(rstart, rend, inclusive, rstep)

            case ExprKind.ListComprehension(expr, clauses):
                var hir_clauses: [HirCompClause] = []
                for clause in clauses:
                    val hir_kind = match clause.kind:
                        case For(var_, iter):
                            val symbol = self.symbols.define(var_, SymbolKind.Variable, nil, clause.span, false, false, nil)
                            HirCompClauseKind.For(symbol, self.lower_hir_expr(iter))
                        case If(cond):
                            HirCompClauseKind.If(self.lower_hir_expr(cond))
                    hir_clauses = hir_clauses.push(HirCompClause(kind: hir_kind, span: clause.span))
                HirExprKind.Comprehension(HirComprehensionKind.List, self.lower_hir_expr(expr), hir_clauses)

            case ExprKind.StructLit(type_, fields):
                var hir_fields: [(text, HirExpr)] = []
                for (name, value) in fields:
                    hir_fields = hir_fields.push((name, self.lower_hir_expr(value)))
                val symbol = self.symbols.lookup_or_invalid(type_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: e.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: e.span)
                HirExprKind.StructLit(hir_type, hir_fields)

            case ExprKind.EnumLit(enum_, variant, payload):
                val symbol = self.symbols.lookup_or_invalid(enum_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: e.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: e.span)
                val hir_payload = payload.map(\p: match p:
                    case Tuple(values):
                        var hir_values: [HirExpr] = []
                        for v in values:
                            hir_values = hir_values.push(self.lower_hir_expr(v))
                        HirEnumPayload.Tuple(hir_values)
                    case Struct(fields):
                        var hir_fields: [(text, HirExpr)] = []
                        for (fname, fvalue) in fields:
                            hir_fields = hir_fields.push((fname, self.lower_hir_expr(fvalue)))
                        HirEnumPayload.Struct(hir_fields)
                )
                HirExprKind.EnumLit(hir_type, variant, hir_payload)

            # Custom blocks (user-defined: sh{}, sql{}, re{}, etc.)
            case ExprKind.CustomBlock(kind, value):
                HirExprKind.CustomBlock(kind, value)

            # Math/DL blocks with special semantics
            case ExprKind.LossBlock(body):
                HirExprKind.LossBlock(self.lower_hir_block(body))

            case ExprKind.NogradBlock(body):
                HirExprKind.NogradBlock(self.lower_hir_block(body))

            # Unsafe block for raw pointer ops, SFFI, inline assembly
            case ExprKind.UnsafeBlock(body):
                HirExprKind.UnsafeBlock(self.lower_hir_block(body))

            # Inline assembly
            case ExprKind.AsmBlock(asm_node):
                HirExprKind.InlineAsm(self.lower_asm(asm_node))

            # Target-qualified inline assembly
            case ExprKind.AsmMatch(arms):
                val hir_arms = self.lower_asm_match_arms(arms)
                HirExprKind.InlineAsmMatch(hir_arms)

            case ExprKind.Error:
                HirExprKind.Error

            case _:
                self.error("unsupported expression kind", e.span)
                HirExprKind.Error

        HirExpr(kind: kind, type_: nil, span: e.span)

    me lower_expr_list(exprs: [Expr]) -> [HirExpr]:
        var result: [HirExpr] = []
        for e in exprs:
            result = result.push(self.lower_hir_expr(e))
        result

    me lower_interpolation_list(interps: [Interpolation]) -> [HirInterpolation]:
        var result: [HirInterpolation] = []
        for i in interps:
            result = result.push(HirInterpolation(
                expr: self.lower_hir_expr(i.expr),
                format: i.format,
                span: i.span
            ))
        result

    me lower_dict_entry(entry: (Expr, Expr)) -> (HirExpr, HirExpr):
        val (key, value) = entry
        (self.lower_hir_expr(key), self.lower_hir_expr(value))

    me lower_dict_entries(entries: [(Expr, Expr)]) -> [(HirExpr, HirExpr)]:
        var result: [(HirExpr, HirExpr)] = []
        for entry in entries:
            result = result.push(self.lower_dict_entry(entry))
        result

    me lower_struct_field(field: (text, Expr)) -> (text, HirExpr):
        val (name, value) = field
        (name, self.lower_hir_expr(value))

    me lower_struct_fields(fields: [(text, Expr)]) -> [(text, HirExpr)]:
        var result: [(text, HirExpr)] = []
        for field in fields:
            result = result.push(self.lower_struct_field(field))
        result

    me lower_binop(op: BinOp) -> HirBinOp:
        match op:
            case BinOp.Add: HirBinOp.Add
            case BinOp.Sub: HirBinOp.Sub
            case BinOp.Mul: HirBinOp.Mul
            case BinOp.Div: HirBinOp.Div
            case BinOp.Mod: HirBinOp.Mod
            case BinOp.Pow: HirBinOp.Pow
            case BinOp.MatMul: HirBinOp.MatMul
            case BinOp.Eq: HirBinOp.Eq
            case BinOp.NotEq: HirBinOp.NotEq
            case BinOp.Lt: HirBinOp.Lt
            case BinOp.LtEq: HirBinOp.LtEq
            case BinOp.Gt: HirBinOp.Gt
            case BinOp.GtEq: HirBinOp.GtEq
            case BinOp.And: HirBinOp.And
            case BinOp.Or: HirBinOp.Or
            case BinOp.BitAnd: HirBinOp.BitAnd
            case BinOp.BitOr: HirBinOp.BitOr
            case BinOp.BitXor: HirBinOp.BitXor
            case BinOp.Shl: HirBinOp.Shl
            case BinOp.Shr: HirBinOp.Shr
            case BinOp.BroadcastAdd: HirBinOp.BroadcastAdd
            case BinOp.BroadcastSub: HirBinOp.BroadcastSub
            case BinOp.BroadcastMul: HirBinOp.BroadcastMul
            case BinOp.BroadcastDiv: HirBinOp.BroadcastDiv
            case BinOp.BroadcastPow: HirBinOp.BroadcastPow
            case BinOp.PipeForward: HirBinOp.PipeForward
            case BinOp.Compose: HirBinOp.Compose
            case BinOp.ComposeBack: HirBinOp.ComposeBack
            case BinOp.Parallel: HirBinOp.Parallel
            case BinOp.LayerConnect: HirBinOp.LayerConnect
            case BinOp.In: HirBinOp.In
            case BinOp.NotIn: HirBinOp.NotIn
            case BinOp.Is: HirBinOp.Is
            case BinOp.IsNot: HirBinOp.IsNot
            case _:
                # stage4 hazard net (iteration 18): if the qualified arms fail
                # to match a genuine BinOp on stage4, do NOT return nil (nil op
                # traps eval_binop). Probe + default to Add.
                HirBinOp.Add

    me lower_unaryop(op: UnaryOp) -> HirUnaryOp:
        match op:
            case UnaryOp.Neg: HirUnaryOp.Neg
            case UnaryOp.Not: HirUnaryOp.Not
            case UnaryOp.BitNot: HirUnaryOp.BitNot
            case UnaryOp.Ref: HirUnaryOp.Ref
            case UnaryOp.Deref: HirUnaryOp.Deref
            case UnaryOp.Transpose: HirUnaryOp.Transpose

    me lower_pattern(p: Pattern) -> HirPattern:
        val kind = match p.kind:
            case Wildcard:
                HirPatternKind.Wildcard

            case Literal(value):
                HirPatternKind.Literal(self.lower_hir_expr(value))

            case Binding(name, mutable):
                val symbol = self.symbols.define(name, SymbolKind.Variable, nil, p.span, false, mutable, nil)
                HirPatternKind.Binding(symbol, mutable)

            case Tuple(elements):
                var hir_elements: [HirPattern] = []
                for elem in elements:
                    hir_elements = hir_elements.push(self.lower_pattern(elem))
                HirPatternKind.Tuple(hir_elements)

            case Array(elements, rest):
                var hir_elements: [HirPattern] = []
                for elem in elements:
                    hir_elements = hir_elements.push(self.lower_pattern(elem))
                var rest_symbol: SymbolId? = nil
                if val rest_name = rest:
                    rest_symbol = Some(self.symbols.define(rest_name, SymbolKind.Variable, nil, p.span, false, false, nil))
                HirPatternKind.Array(hir_elements, rest_symbol)

            case Struct(type_, fields):
                val symbol = self.symbols.lookup_or_invalid(type_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: p.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: p.span)
                var hir_fields: [(text, HirPattern)] = []
                for (fname, fpat) in fields:
                    hir_fields = hir_fields.push((fname, self.lower_pattern(fpat)))
                HirPatternKind.Struct(hir_type, hir_fields)

            case Enum(enum_, variant, payload):
                val symbol = self.symbols.lookup_or_invalid(enum_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: p.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: p.span)
                val hir_payload = payload.map(\pl: match pl:
                    case Tuple(patterns):
                        var hir_patterns: [HirPattern] = []
                        for pat in patterns:
                            hir_patterns = hir_patterns.push(self.lower_pattern(pat))
                        HirPatternPayload.Tuple(hir_patterns)
                    case Struct(fields):
                        var hir_fields: [(text, HirPattern)] = []
                        for (fname, fpat) in fields:
                            hir_fields = hir_fields.push((fname, self.lower_pattern(fpat)))
                        HirPatternPayload.Struct(hir_fields)
                )
                HirPatternKind.Enum(hir_type, variant, hir_payload)

            case Or(patterns):
                var hir_patterns: [HirPattern] = []
                for pat in patterns:
                    hir_patterns = hir_patterns.push(self.lower_pattern(pat))
                HirPatternKind.Or(hir_patterns)

            case Range(start, end, inclusive):
                val pstart = if start.?: self.lower_hir_expr(start) else: nil
                val pend = if end.?: self.lower_hir_expr(end) else: nil
                HirPatternKind.Range(pstart, pend, inclusive)

            case Error:
                HirPatternKind.Error

            case _:
                self.error("unsupported pattern kind", p.span)
                HirPatternKind.Error

        HirPattern(kind: kind, type_: nil, span: p.span)

    me lower_hir_block(b: Block) -> HirBlock:
        # NOTE: a former SIMPLE_BOOTSTRAP branch here returned
        # `HirBlock(stmts:, value:, span:)` — omitting the `has` field, which then
        # read `nil` (an unwritten bool), so MIR lower_block dropped every tail
        # value under bootstrap (implicit-return string/int literals vanished →
        # `ret ptr null` / empty stage2 binary, bug #79). It also used the
        # seed-unsafe re-index + Option patterns the loop below was written to
        # avoid. Deleted: bootstrap now uses this hardened path, which sets `has`.
        self.symbols.push_scope(ScopeKind.Block)

        # Extract the block's trailing value (last statement, if an expression)
        # from the FRESH `lower_hir_stmt` return value during the loop, NOT by
        # re-indexing the `stmts` array afterward. The seed erases `[HirStmt]`
        # elements to ANY, and matching `last.kind` on an ANY array element
        # mis-extracts the `Expr(expr)` enum payload -> a GARBAGE HirExpr pointer
        # (observed 0x1800000007), silently dropping the `-c` "print(...)" body
        # (iteration 10). A direct function return is not ANY-erased, so matching
        # `lowered.kind` in-loop resolves the payload correctly. Also avoids the
        # intermediate `Option<HirExpr>` + `if val v = ...` Some-unwrap the seed
        # miscompiles.
        var stmts: [HirStmt] = []
        var block_has_value = false
        var block_value_expr: HirExpr = HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span)
        val stmt_count = b.stmts.len()
        var stmt_idx = 0
        while stmt_idx < stmt_count:
            val lowered = self.lower_hir_stmt(b.stmts[stmt_idx])
            if stmt_idx == stmt_count - 1:
                # QUALIFIED pattern required: bare `case Expr(expr)` collides with
                # the frontend `struct Expr`, so the seed's unqualified-pattern
                # heuristic (stmt_lowering.rs, enum_name == "_") extracted the
                # payload as a struct FieldAccess at offset 0 (the enum header) —
                # a garbage HirExpr stored as block.value (iterations 10/14/15).
                match lowered.kind:
                    case HirStmtKind.Expr(expr):
                        block_has_value = true
                        block_value_expr = expr
                    case _:
                        stmts = stmts.push(lowered)
            else:
                stmts = stmts.push(lowered)
            stmt_idx = stmt_idx + 1

        self.symbols.pop_scope()

        # HirBlock desugars Option<value> into has + value. The `has` flag MUST
        # be set: MIR lower_block gates the tail value on `block.has`, so without
        # it the extracted last expression-statement is silently dropped (every
        # function body lowered to an empty MIR block in the AOT/native path).
        if block_has_value:
            HirBlock(stmts: stmts, has: true, value: block_value_expr, span: b.span)
        else:
            HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

    # Lower a block that is NOT in value position (a Unit-returning function body,
    # e.g. `fn main(): print(...)`). Every statement — INCLUDING a trailing
    # expression-statement — stays in `stmts`; NO trailing value is extracted and
    # `has=false`.
    #
    # Why a separate path: the value-extracting `lower_hir_block` above destructures
    # `case Expr(expr)` on the FRESH `lower_hir_stmt` return value to lift the last
    # expr into `block.value`. On the seed-compiled stage4 the seed erases the
    # `HirStmtKind` payload to ANY and mis-extracts that `Expr(expr)` payload,
    # storing a GARBAGE HirExpr as `block.value` (iteration 14: eval_expr on it
    # silently no-ops with the has-gate, or SIGSEGVs with a typed rebind — a SEED
    # codegen bug, not fixable by a use-site typed local). For a Unit-returning
    # body the trailing value is never needed, so we sidestep the fragile
    # extraction entirely: the trailing `print(...)` stays a statement and is
    # evaluated by the interpreter's `exec_stmt` statement loop (which destructures
    # `case Expr(expr)` on a PROPERLY-lowered HirStmt — that path works). The
    # value-extracting path is preserved for expression-position blocks and
    # non-Unit returns, where a value is genuinely required (that path keeps the
    # known ANY-extraction limitation, documented in the bug tracker).
    me lower_hir_block_unit(b: Block) -> HirBlock:
        if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_block_unit:start")
            self.symbols.push_scope(ScopeKind.Block)
            var boot_stmts: [HirStmt] = []
            var boot_idx = 0
            while boot_idx < b.stmts.len():
                boot_stmts = boot_stmts.push(self.lower_hir_stmt(b.stmts[boot_idx]))
                boot_idx = boot_idx + 1
            eprint("[hir-lower] lower_block_unit:done")
            self.symbols.pop_scope()
            return HirBlock(stmts: boot_stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

        self.symbols.push_scope(ScopeKind.Block)
        var stmts: [HirStmt] = []
        val stmt_count = b.stmts.len()
        var stmt_idx = 0
        while stmt_idx < stmt_count:
            val lowered: HirStmt = self.lower_hir_stmt(b.stmts[stmt_idx])
            stmts = stmts.push(lowered)
            stmt_idx = stmt_idx + 1
        self.symbols.pop_scope()

        HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

    me lower_asm(asm_node: AsmExpr) -> HirAsm:
        # Lower all constraint value expressions
        var hir_constraints: [HirAsmConstraint] = []
        for constraint in asm_node.constraints:
            val hir_value = self.lower_hir_expr(constraint.value)
            val hir_constraint = HirAsmConstraint(
                name: constraint.name,
                kind: constraint.kind,
                location: constraint.location,
                value: hir_value,
                span: constraint.span
            )
            hir_constraints.push(hir_constraint)

        HirAsm(
            asm_template: asm_node.asm_template,
            is_volatile: asm_node.is_volatile,
            constraints: hir_constraints,
            clobbers: asm_node.clobbers,
            span: asm_node.span
        )

    me lower_asm_match_arms(arms: [AsmMatchArm]) -> [HirAsmMatchArm]:
        var result: [HirAsmMatchArm] = []
        for arm in arms:
            var has_body = arm.has_asm_body
            var hir_body = if has_body:
                self.lower_asm(arm.asm_body)
            else:
                nil
            val hir_arm = HirAsmMatchArm(
                has_spec: arm.has_spec,
                spec: arm.spec,
                is_wildcard: arm.is_wildcard,
                has_asm_body: has_body,
                asm_body: hir_body,
                is_compile_error: arm.is_compile_error,
                error_message: arm.error_message,
                span: arm.span
            )
            result.push(hir_arm)
        result
