# HIR Lowering - Expression Lowering
#
# This module handles lowering of expressions from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.hir.hir_lowering.statements.*
use std.nogc_sync_mut.io.process_ops.{eprint}
use compiler.core.lexer_chars.{is_digit}
use std.string_core.{char_code}

extern fn rt_env_get(key: text) -> text
extern fn rt_enum_discriminant(value: Any) -> i64
extern fn rt_enum_payload(value: Any) -> i64
extern fn rt_array_get_text(array: i64, index: i64) -> text
extern fn rt_tuple_get(tuple: i64, index: i64) -> i64
extern fn rt_is_none(value: i64) -> bool
extern fn rt_unwrap_or_self(value: i64) -> i64
extern fn rt_value_as_int(value: i64) -> i64

fn hir_expr_env_get(key: text) -> text:
    rt_env_get(key)

fn hir_expr_kind_disc(k: ExprKind) -> i64:
    rt_enum_discriminant(k)

fn is_tuple_positional_field(name: text) -> bool:
    """True iff `name` is composed entirely of ASCII digits -- the parser's
    encoding for `.0`, `.1`, ... positional tuple-field access (see the
    `member_kind == 1` numeric-tuple-field branch in parser_expr.spl). A
    real struct/named-tuple field name is always an identifier and can
    never be spelled as a pure-digit string, so this test is unambiguous."""
    if name.len() == 0:
        return false
    var i = 0
    while i < name.len():
        if not is_digit(name[i:i + 1]):
            return false
        i = i + 1
    true

fn parse_tuple_field_index(name: text) -> i64:
    """Parse a digit-only field name (see `is_tuple_positional_field`) into
    the positional index it denotes."""
    var idx: i64 = 0
    var i = 0
    while i < name.len():
        idx = idx * 10 + (char_code(name[i:i + 1]) - 48)
        i = i + 1
    idx

fn hir_pattern_kind_disc(k: PatternKind) -> i64:
    rt_enum_discriminant(k)

fn is_interp_builtin_fn(name: text) -> bool:
    """Free-function builtins dispatched by NAME in the HIR interpreter
    (70.backend/backend/interpreter_calls.spl lookup_builtin_tag)."""
    (name == "print" or name == "println" or name == "to_string" or
     name == "type_of" or name == "clone" or name == "file_exists" or
     name == "file_read" or name == "file_write" or name == "file_delete" or
     name == "env_get" or name == "env_set" or name == "int")

fn primitive_cast_type_kind(name: text) -> HirTypeKind?:
    """`i32(x)`-style primitive casts: a fixed-width numeric type name used
    as a call target is a CAST, not a function call. These names are not in
    the value symbol table, so lowering them as ordinary callees yields
    HirExprKind.Error and native codegen then emits an indirect call on an
    undefined local (llc: "use of undefined value '%l0'"). Restricted to
    fixed-width numeric names -- `int`/`float`/`bool` remain calls (they are
    value-parsing builtins, not pure numeric casts)."""
    match name:
        case "i8": HirTypeKind.Int(8, true)
        case "i16": HirTypeKind.Int(16, true)
        case "i32": HirTypeKind.Int(32, true)
        case "i64": HirTypeKind.Int(64, true)
        case "u8": HirTypeKind.Int(8, false)
        case "u16": HirTypeKind.Int(16, false)
        case "u32": HirTypeKind.Int(32, false)
        case "u64": HirTypeKind.Int(64, false)
        case "f32": HirTypeKind.Float(32)
        case "f64": HirTypeKind.Float(64)
        case _: nil

fn is_bootstrap_builtin_fn(name: text) -> bool:
    name == "get_args" or
    name == "sys_get_args" or
    name == "rt_get_args" or
    name == "eprint" or
    name == "bootstrap_version" or
    name == "native_build_help" or
    name == "compile_result_exit" or
    name == "bootstrap_output_from_args" or
    name == "run_native_build_bootstrap" or
    name == "rt_native_build" or
    name == "get_cli_args" or
    name == "main"

fn hir_bootstrap_i64_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Int(64, true), span: span)

fn hir_bootstrap_text_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Str, span: span)

fn hir_bootstrap_text_array_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Array(hir_bootstrap_text_type(span), nil), span: span)

fn hir_bootstrap_unit_type(span: Span) -> HirType:
    HirType(kind: HirTypeKind.Unit, span: span)

fn bootstrap_builtin_return_type(name: text, span: Span) -> HirType:
    if name == "get_args" or name == "get_cli_args" or name == "sys_get_args" or name == "rt_get_args":
        return hir_bootstrap_text_array_type(span)
    if name == "bootstrap_version" or name == "bootstrap_output_from_args":
        return hir_bootstrap_text_type(span)
    if name == "eprint":
        return hir_bootstrap_unit_type(span)
    hir_bootstrap_i64_type(span)

fn bootstrap_builtin_signature(name: text, span: Span) -> HirType:
    HirType(kind: HirTypeKind.Function([], bootstrap_builtin_return_type(name, span), []), span: span)

# Expression Lowering
# ============================================================================

impl HirLowering:
    me lower_host_gpu_lane_payload(marker: Expr) -> i64:
        match marker.kind:
            case ExprKind.MethodCall(_receiver, method, args):
                if method != "later":
                    return 0
                for arg in args:
                    if arg.has_name and arg.name == "max_packet":
                        match arg.value.kind:
                            case ExprKind.IntLit(value):
                                if value > 0:
                                    return value
                                return 0
                            case _:
                                pass
                if args.len() == 1:
                    match args[0].value.kind:
                        case ExprKind.IntLit(value):
                            if value > 0:
                                return value
                            return 0
                        case _:
                            pass
                0
            case _:
                0

    me lower_host_gpu_lane_body(body_expr: Expr) -> HirBlock:
        match body_expr.kind:
            case ExprKind.Block(block):
                self.lower_hir_block(block)
            case _:
                HirBlock(stmts: [], value: Some(self.lower_hir_expr(body_expr)), span: body_expr.span)

    me try_lower_host_gpu_lane_expr(e: Expr) -> HirExpr?:
        match e.kind:
            case ExprKind.Call(callee, args):
                # Typed rebinds of extracted pattern payloads: reading `.kind`
                # directly off the extracted ANY-ish payload misreads on stage4
                # (most-fields-wins), making `name == "host"` pass on garbage
                # and misrouting print(1+1) into HostGpuLane → mono scan SEGV
                # (bug doc iteration 17/18).
                val callee_t: Expr = callee
                val args_t: [CallArg] = args
                var lane_code: i64 = 0
                val callee_kind_t: ExprKind = callee_t.kind
                match callee_kind_t:
                    case ExprKind.Ident(name):
                        val name_t: text = name
                        if name_t == "host":
                            lane_code = 1
                        elif name_t == "gpu":
                            lane_code = 2
                    case _:
                        pass
                if lane_code == 0:
                    return nil
                if args_t.len() != 2:
                    return nil
                val arg1_t: Expr = args_t[1].value
                val arg1_kind_t: ExprKind = arg1_t.kind
                match arg1_kind_t:
                    case ExprKind.Lambda(_params, lambda_body):
                        val lambda_body_t: Expr = lambda_body
                        val arg0_t: Expr = args_t[0].value
                        val marker = self.lower_hir_expr(arg0_t)
                        val payload_size = self.lower_host_gpu_lane_payload(arg0_t)
                        val body = self.lower_host_gpu_lane_body(lambda_body_t)
                        Some(HirExpr(
                            kind: HirExprKind.HostGpuLane(lane_code, payload_size, marker, body),
                            type_: nil,
                            span: e.span
                        ))
                    case _:
                        nil
            case _:
                nil

    me lower_unresolved_ident(name: text, span: Span) -> HirExprKind:
        """Unresolved identifier: known interpreter builtins (print, ...) are
        not in the symbol table on the single-file/-c unstub path — define
        them on first use and emit NamedVar so the HIR interpreter can
        dispatch by name (process_module registers every table symbol as a
        global Function value). Everything else stays an error."""
        val is_bootstrap_builtin = (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and is_bootstrap_builtin_fn(name)
        # Bare Result variants: `Ok(v)` / `Err(e)` are not in the symbol table
        # (Result is a built-in, not a module enum). Emit NamedVar so MIR
        # lowering's lower_call can intercept by name and construct via
        # rt_enum_new (Ok=0, Err=1); previously these decayed to Error and
        # crashed the LLVM backend with a nil callee local.
        val is_result_variant = name == "Ok" or name == "Err"
        # Bare Option variants: `Some(v)` / `None` are built-ins (not module
        # enums), so like Ok/Err they are absent from the symbol table. Emit
        # NamedVar so MIR lowering intercepts by name and constructs via
        # rt_enum_new (registered in enum_variant_index as Option -> Some=0,
        # None=1); without this they decayed to "unresolved name: Some".
        val is_option_variant = name == "Some" or name == "None"
        if is_interp_builtin_fn(name) or is_bootstrap_builtin or is_result_variant or is_option_variant:
            val symbol_type = if is_bootstrap_builtin:
                bootstrap_builtin_signature(name, span)
            else:
                nil
            val bsym = self.symbols.define(name, SymbolKind.Function, symbol_type, span, false, false, nil)
            HirExprKind.NamedVar(bsym, name)
        else:
            self.error("unresolved name: {name}", span)
            HirExprKind.Error

    me lower_hir_expr(e: Expr) -> HirExpr:
        # Probes UNGATED: Trap D (iteration 17) — env-gated probes are mute in
        # hir_lowering modules. Remove before deploy.
        # DIRECT typed field read, NOT `match e: case Expr(k, _): k`: the struct
        # pattern "matches" on stage4 but destructures a GARBAGE payload (observed
        # kind_disc=823890719) — and the direct read shows the same garbage, so
        # `e` itself is corrupted upstream (bug doc iteration 17).
        val expr_kind_value: ExprKind = e.kind
        val host_gpu_lane = self.try_lower_host_gpu_lane_expr(e)
        if val lowered_host_gpu_lane = host_gpu_lane:
            return lowered_host_gpu_lane
        match expr_kind_value:
            case ExprKind.Call(callee, args):
                val call_callee_t: Expr = callee
                val call_args_t: [CallArg] = args
                # `i32(x)` / `f64(x)`: fixed-width primitive type name used as
                # a callee is a numeric CAST (see primitive_cast_type_kind).
                # Lower it as HirExprKind.Cast -- the callee name would
                # otherwise fail symbol lookup and become HirExprKind.Error.
                match call_callee_t.kind:
                    case ExprKind.Ident(callee_ident):
                        val callee_ident_t: text = callee_ident
                        if call_args_t.len() == 1 and not call_args_t[0].has_name:
                            val prim_kind = primitive_cast_type_kind(callee_ident_t)
                            if prim_kind.?:
                                val cast_arg_t: CallArg = call_args_t[0]
                                val cast_target = HirType(kind: prim_kind.unwrap(), span: e.span)
                                return HirExpr(
                                    kind: HirExprKind.Cast(self.lower_hir_expr(cast_arg_t.value), cast_target),
                                    type_: cast_target,
                                    span: e.span
                                )
                    case _:
                        pass
                var hir_args: [HirCallArg] = []
                for arg in call_args_t:
                    val arg_t: CallArg = arg
                    hir_args = hir_args.push(HirCallArg(
                        has_name: arg_t.has_name,
                        name: arg_t.name,
                        value: self.lower_hir_expr(arg_t.value),
                        span: arg_t.span
                    ))
                return HirExpr(kind: HirExprKind.Call(self.lower_hir_expr(call_callee_t), hir_args, []), type_: nil, span: e.span)
            case _:
                pass
        if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_expr:kind")
        # SEED PATTERN HAZARD (bug doc iteration 18): when a variant pattern's
        # name is ALSO a struct name in scope (`struct Field` in
        # parser_types.spl, `struct Block` in parser_types_expr.spl), the seed
        # compiles the `case ExprKind.Field(...)` TEST as a struct pattern =
        # ALWAYS TRUE (compiler_rust codegen/instr/pattern.rs struct/tuple
        # fallback is `iconst 1`), while payload bindings still extract enum
        # payloads. Such an arm swallows every value that reaches it in the big
        # match below (proven: a Call landed in the Field arm, [LHE-ARMX]
        # Field). Pre-dispatch these variants by explicit discriminant
        # (rt_enum_discriminant = DefaultHasher(variant name) truncated to u32)
        # and keep them OUT of the big match.
        val kind_disc_v: i64 = hir_expr_kind_disc(expr_kind_value)
        if kind_disc_v == 21232742:  # hash("Field")
            match expr_kind_value:
                case ExprKind.Field(base, field):
                    val fld_base_t: Expr = base
                    val fld_name_t: text = field
                    val fld_lowered_base = self.lower_hir_expr(fld_base_t)
                    # Numeric tuple positional access (`t.0`, `t.1`, ...):
                    # route through HirExprKind.Index (rt_array_get at
                    # runtime) instead of the generic struct-field path
                    # below. Tuples are rt_arrays at runtime (see
                    # lower_tuple_destructure in statements.spl) and
                    # resolve_field_index (MIR function_lowering.spl) has no
                    # notion of a tuple's positional layout -- left to fall
                    # through to the struct-field path it silently defaults
                    # the field index and native codegen emits a
                    # struct-shaped GEP with the wrong (or a fixed) index,
                    # which either reads the wrong element or crashes the
                    # LLVM backend outright ("invalid getelementptr
                    # indices" -- reproduced with `val t = (3, 5);
                    # print(t.0 + t.1)` on the native `--entry` path before
                    # this fix). Index codegen is already proven correct
                    # for tuple values by the existing (non-literal-init)
                    # tuple-destructure desugar, which binds a temp tuple
                    # and reads elements via the same rt_array_get path.
                    if is_tuple_positional_field(fld_name_t):
                        val fld_tuple_idx = parse_tuple_field_index(fld_name_t)
                        # Recover the element's real type from local_tuple_types
                        # (see doc comment in types.spl) when the base is a
                        # plain variable bound to a tracked tuple literal --
                        # without this, a mixed-type tuple's non-i64 element
                        # (e.g. text) reads back as raw i64 bits downstream
                        # (MIR's Index case has no per-index element-type table
                        # for MirTypeKind.Tuple and defaults to i64).
                        var fld_tuple_elem_type: HirType? = nil
                        var fld_tuple_base_sym: SymbolId? = nil
                        match fld_lowered_base.kind:
                            case HirExprKind.Var(fld_tb_sym):
                                fld_tuple_base_sym = Some(fld_tb_sym)
                            case HirExprKind.NamedVar(fld_tb_sym2, _):
                                fld_tuple_base_sym = Some(fld_tb_sym2)
                            case _: ()
                        if val fld_tb_sym3 = fld_tuple_base_sym:
                            if self.local_tuple_types.has(fld_tb_sym3.id):
                                val fld_tuple_elem_types = self.local_tuple_types[fld_tb_sym3.id]
                                if fld_tuple_idx >= 0 and fld_tuple_idx < fld_tuple_elem_types.len():
                                    fld_tuple_elem_type = Some(fld_tuple_elem_types[fld_tuple_idx])
                        return HirExpr(
                            kind: HirExprKind.Index(fld_lowered_base, HirExpr(kind: HirExprKind.IntLit(fld_tuple_idx, nil), type_: nil, span: e.span)),
                            type_: fld_tuple_elem_type,
                            span: e.span
                        )
                    # Nested-field-access support (native --entry path bug --
                    # see struct_field_types_by_name / local_struct_types doc
                    # comments in types.spl). Without this, `type_` stays nil
                    # here (no inference pass on this path) and MIR defaults
                    # the field's MirType to i64 -- silently wrong for a
                    # non-i64 field (observed: an array-typed struct field
                    # read as raw i64 -> garbage GEP instead of the runtime
                    # array accessor). Only resolves the narrow, static
                    # `val/var x = StructName(...)` local shape; anything else
                    # falls through to the pre-existing nil/i64-default
                    # behavior unchanged.
                    var fld_field_type: HirType? = nil
                    var fld_base_sym_opt: SymbolId? = nil
                    match fld_lowered_base.kind:
                        case HirExprKind.Var(fld_base_sym):
                            fld_base_sym_opt = Some(fld_base_sym)
                        case HirExprKind.NamedVar(fld_base_sym2, _):
                            fld_base_sym_opt = Some(fld_base_sym2)
                        case _: ()
                    if val fld_base_sym = fld_base_sym_opt:
                        if self.local_struct_types.has(fld_base_sym.id):
                            val fld_struct_name = self.local_struct_types[fld_base_sym.id]
                            if self.struct_field_types_by_name.has(fld_struct_name):
                                val fld_struct_fields = self.struct_field_types_by_name[fld_struct_name]
                                if fld_struct_fields.has(fld_name_t):
                                    fld_field_type = Some(fld_struct_fields[fld_name_t])
                    return HirExpr(kind: HirExprKind.Field(fld_lowered_base, fld_name_t, nil), type_: fld_field_type, span: e.span)
                case _:
                    pass
        if kind_disc_v == 1138084884:  # hash("Block")
            match expr_kind_value:
                case ExprKind.Block(block):
                    return HirExpr(kind: HirExprKind.Block(self.lower_hir_block(block)), type_: nil, span: e.span)
                case _:
                    pass
        val kind = match expr_kind_value:
            case ExprKind.IntLit(value):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:int")
                HirExprKind.IntLit(value, nil)

            case ExprKind.FloatLit(value):
                HirExprKind.FloatLit(value, nil)

            case ExprKind.StringLit(value, interps):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:string")
                val hir_interps = if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    nil
                elif interps.?:
                    self.lower_interpolation_list(interps)
                else:
                    nil
                HirExprKind.StringLit(value, hir_interps)

            case ExprKind.BoolLit(value):
                if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    eprint("[hir-lower] lower_expr:bool")
                HirExprKind.BoolLit(value)

            case ExprKind.ArrayLit(elements):
                val hir_elements = self.lower_expr_list(elements)
                # For empty arrays, use configured default element type
                val elem_type = if hir_elements.is_empty():
                    if self.is_strict_empty_collections():
                        self.error("empty array requires explicit type annotation", e.span)
                        nil
                    else:
                        Some(self.get_empty_array_default())
                else:
                    nil  # Type will be inferred from elements
                HirExprKind.ArrayLit(hir_elements, elem_type)

            case ExprKind.ArrayRepeat(value, count):
                # [value; count] -- repeat `value` `count` times. Element type is
                # inferred from `value` downstream, so leave it nil here.
                val hir_value = self.lower_hir_expr(value)
                val hir_count = self.lower_hir_expr(count)
                HirExprKind.ArrayRepeat(hir_value, hir_count, nil)

            case ExprKind.TupleLit(elements):
                HirExprKind.TupleLit(self.lower_expr_list(elements))

            case ExprKind.DictLit(entries):
                HirExprKind.DictLit(self.lower_dict_entries(entries), nil, nil)

            case ExprKind.SetLit(elements):
                HirExprKind.SetLit(self.lower_expr_list(elements), nil)

            case ExprKind.Ident(name):
                # Typed rebind: extracted ANY-ish payload misreads on stage4
                # when consumed directly (bug doc iteration 18).
                val ident_name_t: text = name
                val found_symbol = self.symbols.lookup_or_invalid(ident_name_t)
                if found_symbol.is_valid():
                    # Capture a same-pass qualified rename in the NamedVar
                    # payload; later MIR lowering cannot rely on that class
                    # mutation surviving the HIR pass boundary.
                    val display_name = self.symbols.symbol_display_name(found_symbol, ident_name_t)
                    HirExprKind.NamedVar(found_symbol, display_name)
                else:
                    self.lower_unresolved_ident(ident_name_t, e.span)

            # NOTE: ExprKind.Field and ExprKind.Block arms are handled by the
            # discriminant pre-dispatch above (seed always-true struct-pattern
            # hazard) and MUST NOT appear in this match.
            case ExprKind.Index(base, index):
                val index_base_t: Expr = base
                val index_t: Expr = index
                match index_base_t.kind:
                    case ExprKind.ExistsCheck(exists_base):
                        val exists_base_t: Expr = exists_base
                        val indexed = HirExpr(
                            kind: HirExprKind.Index(self.lower_hir_expr(exists_base_t), self.lower_hir_expr(index_t)),
                            type_: nil,
                            span: e.span
                        )
                        HirExprKind.ExistsCheck(indexed)
                    case _:
                        HirExprKind.Index(self.lower_hir_expr(index_base_t), self.lower_hir_expr(index_t))

            case ExprKind.OptionalChain(base, field):
                HirExprKind.OptionalChain(self.lower_hir_expr(base), field)

            case ExprKind.NullCoalesce(left, right):
                HirExprKind.NullCoalesce(self.lower_hir_expr(left), self.lower_hir_expr(right))

            case ExprKind.ExistsCheck(base):
                HirExprKind.ExistsCheck(self.lower_hir_expr(base))

            case ExprKind.ForceUnwrap(base):
                HirExprKind.Unwrap(self.lower_hir_expr(base))

            case ExprKind.Cast(operand, target_type):
                HirExprKind.Cast(self.lower_hir_expr(operand), self.lower_type(target_type))

            case ExprKind.Binary(op, left, right):
                # Typed rebinds: extracted ANY-ish payloads misread on stage4
                # when consumed directly (bug doc iteration 18).
                val bin_op_t: BinOp = op
                val bin_left_t: Expr = left
                val bin_right_t: Expr = right
                val hir_op = self.lower_binop(bin_op_t, e.span)
                HirExprKind.Binary(hir_op, self.lower_hir_expr(bin_left_t), self.lower_hir_expr(bin_right_t))

            case ExprKind.Unary(op, operand):
                val un_op_t: UnaryOp = op
                val un_operand_t: Expr = operand
                val hir_op = self.lower_unaryop(un_op_t)
                HirExprKind.Unary(hir_op, self.lower_hir_expr(un_operand_t))

            case ExprKind.MethodCall(receiver, method, args):
                # Same #130 fix as the Call arm: the former SIMPLE_BOOTSTRAP branch
                # wiped method-call args to `[]`. Always run the safe loop.
                var hir_args: [HirCallArg] = []
                for arg in args:
                    val marg_t: CallArg = arg
                    # All-four-fields construction: see Call arm above.
                    hir_args = hir_args.push(HirCallArg(
                        has_name: marg_t.has_name,
                        name: marg_t.name,
                        value: self.lower_hir_expr(marg_t.value),
                        span: marg_t.span
                    ))
                HirExprKind.MethodCall(self.lower_hir_expr(receiver), method, hir_args, MethodResolution.Unresolved)

            case ExprKind.If(cond, then_, else_):
                val else_block = if else_.?: self.lower_hir_block(else_) else: nil
                HirExprKind.If(
                    self.lower_hir_expr(cond),
                    self.lower_hir_block(then_),
                    else_block
                )

            case ExprKind.MatchCase(scrutinee, arms):
                var hir_arms: [HirMatchArm] = []
                for arm in arms:
                    # Typed rebind: without it the deployed seed interpreter
                    # treats `arm` as ANY and field reads mis-decode (a list
                    # field comes back as a scalar handle, so a later `.len()`
                    # crashes with "len on i64"). Every other arm-iterating pass
                    # (40.mono, 30.types) does the same rebind. guard is a
                    # DESUGARED (has_guard, guard) pair — not an Option.
                    val typed_arm: MatchArm = arm
                    # Pattern lowering defines the arm's binding symbols. Keep
                    # these calls in explicit statement order: native struct
                    # constructor argument evaluation is not a sequencing
                    # boundary, and lowering the body first leaves bindings
                    # such as `case Item(_, _, result)` unresolved.
                    val hir_pattern = self.lower_pattern(typed_arm.pattern)
                    val hir_guard = self.lower_hir_expr(typed_arm.guard)
                    val hir_body = self.lower_hir_block(typed_arm.body)
                    hir_arms = hir_arms.push(HirMatchArm(
                        pattern: hir_pattern,
                        has_guard: typed_arm.has_guard,
                        guard: hir_guard,
                        body: hir_body,
                        span: typed_arm.span
                    ))
                self.build_match_expr(self.lower_hir_expr(scrutinee), hir_arms, scrutinee.span)

            case ExprKind.Lambda(params, body):
                self.symbols.push_scope(ScopeKind.Function)
                var hir_params: [HirParam] = []
                for p in params:
                    val type_ = if p.type_.?: self.lower_type(p.type_) else: HirType(kind: HirTypeKind.Infer(0, 0), span: p.span)
                    val symbol = self.symbols.define(p.name, SymbolKind.Parameter, Some(type_), p.span, false, false, nil)
                    hir_params = hir_params.push(HirParam(
                        symbol: symbol,
                        name: p.name,
                        type_: type_,
                        has_default: false,
                        default: HirExpr(
                            kind: HirExprKind.NilLit,
                            has_type_: true,
                            type_: HirType(kind: HirTypeKind.Unit, span: p.span),
                            span: p.span
                        ),
                        span: p.span,
                        is_mutable: false
                    ))
                val hir_body = self.lower_hir_expr(body)
                self.symbols.pop_scope()
                HirExprKind.Lambda(hir_params, hir_body, [])

            case ExprKind.Return(value):
                val rv = self.lower_hir_expr(value)
                HirExprKind.Return(rv)

            case ExprKind.Break(label):
                HirExprKind.Break(label, nil)

            case ExprKind.Continue(label):
                HirExprKind.Continue(label)

            case ExprKind.Yield(value):
                val yv = if value.?: self.lower_hir_expr(value) else: nil
                HirExprKind.Yield(yv)

            case ExprKind.Throw(value):
                HirExprKind.Throw(self.lower_hir_expr(value))

            case ExprKind.Await(expr):
                HirExprKind.Await(self.lower_hir_expr(expr))

            case ExprKind.Try(expr):
                HirExprKind.Try(self.lower_hir_expr(expr))

            case ExprKind.Range(start, end, inclusive, step):
                val rstart = if start.?: self.lower_hir_expr(start) else: nil
                val rend = if end.?: self.lower_hir_expr(end) else: nil
                val rstep = if step.?: self.lower_hir_expr(step) else: nil
                HirExprKind.Range(rstart, rend, inclusive, rstep)

            case ExprKind.ListComprehension(expr, clauses):
                var hir_clauses: [HirCompClause] = []
                for clause in clauses:
                    val hir_kind = match clause.kind:
                        case For(var_, iter):
                            val symbol = self.symbols.define(var_, SymbolKind.Variable, nil, clause.span, false, false, nil)
                            HirCompClauseKind.For(symbol, self.lower_hir_expr(iter))
                        case If(cond):
                            HirCompClauseKind.If(self.lower_hir_expr(cond))
                    hir_clauses = hir_clauses.push(HirCompClause(kind: hir_kind, span: clause.span))
                HirExprKind.Comprehension(HirComprehensionKind.List, self.lower_hir_expr(expr), hir_clauses)

            case ExprKind.StructLit(type_, fields):
                var hir_fields: [(text, HirExpr)] = []
                for (name, value) in fields:
                    hir_fields = hir_fields.push((name, self.lower_hir_expr(value)))
                val symbol = self.symbols.lookup_or_invalid(type_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: e.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: e.span)
                HirExprKind.StructLit(hir_type, hir_fields)

            case ExprKind.EnumLit(enum_, variant, payload):
                val symbol = self.symbols.lookup_or_invalid(enum_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: e.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: e.span)
                val hir_payload = match payload:
                    case Some(p):
                        val lowered_payload = match p:
                            case Tuple(values):
                                var hir_values: [HirExpr] = []
                                for v in values:
                                    hir_values = hir_values.push(self.lower_hir_expr(v))
                                HirEnumPayload.Tuple(hir_values)
                            case Struct(fields):
                                var hir_fields: [(text, HirExpr)] = []
                                for (fname, fvalue) in fields:
                                    hir_fields = hir_fields.push((fname, self.lower_hir_expr(fvalue)))
                                HirEnumPayload.Struct(hir_fields)
                        Some(lowered_payload)
                    case None:
                        nil
                HirExprKind.EnumLit(hir_type, variant, hir_payload)

            # Custom blocks (user-defined: sh{}, sql{}, re{}, etc.)
            case ExprKind.CustomBlock(kind, value):
                HirExprKind.CustomBlock(kind, value)

            # Math/DL blocks with special semantics
            case ExprKind.LossBlock(body):
                HirExprKind.LossBlock(self.lower_hir_block(body))

            case ExprKind.NogradBlock(body):
                HirExprKind.NogradBlock(self.lower_hir_block(body))

            # Unsafe block for raw pointer ops, SFFI, inline assembly
            case ExprKind.UnsafeBlock(body):
                HirExprKind.UnsafeBlock(self.lower_hir_block(body))

            # Inline assembly
            case ExprKind.AsmBlock(asm_node):
                HirExprKind.InlineAsm(self.lower_asm(asm_node))

            # Target-qualified inline assembly
            case ExprKind.AsmMatch(arms):
                val hir_arms = self.lower_asm_match_arms(arms)
                HirExprKind.InlineAsmMatch(hir_arms)

            # Keep this seed-irrefutable no-payload pattern after every real arm.
            case ExprKind.NilLit:
                HirExprKind.NilLit

            case ExprKind.Error:
                HirExprKind.Error

            case _:
                self.error("unsupported expression kind", e.span)
                HirExprKind.Error

        HirExpr(kind: kind, type_: nil, span: e.span)

    me lower_expr_list(exprs: [Expr]) -> [HirExpr]:
        var result: [HirExpr] = []
        for e in exprs:
            result = result.push(self.lower_hir_expr(e))
        result

    me lower_interpolation_list(interps: [Interpolation]) -> [HirInterpolation]:
        var result: [HirInterpolation] = []
        for i in interps:
            result = result.push(HirInterpolation(
                expr: self.lower_hir_expr(i.expr),
                format: i.format,
                span: i.span
            ))
        result

    me lower_dict_entry(entry: (Expr, Expr)) -> (HirExpr, HirExpr):
        val (key, value) = entry
        (self.lower_hir_expr(key), self.lower_hir_expr(value))

    me lower_dict_entries(entries: [(Expr, Expr)]) -> [(HirExpr, HirExpr)]:
        var result: [(HirExpr, HirExpr)] = []
        for entry in entries:
            result = result.push(self.lower_dict_entry(entry))
        result

    me lower_struct_field(field: (text, Expr)) -> (text, HirExpr):
        val (name, value) = field
        (name, self.lower_hir_expr(value))

    me lower_struct_fields(fields: [(text, Expr)]) -> [(text, HirExpr)]:
        var result: [(text, HirExpr)] = []
        for field in fields:
            result = result.push(self.lower_struct_field(field))
        result

    me lower_binop(op: BinOp, span: Span) -> HirBinOp:
        match op:
            case BinOp.Add: HirBinOp.Add
            case BinOp.Sub: HirBinOp.Sub
            case BinOp.Mul: HirBinOp.Mul
            case BinOp.Div: HirBinOp.Div
            case BinOp.Mod: HirBinOp.Mod
            case BinOp.Pow: HirBinOp.Pow
            case BinOp.MatMul: HirBinOp.MatMul
            case BinOp.Eq: HirBinOp.Eq
            case BinOp.NotEq: HirBinOp.NotEq
            case BinOp.Lt: HirBinOp.Lt
            case BinOp.LtEq: HirBinOp.LtEq
            case BinOp.Gt: HirBinOp.Gt
            case BinOp.GtEq: HirBinOp.GtEq
            case BinOp.And: HirBinOp.And
            case BinOp.Or: HirBinOp.Or
            case BinOp.BitAnd: HirBinOp.BitAnd
            case BinOp.BitOr: HirBinOp.BitOr
            case BinOp.BitXor: HirBinOp.BitXor
            case BinOp.Shl: HirBinOp.Shl
            case BinOp.Shr: HirBinOp.Shr
            case BinOp.BroadcastAdd: HirBinOp.BroadcastAdd
            case BinOp.BroadcastSub: HirBinOp.BroadcastSub
            case BinOp.BroadcastMul: HirBinOp.BroadcastMul
            case BinOp.BroadcastDiv: HirBinOp.BroadcastDiv
            case BinOp.BroadcastPow: HirBinOp.BroadcastPow
            case BinOp.PipeForward: HirBinOp.PipeForward
            case BinOp.Compose: HirBinOp.Compose
            case BinOp.ComposeBack: HirBinOp.ComposeBack
            case BinOp.Parallel: HirBinOp.Parallel
            case BinOp.LayerConnect: HirBinOp.LayerConnect
            case BinOp.In: HirBinOp.In
            case BinOp.NotIn: HirBinOp.NotIn
            case BinOp.Is: HirBinOp.Is
            case BinOp.IsNot: HirBinOp.IsNot
            case _:
                self.error("invalid binary operator", span)
                # Type-required recovery value; the fatal diagnostic prevents
                # this HIR from reaching a backend.
                HirBinOp.Add

    me lower_unaryop(op: UnaryOp) -> HirUnaryOp:
        val disc = rt_enum_discriminant(op)
        if disc == rt_enum_discriminant(UnaryOp.Not):
            return HirUnaryOp.Not
        if disc == rt_enum_discriminant(UnaryOp.BitNot):
            return HirUnaryOp.BitNot
        if disc == rt_enum_discriminant(UnaryOp.Ref):
            return HirUnaryOp.Ref
        if disc == rt_enum_discriminant(UnaryOp.Deref):
            return HirUnaryOp.Deref
        if disc == rt_enum_discriminant(UnaryOp.Transpose):
            return HirUnaryOp.Transpose
        HirUnaryOp.Neg

    me lower_pattern(p: Pattern) -> HirPattern:
        val pattern_kind_value: PatternKind = p.kind
        val pattern_disc = hir_pattern_kind_disc(pattern_kind_value)
        if pattern_disc == hir_pattern_kind_disc(PatternKind.Wildcard):
            return HirPattern(kind: HirPatternKind.Wildcard, type_: nil, span: p.span)
        if pattern_disc == hir_pattern_kind_disc(PatternKind.Binding("", false)):
            val raw_payload = rt_enum_payload(pattern_kind_value)
            val binding_name = rt_array_get_text(raw_payload, 0)
            val mutable_slot = rt_tuple_get(raw_payload, 1)
            val binding_mutable = if mutable_slot == 0:
                false
            elif mutable_slot == 1:
                true
            else:
                rt_value_as_int(mutable_slot) != 0
            val binding_symbol = self.symbols.define(binding_name, SymbolKind.Variable, nil, p.span, false, binding_mutable, nil)
            return HirPattern(kind: HirPatternKind.Binding(binding_symbol, binding_mutable), type_: nil, span: p.span)
        if pattern_disc == hir_pattern_kind_disc(PatternKind.Enum("", "", nil)):
            val raw_payload = rt_enum_payload(pattern_kind_value)
            val enum_name = rt_array_get_text(raw_payload, 0)
            val variant_name = rt_array_get_text(raw_payload, 1)
            val payload_slot = rt_tuple_get(raw_payload, 2)
            val enum_symbol = self.symbols.lookup_or_invalid(enum_name)
            val enum_type = if enum_symbol.is_valid():
                HirType(kind: HirTypeKind.Named(enum_symbol, []), span: p.span)
            else:
                HirType(kind: HirTypeKind.Error, span: p.span)
            var hir_payload: HirPatternPayload? = nil
            if not rt_is_none(payload_slot):
                var payload_value = payload_slot
                var payload_disc = rt_enum_discriminant(payload_value)
                val tuple_disc = rt_enum_discriminant(EnumPatternPayload.Tuple([]))
                val struct_disc = rt_enum_discriminant(EnumPatternPayload.Struct([]))
                if payload_disc != tuple_disc and payload_disc != struct_disc:
                    payload_value = rt_unwrap_or_self(payload_slot)
                    payload_disc = rt_enum_discriminant(payload_value)
                if payload_disc == tuple_disc:
                    val patterns = rt_enum_payload(payload_value) as [Pattern]
                    var hir_patterns: [HirPattern] = []
                    for pat in patterns:
                        hir_patterns = hir_patterns.push(self.lower_pattern(pat))
                    hir_payload = Some(HirPatternPayload.Tuple(hir_patterns))
                elif payload_disc == struct_disc:
                    val fields = rt_enum_payload(payload_value) as [(text, Pattern)]
                    var hir_fields: [(text, HirPattern)] = []
                    for (fname, fpat) in fields:
                        hir_fields = hir_fields.push((fname, self.lower_pattern(fpat)))
                    hir_payload = Some(HirPatternPayload.Struct(hir_fields))
            return HirPattern(kind: HirPatternKind.Enum(enum_type, variant_name, hir_payload), type_: nil, span: p.span)

        val kind = match pattern_kind_value:
            case Wildcard:
                HirPatternKind.Wildcard

            case Literal(value):
                HirPatternKind.Literal(self.lower_hir_expr(value))

            case Binding(name, mutable):
                val symbol = self.symbols.define(name, SymbolKind.Variable, nil, p.span, false, mutable, nil)
                HirPatternKind.Binding(symbol, mutable)

            case Tuple(elements):
                var hir_elements: [HirPattern] = []
                for elem in elements:
                    hir_elements = hir_elements.push(self.lower_pattern(elem))
                HirPatternKind.Tuple(hir_elements)

            case Array(elements, rest):
                var hir_elements: [HirPattern] = []
                for elem in elements:
                    hir_elements = hir_elements.push(self.lower_pattern(elem))
                var rest_symbol: SymbolId? = nil
                if val rest_name = rest:
                    rest_symbol = Some(self.symbols.define(rest_name, SymbolKind.Variable, nil, p.span, false, false, nil))
                HirPatternKind.Array(hir_elements, rest_symbol)

            case Struct(type_, fields):
                val symbol = self.symbols.lookup_or_invalid(type_)
                val hir_type = if symbol.is_valid():
                    HirType(kind: HirTypeKind.Named(symbol, []), span: p.span)
                else:
                    HirType(kind: HirTypeKind.Error, span: p.span)
                var hir_fields: [(text, HirPattern)] = []
                for (fname, fpat) in fields:
                    hir_fields = hir_fields.push((fname, self.lower_pattern(fpat)))
                HirPatternKind.Struct(hir_type, hir_fields)

            case Enum(enum_, variant, payload):
                # nestedmatch lane: bare positional struct-pattern
                # reinterpretation. `case Point(x, y):` and a nested payload
                # sub-pattern like `case Circle(Point(x, y)):` both parse
                # IDENTICALLY to a bare (unqualified) enum-variant pattern --
                # convert_flat_pattern (frontend, _FlatAstBridge/
                # convert_nodes.spl) has no dedicated struct-positional-
                # pattern grammar and none is invented here (brace `Point{x,
                # y}` pattern syntax does not parse either -- matchpat lane
                # finding). When the unqualified `variant` name is a
                # REGISTERED STRUCT (struct_field_order_by_name is populated
                # in the up-front declarations pass before any function body
                # is lowered -- see try_register_local_struct_type's
                # identical read of this same map in statements.spl),
                # reinterpret this pattern as a genuine Struct pattern,
                # reusing the SAME positional-field-order convention already
                # established for struct CONSTRUCTION call sites (`Point(3,
                # 4)`) -- not new grammar, just an existing convention
                # applied symmetrically to pattern position. A bare pattern
                # whose name matches neither a struct nor any registered enum
                # variant still falls through unchanged to the plain Enum
                # path below, which the MIR enum-match lowering already
                # rejects with a genuine "unknown variant" compile error
                # (verified empirically: build fails loudly, no binary --
                # never silently wrong), so this branch is purely additive.
                if enum_ == "" and self.struct_field_order_by_name.has(variant):
                    val field_order = self.struct_field_order_by_name[variant]
                    var sub_patterns: [Pattern] = []
                    if val pl_s = payload:
                        match pl_s:
                            case Tuple(patterns_s):
                                sub_patterns = patterns_s
                            case Struct(_):
                                ()
                    val struct_symbol = self.symbols.lookup_or_invalid(variant)
                    val struct_hir_type = if struct_symbol.is_valid():
                        HirType(kind: HirTypeKind.Named(struct_symbol, []), span: p.span)
                    else:
                        HirType(kind: HirTypeKind.Error, span: p.span)
                    var struct_hir_fields: [(text, HirPattern)] = []
                    var sfi = 0
                    while sfi < sub_patterns.len() and sfi < field_order.len():
                        struct_hir_fields = struct_hir_fields.push((field_order[sfi], self.lower_pattern(sub_patterns[sfi])))
                        sfi = sfi + 1
                    HirPatternKind.Struct(struct_hir_type, struct_hir_fields)
                else:
                    val symbol = self.symbols.lookup_or_invalid(enum_)
                    val hir_type = if symbol.is_valid():
                        HirType(kind: HirTypeKind.Named(symbol, []), span: p.span)
                    else:
                        HirType(kind: HirTypeKind.Error, span: p.span)
                    # No `.map(\pl: ...)` lambda here: the seed interpreter does not
                    # bind `self` inside a lambda body, so `self.lower_pattern` in a
                    # closure fails native-build with "variable `self` not found".
                    var hir_payload: HirPatternPayload? = nil
                    if val pl = payload:
                        match pl:
                            case Tuple(patterns):
                                var hir_patterns: [HirPattern] = []
                                for pat in patterns:
                                    hir_patterns = hir_patterns.push(self.lower_pattern(pat))
                                hir_payload = Some(HirPatternPayload.Tuple(hir_patterns))
                            case Struct(fields):
                                var hir_fields: [(text, HirPattern)] = []
                                for (fname, fpat) in fields:
                                    hir_fields = hir_fields.push((fname, self.lower_pattern(fpat)))
                                hir_payload = Some(HirPatternPayload.Struct(hir_fields))
                    HirPatternKind.Enum(hir_type, variant, hir_payload)

            case Or(patterns):
                var hir_patterns: [HirPattern] = []
                for pat in patterns:
                    hir_patterns = hir_patterns.push(self.lower_pattern(pat))
                HirPatternKind.Or(hir_patterns)

            case Range(start, end, inclusive):
                val pstart = if start.?: self.lower_hir_expr(start) else: nil
                val pend = if end.?: self.lower_hir_expr(end) else: nil
                HirPatternKind.Range(pstart, pend, inclusive)

            case Error:
                HirPatternKind.Error

            case _:
                self.error("unsupported pattern kind", p.span)
                HirPatternKind.Error

        HirPattern(kind: kind, type_: nil, span: p.span)

    # ========================================================================
    # matchpat lane: match-pattern forms beyond basic enum-match.
    #
    # The MIR-level match lowering ("B5b", 50.mir/_MirLoweringExpr/
    # expr_dispatch.spl::lower_match_case) only natively supports Wildcard |
    # Binding | Literal(IntLit) | Or(all IntLit) for plain value matches, and
    # Enum patterns whose payload sub-patterns are themselves plain
    # Binding/Wildcard. Every other pattern kind hits a `self.error(...)`
    # there and returns a bare unit temp -- but native-build's lower_to_mir
    # never checks MirLowering.errors, so the build "succeeds" and the
    # resulting binary silently returns a garbage value instead of the
    # correct one or a clean build failure (matchpat lane root-cause; that
    # MIR file is owned by a different lane this round and is not touched
    # here). The HIR-only fix below closes this gap without ever touching
    # the fenced MIR files:
    #
    # Enum-pattern arms keep routing through HirExprKind.MatchCase unchanged
    # (the existing, tested enum-match path) -- an earlier revision also
    # attempted to flatten nested non-Binding enum-payload sub-patterns
    # (e.g. `Maybe.Some(Point(x, y))`) into fresh bindings + prelude
    # statements, but every variant hit a reliable self-hosted-interpreter
    # quirk (a helper's return value silently evaluated to the wrong answer
    # several call-frames deep) and was removed rather than shipped
    # non-working; nested enum-payload destructure remains an unsupported,
    # loud-fail construct, same as before this lane's changes.
    #
    # No arm has an Enum pattern, but some arm needs a pattern kind the MIR
    # fast path can't test (Literal(non-IntLit) e.g. text/bool, Range, Or,
    # Tuple, Struct): desugar the WHOLE match into an ordinary if/else-if
    # chain over a single scrutinee temp, entirely bypassing
    # HirExprKind.MatchCase. The LAST arm in source order always becomes the
    # unconditional terminal branch (mirroring a compiler that only ever
    # lowers programs an earlier front-end stage already accepted), so no
    # synthetic panic/dummy-value fallback is needed for any of the
    # exhaustive forms this lane covers (wildcard/binding default, bool
    # true/false, irrefutable tuple/struct destructure). A match that is
    # genuinely non-exhaustive with no default arm is a pre-existing gap
    # (this compiler does not check pattern exhaustiveness anywhere yet) and
    # is unchanged by this fix.
    # ========================================================================

    me pattern_is_mir_native(kind: HirPatternKind) -> bool:
        """True iff the MIR B5b fast path already handles this pattern kind
        correctly on its own (see lower_match_case in the fenced
        expr_dispatch.spl)."""
        match kind:
            case Wildcard:
                true
            case Binding(_, _):
                true
            case Literal(lit_expr):
                match lit_expr.kind:
                    case IntLit(_, _):
                        true
                    case _:
                        false
            case Or(patterns):
                var ok = true
                for p in patterns:
                    match p.kind:
                        case Literal(lit2):
                            match lit2.kind:
                                case IntLit(_, _):
                                    ()
                                case _:
                                    ok = false
                        case _:
                            ok = false
                ok
            case Enum(_, _, _):
                # Enum arms always route through the pre-existing, tested
                # MatchCase enum-match lowering unchanged (see
                # build_match_expr's `has_enum` branch below) regardless of
                # this function's answer, so this is never actually
                # consulted for them -- true is the conservative "don't
                # touch it" answer. (An earlier revision attempted to also
                # flatten nested non-Binding enum payload sub-patterns, e.g.
                # `Maybe.Some(Point(x, y))`, into fresh bindings + Field-
                # access prelude statements; every variant hit a reliable
                # self-hosted-interpreter quirk where the flatten decision
                # silently evaluated to the wrong answer several call-frames
                # deep, so it was removed rather than shipped non-working.
                # Nested enum-payload destructure remains an unsupported,
                # loud-fail construct, same as before this lane's changes.)
                true
            case _:
                # Tuple, Array, Struct, Range, Error
                false

    me destructure_pattern_prelude(value_expr: HirExpr, pat: HirPattern, span: Span) -> [HirStmt]:
        """Recursively re-create an irrefutable (test-free) pattern's
        bindings as ordinary `Let` statements against `value_expr`, using
        already-working Field/TupleIndex access. Used both for the enum
        payload flatten (case 1 above) and for plain (non-enum) Tuple/Struct
        arms in the if-chain fallback (case 2 above). Literal/Range/Or
        sub-patterns need a runtime TEST, not just a binding, so they are
        left alone here (no-op) -- callers that also need conditions use
        pattern_test_condition for that."""
        match pat.kind:
            case Wildcard:
                []
            case Binding(sym, _):
                [HirStmt(kind: HirStmtKind.Let(sym, nil, value_expr), span: span)]
            case Tuple(elements):
                var stmts: [HirStmt] = []
                var i = 0
                while i < elements.len():
                    # Index(base, IntLit(i)), NOT TupleIndex: tuples lower to
                    # rt_arrays at runtime and MIR's main rvalue dispatch
                    # (expr_dispatch.spl) has no TupleIndex case at all --
                    # this mirrors the proven-working idiom in
                    # lower_tuple_destructure (hir_lowering/statements.spl)
                    # for `val (a, b) = expr`.
                    val elem_expr = HirExpr(kind: HirExprKind.Index(value_expr, HirExpr(kind: HirExprKind.IntLit(i, nil), type_: nil, span: span)), type_: nil, span: span)
                    val sub_stmts = self.destructure_pattern_prelude(elem_expr, elements[i], span)
                    var j = 0
                    while j < sub_stmts.len():
                        stmts = stmts.push(sub_stmts[j])
                        j = j + 1
                    i = i + 1
                stmts
            case Struct(_, fields):
                var stmts2: [HirStmt] = []
                for fpair in fields:
                    val fname: text = fpair.0
                    val fpat: HirPattern = fpair.1
                    val felem_expr = HirExpr(kind: HirExprKind.Field(value_expr, fname, nil), type_: nil, span: span)
                    val sub_stmts2 = self.destructure_pattern_prelude(felem_expr, fpat, span)
                    var k = 0
                    while k < sub_stmts2.len():
                        stmts2 = stmts2.push(sub_stmts2[k])
                        k = k + 1
                stmts2
            case _:
                # Literal/Range/Or/Enum/Error nested where only an
                # irrefutable destructure is expected: no binding to
                # produce. (Not exercised by the matchpat lane's probes;
                # left as a documented no-op rather than guessed at.)
                []

    me literal_test_condition(value_expr: HirExpr, lit_expr: HirExpr, span: Span) -> HirExpr:
        """Build the boolean test for a Literal pattern. `1 | 2 | 3` in
        pattern position parses as a chain of bitwise-or EXPRESSIONS (the
        parser has no dedicated or-pattern token -- see the EXPR_BINARY case
        added to convert_flat_pattern), not a real Or-pattern, so recover
        the intended or-pattern semantics here by splitting a BitOr literal
        back into `v == l or <test r>`."""
        match lit_expr.kind:
            case Binary(op, l, r):
                match op:
                    case BitOr:
                        val left_cond = self.literal_test_condition(value_expr, l, span)
                        val right_cond = self.literal_test_condition(value_expr, r, span)
                        HirExpr(kind: HirExprKind.Binary(HirBinOp.Or, left_cond, right_cond), type_: nil, span: span)
                    case _:
                        HirExpr(kind: HirExprKind.Binary(HirBinOp.Eq, value_expr, lit_expr), type_: nil, span: span)
            case _:
                HirExpr(kind: HirExprKind.Binary(HirBinOp.Eq, value_expr, lit_expr), type_: nil, span: span)

    me pattern_test_condition(value_expr: HirExpr, pat: HirPattern, span: Span) -> HirExpr?:
        """The boolean runtime test for a pattern, or nil if the pattern is
        unconditional (always matches: Wildcard/Binding, or a pure
        Tuple/Struct destructure with no literal/range/or sub-test)."""
        match pat.kind:
            case Wildcard:
                nil
            case Binding(_, _):
                nil
            case Literal(lit_expr):
                Some(self.literal_test_condition(value_expr, lit_expr, span))
            case Range(start, end, inclusive):
                if val rs = start:
                    if val re = end:
                        val ge = HirExpr(kind: HirExprKind.Binary(HirBinOp.GtEq, value_expr, rs), type_: nil, span: span)
                        val hi_op = if inclusive: HirBinOp.LtEq else: HirBinOp.Lt
                        val le = HirExpr(kind: HirExprKind.Binary(hi_op, value_expr, re), type_: nil, span: span)
                        Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.And, ge, le), type_: nil, span: span))
                    else:
                        Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.GtEq, value_expr, rs), type_: nil, span: span))
                else:
                    if val re2 = end:
                        Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.Lt, value_expr, re2), type_: nil, span: span))
                    else:
                        nil
            case Or(patterns):
                var combined: HirExpr? = nil
                for p in patterns:
                    val sub_cond = self.pattern_test_condition(value_expr, p, span)
                    if val sc = sub_cond:
                        if val c = combined:
                            combined = Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.Or, c, sc), type_: nil, span: span))
                        else:
                            combined = Some(sc)
                    else:
                        combined = nil
                combined
            case Tuple(elements):
                var combined2: HirExpr? = nil
                var i = 0
                while i < elements.len():
                    # Index(base, IntLit(i)), NOT TupleIndex: tuples lower to
                    # rt_arrays at runtime and MIR's main rvalue dispatch
                    # (expr_dispatch.spl) has no TupleIndex case at all --
                    # this mirrors the proven-working idiom in
                    # lower_tuple_destructure (hir_lowering/statements.spl)
                    # for `val (a, b) = expr`.
                    val elem_expr = HirExpr(kind: HirExprKind.Index(value_expr, HirExpr(kind: HirExprKind.IntLit(i, nil), type_: nil, span: span)), type_: nil, span: span)
                    val sub_cond2 = self.pattern_test_condition(elem_expr, elements[i], span)
                    if val sc2 = sub_cond2:
                        if val c2 = combined2:
                            combined2 = Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.And, c2, sc2), type_: nil, span: span))
                        else:
                            combined2 = Some(sc2)
                    i = i + 1
                combined2
            case Struct(_, fields):
                var combined3: HirExpr? = nil
                for fpair in fields:
                    val fname: text = fpair.0
                    val fpat: HirPattern = fpair.1
                    val felem_expr = HirExpr(kind: HirExprKind.Field(value_expr, fname, nil), type_: nil, span: span)
                    val sub_cond3 = self.pattern_test_condition(felem_expr, fpat, span)
                    if val sc3 = sub_cond3:
                        if val c3 = combined3:
                            combined3 = Some(HirExpr(kind: HirExprKind.Binary(HirBinOp.And, c3, sc3), type_: nil, span: span))
                        else:
                            combined3 = Some(sc3)
                combined3
            case _:
                nil

    me build_if_chain(scrut_var: HirExpr, hir_arms: [HirMatchArm], idx: i64, span: Span) -> HirExpr:
        val arm = hir_arms[idx]
        val cond = self.pattern_test_condition(scrut_var, arm.pattern, span)
        val prelude = self.destructure_pattern_prelude(scrut_var, arm.pattern, span)
        var arm_stmts: [HirStmt] = []
        var pi = 0
        while pi < prelude.len():
            arm_stmts = arm_stmts.push(prelude[pi])
            pi = pi + 1
        var bi = 0
        while bi < arm.body.stmts.len():
            arm_stmts = arm_stmts.push(arm.body.stmts[bi])
            bi = bi + 1
        val arm_block = HirBlock(stmts: arm_stmts, has: arm.body.has, value: arm.body.value, span: arm.body.span)
        val is_last = idx == hir_arms.len() - 1
        if is_last:
            return HirExpr(kind: HirExprKind.Block(arm_block), type_: nil, span: span)
        match cond:
            case nil:
                HirExpr(kind: HirExprKind.Block(arm_block), type_: nil, span: span)
            case Some(c):
                val rest = self.build_if_chain(scrut_var, hir_arms, idx + 1, span)
                val else_block = HirBlock(stmts: [], has: true, value: rest, span: span)
                HirExpr(kind: HirExprKind.If(c, arm_block, Some(else_block)), type_: nil, span: span)

    me desugar_match_to_if_chain(hir_scrutinee: HirExpr, hir_arms: [HirMatchArm], span: Span) -> HirExprKind:
        val fresh = self.symbols.define("__mp_scrutinee", SymbolKind.Variable, nil, span, false, false, nil)
        val let_stmt = HirStmt(kind: HirStmtKind.Let(fresh, nil, hir_scrutinee), span: span)
        val scrut_var = HirExpr(kind: HirExprKind.Var(fresh), type_: nil, span: span)
        val chain_value = self.build_if_chain(scrut_var, hir_arms, 0, span)
        HirExprKind.Block(HirBlock(stmts: [let_stmt], has: true, value: chain_value, span: span))

    me flatten_enum_match_arm(arm: HirMatchArm, span: Span) -> HirMatchArm:
        """nestedmatch lane: rewrite a `case Variant(sub0, sub1, ...):` arm
        whose payload contains a non-Binding/Wildcard sub-pattern (e.g. the
        nested struct-positional reinterpretation in lower_pattern above,
        `case Circle(Point(x, y)):`) into an equivalent arm the pre-existing,
        TESTED single-level enum-match MIR lowering (lower_enum_match /
        enum_pat_binding_syms, switch_operators_calls.spl -- fenced, not
        edited here) already handles correctly: each complex sub-pattern
        position is replaced by a fresh plain Binding, so the fenced
        payload-binding extraction sees an ordinary Binding -- exactly like a
        hand-written `case Circle(pt):` arm (proven working, including its
        struct-value field-index fix for `pt.x`) -- and the REAL destructure
        is instead done by ordinary Field/Index-access Let statements
        prepended to the arm body, via the already-tested
        destructure_pattern_prelude helper (the same one the if-chain
        fallback above uses for top-level Tuple/Struct patterns). Without
        this flatten, the fenced enum_pat_binding_syms silently SKIPS any
        non-Binding sub-pattern (documented in its own comment: "non-Binding
        sub-patterns...are skipped and simply left unbound"), which left `x`/
        `y` referencing a never-populated local -- observed as a MIR/
        interpreter crash ("undefined field 'id': cannot access field on
        value of type 'nil'"), not a clean compile error. A sub-pattern that
        needs a genuine runtime TEST (Literal/Range/Or/Enum) has no
        single-dispatch-arm fallthrough semantics available here and is NOT
        silently accepted: it is a loud compile error instead (self.error),
        never a silently-wrong bind. Only Tuple/Struct sub-patterns are
        flattened (the two kinds destructure_pattern_prelude actually
        destructures); everything else hits the explicit error() case below
        rather than being inferred from pattern_test_condition's nil/non-nil
        split (both a genuinely-irrefutable AND several genuinely-refutable
        kinds return nil there, so that split alone is not a safe signal for
        this dispatch). Arms with no complex sub-pattern (the pre-existing,
        already-working shape) pass through completely unchanged."""
        match arm.pattern.kind:
            case Enum(etype, variant, payload):
                var out_arm = arm
                if val pl = payload:
                    match pl:
                        case Tuple(patterns):
                            var any_complex = false
                            for pat in patterns:
                                match pat.kind:
                                    case Wildcard:
                                        ()
                                    case Binding(_, _):
                                        ()
                                    case _:
                                        any_complex = true
                            if any_complex:
                                var new_patterns: [HirPattern] = []
                                var prelude: [HirStmt] = []
                                for pat in patterns:
                                    match pat.kind:
                                        case Wildcard:
                                            new_patterns = new_patterns.push(pat)
                                        case Binding(_, _):
                                            new_patterns = new_patterns.push(pat)
                                        case _:
                                            val fresh = self.symbols.define("__mp_nested_flat", SymbolKind.Variable, nil, span, false, false, nil)
                                            val fresh_pat = HirPattern(kind: HirPatternKind.Binding(fresh, false), type_: nil, span: span)
                                            new_patterns = new_patterns.push(fresh_pat)
                                            val fresh_var = HirExpr(kind: HirExprKind.Var(fresh), type_: nil, span: span)
                                            # ONLY Tuple/Struct sub-patterns are safe to flatten this
                                            # way: they are the sole two kinds destructure_pattern_
                                            # prelude actually destructures (everything else --
                                            # Literal/Range/Or/Enum/Error -- is a documented no-op
                                            # there, and pattern_test_condition's catch-all ALSO
                                            # returns nil for those same kinds -- so relying on
                                            # "test == nil means irrefutable" is NOT a safe signal
                                            # for this dispatch; a nested Enum sub-pattern in
                                            # particular genuinely needs a runtime variant test with
                                            # no fallthrough-to-next-arm semantics available here, and
                                            # must not be silently treated as always-matching). Match
                                            # explicitly on the sub-pattern kind instead of trusting
                                            # pattern_test_condition's nil/non-nil split.
                                            match pat.kind:
                                                case Tuple(_):
                                                    val sub_stmts = self.destructure_pattern_prelude(fresh_var, pat, span)
                                                    var si = 0
                                                    while si < sub_stmts.len():
                                                        prelude = prelude.push(sub_stmts[si])
                                                        si = si + 1
                                                case Struct(_, _):
                                                    val sub_stmts2 = self.destructure_pattern_prelude(fresh_var, pat, span)
                                                    var si2 = 0
                                                    while si2 < sub_stmts2.len():
                                                        prelude = prelude.push(sub_stmts2[si2])
                                                        si2 = si2 + 1
                                                case _:
                                                    self.error("nested match pattern kind not supported inside an enum payload here (only Tuple/Struct destructure, e.g. `Circle(Point(x, y))` or `Circle((a, b))`, are supported -- a nested Literal/Range/Or/Enum sub-pattern would need a runtime test with no fallthrough-to-next-arm semantics available) -- unsupported construct", pat.span)
                                var new_body_stmts: [HirStmt] = []
                                var pi = 0
                                while pi < prelude.len():
                                    new_body_stmts = new_body_stmts.push(prelude[pi])
                                    pi = pi + 1
                                var bi = 0
                                while bi < arm.body.stmts.len():
                                    new_body_stmts = new_body_stmts.push(arm.body.stmts[bi])
                                    bi = bi + 1
                                val new_body = HirBlock(stmts: new_body_stmts, has: arm.body.has, value: arm.body.value, span: arm.body.span)
                                val new_pattern = HirPattern(kind: HirPatternKind.Enum(etype, variant, Some(HirPatternPayload.Tuple(new_patterns))), type_: nil, span: arm.pattern.span)
                                out_arm = HirMatchArm(pattern: new_pattern, has_guard: arm.has_guard, guard: arm.guard, body: new_body, span: arm.span)
                        case Struct(_):
                            ()
                out_arm
            case _:
                arm

    me build_match_expr(hir_scrutinee: HirExpr, hir_arms: [HirMatchArm], span: Span) -> HirExprKind:
        var has_enum = false
        var needs_general_fallback = false
        for a in hir_arms:
            match a.pattern.kind:
                case Enum(_, _, _):
                    has_enum = true
                case _:
                    ()
            if not self.pattern_is_mir_native(a.pattern.kind):
                needs_general_fallback = true

        if has_enum:
            # Pre-existing, tested enum-match MIR lowering handles simple
            # payload bindings unchanged (e.g. `case Shape.Circle(r):`).
            # Arms whose payload contains a nested non-Binding sub-pattern
            # (e.g. `Circle(Point(x, y))`) are flattened first -- see
            # flatten_enum_match_arm's doc comment -- so they also reach the
            # same tested lowering as an ordinary single-binding arm.
            var flat_arms: [HirMatchArm] = []
            for a in hir_arms:
                flat_arms = flat_arms.push(self.flatten_enum_match_arm(a, span))
            return HirExprKind.MatchCase(hir_scrutinee, flat_arms)

        if needs_general_fallback:
            return self.desugar_match_to_if_chain(hir_scrutinee, hir_arms, span)

        HirExprKind.MatchCase(hir_scrutinee, hir_arms)

    me lower_hir_block(b: Block) -> HirBlock:
        # NOTE: a former SIMPLE_BOOTSTRAP branch here returned
        # `HirBlock(stmts:, value:, span:)` — omitting the `has` field, which then
        # read `nil` (an unwritten bool), so MIR lower_block dropped every tail
        # value under bootstrap (implicit-return string/int literals vanished →
        # `ret ptr null` / empty stage2 binary, bug #79). It also used the
        # seed-unsafe re-index + Option patterns the loop below was written to
        # avoid. Deleted: bootstrap now uses this hardened path, which sets `has`.
        self.symbols.push_scope(ScopeKind.Block)

        # Extract the block's trailing value (last statement, if an expression)
        # from the FRESH `lower_hir_stmt` return value during the loop, NOT by
        # re-indexing the `stmts` array afterward. The seed erases `[HirStmt]`
        # elements to ANY, and matching `last.kind` on an ANY array element
        # mis-extracts the `Expr(expr)` enum payload -> a GARBAGE HirExpr pointer
        # (observed 0x1800000007), silently dropping the `-c` "print(...)" body
        # (iteration 10). A direct function return is not ANY-erased, so matching
        # `lowered.kind` in-loop resolves the payload correctly. Also avoids the
        # intermediate `Option<HirExpr>` + `if val v = ...` Some-unwrap the seed
        # miscompiles.
        var stmts: [HirStmt] = []
        var block_has_value = false
        var block_value_expr: HirExpr = HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span)
        val stmt_count = b.stmts.len()
        var stmt_idx = 0
        while stmt_idx < stmt_count:
            # A single source statement may desugar into several HIR statements
            # (tuple destructuring, see lower_hir_stmt_multi) -- splice them all
            # in, applying the tail-value extraction only to the very last one.
            val lowered_list = self.lower_hir_stmt_multi(b.stmts[stmt_idx])
            val lowered_count = lowered_list.len()
            var li = 0
            while li < lowered_count:
                val lowered = lowered_list[li]
                if stmt_idx == stmt_count - 1 and li == lowered_count - 1:
                    # QUALIFIED pattern required: bare `case Expr(expr)` collides with
                    # the frontend `struct Expr`, so the seed's unqualified-pattern
                    # heuristic (stmt_lowering.rs, enum_name == "_") extracted the
                    # payload as a struct FieldAccess at offset 0 (the enum header) —
                    # a garbage HirExpr stored as block.value (iterations 10/14/15).
                    match lowered.kind:
                        case HirStmtKind.Expr(expr):
                            block_has_value = true
                            block_value_expr = expr
                        case _:
                            stmts = stmts.push(lowered)
                else:
                    stmts = stmts.push(lowered)
                li = li + 1
            stmt_idx = stmt_idx + 1

        self.symbols.pop_scope()

        # HirBlock desugars Option<value> into has + value. The `has` flag MUST
        # be set: MIR lower_block gates the tail value on `block.has`, so without
        # it the extracted last expression-statement is silently dropped (every
        # function body lowered to an empty MIR block in the AOT/native path).
        if block_has_value:
            HirBlock(stmts: stmts, has: true, value: block_value_expr, span: b.span)
        else:
            HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

    # Lower a block that is NOT in value position (a Unit-returning function body,
    # e.g. `fn main(): print(...)`). Every statement — INCLUDING a trailing
    # expression-statement — stays in `stmts`; NO trailing value is extracted and
    # `has=false`.
    #
    # Why a separate path: the value-extracting `lower_hir_block` above destructures
    # `case Expr(expr)` on the FRESH `lower_hir_stmt` return value to lift the last
    # expr into `block.value`. On the seed-compiled stage4 the seed erases the
    # `HirStmtKind` payload to ANY and mis-extracts that `Expr(expr)` payload,
    # storing a GARBAGE HirExpr as `block.value` (iteration 14: eval_expr on it
    # silently no-ops with the has-gate, or SIGSEGVs with a typed rebind — a SEED
    # codegen bug, not fixable by a use-site typed local). For a Unit-returning
    # body the trailing value is never needed, so we sidestep the fragile
    # extraction entirely: the trailing `print(...)` stays a statement and is
    # evaluated by the interpreter's `exec_stmt` statement loop (which destructures
    # `case Expr(expr)` on a PROPERLY-lowered HirStmt — that path works). The
    # value-extracting path is preserved for expression-position blocks and
    # non-Unit returns, where a value is genuinely required (that path keeps the
    # known ANY-extraction limitation, documented in the bug tracker).
    me lower_hir_block_unit(b: Block) -> HirBlock:
        if (hir_expr_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            eprint("[hir-lower] lower_block_unit:start")
            self.symbols.push_scope(ScopeKind.Block)
            var boot_stmts: [HirStmt] = []
            var boot_idx = 0
            while boot_idx < b.stmts.len():
                val boot_lowered_list = self.lower_hir_stmt_multi(b.stmts[boot_idx])
                var boot_li = 0
                while boot_li < boot_lowered_list.len():
                    boot_stmts = boot_stmts.push(boot_lowered_list[boot_li])
                    boot_li = boot_li + 1
                boot_idx = boot_idx + 1
            eprint("[hir-lower] lower_block_unit:done")
            self.symbols.pop_scope()
            return HirBlock(stmts: boot_stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

        self.symbols.push_scope(ScopeKind.Block)
        var stmts: [HirStmt] = []
        val stmt_count = b.stmts.len()
        var stmt_idx = 0
        while stmt_idx < stmt_count:
            val lowered_list: [HirStmt] = self.lower_hir_stmt_multi(b.stmts[stmt_idx])
            var li = 0
            while li < lowered_list.len():
                stmts = stmts.push(lowered_list[li])
                li = li + 1
            stmt_idx = stmt_idx + 1
        self.symbols.pop_scope()

        HirBlock(stmts: stmts, has: false, value: HirExpr(kind: HirExprKind.NilLit, type_: nil, span: b.span), span: b.span)

    me lower_asm(asm_node: AsmExpr) -> HirAsm:
        # Lower all constraint value expressions
        var hir_constraints: [HirAsmConstraint] = []
        for constraint in asm_node.constraints:
            val hir_value = self.lower_hir_expr(constraint.value)
            val hir_constraint = HirAsmConstraint(
                name: constraint.name,
                kind: constraint.kind,
                location: constraint.location,
                value: hir_value,
                span: constraint.span
            )
            hir_constraints.push(hir_constraint)

        HirAsm(
            asm_template: asm_node.asm_template,
            is_volatile: asm_node.is_volatile,
            constraints: hir_constraints,
            clobbers: asm_node.clobbers,
            span: asm_node.span
        )

    me lower_asm_match_arms(arms: [AsmMatchArm]) -> [HirAsmMatchArm]:
        var result: [HirAsmMatchArm] = []
        for arm in arms:
            var has_body = arm.has_asm_body
            var hir_body = if has_body:
                self.lower_asm(arm.asm_body)
            else:
                nil
            val hir_arm = HirAsmMatchArm(
                has_spec: arm.has_spec,
                spec: arm.spec,
                is_wildcard: arm.is_wildcard,
                has_asm_body: has_body,
                asm_body: hir_body,
                is_compile_error: arm.is_compile_error,
                error_message: arm.error_message,
                span: arm.span
            )
            result.push(hir_arm)
        result
