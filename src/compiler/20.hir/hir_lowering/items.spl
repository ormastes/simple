# HIR Lowering - Item Lowering
#
# This module handles lowering of top-level items (functions, classes, structs, enums, traits, impls) from AST to HIR.

use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use parser.*
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_lowering.types.HirLowering
use compiler.common.attributes.{parse_layout_attrs, parse_function_attrs, parse_export_attrs, FunctionAttr, ExportAttr}
use compiler.types.type_layout.{LayoutAttr, LayoutKind}
use compiler.common.dependency.visibility.{Visibility}

# Item Lowering (Functions, Classes, Structs, Enums, Traits, Impls)
# ============================================================================

impl HirLowering:
    me lower_module(module: Module) -> HirModule:
        """Lower a parsed module to HIR."""
        # Update module_filename so declare_module_symbols tags each symbol
        # with the correct per-module defining_module (prerequisite for
        # import-aware name disambiguation — see FR-COMPILER-002/003).
        self.module_filename = module.name

        # First pass: declare all top-level symbols
        self.declare_module_symbols(module)

        # Second pass: lower definitions
        var functions: Dict<SymbolId, HirFunction> = {}
        var classes: Dict<SymbolId, HirClass> = {}
        var structs: Dict<SymbolId, HirStruct> = {}
        var enums: Dict<SymbolId, HirEnum> = {}
        var bitfields: Dict<SymbolId, HirBitfield> = {}
        var traits: Dict<SymbolId, HirTrait> = {}
        var impls: [HirImpl] = []
        var constants: Dict<SymbolId, HirConst> = {}

        for name in module.functions.keys():
            val fn_ = module.functions[name]
            val hir_fn = self.lower_function(fn_)
            functions[hir_fn.symbol] = hir_fn

        for name in module.classes.keys():
            val class_ = module.classes[name]
            val hir_class = self.lower_class(class_)
            classes[hir_class.symbol] = hir_class

        for name in module.structs.keys():
            val struct_ = module.structs[name]
            val hir_struct = self.lower_struct(struct_)
            structs[hir_struct.symbol] = hir_struct

        for name in module.enums.keys():
            val enum_ = module.enums[name]
            val hir_enum = self.lower_enum(enum_)
            enums[hir_enum.symbol] = hir_enum

        for name in module.bitfields.keys():
            val bf = module.bitfields[name]
            val hir_bf = self.lower_bitfield(bf)
            bitfields[hir_bf.symbol] = hir_bf

        for name in module.traits.keys():
            val trait_ = module.traits[name]
            val hir_trait = self.lower_trait(trait_)
            traits[hir_trait.symbol] = hir_trait

        for impl_ in module.impls:
            impls = impls.push(self.lower_impl(impl_))

        for name in module.constants.keys():
            val const_ = module.constants[name]
            val hir_const = self.lower_const(const_)
            constants[hir_const.symbol] = hir_const

        # Lower static assertions
        var static_asserts: [HirStaticAssert] = []
        for assert_ in module.static_asserts:
            static_asserts = static_asserts.push(self.lower_static_assert(assert_))

        # Lower AOP advices
        var aop_advices: [HirAopAdvice] = []
        for advice in module.aop_advices:
            aop_advices = aop_advices.push(self.lower_aop_advice(advice))

        # Lower DI bindings
        var di_bindings: [HirDiBinding] = []
        for binding in module.di_bindings:
            di_bindings = di_bindings.push(self.lower_di_binding(binding))

        # Lower architecture rules
        var arch_rules: [HirArchRule] = []
        for rule in module.arch_rules:
            arch_rules = arch_rules.push(self.lower_arch_rule(rule))

        # Lower mock declarations
        var mock_decls: [HirMockDecl] = []
        for mock_decl in module.mock_decls:
            mock_decls = mock_decls.push(self.lower_mock_decl(mock_decl))

        # Lower imports
        var imports: [HirImport] = []
        for imp in module.imports:
            imports = imports.push(self.lower_import(imp))

        # Collect exports
        var exports: [text] = []
        for exp in module.exports:
            for item in exp.items:
                exports = exports.push(item)

        HirModule(
            name: module.name,
            path: "",
            imports: imports,
            exports: exports,
            symbols: self.symbols,
            functions: functions,
            classes: classes,
            structs: structs,
            enums: enums,
            bitfields: bitfields,
            traits: traits,
            impls: impls,
            constants: constants,
            static_asserts: static_asserts,
            aop_advices: aop_advices,
            di_bindings: di_bindings,
            arch_rules: arch_rules,
            mock_decls: mock_decls
        )

    me declare_module_symbols(module: Module):
        """Declare all top-level symbols."""
        # Pass module filename for visibility tracking
        val mod_name = Some(self.module_filename)

        # Use while loops instead of for-in (for-in doesn't work in compiled native code)
        val fn_keys = module.functions.keys()
        var idx = 0
        while idx < fn_keys.len():
            val name = fn_keys[idx]
            val fn_ = module.functions[name]
            if fn_ != nil:
                self.symbols.define(name, SymbolKind.Function, nil, fn_.span, fn_.visibility, false, mod_name)
            idx = idx + 1

        val cls_keys = module.classes.keys()
        idx = 0
        while idx < cls_keys.len():
            val name = cls_keys[idx]
            val class_ = module.classes[name]
            if class_ != nil:
                self.symbols.define(name, SymbolKind.Class, nil, class_.span, class_.visibility, false, mod_name)
            idx = idx + 1

        val str_keys = module.structs.keys()
        idx = 0
        while idx < str_keys.len():
            val name = str_keys[idx]
            val struct_ = module.structs[name]
            if struct_ != nil:
                self.symbols.define(name, SymbolKind.Struct, nil, struct_.span, struct_.visibility, false, mod_name)
            idx = idx + 1

        val enum_keys = module.enums.keys()
        idx = 0
        while idx < enum_keys.len():
            val name = enum_keys[idx]
            val enum_ = module.enums[name]
            if enum_ != nil:
                self.symbols.define(name, SymbolKind.Enum, nil, enum_.span, enum_.visibility, false, mod_name)
            idx = idx + 1

        val bf_keys = module.bitfields.keys()
        idx = 0
        while idx < bf_keys.len():
            val name = bf_keys[idx]
            val bf = module.bitfields[name]
            if bf != nil:
                self.symbols.define(name, SymbolKind.Struct, nil, bf.span, bf.visibility, false, mod_name)
            idx = idx + 1

        val trait_keys = module.traits.keys()
        idx = 0
        while idx < trait_keys.len():
            val name = trait_keys[idx]
            val trait_ = module.traits[name]
            if trait_ != nil:
                self.symbols.define(name, SymbolKind.Trait, nil, trait_.span, trait_.visibility, false, mod_name)
            idx = idx + 1

        val const_keys = module.constants.keys()
        idx = 0
        while idx < const_keys.len():
            val name = const_keys[idx]
            val const_ = module.constants[name]
            if const_ != nil:
                self.symbols.define(name, SymbolKind.Const, nil, const_.span, const_.visibility, const_.is_mutable, mod_name)
            idx = idx + 1

        # Declare impl methods
        var impl_idx = 0
        while impl_idx < module.impls.len():
            val impl_ = module.impls[impl_idx]
            val meth_keys = impl_.methods.keys()
            var mi = 0
            while mi < meth_keys.len():
                val name = meth_keys[mi]
                val fn_ = impl_.methods[name]
                self.symbols.define(name, SymbolKind.Method, nil, fn_.span, fn_.visibility, false, mod_name)
                mi = mi + 1
            impl_idx = impl_idx + 1

    me lower_import(imp: Import) -> HirImport:
        """Lower import declaration."""
        var items: [HirImportItem] = []
        for item in imp.items:
            items = items.push(HirImportItem(
                name: item.name,
                alias: item.alias,
                resolved: nil
            ))

        HirImport(
            module_path: imp.module,
            items: items,
            is_lazy: imp.is_lazy,
            span: imp.span
        )

    me lower_function(fn_: Function) -> HirFunction:
        """Lower function to HIR."""
        val fn_symbol_id = self.symbols.lookup(fn_.name).unwrap()
        self.current_function = Some(fn_symbol_id)
        self.symbols.push_scope(ScopeKind.Function)

        # Lower type parameters
        var type_params: [HirTypeParam] = []
        var tpi = 0
        while tpi < fn_.type_params.len():
            type_params = type_params.push(self.lower_type_param(fn_.type_params[tpi]))
            tpi = tpi + 1

        # Lower parameters
        var params: [HirParam] = []
        var pi = 0
        while pi < fn_.params.len():
            params = params.push(self.lower_param(fn_.params[pi]))
            pi = pi + 1

        # Lower return type — use explicit check instead of .map() ?? default
        # to avoid crash with null coalescing on Option.map result
        var return_type = HirType(kind: HirTypeKind.Unit, span: fn_.span)
        if fn_.return_type.?:
            val mapped = fn_.return_type.map(\t: self.lower_type(t))
            if mapped.?:
                return_type = mapped.unwrap()

        # Lower body
        val body = self.lower_block(fn_.body)

        self.symbols.pop_scope()
        self.current_function = nil

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(fn_.name, fn_.visibility)

        # Parse function attributes (@entry, @naked, @noreturn, @section, @interrupt)
        val fa = parse_function_attrs(fn_.attributes)
        val func_attr_opt: FunctionAttr? = if fa.is_entry or fa.is_naked or fa.is_noreturn or fa.section.? or fa.is_interrupt or fa.is_alloc or fa.is_no_alloc or fa.is_gpu_kernel or fa.is_simd:
            Some(fa)
        else:
            nil

        # Parse export attributes (@export("C"))
        val export = parse_export_attrs(fn_.attributes)

        # Seed effects from is_async annotation.
        # The full effect pass (effect_pass.spl) will refine these later.
        var initial_effects: [Effect] = []
        if fn_.is_async:
            initial_effects = initial_effects.push(Effect(kind: EffectKind.Async, span: fn_.span))

        val hir_func = HirFunction(
            symbol: fn_symbol_id,
            name: fn_.name,
            type_params: type_params,
            params: params,
            return_type: return_type,
            body: body,
            effects: initial_effects,
            visibility: effective_visibility,
            is_async: fn_.is_async,
            is_static: fn_.is_static,
            is_public: effective_visibility.is_public(),
            is_method: fn_.is_method,
            is_mutable: fn_.is_mutable,
            is_const: fn_.is_const,
            is_extern: fn_.is_extern,
            func_attr: func_attr_opt,
            export_attr: export,
            doc_comment: fn_.doc_comment,
            span: fn_.span
        )

        # Validate async functions
        if fn_.is_async:
            self.validate_async_function(hir_func)

        hir_func

    me lower_param(p: Param) -> HirParam:
        """Lower function parameter."""
        val type_ = p.type_.map(\t: self.lower_type(t)) ?? HirType(kind: HirTypeKind.Infer(0, 0), span: p.span)
        val symbol = self.symbols.define(p.name, SymbolKind.Parameter, Some(type_), p.span, Visibility.Private, false, nil)

        HirParam(
            symbol: symbol,
            name: p.name,
            type_: type_,
            default: p.default.map(\e: self.lower_expr(e)),
            span: p.span
        )

    me lower_class(class_: Class) -> HirClass:
        """Lower class to HIR."""
        val symbol = self.symbols.lookup(class_.name).unwrap()
        self.symbols.push_scope(ScopeKind.Class)

        var type_params: [HirTypeParam] = []
        for tp in class_.type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in class_.fields:
            fields = fields.push(self.lower_field(f))

        var methods: Dict<text, SymbolId> = {}
        for name in class_.methods.keys():
            val fn_ = class_.methods[name]
            val hir_fn = self.lower_function(fn_)
            methods[name] = hir_fn.symbol

        self.symbols.pop_scope()

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(class_.name, class_.visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout = parse_layout_attrs(class_.attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != LayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil

        # Parse export attributes (@export("C"))
        val export = parse_export_attrs(class_.attributes)

        HirClass(
            symbol: symbol,
            name: class_.name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: class_.doc_comment,
            span: class_.span,
            layout_attr: layout_opt,
            export_attr: export,
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_struct(struct_: Struct) -> HirStruct:
        """Lower struct to HIR."""
        val symbol = self.symbols.lookup(struct_.name).unwrap()

        var type_params: [HirTypeParam] = []
        for tp in struct_.type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var fields: [HirField] = []
        for f in struct_.fields:
            fields = fields.push(self.lower_field(f))

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(struct_.name, struct_.visibility)

        # Parse layout attributes (@repr, @packed, @align)
        val layout = parse_layout_attrs(struct_.attributes)
        val layout_opt: LayoutAttr? = if layout.layout_kind != LayoutKind.Simple or layout.explicit_align.? or layout.is_packed:
            Some(layout)
        else:
            nil

        HirStruct(
            symbol: symbol,
            name: struct_.name,
            type_params: type_params,
            fields: fields,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: struct_.doc_comment,
            span: struct_.span,
            layout_attr: layout_opt,
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_field(f: Field) -> HirField:
        """Lower field to HIR."""
        val type_ = self.lower_type(f.type_)
        val symbol = self.symbols.define(f.name, SymbolKind.Field, Some(type_), f.span, f.visibility, false, nil)

        # Lower default without closures to avoid bootstrap SSA issues
        val lowered_default = if f.default.?:
            Some(self.lower_expr(f.default.unwrap()))
        else:
            nil

        HirField(
            symbol: symbol,
            name: f.name,
            type_: type_,
            default: lowered_default,
            visibility: f.visibility,
            is_public: f.visibility.is_public(),
            is_volatile: f.is_volatile,
            has_bits_attr: f.has_bits,
            bits_width: f.bits,
            fixed_address: f.fixed_address,
            span: f.span
        )

    me lower_enum(enum_: Enum) -> HirEnum:
        """Lower enum to HIR."""
        val symbol = self.symbols.lookup(enum_.name).unwrap()

        var type_params: [HirTypeParam] = []
        for tp in enum_.type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        var variants: [HirVariant] = []
        for v in enum_.variants:
            variants = variants.push(self.lower_variant(v))

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(enum_.name, enum_.visibility)

        HirEnum(
            symbol: symbol,
            name: enum_.name,
            type_params: type_params,
            variants: variants,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: enum_.doc_comment,
            span: enum_.span,
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_variant(v: Variant) -> HirVariant:
        """Lower enum variant."""
        val symbol = self.symbols.define(v.name, SymbolKind.EnumVariant, nil, v.span, Visibility.Public, false, nil)

        val kind = match v.kind:
            case Unit:
                HirVariantKind.Unit
            case Tuple(types):
                var hir_types: [HirType] = []
                for t in types:
                    hir_types = hir_types.push(self.lower_type(t))
                HirVariantKind.Tuple(hir_types)
            case Struct(fields):
                var hir_fields: [HirField] = []
                for f in fields:
                    hir_fields = hir_fields.push(self.lower_field(f))
                HirVariantKind.Struct(hir_fields)

        HirVariant(
            symbol: symbol,
            name: v.name,
            kind: kind,
            span: v.span
        )

    me lower_bitfield(bf: Bitfield) -> HirBitfield:
        """Lower bitfield to HIR."""
        val symbol = self.symbols.lookup(bf.name).unwrap()

        val backing = self.lower_type(bf.backing_type)

        # Lower fields and compute bit offsets
        var fields: [HirBitfieldField] = []
        var bit_offset: i64 = 0
        for f in bf.fields:
            val hir_field = self.lower_bitfield_field(f, bit_offset)
            fields = fields.push(hir_field)
            bit_offset = bit_offset + hir_field.bit_width

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(bf.name, bf.visibility)

        HirBitfield(
            symbol: symbol,
            name: bf.name,
            backing_type: backing,
            fields: fields,
            total_bits: bit_offset,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: bf.doc_comment,
            span: bf.span
        )

    me lower_bitfield_field(f: BitfieldField, offset: i64) -> HirBitfieldField:
        """Lower bitfield field to HIR."""
        val symbol = self.symbols.define(f.name, SymbolKind.Field, nil, f.span, Visibility.Private, false, nil)

        # Determine bit width:
        # 1. Explicit @bits(N) takes precedence
        # 2. For reserved fields, use explicit bits
        # 3. For typed fields, infer from type
        val bit_width = if f.bits.?:
            f.bits.unwrap()
        elif f.is_reserved:
            0  # Reserved without explicit bits = 0
        else:
            # Infer from type (use default primitive widths)
            self.infer_bit_width(f.type_)

        HirBitfieldField(
            symbol: symbol,
            name: f.name,
            type_: f.type_.map(\t: self.lower_type(t)),
            bit_width: bit_width,
            bit_offset: offset,
            is_reserved: f.is_reserved,
            span: f.span
        )

    fn infer_bit_width(type_: Type?) -> i64:
        """Infer bit width from type."""
        if not type_.?:
            return 0

        val t = type_.unwrap()
        match t.kind:
            case Named(name, _):
                match name:
                    case "bool": 1
                    case "u1" | "i1": 1
                    case "u2" | "i2": 2
                    case "u3" | "i3": 3
                    case "u4" | "i4": 4
                    case "u5" | "i5": 5
                    case "u6" | "i6": 6
                    case "u7" | "i7": 7
                    case "u8" | "i8": 8
                    case "u9" | "i9": 9
                    case "u10" | "i10": 10
                    case "u11" | "i11": 11
                    case "u12" | "i12": 12
                    case "u16" | "i16": 16
                    case "u32" | "i32": 32
                    case "u64" | "i64": 64
                    case _: 0  # Unknown type, require explicit @bits
            case _: 0  # Complex types require explicit @bits

    me lower_trait(trait_: Trait) -> HirTrait:
        """Lower trait to HIR."""
        val symbol = self.symbols.lookup(trait_.name).unwrap()

        self.symbols.push_scope(ScopeKind.Class)

        var type_params: [HirTypeParam] = []
        for tp in trait_.type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        # Lower supertraits
        var supertraits: [HirType] = []
        for st in trait_.super_traits:
            supertraits = supertraits.push(self.lower_type(st))

        # Lower where clause
        var where_clause: [HirTraitBound] = []
        for bound in trait_.where_clause:
            where_clause = where_clause.push(self.lower_trait_bound(bound))

        # Lower associated type declarations
        var assoc_types: [HirAssocTypeDecl] = []
        for at in trait_.assoc_types:
            assoc_types = assoc_types.push(self.lower_assoc_type_decl(at))

        # Separate methods into abstract (no body) and defaults (with body)
        var abstract_methods: [HirFunction] = []
        var defaults: [HirFunction] = []
        for m in trait_.methods:
            val hir_fn = self.lower_function(m)
            # Check if method has a body (default implementation)
            # Function.body is a Block, check if it has statements
            if m.body.stmts.is_empty() and m.body.value.is_none():
                abstract_methods = abstract_methods.push(hir_fn)
            else:
                defaults = defaults.push(hir_fn)

        self.symbols.pop_scope()

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(trait_.name, trait_.visibility)

        HirTrait(
            symbol: symbol,
            name: trait_.name,
            type_params: type_params,
            methods: abstract_methods,
            supertraits: supertraits,
            defaults: defaults,
            where_clause: where_clause,
            assoc_types: assoc_types,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            doc_comment: trait_.doc_comment,
            span: trait_.span,
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {}
        )

    me lower_impl(impl_: Impl) -> HirImpl:
        """Lower impl block to HIR."""
        self.symbols.push_scope(ScopeKind.Impl)

        # Lower generic type parameters
        var type_params: [HirTypeParam] = []
        for tp in impl_.type_params:
            type_params = type_params.push(self.lower_type_param(tp))

        # Lower where clause
        var where_clause: [HirTraitBound] = []
        for bound in impl_.where_clause:
            where_clause = where_clause.push(self.lower_trait_bound(bound))

        val type_ = self.lower_type(impl_.type_)
        val trait_ = impl_.trait_.map(\t: self.lower_type(t))

        var methods: Dict<text, SymbolId> = {}
        for name in impl_.methods.keys():
            val fn_ = impl_.methods[name]
            val hir_fn = self.lower_function(fn_)
            methods[name] = hir_fn.symbol

        # Lower associated type implementations
        var assoc_type_impls: [HirAssocTypeImpl] = []
        for at in impl_.assoc_types:
            assoc_type_impls = assoc_type_impls.push(self.lower_assoc_type_impl(at))

        self.symbols.pop_scope()

        HirImpl(
            type_: type_,
            trait_: trait_,
            type_params: type_params,
            where_clause: where_clause,
            methods: methods,
            assoc_type_impls: assoc_type_impls,
            span: impl_.span
        )

    me lower_assoc_type_decl(at: AssocTypeDecl) -> HirAssocTypeDecl:
        """Lower associated type declaration from trait to HIR."""
        var bounds: [HirType] = []
        for b in at.bounds:
            bounds = bounds.push(self.lower_type(b))

        # Lower default type if present
        val default_type = if at.has_default:
            Some(self.lower_type(at.default))
        else:
            nil

        HirAssocTypeDecl(
            name: at.name,
            bounds: bounds,
            default: default_type,
            span: at.span
        )

    me lower_assoc_type_impl(at: AssocTypeDecl) -> HirAssocTypeImpl:
        """Lower associated type implementation from impl block to HIR.

        In an impl block, `type Item = i64` provides a concrete type.
        The `default` field of AssocTypeDecl holds the concrete type.
        """
        val concrete = if at.has_default:
            self.lower_type(at.default)
        else:
            # Missing concrete type -- report error
            self.error("associated type '{at.name}' in impl block must have a concrete type", at.span)
            HirType(kind: HirTypeKind.Error, span: at.span)

        HirAssocTypeImpl(
            name: at.name,
            concrete_type: concrete,
            span: at.span
        )

    me lower_const(const_: Const) -> HirConst:
        """Lower constant to HIR."""
        val symbol = self.symbols.lookup(const_.name).unwrap()
        val type_ = const_.type_.map(\t: self.lower_type(t)) ?? HirType(kind: HirTypeKind.Infer(0, 0), span: const_.span)
        val value = self.lower_expr(const_.value)

        # Compute effective visibility using filename matching
        val effective_visibility = self.compute_visibility(const_.name, const_.visibility)

        HirConst(
            symbol: symbol,
            name: const_.name,
            type_: type_,
            value: value,
            is_mutable: const_.is_mutable,
            visibility: effective_visibility,
            is_public: effective_visibility.is_public(),
            is_volatile: const_.is_volatile,
            fixed_address: const_.fixed_address,
            span: const_.span
        )

    me lower_static_assert(assert_: StaticAssert) -> HirStaticAssert:
        """Lower static assertion to HIR."""
        val condition = self.lower_expr(assert_.condition)

        HirStaticAssert(
            condition: condition,
            message: assert_.message,
            span: assert_.span
        )

    fn lower_aop_advice(advice: AopAdvice) -> HirAopAdvice:
        """Lower AOP advice to HIR."""
        HirAopAdvice(
            predicate_text: advice.pointcut,
            advice_function: advice.handler,
            form: advice.form,
            priority: advice.priority,
            span: advice.span
        )

    fn lower_di_binding(binding: DiBinding) -> HirDiBinding:
        """Lower DI binding to HIR."""
        HirDiBinding(
            predicate_text: binding.pointcut,
            implementation: binding.implementation,
            span: binding.span
        )

    fn lower_arch_rule(rule: ArchRule) -> HirArchRule:
        """Lower architecture rule to HIR."""
        HirArchRule(
            kind: rule.kind,
            predicate_text: rule.pointcut,
            message: rule.message,
            span: rule.span
        )

    fn lower_mock_decl(mock_decl: MockDecl) -> HirMockDecl:
        """Lower mock declaration to HIR."""
        HirMockDecl(
            name: mock_decl.name,
            trait_name: mock_decl.trait_name,
            span: mock_decl.span
        )

fn HirLowering_dot_lower_module(self: HirLowering, module: Module) -> HirModule:
    """Bootstrap-safe HIR lowering entrypoint."""
    # Update module_filename so declare_module_symbols tags each symbol
    # with the correct per-module defining_module (FR-COMPILER-002/003).
    self.module_filename = module.name
    self.declare_module_symbols(module)

    var functions: Dict<SymbolId, HirFunction> = {}
    var classes: Dict<SymbolId, HirClass> = {}
    var structs: Dict<SymbolId, HirStruct> = {}
    var enums: Dict<SymbolId, HirEnum> = {}
    var bitfields: Dict<SymbolId, HirBitfield> = {}
    var traits: Dict<SymbolId, HirTrait> = {}
    var impls: [HirImpl] = []
    var constants: Dict<SymbolId, HirConst> = {}

    val fn_key_list = module.functions.keys()
    var fi = 0
    while fi < fn_key_list.len():
        val name = fn_key_list[fi]
        val fn_ = module.functions[name]
        val hir_fn = self.lower_function(fn_)
        functions[hir_fn.symbol] = hir_fn
        fi = fi + 1

    for name in module.classes.keys():
        val class_ = module.classes[name]
        val hir_class = self.lower_class(class_)
        classes[hir_class.symbol] = hir_class

    for name in module.structs.keys():
        val struct_ = module.structs[name]
        val hir_struct = self.lower_struct(struct_)
        structs[hir_struct.symbol] = hir_struct

    for name in module.enums.keys():
        val enum_ = module.enums[name]
        val hir_enum = self.lower_enum(enum_)
        enums[hir_enum.symbol] = hir_enum

    for name in module.bitfields.keys():
        val bf = module.bitfields[name]
        val hir_bf = self.lower_bitfield(bf)
        bitfields[hir_bf.symbol] = hir_bf

    for name in module.traits.keys():
        val trait_ = module.traits[name]
        val hir_trait = self.lower_trait(trait_)
        traits[hir_trait.symbol] = hir_trait

    for impl_ in module.impls:
        impls = impls.push(self.lower_impl(impl_))

    for name in module.constants.keys():
        val const_ = module.constants[name]
        val hir_const = self.lower_const(const_)
        constants[hir_const.symbol] = hir_const

    var static_asserts: [HirStaticAssert] = []
    for assert_ in module.static_asserts:
        static_asserts = static_asserts.push(self.lower_static_assert(assert_))

    var aop_advices: [HirAopAdvice] = []
    for advice in module.aop_advices:
        aop_advices = aop_advices.push(self.lower_aop_advice(advice))

    var di_bindings: [HirDiBinding] = []
    for binding in module.di_bindings:
        di_bindings = di_bindings.push(self.lower_di_binding(binding))

    var arch_rules: [HirArchRule] = []
    for rule in module.arch_rules:
        arch_rules = arch_rules.push(self.lower_arch_rule(rule))

    var mock_decls: [HirMockDecl] = []
    for mock_decl in module.mock_decls:
        mock_decls = mock_decls.push(self.lower_mock_decl(mock_decl))

    var imports: [HirImport] = []
    for imp in module.imports:
        imports = imports.push(self.lower_import(imp))

    var exports: [text] = []
    for exp in module.exports:
        for item in exp.items:
            exports = exports.push(item)

    HirModule(
        name: module.name,
        path: "",
        imports: imports,
        exports: exports,
        symbols: self.symbols,
        functions: functions,
        classes: classes,
        structs: structs,
        enums: enums,
        bitfields: bitfields,
        traits: traits,
        impls: impls,
        constants: constants,
        static_asserts: static_asserts,
        aop_advices: aop_advices,
        di_bindings: di_bindings,
        arch_rules: arch_rules,
        mock_decls: mock_decls
    )
