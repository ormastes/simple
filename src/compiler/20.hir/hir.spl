# HIR - High-level Intermediate Representation
#
# This module re-exports HIR components from split modules.
# The implementation has been split into:
# - hir_types.spl: Core types, symbol table, method resolution (556 lines)
# - hir_definitions.spl: HIR node definitions (374 lines)
# - hir_lowering.spl: AST→HIR transformation (1148 lines)

export use compiler.hir.hir_types.*
export use compiler.hir.hir_definitions.*
export use compiler.hir.hir_lowering.module_surface.{
    ModuleSurface, ModuleSurfacesByName,
    ModuleSurfaceCallable, ModuleSurfaceComposite, ModuleSurfaceEnum,
    ModuleSurfaceTrait, ModuleSurfaceImpl, ModuleSurfaceConst,
    module_surface_from_module, module_surfaces_from_modules,
    module_surface_source_matches, module_surface_trait_origin_key
}
use compiler.hir.hir_lowering.types.{HirLowering, LoweringError, LoweringErrorKind, hirlowering_for_module}
use compiler.hir.hir_lowering.async.{AsyncFunctionCheck}
use compiler.hir.hir_lowering.async_errors.{AsyncErrorCode, AsyncError, AsyncErrorCollector}
use compiler.hir.hir_lowering.items.{imported_symbol_local_name}

# Re-export all HIR components for backward compatibility
export HirAopAdvice
export HirLowering, LoweringError, LoweringErrorKind, hirlowering_for_module
export AsyncFunctionCheck
export AsyncErrorCode, AsyncError, AsyncErrorCollector
export imported_symbol_local_name
