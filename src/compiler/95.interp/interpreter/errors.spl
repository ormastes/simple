            description: "A dependency cycle was detected but classified as a warning for the current compilation mode",
            causes: ["A cycle exists only through soft or optional edges", "Compatibility mode keeps the cycle non-fatal"],
            fixes: ["Break the cycle before enabling stricter production gates", "Document why the soft cycle is intentional"],
            example_bad: nil, example_good: nil,
