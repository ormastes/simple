# Driver Types - Compiler Driver Type Definitions
#
# This module contains compiler driver type definitions:
# - CompileMode: Compilation mode (interpret, JIT, AOT, check)
# - OutputFormat: Output format options
# - CompileOptions: Compilation configuration
# - CompileResult: Compilation result types
# - SourceFile: Source file representation
#
# The compiler driver implementation is in driver.spl

use compiler.hir.hir.*
use compiler.mir.mir.*
use compiler.frontend.core.lexer.*
use compiler.core.parser.*
use compiler.frontend.treesitter.*
use compiler.blocks.blocks.*
use compiler.common.config.*
use compiler.backend.backend_port.{BackendPort}
use compiler.backend.backend_types.{BackendResult, BackendError}
use compiler.backend.codegen.{CodegenMode}
use compiler.backend.backend.compiler.{CompilerBackendImpl}
use compiler.backend.backend.interpreter.{InterpreterBackendImpl}
use compiler.backend.backend.sdn.{SdnBackendImpl}
use compiler.common.di.{DiContainer}
use compiler.tools.aop.{AopWeaver, LogAspect}
use compiler.frontend.core.aop.{WeavingConfig, Pointcut, PointcutKind}
use compiler.common.compiler_services.{CompilerServices, create_default_services, LoggerPort, ModuleLoaderPort}
use compiler.common.compiler_services.{_make_noop_lexer, _make_noop_parser, _make_noop_desugarer}
use compiler.common.compiler_services.{_make_noop_type_checker, _make_noop_hir_lowerer, _make_noop_mir_lowerer}
use compiler.common.compiler_services.{_noop_resolve}
use compiler.mdsoc.feature.events.ports.{CompilationEventPort, create_noop_event_port}
use compiler.mdsoc.feature.module_loading.app.module_storage_port.{ModuleStoragePort}
