# Driver — Logging Helpers
#
# Lightweight logging free functions shared across driver modules.
# Extracted from driver.spl.

use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text
extern fn rt_heap_registry_count() -> i64
extern fn rt_time_now_monotonic_ms() -> i64

fn driver_phase_trace_enabled() -> bool:
    ((rt_env_get("SIMPLE_COMPILER_PHASE_PROFILE") ?? "") == "1") or ((rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1")

# Monotonic base captured at the first log_phase call, so every phase marker
# carries a wall-clock delta. This is what turns the [BOOTSTRAP-PHASE] trail
# into a usable profile: the stage-4 graph-load wall
# (doc/08_tracking/bug/bootstrap_stage4_graph_load_timeout_2026-07-05.md) was
# root-caused to interpreted parse (phase2) using exactly these deltas.
var _g_phase_t0_ms: i64 = 0
var _g_phase_t0_set: bool = false

fn _phase_elapsed_ms() -> i64:
    val now = rt_time_now_monotonic_ms()
    if not _g_phase_t0_set:
        _g_phase_t0_ms = now
        _g_phase_t0_set = true
    now - _g_phase_t0_ms

pub fn log_debug(msg: text):
    val _ = msg
    ()
pub fn log_trace(msg: text):
    val _ = msg
    ()
pub fn log_info(msg: text):
    val _ = msg
    ()
pub fn log_warn(msg: text):
    print "[WARN] {msg}"
pub fn log_error(msg: text):
    print "[ERROR] {msg}"

pub fn log_phase(msg: text):
    if driver_phase_trace_enabled():
        eprint("[BOOTSTRAP-PHASE] +{_phase_elapsed_ms()}ms {msg} heap_registry={rt_heap_registry_count()}")

pub fn log_module_surface_released(path: text, seq: i64):
    eprint("phase2:surface:file:released path={path} seq={seq} heap_registry={rt_heap_registry_count()}")
