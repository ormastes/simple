# Driver — Logging Helpers
#
# Lightweight logging free functions shared across driver modules.
# Extracted from driver.spl.

use std.nogc_sync_mut.io.process_ops.{eprint}

pub fn log_debug(msg: text):
    val _ = msg
    ()
pub fn log_trace(msg: text):
    val _ = msg
    ()
pub fn log_info(msg: text):
    val _ = msg
    ()
pub fn log_warn(msg: text):
    print "[WARN] {msg}"
pub fn log_error(msg: text):
    print "[ERROR] {msg}"

pub fn log_phase(msg: text):
    eprint("[BOOTSTRAP-PHASE] {msg}")
