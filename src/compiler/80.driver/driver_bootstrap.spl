    HirModule(
        name: "app.cli.bootstrap_main",
        path: "",
        imports: [],
        exports: [],
        domain_blocks: [],
        symbols: SymbolTable.new(),
        functions: {},
        classes: {},
        structs: {},
        enums: {},
        bitfields: {},
        traits: {},
        impls: [],
        constants: {},
        static_asserts: [],
        aop_advices: [],
        di_bindings: [],
        arch_rules: [],
        mock_decls: [],
        types: []
    )

pub fn bootstrap_driver_stub_mir_function(symbol: SymbolId, name: text) -> MirFunction:
    val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
    val block = MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [],
        terminator: MirTerminator.Ret(Some(mir_operand_const_int(0)))
    )
    MirFunction(
        symbol: symbol,
        name: name,
        signature: signature,
        locals: [],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: nil,
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: nil,
        has_fast_math: false,
        unroll_factor: 0,
        pipeline_ii: 0,
        memory_banks: 0
    )

pub fn bootstrap_lower_hir_globals_to_mir_module_driver(ctx: CompileContext) -> MirModule:
    """Driver-local entry point for real bootstrap MIR lowering."""
    log_phase("aot:bootstrap_driver_mir:start")
    val target_context = driver_mir_target_context(ctx.options)
    val module = bootstrap_lower_hir_globals_to_mir_module_for_target(target_context)
    log_phase("aot:bootstrap_driver_mir:done")
    module

fn bootstrap_ssa_phi_function(fn_: MirFunction) -> MirFunction:
    # A single-block function is NOT skippable: a straight-line reassignment
    # (e.g. a fixed-width `c = c + 1` twice, #171) lowers to multiple defs of
    # one local inside ONE block, which the textual `%lN` emitter would emit as
    # a duplicate SSA def -> llc "multiple definition of local value". The
    # alloca transform below slots such single-block multi-def locals (its own
    # `slotted.len() == 0` check keeps a single-def single-block function a
    # byte-for-byte no-op), so only a truly empty function is skipped here.
    if fn_.blocks.len() == 0:
        return fn_
    # This whole file only runs under the SIMPLE_BOOTSTRAP real-LLVM path
    # (bootstrap_emit_real_llvm_object / bootstrap_emit_real_llvm_module_object,
    # both gated on SIMPLE_BOOTSTRAP_REAL_LLVM upstream in driver.spl), so the
    # alloca-per-reassigned-local transform always applies here instead of the
    # hand-built phi mechanism, which cannot correctly resolve each phi's
    # incoming-value-per-predecessor for real control flow. An entry-block
    # alloca dominates every use by construction, so it cannot produce the
    # `undef` phi operands the join-predecessor phi materialization could.
    val rewritten = ssa_alloca_transform_blocks(fn_.blocks, fn_.locals, fn_.entry_block)
    if bootstrap_trace_enabled():
        print "[bootstrap-real-llvm] ssa-result {fn_.name} applied={rewritten.applied} reason={rewritten.reason} phi={rewritten.phi_required_count}"
    if rewritten.applied:
        return MirFunction.with_blocks(fn_, rewritten.blocks)
    fn_

fn bootstrap_is_runtime_declared_name(name: text) -> bool:
    """Names emit_runtime_declarations() (asm_constraints_helpers.spl) always
    statically pre-declares with their REAL signature but does not also add to
    `defined_func_names` (that dict only covers a subset -- see its own
    registrations). bootstrap_emit_llvm_trailer's fallback below emits a
    generic `declare {ret} @name(...)` for any call target not covered by
    EITHER check, which is a wrong-signature REDEFINITION for these -- llc
    rejects the module. This used to be a stale 6-name list that predated
    rt_interp_cstr/rt_raw_u64_to_string/rt_raw_i64_to_string's addition to the
    static block (Bug #136 string interpolation); Task #144 hit the same gap
    routing `n.to_string()` through rt_raw_i64_to_string + rt_interp_cstr.
    Keep this list in sync with the static declares that aren't also added to
    defined_func_names. Do NOT broaden this to `name.starts_with("rt_")`:
    rt_len (and other rt_* helpers with no static declare, e.g. rt_string_data,
    rt_string_starts_with) rely on the generic fallback declare below to be
    callable at all.
    """
    name == "rt_get_args" or name == "rt_env_get" or name == "rt_print" or name == "rt_println" or
    name == "rt_panic" or name == "rt_array_get" or name == "rt_interp_cstr" or
    name == "rt_raw_u64_to_string" or name == "rt_raw_i64_to_string" or name == "rt_raw_bool_to_string" or
    name == "rt_raw_f64_to_string"

fn bootstrap_unknown_decl_return_type(name: text) -> text:
    if name == "env_get":
        return "ptr"
    "i64"

fn bootstrap_emit_llvm_trailer(translator: MirToLlvm):
    if translator.unknown_func_decls.len() > 0:
        translator.builder.emit("")
        translator.builder.emit("; External call declarations")
        for unknown_name in translator.unknown_func_decls.keys():
            if not translator.defined_func_names.has(unknown_name) and not bootstrap_is_runtime_declared_name(unknown_name):
                translator.builder.emit("declare {bootstrap_unknown_decl_return_type(unknown_name)} @{unknown_name}(...)")
    val string_globals = llvm_bootstrap_string_globals_text()
    if string_globals != "":
        translator.builder.emit("")
        translator.builder.emit("; String constants")
        translator.builder.emit(string_globals)

pub fn bootstrap_emit_real_llvm_object(output: text, opt_level_i64: i64) -> CompileResult:
    """Emit LLVM for bootstrap MIR functions from the local driver module instance."""
    log_phase("aot:bootstrap_real_llvm:start")
    val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.Host, nil)
    val temp_obj = llvm_bootstrap_last_object_path()
    val temp_ir = bootstrap_llvm_ir_path_from_object_path(temp_obj)
    var translator = MirToLlvm.create("app.cli.bootstrap_main", CodegenTarget.Host, nil)
    translator.builder.emit_module_header()
    translator.emit_runtime_declarations()
    val count = bootstrap_mir_function_count()
    print "[bootstrap-real-llvm] count {count}"
    log_phase("aot:bootstrap_real_llvm:functions")
    var idx = 0
    while idx < count:
        val name = bootstrap_mir_function_name_at(idx)
        print "[bootstrap-real-llvm] function {name}"
        val fn_ = bootstrap_mir_function_at(idx)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm] ssa-start {name}"
        val ssa_fn = bootstrap_ssa_phi_function(fn_)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm] body-start {name}"
        val body = MirBody.from_function(ssa_fn)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm] translate-start {name}"
        translator.translate_function(if name == "main": "__simple_main" else: name, body)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm] translate-done {name}"
        idx = idx + 1
    bootstrap_emit_llvm_trailer(translator)
    val llvm_ir = translator.builder.build()
    log_phase("aot:bootstrap_real_llvm:compile")
    val result = compile_ir_to_object(llvm_ir, config, bootstrap_llvm_opt_level(opt_level_i64))
    if result.is_err():
        val err = result.unwrap_err()
        return CompileResult.CodegenError(bootstrap_llvm_phase_message("llc", "ir={temp_ir} obj={temp_obj}", err))
    val bootstrap_obj = temp_obj
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
        log_phase("aot:bootstrap_real_llvm:copied_obj")
        return CompileResult.Success(obj_path)
    CompileResult.CodegenError(
        bootstrap_llvm_phase_message(
            "object",
            "source={bootstrap_obj} dest={obj_path}",
            "Bootstrap real LLVM did not preserve an object file"
        )
    )

pub fn bootstrap_emit_real_llvm_module_object(module: MirModule, output: text, opt_level_i64: i64) -> CompileResult:
    """Emit LLVM for the bootstrap MIR module returned through CompileContext."""
    log_phase("aot:bootstrap_real_llvm_module:start")
    if module.functions.len() == 0:
        return CompileResult.CodegenError("Bootstrap module LLVM has no MIR functions")
    val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.Host, nil)
    val temp_obj = llvm_bootstrap_last_object_path()
    val temp_ir = bootstrap_llvm_ir_path_from_object_path(temp_obj)
    var translator = MirToLlvm.create("app.cli.bootstrap_main", CodegenTarget.Host, nil)
    translator.builder.emit_module_header()
    translator.emit_runtime_declarations()
    val fn_count = module.functions.len()
    if bootstrap_trace_enabled():
        print "[bootstrap-real-llvm-module] count {fn_count}"
    for fn_ in module.functions.values():
        val body = MirBody.from_function(fn_)
        val name = if fn_.name == "main": "__simple_main" else: fn_.name
        val ret_ty = translator.llvm_type_text(body.return_ty)
        translator.remember_function_return_type(fn_.name, ret_ty)
        translator.remember_function_return_type(name, ret_ty)
    for fn_ in module.functions.values():
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm-module] function {fn_.name}"
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm-module] ssa-start {fn_.name}"
        val ssa_fn = bootstrap_ssa_phi_function(fn_)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm-module] body-start {fn_.name}"
        val body = MirBody.from_function(ssa_fn)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm-module] translate-start {fn_.name}"
        translator.translate_function(if fn_.name == "main": "__simple_main" else: fn_.name, body)
        if bootstrap_trace_enabled():
            print "[bootstrap-real-llvm-module] translate-done {fn_.name}"
    bootstrap_emit_llvm_trailer(translator)
    val llvm_ir = translator.builder.build()
    log_phase("aot:bootstrap_real_llvm_module:compile")
    val result = compile_ir_to_object(llvm_ir, config, bootstrap_llvm_opt_level(opt_level_i64))
    if result.is_err():
        val err = result.unwrap_err()
        return CompileResult.CodegenError(bootstrap_llvm_phase_message("llc", "ir={temp_ir} obj={temp_obj}", err))
    val bootstrap_obj = temp_obj
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
        log_phase("aot:bootstrap_real_llvm_module:copied_obj")
        return CompileResult.Success(obj_path)
    CompileResult.CodegenError(
        bootstrap_llvm_phase_message(
            "object",
            "source={bootstrap_obj} dest={obj_path}",
            "Bootstrap module LLVM did not preserve an object file"
        )
    )

pub fn bootstrap_emit_driver_stub_llvm_object(output: text, opt_level_i64: i64) -> CompileResult:
    """Fail closed: bootstrap LLVM stubs are not valid compiler artifacts."""
    val _ = output
    val _opt = opt_level_i64
    CompileResult.CodegenError("bootstrap driver stub LLVM was removed")

pub fn compile_bootstrap_context_to_native(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Compile the bootstrap MIR module stored on the context.

    Bootstrap stages must produce a real native compiler.  Seed-wrapper and
    ret-0 stub fallbacks are intentionally rejected.
    """
    if (rt_env_get("SIMPLE_BOOTSTRAP_DIRECT_STUB_IR") ?? "") == "1":
        return bootstrap_compile_to_native_local(ctx, backend_name, output)
    val is_release = ctx.options.release
    val opt_level = bootstrap_native_opt_level(ctx, is_release)
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_mir_function_count() > 0:
        val real_result = bootstrap_emit_real_llvm_object(output, opt_level)
        match real_result:
            case CompileResult.Success(_): ()
            case _: return real_result
    elif ctx.bootstrap_entry_mir.?:
        val module = ctx.bootstrap_entry_mir.unwrap()
        val real_result = bootstrap_emit_real_llvm_module_object(module, output, opt_level)
        match real_result:
            case CompileResult.Success(_): ()
            case _: return real_result
    else:
        val compiled = compile_bootstrap_module_with_backend(backend_name, is_release, opt_level)
        if compiled.is_err():
            val err = compiled.unwrap_err()
            return CompileResult.CodegenError(
                bootstrap_llvm_phase_message("worker", "backend={backend_name} output={obj_path}", err.message)
            )
        val bootstrap_obj = llvm_bootstrap_last_object_path()
        if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
            log_phase("aot:bootstrap_native_context:copied_obj")
        else:
            return CompileResult.CodegenError(
                bootstrap_llvm_phase_message(
                    "object",
                    "source={bootstrap_obj} dest={obj_path}",
                    "Bootstrap backend did not preserve an object file"
                )
            )
    # Both branches above unconditionally emit the bootstrap module object via
    # real LLVM+llc (bootstrap_emit_real_llvm_module_object /
    # compile_bootstrap_module_with_backend), regardless of the requested
    # --backend. The link step must follow the actual emission mode, not the
    # outer backend flag: gating this on effective_backend let a non-LLVM
    # backend (e.g. cranelift, as hardcoded by bootstrap-from-scratch.sh
    # Stage 2) send an LLVM-emitted object through the generic linker, which
    # never synthesizes the C main() entry wrapper -> "Undefined symbols: _main".
    val llvm_opts = NativeLinkOptions(
        debug: ctx.options.debug_info,
        verbose: ctx.options.verbose,
        pie: false,
        bare_metal: false,
        opt_level: opt_level,
        stage4_backend: "llvm",
        stage4_compiler_hash: native_build_compiler_identity()
    )
    match link_llvm_native([obj_path], output, llvm_opts):
        case Ok(_):
            CompileResult.Success(output)
        case Err(e):
            CompileResult.CodegenError(
                bootstrap_llvm_phase_message("link", "input={obj_path} output={output}", e)
            )

pub fn bootstrap_compile_context_to_native_local(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Bootstrap-local real native output path; avoids cross-module driver helper dispatch."""
    log_phase("aot:bootstrap_native_local_real:start")
    if ctx.bootstrap_entry_mir.?:
        log_phase("aot:bootstrap_native_local_real:context_mir")
        return compile_bootstrap_context_to_native(ctx, backend_name, output)
    if (rt_env_get("SIMPLE_BOOTSTRAP_REAL_LLVM") ?? "") == "1":
        log_phase("aot:bootstrap_native_local_real:local_mir")
        var next_ctx = ctx
        log_phase("aot:bootstrap_native_local_real:free_mir:start")
        val bootstrap_mir = bootstrap_lower_hir_globals_to_mir_module_driver(ctx)
        log_phase("aot:bootstrap_native_local_real:free_mir:done")
        next_ctx.bootstrap_entry_mir = Some(bootstrap_mir)
        return compile_bootstrap_context_to_native(next_ctx, backend_name, output)
    val is_release = ctx.options.release
    val opt_level = bootstrap_native_opt_level(ctx, is_release)
    log_phase("aot:bootstrap_native_local_real:module")
    log_phase("aot:bootstrap_native_local_real:compile")
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if (rt_env_get("SIMPLE_BOOTSTRAP_REAL_LLVM") ?? "") == "1":
        val real_result = bootstrap_emit_real_llvm_object(output, opt_level)
        match real_result:
            case CompileResult.Success(_): ()
            case _: return real_result
    else:
        val compiled = compile_bootstrap_module_with_backend(backend_name, is_release, opt_level)
        if compiled.is_err():
            val err = compiled.unwrap_err()
            return CompileResult.CodegenError(
                bootstrap_llvm_phase_message("worker", "backend={backend_name} output={obj_path}", err.message)
            )
        val bootstrap_obj = llvm_bootstrap_last_object_path()
        if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
            log_phase("aot:bootstrap_native_local_real:copied_obj")
        else:
            return CompileResult.CodegenError(
                bootstrap_llvm_phase_message(
                    "object",
                    "source={bootstrap_obj} dest={obj_path}",
                    "Bootstrap backend did not preserve an object file"
                )
            )

    log_phase("aot:bootstrap_native_local_real:link")
    # Same reasoning as compile_bootstrap_context_to_native above: both
    # branches above always emit via real LLVM+llc, so the link must always
    # go through link_llvm_native, not the generic linker gated on
    # effective_backend.
    val llvm_opts = NativeLinkOptions(
        debug: ctx.options.debug_info,
        verbose: ctx.options.verbose,
        pie: false,
        bare_metal: false,
        opt_level: opt_level,
        stage4_backend: "llvm",
        stage4_compiler_hash: native_build_compiler_identity()
    )
    match link_llvm_native([obj_path], output, llvm_opts):
        case Ok(_):
            CompileResult.Success(output)
        case Err(e):
            CompileResult.CodegenError(
                bootstrap_llvm_phase_message("link", "input={obj_path} output={output}", e)
            )
