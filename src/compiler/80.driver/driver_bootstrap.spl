extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_write_text_at(path: text, offset: i64, content: text) -> bool
extern fn rt_file_copy(src: text, dst: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text

fn bootstrap_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_BOOTSTRAP_DEBUG") ?? "") == "1"

pub fn bootstrap_native_opt_level(ctx: CompileContext, is_release: bool) -> i64:
    # NOTE: explicit match, not `if ctx.options.opt_level.?:` -- an explicit
    # `-O0` request is Some(0); truthiness on the boxed i64? here silently
    # dropped that request and fell through to the release default (O3),
    # optimizing a build the user asked to leave unoptimized.
    match ctx.options.opt_level:
        case Some(level): return level
        case nil: pass_do_nothing
    if is_release:
        return 3
    0

pub fn bootstrap_llvm_opt_level(opt_level_i64: i64) -> OptimizationLevel:
    if opt_level_i64 <= 0:
        OptimizationLevel.None_
    elif opt_level_i64 == 1:
        OptimizationLevel.Size
    elif opt_level_i64 == 2:
        OptimizationLevel.Speed
    else:
        OptimizationLevel.Aggressive

pub fn bootstrap_llvm_ir_path_from_object_path(obj_path: text) -> text:
    if obj_path.ends_with(".o"):
        obj_path.slice(0, obj_path.len() - 1) + "ll"
    else:
        obj_path + ".ll"

pub fn bootstrap_llvm_phase_message(phase: text, subject: text, detail: text) -> text:
    "Bootstrap LLVM {phase} failed ({subject}): {detail}"

pub fn bootstrap_symbol_for_name(name: text) -> SymbolId:
    if name == "bootstrap_version":
        return SymbolId(id: 1)
    if name == "native_build_help":
        return SymbolId(id: 2)
    if name == "compile_result_exit":
        return SymbolId(id: 3)
    if name == "run_native_build_bootstrap":
        return SymbolId(id: 4)
    if name == "get_cli_args":
        return SymbolId(id: 5)
    if name == "main":
        return SymbolId(id: 6)
    if name == "rt_native_build":
        return SymbolId(id: 8)
    SymbolId(id: 100)

pub fn bootstrap_function_names() -> [text]:
    ["bootstrap_version", "native_build_help", "compile_result_exit", "run_native_build_bootstrap", "get_cli_args", "main", "rt_native_build"]

pub fn bootstrap_compile_to_native_local(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Fail closed: the old direct-IR path emitted ret-0 diagnostic stubs."""
    val _ = ctx
    val _backend = backend_name
    val _output = output
    CompileResult.CodegenError("bootstrap direct stub IR was removed; use real Simple lowering/codegen")

pub fn bootstrap_emit_seed_wrapper(output: text) -> CompileResult:
    """Fail closed: bootstrap stages must not delegate to a seed fallback."""
    val _ = output
    CompileResult.CodegenError("bootstrap seed-wrapper fallback was removed")

pub fn bootstrap_entry_module_name(ctx: CompileContext) -> text:
    val native_entry = rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY") ?? ""
    if native_entry != "":
        var i = 0
        while i < ctx.sources.len():
            val source = ctx.sources[i]
            if source.path == native_entry or source.path.ends_with("/" + native_entry):
                return source.module_name
            i = i + 1
        return _driver_module_name_from_path(native_entry)
    "app.cli.bootstrap_main"

pub fn bootstrap_lower_to_mir_context(ctx: CompileContext) -> (CompileContext, bool):
    """Bootstrap MIR lowering as a free function to avoid Stage1 method dispatch instability."""
    if bootstrap_trace_enabled():
        print "[driver-mir] bootstrap free:start"
    var next_ctx = ctx
    val target_context = driver_mir_target_context(ctx.options)
    # Hand the real HIR module for the requested entry (produced by the HIR phase
    # from the freshly-parsed Module.functions) to the MIR free path so it lowers
    # real bodies instead of ret-0 stubs.
    val entry_module_name = bootstrap_entry_module_name(ctx)
    bootstrap_clear_entry_hir_module()
    bootstrap_function_value_names_reset()
    for hir_module in ctx.hir_modules.values():
        if hir_module != nil:
            bootstrap_register_function_value_module(hir_module)
    if ctx.bootstrap_entry_hir.?:
        bootstrap_set_entry_hir_module(ctx.bootstrap_entry_hir.unwrap())
    var bootstrap_mir = bootstrap_lower_hir_globals_to_mir_module_for_target(target_context)
    # --entry-closure builds parse+HIR-lower EVERY module reachable from the
    # entry (see SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE handling in driver.spl and
    # flat_is_bootstrap_entry_path), but the line above only feeds the single
    # entry module into MIR lowering. The real object emitter
    # (bootstrap_emit_real_llvm_object) reads the flat
    # _bootstrap_mir_functions accumulator by index, not a per-module
    # MirModule -- so a helper module's functions, though correctly
    # HIR-lowered and resolvable by name in the entry's symbol table (see
    # resolve_import_symbols), never reached that accumulator and linked as
    # "undefined symbol: <fn>". Lower every OTHER closure module's functions
    # too, appending to the same accumulator (bug
    # bootstrap_stage2_empty_mir_bodies_2026-07-05, cross-module closure gap,
    # stage 3: object emission).
    val closure_mode = (rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE") ?? "") == "1"
    if closure_mode:
        for extra_hir in ctx.hir_modules.values():
            if extra_hir != nil:
                val extra_name = _driver_module_name_from_path(extra_hir.name)
                if extra_name != entry_module_name:
                    if bootstrap_trace_enabled():
                        print "[driver-mir] bootstrap closure extra module={extra_name}"
                    val _added = bootstrap_lower_extra_hir_module_to_mir_for_target(extra_hir, target_context)
    next_ctx.bootstrap_entry_mir = Some(bootstrap_mir)
    next_ctx.mir_modules[entry_module_name] = bootstrap_mir
    if bootstrap_trace_enabled():
        print "[driver-mir] bootstrap free:done"
    (next_ctx, next_ctx.errors.len() == 0)

