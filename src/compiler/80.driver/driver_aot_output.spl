extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_copy(src: text, dst: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_dir_remove_all(path: text) -> bool
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_path_join(a: text, b: text) -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_copy(src: text, dst: text) -> bool
extern fn rt_file_size(path: text) -> i64
extern fn rt_hash_text(content: text) -> i64

fn driver_log_debug(log: Logger, message: text):
    if log.level >= 10:
        print "[DEBUG] {message}"

fn driver_log_trace(log: Logger, message: text):
    if log.level >= 20:
        print "[TRACE] {message}"

fn driver_log_info(log: Logger, message: text):
    if log.level >= 4:
        print "[INFO] {message}"

fn driver_effective_native_opt_level(ctx: CompileContext, is_release: bool) -> i64:
    if ctx.options.opt_level.?:
        return ctx.options.opt_level ?? 0
    if is_release:
        return 3
    0

fn driver_effective_mir_opt_level(ctx: CompileContext) -> i64:
    compileoptions_effective_mir_opt_level(ctx.options)

fn driver_native_build_threads() -> i64:
    val raw = rt_env_get("SIMPLE_NATIVE_BUILD_THREADS") ?? ""
    if raw == "":
        return 0
    val parsed = raw.to_i64() ?? 0
    if parsed < 0:
        return 0
    parsed

fn driver_native_build_cache_dir() -> text:
    val dir = rt_env_get("SIMPLE_NATIVE_BUILD_CACHE_DIR") ?? ""
    if dir == "":
        "build/native_cache"
    else:
        dir

fn driver_native_build_cache_path(cache_dir: text) -> text:
    rt_path_join(cache_dir, "build_cache.sdn")

fn driver_native_build_cache_scope(backend: text, cache_dir: text, target_cpu: text, opt_level: i64) -> (text, text):
    val raw_target = if target_cpu == "": nil else: Some(target_cpu)
    val scope = native_build_cache_scope_key(Some(backend), raw_target, [], opt_level as i32, native_build_compiler_identity())
    val cache_scope_root = rt_path_join(cache_dir, scope)
    (cache_scope_root, scope)

fn driver_native_module_cache_source(ctx: CompileContext, module_name: text) -> text:
    var found_path = ""
    for source in ctx.sources:
        if source.module_name == module_name:
            found_path = source.path
            break
    if found_path == "":
        return ""
    # A single file can be loaded under multiple module aliases. BuildCache is
    # keyed by source path, so sharing that entry would let one alias reuse the
    # other alias's object. Fail closed for aliases instead of guessing.
    var path_count = 0
    for source in ctx.sources:
        if source.path == found_path:
            path_count = path_count + 1
    if path_count == 1:
        found_path
    else:
        ""

pub fn driver_native_sources_fingerprint(sources: [SourceFile]) -> text:
    # Conservative dependency closure: any loaded source change gets a new
    # object-cache scope. Hash content into compact length-prefixed rows so the
    # pass stays linear and path/module boundaries are unambiguous. Source
    # order changes only cause a safe cache miss.
    var rows: [text] = []
    for source in sources:
        val content_hash = rt_hash_text(source.content)
        rows = rows.push("{source.path.len()}:{source.path}{source.module_name.len()}:{source.module_name}{source.content.len()}:{content_hash}")
    val manifest = rows.join("\n")
    "{rt_hash_text(manifest)}n{sources.len()}"

pub fn driver_native_module_is_export_facade(mir: MirModule, parsed_module: Module?) -> bool:
    if mir.functions.len() > 0 or mir.statics.len() > 0 or mir.constants.len() > 0 or mir.types.len() > 0:
        return false
    if parsed_module == nil:
        return false
    val parsed = parsed_module
    # Extern-only declaration modules (e.g. std.nogc_sync_mut.env.types: only
    # `extern fn rt_env_*` + export) legitimately lower to a MIR module with
    # zero functions — the externs resolve at link time. Treat them like the
    # bodyless facades below instead of failing "MIR module has no functions".
    # A module with any NON-extern parsed function still hard-fails there:
    # HIR had bodies, so an empty MIR is a real lowering bug and must stay
    # loud (bug bootstrap_stage2_empty_mir_bodies_2026-07-05).
    var only_extern_functions = true
    for fn_name in parsed.functions.keys():
        val parsed_fn = parsed.functions[fn_name]
        if not parsed_fn.is_extern:
            only_extern_functions = false
    # `export use backend.{...}` facades produce an Import record but NO
    # Export record in the flat bridge (only bare `export a, b` emits one),
    # e.g. std.nogc_async_mut.env.types — accept import-only and trait-only
    # modules too; neither has standalone code by the decl checks below.
    ((parsed.exports.len() > 0 or parsed.imports.len() > 0 or parsed.traits.len() > 0) and parsed.domain_blocks.len() == 0 and
        only_extern_functions and parsed.classes.len() == 0 and parsed.actors.len() == 0 and
        parsed.structs.len() == 0 and parsed.enums.len() == 0 and parsed.bitfields.len() == 0 and
        parsed.impls.len() == 0 and parsed.type_aliases.len() == 0 and
        parsed.constants.len() == 0 and parsed.static_asserts.len() == 0 and
        parsed.aop_advices.len() == 0 and parsed.di_bindings.len() == 0 and
        parsed.arch_rules.len() == 0 and parsed.mock_decls.len() == 0)

fn driver_native_build_filter_scoped_outputs(cached_outputs: [text], cache_scope_root: text) -> ([text], bool):
    var scoped_outputs: [text] = []
    var all_in_scope = true
    for obj in cached_outputs:
        if obj.starts_with(cache_scope_root + "/"):
            scoped_outputs = scoped_outputs.push(obj)
        else:
            all_in_scope = false
    (scoped_outputs, all_in_scope)

fn native_pre_parse_skip_diagnostic(path: text, reason: text) -> text:
    if reason == "":
        "[native-pre-parse] skip cache path={path}"
    else:
        "[native-pre-parse] not implemented for {path}: {reason}"

fn _extract_driver_ctx(driver: CompilerDriver) -> CompileContext:
    driver.ctx

fn driver_native_launch_trailer_magic() -> [u8]:
    # "SIMPLE_LAUNCH_V1" = 16 bytes.
    [83, 73, 77, 80, 76, 69, 95, 76, 65, 85, 78, 67, 72, 95, 86, 49]

fn driver_render_native_launch_metadata(ctx: CompileContext) -> text:
    val target = Target.host()
    "simple_launch_metadata:\n" +
        "  entry_kind: \"native\"\n" +
        "  target_os: \"" + target.os + "\"\n" +
        "  target_arch: \"" + target.arch + "\"\n" +
        "  target_abi: \"native\"\n" +
        "  uses_arg_parser: false\n" +
        "  mmap_hint: false\n"

fn driver_render_smf_launch_metadata(ctx: CompileContext) -> text:
    val target = Target.host()
    "simple_launch_metadata:\n" +
        "  entry_kind: \"smf\"\n" +
        "  target_os: \"" + target.os + "\"\n" +
        "  target_arch: \"" + target.arch + "\"\n" +
        "  target_abi: \"smf\"\n" +
        "  uses_arg_parser: true\n" +
        "  mmap_hint: true\n"

fn driver_native_launch_metadata_trailer(ctx: CompileContext) -> [u8]:
    val payload = driver_render_native_launch_metadata(ctx).bytes()
    var out: [u8] = []
    out = out.concat(payload)
    out = out.concat(u64_to_bytes(payload.len()))
    out = out.concat(driver_native_launch_trailer_magic())
    out

fn driver_native_success_with_launch_metadata(ctx: CompileContext, output: text) -> CompileResult:
    # Native launch metadata is optional. Keep native-build self-hostable even
    # when the byte-range file API is unavailable in the pure Simple runtime.
    CompileResult.Success(output)

pub fn compile_bootstrap_context_to_native(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Bootstrap-stable native output path.

    Stage1-generated compilers can crash dispatching the cross-module
    `CompilerDriver.compile_to_native` extension method. Keep the bootstrap lane
    on a plain function that takes the already-available context.
    """
    val is_release = ctx.options.release
    val driver_opt_level = driver_effective_native_opt_level(ctx, is_release)
    val trace = (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"
    if trace:
        print "[NATIVE] bootstrap direct backend_name={backend_name}, is_release={is_release}"
    val effective_backend = get_effective_backend_name(backend_name, is_release)
    if trace:
        print "[NATIVE] bootstrap direct effective_backend={effective_backend}"

    val entry_module_name = bootstrap_entry_module_name(ctx)
    val direct_result = _compile_one_module(ctx, backend_name, is_release, driver_opt_level, output, entry_module_name)
    match direct_result:
        case Ok(obj_path):
            if effective_backend == "llvm" or effective_backend == "llvm-lib":
                val llvm_opts = NativeLinkOptions(
                    debug: ctx.options.debug_info,
                    verbose: ctx.options.verbose,
                    pie: true,
                    bare_metal: false,
                    opt_level: driver_opt_level,
                    stage4_backend: effective_backend,
                    stage4_compiler_hash: native_build_compiler_identity()
                )
                match link_llvm_native([obj_path], output, llvm_opts):
                    case Ok(_):
                        return driver_native_success_with_launch_metadata(ctx, output)
                    case Err(e):
                        return CompileResult.CodegenError("LLVM native linking failed: {e}")
            val hosted_opts = NativeLinkOptions(
                debug: ctx.options.debug_info,
                verbose: ctx.options.verbose,
                pie: true,
                bare_metal: false,
                opt_level: driver_opt_level,
                stage4_backend: effective_backend,
                stage4_compiler_hash: native_build_compiler_identity()
            )
            match link_llvm_native([obj_path], output, hosted_opts):
                case Ok(_):
                    return driver_native_success_with_launch_metadata(ctx, output)
                case Err(e):
                    return CompileResult.CodegenError("Hosted native linking failed: {e}")
        case Err(e):
            return CompileResult.CodegenError(e)

impl CompilerDriver:
    me compile_to_native(output: text) -> CompileResult:
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val backend_name = ctx.options.backend
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_native_opt_level(ctx, is_release)
        val stage4_requested = (rt_env_get("SIMPLE_BOOTSTRAP_STAGE4") ?? "") == "1"
        val emit_object_requested = (rt_env_get("SIMPLE_NATIVE_BUILD_EMIT_OBJECT") ?? "") == "1"
        if stage4_requested and emit_object_requested:
            return CompileResult.CodegenError("Stage4 strict profile does not support emit-object output")
        val trace = (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"
        if trace:
            print "[NATIVE] backend_name={backend_name}, is_release={is_release}"
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        if trace:
            print "[NATIVE] effective_backend={effective_backend}"

        # Load build cache
        val cache_dir = driver_native_build_cache_dir()
        rt_dir_create(cache_dir, true)
        val native_target = rt_env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? ""
        val (base_cache_scope_root, _) = driver_native_build_cache_scope(effective_backend, cache_dir, native_target, driver_opt_level)
        val cache_scope_root = rt_path_join(base_cache_scope_root, "sources-{driver_native_sources_fingerprint(ctx.sources)}")
        # --clean requested a clean build: drop this entry's cache scope so no
        # previously compiled object in this scope can be reused. Consume the
        # flag (clear the env) so it applies to this build only.
        if (rt_env_get("SIMPLE_NATIVE_BUILD_CLEAN") ?? "") == "1":
            rt_dir_remove_all(base_cache_scope_root)
            rt_env_set("SIMPLE_NATIVE_BUILD_CLEAN", "")
        rt_dir_create(cache_scope_root, true)
        val cache_path = driver_native_build_cache_path(cache_dir)
        val object_base = rt_path_join(cache_scope_root, "object")
        var build_cache: BuildCache = BuildCache.load(cache_path)
        var cache_hit_count: i64 = 0
        var cache_miss_count: i64 = 0

        # Compile all modules and collect object files
        var object_files: [text] = []

        val low_memory = ctx.options.low_memory
        val module_names = ctx.mir_modules.keys()
        val total_modules = module_names.len()
        if trace:
            print "[NATIVE] compiling {total_modules} modules..."

        # Guard (bug #119): refuse empty mir_modules. A requested --entry that
        # produces no modules is likely a misconfiguration (isolated entry with
        # zero imports). Hard-error instead of silently falling back to bootstrap_main.
        if total_modules <= 0:
            val entry_hint = if ctx.options.input_files.len() > 0:
                " (input: {ctx.options.input_files[0]})"
            else:
                ""
            return CompileResult.CodegenError("native-build produced empty mir_modules{entry_hint} — no modules loaded. Try adding an import (use std.text) or using the standard entry point.")

        if total_modules > 1000000:
            return CompileResult.CodegenError("native-build mir_modules exceeds sanity limit (1000000 modules)")

        # Phase 1: Check cache, collect cached objects, identify uncached modules
        var uncached_names: [text] = []
        for name in module_names:
            # Import/export facades contribute symbols through their imported
            # implementation modules and have no object code of their own.
            if driver_native_module_is_export_facade(ctx.mir_modules[name], ctx.modules.get(name)):
                continue
            val cache_source = driver_native_module_cache_source(ctx, name)
            var used_cache = false
            if cache_source != "":
                val cached_outputs = build_cache.get_cached_outputs(cache_source)
                if cached_outputs.?:
                    val all_outputs = cached_outputs.unwrap()
                    val (scoped_outputs, all_in_scope) = driver_native_build_filter_scoped_outputs(all_outputs, cache_scope_root)
                    # A hit also requires every cached object to still exist on
                    # disk (a --clean scope wipe or manual cache deletion leaves
                    # stale build_cache.sdn entries behind).
                    var outputs_exist = true
                    for obj in scoped_outputs:
                        if not rt_file_exists(obj):
                            outputs_exist = false
                    if all_in_scope and scoped_outputs.len() > 0 and outputs_exist:
                        print "[NATIVE] cache hit: {name}"
                        cache_hit_count = cache_hit_count + 1
                        for obj in scoped_outputs:
                            object_files = object_files.push(obj)
                        if low_memory:
                            ctx.evict_mir_module(name)
                        used_cache = true
                    elif not all_in_scope or not outputs_exist:
                        build_cache.remove_entry(cache_source)
            if not used_cache:
                uncached_names = uncached_names.push(name)

        if object_files.len() == 0 and uncached_names.len() == 0:
            return CompileResult.CodegenError("native-build produced no code-bearing MIR modules")

        # Phase 2: Compile uncached modules through ParallelBuilder
        if uncached_names.len() > 0:
            if uncached_names.len() == 1:
                val name = uncached_names[0]
                val direct_result = _compile_one_module(ctx, backend_name, is_release, driver_opt_level, object_base, name)
                match direct_result:
                    case Ok(_):
                        cache_miss_count = 1
                    case Err(e):
                        return CompileResult.CodegenError(e)
            else:
                val parallel_cfg = ParallelBuildConfig(
                    num_threads: driver_native_build_threads(),
                    parallel_threshold: 4,
                    deterministic: false,
                    verbose: ctx.options.verbose
                )
                var builder = ParallelBuilder.create(parallel_cfg)

                for name in uncached_names:
                    builder.add_unit(name, [])

                val build_result = builder.build(_compile_one_module(ctx, backend_name, is_release, driver_opt_level, object_base, _1))
                cache_miss_count = build_result.stats.completed + build_result.stats.failed

                if not build_result.success:
                    val first_err = build_result.errors[0]
                    return CompileResult.CodegenError(first_err[1])

            # Post-process: update cache and collect object paths. Do not rely
            # on BuildResult.outputs here: stage1-generated compilers can lose
            # pushes into arrays that start empty. _compile_one_module writes
            # objects at this stable path, so reconstruct from uncached_names.
            var reconstructed_outputs: [text] = []
            for name in uncached_names:
                val obj_path = "{object_base}.{name}.o"
                if rt_file_exists(obj_path):
                    reconstructed_outputs = reconstructed_outputs.push(obj_path)
                    object_files = object_files.push(obj_path)
            for obj_path in reconstructed_outputs:
                val obj_fp = FileFingerprint.from_file(obj_path)
                if obj_fp.?:
                    # Extract module name from obj_path: "{object_base}.{name}.o"
                    val prefix = object_base + "."
                    var mod_name = obj_path
                    if obj_path.starts_with(prefix):
                        mod_name = obj_path[prefix.len():obj_path.len() - 2]
                    val cache_source = driver_native_module_cache_source(ctx, mod_name)
                    if cache_source != "":
                        val source_fp = FileFingerprint.from_file(cache_source)
                        # Flat-safe: .unwrap() on a flat optional lowers to the
                        # box-assuming rt_enum_payload on the stage4 lane and
                        # stores a garbage fingerprint (BuildCache.save then
                        # traps on fp.content_hash); if-val is the safe form.
                        if val source_fp_val = source_fp:
                            build_cache.update_entry(cache_source, source_fp_val, [], [obj_path])

            # Evict MIR for compiled modules in low-memory mode
            if low_memory:
                for name in uncached_names:
                    ctx.evict_mir_module(name)

        # Save build cache
        build_cache.save()
        if trace and (cache_hit_count > 0 or cache_miss_count > 0):
            print "[NATIVE] cache: {cache_hit_count} hits, {cache_miss_count} misses"

        # Link object files into final executable
        # Guard (bug #119): refuse to silently fallback when no object files were produced.
        # This indicates zero modules compiled, which is a hard error — do not substitute bootstrap_main.
        if object_files.len() == 0:
            val entry_hint = if ctx.options.input_files.len() > 0:
                " (input: {ctx.options.input_files[0]})"
            else:
                ""
            return CompileResult.CodegenError("native-build produced no object files{entry_hint} — no modules compiled. Try adding an import (use std.text) or using the standard entry point.")

        if emit_object_requested:
            if object_files.len() == 0:
                return CompileResult.CodegenError("emit-object requested but no object files were produced")
            if object_files.len() == 1:
                if not rt_file_copy(object_files[0], output):
                    return CompileResult.CodegenError("emit-object failed to copy {object_files[0]} to {output}")
            else:
                var args: [text] = ["-r"]
                for obj in object_files:
                    args = args.push(obj)
                args = args.push("-o")
                args = args.push(output)
                val (_stdout, stderr, code) = rt_process_run("ld.lld", args)
                if code != 0:
                    return CompileResult.CodegenError("emit-object relocatable link failed: {stderr}")
            driver_log_info(log, "Native object written to {output}")
            return driver_native_success_with_launch_metadata(ctx, output)

        if trace:
            print "[NATIVE] linking {object_files.len()} object files..."
        if effective_backend == "llvm" or effective_backend == "llvm-lib":
            # LLVM path: compile C runtime and link with entry point
            if trace:
                print "[NATIVE] creating NativeLinkOptions..."
            val llvm_opts = NativeLinkOptions(
                debug: ctx.options.debug_info,
                verbose: ctx.options.verbose,
                pie: true,
                bare_metal: false,
                opt_level: driver_opt_level,
                stage4_backend: effective_backend,
                stage4_compiler_hash: native_build_compiler_identity()
            )
            if trace:
                print "[NATIVE] calling link_llvm_native..."
            match link_llvm_native(object_files, output, llvm_opts):
                case Ok(_):
                    driver_log_info(log, "Native executable written to {output} (backend: LLVM)")
                    return driver_native_success_with_launch_metadata(ctx, output)
                case Err(e):
                    CompileResult.CodegenError("LLVM native linking failed: {e}")
        else:
            # Hosted native binaries need the same runtime objects and C `main`
            # entry shim regardless of which backend produced user objects.
            val hosted_opts = NativeLinkOptions(
                debug: ctx.options.debug_info,
                verbose: ctx.options.verbose,
                pie: true,
                bare_metal: false,
                opt_level: driver_opt_level,
                stage4_backend: effective_backend,
                stage4_compiler_hash: native_build_compiler_identity()
            )
            match link_llvm_native(object_files, output, hosted_opts):
                case Ok(_):
                    driver_log_info(log, "Native executable written to {output} (backend: {effective_backend})")
                    driver_native_success_with_launch_metadata(ctx, output)
                case Err(e):
                    CompileResult.CodegenError("Hosted native linking failed: {e}")

    me compile_to_c(output: text) -> CompileResult:
        """Compile all MIR modules to C++20 source. Routes to single-file or directory mode."""
        if output.ends_with(".cpp") or output.ends_with(".c") or output.ends_with(".cxx"):
            return self.compile_to_c_single_file(output)
        else:
            return self.compile_to_c_directory(output)

    me compile_to_c_single_file(output: text) -> CompileResult:
        """Compile all MIR modules to a single C++20 source file."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT C: generating C++20 to {output}")

        var all_c_source = ""
        for name in ctx.mir_modules.keys():
            driver_log_trace(log, "translating module: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("c", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("C codegen error in {name}: {err}")
            val module: CompiledModule = compiled.unwrap()
            all_c_source = all_c_source + module.assembly

        # Write C++ source to output file
        if not rt_file_write_text(output, all_c_source):
            return CompileResult.CodegenError("Failed to write C++ source to {output}")
        driver_log_info(log, "C++20 source written to {output}")
        CompileResult.Success(output)

    me compile_to_c_directory(output_dir: text) -> CompileResult:
        """Compile MIR modules to per-module C++20 files with CMake infrastructure."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT C (multi-file): generating C++20 to {output_dir}/")

        # Create root output directory
        if not rt_dir_create(output_dir, true):
            return CompileResult.CodegenError("Failed to create output directory {output_dir}")

        var module_files: [(text, text)] = []

        for name in ctx.mir_modules.keys():
            driver_log_trace(log, "translating module: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("c", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("C codegen error in {name}: {err}")
            val module: CompiledModule = compiled.unwrap()

            # Convert module name to relative file path: "compiler.core.parser" -> "compiler/core/parser.cpp"
            val rel_path = name.replace(".", "/") + ".cpp"
            val full_path = rt_path_join(output_dir, rel_path)

            # Create parent directories
            val parent_dir = _driver_entry_import_dirname(full_path)
            if not rt_dir_create(parent_dir, true):
                return CompileResult.CodegenError("Failed to create directory {parent_dir}")

            # Write per-module .cpp file
            if not rt_file_write_text(full_path, module.assembly):
                return CompileResult.CodegenError("Failed to write {full_path}")

            # Write per-module .h file if header content present
            if module.has_llvm_ir and module.llvm_ir != "":
                val h_rel_path = name.replace(".", "/") + ".h"
                val h_full_path = rt_path_join(output_dir, h_rel_path)
                if not rt_file_write_text(h_full_path, module.llvm_ir):
                    return CompileResult.CodegenError("Failed to write {h_full_path}")
                driver_log_trace(log, "wrote {h_rel_path}")

            module_files.push((name, rel_path))
            driver_log_trace(log, "wrote {rel_path}")

        # Generate CMake infrastructure
        val cmake_err = generate_cmake_for_modules(output_dir, module_files, log)
        if cmake_err != nil:
            return CompileResult.CodegenError(cmake_err)

        driver_log_info(log, "C++20 multi-file output written to {output_dir}/ ({module_files.len()} modules)")
        CompileResult.Success(output_dir)

    me compile_to_cuda(output: text) -> CompileResult:
        """Compile all MIR modules to PTX assembly (CUDA backend)."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT CUDA: generating PTX to {output}")

        var all_ptx = ""
        val keys = ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to PTX: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("cuda", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("CUDA compile error in {name}: {err}")
            val module_result: CompiledModule = compiled.unwrap()
            val ptx_text = module_result.assembly ?? ""
            all_ptx = all_ptx + ptx_text

        if not rt_file_write_text(output, all_ptx):
            return CompileResult.CodegenError("Failed to write PTX to {output}")
        driver_log_info(log, "PTX assembly written to {output}")
        CompileResult.Success(output)

    me compile_to_opencl(output: text) -> CompileResult:
        """Compile all MIR modules to OpenCL C source."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT OpenCL: generating OpenCL C to {output}")

        var all_source = ""
        val keys = ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to OpenCL C: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("opencl", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("OpenCL compile error in {name}: {err}")
            val module_result: CompiledModule = compiled.unwrap()
            val source = module_result.assembly ?? ""
            all_source = all_source + source

        if not rt_file_write_text(output, all_source):
            return CompileResult.CodegenError("Failed to write OpenCL source to {output}")
        driver_log_info(log, "OpenCL C source written to {output}")
        CompileResult.Success(output)

    me compile_to_vhdl(output: text) -> CompileResult:
        """Compile all MIR modules to VHDL source (VHDL backend)."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT VHDL: generating VHDL to {output}")

        var all_vhdl = ""
        val keys = ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to VHDL: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("vhdl", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("VHDL compile error in {name}: {err}")
            val module_result: CompiledModule = compiled.unwrap()
            val vhdl = module_result.assembly ?? ""
            if all_vhdl != "" and vhdl != "":
                all_vhdl = all_vhdl + "\n\n"
            all_vhdl = all_vhdl + vhdl

        # W2-B fail-closed: if aspects/advices were requested but zero weaves
        # were applied before VHDL emission, the woven logic (e.g. JTAG hart
        # debug hooks) would silently be missing from the emitted RTL.
        val vhdl_aop_requested = aop_advices_requested()
        val vhdl_aop_woven = aop_weave_count()
        if vhdl_aop_requested > 0 and vhdl_aop_woven == 0:
            return CompileResult.CodegenError("VHDL generation error: {vhdl_aop_requested} AOP advice declaration(s) were requested but 0 weaves were applied before VHDL emission — refusing to emit RTL with silently dropped aspects")

        if not rt_file_write_text(output, all_vhdl):
            return CompileResult.CodegenError("Failed to write VHDL to {output}")
        # W2-B: generation manifest with AOP weave accounting.
        var vhdl_manifest = "{\n"
        vhdl_manifest = vhdl_manifest + "  \"version\": 1,\n"
        vhdl_manifest = vhdl_manifest + "  \"generated\": \"" + output + "\",\n"
        vhdl_manifest = vhdl_manifest + "  \"backend\": \"vhdl\",\n"
        vhdl_manifest = vhdl_manifest + "  \"aop_advices_requested\": " + vhdl_aop_requested.to_text() + ",\n"
        vhdl_manifest = vhdl_manifest + "  \"aop_weave_count\": " + vhdl_aop_woven.to_text() + "\n"
        vhdl_manifest = vhdl_manifest + "}\n"
        rt_file_write_text(output + ".gen.json", vhdl_manifest)
        driver_log_info(log, "VHDL source written to {output}")
        CompileResult.Success(output)

    me compile_to_wasm(output: text) -> CompileResult:
        """Compile all MIR modules to WAT (WebAssembly text) via the pure-Simple
        WASM backend. No LLVM required — the WasmCodegenAdapter emits WAT text
        that is written to `output` (use a .wat extension; assemble to .wasm with
        an external assembler if a binary module is needed)."""
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)
        driver_log_debug(log, "AOT WASM: generating WAT to {output}")

        var all_wat = ""
        val keys = ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to WAT: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend("wasm", mir_module, is_release, driver_opt_level)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("WASM compile error in {name}: {err}")
            val module_result: CompiledModule = compiled.unwrap()
            val wat = module_result.assembly ?? ""
            if all_wat != "" and wat != "":
                all_wat = all_wat + "\n\n"
            all_wat = all_wat + wat

        if not rt_file_write_text(output, all_wat):
            return CompileResult.CodegenError("Failed to write WAT to {output}")
        driver_log_info(log, "WAT written to {output}")
        CompileResult.Success(output)

    me compile_to_smf(output: text) -> CompileResult:
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val backend_name = ctx.options.backend
        val is_release = ctx.options.release
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        driver_log_debug(log, "AOT SMF: compiling to {output} (backend: {effective_backend})")

        val smf_result = self.collect_smf_bytes()
        if not smf_result.is_success():
            return smf_result

        val smf_bytes = smf_result.get_value()

        # Write SMF file using linker wrapper
        match link_to_smf(smf_bytes, output, ctx.options.verbose):
            case Ok(_):
                driver_log_info(log, "SMF module written to {output} (backend: {effective_backend})")
                CompileResult.Success(output)
            case Err(e):
                CompileResult.CodegenError("Failed to write SMF file: {e}")

    me compile_to_self_contained(output: text) -> CompileResult:
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val backend_name = ctx.options.backend
        val is_release = ctx.options.release
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        driver_log_debug(log, "AOT self-contained: compiling to {output} (backend: {effective_backend})")

        val smf_result = self.collect_smf_bytes()
        if not smf_result.is_success():
            return smf_result

        val smf_bytes = smf_result.get_value()

        # Build self-contained binary using linker wrapper
        var sc_config = SelfContainedConfig.default()
        sc_config.verbose = ctx.options.verbose

        match link_to_self_contained(smf_bytes, output, sc_config):
            case Ok(_):
                driver_log_info(log, "Self-contained binary written to {output} (backend: {effective_backend})")
                CompileResult.Success(output)
            case Err(e):
                CompileResult.CodegenError("Self-contained build failed: {e}")

    me collect_smf_bytes() -> CompileResult:
        val ctx: CompileContext = _extract_driver_ctx(self)
        val log = ctx.logger
        val backend_name = ctx.options.backend
        val is_release = ctx.options.release
        val driver_opt_level = driver_effective_mir_opt_level(ctx)

        var all_object_bytes: [u8] = []

        for name in ctx.mir_modules.keys():
            driver_log_trace(log, "compiling module for SMF: {name}")
            val mir_module = ctx.mir_modules[name]
            val compiled = compile_module_with_backend(backend_name, mir_module, is_release, driver_opt_level)
            # Flat-safe extraction (same defect as _compile_selected_module:
            # Result.unwrap returns 0-nil; object_code .unwrap box-assumes;
            # is_err/unwrap_err dispatched as void.* before the helper's
            # return type was annotated — match arms are the verified idiom).
            match compiled:
                case Err(err):
                    return CompileResult.CodegenError("AOT compile error in {name}: {err}")
                case Ok(module):
                    if val obj_bytes = module.object_code:
                        all_object_bytes = all_object_bytes.concat(obj_bytes)
                case _:
                    return CompileResult.CodegenError("AOT compile error in {name}: backend result not Ok")

        # Collect dependency interface hashes for staleness tracking
        val deps = collect_dependency_hashes(ctx)
        val driver_manifest_bytes = collect_driver_manifest_bytes(ctx.mir_modules)
        val launch_metadata_bytes = driver_render_smf_launch_metadata(ctx).bytes()

        # Wrap object code into SMF format
        val target = Target.host()
        val smf_mode = ctx.options.smf_output_mode
        val smf_bytes = if smf_mode == "elf_embedded":
            # Phase 1: Store full ELF .o in Code section (native linker can read it)
            var opts: SmfBuildOptions = SmfBuildOptions.create(target)
            opts.deps = deps
            opts.driver_manifest_bytes = driver_manifest_bytes
            opts.launch_metadata_bytes = launch_metadata_bytes
            generate_smf_with_raw_code_options(all_object_bytes, opts)
        elif smf_mode == "reloc_sections":
            # Phase 2: Extract .text + relocations into separate sections
            var opts: SmfBuildOptions = SmfBuildOptions.create(target)
            opts.deps = deps
            opts.driver_manifest_bytes = driver_manifest_bytes
            opts.launch_metadata_bytes = launch_metadata_bytes
            build_smf_with_relocations(all_object_bytes, opts)
        else:
            # Default: strip ELF to raw .text bytes, with dependency tracking
            var opts: SmfBuildOptions = SmfBuildOptions.create(target)
            opts.deps = deps
            opts.driver_manifest_bytes = driver_manifest_bytes
            opts.launch_metadata_bytes = launch_metadata_bytes
            generate_smf_with_options(all_object_bytes, opts)
        CompileResult.Success(smf_bytes)

    # --------------------------------------------------------------------------
    # Linker Helper (legacy - kept for compatibility, delegates to linker_wrapper)
    # --------------------------------------------------------------------------

    fn link_objects(objects: [text], output: text) -> Result<text, text>:
        if objects.is_empty():
            return Err("No object files to link")

        var config = NativeLinkConfig.default()
        link_to_native(objects, output, config)

# ============================================================================
# Single-Module Compilation Helper (for ParallelBuilder)
# ============================================================================

fn _compile_one_module(ctx: any, backend_name: text, is_release: bool, opt_level: i64, output_base: text, name: text) -> Result<text, text>:
    """Compile a single module by name, write object file, return path."""
    val trace = (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"
    if trace:
        print "[NATIVE] compiling module: {name}"
        print "[NATIVE] select module:start"
    if name == bootstrap_entry_module_name(ctx):
        if trace:
            print "[NATIVE] select module:bootstrap check"
        if ctx.bootstrap_entry_mir.?:
            if trace:
                print "[NATIVE] select module:bootstrap field"
            val direct_mir = ctx.bootstrap_entry_mir.unwrap()
            return _compile_selected_module(backend_name, is_release, opt_level, output_base, name, direct_mir)
    if trace:
        print "[NATIVE] select module:dict"
    val mir_module = ctx.mir_modules[name]
    return _compile_selected_module(backend_name, is_release, opt_level, output_base, name, mir_module)

fn _compile_selected_module(backend_name: text, is_release: bool, opt_level: i64, output_base: text, name: text, mir_module: MirModule) -> Result<text, text>:
    if (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1":
        print "[NATIVE] select module:done"
    if mir_module.functions.len() == 0:
        return Err("AOT compile error in {name}: MIR module has no functions")
    val empty_native_obj = rt_env_get("SIMPLE_BOOTSTRAP_EMPTY_NATIVE_OBJ") ?? ""
    if empty_native_obj == "1":
        val c_path = "{output_base}.{name}.bootstrap_empty.c"
        val obj_path = "{output_base}.{name}.o"
        val c_ok = rt_file_write_text(c_path, "int main(int argc, char **argv) { (void)argc; (void)argv; return 0; }\n")
        if not c_ok:
            return Err("Failed to write bootstrap empty C file {c_path}")
        val (_cc_out, cc_err, cc_code) = rt_process_run("cc", ["-c", c_path, "-o", obj_path])
        if cc_code != 0:
            return Err("Bootstrap empty object compile failed: {cc_err}")
        return Ok(obj_path)

    val compiled = compile_module_with_backend(backend_name, mir_module, is_release, opt_level)

    match compiled:
        case Err(err):
            return Err("AOT compile error in {name}: {err}")
        case _:
            ()

    # Flat-safe extraction: .unwrap() on this Result returns a 0-nil on the
    # stage4 native lane (the nil-receiver guard catches 0 while `== nil`
    # only sees sentinel 3); match-arm payload extraction is the verified
    # path. Same for the flat [u8]? object_code — if-val, not .unwrap().
    match compiled:
        case Ok(module):
            if val obj_bytes = module.object_code:
                val obj_path = "{output_base}.{name}.o"
                if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                    val bootstrap_obj = llvm_bootstrap_last_object_path()
                    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
                        return Ok(obj_path)
                match write_elf_bytes_to_file(obj_path, obj_bytes):
                    case Ok(_):
                        Ok(obj_path)
                    case Err(e):
                        Err("Failed to write object file {obj_path}: {e}")
            else:
                Err("Backend produced no object code for {name}")
        case _:
            Err("AOT compile error in {name}: backend result not Ok")

# ============================================================================
# Dependency Collection for SMF Staleness Tracking
# ============================================================================

fn collect_driver_manifest_bytes(modules: Dict<text, MirModule>) -> [u8]:
    var payload: [u8] = []
    for module_name in modules.keys():
        val module = modules[module_name]
        for fn_ in module.functions.values():
            if fn_.has_driver_manifest_attr:
                payload = payload.concat(encode_driver_manifest_record(fn_.name, fn_.driver_manifest_attr))
    payload

fn encode_driver_manifest_record(name: text, attr: DriverManifestAttr) -> [u8]:
    var buf: [u8] = []
    buf = buf.concat(u32_to_bytes(0x44525653))  # DRVS

    var kind_byte: u8 = 0
    match attr.kind:
        case Driver:
            kind_byte = 0
        case NativeLib:
            kind_byte = 1
    buf = buf.push(kind_byte)
    buf = buf.push((attr.driver_class & 0xFF).to_u8())
    buf = buf.push(1)  # abi_rev low byte
    buf = buf.push(0)  # abi_rev high byte
    buf = buf.concat(u32_to_bytes(attr.vendor as i32))
    buf = buf.concat(u32_to_bytes(attr.device_ids.len() as i32))
    buf = buf.concat(fixed_ascii_bytes(attr.version, 16))
    buf = buf.concat(fixed_ascii_bytes(name, 32))

    for id in attr.device_ids:
        buf = buf.concat(u32_to_bytes(0))
        buf = buf.concat(u32_to_bytes(id as i32))

    buf

fn fixed_ascii_bytes(value: text, width: i64) -> [u8]:
    var out: [u8] = []
    val raw = value.bytes()
    var i: i64 = 0
    while i < width:
        if i < raw.len():
            out = out.push(raw[i])
        else:
            out = out.push(0)
        i = i + 1
    out

fn collect_dependency_hashes(ctx: any) -> [SmfDependencyEntry]:
    """Collect interface hashes of all imported modules for SMF dependency tracking.

    Reads SHB interface hashes for each module's imports. If SHB files are not
    available yet, returns empty list (backward compatible — deps section omitted).
    """
    use compiler.driver.cache.cache_validator.{source_to_cache_path, get_shb_interface_hash}

    var deps: [SmfDependencyEntry] = []
    var seen: Dict<text, bool> = {}

    # Collect input file paths as dependency sources
    val input_files = ctx.options.input_files
    for input_path in input_files:
        # Look up SHB for this input's imports
        val hash = get_shb_interface_hash(input_path)
        if hash != 0 and not seen.has(input_path):
            seen[input_path] = true
            deps.push(SmfDependencyEntry(module_path: input_path, interface_hash: hash))

    deps
