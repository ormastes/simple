# Driver — AOT Output Methods
#
# Extracted from driver.spl. Contains CompilerDriver methods for:
# - compile_to_native: Native ELF compilation via backend + linker
# - compile_to_c: C++20 source generation (single-file and directory modes)
# - compile_to_smf: SMF module format compilation
# - compile_to_self_contained: Self-contained binary compilation
# - collect_smf_bytes: Shared helper for SMF byte collection
# - link_objects: Legacy linker helper

# Backend helpers for module compilation and backend resolution
use compiler.backend.backend.backend_helpers.{compile_module_with_backend, get_effective_backend_name}
use compiler.backend.linker.linker_wrapper.{link_to_native, link_to_smf, link_to_self_contained, NativeLinkConfig, SelfContainedConfig, write_elf_bytes_to_file}
use compiler.backend.backend.llvm_native_link.{link_llvm_native, NativeLinkOptions}
use compiler.driver.smf_writer.{generate_smf_with_templates, Target, build_smf_with_elf_embedded, build_smf_with_relocations, SmfBuildOptions, SmfDependencyEntry}
use compiler.backend.backend.cmake_gen.{generate_cmake_for_modules}
use driver_types.{CompileResult, CompileOptions, OutputFormat}
use compiler.driver.driver.{CompilerDriver}
use compiler.common.config.{Logger}
use compiler.driver.incremental.{BuildCache, FileFingerprint}
use compiler.driver.driver.parallel.{ParallelBuilder, ParallelBuildConfig, BuildResult}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_path_join(a: text, b: text) -> text
extern fn rt_path_parent(path: text) -> text

fn driver_log_debug(log: Logger, message: text):
    if log.level >= 10:
        print "[DEBUG] {message}"

fn driver_log_trace(log: Logger, message: text):
    if log.level >= 20:
        print "[TRACE] {message}"

fn driver_log_info(log: Logger, message: text):
    if log.level >= 4:
        print "[INFO] {message}"

impl CompilerDriver:
    me compile_to_native(output: text) -> CompileResult:
        val log = self.ctx.logger
        val backend_name = self.ctx.options.backend
        val is_release = self.ctx.options.release
        print "[NATIVE] backend_name={backend_name}, is_release={is_release}"
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        print "[NATIVE] effective_backend={effective_backend}"

        # Load build cache
        val cache_path = ".build/build_cache.sdn"
        var build_cache = BuildCache.load(cache_path)
        var cache_hit_count: i64 = 0
        var cache_miss_count: i64 = 0

        # Compile all modules and collect object files
        var object_files: [text] = []

        val low_memory = self.ctx.options.low_memory
        val module_names = self.ctx.mir_modules.keys()
        val total_modules = module_names.len()
        print "[NATIVE] compiling {total_modules} modules..."

        # Phase 1: Check cache, collect cached objects, identify uncached modules
        var uncached_names: [text] = []
        for name in module_names:
            val cached_entry = build_cache.get_entry(name)
            var used_cache = false
            if cached_entry.?:
                val entry = cached_entry.unwrap()
                if entry.outputs.len() > 0:
                    var all_exist = true
                    for out in entry.outputs:
                        if not rt_file_exists(out):
                            all_exist = false
                    if all_exist:
                        print "[NATIVE] cache hit: {name}"
                        cache_hit_count = cache_hit_count + 1
                        for obj in entry.outputs:
                            object_files = object_files.push(obj)
                        if low_memory:
                            self.ctx.evict_mir_module(name)
                        used_cache = true
            if not used_cache:
                uncached_names = uncached_names.push(name)

        # Phase 2: Compile uncached modules through ParallelBuilder
        if uncached_names.len() > 0:
            val parallel_cfg = ParallelBuildConfig(
                num_threads: 0,
                parallel_threshold: 4,
                deterministic: false,
                verbose: self.ctx.options.verbose
            )
            var builder = ParallelBuilder.create(parallel_cfg)

            for name in uncached_names:
                builder.add_unit(name, [])

            val build_result = builder.build(\name:
                _compile_one_module(self.ctx, backend_name, is_release, output, name)
            )
            cache_miss_count = build_result.stats.completed + build_result.stats.failed

            if not build_result.success:
                val first_err = build_result.errors[0]
                return CompileResult.CodegenError(first_err[1])

            # Post-process: update cache and collect object paths
            for obj_path in build_result.outputs:
                object_files = object_files.push(obj_path)
                val obj_fp = FileFingerprint.from_file(obj_path)
                if obj_fp.?:
                    # Extract module name from obj_path: "{output}.{name}.o"
                    val prefix = output + "."
                    var mod_name = obj_path
                    if obj_path.starts_with(prefix):
                        mod_name = obj_path[prefix.len():obj_path.len() - 2]
                    build_cache.update_entry(mod_name, obj_fp.unwrap(), [], [obj_path])

            # Evict MIR for compiled modules in low-memory mode
            if low_memory:
                for name in uncached_names:
                    self.ctx.evict_mir_module(name)

        # Save build cache
        build_cache.save()
        if cache_hit_count > 0 or cache_miss_count > 0:
            print "[NATIVE] cache: {cache_hit_count} hits, {cache_miss_count} misses"

        # Link object files into final executable
        print "[NATIVE] linking {object_files.len()} object files..."
        if effective_backend == "llvm" or effective_backend == "llvm-lib":
            # LLVM path: compile C runtime and link with entry point
            print "[NATIVE] creating NativeLinkOptions..."
            val llvm_opts = NativeLinkOptions(
                debug: self.ctx.options.debug_info,
                verbose: self.ctx.options.verbose,
                pie: true,
                bare_metal: false
            )
            print "[NATIVE] calling link_llvm_native..."
            match link_llvm_native(object_files, output, llvm_opts):
                case Ok(_):
                    driver_log_info(log, "Native executable written to {output} (backend: LLVM)")
                    CompileResult.Success(output)
                case Err(e):
                    CompileResult.CodegenError("LLVM native linking failed: {e}")
        else:
            # Original path for other backends
            var link_config = NativeLinkConfig.default()
            link_config.debug = self.ctx.options.debug_info
            link_config.verbose = self.ctx.options.verbose
            link_config.extra_flags = link_config.extra_flags.push("--fixed-be={effective_backend}")

            match link_to_native(object_files, output, link_config):
                case Ok(_):
                    driver_log_info(log, "Native executable written to {output} (backend: {effective_backend})")
                    CompileResult.Success(output)
                case Err(e):
                    CompileResult.CodegenError("Linking failed: {e}")

fn CompilerDriver_dot_compile_to_native(driver: CompilerDriver, output: text) -> CompileResult:
    driver.compile_to_native(output)

    me compile_to_c(output: text) -> CompileResult:
        """Compile all MIR modules to C++20 source. Routes to single-file or directory mode."""
        if output.ends_with(".cpp") or output.ends_with(".c") or output.ends_with(".cxx"):
            return self.compile_to_c_single_file(output)
        else:
            return self.compile_to_c_directory(output)

    me compile_to_c_single_file(output: text) -> CompileResult:
        """Compile all MIR modules to a single C++20 source file."""
        val log = self.ctx.logger
        val is_release = self.ctx.options.release
        driver_log_debug(log, "AOT C: generating C++20 to {output}")

        var all_c_source = ""
        for name in self.ctx.mir_modules.keys():
            driver_log_trace(log, "translating module: {name}")
            val mir_module = self.ctx.mir_modules[name]
            val compiled = compile_module_with_backend("c", mir_module, is_release)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("C codegen error in {name}: {err}")
            val module = compiled.unwrap()
            all_c_source = all_c_source + module.assembly

        # Write C++ source to output file
        if not rt_file_write_text(output, all_c_source):
            return CompileResult.CodegenError("Failed to write C++ source to {output}")
        driver_log_info(log, "C++20 source written to {output}")
        CompileResult.Success(output)

    me compile_to_c_directory(output_dir: text) -> CompileResult:
        """Compile MIR modules to per-module C++20 files with CMake infrastructure."""
        val log = self.ctx.logger
        val is_release = self.ctx.options.release
        driver_log_debug(log, "AOT C (multi-file): generating C++20 to {output_dir}/")

        # Create root output directory
        if not rt_dir_create(output_dir, true):
            return CompileResult.CodegenError("Failed to create output directory {output_dir}")

        var module_files: [(text, text)] = []

        for name in self.ctx.mir_modules.keys():
            driver_log_trace(log, "translating module: {name}")
            val mir_module = self.ctx.mir_modules[name]
            val compiled = compile_module_with_backend("c", mir_module, is_release)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("C codegen error in {name}: {err}")
            val module = compiled.unwrap()

            # Convert module name to relative file path: "compiler.core.parser" -> "compiler/core/parser.cpp"
            val rel_path = name.replace(".", "/") + ".cpp"
            val full_path = rt_path_join(output_dir, rel_path)

            # Create parent directories
            val parent_dir = rt_path_parent(full_path)
            if not rt_dir_create(parent_dir, true):
                return CompileResult.CodegenError("Failed to create directory {parent_dir}")

            # Write per-module .cpp file
            if not rt_file_write_text(full_path, module.assembly):
                return CompileResult.CodegenError("Failed to write {full_path}")

            # Write per-module .h file if header content present
            if module.has_llvm_ir and module.llvm_ir != "":
                val h_rel_path = name.replace(".", "/") + ".h"
                val h_full_path = rt_path_join(output_dir, h_rel_path)
                if not rt_file_write_text(h_full_path, module.llvm_ir):
                    return CompileResult.CodegenError("Failed to write {h_full_path}")
                driver_log_trace(log, "wrote {h_rel_path}")

            module_files.push((name, rel_path))
            driver_log_trace(log, "wrote {rel_path}")

        # Generate CMake infrastructure
        val cmake_err = generate_cmake_for_modules(output_dir, module_files, log)
        if cmake_err != nil:
            return CompileResult.CodegenError(cmake_err)

        driver_log_info(log, "C++20 multi-file output written to {output_dir}/ ({module_files.len()} modules)")
        CompileResult.Success(output_dir)

    me compile_to_cuda(output: text) -> CompileResult:
        """Compile all MIR modules to PTX assembly (CUDA backend)."""
        val log = self.ctx.logger
        val is_release = self.ctx.options.release
        driver_log_debug(log, "AOT CUDA: generating PTX to {output}")

        var all_ptx = ""
        val keys = self.ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to PTX: {name}")
            val mir_module = self.ctx.mir_modules[name]
            val compiled = compile_module_with_backend("cuda", mir_module, is_release)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("CUDA compile error in {name}: {err}")
            val module_result = compiled.unwrap()
            val asm = module_result.assembly ?? ""
            all_ptx = all_ptx + asm

        if not rt_file_write_text(output, all_ptx):
            return CompileResult.CodegenError("Failed to write PTX to {output}")
        driver_log_info(log, "PTX assembly written to {output}")
        CompileResult.Success(output)

    me compile_to_vhdl(output: text) -> CompileResult:
        """Compile all MIR modules to VHDL source (VHDL backend)."""
        val log = self.ctx.logger
        val is_release = self.ctx.options.release
        driver_log_debug(log, "AOT VHDL: generating VHDL to {output}")

        var all_vhdl = ""
        val keys = self.ctx.mir_modules.keys()
        for name in keys:
            driver_log_trace(log, "translating module to VHDL: {name}")
            val mir_module = self.ctx.mir_modules[name]
            val compiled = compile_module_with_backend("vhdl", mir_module, is_release)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("VHDL compile error in {name}: {err}")
            val module_result = compiled.unwrap()
            val vhdl = module_result.assembly ?? ""
            if all_vhdl != "" and vhdl != "":
                all_vhdl = all_vhdl + "\n\n"
            all_vhdl = all_vhdl + vhdl

        if not rt_file_write_text(output, all_vhdl):
            return CompileResult.CodegenError("Failed to write VHDL to {output}")
        driver_log_info(log, "VHDL source written to {output}")
        CompileResult.Success(output)

    me compile_to_smf(output: text) -> CompileResult:
        val log = self.ctx.logger
        val backend_name = self.ctx.options.backend
        val is_release = self.ctx.options.release
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        driver_log_debug(log, "AOT SMF: compiling to {output} (backend: {effective_backend})")

        val smf_result = self.collect_smf_bytes()
        if not smf_result.is_success():
            return smf_result

        val smf_bytes = smf_result.get_value()

        # Write SMF file using linker wrapper
        match link_to_smf(smf_bytes, output, self.ctx.options.verbose):
            case Ok(_):
                driver_log_info(log, "SMF module written to {output} (backend: {effective_backend})")
                CompileResult.Success(output)
            case Err(e):
                CompileResult.CodegenError("Failed to write SMF file: {e}")

    me compile_to_self_contained(output: text) -> CompileResult:
        val log = self.ctx.logger
        val backend_name = self.ctx.options.backend
        val is_release = self.ctx.options.release
        val effective_backend = get_effective_backend_name(backend_name, is_release)
        driver_log_debug(log, "AOT self-contained: compiling to {output} (backend: {effective_backend})")

        val smf_result = self.collect_smf_bytes()
        if not smf_result.is_success():
            return smf_result

        val smf_bytes = smf_result.get_value()

        # Build self-contained binary using linker wrapper
        var sc_config = SelfContainedConfig.default()
        sc_config.verbose = self.ctx.options.verbose

        match link_to_self_contained(smf_bytes, output, sc_config):
            case Ok(_):
                driver_log_info(log, "Self-contained binary written to {output} (backend: {effective_backend})")
                CompileResult.Success(output)
            case Err(e):
                CompileResult.CodegenError("Self-contained build failed: {e}")

    me collect_smf_bytes() -> CompileResult:
        val log = self.ctx.logger
        val backend_name = self.ctx.options.backend
        val is_release = self.ctx.options.release

        var all_object_bytes: [u8] = []

        for name in self.ctx.mir_modules.keys():
            driver_log_trace(log, "compiling module for SMF: {name}")
            val mir_module = self.ctx.mir_modules[name]
            val compiled = compile_module_with_backend(backend_name, mir_module, is_release)
            if compiled.is_err():
                val err = compiled.unwrap_err()
                return CompileResult.CodegenError("AOT compile error in {name}: {err}")

            val module = compiled.unwrap()
            if module.object_code.?:
                all_object_bytes = all_object_bytes.concat(module.object_code.unwrap())

        # Collect dependency interface hashes for staleness tracking
        val deps = collect_dependency_hashes(self.ctx)

        # Wrap object code into SMF format
        val target = Target.host()
        val smf_mode = self.ctx.options.smf_output_mode
        val smf_bytes = if smf_mode == "elf_embedded":
            # Phase 1: Store full ELF .o in Code section (native linker can read it)
            build_smf_with_elf_embedded(all_object_bytes, target)
        elif smf_mode == "reloc_sections":
            # Phase 2: Extract .text + relocations into separate sections
            var opts = SmfBuildOptions.create(target)
            opts.deps = deps
            build_smf_with_relocations(all_object_bytes, opts)
        else:
            # Default: strip ELF to raw .text bytes, with dependency tracking
            var opts = SmfBuildOptions.create(target)
            opts.deps = deps
            generate_smf_with_templates(all_object_bytes, nil, nil, target)
        CompileResult.Success(smf_bytes)

    # --------------------------------------------------------------------------
    # Linker Helper (legacy - kept for compatibility, delegates to linker_wrapper)
    # --------------------------------------------------------------------------

    fn link_objects(objects: [text], output: text) -> Result<text, text>:
        if objects.is_empty():
            return Err("No object files to link")

        var config = NativeLinkConfig.default()
        link_to_native(objects, output, config)

# ============================================================================
# Single-Module Compilation Helper (for ParallelBuilder)
# ============================================================================

fn _compile_one_module(ctx: any, backend_name: text, is_release: bool, output_base: text, name: text) -> Result<text, text>:
    """Compile a single module by name, write object file, return path."""
    print "[NATIVE] compiling module: {name}"
    val mir_module = ctx.mir_modules[name]
    val compiled = compile_module_with_backend(backend_name, mir_module, is_release)

    if compiled.is_err():
        val err = compiled.unwrap_err()
        return Err("AOT compile error in {name}: {err}")

    val module = compiled.unwrap()
    if module.object_code.?:
        val obj_path = "{output_base}.{name}.o"
        match write_elf_bytes_to_file(obj_path, module.object_code.unwrap()):
            case Ok(_):
                Ok(obj_path)
            case Err(e):
                Err("Failed to write object file {obj_path}: {e}")
    else:
        Err("Backend produced no object code for {name}")

# ============================================================================
# Dependency Collection for SMF Staleness Tracking
# ============================================================================

extern fn rt_file_read_bytes_range(path: text, offset: i64, count: i64) -> [u8]

fn collect_dependency_hashes(ctx: any) -> [SmfDependencyEntry]:
    """Collect interface hashes of all imported modules for SMF dependency tracking.

    Reads SHB interface hashes for each module's imports. If SHB files are not
    available yet, returns empty list (backward compatible — deps section omitted).
    """
    use compiler.driver.cache.cache_validator.{source_to_cache_path, get_shb_interface_hash}

    var deps: [SmfDependencyEntry] = []
    var seen: Dict<text, bool> = {}

    # Collect input file paths as dependency sources
    val input_files = ctx.options.input_files
    for input_path in input_files:
        # Look up SHB for this input's imports
        val hash = get_shb_interface_hash(input_path)
        if hash != 0 and not seen.contains_key(input_path):
            seen[input_path] = true
            deps = deps + [SmfDependencyEntry(module_path: input_path, interface_hash: hash)]

    deps
