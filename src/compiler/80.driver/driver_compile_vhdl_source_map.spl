# Driver — VHDL Source Map and Type Alias Resolution
#
# Extracted from driver_public_compile.spl. Contains:
# - _compile_simple_vhdl_subset: entry point for VHDL subset transpilation
# - Source map generation (_write_simple_vhdl_source_map, _simple_vhdl_entities_for_source_map, etc.)
# - Type alias resolution (_simple_type_aliases_for_source, _simple_resolve_type_alias, etc.)
# - Text utility helpers (_text_to_i64, _decimal_digit_value, _json_escape, _file_contains_vhdl_design)

use compiler.common.driver_core_types.{CompileResult}
use compiler.driver.driver_compile_vhdl_codegen.{_simple_vhdl_source_to_text}
use compiler.driver.driver_compile_vhdl_lowering.{_simple_is_labeled_tuple_type, _simple_labeled_tuple_labels, _simple_labeled_tuple_types}
use compiler.driver.driver_compile_vhdl_util.{
    _simple_split_top_level, _simple_find_top_level, _simple_find_matching_paren,
    _simple_vhdl_identifier, _simple_param_vhdl_name, _simple_decorator_payload, _is_decimal_digit,
    _simple_enum_name_from_header, _simple_enum_variant_name, _simple_enum_variant_payload_type,
    _simple_enum_block_has_payload, _simple_skip_enum_block,
    _text_list_contains, _text_list_index, _text_list_index_from
}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool

fn _simple_join_text(items: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < items.len():
        if i > 0:
            out = out + sep
        out = out + items[i]
        i = i + 1
    out

fn _compile_simple_vhdl_subset(path: text, output: text) -> CompileResult:
    val source = rt_file_read_text(path) ?? ""
    val vhdl_result = _simple_vhdl_source_to_text(source)
    if vhdl_result.is_err():
        _delete_simple_vhdl_outputs(output)
        return CompileResult.RuntimeError(vhdl_result.unwrap_err())
    val vhdl = vhdl_result.unwrap()
    if rt_file_write_text(output, vhdl):
        _write_simple_vhdl_source_map(path, output, source, vhdl)
        CompileResult.Success(output)
    else:
        _delete_simple_vhdl_outputs(output)
        CompileResult.RuntimeError("failed to write VHDL output: {output}")

fn _delete_simple_vhdl_outputs(output: text):
    rt_file_delete(output)
    rt_file_delete(output + ".map.json")

fn _write_simple_vhdl_source_map(path: text, output: text, source: text, vhdl: text):
    val map_path = output + ".map.json"
    val entities = _simple_vhdl_entities_for_source_map(vhdl, source)
    val ports = _simple_vhdl_ports_for_source_map(vhdl, source)
    var json = "{\n"
    json = json + "  \"version\": 1,\n"
    json = json + "  \"source\": \"" + _json_escape(path) + "\",\n"
    json = json + "  \"generated\": \"" + _json_escape(output) + "\",\n"
    json = json + "  \"backend\": \"simple-vhdl-source-facade\",\n"
    json = json + "  \"entities\": [" + entities + "],\n"
    json = json + "  \"ports\": [" + ports + "]\n"
    json = json + "}\n"
    rt_file_write_text(map_path, json)

fn _simple_vhdl_entities_for_source_map(vhdl: text, source: text) -> text:
    var entries: [text] = []
    val lines = vhdl.split("\n")
    var line_no = 1
    for raw in lines:
        val line = raw.trim()
        if line.starts_with("entity ") and line.contains(" is"):
            val rest = line.substring(7, line.len())
            val end_opt = rest.find(" ")
            val name = if end_opt.?: rest.substring(0, end_opt.unwrap()) else: rest
            val source_line = _simple_vhdl_source_entity_line(source, name)
            var entry = "{\"name\":\"" + _json_escape(name) + "\",\"line\":" + line_no.to_text()
            entry = entry + ",\"hwirId\":\"" + _json_escape(_simple_vhdl_hwir_node_id("entity", name, line_no)) + "\""
            if source_line > 0:
                entry = entry + ",\"sourceLine\":" + source_line.to_text()
            entry = entry + "}"
            entries = entries.push(entry)
        line_no = line_no + 1
    _simple_join_text(entries, ", ")

fn _simple_vhdl_ports_for_source_map(vhdl: text, source: text) -> text:
    var entries: [text] = []
    val aliases = _simple_type_aliases_for_source(source)
    val source_ports = _simple_vhdl_source_ports_for_map(source, aliases[0], aliases[1])
    val original_names = source_ports[0].split("\n")
    val sanitized_names = source_ports[1].split("\n")
    val source_lines = source_ports[2].split("\n")
    val lines = vhdl.split("\n")
    var line_no = 1
    var source_cursor = 0
    for raw in lines:
        val line = raw.trim()
        if (line.contains(" : in ") or line.contains(" : out ")) and not line.starts_with("signal "):
            val sep = line.find(":")
            if sep.?:
                val original_name = line.substring(0, sep.unwrap()).trim()
                val name = if original_name.ends_with(";"): original_name.substring(0, original_name.len() - 1) else: original_name
                var source_index = _text_list_index_from(sanitized_names, name, source_cursor)
                if source_index < 0:
                    source_index = _text_list_index(sanitized_names, name)
                val source_original = if source_index >= 0 and source_index < original_names.len(): original_names[source_index] else: name
                val source_line = if source_index >= 0 and source_index < source_lines.len(): _text_to_i64(source_lines[source_index]) else: 0
                var entry = "{\"name\":\"" + _json_escape(name) + "\",\"originalName\":\"" + _json_escape(source_original) + "\",\"sanitizedName\":\"" + _json_escape(name) + "\",\"line\":" + line_no.to_text()
                entry = entry + ",\"hwirId\":\"" + _json_escape(_simple_vhdl_hwir_node_id("port", name, line_no)) + "\""
                if source_line > 0:
                    entry = entry + ",\"sourceLine\":" + source_line.to_text()
                entry = entry + "}"
                entries = entries.push(entry)
                if source_index >= 0:
                    source_cursor = source_index + 1
        line_no = line_no + 1
    _simple_join_text(entries, ", ")

fn _simple_vhdl_source_entity_line(source: text, entity_name: text) -> i64:
    val lines = source.split("\n")
    var line_no = 1
    for raw in lines:
        val line = raw.trim()
        if line.starts_with("fn "):
            val after_fn = line.substring(3).trim()
            val name_end = after_fn.find("(")
            if name_end.?:
                val fn_name = after_fn.substring(0, name_end.unwrap()).trim()
                if _simple_vhdl_identifier(fn_name) == entity_name:
                    return line_no
        line_no = line_no + 1
    0

fn _simple_vhdl_source_ports_for_map(source: text, alias_names: [text], alias_types: [text]) -> [[text]]:
    var originals: [text] = []
    var sanitized: [text] = []
    var source_lines: [text] = []
    val lines = source.split("\n")
    var pending_clocked = ""
    var pending_clocked_line = 0
    var line_no = 1
    for raw in lines:
        val line = raw.trim()
        if line.starts_with("@clocked("):
            pending_clocked = _simple_decorator_payload(line, "@clocked")
            pending_clocked_line = line_no
        elif line.starts_with("fn "):
            val signature = _simple_source_signature_parts(line)
            if signature.len() == 3:
                val params_text = signature[1]
                val return_type = signature[2]
                val param_result = _simple_source_port_names_from_params(params_text, line_no, alias_names, alias_types)
                originals = originals + param_result[0]
                sanitized = sanitized + param_result[1]
                source_lines = source_lines + param_result[2]
                if pending_clocked != "":
                    val clock_result = _simple_source_clock_port_names(pending_clocked, if pending_clocked_line > 0: pending_clocked_line else: line_no)
                    originals = originals + clock_result[0]
                    sanitized = sanitized + clock_result[1]
                    source_lines = source_lines + clock_result[2]
                val return_result = _simple_source_port_names_from_return(return_type, line_no, alias_names, alias_types)
                originals = originals + return_result[0]
                sanitized = sanitized + return_result[1]
                source_lines = source_lines + return_result[2]
            pending_clocked = ""
            pending_clocked_line = 0
        line_no = line_no + 1
    [_simple_join_text(originals, "\n"), _simple_join_text(sanitized, "\n"), _simple_join_text(source_lines, "\n")]

fn _simple_source_signature_parts(line: text) -> [text]:
    if not line.starts_with("fn "):
        return []
    val after_fn = line.substring(3).trim()
    val name_end_opt = after_fn.find("(")
    val ret_start_opt = after_fn.find("->")
    if not name_end_opt.? or not ret_start_opt.?:
        return []
    val name_end = name_end_opt.unwrap()
    val params_end_opt = _simple_find_matching_paren(after_fn, name_end)
    if not params_end_opt.?:
        return []
    val params_end = params_end_opt.unwrap()
    val fn_name = after_fn.substring(0, name_end).trim()
    val params_text = after_fn.substring(name_end + 1, params_end).trim()
    var return_type = after_fn.substring(ret_start_opt.unwrap() + 2, after_fn.len()).trim()
    if return_type.ends_with(":"):
        return_type = return_type.substring(0, return_type.len() - 1).trim()
    [fn_name, params_text, return_type]

fn _simple_source_port_names_from_params(params_text: text, source_line: i64, alias_names: [text], alias_types: [text]) -> [[text]]:
    var originals: [text] = []
    var sanitized: [text] = []
    var lines: [text] = []
    if params_text.trim() != "":
        val parts = _simple_split_top_level(params_text, ",")
        for part in parts:
            val param = part.trim()
            val type_sep_opt = _simple_find_top_level(param, ":")
            if type_sep_opt.?:
                val param_name = param.substring(0, type_sep_opt.unwrap()).trim()
                val param_type = param.substring(type_sep_opt.unwrap() + 1, param.len()).trim()
                if _simple_is_labeled_tuple_type_alias(param_type, alias_names, alias_types):
                    val flattened = _simple_flatten_source_tuple_port_names(param_name, param_type, alias_names, alias_types)
                    for name in flattened:
                        originals = originals.push(name)
                        sanitized = sanitized.push(_simple_param_vhdl_name(name))
                        lines = lines.push(source_line.to_text())
                else:
                    originals = originals.push(param_name)
                    sanitized = sanitized.push(_simple_param_vhdl_name(param_name))
                    lines = lines.push(source_line.to_text())
    [originals, sanitized, lines]

fn _simple_flatten_source_tuple_port_names(prefix: text, tuple_type: text, alias_names: [text], alias_types: [text]) -> [text]:
    var names: [text] = []
    val labels = _simple_labeled_tuple_labels_alias(tuple_type, alias_names, alias_types)
    val types = _simple_labeled_tuple_types_alias(tuple_type, alias_names, alias_types)
    var i = 0
    while i < labels.len():
        val source_name = prefix + "." + labels[i]
        if i < types.len() and _simple_is_labeled_tuple_type_alias(types[i], alias_names, alias_types):
            names = names + _simple_flatten_source_tuple_port_names(source_name, types[i], alias_names, alias_types)
        else:
            names = names.push(source_name)
        i = i + 1
    names

fn _simple_source_clock_port_names(clocked_text: text, source_line: i64) -> [[text]]:
    var originals: [text] = []
    var sanitized: [text] = []
    var lines: [text] = []
    val parts = _simple_split_top_level(clocked_text, ",")
    if parts.len() >= 1 and parts[0].trim() != "":
        val clk = parts[0].trim()
        originals = originals.push(clk)
        sanitized = sanitized.push(_simple_param_vhdl_name(clk))
        lines = lines.push(source_line.to_text())
    if parts.len() >= 2 and parts[1].trim() != "":
        val reset_name = parts[1].trim()
        originals = originals.push(reset_name)
        sanitized = sanitized.push(_simple_param_vhdl_name(reset_name))
        lines = lines.push(source_line.to_text())
    [originals, sanitized, lines]

fn _simple_source_port_names_from_return(return_type: text, source_line: i64, alias_names: [text], alias_types: [text]) -> [[text]]:
    var originals: [text] = []
    var sanitized: [text] = []
    var lines: [text] = []
    if _simple_is_labeled_tuple_type_alias(return_type, alias_names, alias_types):
        val labels = _simple_labeled_tuple_labels_alias(return_type, alias_names, alias_types)
        for label in labels:
            originals = originals.push(label)
            sanitized = sanitized.push(_simple_vhdl_identifier(label))
            lines = lines.push(source_line.to_text())
    else:
        originals = originals.push("result_out")
        sanitized = sanitized.push("result_out")
        lines = lines.push(source_line.to_text())
    [originals, sanitized, lines]

fn _text_to_i64(value: text) -> i64:
    var out = 0
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if _is_decimal_digit(ch):
            out = out * 10 + _decimal_digit_value(ch)
        i = i + 1
    out

fn _decimal_digit_value(ch: text) -> i64:
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn _json_escape(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\"":
            out = out + "\\\""
        elif ch == "\n":
            out = out + "\\n"
        else:
            out = out + ch
        i = i + 1
    out

class RtlExplainResult:
    """Resolved VHDL-to-Simple explanation for an RTL line."""
    found: bool
    vhdl_line: i64
    hwir_id: text
    signal_name: text
    source_line: i64
    optimization_note: text

    me to_text() -> text:
        if not self.found:
            return "no RTL source-map entry for VHDL line " + self.vhdl_line.to_text()
        var out = "VHDL line " + self.vhdl_line.to_text() + " maps to " + self.signal_name
        if self.hwir_id != "":
            out = out + " (" + self.hwir_id + ")"
        if self.source_line > 0:
            out = out + " from Simple line " + self.source_line.to_text()
        if self.optimization_note != "":
            out = out + "; optimization: " + self.optimization_note
        return out

    static fn missing(vhdl_line: i64) -> RtlExplainResult:
        return RtlExplainResult(found: false, vhdl_line: vhdl_line, hwir_id: "", signal_name: "", source_line: 0, optimization_note: "")

class RtlWaveformGroup:
    """Named group of VHDL signals for waveform viewers."""
    name: text
    signals: [text]

    me render_gtkw() -> text:
        var out = "[group] " + self.name + "\n"
        for signal in self.signals:
            out = out + signal + "\n"
        out = out + "[end]\n"
        return out

class RtlFirstDivergence:
    """First formal/random divergence summary."""
    cycle: i64
    pc: text
    instruction: text
    register_diff: text
    memory_diff: text
    csr_diff: text
    source_span: text
    vhdl_signal_path: text
    waveform_link: text

    me render_markdown() -> text:
        var out = "## First RTL Divergence\n\n"
        out = out + "| Field | Value |\n"
        out = out + "|-------|-------|\n"
        out = out + "| Cycle | " + self.cycle.to_text() + " |\n"
        out = out + "| PC | " + self.pc + " |\n"
        out = out + "| Instruction | " + self.instruction + " |\n"
        out = out + "| Register diff | " + self.register_diff + " |\n"
        out = out + "| Memory diff | " + self.memory_diff + " |\n"
        out = out + "| CSR diff | " + self.csr_diff + " |\n"
        out = out + "| Source | " + self.source_span + " |\n"
        out = out + "| VHDL signal | " + self.vhdl_signal_path + " |\n"
        out = out + "| Waveform | " + self.waveform_link + " |\n"
        return out

fn _simple_vhdl_hwir_node_id(kind: text, name: text, line_no: i64) -> text:
    kind + ":" + _simple_vhdl_identifier(name) + ":" + line_no.to_text()

fn rtl_explain_vhdl_line_from_map(map_json: text, vhdl_line: i64) -> RtlExplainResult:
    val line_needle = "\"line\":" + vhdl_line.to_text()
    val line_index = map_json.find(line_needle)
    if line_index < 0:
        return RtlExplainResult.missing(vhdl_line)
    val prefix = map_json.slice(0, line_index)
    val object_start = prefix.rfind("{")
    val suffix = map_json.slice(line_index)
    val object_end = suffix.find("}")
    if object_start < 0 or object_end < 0:
        return RtlExplainResult.missing(vhdl_line)
    val object_text = map_json.slice(object_start, line_index + object_end + 1)
    val hwir_id = _extract_json_field_text(object_text, "hwirId")
    var signal_name = _extract_json_field_text(object_text, "originalName")
    if signal_name == "":
        signal_name = _extract_json_field_text(object_text, "name")
    val source_line = _extract_json_field_i64(object_text, "sourceLine")
    val opt_note = _extract_json_field_text(object_text, "optimization")
    return RtlExplainResult(found: true, vhdl_line: vhdl_line, hwir_id: hwir_id, signal_name: signal_name, source_line: source_line, optimization_note: opt_note)

fn rtl_waveform_groups_from_map(map_json: text) -> [RtlWaveformGroup]:
    var ports: [text] = []
    val parts = map_json.split("\"sanitizedName\":\"")
    var i = 1
    while i < parts.len():
        val tail = parts[i]
        val end = tail.find("\"")
        if end > 0:
            ports = ports.push(tail.slice(0, end))
        i = i + 1
    if ports.len() == 0:
        return []
    [RtlWaveformGroup(name: "ports", signals: ports)]

fn rtl_render_gtkw_from_groups(groups: [RtlWaveformGroup]) -> text:
    var out = ""
    for group in groups:
        out = out + group.render_gtkw()
    out

fn rtl_first_divergence_report(cycle: i64, pc: text, instruction: text, register_diff: text, memory_diff: text, csr_diff: text, source_span: text, vhdl_signal_path: text, waveform_link: text) -> text:
    val divergence = RtlFirstDivergence(
        cycle: cycle,
        pc: pc,
        instruction: instruction,
        register_diff: register_diff,
        memory_diff: memory_diff,
        csr_diff: csr_diff,
        source_span: source_span,
        vhdl_signal_path: vhdl_signal_path,
        waveform_link: waveform_link
    )
    divergence.render_markdown()

fn _extract_json_field_text(object_text: text, key: text) -> text:
    val needle = "\"" + key + "\":\""
    val start = object_text.find(needle)
    if start < 0:
        return ""
    val tail = object_text.slice(start + needle.len())
    val end = tail.find("\"")
    if end < 0:
        return ""
    tail.slice(0, end)

fn _extract_json_field_i64(object_text: text, key: text) -> i64:
    val needle = "\"" + key + "\":"
    val start = object_text.find(needle)
    if start < 0:
        return 0
    val tail = object_text.slice(start + needle.len())
    var digits = ""
    var i = 0
    while i < tail.len():
        val ch = tail.substring(i, i + 1)
        if _is_decimal_digit(ch):
            digits = digits + ch
        else:
            break
        i = i + 1
    _text_to_i64(digits)

fn _simple_type_aliases_for_source(source: text) -> [[text]]:
    var names: [text] = []
    var types: [text] = []
    val lines = source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("type "):
            val eq_opt = line.find("=")
            if eq_opt.?:
                val eq_index = eq_opt.unwrap()
                val alias_name = line.substring(5, eq_index).trim()
                val alias_type = line.substring(eq_index + 1, line.len()).trim()
                if alias_name != "" and alias_type != "":
                    names = names.push(alias_name)
                    types = types.push(alias_type)
        elif line.starts_with("enum "):
            val name_result = _simple_enum_name_from_header(line)
            if name_result != "":
                var variants: [text] = []
                var payload_fields: [text] = []
                i = i + 1
                while i < lines.len():
                    val variant_line = lines[i].trim()
                    if variant_line == "":
                        break
                    if variant_line.starts_with("@") or variant_line.starts_with("fn ") or variant_line.starts_with("type ") or variant_line.starts_with("enum "):
                        i = i - 1
                        break
                    val variant_name = _simple_enum_variant_name(variant_line)
                    if variant_name != "":
                        val safe_variant = _simple_vhdl_identifier(variant_name)
                        variants = variants.push(safe_variant)
                        val payload_type = _simple_enum_variant_payload_type(variant_line)
                        if payload_type != "":
                            payload_fields = payload_fields.push(safe_variant + "_payload:" + payload_type)
                    i = i + 1
                if variants.len() > 0:
                    names = names.push(name_result)
                    val payload_suffix = if payload_fields.len() > 0: "|" + _simple_join_text(payload_fields, ",") else: ""
                    types = types.push("enum:" + _simple_vhdl_identifier(name_result) + "_t:" + _simple_join_text(variants, ", ") + payload_suffix)
        i = i + 1
    [names, types]

fn _simple_resolve_type_alias(type_text: text, alias_names: [text], alias_types: [text]) -> text:
    var resolved = type_text.trim()
    var depth = 0
    while depth < 32:
        val index = _text_list_index(alias_names, resolved)
        if index < 0 or index >= alias_types.len():
            return resolved
        resolved = alias_types[index].trim()
        depth = depth + 1
    resolved

fn _simple_is_labeled_tuple_type_alias(type_text: text, alias_names: [text], alias_types: [text]) -> bool:
    _simple_is_labeled_tuple_type(_simple_resolve_type_alias(type_text, alias_names, alias_types))

fn _simple_is_anonymous_tuple_type_alias(type_text: text, alias_names: [text], alias_types: [text]) -> bool:
    val resolved = _simple_resolve_type_alias(type_text, alias_names, alias_types).trim()
    resolved.starts_with("(") and resolved.ends_with(")") and not _simple_is_labeled_tuple_type(resolved)

fn _simple_labeled_tuple_labels_alias(type_text: text, alias_names: [text], alias_types: [text]) -> [text]:
    _simple_labeled_tuple_labels(_simple_resolve_type_alias(type_text, alias_names, alias_types))

fn _simple_labeled_tuple_types_alias(type_text: text, alias_names: [text], alias_types: [text]) -> [text]:
    var out: [text] = []
    val types = _simple_labeled_tuple_types(_simple_resolve_type_alias(type_text, alias_names, alias_types))
    for type_name in types:
        out = out.push(_simple_resolve_type_alias(type_name, alias_names, alias_types))
    out

fn _simple_anonymous_tuple_labels_alias(type_text: text, alias_names: [text], alias_types: [text]) -> [text]:
    var labels: [text] = []
    val types = _simple_anonymous_tuple_types_alias(type_text, alias_names, alias_types)
    var i = 0
    while i < types.len():
        labels = labels.push("out_" + i.to_text())
        i = i + 1
    labels

fn _simple_anonymous_tuple_types_alias(type_text: text, alias_names: [text], alias_types: [text]) -> [text]:
    var out: [text] = []
    val resolved = _simple_resolve_type_alias(type_text, alias_names, alias_types).trim()
    if not resolved.starts_with("(") or not resolved.ends_with(")"):
        return out
    val inner = resolved.substring(1, resolved.len() - 1)
    val parts = _simple_split_top_level(inner, ",")
    for part in parts:
        val trimmed = part.trim()
        if trimmed != "":
            out = out.push(_simple_resolve_type_alias(trimmed, alias_names, alias_types))
    out

fn _file_contains_vhdl_design(path: text) -> bool:
    val content = rt_file_read_text(path) ?? ""
    val trimmed = content.trim()
    val has_design_unit = trimmed.starts_with("library ") or trimmed.starts_with("use ") or trimmed.starts_with("package ") or trimmed.starts_with("entity ") or trimmed.contains("\nentity ")
    has_design_unit and trimmed.contains("<=")
