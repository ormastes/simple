# Driver API Compile Single [Tier 2] - Single-file compilation helpers.
#
# Dependency rules:
#   - May import from: driver_api_types (Tier 0), driver_api_interpret (Tier 1),
#     driver_core_types
#   - Must NOT import from Tier 3+ files
#   - Uses `use lazy` for CompilerDriver

use compiler.common.driver_core_types.{CompileOptions, CompileMode, CompileResult, OutputFormat, driver_core_compile_options_default, compileoptions_normalize_mir_optimization}
use lazy compiler.driver.driver.{compiler_driver_create, compiler_driver_run_compile}

pub fn compile_file(path: text) -> CompileResult:
    val options = driver_core_compile_options_default()
    options.input_files = [path]
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

pub fn compile_files(paths: [text], mode: CompileMode) -> CompileResult:
    val options = driver_core_compile_options_default()
    options.input_files = paths
    options.mode = mode
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

pub fn jit_file(path: text) -> CompileResult:
    compile_files([path], CompileMode.Jit)

pub fn check_file(path: text) -> CompileResult:
    compile_files([path], CompileMode.Check)

pub fn parse_sdn_file(path: text) -> CompileResult:
    compile_files([path], CompileMode.Sdn)

pub fn compile_to_smf(path: text, output: text) -> Result<text, text>:
    val options = driver_core_compile_options_default()
    options.input_files = [path]
    options.output_file = output
    options.mode = CompileMode.Aot
    options.output_format = OutputFormat.Smf

    val driver = compiler_driver_create(options)
    val result = compiler_driver_run_compile(driver)

    match result:
        case CompileResult.Success(_):
            Ok(output)
        case _:
            val errors = result.get_errors()
            val error_msg = if errors.len() > 0:
                errors.join("\n")
            else:
                "Compilation failed"
            Err(error_msg)

pub fn compile_to_smf_with_options(
    path: text,
    output: text,
    backend: text,
    opt_level: i64,
    release: bool,
    debug_info: bool,
    gc_off: bool,
    profile: text,
    allowed_families: [text]
) -> Result<text, text>:
    val options = driver_core_compile_options_default()
    options.input_files = [path]
    options.output_file = output
    options.mode = CompileMode.Aot
    options.output_format = OutputFormat.Smf
    options.backend = backend
    options.opt_level = opt_level
    options.release = release
    options.debug_info = debug_info
    options.gc_off = gc_off
    options.profile = profile
    options.allowed_families = allowed_families
    val options = compileoptions_normalize_mir_optimization(options)

    val driver = compiler_driver_create(options)
    val result = compiler_driver_run_compile(driver)

    match result:
        case CompileResult.Success(_):
            Ok(output)
        case _:
            val errors = result.get_errors()
            val error_msg = if errors.len() > 0:
                errors.join("\n")
            else:
                "Compilation failed"
            Err(error_msg)
