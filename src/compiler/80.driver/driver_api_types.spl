#![allow(export_outside_init)]
# Driver API Types [Tier 0] - Extern declarations and lightweight helpers.
#
# Dependency rules:
#   - NO compiler graph imports (no HIR, MIR, backend, linker, etc.)
#   - May import only driver_core_types for CompileResult / CompileOptions
#   - All higher tiers may import from this file
#
# Contains: extern fn declarations shared across tiers, find_runtime_lib_dir,
# and the _combine_driver_api_process_error helper.

extern fn _rt_dir_exists(path: text) -> bool
extern fn _rt_dir_list(path: text) -> [text]
extern fn _rt_file_exists(path: text) -> bool
extern fn _rt_file_write_text(path: text, content: text) -> bool
extern fn _rt_file_delete(path: text) -> bool
extern fn _rt_dir_create(path: text, recursive: bool) -> bool
extern fn _rt_path_join(a: text, b: text) -> text
extern fn _rt_path_parent(path: text) -> text
extern fn _rt_process_run(cmd: text, args: [text]) -> text
extern fn _rt_env_get(name: text) -> text
extern fn _sys_get_args() -> [text]

fn rt_dir_exists(path: text) -> bool:
    _rt_dir_exists(path)

fn rt_dir_list(path: text) -> [text]:
    _rt_dir_list(path)

fn rt_file_exists(path: text) -> bool:
    _rt_file_exists(path)

fn rt_file_write_text(path: text, content: text) -> bool:
    _rt_file_write_text(path, content)

fn rt_file_delete(path: text) -> bool:
    _rt_file_delete(path)

fn rt_dir_create(path: text, recursive: bool) -> bool:
    _rt_dir_create(path, recursive)

fn rt_path_join(a: text, b: text) -> text:
    _rt_path_join(a, b)

fn rt_path_parent(path: text) -> text:
    _rt_path_parent(path)

fn rt_process_run(cmd: text, args: [text]) -> text:
    _rt_process_run(cmd, args)

fn rt_env_get(name: text) -> text:
    _rt_env_get(name)

fn sys_get_args() -> [text]:
    _sys_get_args()

fn find_runtime_lib_dir() -> text:
    val env_path = rt_env_get("SIMPLE_RUNTIME_PATH")
    if env_path != nil and env_path != "":
        return env_path

    val candidates = [
        "src/compiler_rust/target/bootstrap",
        "src/compiler_rust/target/debug",
        "src/compiler_rust/target/release",
        "rust/target/bootstrap",
        "rust/target/debug",
        "rust/target/release"
    ]

    for dir in candidates:
        if rt_file_exists("{dir}/libsimple_compiler.so"):
            return dir
        if rt_file_exists("{dir}/libsimple_compiler.dylib"):
            return dir
        if rt_file_exists("{dir}/simple_compiler.dll"):
            return dir

    "src/compiler_rust/target/bootstrap"

fn _combine_driver_api_process_error(prefix: text, stdout: text, stderr: text) -> text:
    var detail = stderr.trim()
    if detail == "":
        detail = stdout.trim()
    if detail == "":
        return prefix
    prefix + ": " + detail

export find_runtime_lib_dir
export _combine_driver_api_process_error
export rt_dir_exists, rt_dir_list, rt_file_exists, rt_file_write_text, rt_file_delete
export rt_dir_create, rt_path_join, rt_path_parent, rt_process_run, rt_env_get, sys_get_args
