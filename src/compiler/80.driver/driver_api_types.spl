#![allow(export_outside_init)]
# Driver API Types [Tier 0] - Extern declarations and lightweight helpers.
#
# Dependency rules:
#   - NO compiler graph imports (no HIR, MIR, backend, linker, etc.)
#   - May import only driver_core_types for CompileResult / CompileOptions
#   - All higher tiers may import from this file
#
# Contains: extern fn declarations shared across tiers, find_runtime_lib_dir,
# and the _combine_driver_api_process_error helper.

extern fn rt_dir_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_path_join(a: text, b: text) -> text
extern fn rt_path_parent(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> text
extern fn rt_env_get(name: text) -> text
extern fn sys_get_args() -> [text]

fn find_runtime_lib_dir() -> text:
    val env_path = rt_env_get("SIMPLE_RUNTIME_PATH")
    if env_path != nil and env_path != "":
        return env_path
    if rt_file_exists("rust/target/debug/libsimple_compiler.so"):
        return "rust/target/debug"
    if rt_file_exists("rust/target/release/libsimple_compiler.so"):
        return "rust/target/release"
    "rust/target/debug"

fn _combine_driver_api_process_error(prefix: text, stdout: text, stderr: text) -> text:
    var detail = stderr.trim()
    if detail == "":
        detail = stdout.trim()
    if detail == "":
        return prefix
    prefix + ": " + detail

export find_runtime_lib_dir
export _combine_driver_api_process_error
export rt_dir_exists, rt_dir_list, rt_file_exists, rt_file_write_text, rt_file_delete
export rt_dir_create, rt_path_join, rt_path_parent, rt_process_run, rt_env_get, sys_get_args
