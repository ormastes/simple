# Build Orchestrator - OPTIMIZED VERSION
#
# Orchestrates build operations with proper sequencing
#
# Build pipeline:
# 1. Run the real FFI generator to create Rust code in build/rust/ffi_gen/
# 2. Run native compilation with the generated workspace in place
#
# OPTIMIZATIONS APPLIED:
# 1. Use .? existence check instead of .len() > 0
# 2. Cache string splits to avoid repeated parsing
# 3. Batch string building for error messages

use app.build.types (BuildConfig, BuildResult, BuildProfile, profile_to_string)
use app.build.cargo (Cargo, print_build_result)
use app.build.doc_warnings (run_doc_warnings)
use app.io.mod (file_exists, process_run, file_read, env_get)
use app.compile.native.{compile_native}
use std.log.{info, debug, error}

fn ffi_workspace_root() -> text:
    "build/rust/ffi_gen"

fn ffi_output_env_name() -> text:
    "SIMPLE_FFI_OUTPUT_DIR"

fn ffi_mode_env_name() -> text:
    "SIMPLE_FFI_GEN_MODE"

fn ffi_verify_env_name() -> text:
    "SIMPLE_FFI_VERIFY"

fn ffi_clean_env_name() -> text:
    "SIMPLE_FFI_CLEAN"

fn ffi_lto_env_name() -> text:
    "SIMPLE_FFI_USE_LTO"

fn ffi_generator_script_path() -> text:
    "src/compiler/90.tools/ffi_gen/main.spl"

fn ffi_generator_output_dir() -> text:
    val output_dir = env_get(ffi_output_env_name())
    if output_dir != "":
        return output_dir
    ffi_workspace_root()

fn ffi_workspace_manifest_path() -> text:
    "{ffi_generator_output_dir()}/Cargo.toml"

fn ffi_workspace_source_path() -> text:
    "{ffi_generator_output_dir()}/src/lib.rs"

fn ffi_generation_skip_env_name() -> text:
    "SIMPLE_SKIP_FFI_GEN"

fn simple_binary_path() -> text:
    val env_bin = env_get("SIMPLE_BINARY")
    if env_bin != "":
        return env_bin
    if file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if file_exists("bin/release/simple"):
        return "bin/release/simple"
    if file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    "bin/simple"

fn build_ffi_generator_args() -> [text]:
    var args = [ffi_generator_script_path()]
    val mode = env_get(ffi_mode_env_name())

    if mode == "all":
        args.push("--gen-all")
    else:
        args.push("--gen-workspace")

    if env_get(ffi_clean_env_name()) == "1":
        args.push("--clean")

    args.push("--output={ffi_generator_output_dir()}")

    if env_get(ffi_verify_env_name()) == "1":
        args.push("--verify")

    args

fn ffi_workspace_ready() -> bool:
    file_exists(ffi_workspace_manifest_path()) and file_exists(ffi_workspace_source_path())

fn ffi_generation_skipped() -> bool:
    val skip = env_get(ffi_generation_skip_env_name())
    return skip == "1" or skip == "true"

# Run the real FFI generator to create the Rust workspace used by later builds.
fn run_ffi_generator(verbose: bool) -> bool:
    run_ffi_generator_with_binary(simple_binary_path(), verbose)

fn run_ffi_generator_with_binary(binary: text, verbose: bool) -> bool:
    if ffi_generation_skipped():
        if verbose:
            print "FFI generation skipped via {ffi_generation_skip_env_name()}"
        return true

    if verbose:
        print "Running FFI generator..."
        print "  Binary: {binary}"
        print "  Script: {ffi_generator_script_path()}"
        print "  Output: {ffi_generator_output_dir()}"

    val result = process_run(binary, build_ffi_generator_args())
    val stdout = result.0
    val stderr = result.1
    val exit_code = result.2

    if verbose and stdout.?:
        print stdout
    if verbose and stderr.?:
        print stderr

    if exit_code != 0:
        error("build", "FFI generator failed (exit code {exit_code})")
        return false

    if not ffi_workspace_ready():
        error("build", "FFI generator completed but workspace is missing: {ffi_workspace_root()}")
        return false

    if verbose:
        print "FFI generation complete"

    true

# Orchestrate a build
fn orchestrate_build(config: BuildConfig) -> BuildResult:
    if config.verbose:
        # OPTIMIZATION: Build verbose output as batch
        var info_lines = [
            "Building with profile: {profile_to_string(config.profile)}",
            "Workspace root: {config.workspace_root}"
        ]

        # OPTIMIZATION: Use .? check
        if config.features.?:
            info_lines.push("Features: {config.features}")

        if config.release_optimized:
            info_lines.push("Release optimized: -O2 + {config.march_target} + ThinLTO")
        if config.use_lto:
            info_lines.push("ThinLTO: enabled")
        if config.march_target != "":
            info_lines.push("Target arch: {config.march_target}")
        if config.pgo_generate:
            info_lines.push("PGO: instrumentation mode")
        if config.pgo_use_path != "":
            info_lines.push("PGO: using profile {config.pgo_use_path}")

        print info_lines.join("\n")

    # Check documentation warnings if requested
    if config.warn_docs:
        val doc_exit = run_doc_warnings(config.verbose)
        if doc_exit != 0 and config.verbose:
            info("build", "Documentation warnings found (build continues)")

    # Generate FFI wrappers before the native compile step.
    # Bootstrap sets SIMPLE_SKIP_FFI_GEN after its single pre-generation pass so
    # the nested stage builds reuse the same workspace instead of regenerating.
    if not run_ffi_generator(config.verbose):
        return BuildResult(
            success: false,
            exit_code: 1,
            stdout: "",
            stderr: "FFI generation failed",
            duration_ms: 0
        )

    # Native compilation via C backend -> clang++ -> mold
    debug("build", "Starting native compilation pipeline")

    val source_file = "src/app/cli/main.spl"
    val is_release = config.profile == BuildProfile.Release

    # Output to build/ for debug, bin/release/ for release (avoid overwriting running binary)
    var output_path = "build/simple"
    var final_path = "build/simple"
    if is_release:
        output_path = "build/simple-release"
        final_path = "bin/release/simple"

    debug("build", "Profile: {profile_to_string(config.profile)}, output: {output_path}")

    # Ensure output directory exists
    val (_, _, mkdir_exit) = process_run("mkdir", ["-p", "build"])
    if mkdir_exit != 0:
        error("build", "Failed to create build/ directory")
        return BuildResult(
            success: false,
            exit_code: 1,
            stdout: "",
            stderr: "Failed to create build/ directory",
            duration_ms: 0
        )

    # Run compile pipeline in-process
    debug("build", "Compiling {source_file} -> {output_path} (in-process)")
    info("build", "Compiling {source_file} -> {output_path}")

    var exit_code = 0
    if is_release:
        # Release: native compilation via subprocess (avoids interpreter import chain issues)
        info("build", "Using native compilation (release)")
        val build_log = "build/simple-release.log"
        var compile_cmd = "SIMPLE_BOOTSTRAP=1 bin/release/simple compile {source_file} --native -o {output_path}"
        if config.verbose:
            compile_cmd = compile_cmd + " --verbose"
        compile_cmd = compile_cmd + " > {build_log} 2>&1"
        val (stdout, stderr, compile_exit) = process_run("sh", ["-lc", compile_cmd])
        if config.verbose and file_exists(build_log):
            val compile_output = file_read(build_log)
            if compile_output.?:
                print compile_output
        elif stdout.?:
            print stdout
        if stderr.?:
            print stderr
        exit_code = compile_exit
    else:
        # Debug: C backend (fast compilation)
        exit_code = compile_native(source_file, output_path, config.verbose, "", false, "")

    if exit_code != 0:
        error("build", "Compilation failed (exit code {exit_code})")
        var err_text = "Native compilation failed"
        if is_release and file_exists("build/simple-release.log"):
            err_text = file_read("build/simple-release.log")

        return BuildResult(
            success: false,
            exit_code: exit_code,
            stdout: "",
            stderr: err_text,
            duration_ms: 0
        )

    # For release builds, copy to final location
    if is_release and output_path != final_path:
        debug("build", "Copying {output_path} -> {final_path}")
        val (_, cp_err, cp_exit) = process_run("cp", [output_path, final_path])
        if cp_exit != 0:
            error("build", "Failed to copy to {final_path}: {cp_err}")

    info("build", "Build complete: {final_path}")

    val result = BuildResult(
        success: true,
        exit_code: 0,
        stdout: "",
        stderr: "",
        duration_ms: 0
    )

    # Print result
    print_build_result(result)

    result

# Orchestrate tests
fn orchestrate_test(config: BuildConfig) -> i64:
    if config.verbose:
        print "Running tests..."

    # First ensure we have a debug build
    if config.verbose:
        print "Ensuring debug build exists..."

    var build_config = config
    build_config.profile = BuildProfile.Debug

    val build_result = Cargo.build(build_config)
    if not build_result.success:
        print "Build failed, cannot run tests"
        return 1

    # Run tests
    val test_result = Cargo.test_workspace()

    if test_result.success:
        print "All tests passed: {test_result.tests_passed}/{test_result.tests_run}"
        return 0
    else:
        print "Tests failed: {test_result.tests_failed}/{test_result.tests_run}"
        return 1

# Clean build artifacts
fn orchestrate_clean(verbose: bool) -> i64:
    if verbose:
        print "Cleaning build artifacts..."

    val exit_code = Cargo.clean()

    if exit_code == 0:
        print "Clean complete"
    else:
        print "Clean failed"

    exit_code
