# Layer Check - Build-Time Layer Dependency Enforcement
#
# Scans `use compiler.*` imports in the compiler source tree and validates
# that dependencies respect the numbered layer ordering (NN.name/).
# Lower-numbered layers must not import from higher-numbered layers.
#
# Wire into orchestrate_build() for build-time enforcement,
# or invoke standalone via `simple check-layers`.
#
# Uses _check_layer_dep() from layer_checker.spl.
#
# NOTE: Avoids text.substring() which is destructive in interpreter mode.
# Uses split("/") and character iteration instead.

use compiler.mdsoc.checker_types.layer_violation.{LayerViolation}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool

# Result of a layer check run
struct LayerCheckResult:
    violation_count: i64
    files_scanned: i64
    imports_checked: i64
    violations: [LayerViolation]

    fn has_violations() -> bool:
        self.violation_count > 0

    fn summary() -> text:
        if self.violation_count == 0:
            "Layer check passed: {self.files_scanned} files, {self.imports_checked} imports checked, 0 violations"
        else:
            "Layer check FAILED: {self.files_scanned} files, {self.imports_checked} imports checked, {self.violation_count} violations"

# Extract the numeric prefix from a numbered dir name.
# E.g., "10.frontend" -> 10, "85.mdsoc" -> 85, "common" -> -1
fn _extract_layer_number(dir_name: text) -> i64:
    var num_str = ""
    for ch in dir_name:
        if ch == ".":
            break
        if ch >= "0" and ch <= "9":
            num_str = num_str + ch
        else:
            return -1
    if num_str == "":
        return -1
    # Parse number manually: "10" -> 10, "85" -> 85
    var result: i64 = 0
    for ch in num_str:
        val digit = match ch:
            case "0": 0
            case "1": 1
            case "2": 2
            case "3": 3
            case "4": 4
            case "5": 5
            case "6": 6
            case "7": 7
            case "8": 8
            case "9": 9
            case _: 0
        result = result * 10 + digit
    result

# Check if a dependency between numbered directories is allowed.
# Returns nil if allowed, a LayerViolation if from_dir imports from a higher layer.
fn _check_layer_dep(from_dir: text, to_dir: text) -> LayerViolation?:
    val from_num = _extract_layer_number(from_dir)
    val to_num = _extract_layer_number(to_dir)
    if from_num < 0 or to_num < 0:
        return nil
    if to_num <= from_num:
        return nil
    # Violation
    LayerViolation.new(
        from_dir, to_dir,
        "layer {from_num}", "layer {to_num}",
        "layer {from_num} ({from_dir}) cannot import from layer {to_num} ({to_dir})",
        ""
    )

# Check if a string starts with a digit (0-9)
fn _starts_with_digit(s: text) -> bool:
    (s.starts_with("0") or s.starts_with("1") or
     s.starts_with("2") or s.starts_with("3") or
     s.starts_with("4") or s.starts_with("5") or
     s.starts_with("6") or s.starts_with("7") or
     s.starts_with("8") or s.starts_with("9"))

# Extract the layer directory from a compiler module path.
# E.g., "src/compiler/10.frontend/core/lexer.spl" -> "10.frontend"
# Returns empty string if the path is not in a numbered compiler layer.
fn _extract_layer_dir(path: text) -> text:
    if not path.starts_with("src/compiler/"):
        return ""
    # Split by "/" to get path segments safely (no substring mutation)
    val parts = path.split("/")
    # parts = ["src", "compiler", "10.frontend", "core", "lexer.spl"]
    if parts.len() < 4:
        return ""
    val segment = parts[2]
    # Verify it's a numbered directory (NN.name pattern)
    if segment.len() < 3:
        return ""
    if not _starts_with_digit(segment):
        return ""
    if not segment.contains("."):
        return ""
    segment

# Extract the suffix after the first dot in a numbered dir name.
# E.g., "10.frontend" -> "frontend", "85.mdsoc" -> "mdsoc"
fn _dir_suffix(dir_name: text) -> text:
    var suffix = ""
    var past_dot = false
    for ch in dir_name:
        if past_dot:
            suffix = suffix + ch
        elif ch == ".":
            past_dot = true
    suffix

# Extract the first segment after "compiler." from an import path.
# E.g., "compiler.frontend.core.lexer" -> "frontend"
fn _import_first_seg(import_path: text) -> text:
    if not import_path.starts_with("compiler."):
        return ""
    # Skip first 9 chars ("compiler."), collect until next "."
    var seg = ""
    var i = 0
    for ch in import_path:
        if i < 9:
            i = i + 1
            continue
        if ch == ".":
            break
        seg = seg + ch
        i = i + 1
    seg

# Extract the layer directory from a `use compiler.XXX` import path.
# E.g., "compiler.frontend.core.lexer" -> "10.frontend"
# We map the first segment after "compiler." to the actual numbered dir.
fn _resolve_import_to_layer_dir(import_path: text, layer_dirs: [text]) -> text:
    val first_seg = _import_first_seg(import_path)
    if first_seg == "":
        return ""
    # Match against known numbered dirs: "10.frontend" matches "frontend"
    var result = ""
    for dir_name in layer_dirs:
        val suffix = _dir_suffix(dir_name)
        if suffix == first_seg:
            result = dir_name
    result

# Extract import path from a "use compiler.xxx.yyy.{Z}" line.
# Returns the module path without "use " prefix, braces, or glob.
fn _extract_import_path(trimmed: text) -> text:
    # Build the import path char by char, skipping "use " prefix
    var import_text = ""
    var i = 0
    for ch in trimmed:
        if i < 4:
            i = i + 1
            continue
        if ch == "{" or ch == "(":
            break
        import_text = import_text + ch
        i = i + 1
    # Remove trailing dot (from "compiler.foo.{Bar}" pattern)
    if import_text.ends_with("."):
        var trimmed_text = ""
        var k = 0
        val target_len = import_text.len() - 1
        for ch in import_text:
            if k < target_len:
                trimmed_text = trimmed_text + ch
            k = k + 1
        import_text = trimmed_text
    # Remove trailing .* glob
    if import_text.ends_with(".*"):
        var trimmed_text = ""
        var k = 0
        val target_len = import_text.len() - 2
        for ch in import_text:
            if k < target_len:
                trimmed_text = trimmed_text + ch
            k = k + 1
        import_text = trimmed_text
    import_text

# Scan a single .spl file for `use compiler.*` imports.
# Returns list of (from_layer_dir, to_layer_dir) pairs.
fn _scan_file_imports(path: text, content: text, layer_dirs: [text]) -> ([text], [text]):
    val from_dir = _extract_layer_dir(path)
    if from_dir == "":
        return ([], [])

    var from_dirs: [text] = []
    var to_dirs: [text] = []

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if not trimmed.starts_with("use compiler."):
            continue

        val import_text = _extract_import_path(trimmed)
        val to_dir = _resolve_import_to_layer_dir(import_text, layer_dirs)
        if to_dir != "" and to_dir != from_dir:
            from_dirs = from_dirs.push(from_dir)
            to_dirs = to_dirs.push(to_dir)

    (from_dirs, to_dirs)

# Recursively collect .spl files from a directory
fn _collect_spl_files(dir: text) -> [text]:
    var result: [text] = []
    val entries = rt_dir_list(dir) ?? []
    for entry in entries:
        val child_path = "{dir}/{entry}"
        if entry.ends_with(".spl"):
            result = result.push(child_path)
        elif not entry.contains("."):
            # Subdirectory (no extension)
            val sub_files = _collect_spl_files(child_path)
            for f in sub_files:
                result = result.push(f)
    result

# Get the list of numbered layer directories under src/compiler/
fn _get_layer_dirs() -> [text]:
    val entries = rt_dir_list("src/compiler") ?? []
    var layer_dirs: [text] = []
    for entry in entries:
        if entry.len() < 3:
            continue
        if not _starts_with_digit(entry):
            continue
        if not entry.contains("."):
            continue
        layer_dirs = layer_dirs.push(entry)
    layer_dirs

# Run the layer dependency check on the compiler source tree.
fn run_layer_check(strict: bool) -> LayerCheckResult:
    val layer_dirs = _get_layer_dirs()
    var violations: [LayerViolation] = []
    var files_scanned: i64 = 0
    var imports_checked: i64 = 0
    var violation_count: i64 = 0

    # Scan each numbered layer directory
    for dir_name in layer_dirs:
        val dir_path = "src/compiler/{dir_name}"
        val spl_files = _collect_spl_files(dir_path)
        for file_path in spl_files:
            files_scanned = files_scanned + 1
            val content = rt_file_read_text(file_path) ?? ""
            if content == "":
                continue

            val (from_dirs, to_dirs) = _scan_file_imports(file_path, content, layer_dirs)
            var idx = 0
            while idx < from_dirs.len():
                imports_checked = imports_checked + 1
                val violation = _check_layer_dep(from_dirs[idx], to_dirs[idx])
                if violation.?:
                    val v = violation ?? LayerViolation.new("", "", "", "", "", "")
                    val enriched = LayerViolation.new(
                        file_path, to_dirs[idx],
                        v.from_layer, v.to_layer,
                        v.message, file_path
                    )
                    violations = violations.push(enriched)
                    violation_count = violation_count + 1
                idx = idx + 1

    LayerCheckResult(
        violation_count: violation_count,
        files_scanned: files_scanned,
        imports_checked: imports_checked,
        violations: violations
    )

# Print layer check results to stdout
fn print_layer_check_result(result: LayerCheckResult, strict: bool):
    if result.has_violations():
        print "[LAYER] {result.summary()}"
        print ""
        for v in result.violations:
            print "  VIOLATION: {v.from_module}"
            print "    imports: {v.to_module}"
            print "    {v.message}"
            print ""
        if strict:
            print "Layer check failed (--strict-layers enabled)"
    else:
        print "[LAYER] {result.summary()}"
