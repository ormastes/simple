# Build System CLI Entry Point - Lightweight
#
# Handles lint/fmt/check directly (fast path, no heavy imports).
# Delegates all other subcommands to cli_entry_full.spl via subprocess.

extern fn sys_get_args() -> [text]
extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)

use std.log.{log_point_start, log_point_flush, log_point_discard, log_print}

# Stored exit code from main(). -1 = not yet run.
var _exit_code = -1

fn delegate_full(args: [text]) -> i64:
    val script = "src/compiler/80.driver/build/cli_entry_full.spl"
    var all_args = [script]
    for arg in args:
        all_args.push(arg)
    val (stdout, stderr, code) = rt_process_run("bin/simple", all_args)
    if stdout.?:
        print stdout
    if stderr.?:
        print stderr
    code

fn run_lint() -> i64:
    val lp = log_point_start("lint")
    val args = ["clippy", "--manifest-path", "src/compiler_rust/Cargo.toml", "--workspace", "--", "-W", "clippy::all"]
    val (stdout, stderr, exit_code) = rt_process_run("cargo", args)
    if stdout.?:
        log_print(stdout)
    if stderr.?:
        log_print(stderr)
    if exit_code != 0:
        log_point_flush(lp)
    else:
        log_point_discard(lp)
    exit_code

fn run_fmt() -> i64:
    val lp = log_point_start("fmt")
    val args = ["fmt", "--manifest-path", "src/compiler_rust/Cargo.toml", "--all"]
    val (stdout, stderr, exit_code) = rt_process_run("cargo", args)
    if stdout.?:
        log_print(stdout)
    if stderr.?:
        log_print(stderr)
    if exit_code != 0:
        log_point_flush(lp)
    else:
        log_point_discard(lp)
    exit_code

fn run_check() -> i64:
    # Lint
    print "\n=== Running Lint (clippy) ==="
    val lint_code = run_lint()
    # Format check
    print "\n=== Running Format (rustfmt) ==="
    val fmt_args = ["fmt", "--manifest-path", "src/compiler_rust/Cargo.toml", "--all", "--check"]
    val (fmt_stdout, fmt_stderr, fmt_code) = rt_process_run("cargo", fmt_args)
    if fmt_stdout.?:
        print fmt_stdout
    if fmt_stderr.?:
        print fmt_stderr
    # Tests via subprocess
    print "\n=== Running Tests ==="
    val (test_stdout, test_stderr, test_code) = rt_process_run("bin/simple", ["test"])
    if test_stdout.?:
        print test_stdout
    if test_stderr.?:
        print test_stderr
    # Overall
    if lint_code != 0:
        return lint_code
    if fmt_code != 0:
        return fmt_code
    test_code

fn handle_build(args: [text]) -> i64:
    # If main() already handled the command, return its exit code
    if _exit_code >= 0:
        return _exit_code
    if args.len() == 0:
        return delegate_full(args)
    val cmd = args[0]
    match cmd:
        case "lint":
            return run_lint()
        case "fmt":
            return run_fmt()
        case "check":
            return run_check()
        case _:
            return delegate_full(args)
    0

fn main() -> i64:
    val all_args = sys_get_args()
    var args: [text] = []
    var i = 1
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    _exit_code = handle_build(args)
    _exit_code
