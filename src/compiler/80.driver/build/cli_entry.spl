# Build System CLI Entry Point - Lightweight
#
# Handles lint/fmt/check directly (fast path, no heavy imports).
# Delegates all other subcommands to cli_entry_full.spl via subprocess.

extern fn sys_get_args() -> [text]
extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64

# Stored exit code from main(). -1 = not yet run.
var _exit_code = -1

fn delegate_full(args: [text]) -> i64:
    val script = "src/compiler/80.driver/build/cli_entry_full.spl"
    var all_args = [script]
    for arg in args:
        all_args.push(arg)
    val (stdout, stderr, code) = rt_process_run("bin/simple", all_args)
    if stdout.?:
        print stdout
    if stderr.?:
        print stderr
    code

fn run_lint() -> i64:
    val args = ["clippy", "--manifest-path", "src/compiler_rust/Cargo.toml", "--workspace", "--", "-W", "clippy::all"]
    val (stdout, stderr, exit_code) = rt_process_run("cargo", args)
    if stdout.?:
        print stdout
    if stderr.?:
        print stderr
    exit_code

fn run_fmt() -> i64:
    val args = ["fmt", "--manifest-path", "src/compiler_rust/Cargo.toml", "--all"]
    val (stdout, stderr, exit_code) = rt_process_run("cargo", args)
    if stdout.?:
        print stdout
    if stderr.?:
        print stderr
    exit_code

fn run_check() -> i64:
    # Run lint + fmt in parallel (they are independent), then tests
    print "\n=== Running Lint + Format (parallel) ==="
    val lint_pid = rt_process_spawn_async("cargo", ["clippy", "--manifest-path", "src/compiler_rust/Cargo.toml", "--workspace", "--", "-W", "clippy::all"])
    val fmt_pid = rt_process_spawn_async("cargo", ["fmt", "--manifest-path", "src/compiler_rust/Cargo.toml", "--all", "--check"])

    # Wait for both (5 min timeout each)
    val lint_code = rt_process_wait(lint_pid, 300000)
    val fmt_code = rt_process_wait(fmt_pid, 300000)

    if lint_code != 0:
        print "Lint failed (exit code {lint_code})"
    if fmt_code != 0:
        print "Format check failed (exit code {fmt_code})"

    # Tests via subprocess
    print "\n=== Running Tests ==="
    val (test_stdout, test_stderr, test_code) = rt_process_run("bin/simple", ["test"])
    if test_stdout.?:
        print test_stdout
    if test_stderr.?:
        print test_stderr
    # Overall
    if lint_code != 0:
        return lint_code
    if fmt_code != 0:
        return fmt_code
    test_code

fn handle_build(args: [text]) -> i64:
    # If main() already handled the command, return its exit code
    if _exit_code >= 0:
        return _exit_code
    if args.len() == 0:
        return delegate_full(args)
    val cmd = args[0]
    match cmd:
        case "lint":
            return run_lint()
        case "fmt":
            return run_fmt()
        case "check":
            return run_check()
        case _:
            return delegate_full(args)
    0

fn main() -> i64:
    val all_args = sys_get_args()
    var args: [text] = []
    var i = 1
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    _exit_code = handle_build(args)
    _exit_code
