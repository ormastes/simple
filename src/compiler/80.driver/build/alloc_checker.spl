#![allow(unnamed_duplicate_typed_args)]
# @no_alloc
# Alloc import checker — static analysis for baremetal builds
#
# Scans source files for heap-allocating stdlib imports and reports errors
# when such imports appear in a no-alloc build configuration.

extern fn rt_file_read_text(path: text) -> text


# Error produced when an @alloc module is imported in a no-alloc build
struct AllocCheckError:
    file_path: text
    imported_module: text
    message: text

# Construct an AllocCheckError with a standard message
fn alloc_check_error_new(file_path: text, imported_module: text) -> AllocCheckError:
    AllocCheckError(
        file_path: file_path,
        imported_module: imported_module,
        message: "alloc module '" + imported_module + "' imported in no-alloc build"
    )

# Read source text and return its alloc annotation.
# Returns "@alloc", "@no_alloc", or "" if the file is untagged.
fn alloc_annotation_from_source(source_text: text) -> text:
    val lines = source_text.split("\n")
    if lines.len() == 0:
        return ""
    val first = lines[0]
    if first == "# @alloc":
        return "@alloc"
    if first == "# @no_alloc":
        return "@no_alloc"
    ""

# Determine if a use-spec imports from an allocating family.
# Family classification by prefix:
#   - nogc_async_mut_noalloc  -> no-alloc (baremetal, no heap)
#   - nogc_*                  -> no-gc but may allocate (unique ptrs)
#   - gc_*                    -> gc-managed, allocates
#   - common                  -> pure, no allocation restrictions
#
# Returns "alloc" if the imported module is from an allocating family,
# "noalloc" if from a no-alloc family, or "" if unknown/pure.
fn _classify_import_family(use_spec: text) -> text:
    # Normalize: std.X and lib.X both resolve to src/lib/X
    var module_path = use_spec
    if module_path.starts_with("std."):
        module_path = module_path[4:module_path.len()]
    elif module_path.starts_with("lib."):
        module_path = module_path[4:module_path.len()]

    # Check family prefix (order matters: check noalloc before nogc)
    if module_path.starts_with("nogc_async_mut_noalloc"):
        return "noalloc"
    if module_path.starts_with("nogc_"):
        return "nogc"
    if module_path.starts_with("gc_"):
        return "alloc"
    if module_path.starts_with("common"):
        return "pure"
    # Unknown family — fall back to legacy file-level check
    ""

# Map a use-spec prefix to a source file path (legacy fallback).
# "std.string.{...}" -> "src/lib/string.spl"
# Returns "" when the module is unknown.
fn _extract_module_path(use_spec: text) -> text:
    # Try family-based classification first
    val family = _classify_import_family(use_spec)
    if family.len() > 0:
        return ""  # Family-based check handles this; no file read needed

    # Legacy: map specific well-known modules to file paths
    if use_spec.starts_with("std.string"):
        return "src/lib/string.spl"
    if use_spec.starts_with("std.text"):
        return "src/lib/text.spl"
    if use_spec.starts_with("std.array"):
        return "src/lib/array.spl"
    if use_spec.starts_with("std.path"):
        return "src/lib/path.spl"
    if use_spec.starts_with("std.effects"):
        return "src/lib/effects.spl"
    ""

# Try to read a module file.  Returns "" if the file cannot be read.
fn _try_read_module(path: text) -> text:
    val content = rt_file_read_text(path)
    content ?? ""

# Check a source file's imports against alloc annotations.
# source_text   — full text of the file being analysed
# alloc_allowed — when true, no errors are ever produced
# Returns a (possibly empty) list of AllocCheckError values.
fn check_alloc_imports(source_text: text, alloc_allowed: bool) -> [AllocCheckError]:
    var errors: [AllocCheckError] = []
    if alloc_allowed:
        return errors
    val lines = source_text.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("use std.") or trimmed.starts_with("use lib."):
            val after_use = trimmed[4:trimmed.len()]

            # Family-prefix-based check (covers entire namespace)
            val family = _classify_import_family(after_use)
            if family == "alloc":
                errors.push(alloc_check_error_new("(source)", after_use))
                continue

            # Legacy file-level annotation fallback for non-family modules
            val module_path = _extract_module_path(after_use)
            if module_path.len() > 0:
                val module_text = _try_read_module(module_path)
                if module_text.len() > 0:
                    val annotation = alloc_annotation_from_source(module_text)
                    if annotation == "@alloc":
                        errors.push(alloc_check_error_new("(source)", module_path))
    errors
