# Coverage Orchestrator - Pure Simple Pipeline
#
# Code coverage integration for the Simple build system.
# Runs the Pure Simple test runner with --coverage flag
# instead of cargo llvm-cov.

use app.io.mod (process_run, process_run_timeout, file_exists, file_read, dir_create)
use app.io.dir_ops.{dir_create_all}
use app.io.env_ops.{env_set}

# Coverage level
enum CoverageLevel:
    Unit          # Unit tests only
    Integration   # Integration tests only
    System        # System tests only
    All           # All test levels

# Coverage format
enum CoverageFormat:
    Text          # Plain text summary
    Html          # HTML report (not yet supported, falls back to text+markdown)
    Lcov          # LCOV format (not yet supported, falls back to text+markdown)
    Json          # JSON format (not yet supported, falls back to text+markdown)

# Coverage configuration
struct CoverageConfig:
    level: CoverageLevel
    format: CoverageFormat
    output_dir: text
    threshold: f64        # Minimum coverage percentage (0.0 = no threshold)
    fail_on_threshold: bool
    include_doctests: bool
    test_path: text       # Test path filter (empty = all tests)

# Coverage result
struct CoverageResult:
    success: bool
    exit_code: i64
    coverage_percent: f64
    lines_covered: i64
    lines_total: i64
    report_path: text
    stdout: text
    stderr: text
    met_threshold: bool

impl CoverageResult:
    fn summary() -> text:
        "Coverage: {self.coverage_percent}% ({self.lines_covered}/{self.lines_total} decisions)"

# Coverage orchestrator class
class Coverage:
    # Run coverage with configuration
    static fn run(config: CoverageConfig) -> CoverageResult:
        # Find Simple binary
        val binary = find_simple_binary_for_cov()
        if binary == "":
            return CoverageResult(
                success: false,
                exit_code: 1,
                coverage_percent: 0.0,
                lines_covered: 0,
                lines_total: 0,
                report_path: "",
                stdout: "",
                stderr: "Simple binary not found (checked bin/release/simple and bin/simple)",
                met_threshold: false
            )

        # Ensure output directory exists
        dir_create_all(config.output_dir)

        # Enable coverage via environment variable
        env_set("SIMPLE_COVERAGE", "1")

        # Build test runner args
        var args: [text] = ["test"]

        # Add test path filter
        if config.test_path != "":
            args.push(config.test_path)

        # Run test runner with coverage enabled via env var
        val timeout_ms = 600000  # 10 minute timeout for full coverage run
        val (stdout, stderr, exit_code) = process_run_timeout(binary, args, timeout_ms)

        # Read coverage data from saved SDN file
        val sdn_path = "{config.output_dir}/coverage.sdn"
        var coverage_percent = 0.0
        var lines_covered = 0
        var lines_total = 0
        if file_exists(sdn_path):
            val sdn_content = file_read(sdn_path)
            val (cov_pct, cov_covered, cov_total) = parse_sdn_coverage_stats(sdn_content)
            coverage_percent = cov_pct
            lines_covered = cov_covered
            lines_total = cov_total
        else:
            # Fallback: parse from stdout
            coverage_percent = parse_coverage_percent_from_summary(stdout)
            val (c, t) = parse_coverage_decisions(stdout)
            lines_covered = c
            lines_total = t

        # Check threshold
        var met_threshold = true
        if config.threshold > 0.0:
            met_threshold = coverage_percent >= config.threshold

        val success = (exit_code == 0) and (not config.fail_on_threshold or met_threshold)

        # Report path
        val report_path = "{config.output_dir}/summary.md"

        CoverageResult(
            success: success,
            exit_code: exit_code,
            coverage_percent: coverage_percent,
            lines_covered: lines_covered,
            lines_total: lines_total,
            report_path: report_path,
            stdout: stdout,
            stderr: stderr,
            met_threshold: met_threshold
        )

    # Quick coverage run with defaults
    static fn quick() -> CoverageResult:
        Coverage.run(default_coverage_config())

    # Coverage for specific level
    static fn for_level(level: CoverageLevel) -> CoverageResult:
        var config = default_coverage_config()
        config.level = level
        Coverage.run(config)

# Find the Simple binary
fn find_simple_binary_for_cov() -> text:
    if file_exists("bin/release/simple"):
        return "bin/release/simple"
    if file_exists("bin/simple"):
        return "bin/simple"
    ""

# Parse coverage percentage from test runner summary output
fn parse_coverage_percent_from_summary(output: text) -> f64:
    # Look for "Decision coverage: XX% (..."
    val lines = output.split("\n")
    for line in lines:
        if line.contains("Decision coverage:"):
            val trimmed = line.trim()
            # Extract percentage: "Decision coverage: 85% (..."
            val pct_idx = trimmed.index_of("%")
            if pct_idx.?:
                val idx = pct_idx.unwrap()
                var start = idx - 1
                var num_str = ""
                while start >= 0:
                    val ch = trimmed[start]
                    if ch >= "0" and ch <= "9":
                        num_str = ch + num_str
                        start = start - 1
                    elif num_str != "":
                        break
                    else:
                        start = start - 1
                if num_str != "":
                    return to_float(num_str)
    0.0

# Parse decisions covered/total from output
fn parse_coverage_decisions(output: text) -> (i64, i64):
    # Look for "Decision coverage: XX% (covered/total decisions)"
    val lines = output.split("\n")
    for line in lines:
        if line.contains("Decision coverage:") and line.contains("/"):
            # Extract "123/456" from the parenthesized part
            val paren_start = line.index_of("(")
            val paren_end = line.index_of(")")
            if paren_start.? and paren_end.?:
                val inner = line[paren_start.unwrap() + 1 : paren_end.unwrap()]
                # inner is like "123/456 decisions"
                val slash_idx = inner.index_of("/")
                if slash_idx.?:
                    val si = slash_idx.unwrap()
                    val covered_str = inner[0:si].trim()
                    val rest = inner[si + 1:]
                    # rest is like "456 decisions"
                    val space_idx = rest.index_of(" ")
                    var total_str = rest.trim()
                    if space_idx.?:
                        total_str = rest[0:space_idx.unwrap()].trim()
                    val covered = to_int(covered_str)
                    val total = to_int(total_str)
                    return (covered, total)
    (0, 0)

# Parse coverage stats from SDN file content
fn parse_sdn_coverage_stats(sdn: text) -> (f64, i64, i64):
    var total_decisions = 0
    var covered_decisions = 0
    var in_decisions = false
    val lines = sdn.split("\n")
    # Count decisions: a decision is covered if it has both true>0 and false>0
    var decision_ids: [text] = []
    var decision_true_counts: [i64] = []
    var decision_false_counts: [i64] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("decisions"):
            in_decisions = true
            continue
        if trimmed.starts_with("conditions") or trimmed.starts_with("summary") or trimmed.starts_with("paths"):
            in_decisions = false
            continue
        if in_decisions and trimmed != "" and not trimmed.starts_with("#"):
            val parts = trimmed.split(",")
            if parts.len() >= 6:
                val decision_id = parts[0].trim()
                val true_count = to_int(parts[4].trim())
                val false_count = to_int(parts[5].trim())
                total_decisions = total_decisions + 1
                if true_count > 0 and false_count > 0:
                    covered_decisions = covered_decisions + 1
    var pct = 0.0
    if total_decisions > 0:
        pct = (covered_decisions * 100) / total_decisions * 1.0
    (pct, covered_decisions, total_decisions)

fn to_float(s: text) -> f64:
    val n = to_int(s)
    n * 1.0

# Print coverage result
fn print_coverage_result(result: CoverageResult):
    if result.success:
        print "Coverage: {result.coverage_percent}%"
        print "  Decisions covered: {result.lines_covered}/{result.lines_total}"
        if result.report_path != "":
            print "  Report: {result.report_path}"
        if result.met_threshold:
            print "  Threshold check: passed"
        else:
            print "  Threshold check: FAILED"
    else:
        print "Coverage failed with exit code {result.exit_code}"
        if result.stderr != "":
            print result.stderr

# Default coverage configuration
fn default_coverage_config() -> CoverageConfig:
    CoverageConfig(
        level: CoverageLevel.All,
        format: CoverageFormat.Text,
        output_dir: "build/coverage",
        threshold: 0.0,
        fail_on_threshold: false,
        include_doctests: false,
        test_path: ""
    )

# Helper: Convert level to string
fn level_to_string(level: CoverageLevel) -> text:
    match level:
        case CoverageLevel.Unit: "unit"
        case CoverageLevel.Integration: "integration"
        case CoverageLevel.System: "system"
        case CoverageLevel.All: "all"

# Helper: Convert format to string
fn format_to_string(format: CoverageFormat) -> text:
    match format:
        case CoverageFormat.Text: "text"
        case CoverageFormat.Html: "html"
        case CoverageFormat.Lcov: "lcov"
        case CoverageFormat.Json: "json"
