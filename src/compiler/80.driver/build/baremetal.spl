# Bare-Metal Build Module
#
# Build commands for bare-metal targets (ARM, x86_64, RISC-V).
# Uses static linker scripts and crt0.s startup code.
#
# Usage:
#   simple build baremetal --target=arm
#   simple build baremetal --target=x86_64
#   simple build baremetal --target=riscv

use app.build.types.{BuildResult, TestResult}
use app.io.mod.{dir_create, file_write, file_exists, process_run, current_time_ms}
use app.build.compile_to_llvm.{compile_to_llvm_ir_pure}


# Bare-metal target architectures
enum BaremetalTarget:
    Arm           # ARM Cortex-M4 generic (versatilepb in QEMU)
    X86_64        # x86_64 with multiboot2
    Riscv         # RISC-V 64-bit (virt machine)
    Riscv32       # RISC-V 32-bit (virt machine)
    Stm32h7       # STM32H7 (Cortex-M7, flash @ 0x08000000)
    Stm32wb       # STM32WB (Cortex-M4, flash @ 0x08000000)

# Bare-metal build configuration
class BaremetalConfig:
    target: BaremetalTarget
    output_dir: text
    linker_script: text
    crt0_path: text
    entry_point: text
    alloc_allowed: bool

impl BaremetalConfig:
    # Create ARM Cortex-M config
    static fn arm() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.Arm,
            output_dir: "build/baremetal-arm",
            linker_script: "src/compiler/70.backend/baremetal/arm/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/arm/crt0.s",
            entry_point: "reset_handler",
            alloc_allowed: false
        )

    # Create x86_64 config
    static fn x86_64() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.X86_64,
            output_dir: "build/baremetal-x86_64",
            linker_script: "src/compiler/70.backend/baremetal/x86_64/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/x86_64/crt0.s",
            entry_point: "_start",
            alloc_allowed: false
        )

    # Create RISC-V 64-bit config
    static fn riscv() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.Riscv,
            output_dir: "build/baremetal-riscv",
            linker_script: "src/compiler/70.backend/baremetal/riscv/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/riscv/crt0.s",
            entry_point: "_start",
            alloc_allowed: false
        )

    # Create RISC-V 32-bit config
    static fn riscv32() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.Riscv32,
            output_dir: "build/baremetal-riscv32",
            linker_script: "src/lib/nogc_async_mut_noalloc/baremetal/riscv32/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/riscv/crt0.s",
            entry_point: "_start",
            alloc_allowed: false
        )

    # Create STM32H7 config (Cortex-M7)
    static fn stm32h7() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.Stm32h7,
            output_dir: "build/baremetal-stm32h7",
            linker_script: "src/compiler/70.backend/baremetal/arm/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/arm/crt0.s",
            entry_point: "reset_handler",
            alloc_allowed: false
        )

    # Create STM32WB config (Cortex-M4)
    static fn stm32wb() -> BaremetalConfig:
        BaremetalConfig(
            target: BaremetalTarget.Stm32wb,
            output_dir: "build/baremetal-stm32wb",
            linker_script: "src/compiler/70.backend/baremetal/arm/linker.ld",
            crt0_path: "src/compiler/70.backend/baremetal/arm/crt0.s",
            entry_point: "reset_handler",
            alloc_allowed: false
        )

    # Create x86_64 QEMU config (alias for x86_64)
    static fn qemu_x86() -> BaremetalConfig:
        BaremetalConfig.x86_64()

    # Return a copy of this config with heap allocation enabled
    fn with_alloc() -> BaremetalConfig:
        BaremetalConfig(
            target: self.target,
            output_dir: self.output_dir,
            linker_script: self.linker_script,
            crt0_path: self.crt0_path,
            entry_point: self.entry_point,
            alloc_allowed: true
        )

    # Get target triple
    fn target_triple() -> text:
        match self.target:
            case BaremetalTarget.Arm: "armv7m-none-eabi"
            case BaremetalTarget.X86_64: "x86_64-unknown-none"
            case BaremetalTarget.Riscv: "riscv64gc-unknown-none-elf"
            case BaremetalTarget.Riscv32: "riscv32-unknown-none-elf"
            case BaremetalTarget.Stm32h7: "armv7em-none-eabihf"
            case BaremetalTarget.Stm32wb: "armv7m-none-eabi"

# Factory functions (exported)
fn baremetal_config_arm() -> BaremetalConfig:
    BaremetalConfig.arm()

fn baremetal_config_x86_64() -> BaremetalConfig:
    BaremetalConfig.x86_64()

fn baremetal_config_riscv() -> BaremetalConfig:
    BaremetalConfig.riscv()

fn baremetal_config_riscv32() -> BaremetalConfig:
    BaremetalConfig.riscv32()

fn baremetal_config_stm32h7() -> BaremetalConfig:
    BaremetalConfig.stm32h7()

fn baremetal_config_stm32wb() -> BaremetalConfig:
    BaremetalConfig.stm32wb()

# Bare-metal builder
class BaremetalBuilder:
    config: BaremetalConfig

impl BaremetalBuilder:
    static fn new(config: BaremetalConfig) -> BaremetalBuilder:
        BaremetalBuilder(config: config)

    # Build a bare-metal binary
    fn build(source_files: [text]) -> BuildResult:
        if source_files.len() == 0:
            return BuildResult(
                success: false,
                exit_code: 1,
                stdout: "",
                stderr: "No Simple source files provided for bare-metal build",
                duration_ms: 0
            )

        # Create output directory
        dir_create(self.config.output_dir, true)

        # Verify linker script exists
        if not file_exists(self.config.linker_script):
            return BuildResult(
                success: false,
                exit_code: 1,
                stdout: "",
                stderr: "Linker script not found: {self.config.linker_script}",
                duration_ms: 0
            )

        # Verify crt0.s exists
        if not file_exists(self.config.crt0_path):
            return BuildResult(
                success: false,
                exit_code: 1,
                stdout: "",
                stderr: "Startup code not found: {self.config.crt0_path}",
                duration_ms: 0
            )

        val start_time = current_time_ms()

        # Step 1: Assemble crt0.s
        val crt0_result = self.assemble_crt0()
        if not crt0_result.success:
            return crt0_result

        # Step 2: Compile minimal runtime support
        val runtime_result = self.compile_runtime_support()
        if not runtime_result.success:
            return BuildResult(
                success: false,
                exit_code: runtime_result.exit_code,
                stdout: crt0_result.stdout + "\n" + runtime_result.stdout,
                stderr: crt0_result.stderr + runtime_result.stderr,
                duration_ms: current_time_ms() - start_time
            )

        # Step 3: Compile Simple source files to object files
        var object_files: [text] = [crt0_result.stdout, runtime_result.stdout]
        var all_stdout = crt0_result.stdout + "\n"
        all_stdout = all_stdout + runtime_result.stdout + "\n"
        var all_stderr = crt0_result.stderr + runtime_result.stderr

        for source_file in source_files:
            val obj_result = self.compile_source(source_file)
            if not obj_result.success:
                return BuildResult(
                    success: false,
                    exit_code: obj_result.exit_code,
                    stdout: all_stdout + obj_result.stdout,
                    stderr: all_stderr + obj_result.stderr,
                    duration_ms: current_time_ms() - start_time
                )
            object_files.push(obj_result.stdout)  # object file path
            all_stdout = all_stdout + obj_result.stdout + "\n"
            all_stderr = all_stderr + obj_result.stderr

        # Step 4: Link object files to ELF binary
        val link_result = self.link_to_elf(object_files)
        val end_time = current_time_ms()

        if link_result.success:
            BuildResult(
                success: true,
                exit_code: 0,
                stdout: all_stdout + link_result.stdout + "\nBinary: {link_result.stdout}",
                stderr: all_stderr + link_result.stderr,
                duration_ms: end_time - start_time
            )
        else:
            BuildResult(
                success: false,
                exit_code: link_result.exit_code,
                stdout: all_stdout + link_result.stdout,
                stderr: all_stderr + link_result.stderr + "\nLinking failed",
                duration_ms: end_time - start_time
            )

    # Assemble crt0.s to crt0.o
    fn assemble_crt0() -> BuildResult:
        val obj_file = "{self.config.output_dir}/crt0.o"
        var args = self.target_clang_args()
        args.push("-x")
        args.push("assembler-with-cpp")
        args.push("-c")
        args.push(self.config.crt0_path)
        args.push("-o")
        args.push(obj_file)

        val (stdout, stderr, exit_code) = process_run("clang", args)

        if exit_code == 0:
            BuildResult(success: true, exit_code: 0, stdout: obj_file, stderr: stderr, duration_ms: 0)
        else:
            BuildResult(success: false, exit_code: exit_code, stdout: stdout, stderr: "Assembly failed: {stderr}", duration_ms: 0)

    fn compile_runtime_support() -> BuildResult:
        val source_path = "src/runtime/startup/baremetal/runtime_minimal.c"
        val obj_file = "{self.config.output_dir}/runtime_minimal.o"
        var args = self.target_clang_args()
        args.push("-ffreestanding")
        args.push("-fno-builtin")
        args.push("-fdata-sections")
        args.push("-ffunction-sections")
        args.push("-fno-stack-protector")
        args.push("-fno-exceptions")
        args.push("-c")
        args.push(source_path)
        args.push("-o")
        args.push(obj_file)

        val (stdout, stderr, exit_code) = process_run("clang", args)
        if exit_code == 0:
            BuildResult(success: true, exit_code: 0, stdout: obj_file, stderr: stderr, duration_ms: 0)
        else:
            BuildResult(success: false, exit_code: exit_code, stdout: stdout, stderr: "Runtime support compilation failed: {stderr}", duration_ms: 0)

    # Assemble an arbitrary .S or .s file to object file
    fn assemble_file(asm_file: text) -> BuildResult:
        # Extract base name
        var base_name = asm_file
        if base_name.contains("/"):
            val parts = base_name.split("/")
            base_name = parts[parts.len() - 1]
        if base_name.ends_with(".S"):
            base_name = base_name[0:base_name.len() - 2]
        elif base_name.ends_with(".s"):
            base_name = base_name[0:base_name.len() - 2]

        val obj_file = "{self.config.output_dir}/{base_name}.o"
        var args = self.target_clang_args()
        args.push("-x")
        args.push("assembler-with-cpp")
        args.push("-c")
        args.push(asm_file)
        args.push("-o")
        args.push(obj_file)

        val (stdout, stderr, exit_code) = process_run("clang", args)
        if exit_code == 0:
            BuildResult(success: true, exit_code: 0, stdout: obj_file, stderr: stderr, duration_ms: 0)
        else:
            BuildResult(success: false, exit_code: exit_code, stdout: stdout, stderr: "Assembly failed: {stderr}", duration_ms: 0)

    # Compile Simple source to object file
    fn compile_source(source_file: text) -> BuildResult:
        # Assembly files: route through clang assembler
        if source_file.ends_with(".S") or source_file.ends_with(".s"):
            return self.assemble_file(source_file)

        # Extract base name
        var base_name = source_file
        if base_name.contains("/"):
            val parts = base_name.split("/")
            base_name = parts[parts.len() - 1]
        if base_name.ends_with(".spl"):
            base_name = base_name[0:base_name.len() - 4]

        val ir_file = "{self.config.output_dir}/{base_name}.ll"
        val obj_file = "{self.config.output_dir}/{base_name}.o"
        val (llvm_ir, compile_err, compile_exit) = compile_to_llvm_ir_pure(source_file, self.config.target_triple(), true)
        if compile_exit != 0 or llvm_ir == "":
            val err = if compile_err != "": compile_err else: "Pure Simple LLVM IR generation returned no output"
            return BuildResult(success: false, exit_code: if compile_exit == 0: 1 else: compile_exit, stdout: "", stderr: err, duration_ms: 0)

        if not file_write(ir_file, llvm_ir):
            return BuildResult(success: false, exit_code: 1, stdout: "", stderr: "Failed to write LLVM IR: {ir_file}", duration_ms: 0)

        var args = self.llc_args(ir_file, obj_file)
        val (stdout, stderr, exit_code) = process_run("llc", args)
        if exit_code == 0:
            BuildResult(success: true, exit_code: 0, stdout: obj_file, stderr: stderr, duration_ms: 0)
        else:
            BuildResult(success: false, exit_code: exit_code, stdout: stdout, stderr: "LLVM object generation failed: {stderr}", duration_ms: 0)

    # Link object files to ELF binary using linker script
    fn link_to_elf(object_files: [text]) -> BuildResult:
        val elf_file = "{self.config.output_dir}/kernel.elf"
        var args: [text] = ["-T", self.config.linker_script, "-nostdlib", "--entry={self.config.entry_point}", "--gc-sections"]

        # Add all object files
        for obj_file in object_files:
            args.push(obj_file)

        # Output file
        args.push("-o")
        args.push(elf_file)

        val (stdout, stderr, exit_code) = process_run("ld.lld", args)

        if exit_code == 0:
            BuildResult(success: true, exit_code: 0, stdout: elf_file, stderr: stderr, duration_ms: 0)
        else:
            BuildResult(success: false, exit_code: exit_code, stdout: stdout, stderr: "Linking failed: {stderr}", duration_ms: 0)

    fn target_clang_args() -> [text]:
        match self.config.target:
            case BaremetalTarget.Arm:
                ["--target=armv7m-none-eabi", "-mcpu=cortex-m4", "-mthumb"]
            case BaremetalTarget.X86_64:
                ["--target=x86_64-unknown-none-elf"]
            case BaremetalTarget.Riscv:
                ["--target=riscv64-unknown-elf", "-march=rv64gc", "-mabi=lp64d"]
            case BaremetalTarget.Riscv32:
                ["--target=riscv32-unknown-elf", "-march=rv32imc", "-mabi=ilp32"]
            case BaremetalTarget.Stm32h7:
                ["--target=armv7em-none-eabihf", "-mcpu=cortex-m7", "-mthumb", "-mfpu=fpv5-sp-d16", "-mfloat-abi=hard"]
            case BaremetalTarget.Stm32wb:
                ["--target=armv7m-none-eabi", "-mcpu=cortex-m4", "-mthumb"]

    fn llc_args(ir_file: text, obj_file: text) -> [text]:
        var args = ["--filetype=obj", "--relocation-model=static", "-mtriple", self.config.target_triple(), ir_file, "-o", obj_file]
        match self.config.target:
            case BaremetalTarget.Arm:
                args.push("-mcpu=cortex-m4")
                args.push("-mattr=+thumb2")
            case BaremetalTarget.Riscv:
                args.push("-march=riscv64")
                args.push("-mattr=+m,+a,+f,+d,+c")
            case BaremetalTarget.Riscv32:
                args.push("-march=riscv32")
                args.push("-mattr=+m,+c")
            case BaremetalTarget.Stm32h7:
                args.push("-mcpu=cortex-m7")
                args.push("-mattr=+thumb2,+fp-armv8d16")
            case BaremetalTarget.Stm32wb:
                args.push("-mcpu=cortex-m4")
                args.push("-mattr=+thumb2")
            case _: ()
        args

# QEMU test runner
class QemuRunner:
    config: BaremetalConfig
    timeout_ms: i64

impl QemuRunner:
    static fn new(config: BaremetalConfig, timeout_ms: i64) -> QemuRunner:
        QemuRunner(config: config, timeout_ms: timeout_ms)

    # Get QEMU executable for target architecture
    fn qemu_executable() -> text:
        match self.config.target:
            case BaremetalTarget.Arm: "qemu-system-arm"
            case BaremetalTarget.X86_64: "qemu-system-x86_64"
            case BaremetalTarget.Riscv: "qemu-system-riscv64"
            case BaremetalTarget.Riscv32: "qemu-system-riscv32"
            case BaremetalTarget.Stm32h7: "qemu-system-arm"
            case BaremetalTarget.Stm32wb: "qemu-system-arm"

    # Build QEMU command line arguments
    fn build_args(kernel_path: text) -> [text]:
        var args: [text] = []

        match self.config.target:
            case BaremetalTarget.Arm:
                args = ["-M", "versatilepb", "-nographic", "-serial", "stdio", "-kernel", kernel_path]
            case BaremetalTarget.X86_64:
                args = ["-kernel", kernel_path, "-serial", "stdio", "-display", "none", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"]
            case BaremetalTarget.Riscv:
                args = ["-M", "virt", "-bios", "none", "-nographic", "-serial", "stdio", "-kernel", kernel_path]
            case BaremetalTarget.Riscv32:
                args = ["-M", "virt", "-bios", "none", "-nographic", "-semihosting-config", "enable=on,target=native", "-kernel", kernel_path]
            case BaremetalTarget.Stm32h7:
                args = ["-M", "netduinoplus2", "-nographic", "-semihosting-config", "enable=on,target=native", "-kernel", kernel_path]
            case BaremetalTarget.Stm32wb:
                args = ["-M", "netduinoplus2", "-nographic", "-semihosting-config", "enable=on,target=native", "-kernel", kernel_path]

        args

    # Run kernel in QEMU and capture output
    fn run(kernel_path: text) -> TestResult:
        val qemu = self.qemu_executable()
        val args = self.build_args(kernel_path)

        val start_time = current_time_ms()
        val (stdout, stderr, exit_code) = process_run(qemu, args)
        val end_time = current_time_ms()

        # Check if execution took too long
        val duration_ms = end_time - start_time
        if duration_ms > self.timeout_ms:
            return TestResult(
                success: false,
                exit_code: -1,
                stdout: stdout,
                stderr: "QEMU execution exceeded timeout ({duration_ms}ms > {self.timeout_ms}ms)",
                tests_run: 0,
                tests_passed: 0,
                tests_failed: 0
            )

        # Parse test results from serial output
        parse_test_output(stdout, exit_code)

# Parse bare-metal test output from serial
# Expected format (SSpec-compatible):
#   [TEST START]
#   [PASS] test_name
#   [FAIL] test_name: error message
#   [TEST END] passed=N failed=M
fn parse_test_output(output: text, exit_code: i64) -> TestResult:
    var tests_run: i64 = 0
    var tests_passed: i64 = 0
    var tests_failed: i64 = 0

    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("[PASS]"):
            tests_run = tests_run + 1
            tests_passed = tests_passed + 1
        elif trimmed.starts_with("[FAIL]"):
            tests_run = tests_run + 1
            tests_failed = tests_failed + 1
        elif trimmed.starts_with("[TEST END]"):
            # Parse final counts if provided
            val parts = trimmed.split(" ")
            for part in parts:
                if part.starts_with("passed="):
                    val num_str = part[7:]
                    val parsed = int(num_str)
                    tests_passed = parsed
                elif part.starts_with("failed="):
                    val num_str = part[7:]
                    val parsed = int(num_str)
                    tests_failed = parsed
            tests_run = tests_passed + tests_failed

    # QEMU exit code handling:
    # isa-debug-exit returns (value << 1) | 1
    # So exit code 0 becomes 1, exit code 1 becomes 3
    var adjusted_exit = 0
    if exit_code > 0:
        adjusted_exit = (exit_code - 1) / 2

    TestResult(
        success: tests_failed == 0 and adjusted_exit == 0,
        exit_code: adjusted_exit,
        stdout: output,
        stderr: "",
        tests_run: tests_run,
        tests_passed: tests_passed,
        tests_failed: tests_failed
    )
