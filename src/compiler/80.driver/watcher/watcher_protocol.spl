# Watcher Protocol — File-based request/response for watcher IPC
#
# Delegates to daemon_sdk.protocol for core IPC, converting between
# WatcherRequest and DaemonRequest types.


use compiler.driver.watcher.watcher_types.{
    WatcherRequest, WatcherRequestKind, watcher_request_new,
    watcher_request_to_daemon, daemon_request_to_watcher
}
use std.daemon_sdk.protocol.{
    write_daemon_request, read_daemon_requests,
    clear_processed_requests, daemon_request_path_for
}
use std.daemon_sdk.types.{DaemonRequest}

extern fn rt_hash_text(s: text) -> i64

# ============================================================================
# Write Request
# ============================================================================

fn write_request(req: WatcherRequest, request_dir: text) -> text:
    val dreq = watcher_request_to_daemon(req)
    write_daemon_request(dreq, request_dir)

# ============================================================================
# Read Requests
# ============================================================================

fn read_requests(request_dir: text) -> [WatcherRequest]:
    val dreqs = read_daemon_requests(request_dir)
    var requests: [WatcherRequest] = []
    var i = 0
    while i < dreqs.len():
        requests.push(daemon_request_to_watcher(dreqs[i]))
        i = i + 1
    requests

# ============================================================================
# Cleanup
# ============================================================================

fn clear_processed_requests(request_dir: text, processed_paths: [text]):
    # Legacy API accepted source paths; now delegates with request IDs
    # For backward compat, just delete the files directly
    extern fn rt_file_delete(path: text) -> bool
    var i = 0
    while i < processed_paths.len():
        rt_file_delete(processed_paths[i])
        i = i + 1

# ============================================================================
# Path Helper
# ============================================================================

fn request_path_for(source_path: text, request_dir: text) -> text:
    val hash = rt_hash_text(source_path)
    val with_slashes = source_path.replace("/", "_")
    val base = with_slashes.replace(".spl", "")
    "{request_dir}/{base}_{hash}.req"
