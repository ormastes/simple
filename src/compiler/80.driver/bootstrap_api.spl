use lazy compiler.driver.{compiler_driver_create, compiler_driver_run_compile}
use compiler.common.driver_core_types.{CompileMode, CompileOptions, CompileResult, OutputFormat, driver_core_compile_options_default, compileoptions_normalize_mir_optimization}

pub fn aot_native_file_with_backend(path: text, output: text, backend: text, release: bool, opt_level: i64) -> CompileResult:
    var options = driver_core_compile_options_default()
    options.input_files = [path]
    options.bootstrap_input_count = 1
    options.bootstrap_input_0 = path
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = release
    options.opt_level = opt_level
    print "[bootstrap-api] fixed count {options.bootstrap_input_count} input0 {options.bootstrap_input_0}"
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

pub fn aot_native_project_with_backend(source_dirs: [text], entry: text, output: text, backend: text, strip: bool, release: bool, opt_level: i64) -> CompileResult:
    var options = driver_core_compile_options_default()
    val inputs: [text] = source_dirs + [entry]
    options.input_files = inputs
    options.bootstrap_input_count = inputs.len()
    if inputs.len() > 0:
        options.bootstrap_input_0 = inputs[0]
    if inputs.len() > 1:
        options.bootstrap_input_1 = inputs[1]
    if inputs.len() > 2:
        options.bootstrap_input_2 = inputs[2]
    if inputs.len() > 3:
        options.bootstrap_input_3 = inputs[3]
    if inputs.len() > 4:
        options.bootstrap_input_4 = inputs[4]
    if inputs.len() > 5:
        options.bootstrap_input_5 = inputs[5]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = release
    options.opt_level = opt_level
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

pub fn aot_native_project_with_backend_fixed(
    source_0: text,
    source_1: text,
    source_2: text,
    source_3: text,
    source_4: text,
    source_count: i64,
    entry: text,
    output: text,
    backend: text,
    strip: bool,
    release: bool,
    opt_level: i64
) -> CompileResult:
    var options = driver_core_compile_options_default()
    if source_count <= 0:
        options.input_files = [entry]
    elif source_count == 1:
        options.input_files = [source_0, entry]
    elif source_count == 2:
        options.input_files = [source_0, source_1, entry]
    elif source_count == 3:
        options.input_files = [source_0, source_1, source_2, entry]
    elif source_count == 4:
        options.input_files = [source_0, source_1, source_2, source_3, entry]
    else:
        options.input_files = [source_0, source_1, source_2, source_3, source_4, entry]
    options.bootstrap_input_count = source_count + 1
    if source_count > 0:
        options.bootstrap_input_0 = source_0
    if source_count > 1:
        options.bootstrap_input_1 = source_1
    if source_count > 2:
        options.bootstrap_input_2 = source_2
    if source_count > 3:
        options.bootstrap_input_3 = source_3
    if source_count > 4:
        options.bootstrap_input_4 = source_4
    if source_count == 0:
        options.bootstrap_input_0 = entry
    elif source_count == 1:
        options.bootstrap_input_1 = entry
    elif source_count == 2:
        options.bootstrap_input_2 = entry
    elif source_count == 3:
        options.bootstrap_input_3 = entry
    elif source_count == 4:
        options.bootstrap_input_4 = entry
    else:
        options.bootstrap_input_5 = entry
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = release
    options.opt_level = opt_level
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)
