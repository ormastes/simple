# Parallel Build Orchestration
#
# Dependency-aware parallel compilation using work queues.
# Respects module dependency order while maximizing parallelism.
# Uses process-based parallelism (rt_process_spawn_async) to avoid
# thread-safety issues with global compiler state.

extern fn spl_thread_cpu_count() -> i64
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_thread_sleep(millis: i64)

# ============================================================================
# Configuration
# ============================================================================

struct ParallelBuildConfig:
    num_threads: i64            # 0 = use all available CPUs
    parallel_threshold: i64     # Min modules to enable parallelism
    deterministic: bool         # Sort inputs for reproducible builds
    verbose: bool

impl ParallelBuildConfig:
    static fn default() -> ParallelBuildConfig:
        ParallelBuildConfig(num_threads: 0, parallel_threshold: 4,
                            deterministic: true, verbose: false)

    static fn single_threaded() -> ParallelBuildConfig:
        ParallelBuildConfig(num_threads: 1, parallel_threshold: 999,
                            deterministic: true, verbose: false)

    fn effective_threads() -> i64:
        """Resolve num_threads: 0 means auto-detect from CPU count, capped at 8."""
        if self.num_threads > 0:
            return self.num_threads
        val cpus = spl_thread_cpu_count()
        if cpus < 1:
            return 4
        if cpus > 8:
            return 8
        cpus

# ============================================================================
# Build Units and Dependency Graph
# ============================================================================

struct BuildUnit:
    """A unit of compilation (usually one source file)."""
    id: i64
    path: text
    dependencies: [i64]     # IDs of units this depends on
    dependents: [i64]       # IDs of units that depend on this
    status: BuildUnitStatus
    output: text?           # Output artifact path

enum BuildUnitStatus:
    Pending
    Ready           # All deps satisfied
    InProgress
    Completed
    Failed(text)

class BuildGraph:
    """Dependency graph for build units."""
    units: {i64: BuildUnit}
    next_id: i64
    ready_queue: [i64]

impl BuildGraph:
    static fn empty() -> BuildGraph:
        BuildGraph(units: {}, next_id: 0, ready_queue: [])

    me add_unit(path: text, dependencies: [i64]) -> i64:
        """Add a build unit, return its ID."""
        val id = self.next_id
        self.next_id = self.next_id + 1
        val unit = BuildUnit(id: id, path: path, dependencies: dependencies,
                             dependents: [], status: BuildUnitStatus.Pending,
                             output: nil)
        self.units[id] = unit

        # Update dependents
        for dep_id in dependencies:
            if self.units.has(dep_id):
                var dep = self.units[dep_id]
                self.units[dep_id] = BuildUnit(
                    id: dep.id, path: dep.path,
                    dependencies: dep.dependencies,
                    dependents: dep.dependents.push(id),
                    status: dep.status, output: dep.output)

        # Zero-dependency units are immediately ready
        if dependencies.len() == 0:
            self.ready_queue = self.ready_queue.push(id)

        id

    me ready_units() -> [BuildUnit]:
        """Drain the ready queue and return units ready to build."""
        var ready: [BuildUnit] = []
        for id in self.ready_queue:
            if self.units.has(id):
                val unit = self.units[id]
                match unit.status:
                    case Pending:
                        ready = ready.push(unit)
                    case _: ()
        self.ready_queue = []
        ready

    me mark_ready(id: i64):
        if self.units.has(id):
            val u = self.units[id]
            self.units[id] = BuildUnit(id: u.id, path: u.path,
                dependencies: u.dependencies, dependents: u.dependents,
                status: BuildUnitStatus.Ready, output: u.output)

    me mark_in_progress(id: i64):
        if self.units.has(id):
            val u = self.units[id]
            self.units[id] = BuildUnit(id: u.id, path: u.path,
                dependencies: u.dependencies, dependents: u.dependents,
                status: BuildUnitStatus.InProgress, output: u.output)

    me mark_completed(id: i64, output: text?):
        if self.units.has(id):
            val u = self.units[id]
            self.units[id] = BuildUnit(id: u.id, path: u.path,
                dependencies: u.dependencies, dependents: u.dependents,
                status: BuildUnitStatus.Completed, output: output)

            # Check reverse-dependencies: enqueue newly ready units
            for dep_id in u.dependents:
                if not self.units.has(dep_id):
                    continue
                val dep_unit = self.units[dep_id]
                match dep_unit.status:
                    case Pending:
                        var all_done = true
                        for req_id in dep_unit.dependencies:
                            if self.units.has(req_id):
                                match self.units[req_id].status:
                                    case Completed: ()
                                    case _: all_done = false
                            # Missing dep treated as satisfied
                        if all_done:
                            self.ready_queue = self.ready_queue.push(dep_id)
                    case _: ()

    me mark_failed(id: i64, error: text):
        if self.units.has(id):
            val u = self.units[id]
            self.units[id] = BuildUnit(id: u.id, path: u.path,
                dependencies: u.dependencies, dependents: u.dependents,
                status: BuildUnitStatus.Failed(error), output: u.output)

    fn is_complete() -> bool:
        """All units completed or failed."""
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for id in self.units.keys():
            val unit = self.units[id]
            match unit.status:
                case Completed | Failed(_): ()
                case _: return false
        true

    fn has_failures() -> bool:
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for id in self.units.keys():
            val unit = self.units[id]
            match unit.status:
                case Failed(_): return true
                case _: ()
        false

    fn topological_order() -> [i64]:
        """Get units in dependency order (for deterministic builds)."""
        var order: [i64] = []
        var visited: {i64: bool} = {}

        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        # Iterative DFS to avoid nested function (native backend limitation)
        for id in self.units.keys():
            if visited.has(id):
                continue
            var stack: [(i64, bool)] = [(id, false)]
            while stack.?:
                val (node, expanded) = stack.pop().unwrap()
                if expanded:
                    order = order.push(node)
                    continue
                if visited.has(node):
                    continue
                visited[node] = true
                stack = stack.push((node, true))
                if self.units.has(node):
                    for dep in self.units[node].dependencies:
                        if not visited.has(dep):
                            stack = stack.push((dep, false))

        order

# ============================================================================
# Build Statistics
# ============================================================================

struct BuildStats:
    total_units: i64
    completed: i64
    failed: i64
    skipped: i64
    parallel_batches: i64

impl BuildStats:
    static fn empty() -> BuildStats:
        BuildStats(total_units: 0, completed: 0, failed: 0,
                   skipped: 0, parallel_batches: 0)

# ============================================================================
# Build Result
# ============================================================================

struct BuildResult:
    success: bool
    stats: BuildStats
    errors: [(text, text)]      # (file, error_message)
    outputs: [text]             # Generated artifact paths

# ============================================================================
# Parallel Builder
# ============================================================================

class ParallelBuilder:
    """Orchestrates parallel compilation respecting dependencies."""
    config: ParallelBuildConfig
    graph: BuildGraph
    stats: BuildStats

impl ParallelBuilder:
    static fn create(config: ParallelBuildConfig) -> ParallelBuilder:
        ParallelBuilder(config: config, graph: BuildGraph.empty(),
                        stats: BuildStats.empty())

    fn wait_for_finished_process(in_flight_pid: {i64: i64}) -> (i64, i64):
        """Wait for any in-flight process to finish using bounded polling.

        Returns: (pid, exit_code), or (-1, -1) if no process is available.
        """
        if in_flight_pid.len() == 0:
            return (-1, -1)

        var poll_iteration = 0
        while true:
            # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
            for pid in in_flight_pid.keys():
                if not rt_process_is_running(pid):
                    val exit_code = rt_process_wait(pid, 1)
                    if exit_code != -2:
                        return (pid, exit_code)

            var sleep_ms = 10
            if poll_iteration >= 50:
                sleep_ms = 100
            elif poll_iteration >= 10:
                sleep_ms = 25

            rt_thread_sleep(sleep_ms)
            poll_iteration = poll_iteration + 1

    me add_unit(path: text, dependencies: [i64]) -> i64:
        self.graph.add_unit(path, dependencies)

    me build(compile_fn: any) -> BuildResult:
        """Execute the build using the provided compile function.

        In deterministic mode, processes units in topological order.
        Otherwise, processes ready units in parallel batches.
        """
        val total = self.graph.units.len()
        self.stats = BuildStats(total_units: total, completed: 0, failed: 0,
                                skipped: 0, parallel_batches: 0)
        var errors: [(text, text)] = []
        var outputs: [text] = []

        if self.config.deterministic or total < self.config.parallel_threshold:
            # Sequential build in topological order
            val order = self.graph.topological_order()
            for id in order:
                if not self.graph.units.has(id):
                    continue
                val unit = self.graph.units[id]

                # Skip if any dependency failed
                var dep_failed = false
                for dep_id in unit.dependencies:
                    if self.graph.units.has(dep_id):
                        match self.graph.units[dep_id].status:
                            case Failed(_): dep_failed = true
                            case _: ()
                if dep_failed:
                    self.graph.mark_failed(id, "Dependency failed")
                    self.stats = BuildStats(total_units: self.stats.total_units,
                        completed: self.stats.completed,
                        failed: self.stats.failed + 1,
                        skipped: self.stats.skipped,
                        parallel_batches: self.stats.parallel_batches)
                    continue

                self.graph.mark_in_progress(id)
                val result = compile_fn(unit.path)
                match result:
                    case Ok(output):
                        self.graph.mark_completed(id, Some(output))
                        outputs = outputs.push(output)
                        self.stats = BuildStats(total_units: self.stats.total_units,
                            completed: self.stats.completed + 1,
                            failed: self.stats.failed,
                            skipped: self.stats.skipped,
                            parallel_batches: self.stats.parallel_batches)
                    case Err(msg):
                        self.graph.mark_failed(id, msg)
                        errors = errors.push((unit.path, msg))
                        self.stats = BuildStats(total_units: self.stats.total_units,
                            completed: self.stats.completed,
                            failed: self.stats.failed + 1,
                            skipped: self.stats.skipped,
                            parallel_batches: self.stats.parallel_batches)
        else:
            # Parallel build: batch-concurrent execution
            val max_workers = self.config.effective_threads()
            if self.config.verbose:
                print "[PARALLEL] batch-concurrent mode, {max_workers} workers"

            while not self.graph.is_complete():
                val ready = self.graph.ready_units()
                if ready.len() == 0:
                    break

                self.stats = BuildStats(total_units: self.stats.total_units,
                    completed: self.stats.completed, failed: self.stats.failed,
                    skipped: self.stats.skipped,
                    parallel_batches: self.stats.parallel_batches + 1)

                # Process batch in chunks of max_workers
                var batch_idx: i64 = 0
                while batch_idx < ready.len():
                    var chunk_end = batch_idx + max_workers
                    if chunk_end > ready.len():
                        chunk_end = ready.len()

                    # Mark chunk units in-progress
                    var chunk_idx = batch_idx
                    while chunk_idx < chunk_end:
                        self.graph.mark_in_progress(ready[chunk_idx].id)
                        chunk_idx = chunk_idx + 1

                    # Execute chunk: compile each unit
                    chunk_idx = batch_idx
                    while chunk_idx < chunk_end:
                        val unit = ready[chunk_idx]
                        val result = compile_fn(unit.path)
                        match result:
                            case Ok(output):
                                self.graph.mark_completed(unit.id, Some(output))
                                outputs = outputs.push(output)
                                self.stats = BuildStats(total_units: self.stats.total_units,
                                    completed: self.stats.completed + 1,
                                    failed: self.stats.failed,
                                    skipped: self.stats.skipped,
                                    parallel_batches: self.stats.parallel_batches)
                            case Err(msg):
                                self.graph.mark_failed(unit.id, msg)
                                errors = errors.push((unit.path, msg))
                                self.stats = BuildStats(total_units: self.stats.total_units,
                                    completed: self.stats.completed,
                                    failed: self.stats.failed + 1,
                                    skipped: self.stats.skipped,
                                    parallel_batches: self.stats.parallel_batches)
                        chunk_idx = chunk_idx + 1

                    batch_idx = chunk_end

        BuildResult(success: not self.graph.has_failures(),
                    stats: self.stats, errors: errors, outputs: outputs)

    me build_parallel(spawn_fn: any, collect_fn: any) -> BuildResult:
        """Execute the build using process-based parallelism.

        spawn_fn(path: text) -> i64:
            Launches a subprocess to compile the given module path.
            Returns a process ID (pid), or -1 on spawn failure.

        collect_fn(exit_code: i64, path: text) -> Result<text, text>:
            Called after the subprocess finishes. Receives exit code and
            module path. Returns Ok(output_path) or Err(error_message).
            The process is already reaped; read output files here.

        Units are spawned up to max_workers concurrently. When a process
        finishes, newly ready units are spawned immediately, keeping
        the worker pool saturated.
        """
        val total = self.graph.units.len()
        val max_workers = self.config.effective_threads()
        self.stats = BuildStats(total_units: total, completed: 0, failed: 0,
                                skipped: 0, parallel_batches: 0)
        var errors: [(text, text)] = []
        var outputs: [text] = []

        if self.config.verbose:
            print "[PARALLEL] process-parallel mode, {max_workers} workers, {total} units"

        # pid -> unit_id mapping for in-flight processes
        var in_flight_pid: {i64: i64} = {}
        var in_flight_path: {i64: text} = {}

        while not self.graph.is_complete():
            # Fill worker slots with ready units
            val ready = self.graph.ready_units()
            var ready_idx = 0
            while in_flight_pid.len() < max_workers and ready_idx < ready.len():
                val unit = ready[ready_idx]
                ready_idx = ready_idx + 1

                # Check dependency failures
                var dep_failed = false
                for dep_id in unit.dependencies:
                    if self.graph.units.has(dep_id):
                        match self.graph.units[dep_id].status:
                            case Failed(_): dep_failed = true
                            case _: ()
                if dep_failed:
                    self.graph.mark_failed(unit.id, "Dependency failed")
                    self.stats = BuildStats(total_units: self.stats.total_units,
                        completed: self.stats.completed,
                        failed: self.stats.failed + 1,
                        skipped: self.stats.skipped,
                        parallel_batches: self.stats.parallel_batches)
                    continue

                self.graph.mark_in_progress(unit.id)
                val pid = spawn_fn(unit.path)
                if pid < 0:
                    self.graph.mark_failed(unit.id, "Failed to spawn compilation process")
                    errors = errors.push((unit.path, "Failed to spawn compilation process"))
                    self.stats = BuildStats(total_units: self.stats.total_units,
                        completed: self.stats.completed,
                        failed: self.stats.failed + 1,
                        skipped: self.stats.skipped,
                        parallel_batches: self.stats.parallel_batches)
                    continue

                in_flight_pid[pid] = unit.id
                in_flight_path[pid] = unit.path
                if self.config.verbose:
                    print "[PARALLEL] spawned pid={pid} for {unit.path}"

            # If nothing in-flight and nothing ready, we're stuck
            if in_flight_pid.len() == 0:
                break

            # Wait for one process to finish before recomputing ready work.
            val (finished_pid, finished_exit_code) = self.wait_for_finished_process(in_flight_pid)
            if finished_pid < 0:
                break

            # Collect result from finished process
            val unit_id = in_flight_pid[finished_pid]
            val unit_path = in_flight_path[finished_pid]
            in_flight_pid.remove(finished_pid)
            in_flight_path.remove(finished_pid)

            val result = collect_fn(finished_exit_code, unit_path)
            match result:
                case Ok(output):
                    self.graph.mark_completed(unit_id, Some(output))
                    outputs = outputs.push(output)
                    self.stats = BuildStats(total_units: self.stats.total_units,
                        completed: self.stats.completed + 1,
                        failed: self.stats.failed,
                        skipped: self.stats.skipped,
                        parallel_batches: self.stats.parallel_batches)
                    if self.config.verbose:
                        print "[PARALLEL] completed {unit_path}"
                case Err(msg):
                    self.graph.mark_failed(unit_id, msg)
                    errors = errors.push((unit_path, msg))
                    self.stats = BuildStats(total_units: self.stats.total_units,
                        completed: self.stats.completed,
                        failed: self.stats.failed + 1,
                        skipped: self.stats.skipped,
                        parallel_batches: self.stats.parallel_batches)
                    if self.config.verbose:
                        print "[PARALLEL] failed {unit_path}: {msg}"

            self.stats = BuildStats(total_units: self.stats.total_units,
                completed: self.stats.completed, failed: self.stats.failed,
                skipped: self.stats.skipped,
                parallel_batches: self.stats.parallel_batches + 1)

        # Drain remaining in-flight processes on early exit
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for pid in in_flight_pid.keys():
            val unit_id = in_flight_pid[pid]
            val unit_path = in_flight_path[pid]
            rt_process_kill(pid)
            self.graph.mark_failed(unit_id, "Build cancelled")
            errors = errors.push((unit_path, "Build cancelled"))

        BuildResult(success: not self.graph.has_failures(),
                    stats: self.stats, errors: errors, outputs: outputs)
