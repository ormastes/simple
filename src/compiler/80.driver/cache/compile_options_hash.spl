# CompileOptionsHash — Backend + compile options hash for SMF validation
#
# Stored in SMF header reserved[0..16] bytes (backward-compatible).
# Old readers ignore reserved bytes; new readers validate backend match.
#
# Hash includes: backend, opt_level, target_arch, debug_info, gc_off, release
# Quick hash compare (O(1)) → if match, cross-check fields for collision detection.


extern fn rt_hash_text(s: text) -> i64

# ============================================================================
# Backend Kind Constants
# ============================================================================

val BACKEND_AUTO: u8 = 0
val BACKEND_LLVM: u8 = 1
val BACKEND_CRANELIFT: u8 = 2
val BACKEND_C: u8 = 3
val BACKEND_WASM: u8 = 4
val BACKEND_VHDL: u8 = 5
val BACKEND_NATIVE: u8 = 6

# ============================================================================
# CompileOptionsHash
# ============================================================================

struct CompileOptionsHash:
    hash: i64
    backend_kind: u8
    opt_level: u8
    target_arch: u8
    flags: u8

impl CompileOptionsHash:
    fn to_text() -> text:
        "CompileOptionsHash(hash: {self.hash}, backend: {self.backend_kind}, opt: {self.opt_level}, flags: {self.flags})"

# ============================================================================
# Factory Functions
# ============================================================================

fn compile_options_hash_zero() -> CompileOptionsHash:
    CompileOptionsHash(hash: 0, backend_kind: 0, opt_level: 0, target_arch: 0, flags: 0)

fn compile_options_hash_is_zero(h: CompileOptionsHash) -> bool:
    h.hash == 0 and h.backend_kind == 0 and h.opt_level == 0 and h.target_arch == 0 and h.flags == 0

# ============================================================================
# Compute from CompileOptions fields
# ============================================================================

fn compile_options_hash_compute(backend: text, opt_level: i64, release: bool, debug_info: bool, gc_off: bool) -> CompileOptionsHash:
    # Build canonical string for hashing
    val bk = backend_text_to_kind(backend)
    val opt = if opt_level < 0: 0 else: if opt_level > 3: 3 else: opt_level
    val rel_str = if release: "1" else: "0"
    val dbg_str = if debug_info: "1" else: "0"
    val gc_str = if gc_off: "1" else: "0"

    val canonical = "backend={backend};opt={opt};release={rel_str};debug={dbg_str};gc={gc_str}"
    val hash = rt_hash_text(canonical)

    # Build flags bitfield
    var flags: u8 = 0
    if debug_info:
        flags = flags | 0x01
    if gc_off:
        flags = flags | 0x02
    if release:
        flags = flags | 0x04

    CompileOptionsHash(
        hash: hash,
        backend_kind: bk,
        opt_level: opt as u8,
        target_arch: 0,
        flags: flags
    )

# ============================================================================
# Validation
# ============================================================================

fn compile_options_hash_validate(stored: CompileOptionsHash, current: CompileOptionsHash) -> CacheCheckResult:
    use compiler.driver.cache.cache_types.{CacheCheckResult, cache_check_result_fresh, cache_check_result_stale, CACHE_FRESH}

    # Zero hash means old SMF without options — always stale
    if compile_options_hash_is_zero(stored):
        return cache_check_result_stale(current.hash, 0, "SMF missing compile options hash (pre-validation era)")

    # Quick hash compare
    if stored.hash == current.hash:
        # Cross-check individual fields for collision detection
        if stored.backend_kind != current.backend_kind:
            return cache_check_result_stale(current.hash, stored.hash, "hash collision: backend mismatch ({stored.backend_kind} vs {current.backend_kind})")
        if stored.opt_level != current.opt_level:
            return cache_check_result_stale(current.hash, stored.hash, "hash collision: opt_level mismatch ({stored.opt_level} vs {current.opt_level})")
        if stored.flags != current.flags:
            return cache_check_result_stale(current.hash, stored.hash, "hash collision: flags mismatch ({stored.flags} vs {current.flags})")
        return cache_check_result_fresh(current.hash)

    # Hash mismatch — determine specific reason
    if stored.backend_kind != current.backend_kind:
        return cache_check_result_stale(current.hash, stored.hash, "backend changed ({backend_kind_to_text(stored.backend_kind)} -> {backend_kind_to_text(current.backend_kind)})")
    if stored.opt_level != current.opt_level:
        return cache_check_result_stale(current.hash, stored.hash, "opt_level changed ({stored.opt_level} -> {current.opt_level})")
    if stored.flags != current.flags:
        return cache_check_result_stale(current.hash, stored.hash, "compile flags changed ({stored.flags} -> {current.flags})")
    cache_check_result_stale(current.hash, stored.hash, "compile options changed")

# ============================================================================
# Serialization (16 bytes: 8 hash + 1 backend + 1 opt + 1 arch + 1 flags + 4 reserved)
# ============================================================================

fn compile_options_hash_to_bytes(h: CompileOptionsHash) -> [u8]:
    var bytes: [u8] = []
    # hash as 8 bytes (little-endian)
    bytes.push((h.hash & 0xFF) as u8)
    bytes.push(((h.hash >> 8) & 0xFF) as u8)
    bytes.push(((h.hash >> 16) & 0xFF) as u8)
    bytes.push(((h.hash >> 24) & 0xFF) as u8)
    bytes.push(((h.hash >> 32) & 0xFF) as u8)
    bytes.push(((h.hash >> 40) & 0xFF) as u8)
    bytes.push(((h.hash >> 48) & 0xFF) as u8)
    bytes.push(((h.hash >> 56) & 0xFF) as u8)
    # fields
    bytes.push(h.backend_kind)
    bytes.push(h.opt_level)
    bytes.push(h.target_arch)
    bytes.push(h.flags)
    # 4 bytes reserved padding
    bytes.push(0)
    bytes.push(0)
    bytes.push(0)
    bytes.push(0)
    bytes

fn compile_options_hash_from_bytes(bytes: [u8]) -> CompileOptionsHash:
    if bytes.len() < 16:
        return compile_options_hash_zero()

    val b0 = bytes[0] as i64
    val b1 = bytes[1] as i64
    val b2 = bytes[2] as i64
    val b3 = bytes[3] as i64
    val b4 = bytes[4] as i64
    val b5 = bytes[5] as i64
    val b6 = bytes[6] as i64
    val b7 = bytes[7] as i64
    val hash = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)

    CompileOptionsHash(
        hash: hash,
        backend_kind: bytes[8],
        opt_level: bytes[9],
        target_arch: bytes[10],
        flags: bytes[11]
    )

# ============================================================================
# Helper Functions
# ============================================================================

fn backend_text_to_kind(backend: text) -> u8:
    match backend:
        case "auto": BACKEND_AUTO
        case "llvm": BACKEND_LLVM
        case "llvm-lib" | "llvmlib": BACKEND_LLVM
        case "cranelift": BACKEND_CRANELIFT
        case "c" | "cpp": BACKEND_C
        case "wasm": BACKEND_WASM
        case "vhdl": BACKEND_VHDL
        case "native": BACKEND_NATIVE
        case _: BACKEND_AUTO

fn backend_kind_to_text(kind: u8) -> text:
    match kind:
        case 0: "auto"
        case 1: "llvm"
        case 2: "cranelift"
        case 3: "c"
        case 4: "wasm"
        case 5: "vhdl"
        case 6: "native"
        case _: "unknown"
