#![allow(unnamed_duplicate_typed_args)]
use compiler.common.driver_core_types.{CompileMode, CompileResult}
use compiler.driver.driver_public_api.{interpret_file}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_env_get(name: text) -> text
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

fn compile_file(path: text) -> CompileResult:
    val simple_bin = _find_simple_binary()
    val default_output = _default_smf_output(path)
    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, ["compile", path])
    val combined = _clean_child_output(stdout, stderr)
    if exit_code == 0 and rt_file_exists(default_output):
        return CompileResult.Success(default_output)
    if exit_code == 0:
        return CompileResult.RuntimeError("compile reported success but did not create output: {default_output}")
    CompileResult.RuntimeError(combined)

fn compile_to_smf(path: text, output: text) -> Result<text, text>:
    val simple_bin = _find_simple_binary()
    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, ["compile", path, "-o", output])
    val combined = _clean_child_output(stdout, stderr)
    if exit_code == 0 and rt_file_exists(output):
        return Ok(output)
    if exit_code == 0:
        return Err("compile reported success but did not create output: {output}")
    Err(combined)

fn compile_files(paths: [text], mode: CompileMode) -> CompileResult:
    if paths.len() == 0:
        return CompileResult.RuntimeError("compile_files requires at least one input path")
    if paths.len() > 1:
        return CompileResult.RuntimeError("lightweight external compile_files only supports a single input path")

    val path = paths[0]
    match mode:
        case CompileMode.Interpret:
            interpret_file(path)
        case CompileMode.Jit:
            jit_file(path)
        case CompileMode.Aot:
            compile_file(path)
        case CompileMode.Check:
            check_file(path)
        case CompileMode.Sdn:
            parse_sdn_file(path)
        case CompileMode.SmfExec:
            CompileResult.RuntimeError("SmfExec mode is not supported by the lightweight external driver_api facade")
        case _:
            CompileResult.RuntimeError("unsupported compile mode for lightweight external facade")

fn jit_file(path: text) -> CompileResult:
    val simple_bin = _find_simple_binary()
    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, [path])
    val combined = _clean_child_output(stdout, stderr)
    if exit_code == 0:
        return CompileResult.Success(combined)
    CompileResult.RuntimeError(combined)

fn aot_file(path: text, output: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--native"])

fn aot_c_file(path: text, output: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--backend=c"])

fn aot_llvm_file(path: text, output: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--backend=llvm"])

fn aot_llvm_native_file(path: text, output: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--backend=llvm", "--native"])

fn aot_native_file_with_backend(path: text, output: text, backend: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--backend={backend}", "--native"])

fn aot_native_project_with_backend(source_dirs: [text], entry: text, output: text, backend: text, strip: bool) -> CompileResult:
    CompileResult.RuntimeError("lightweight external aot_native_project_with_backend is not supported; use the CLI directly for multi-source native builds")

fn aot_cuda_file(path: text, output: text) -> CompileResult:
    _run_compile_to_path(path, output, ["--backend=cuda"])

fn aot_vhdl_file(path: text, output: text) -> CompileResult:
    val fallback_result = _compile_simple_vhdl_subset(path, output)
    if fallback_result.is_success():
        return fallback_result
    val external_result = _run_compile_to_path(path, output, ["--backend=vhdl"])
    if external_result.is_success() and _file_contains_vhdl_design(output):
        return external_result
    external_result

fn check_file(path: text) -> CompileResult:
    val simple_bin = _find_simple_binary()
    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, ["lint", path])
    val combined = _clean_child_output(stdout, stderr)
    if exit_code == 0:
        return CompileResult.Success(combined)
    CompileResult.RuntimeError(combined)

fn parse_sdn_file(path: text) -> CompileResult:
    val content = rt_file_read_text(path) ?? ""
    if content.trim() == "":
        return CompileResult.RuntimeError("failed to read SDN file: {path}")
    CompileResult.Success(content)

fn _find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    if rt_file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if rt_file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if rt_file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if rt_file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if rt_file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    "bin/simple"

fn _clean_child_output(stdout: text, stderr: text) -> text:
    val combined = if stderr.trim() != "":
        stdout + "\n" + stderr
    else:
        stdout

    val lines = combined.split("\n")
    var kept: [text] = []
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line != "":
            kept = kept.push(line)
        i = i + 1
    kept.join("\n")

fn _default_smf_output(path: text) -> text:
    if path.ends_with(".spl"):
        return path.substring(0, path.len() - 4) + ".smf"
    path + ".smf"

fn _compile_simple_vhdl_subset(path: text, output: text) -> CompileResult:
    val source = rt_file_read_text(path) ?? ""
    val vhdl_result = _simple_vhdl_source_to_text(source)
    if vhdl_result.is_err():
        return CompileResult.RuntimeError(vhdl_result.unwrap_err())
    if rt_file_write_text(output, vhdl_result.unwrap()):
        CompileResult.Success(output)
    else:
        CompileResult.RuntimeError("failed to write VHDL output: {output}")

fn _file_contains_vhdl_design(path: text) -> bool:
    val content = rt_file_read_text(path) ?? ""
    val trimmed = content.trim()
    val has_design_unit = trimmed.starts_with("library ") or trimmed.starts_with("use ") or trimmed.starts_with("package ") or trimmed.starts_with("entity ") or trimmed.contains("\nentity ")
    has_design_unit and trimmed.contains("<=")

fn _simple_vhdl_source_to_text(source: text) -> Result<text, text>:
    val lines = source.split("\n")
    var header = ""
    var body_lines: [text] = []
    var i = 0
    while i < lines.len():
        val raw_line = lines[i]
        val line = raw_line.trim()
        if line != "":
            if header == "":
                header = line
            else:
                body_lines = body_lines.push(raw_line)
        i = i + 1
    if not header.starts_with("fn "):
        return Err("VHDL subset fallback requires a single function declaration")
    if body_lines.len() == 0:
        return Err("VHDL subset fallback requires a single expression body")

    val after_fn = header.substring(3).trim()
    val name_end_opt = after_fn.find("(")
    val params_end_opt = after_fn.find(")")
    val ret_start_opt = after_fn.find("->")
    if not name_end_opt.? or not params_end_opt.? or not ret_start_opt.?:
        return Err("VHDL subset fallback could not parse function signature")
    val name_end = name_end_opt.unwrap()
    val params_end = params_end_opt.unwrap()
    val ret_start = ret_start_opt.unwrap()

    val fn_name = after_fn.substring(0, name_end).trim()
    val params_text = after_fn.substring(name_end + 1, params_end).trim()
    var return_type = after_fn.substring(ret_start + 2, after_fn.len()).trim()
    if return_type.ends_with(":"):
        return_type = return_type.substring(0, return_type.len() - 1).trim()
    val return_vhdl_type = _simple_type_to_vhdl(return_type)
    if return_vhdl_type == "":
        return Err("VHDL subset fallback unsupported return type: {return_type}")

    var param_names: [text] = []
    var param_types: [text] = []
    var ports: [text] = []
    if params_text != "":
        val parts = params_text.split(",")
        for part in parts:
            val param = part.trim()
            val type_sep_opt = param.find(":")
            if not type_sep_opt.?:
                return Err("VHDL subset fallback could not parse parameter: {param}")
            val type_sep = type_sep_opt.unwrap()
            val param_name = param.substring(0, type_sep).trim()
            val param_type = param.substring(type_sep + 1, param.len()).trim()
            val vhdl_type = _simple_type_to_vhdl(param_type)
            if vhdl_type == "":
                return Err("VHDL subset fallback unsupported parameter type: {param_type}")
            param_names = param_names.push(param_name)
            param_types = param_types.push(param_type)
            ports = ports.push("        {param_name} : in {vhdl_type};")
    ports = ports.push("        result_out : out {return_vhdl_type}")

    val expr_result = _simple_body_to_vhdl(body_lines, return_type, param_names, param_types)
    if expr_result.is_err():
        return Err(expr_result.unwrap_err())
    val expr = expr_result.unwrap()

    var out = "library ieee;\n"
    out = out + "use ieee.std_logic_1164.all;\n"
    out = out + "use ieee.numeric_std.all;\n\n"
    out = out + "entity {fn_name} is\n"
    out = out + "    port (\n"
    out = out + ports.join("\n") + "\n"
    out = out + "    );\n"
    out = out + "end entity {fn_name};\n\n"
    out = out + "architecture rtl of {fn_name} is\n"
    out = out + "begin\n"
    out = out + "    result_out <= {expr};\n"
    out = out + "end architecture rtl;\n"
    Ok(out)

fn _simple_body_to_vhdl(body_lines: [text], result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    var trimmed_lines: [text] = []
    var i = 0
    while i < body_lines.len():
        val trimmed = body_lines[i].trim()
        if trimmed != "":
            trimmed_lines = trimmed_lines.push(trimmed)
        i = i + 1

    if trimmed_lines.len() == 0:
        return Err("VHDL subset fallback requires a non-empty body")

    if trimmed_lines.len() == 1:
        return _simple_expr_to_vhdl(_simple_strip_return(trimmed_lines[0]), result_type, param_names, param_types)

    val first = trimmed_lines[0]
    if first.starts_with("if "):
        return _simple_if_block_to_vhdl(trimmed_lines, result_type, param_names, param_types)

    if first.starts_with("return "):
        return _simple_expr_to_vhdl(first.substring(7).trim(), result_type, param_names, param_types)

    Err("VHDL subset fallback supports only a single expression or a simple if block")

fn _simple_if_block_to_vhdl(lines: [text], result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    val first = lines[0]
    if not first.starts_with("if "):
        return Err("VHDL subset fallback expected an if block")
    if not first.ends_with(":"):
        return Err("VHDL subset fallback if block must end with ':'")

    var else_index = -1
    var i = 1
    while i < lines.len():
        if lines[i] == "else:":
            else_index = i
            break
        i = i + 1
    if else_index < 0:
        return Err("VHDL subset fallback if block requires an else branch")

    val cond_text = first.substring(3, first.len() - 1).trim()
    val then_result = _simple_single_branch_expr(lines, 1, else_index, result_type, param_names, param_types)
    if then_result.is_err():
        return Err(then_result.unwrap_err())
    val else_result = _simple_single_branch_expr(lines, else_index + 1, lines.len(), result_type, param_names, param_types)
    if else_result.is_err():
        return Err(else_result.unwrap_err())
    val cond_result = _simple_expr_to_vhdl(cond_text, "bool", param_names, param_types)
    if cond_result.is_err():
        return Err(cond_result.unwrap_err())
    Ok("{then_result.unwrap()} when {cond_result.unwrap()} = '1' else {else_result.unwrap()}")

fn _simple_single_branch_expr(lines: [text], start_index: i64, end_index: i64, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    var branch_lines: [text] = []
    var i = start_index
    while i < end_index:
        val trimmed = lines[i].trim()
        if trimmed != "":
            branch_lines = branch_lines.push(trimmed)
        i = i + 1

    if branch_lines.len() != 1:
        return Err("VHDL subset fallback if branches must contain exactly one expression")

    return _simple_expr_to_vhdl(_simple_strip_return(branch_lines[0]), result_type, param_names, param_types)

fn _simple_strip_return(expr: text) -> text:
    if expr.starts_with("return "):
        return expr.substring(7, expr.len()).trim()
    expr

fn _simple_type_to_vhdl(type_name: text) -> text:
    match type_name:
        case "i8": "signed(7 downto 0)"
        case "i16": "signed(15 downto 0)"
        case "i32": "signed(31 downto 0)"
        case "i64": "signed(63 downto 0)"
        case "u8": "unsigned(7 downto 0)"
        case "u16": "unsigned(15 downto 0)"
        case "u32": "unsigned(31 downto 0)"
        case "u64": "unsigned(63 downto 0)"
        case "bool": "std_logic"
        case _: ""

fn _simple_expr_to_vhdl(expr: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    val trimmed = expr.trim()
    val inline_if_result = _simple_inline_if_to_vhdl(trimmed, result_type, param_names, param_types)
    if not inline_if_result.is_err():
        return inline_if_result
    val cast_result = _simple_cast_to_vhdl(trimmed, result_type, param_names, param_types)
    if not cast_result.is_err():
        return cast_result
    val comparison_result = _simple_comparison_to_vhdl(trimmed, param_names, param_types)
    if not comparison_result.is_err():
        return comparison_result
    val bool_logic_result = _simple_bool_logic_to_vhdl(trimmed, param_names, param_types)
    if not bool_logic_result.is_err():
        return bool_logic_result
    val unary_result = _simple_unary_to_vhdl(trimmed, result_type, param_names, param_types)
    if not unary_result.is_err():
        return unary_result
    if trimmed.contains(" + "):
        val parts = trimmed.split(" + ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "+", result_type, param_names, param_types)
    if trimmed.contains(" - "):
        val parts = trimmed.split(" - ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "-", result_type, param_names, param_types)
    if trimmed.contains(" * "):
        val parts = trimmed.split(" * ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "*", result_type, param_names, param_types)
    if trimmed.contains(" / "):
        val parts = trimmed.split(" / ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "/", result_type, param_names, param_types)
    if trimmed.contains(" & "):
        val parts = trimmed.split(" & ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "and", result_type, param_names, param_types)
    if trimmed.contains(" | "):
        val parts = trimmed.split(" | ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "or", result_type, param_names, param_types)
    if trimmed.contains(" ^ "):
        val parts = trimmed.split(" ^ ")
        if parts.len() == 2:
            return _simple_binary_arith_to_vhdl(parts[0].trim(), parts[1].trim(), "xor", result_type, param_names, param_types)
    if trimmed.contains(" << "):
        val parts = trimmed.split(" << ")
        if parts.len() == 2:
            return _simple_shift_to_vhdl(parts[0].trim(), parts[1].trim(), "shift_left", result_type, param_names, param_types)
    if trimmed.contains(" >> "):
        val parts = trimmed.split(" >> ")
        if parts.len() == 2:
            return _simple_shift_to_vhdl(parts[0].trim(), parts[1].trim(), "shift_right", result_type, param_names, param_types)
    _simple_operand_to_vhdl(trimmed, result_type, param_names, param_types)

fn _simple_binary_arith_to_vhdl(left: text, right: text, op: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if _simple_integer_width(result_type) == "":
        return Err("VHDL subset fallback arithmetic requires an integer result type: {result_type}")
    val left_result = _simple_operand_to_vhdl(left, result_type, param_names, param_types)
    if left_result.is_err():
        return Err(left_result.unwrap_err())
    val right_result = _simple_operand_to_vhdl(right, result_type, param_names, param_types)
    if right_result.is_err():
        return Err(right_result.unwrap_err())
    Ok("{left_result.unwrap()} {op} {right_result.unwrap()}")

fn _simple_shift_to_vhdl(left: text, right: text, op: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if _simple_integer_width(result_type) == "":
        return Err("VHDL subset fallback shift requires an integer result type: {result_type}")
    if not _is_decimal_literal(right):
        return Err("VHDL subset fallback shift count must be a decimal literal")
    val left_result = _simple_operand_to_vhdl(left, result_type, param_names, param_types)
    if left_result.is_err():
        return Err(left_result.unwrap_err())
    Ok("{op}({left_result.unwrap()}, {right})")

fn _simple_unary_to_vhdl(expr: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if expr.starts_with("-"):
        if not result_type.starts_with("i"):
            return Err("VHDL subset fallback unary negation requires a signed integer result type")
        val operand = expr.substring(1, expr.len()).trim()
        if operand == "":
            return Err("VHDL subset fallback unary negation requires an operand")
        val operand_result = _simple_operand_to_vhdl(operand, result_type, param_names, param_types)
        if operand_result.is_err():
            return Err(operand_result.unwrap_err())
        return Ok("-({operand_result.unwrap()})")
    if expr.starts_with("not "):
        val operand = expr.substring(4, expr.len()).trim()
        val operand_result = _simple_operand_to_vhdl(operand, "bool", param_names, param_types)
        if operand_result.is_err():
            return Err(operand_result.unwrap_err())
        return Ok("not {operand_result.unwrap()}")
    Err("not a unary expression")

fn _simple_comparison_to_vhdl(expr: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    val ops = [" == ", " != ", " <= ", " >= ", " < ", " > "]
    var i = 0
    while i < ops.len():
        val op = ops[i]
        if expr.contains(op):
            val parts = expr.split(op)
            if parts.len() != 2:
                return Err("VHDL subset fallback supports only binary comparisons")
            val left_text = parts[0].trim()
            val right_text = parts[1].trim()
            val left_type = _simple_expr_type(left_text, param_names, param_types)
            val right_type = _simple_expr_type(right_text, param_names, param_types)
            var compare_type = left_type
            if compare_type == "":
                compare_type = right_type
            if compare_type == "":
                return Err("VHDL subset fallback could not infer comparison type")
            val left_result = _simple_operand_to_vhdl(left_text, compare_type, param_names, param_types)
            if left_result.is_err():
                return Err(left_result.unwrap_err())
            val right_result = _simple_operand_to_vhdl(right_text, compare_type, param_names, param_types)
            if right_result.is_err():
                return Err(right_result.unwrap_err())
            val vhdl_op = _simple_comparison_op_to_vhdl(op.trim())
            if vhdl_op == "":
                return Err("VHDL subset fallback unsupported comparison operator: {op}")
            return Ok("'1' when {left_result.unwrap()} {vhdl_op} {right_result.unwrap()} else '0'")
        i = i + 1
    Err("not a comparison")

fn _simple_comparison_op_to_vhdl(op: text) -> text:
    match op:
        case "==": "="
        case "!=": "/="
        case "<": "<"
        case "<=": "<="
        case ">": ">"
        case ">=": ">="
        case _: ""

fn _simple_bool_logic_to_vhdl(expr: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if expr.contains(" and "):
        val parts = expr.split(" and ")
        if parts.len() == 2:
            return _simple_binary_bool_to_vhdl(parts[0].trim(), parts[1].trim(), "and", param_names, param_types)
    if expr.contains(" or "):
        val parts = expr.split(" or ")
        if parts.len() == 2:
            return _simple_binary_bool_to_vhdl(parts[0].trim(), parts[1].trim(), "or", param_names, param_types)
    Err("not a boolean logic expression")

fn _simple_binary_bool_to_vhdl(left: text, right: text, op: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    val left_result = _simple_operand_to_vhdl(left, "bool", param_names, param_types)
    if left_result.is_err():
        return Err(left_result.unwrap_err())
    val right_result = _simple_operand_to_vhdl(right, "bool", param_names, param_types)
    if right_result.is_err():
        return Err(right_result.unwrap_err())
    Ok("{left_result.unwrap()} {op} {right_result.unwrap()}")

fn _simple_inline_if_to_vhdl(expr: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if not expr.starts_with("if "):
        return Err("not an inline if")
    val else_opt = expr.find(" else:")
    if not else_opt.?:
        return Err("not an inline if")
    val else_index = else_opt.unwrap()
    val head = expr.substring(3, else_index).trim()
    val colon_opt = head.find(":")
    if not colon_opt.?:
        return Err("inline if is missing ':'")
    val colon_index = colon_opt.unwrap()
    val cond_text = head.substring(0, colon_index).trim()
    val then_text = head.substring(colon_index + 1, head.len()).trim()
    val else_text = expr.substring(else_index + 6, expr.len()).trim()
    if then_text == "" or else_text == "":
        return Err("inline if must have both then and else expressions")
    val cond_result = _simple_expr_to_vhdl(cond_text, "bool", param_names, param_types)
    if cond_result.is_err():
        return Err(cond_result.unwrap_err())
    val then_result = _simple_expr_to_vhdl(_simple_strip_return(then_text), result_type, param_names, param_types)
    if then_result.is_err():
        return Err(then_result.unwrap_err())
    val else_result = _simple_expr_to_vhdl(_simple_strip_return(else_text), result_type, param_names, param_types)
    if else_result.is_err():
        return Err(else_result.unwrap_err())
    Ok("{then_result.unwrap()} when {cond_result.unwrap()} = '1' else {else_result.unwrap()}")

fn _simple_cast_to_vhdl(expr: text, result_type: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    val as_opt = expr.find(" as ")
    if not as_opt.?:
        return Err("not a cast expression")
    val as_index = as_opt.unwrap()
    val source_text = expr.substring(0, as_index).trim()
    val target_type = expr.substring(as_index + 4, expr.len()).trim()
    if source_text == "" or target_type == "":
        return Err("not a cast expression")
    val source_type = _simple_expr_type(source_text, param_names, param_types)
    if source_type == "":
        return Err("VHDL subset fallback could not infer cast source type for {source_text}")
    val source_width = _simple_integer_width(source_type)
    val target_width = _simple_integer_width(target_type)
    if target_type == "bool":
        if source_type == "bool":
            return Ok(source_text)
        if source_width == "":
            return Err("VHDL subset fallback unsupported cast source type: {source_type}")
        if source_type.starts_with("u"):
            return Ok("'1' when {source_text} /= to_unsigned(0, {source_width}) else '0'")
        if source_type.starts_with("i"):
            return Ok("'1' when {source_text} /= to_signed(0, {source_width}) else '0'")
        return Err("VHDL subset fallback unsupported cast source type: {source_type}")
    if target_width == "":
        return Err("VHDL subset fallback unsupported cast target type: {target_type}")
    if source_type == "bool":
        if target_type.starts_with("u"):
            return Ok("to_unsigned(1, {target_width}) when {source_text} = '1' else to_unsigned(0, {target_width})")
        if target_type.starts_with("i"):
            return Ok("to_signed(1, {target_width}) when {source_text} = '1' else to_signed(0, {target_width})")
        return Err("VHDL subset fallback unsupported cast target type: {target_type}")
    if source_width == "":
        return Err("VHDL subset fallback unsupported cast source type: {source_type}")
    if target_type.starts_with("u"):
        return Ok("resize(unsigned({source_text}), {target_width})")
    if target_type.starts_with("i"):
        return Ok("resize(signed({source_text}), {target_width})")
    Err("VHDL subset fallback unsupported cast target type: {target_type}")

fn _simple_expr_type(expr: text, param_names: [text], param_types: [text]) -> text:
    val trimmed = expr.trim()
    if trimmed == "true" or trimmed == "false":
        return "bool"
    val comparison_result = _simple_comparison_to_vhdl(trimmed, param_names, param_types)
    if not comparison_result.is_err():
        return "bool"
    val name_type = _simple_param_type(trimmed, param_names, param_types)
    if name_type != "":
        return name_type
    if _is_decimal_literal(trimmed):
        return "i32"
    ""

fn _simple_param_type(name: text, param_names: [text], param_types: [text]) -> text:
    var i = 0
    while i < param_names.len():
        if param_names[i] == name:
            return param_types[i]
        i = i + 1
    ""

fn _simple_integer_width(type_name: text) -> text:
    match type_name:
        case "i8": "8"
        case "i16": "16"
        case "i32": "32"
        case "i64": "64"
        case "u8": "8"
        case "u16": "16"
        case "u32": "32"
        case "u64": "64"
        case _: ""

fn _is_decimal_literal(value: text) -> bool:
    if value.len() == 0:
        return false
    var i = 0
    while i < value.len():
        if not _is_decimal_digit(value.substring(i, i + 1)):
            return false
        i = i + 1
    true

fn _simple_operand_to_vhdl(value: text, type_name: text, param_names: [text], param_types: [text]) -> Result<text, text>:
    if value == "true":
        return Ok("'1'")
    if value == "false":
        return Ok("'0'")
    val param_type = _simple_param_type(value, param_names, param_types)
    if param_type != "":
        return Ok(value)
    val first = if value.len() > 0: value.substring(0, 1) else: ""
    if _is_decimal_digit(first):
        match type_name:
            case "i8": return Ok("to_signed({value}, 8)")
            case "i16": return Ok("to_signed({value}, 16)")
            case "i32": return Ok("to_signed({value}, 32)")
            case "i64": return Ok("to_signed({value}, 64)")
            case "u8": return Ok("to_unsigned({value}, 8)")
            case "u16": return Ok("to_unsigned({value}, 16)")
            case "u32": return Ok("to_unsigned({value}, 32)")
            case "u64": return Ok("to_unsigned({value}, 64)")
            case _: return Err("VHDL subset fallback cannot materialize integer literal for type: {type_name}")
    Err("VHDL subset fallback unsupported expression: {value}")

fn _is_decimal_digit(ch: text) -> bool:
    ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9"

fn _run_compile_to_path(path: text, output: text, extra_args: [text]) -> CompileResult:
    val simple_bin = _find_simple_binary()
    var args = ["compile", path]
    var i = 0
    while i < extra_args.len():
        args = args.push(extra_args[i])
        i = i + 1
    args = args.push("-o")
    args = args.push(output)

    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, args)
    val combined = _clean_child_output(stdout, stderr)
    if exit_code == 0 and rt_file_exists(output):
        return CompileResult.Success(output)
    if exit_code == 0:
        return CompileResult.RuntimeError("compile reported success but did not create output: {output}")
    CompileResult.RuntimeError(combined)
