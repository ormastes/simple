# Driver API Codegen Backends [Tier 3] - AOT codegen backend helpers.
#
# Dependency rules:
#   - May import from: driver_api_types (Tier 0), driver_core_types
#   - Must NOT import from Tier 4+ files
#   - Uses `use lazy` for CompilerDriver

use compiler.common.driver_core_types.{CompileOptions, CompileMode, CompileResult, OutputFormat, compileoptions_normalize_mir_optimization}
use lazy compiler.driver.driver.{CompilerDriver}

fn aot_options(path: text, output: text, backend: text) -> CompileOptions:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    if backend != "":
        options.backend = backend
    compileoptions_normalize_mir_optimization(options)

pub fn aot_file(path: text, output: text) -> CompileResult:
    val driver = CompilerDriver.create(aot_options(path, output, ""))
    CompilerDriver.run_compile(driver)

pub fn aot_c_file(path: text, output: text) -> CompileResult:
    val driver = CompilerDriver.create(aot_options(path, output, "c"))
    CompilerDriver.run_compile(driver)

pub fn aot_llvm_file(path: text, output: text) -> CompileResult:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Smf
    options.backend = "llvm"
    options.release = true
    options.optimize = true
    options.opt_level = 3
    options = compileoptions_normalize_mir_optimization(options)
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

pub fn aot_cuda_file(path: text, output: text) -> CompileResult:
    val driver = CompilerDriver.create(aot_options(path, output, "cuda"))
    CompilerDriver.run_compile(driver)

pub fn aot_vhdl_file(path: text, output: text) -> CompileResult:
    val driver = CompilerDriver.create(aot_options(path, output, "vhdl"))
    CompilerDriver.run_compile(driver)
