# Driver API Codegen Backends [Tier 3] - AOT codegen backend helpers.
#
# Dependency rules:
#   - May import from: driver_api_types (Tier 0), driver_core_types
#   - Must NOT import from Tier 4+ files
#   - Uses `use lazy` for CompilerDriver

use compiler.driver.driver_core_types.{CompileOptions, CompileMode, CompileResult, OutputFormat}
use lazy compiler.driver.driver.{CompilerDriver}

fn aot_file(path: text, output: text) -> CompileResult:
    val options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

fn aot_c_file(path: text, output: text) -> CompileResult:
    val options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.backend = "c"
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

fn aot_llvm_file(path: text, output: text) -> CompileResult:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Smf
    options.backend = "llvm"
    options.release = true
    options.optimize = true
    options.opt_level = 3
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

fn aot_cuda_file(path: text, output: text) -> CompileResult:
    val options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.backend = "cuda"
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

fn aot_vhdl_file(path: text, output: text) -> CompileResult:
    val options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.backend = "vhdl"
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

export aot_file, aot_c_file, aot_llvm_file, aot_cuda_file, aot_vhdl_file
