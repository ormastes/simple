use compiler.driver.driver.{CompilerDriver}
use compiler.common.driver_core_types.{CompileOptions, CompileResult}

extern fn compiler__driver__driver__compiler_driver_create(options: CompileOptions) -> CompilerDriver
extern fn compiler__driver__driver__CompilerDriver_dot_compile(driver: CompilerDriver) -> CompileResult

pub fn bootstrap_compiler_driver_create(options: CompileOptions) -> CompilerDriver:
    compiler__driver__driver__compiler_driver_create(options)

pub fn bootstrap_compiler_driver_run_compile(driver: CompilerDriver) -> CompileResult:
    compiler__driver__driver__CompilerDriver_dot_compile(driver)
