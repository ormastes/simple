# Driver — Pipeline Methods (CompilerDriver extensions)
#
# Extracted from driver.spl. Contains CompilerDriver methods for:
# - JIT compilation (jit_compile_and_run)
# - SMF execution (execute_smf)
# - Borrow checking (borrow_check, format_borrow_error)
# - Async processing (process_async)
# - MIR optimization (optimize_mir)
# - AOP weaving (weave_aop)
# - Debug trace injection (apply_debug_trace)
# - Optimization config (get_optimization_config)

use compiler.hir.hir.*
use compiler.mir.mir.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, MirBody}
use compiler.backend.codegen.{CodegenPipeline, CompiledModule}
use compiler.backend.backend_types.{BackendResult}
use compiler.borrow.borrow_check.*
use compiler.tools.async_integration.{AsyncIntegration, AsyncStateMachine, process_async_mir}
use compiler.mir_opt.mir_opt_integration.{OptimizationConfig, optimize_mir_module, optimizationconfig_speed}
use compiler.frontend.core.aop.{weave_function, weavingconfig_all_rules, WeavingConfig, MirBlockInfo, InstructionInfo}
use compiler.frontend.core.aop_log_policy.{AopLogInstrumentationConfig, aop_log_weaving_rules, aop_log_with_compile_level, aop_log_with_runtime_level}
use compiler.mir.mir_aop_injection.{extract_mir_block_info, apply_weaving_result}
use compiler.mir.mir_debug_trace_injection.{inject_debug_trace}
use compiler.mdsoc.weaving.weaving_config.{weavingconfig_from_hir_advices}
use compiler.frontend.core.aop_conflict_detect.{detect_advice_conflicts}
use compiler.frontend.core.aop_predicate_parser.{validate_predicate, validate_advice_form}
use compiler.common.driver_core_types.{CompileResult}
use compiler.hir.hir_types.{SymbolTable}
use driver_types.{CompileContext, CompileOptions}
use compiler.driver.driver.{CompilerDriver}
use compiler.driver.driver_log_helpers.{log_debug, log_warn, log_phase}
use compiler.driver.driver_source_loading.{_format_nll_error, _driver_is_bootstrap_entry_source}
use std.alloc.sffi.{rt_dict_keys}

extern fn rt_env_get(key: text) -> text

fn _driver_env_bool(key: text) -> bool:
    val value = (rt_env_get(key) ?? "").to_lower()
    value == "1" or value == "true" or value == "yes" or value == "on"

# Diagnostics-plumbing: MirLowering.errors was silently dropped on the
# native-build worker path (nothing outside 70.backend read it), so a bare
# `nosuchfn(1)` call or an unsupported construct produced broken MIR that
# only surfaced later as an llc crash / nil-callee far from the real cause.
# Format each MirError the same way jit_interpreter.spl / compiler.spl
# already report them (message, plus file:line:col when the span is known).
fn _format_mir_error(err: MirError) -> text:
    # Span payloads can be absent even when a staged native Optional is tagged
    # Some. Diagnostics must never crash while reporting the original failure.
    "MIR lowering error: {err.message}"

# MirLowering.errors mixes genuine "this MIR is broken" failures with
# recoverable/informational entries the lowering pipeline pushes through the
# same channel and then continues past (e.g. `lower_type` falling back to
# MirType.I64 for a HIR type it can't map 1:1 — commonly HirTypeKind.Infer,
# since this pipeline has no expression type-inference pass; or the asm
# target-match "note:"-prefixed advisories in asm_and_targets.spl). Treating
# every entry as fatal regresses currently-passing builds: confirmed
# empirically that native-smoke-matrix cases (8) enum_match and (13)
# dict_index both hit "unsupported MIR type kind: ..." on every
# currently-passing build and still produce correct output.
#
# So this allowlists the specific message shapes that name an actually
# unresolved symbol/construct with no fallback — the class of bug this fix
# targets (a bare `nosuchfn(1)` call, or a first-class lambda value passed
# where only a direct call is supported) — and leaves everything else as a
# non-fatal warning.
#
# silentfactory audit (2026-07-14): widened this allowlist after reading
# every self.error(...) call site in 50.mir/_MirLoweringExpr/expr_dispatch.spl
# and switch_operators_calls.spl. Added, each confirmed unreachable by any
# currently-passing native-smoke-matrix case (verified empirically, not just
# by inspection):
#   - "undefined variable" (was "undefined variable:" only — the Var(symbol)
#     case in expr_dispatch.spl pushes the bare, colon-less "undefined
#     variable" string with no name, so it fell through this prefix check
#     entirely and silently produced an i64 nil temp).
#   - "unsupported array/string slice index" — a[start:end] has no native
#     lowering; was silently producing a garbage value.
#   - "B5b" — every int-literal `match` Phase-2 diagnostic in
#     lower_int_match's arm loop (non-IntLit literal/Or, Tuple/Array/Struct/
#     Range/Error pattern kinds, missing wildcard default, duplicate
#     default arms) shares this prefix; none of these pattern shapes appear
#     in the matrix's enum_match/result_try_op cases, which route through
#     lower_enum_match instead and never reach this arm loop.
#   - "match default binding has no resolved symbol" — an internal
#     invariant violation (the `if val default_symbol = default_binding`
#     bind succeeded but the value is nil), never a normal fallback.
#   - "enum match:" — bare/ambiguous/unknown variant and unsupported arm
#     pattern in lower_enum_match; the function's own comment already says
#     "emit a LOUD error instead of silently falling through", it just
#     wasn't wired to this allowlist. Matrix's enum_match/result_try_op
#     cases use fully-qualified, registered variants and never hit this.
#   - "enum construction: unregistered enum" — lower_enum_lit only runs for
#     the explicit `EnumName.Variant(...)` HIR shape with a resolved Named
#     type; Ok/Err/Option construction is gated separately (see the
#     enum_variant_index.has("Result"/"Option") checks in
#     switch_operators_calls.spl) and never reaches this function, so
#     result_try_op is unaffected.
#   - "unsupported struct field initializer" — a Lambda literal (or other
#     value lower_expr can't handle) in field-initializer position; that
#     call site's own comment says the fix's whole point is "a clean loud
#     build failure, never a crash". Matrix's struct_field case only ever
#     passes int literals.
#
# iterators lane (2026-07-14): added "for-in over non-array iterables" —
# lower_for_iterator (mir_lowering_stmts.spl, #143) already records this via
# self.error(...) AND emits a belt-and-braces rt_panic call for any `for x in
# c:` where `c` is neither a Range nor a runtime array (e.g. `for ch in
# some_string:` — bug #143 confirmed still unimplemented natively). Without
# this prefix in the allowlist, the message was downgraded to a warning, the
# build silently SUCCEEDED, and the failure only surfaced as a runtime PANIC
# when the binary ran — the exact "silent success, loud crash later" shape
# this allowlist exists to prevent for every other unsupported-construct
# message. Verified empirically against the full native-smoke-matrix (all 15
# cases still PASS): no passing case iterates a non-array/non-range
# collection, so this cannot regress currently-working native-build output.
fn _mir_error_is_fatal(message: text) -> bool:
    message.starts_with("undefined variable") or
        message.starts_with("unresolved method call:") or
        message.starts_with("unsupported MIR expression:") or
        message.starts_with("match guards (case x if cond:) are not supported") or
        message.starts_with("unsupported array/string slice index") or
        message.starts_with("B5b") or
        message.starts_with("match default binding has no resolved symbol") or
        message.starts_with("enum match:") or
        message.starts_with("enum construction: unregistered enum") or
        message.starts_with("unsupported struct field initializer") or
        message.starts_with("unsupported Result unwrap payload type") or
        message.starts_with("for-in over non-array iterables") or
        message.starts_with("native Option try operator requires the tagged Option ABI")

fn _driver_collect_mir_errors(ctx: CompileContext, errors: [MirError]):
    for err in errors:
        if _mir_error_is_fatal(err.message):
            ctx.add_error(_format_mir_error(err))
        else:
            ctx.add_warning(_format_mir_error(err))

impl CompilerDriver:
    # --------------------------------------------------------------------------
    # Mode: JIT Compile and Run
    # --------------------------------------------------------------------------

    me jit_compile_and_run() -> CompileResult:
        # Lower to MIR
        if not self.lower_to_mir():
            val first_err = self.ctx.errors.first()
            val msg = if first_err != nil: first_err else: "MIR lowering failed"
            return CompileResult.CodegenError(msg)

        # Evict HIR modules (no longer needed after MIR lowering)
        if self.ctx.options.low_memory:
            self.ctx.evict_hir()

        # Borrow checking
        if not self.borrow_check():
            return CompileResult.BorrowError(self.ctx.errors)

        # Process async functions (generate state machines for await/yield)
        val _async_state_machines = self.process_async()

        # Optimize MIR (speed optimization for JIT)
        self.optimize_mir(optimizationconfig_speed())

        # AOP weaving (after optimization, before codegen)
        self.weave_aop()

        # Debug trace injection (after AOP, before codegen)
        self.apply_debug_trace()

        # JIT compile
        var pipeline = CodegenPipeline.jit()
        var compiled_modules: [CompiledModule] = []

        val jit_module_names: [text] = rt_dict_keys(self.ctx.mir_modules)
        var jit_module_i = 0
        while jit_module_i < jit_module_names.len():
            val name = jit_module_names[jit_module_i]
            val mir_module = self.ctx.mir_modules[name]
            match pipeline.compile_module(mir_module):
                case Ok(compiled):
                    compiled_modules.push(compiled)
                case Err(e):
                    return CompileResult.CodegenError("JIT compile error in {name}: {e.message}")
            jit_module_i = jit_module_i + 1

        if compiled_modules.len() == 0:
            return CompileResult.RuntimeError("No modules compiled")

        val compiled = compiled_modules[compiled_modules.len() - 1]
        match compiled.call("main", []):
            case Ok(result):
                compiled.release_codegen_module()
                CompileResult.Success(result)
            case Err(e):
                compiled.release_codegen_module()
                CompileResult.RuntimeError(e.message)

    # --------------------------------------------------------------------------
    # Mode: SMF Exec (load and execute pre-compiled SMF)
    # --------------------------------------------------------------------------

    me execute_smf() -> CompileResult:
        """Load a pre-compiled SMF file and execute its main function.

        Uses JIT infrastructure to map SMF code into executable memory.
        Falls back to interpret mode if SMF loading fails.
        """
        val smf_path = self.ctx.options.input_files[0]
        log_debug("execute_smf: loading {smf_path}")

        # Use JIT pipeline to load and execute the SMF
        var pipeline = CodegenPipeline.jit()
        match pipeline.load_smf_and_execute(smf_path):
            case Ok(result):
                CompileResult.Success(result)
            case Err(e):
                # Fallback: log and return error (caller can retry with interpret)
                log_warn("SMF exec failed: {e}, falling back")
                CompileResult.RuntimeError("SMF execution failed: {e}")

    # --------------------------------------------------------------------------
    # Borrow Checking
    # --------------------------------------------------------------------------

    me borrow_check() -> bool:
        """Run borrow checking on all MIR modules.

        Uses the NLL (Non-Lexical Lifetimes) borrow checker to detect:
        - Conflicting borrows (E0502)
        - Use after move
        - Assignment while borrowed
        Errors include relatedInformation for first borrow location.
        """
        if self.ctx.options.no_borrow_check:
            log_debug("borrow checking skipped (--no-borrow-check)")
            return true
        log_debug("running borrow check")
        var checker = BorrowChecker.create()
        val borrow_module_names: [text] = rt_dict_keys(self.ctx.mir_modules)
        var borrow_module_i = 0
        while borrow_module_i < borrow_module_names.len():
            val name = borrow_module_names[borrow_module_i]
            val mir_module = self.ctx.mir_modules[name]
            val all_errors = check_mir_module(mir_module)
            for err in all_errors:
                self.ctx.add_error(_format_nll_error(err))
            borrow_module_i = borrow_module_i + 1
        self.ctx.errors.len() == 0

    fn format_borrow_error(err: NLLError) -> text:
        """Format a borrow error for display."""
        _format_nll_error(err)

    # --------------------------------------------------------------------------
    # Async Processing
    # --------------------------------------------------------------------------

    me process_async() -> Dict<text, AsyncStateMachine>:
        """Process async functions and generate state machines.

        This is called after MIR lowering to analyze and transform async functions.
        State machines are used by codegen for async execution.
        """
        val log = self.ctx.logger
        log_debug("processing async functions")

        val state_machines = process_async_mir(self.ctx.mir_modules)

        log_debug("generated async state machines")
        state_machines

    # --------------------------------------------------------------------------
    # MIR Optimization
    # --------------------------------------------------------------------------

    me optimize_mir(config: OptimizationConfig):
        """Apply MIR optimization passes to all modules."""
        val log = self.ctx.logger
        log_debug("optimizing MIR modules")

        val optimize_module_names: [text] = rt_dict_keys(self.ctx.mir_modules)
        var optimize_module_i = 0
        while optimize_module_i < optimize_module_names.len():
            val name = optimize_module_names[optimize_module_i]
            val mir_module = self.ctx.mir_modules[name]
            val optimized = optimize_mir_module(mir_module, config)
            # Direct mutation (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.mir_modules[name] = optimized
            optimize_module_i = optimize_module_i + 1

    # --------------------------------------------------------------------------
    # AOP Weaving
    # --------------------------------------------------------------------------

    me weave_aop():
        """Apply AOP weaving to all MIR modules using advice from HIR modules."""
        # Collect all AOP advices from HIR modules
        var all_advices: [HirAopAdvice] = []
        val advice_module_names: [text] = rt_dict_keys(self.ctx.hir_modules)
        var advice_module_i = 0
        while advice_module_i < advice_module_names.len():
            val name = advice_module_names[advice_module_i]
            val hir_mod = self.ctx.hir_modules[name]
            for advice in hir_mod.aop_advices:
                all_advices.push(advice)
            advice_module_i = advice_module_i + 1

        # Validate predicates and advice forms
        for advice in all_advices:
            val pred_err = validate_predicate(advice.predicate_text)
            if pred_err.len() > 0:
                self.ctx.errors.push("[AOP] {pred_err} in advice '{advice.advice_function}'")
            val form_err = validate_advice_form(advice.form)
            if form_err.len() > 0:
                self.ctx.errors.push("[AOP] {form_err} in advice '{advice.advice_function}'")

        # Build weaving config from collected advices and optional compiler
        # AOP debug logging knobs. Disabled logging only reads these env values
        # once, so no MIR join-point scan is added to the default path.
        var config = weavingconfig_from_hir_advices(all_advices)
        var log_config = AopLogInstrumentationConfig.for_debug(
            _driver_env_bool("SIMPLE_AOP_LOG_CALLS"),
            _driver_env_bool("SIMPLE_AOP_LOG_ASSIGNMENTS")
        )
        log_config = aop_log_with_compile_level(log_config, rt_env_get("SIMPLE_AOP_COMPILE_LOG_LEVEL") ?? "debug")
        log_config = aop_log_with_runtime_level(log_config, rt_env_get("SIMPLE_AOP_RUNTIME_LOG_LEVEL") ?? "debug")
        val log_rules = aop_log_weaving_rules(log_config)
        if log_rules.len() > 0:
            var combined_rules = weavingconfig_all_rules(config)
            for log_rule in log_rules:
                combined_rules.push(log_rule)
            config = WeavingConfig.from_rules(combined_rules)
        if not config.enabled:
            log_debug("AOP weaving: no advice declarations or enabled log instrumentation found, skipping")
            return

        val all_rules = weavingconfig_all_rules(config)
        val rule_count = all_rules.len()
        log_debug("AOP weaving")

        # Detect advice conflicts (E1504, E1506)
        val conflicts = detect_advice_conflicts(all_rules)
        for conflict in conflicts:
            if conflict.is_error():
                self.ctx.errors.push("[AOP] {conflict.message}")
            elif conflict.is_warning():
                self.ctx.warnings.push("[AOP] {conflict.message}")

        # Weave each MIR function
        val weave_module_names: [text] = rt_dict_keys(self.ctx.mir_modules)
        var weave_module_i = 0
        while weave_module_i < weave_module_names.len():
            val mod_name = weave_module_names[weave_module_i]
            val mir_module = self.ctx.mir_modules[mod_name]
            var woven_functions: Dict<SymbolId, MirFunction> = {}
            val weave_function_symbols: [SymbolId] = rt_dict_keys(mir_module.functions)
            var weave_function_i = 0
            while weave_function_i < weave_function_symbols.len():
                val func = mir_module.functions[weave_function_symbols[weave_function_i]]
                # Extract block info for AOP matching
                val blocks = extract_mir_block_info(func.blocks)
                # Run weaving analysis
                val result = weave_function(config, func.name, mod_name, [], [], blocks)
                # Apply advice insertions to MIR
                if result.advices_inserted > 0:
                    val woven_func = apply_weaving_result(func, result)
                    woven_functions[func.symbol] = woven_func
                else:
                    woven_functions[func.symbol] = func
                # Report diagnostics
                for diag in result.diagnostics:
                    if diag.is_error():
                        self.ctx.errors.push("[AOP] {diag.message}")
                    elif diag.is_warning():
                        self.ctx.warnings.push("[AOP] {diag.message}")
                weave_function_i = weave_function_i + 1
            self.ctx.mir_modules[mod_name] = MirModule(
                name: mir_module.name,
                functions: woven_functions,
                statics: mir_module.statics,
                constants: mir_module.constants,
                types: mir_module.types
            )
            weave_module_i = weave_module_i + 1

    # --------------------------------------------------------------------------
    # Debug Trace Injection
    # --------------------------------------------------------------------------

    me apply_debug_trace():
        """Apply semantic trace injection to all MIR modules.

        Reads self.ctx.options.debug_trace_level (text).  If empty or
        "none", this is a no-op.  Otherwise injects __spl_trace_* calls
        into every MIR function, gated by the requested level."""
        val level = self.ctx.options.debug_trace_level
        if level == "" or level == "none":
            return

        log_debug("debug trace injection: level={level}")
        val trace_module_names: [text] = rt_dict_keys(self.ctx.mir_modules)
        var trace_module_i = 0
        while trace_module_i < trace_module_names.len():
            val name = trace_module_names[trace_module_i]
            val mir_module = self.ctx.mir_modules[name]
            val instrumented = inject_debug_trace(mir_module, level)
            self.ctx.mir_modules[name] = instrumented
            trace_module_i = trace_module_i + 1

    fn get_optimization_config() -> OptimizationConfig:
        """Get optimization config from compiler options."""
        optimizationconfig_speed()

    # --------------------------------------------------------------------------
    # MIR Lowering
    # --------------------------------------------------------------------------

    me lower_to_mir() -> bool:
        val skip_mir_lower = rt_env_get("SIMPLE_BOOTSTRAP_SKIP_MIR_LOWER") ?? ""
        if skip_mir_lower == "1":
            print "[bootstrap] skipping MIR lowering"
            var skip_idx = 0
            while skip_idx < self.ctx.sources.len():
                val src_skip = self.ctx.sources[skip_idx]
                val name_skip = src_skip.module_name
                val mir_skip = MirModule(
                    name: name_skip,
                    functions: {},
                    statics: {},
                    constants: {},
                    types: {}
                )
                self.ctx.mir_modules[name_skip] = mir_skip
                if name_skip == "app.cli.bootstrap_main":
                    self.ctx.bootstrap_entry_mir = Some(mir_skip)
                skip_idx = skip_idx + 1
            return self.ctx.errors.len() == 0

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and (rt_env_get("SIMPLE_BOOTSTRAP_STAGE4") ?? "") != "1":
            val bootstrap_hir = self.ctx.hir_modules["app.cli.bootstrap_main"]
            if bootstrap_hir == nil:
                self.ctx.errors.push("MIR lowering missing HIR module for app.cli.bootstrap_main during bootstrap")
                log_phase("aot:lower_to_mir:missing_hir module=app.cli.bootstrap_main")
                return false
            log_phase("aot:bootstrap_fixed:start module=app.cli.bootstrap_main functions={bootstrap_hir.functions.len()}")
            var bootstrap_lowering = MirLowering.new(bootstrap_hir.symbols)
            var bootstrap_mir = bootstrap_lowering.lower_module(bootstrap_hir)
            self.ctx.bootstrap_entry_mir = Some(bootstrap_mir)
            _driver_collect_mir_errors(self.ctx, bootstrap_lowering.errors)
            log_phase("aot:bootstrap_fixed:done module=app.cli.bootstrap_main functions={bootstrap_mir.functions.len()}")
            return self.ctx.errors.len() == 0

        if self.ctx.sources.len() > 0:
            # Mirror phase-2 parse_all_impl (driver.spl): under --entry-closure
            # every source in ctx.sources is a real module reachable from the
            # entry point (parsed fully in phase 2), not just the bootstrap
            # main file. Without this flag here, every non-main module fell
            # through to the empty MirModule stub below, producing "MIR module
            # has no functions" for the first such module the AOT backend
            # tried to compile on its own (e.g. std.io_runtime).
            val native_entry_closure_mir = (rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE") ?? "") == "1"
            var direct_idx = 0
            var direct_lowering = MirLowering(
                builder: MirBuilder(
                    module: MirModule(
                        name: "",
                        functions: {},
                        statics: {},
                        constants: {},
                        types: {}
                    ),
                    current_function: nil,
                    current_block: BlockId(id: 0),
                    next_local_id: 0,
                    next_block_id: 1,
                    locals: [],
                    blocks: [],
                    instructions: []
                ),
                symbols: SymbolTable.new(),
                local_map: {},
                local_symbol_ids: [],
                local_symbol_values: [],
                current_function_symbols: [],
                current_function_names: [],
                loop_stack: [],
                errors: [],
                field_map: {},
                bitfield_map: {},
                bitfield_value_syms: {},
                struct_field_order: {},
                struct_field_type_name: {},
                struct_value_syms: {},
                struct_method_syms: {},
                struct_method_return_names: {},
                struct_method_return_is_array: {},
                enum_payload_struct_names: {},
                runtime_array_locals: {},
                runtime_dict_locals: {},
                array_element_struct_syms: {},
                runtime_value_locals: {},
                nil_locals: {},
                enum_variant_index: {},
                lambda_bindings: {},
                lambda_capture_snapshot: {},
                current_has_vhdl_metadata: false,
                global_symbol_ids: {}
            )
            while direct_idx < self.ctx.sources.len():
                val src_direct = self.ctx.sources[direct_idx]
                val name_direct = src_direct.module_name
                val mir_direct = if native_entry_closure_mir or _driver_is_bootstrap_entry_source(src_direct.path, name_direct) or (rt_env_get("SIMPLE_UNSTUB_HIR") ?? "") == "1":
                    log_phase("aot:lower_to_mir:module:start idx={direct_idx} module={name_direct} path={src_direct.path}")
                    val direct_hir = self.ctx.hir_modules[name_direct]
                    if direct_hir == nil:
                        self.ctx.errors.push("MIR lowering missing HIR module for {name_direct} ({src_direct.path})")
                        log_phase("aot:lower_to_mir:missing_hir idx={direct_idx} module={name_direct} path={src_direct.path}")
                        return false
                    direct_lowering.symbols = direct_hir.symbols
                    var lowered_entry = direct_lowering.lower_module(direct_hir)
                    lowered_entry.name = name_direct
                    log_phase("aot:lower_to_mir:module:done idx={direct_idx} module={name_direct} functions={lowered_entry.functions.len()}")
                    lowered_entry
                else:
                    MirModule(
                        name: name_direct,
                        functions: {},
                        statics: {},
                        constants: {},
                        types: {}
                    )
                self.ctx.mir_modules[name_direct] = mir_direct
                if name_direct == "app.cli.bootstrap_main":
                    self.ctx.bootstrap_entry_mir = Some(mir_direct)
                direct_idx = direct_idx + 1
            _driver_collect_mir_errors(self.ctx, direct_lowering.errors)
            return self.ctx.errors.len() == 0

        var lowering = MirLowering(
            builder: MirBuilder(
                module: MirModule(
                    name: "",
                    functions: {},
                    statics: {},
                    constants: {},
                    types: {}
                ),
                current_function: nil,
                current_block: BlockId(id: 0),
                next_local_id: 0,
                next_block_id: 1,
                locals: [],
                blocks: [],
                instructions: []
            ),
            symbols: SymbolTable.new(),
            local_map: {},
            local_symbol_ids: [],
            local_symbol_values: [],
            current_function_symbols: [],
            current_function_names: [],
            loop_stack: [],
            errors: [],
            field_map: {},
            bitfield_map: {},
            bitfield_value_syms: {},
            struct_field_order: {},
            struct_field_type_name: {},
            struct_value_syms: {},
            struct_method_syms: {},
            struct_method_return_names: {},
            struct_method_return_is_array: {},
            enum_payload_struct_names: {},
            runtime_array_locals: {},
            runtime_dict_locals: {},
            array_element_struct_syms: {},
            runtime_value_locals: {},
            nil_locals: {},
            enum_variant_index: {},
            lambda_bindings: {},
            lambda_capture_snapshot: {},
            current_has_vhdl_metadata: false,
            global_symbol_ids: {}
        )

        # BUG-001 diagnostic: log module count entering MIR lowering
        log_debug("[lower_to_mir] lowering to MIR")
        var lower_trace_count = 0
        if self.ctx.sources.len() <= 0:
            for hir_module in self.ctx.hir_modules:
                val name = hir_module.name
                var mir_module = lowering.lower_module(hir_module)
                mir_module.name = name
                self.ctx.mir_modules[name] = mir_module
                if name == "app.cli.bootstrap_main":
                    self.ctx.bootstrap_entry_mir = Some(mir_module)
            _driver_collect_mir_errors(self.ctx, lowering.errors)
            log_debug("[lower_to_mir] MIR done")
            return self.ctx.errors.len() == 0
        for src3 in self.ctx.sources:
            val name = src3.module_name
            val mir_module = MirModule(
                name: name,
                functions: {},
                statics: {},
                constants: {},
                types: {}
            )
            self.ctx.mir_modules[name] = mir_module
            if name == "app.cli.bootstrap_main":
                self.ctx.bootstrap_entry_mir = Some(mir_module)

        log_debug("[lower_to_mir] MIR done")
        self.ctx.errors.len() == 0
