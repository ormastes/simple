fn aot_native_project_with_backend(source_dirs: [text], entry: text, output: text, backend: text, strip: bool) -> CompileResult:
    print "[API] aot_native_project_with_backend: entry={entry}, output={output}, backend={backend}, sources={source_dirs.len()}"
    var options = CompileOptions.default()
    var inputs: [text] = []
    for dir in source_dirs:
        inputs = inputs.push(dir)
    inputs = inputs.push(entry)
    options.input_files = inputs
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = true
    options.optimize = true
    options.opt_level = 3
    print "[API] creating driver with {inputs.len()} inputs..."
    val driver = CompilerDriver.create(options)
    print "[API] driver created, calling compile..."
    val result = driver.compile()
    print "[API] compile result: {result}"
    result

