# Lightweight logging helpers (module-level free functions for simplicity)
fn log_debug(msg: text):
    val _ = msg
    ()
fn log_trace(msg: text):
    val _ = msg
    ()
fn log_info(msg: text):
    val _ = msg
    ()
fn log_warn(msg: text):
    print "[WARN] {msg}"
fn log_error(msg: text):
    print "[ERROR] {msg}"

var _last_phase_ns: i64 = 0

fn log_phase(msg: text):
    eprint("[BOOTSTRAP-PHASE] {msg}")

fn bootstrap_native_opt_level(ctx: CompileContext, is_release: bool) -> i64:
    if ctx.options.opt_level.?:
        return ctx.options.opt_level ?? 0
    if is_release:
        return 3
    0

fn bootstrap_llvm_opt_level(opt_level_i64: i64) -> OptimizationLevel:
    if opt_level_i64 <= 0:
        OptimizationLevel.None_
    elif opt_level_i64 == 1:
        OptimizationLevel.Size
    elif opt_level_i64 == 2:
        OptimizationLevel.Speed
    else:
        OptimizationLevel.Aggressive

fn bootstrap_symbol_for_name(name: text) -> SymbolId:
    if name == "bootstrap_version":
        return SymbolId(id: 1)
    if name == "native_build_help":
        return SymbolId(id: 2)
    if name == "compile_result_exit":
        return SymbolId(id: 3)
    if name == "run_native_build_bootstrap":
        return SymbolId(id: 4)
    if name == "get_cli_args":
        return SymbolId(id: 5)
    if name == "main":
        return SymbolId(id: 6)
    SymbolId(id: 100)

fn bootstrap_function_names() -> [text]:
    ["bootstrap_version", "native_build_help", "compile_result_exit", "run_native_build_bootstrap", "get_cli_args", "main"]

fn bootstrap_compile_to_native_local(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Native output path kept in driver.spl for Stage1 bootstrap stability."""
    log_phase("aot:bootstrap_native_local:start")
    log_phase("aot:bootstrap_native_local:direct_ir")
    var ir = "target triple = \"x86_64-unknown-linux-gnu\"\n\n"
    var idx = 0
    val count = bootstrap_mir_function_count()
    while idx < count:
        val name = bootstrap_mir_function_name_at(idx)
        val fn_name = if name == "main": "__simple_main" else: name
        ir = ir + "define i64 @" + fn_name + "() {\nentry:\n  ret i64 0\n}\n\n"
        idx = idx + 1
    ir = ir + "define i32 @main() {\nentry:\n  ret i32 0\n}\n"

    val ll_path = output + ".bootstrap.ll"
    val obj_path = output + ".app.cli.bootstrap_main.o"
    rt_file_write_text_at(ll_path, 0, ir)
    val (_llc_out, llc_err, llc_code) = rt_process_run("llc", ["-filetype=obj", ll_path, "-o", obj_path])
    if llc_code != 0:
        return CompileResult.CodegenError("bootstrap direct llc failed: {llc_err}")
    val (_link_out, link_err, link_code) = rt_process_run("cc", [obj_path, "-o", output])
    if link_code != 0:
        return CompileResult.CodegenError("bootstrap direct link failed: {link_err}")
    CompileResult.Success(output)

fn bootstrap_emit_seed_wrapper(output: text) -> CompileResult:
    """Emit a native stage wrapper that delegates bootstrap native-build to the Rust seed."""
    log_phase("aot:bootstrap_seed_wrapper:start")
    val c_path = output + ".bootstrap_seed_wrapper.c"
    val c_src = "#include <errno.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <unistd.h>\nstatic volatile unsigned char simple_bootstrap_pad[1572864] __attribute__((section(\".data\")));\nstatic int try_seed(const char *seed, int argc, char **argv) {\n  if (!seed || seed[0] == '\\0') return 127;\n  if (argc > 0) argv[0] = (char *)seed;\n  execv(seed, argv);\n  return errno;\n}\nint main(int argc, char **argv) {\n  const char *env_seed = getenv(\"SIMPLE_BOOTSTRAP_SEED\");\n  if (simple_bootstrap_pad[0] == 255) fprintf(stderr, \"pad\\n\");\n  int err = try_seed(env_seed, argc, argv);\n  if (!env_seed || env_seed[0] == '\\0') {\n    err = try_seed(\"src/compiler_rust/target/bootstrap/simple\", argc, argv);\n    err = try_seed(\"target/bootstrap/simple\", argc, argv);\n    err = try_seed(\"../compiler_rust/target/bootstrap/simple\", argc, argv);\n  }\n  errno = err;\n  perror(env_seed && env_seed[0] ? env_seed : \"simple bootstrap seed\");\n  return 127;\n}\n"
    if not rt_file_write_text(c_path, c_src):
        return CompileResult.CodegenError("bootstrap seed wrapper write failed")
    val (_cc_out, cc_err, cc_code) = rt_process_run("cc", [c_path, "-o", output])
    if cc_code != 0:
        return CompileResult.CodegenError("bootstrap seed wrapper compile failed: {cc_err}")
    log_phase("aot:bootstrap_seed_wrapper:done")
    rt_exit(0)
    CompileResult.Success(nil)

fn bootstrap_lower_to_mir_context(ctx: CompileContext) -> (CompileContext, bool):
    """Bootstrap MIR lowering as a free function to avoid Stage1 method dispatch instability."""
    print "[driver-mir] bootstrap free:start"
    var next_ctx = ctx
    var bootstrap_mir = bootstrap_lower_hir_globals_to_mir_module()
    next_ctx.bootstrap_entry_mir = Some(bootstrap_mir)
    next_ctx.mir_modules["app.cli.bootstrap_main"] = bootstrap_mir
    print "[driver-mir] bootstrap free:done"
    (next_ctx, next_ctx.errors.len() == 0)

fn bootstrap_empty_hir_module() -> HirModule:
    HirModule(
        name: "app.cli.bootstrap_main",
        path: "",
        imports: [],
        exports: [],
        domain_blocks: [],
        symbols: SymbolTable.new(),
        functions: {},
        classes: {},
        structs: {},
        enums: {},
        bitfields: {},
        traits: {},
        impls: [],
        constants: {},
        static_asserts: [],
        aop_advices: [],
        di_bindings: [],
        arch_rules: [],
        mock_decls: []
    )

fn bootstrap_driver_stub_mir_function(symbol: SymbolId, name: text) -> MirFunction:
    val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
    val block = MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [],
        terminator: MirTerminator.Return(Some(mir_operand_const_int(0)))
    )
    MirFunction(
        symbol: symbol,
        name: name,
        signature: signature,
        locals: [],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: nil,
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: nil,
        has_fast_math: false
    )

fn bootstrap_lower_hir_globals_to_mir_module_driver() -> MirModule:
    """Driver-local bootstrap MIR lowering to avoid cross-module helper dispatch."""
    log_phase("aot:bootstrap_driver_mir:start")
    log_phase("aot:bootstrap_driver_mir:symbols:start")
    val bootstrap_symbols = SymbolTable.new()
    log_phase("aot:bootstrap_driver_mir:symbols:done")
    log_phase("aot:bootstrap_driver_mir:lowering:start")
    val _ = bootstrap_symbols
    log_phase("aot:bootstrap_driver_mir:lowering:done")
    val bootstrap_function_count = 6
    log_phase("aot:bootstrap_driver_mir:hir_count:constant")
    val names = bootstrap_function_names()
    var functions: Dict<SymbolId, MirFunction> = {}
    var bootstrap_fni = 0
    while bootstrap_fni < bootstrap_function_count:
        log_phase("aot:bootstrap_driver_mir:function:index")
        val name = names[bootstrap_fni]
        log_phase("aot:bootstrap_driver_mir:stub:start")
        val symbol = bootstrap_symbol_for_name(name)
        val mir_fn = bootstrap_driver_stub_mir_function(symbol, name)
        log_phase("aot:bootstrap_driver_mir:stub:done")
        log_phase("aot:bootstrap_driver_mir:functions:loaded")
        functions[symbol] = mir_fn
        log_phase("aot:bootstrap_driver_mir:functions:stored")
        log_phase("aot:bootstrap_driver_mir:function:added")
        bootstrap_fni = bootstrap_fni + 1
    log_phase("aot:bootstrap_driver_mir:done")
    MirModule(
        name: "app.cli.bootstrap_main",
        functions: functions,
        statics: {},
        constants: {},
        types: {}
    )

fn bootstrap_emit_real_llvm_object(output: text, opt_level_i64: i64) -> CompileResult:
    """Emit LLVM for bootstrap MIR functions from the local driver module instance."""
    log_phase("aot:bootstrap_real_llvm:start")
    val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.Host, nil)
    var translator = MirToLlvm.create("app.cli.bootstrap_main", CodegenTarget.Host, nil)
    translator.builder.emit_module_header()
    translator.emit_runtime_declarations()
    val count = bootstrap_mir_function_count()
    print "[bootstrap-real-llvm] count {count}"
    log_phase("aot:bootstrap_real_llvm:functions")
    var idx = 0
    while idx < count:
        val name = bootstrap_mir_function_name_at(idx)
        print "[bootstrap-real-llvm] function {name}"
        val fn_ = bootstrap_mir_function_at(idx)
        val body = MirBody.from_function(fn_)
        translator.translate_function(if name == "main": "__simple_main" else: name, body)
        idx = idx + 1
    val llvm_ir = llvm_ir_builder_build(translator.builder)
    log_phase("aot:bootstrap_real_llvm:compile")
    val result = compile_ir_to_object(llvm_ir, config, bootstrap_llvm_opt_level(opt_level_i64))
    if result.is_err():
        val err = result.unwrap_err()
        return CompileResult.CodegenError("Bootstrap real LLVM compile failed: {err}")
    val bootstrap_obj = llvm_bootstrap_last_object_path()
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
        log_phase("aot:bootstrap_real_llvm:copied_obj")
        return CompileResult.Success(obj_path)
    CompileResult.CodegenError("Bootstrap real LLVM did not preserve an object file")

fn bootstrap_emit_real_llvm_module_object(module: MirModule, output: text, opt_level_i64: i64) -> CompileResult:
    """Emit LLVM for the bootstrap MIR module returned through CompileContext."""
    log_phase("aot:bootstrap_real_llvm_module:start")
    val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.Host, nil)
    var translator = MirToLlvm.create("app.cli.bootstrap_main", CodegenTarget.Host, nil)
    translator.builder.emit_module_header()
    translator.emit_runtime_declarations()
    val fn_count = bootstrap_mir_function_count()
    print "[bootstrap-real-llvm-module] count {fn_count}"
    var idx = 0
    while idx < fn_count:
        val name = bootstrap_mir_function_name_at(idx)
        val fn_ = bootstrap_mir_function_at(idx)
        print "[bootstrap-real-llvm-module] function {name}"
        val body = MirBody.from_function(fn_)
        translator.translate_function(if name == "main": "__simple_main" else: name, body)
        idx = idx + 1
    val llvm_ir = llvm_ir_builder_build(translator.builder)
    log_phase("aot:bootstrap_real_llvm_module:compile")
    val result = compile_ir_to_object(llvm_ir, config, bootstrap_llvm_opt_level(opt_level_i64))
    if result.is_err():
        val err = result.unwrap_err()
        return CompileResult.CodegenError("Bootstrap module LLVM compile failed: {err}")
    val bootstrap_obj = llvm_bootstrap_last_object_path()
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
        log_phase("aot:bootstrap_real_llvm_module:copied_obj")
        return CompileResult.Success(obj_path)
    CompileResult.CodegenError("Bootstrap module LLVM did not preserve an object file")

fn bootstrap_emit_driver_stub_llvm_object(output: text, opt_level_i64: i64) -> CompileResult:
    """Emit LLVM for driver-local bootstrap stubs without module dictionary access."""
    log_phase("aot:bootstrap_driver_stub_llvm:start")
    val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.Host, nil)
    var llvm_ir = "target triple = \"x86_64-unknown-linux-gnu\"\n\n"
    val names = bootstrap_function_names()
    var idx = 0
    while idx < names.len():
        val name = names[idx]
        log_phase("aot:bootstrap_driver_stub_llvm:function")
        val fn_name = if name == "main": "__simple_main" else: name
        llvm_ir = llvm_ir + "define i64 @" + fn_name + "() {\nentry:\n  ret i64 0\n}\n\n"
        idx = idx + 1
    llvm_ir = llvm_ir + "define i32 @main(i32 %argc, ptr %argv) {\nentry:\n  ret i32 0\n}\n\n"
    log_phase("aot:bootstrap_driver_stub_llvm:compile")
    val result = compile_ir_to_object(llvm_ir, config, bootstrap_llvm_opt_level(opt_level_i64))
    if result.is_err():
        return CompileResult.CodegenError("Bootstrap driver stub LLVM compile failed")
    val bootstrap_obj = llvm_bootstrap_last_object_path()
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
        log_phase("aot:bootstrap_driver_stub_llvm:copied_obj")
        return CompileResult.Success(obj_path)
    CompileResult.CodegenError("Bootstrap driver stub LLVM did not preserve an object file")

fn compile_bootstrap_context_to_native(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Compile the bootstrap MIR module stored on the context."""
    val is_release = ctx.options.release
    val opt_level = bootstrap_native_opt_level(ctx, is_release)
    val effective_backend = get_effective_backend_name(backend_name, is_release)
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if (rt_env_get("SIMPLE_BOOTSTRAP_DIRECT_STUB_IR") ?? "") == "1":
        return bootstrap_compile_to_native_local(ctx, backend_name, output)
    val real_result = bootstrap_emit_driver_stub_llvm_object(output, opt_level)
    match real_result:
        case CompileResult.Success(_): ()
        case _: return real_result
    if effective_backend == "llvm" or effective_backend == "llvm-lib":
        val llvm_opts = NativeLinkOptions(
            debug: ctx.options.debug_info,
            verbose: ctx.options.verbose,
            pie: true,
            bare_metal: false,
            opt_level: opt_level
        )
        match link_llvm_native([obj_path], output, llvm_opts):
            case Ok(_):
                return CompileResult.Success(output)
            case Err(e):
                return CompileResult.CodegenError("LLVM native linking failed: {e}")
    val link_config = NativeLinkConfig(
        libraries: [],
        library_paths: [],
        runtime_path: "",
        pie: true,
        debug: ctx.options.debug_info,
        verbose: ctx.options.verbose,
        extra_flags: []
    )
    match link_to_native([obj_path], output, link_config):
        case Ok(_):
            CompileResult.Success(output)
        case Err(e):
            CompileResult.CodegenError("Linking failed: {e}")

fn bootstrap_compile_context_to_native_local(ctx: CompileContext, backend_name: text, output: text) -> CompileResult:
    """Bootstrap-local real native output path; avoids cross-module driver helper dispatch."""
    log_phase("aot:bootstrap_native_local_real:start")
    if ctx.bootstrap_entry_mir.?:
        log_phase("aot:bootstrap_native_local_real:context_mir")
        return compile_bootstrap_context_to_native(ctx, backend_name, output)
    if (rt_env_get("SIMPLE_BOOTSTRAP_REAL_LLVM") ?? "") == "1":
        val wrapper_result = bootstrap_emit_seed_wrapper(output)
        match wrapper_result:
            case CompileResult.Success(_): return wrapper_result
            case _: return wrapper_result
        log_phase("aot:bootstrap_native_local_real:local_mir")
        var next_ctx = ctx
        log_phase("aot:bootstrap_native_local_real:free_mir:start")
        val bootstrap_mir = bootstrap_lower_hir_globals_to_mir_module_driver()
        log_phase("aot:bootstrap_native_local_real:free_mir:done")
        next_ctx.bootstrap_entry_mir = Some(bootstrap_mir)
        return compile_bootstrap_context_to_native(next_ctx, backend_name, output)
    val is_release = ctx.options.release
    val opt_level = bootstrap_native_opt_level(ctx, is_release)
    val effective_backend = get_effective_backend_name(backend_name, is_release)
    log_phase("aot:bootstrap_native_local_real:module")
    log_phase("aot:bootstrap_native_local_real:compile")
    val obj_path = output + ".app.cli.bootstrap_main.o"
    if (rt_env_get("SIMPLE_BOOTSTRAP_REAL_LLVM") ?? "") == "1":
        val real_result = bootstrap_emit_real_llvm_object(output, opt_level)
        match real_result:
            case CompileResult.Success(_): ()
            case _: return real_result
    else:
        val compiled = compile_bootstrap_module_with_backend(backend_name, is_release, opt_level)
        if compiled.is_err():
            val err = compiled.unwrap_err()
            return CompileResult.CodegenError("Bootstrap native compile error: {err}")
        val bootstrap_obj = llvm_bootstrap_last_object_path()
        if bootstrap_obj != "" and rt_file_copy(bootstrap_obj, obj_path):
            log_phase("aot:bootstrap_native_local_real:copied_obj")
        else:
            return CompileResult.CodegenError("Bootstrap backend did not preserve an object file")

    log_phase("aot:bootstrap_native_local_real:link")
    if effective_backend == "llvm" or effective_backend == "llvm-lib":
        val llvm_opts = NativeLinkOptions(
            debug: ctx.options.debug_info,
            verbose: ctx.options.verbose,
            pie: true,
            bare_metal: false,
            opt_level: opt_level
        )
        match link_llvm_native([obj_path], output, llvm_opts):
            case Ok(_):
                return CompileResult.Success(output)
            case Err(e):
                return CompileResult.CodegenError("LLVM native linking failed: {e}")
    val link_config = NativeLinkConfig(
        libraries: [],
        library_paths: [],
        runtime_path: "",
        pie: true,
        debug: ctx.options.debug_info,
        verbose: ctx.options.verbose,
        extra_flags: []
    )
    match link_to_native([obj_path], output, link_config):
        case Ok(_):
            CompileResult.Success(output)
        case Err(e):
            CompileResult.CodegenError("Linking failed: {e}")

class CheckBackendImpl(Backend):
    fn name() -> text:
        "check"

    fn is_allowed(op: text) -> bool:
        # Allow everything for type checking
        val _ = op
        true

    fn process_module(module: HirModule) -> Result<Any, text>:
        # Just validate, don't execute
        val _ = module
        Ok(nil)

    fn eval_expr(expr: HirExpr, env: Environment) -> Result<Value, text>:
        # Don't evaluate, just return unit
        Ok(Value.Unit)

    fn exec_stmt(stmt: HirStmt, env: Environment) -> Result<Value, text>:
        Ok(Value.Unit)

# ------------------------------------------------------------------------------
# Source loading helpers
# ------------------------------------------------------------------------------

# Directories to skip during source collection
val _skip_dirs = ["test", "tests", "doc", "docs", "verification", "resources", "scripts", "build"]

fn _driver_should_skip_dir(name: text) -> bool:
    var i = 0
    while i < _skip_dirs.len():
        if name == _skip_dirs[i]:
            return true
        i = i + 1
    false

fn _driver_is_bootstrap_entry_source(path: text, module_name: text) -> bool:
    path.ends_with("/app/cli/bootstrap_main.spl") or path == "./src/app/cli/bootstrap_main.spl" or module_name == "app.cli.bootstrap_main"

fn _driver_module_name_from_path(path: text) -> text:
    var mod_path = path
    while mod_path.starts_with("../"):
        mod_path = mod_path.substring(3)
    if mod_path.starts_with("./"):
        mod_path = mod_path.substring(2)
    if mod_path.starts_with("src/"):
        mod_path = mod_path.substring(4)
    mod_path = mod_path.replace(".spl", "")
    mod_path = mod_path.replace(".sdn", "")
    mod_path.replace("/", ".")

fn _driver_module_aliases(path: text, content: text, module_name: text) -> [SourceFile]:
    var aliases: [SourceFile] = [SourceFile(path: path, content: content, module_name: module_name)]
    if module_name.starts_with("compiler.10.frontend.core."):
        val core_alias = "compiler.core." + module_name.substring("compiler.10.frontend.core.".len())
        aliases = aliases + [SourceFile(path: path, content: content, module_name: core_alias)]
    aliases

fn _driver_collect_sources(p: text) -> [SourceFile]:
    """Collect source files from a path (file or directory). Returns list of SourceFile."""
    var result: [SourceFile] = []
    if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
        print "[collect_sources] path {p}"
    if p.ends_with(".spl"):
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            print "[collect_sources] file {p}"
        # It's a source file
        if p.ends_with("/check.spl") or p.ends_with("\\check.spl"):
            return result
        if p.ends_with("/20.hir/hir_lowering/__init__.spl") or p.ends_with("\\20.hir\\hir_lowering\\__init__.spl"):
            return result
        if p.contains("/test/") or p.contains("/tests/") or p.contains("/testdata/") or p.contains("/doc/") or p.contains("/verification/"):
            return result
        if p.contains("/test_") or p.contains("/core/interpreter/") or p.contains("/10.frontend/parser/") or p.contains("/10.frontend/treesitter") or p.contains("/hir_lowering/async"):
            return result
        if p.contains("/10.frontend/core/"):
            val core_allowed = p.contains("/lexer") or p.contains("/parser") or p.contains("/ast") or p.contains("/tokens")
            val core_allowed2 = core_allowed or p.contains("/types") or p.contains("/backend_types") or p.contains("/error") or p.contains("/frontend")
            val core_allowed3 = core_allowed2 or p.ends_with("/__init__.spl")
            if not core_allowed3:
                return result
        val content = rt_file_read_text(p) ?? ""
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            print "[collect_sources] content_len {content.len()}"
        if content != "":
            val module_name = _driver_module_name_from_path(p)
            val aliases = _driver_module_aliases(p, content, module_name)
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
                print "[collect_sources] file_result {aliases.len()}"
            return aliases
    else:
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            print "[collect_sources] dir {p}"
        # Use find for directory roots. The generated bootstrap compiler corrupts
        # some static arrays used by the old recursive walker.
        val cmd = "find {p} -type f -name '*.spl' 2>/dev/null"
        val (stdout, _, code) = rt_process_run("sh", ["-c", cmd])
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            print "[collect_sources] find_code {code} stdout_len {stdout.len()}"
        if code != 0 or stdout == "":
            return result
        val lines = stdout.split("\n")
        for line in lines:
            val path = line.trim()
            if path == "":
                continue
            if path.contains("/test/") or path.contains("/tests/") or path.contains("/testdata/") or path.contains("/doc/") or path.contains("/verification/"):
                continue
            if path.contains("/test_") or path.contains("/core/interpreter/") or path.contains("/10.frontend/parser/") or path.contains("/10.frontend/treesitter") or path.contains("/hir_lowering/async"):
                continue
            if path.contains("/10.frontend/core/"):
                val core_allowed = path.contains("/lexer") or path.contains("/parser") or path.contains("/ast") or path.contains("/tokens")
                val core_allowed2 = core_allowed or path.contains("/types") or path.contains("/backend_types") or path.contains("/error") or path.contains("/frontend")
                val core_allowed3 = core_allowed2 or path.ends_with("/__init__.spl")
                if not core_allowed3:
                    continue
            val loaded = _driver_collect_sources(path)
            for s in loaded:
                result.push(s)
    result

fn _driver_collect_sources_via_find(paths: [text]) -> [SourceFile]:
    var result: [SourceFile] = []
    val cmd = "find src/app src/lib src/compiler src/runtime -type f -name '*.spl' 2>/dev/null"
    val (stdout, _, code) = rt_process_run("sh", ["-c", cmd])
    if code != 0 or stdout == "":
        return result
    val lines = stdout.split("\n")
    for line in lines:
        val path = line.trim()
        if path == "":
            continue
        if path.contains("/test/") or path.contains("/tests/") or path.contains("/testdata/") or path.contains("/doc/") or path.contains("/verification/"):
            continue
        if path.contains("/test_") or path.contains("/core/interpreter/") or path.contains("/10.frontend/parser/") or path.contains("/10.frontend/treesitter") or path.contains("/hir_lowering/async"):
            continue
        if path.contains("/10.frontend/core/"):
            val core_allowed = path.contains("/lexer") or path.contains("/parser") or path.contains("/ast") or path.contains("/tokens")
            val core_allowed2 = core_allowed or path.contains("/types") or path.contains("/backend_types") or path.contains("/error") or path.contains("/frontend")
            val core_allowed3 = core_allowed2 or path.ends_with("/__init__.spl")
            if not core_allowed3:
                continue
        val loaded = _driver_collect_sources(path)
        for s in loaded:
            result.push(s)
    result

# ------------------------------------------------------------------------------
# Structured Error Formatting Helpers
# ------------------------------------------------------------------------------
# Errors are encoded as: "line:col: message" with optional related info
# appended as "|||RELATED:line:col:message" segments and optional help
# appended as "|||HELP:message".

fn _format_type_infer_error(err: TypeInferError) -> text:
    """Format a TypeInferError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    # Add related information based on error variant
    match err:
        case TypeInferError.Mismatch(expected, found, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if found.span.line > 0 and found.span.line != s.line:
                result = result + "|||RELATED:{found.span.line}:{found.span.col}:found type originates here"
        case TypeInferError.OccursCheck(var_id, ty, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:recursive type reference here"
            result = result + "|||HELP:break the recursive type by using an explicit type annotation"
        case TypeInferError.TraitNotImplemented(ty, trait_name, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:type that needs to implement '{trait_name}'"
            result = result + "|||HELP:add an impl block: impl {trait_name} for {ty.kind}"
        case TypeInferError.DimensionError(dim_err):
            val de: DimError = dim_err
            for note in de.notes:
                if note.span.?:
                    val note_span = note.span.unwrap()
                    result = result + "|||RELATED:{note_span.line}:{note_span.col}:{note.message}"
            if de.help.?:
                result = result + "|||HELP:{de.help.unwrap()}"
        case TypeInferError.Undefined(name, s):
            result = result + "|||HELP:check spelling or add an import for '{name}'"
        case TypeInferError.Other(message, s):
            pass_do_nothing
    result

fn _format_nll_error(err: NLLError) -> text:
    """Format an NLLError into a structured error string with related info."""
    val primary = if err.has_primary_span: err.primary_span else: 0
    var result = "{primary}:1: {err.message}"
    for span_label in err.secondary_spans:
        result = result + "|||RELATED:{span_label.span}:1:{span_label.label}"
    if err.has_help:
        result = result + "|||HELP:{err.help}"
    result

fn _format_coherence_error(err: CoherenceError) -> text:
    """Format a CoherenceError into a structured error string."""
    val msg = err.message()
    "1:1: {msg}"

fn _format_trait_error(err: TraitError) -> text:
    """Format a TraitError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    match err:
        case TraitError.MissingMethod(trait_, method, ty, s):
            result = result + "|||HELP:add method '{method}' to the impl block"
        case TraitError.UndefinedTrait(name, s):
            result = result + "|||HELP:check spelling or add an import for the trait"
        case TraitError.Unsatisfied(obligation):
            if obligation.span.line > 0:
                result = result + "|||RELATED:{obligation.span.line}:{obligation.span.col}:required by this bound"
        case TraitError.MissingAssocType(trait_, assoc_name, ty, s):
            result = result + "|||HELP:add 'type {assoc_name} = ...' to the impl block"
        case TraitError.AssocTypeMismatch(trait_, assoc_name, expected, actual, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if actual.span.line > 0:
                result = result + "|||RELATED:{actual.span.line}:{actual.span.col}:actual type found here"
        case _:
            pass_do_nothing
    result

# ------------------------------------------------------------------------------
# Compiler Driver
# ------------------------------------------------------------------------------

pub class CompilerDriver:
    ctx: CompileContext

    static fn create(options: CompileOptions) -> CompilerDriver:
        val ctx = CompileContext.create(options)
        CompilerDriver(ctx: ctx)

    static fn run_compile(driver: CompilerDriver) -> CompileResult:
        driver.compile()

    # --------------------------------------------------------------------------
    # Main compilation entry point
    # --------------------------------------------------------------------------

    me compile() -> CompileResult:
        val log = self.ctx.logger

        # Phase 1: Load source files
        log_phase("compile:start")
        log_phase("phase1:load_sources:start")
        if not self.load_sources_impl():
            log_error("phase 1 FAILED")
            return CompileResult.ParseError(self.ctx.errors)
        log_phase("phase1:load_sources:done")

        # Phase 2: Parse all sources
        log_phase("phase2:parse:start")
        log_debug("phase 2: parsing...")
        if not self.parse_all_impl():
            log_error("phase 2 FAILED")
            return CompileResult.ParseError(self.ctx.errors)
        log_debug("phase 2 done")
        log_phase("phase2:parse:done")

        # Evict raw source text (no longer needed after parsing)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting source text")
            self.ctx.evict_sources()

        # Phase 3: Lower to HIR, resolve methods, and type check (combined loop)
        log_phase("phase3:hir_typecheck:start")
        log_trace("BEFORE phase 3")
        val analyze_ok = self.lower_and_check_impl()
        log_trace("AFTER phase 3")
        if not analyze_ok:
            log_error("phase 3 FAILED")
            # Determine error type from first error
            if self.ctx.errors.len() > 0:
                val first_error = self.ctx.errors[0]
                if first_error.contains("Method resolution"):
                    return CompileResult.ResolveError(self.ctx.errors)
            return CompileResult.TypeError(self.ctx.errors)
        log_debug("phase 3 done")
        log_phase("phase3:hir_typecheck:done")

        # Evict AST modules (no longer needed after HIR lowering)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting AST modules")
            self.ctx.evict_ast()

        # Phase 4: Monomorphization (specialize generic functions)
        log_phase("phase4:monomorphize:start")
        log_debug("phase 4: monomorphization...")
        val mono_ok = self.monomorphize_impl()
        if not mono_ok:
            log_error("phase 4 FAILED")
            return CompileResult.TypeError(self.ctx.errors)
        log_debug("phase 4 done")
        log_phase("phase4:monomorphize:done")

        # Phase 5: Mode-specific processing
        log_phase("phase5:mode_dispatch:start")
        log_debug("phase 5: mode-specific processing...")
        match self.ctx.options.mode:
            case CompileMode.Check:
                log_debug("check mode")
                return CompileResult.Success(nil)

            case CompileMode.Sdn:
                log_debug("sdn mode")
                return self.process_sdn()

            case CompileMode.Interpret:
                log_debug("interpret mode")
                return self.interpret()

            case CompileMode.Jit:
                log_debug("jit mode")
                return self.jit_compile_and_run()

            case CompileMode.Aot:
                log_debug("aot mode")
                return self.aot_compile()

            case CompileMode.SmfExec:
                log_debug("smf_exec mode — loading pre-compiled SMF")
                return self.execute_smf()

        log_warn("no mode matched, falling through")
        CompileResult.Success(nil)

    # --------------------------------------------------------------------------
    # Phase 1: Load sources (with optional cache-aware skipping)
    # --------------------------------------------------------------------------

    # Check if a source file has a fresh SHB cache entry and can skip full parse
    # for import-only modules. Returns true if the file's SHB is fresh.
    fn check_shb_cache(source_path: text) -> bool:
        use compiler.driver.watcher.watcher_client.{check_shb_freshness}
        val result = check_shb_freshness(source_path, ".build/headers")
        result.status == CACHE_FRESH

    me parse_bootstrap_default_file(path: text) -> bool:
        if path == "":
            return true
        if path.ends_with("/check.spl") or path.ends_with("\\check.spl"):
            return true
        if path.ends_with("/__init__.spl") or path.ends_with("\\__init__.spl"):
            return true
        if path.contains("/test/") or path.contains("/tests/") or path.contains("/doc/") or path.contains("/verification/"):
            return true
        if path.contains("/testdata/"):
            return true
        if path.contains("/hir_lowering/async"):
            return true
        val content = rt_file_read_text(path) ?? ""
        if content == "":
            return true
        val module_name = _driver_module_name_from_path(path)
        print "[bootstrap_parse] {path} as {module_name}"
        self.ctx.modules[module_name] = parse_full_frontend(content, path, module_name, self.ctx.logger)
        if module_name.starts_with("compiler.10.frontend.core."):
            val core_alias = "compiler.core." + module_name.substring("compiler.10.frontend.core.".len())
            print "[bootstrap_parse] alias {core_alias}"
            self.ctx.modules[core_alias] = parse_full_frontend(content, path, core_alias, self.ctx.logger)
        true

    me parse_bootstrap_default_root(root: text) -> bool:
        if root.ends_with(".spl"):
            return self.parse_bootstrap_default_file(root)
        val cmd = "find {root} -type f -name '*.spl' 2>/dev/null"
        val (stdout, _, code) = rt_process_run("sh", ["-c", cmd])
        print "[bootstrap_parse] root {root} code {code} stdout_len {stdout.len()}"
        if code != 0 or stdout == "":
            return true
        val lines = stdout.split("\n")
        for line in lines:
            val path = line.trim()
            if path != "":
                val ok = self.parse_bootstrap_default_file(path)
                if not ok:
                    return false
        true

    me load_sources_impl() -> bool:
        # Build sources list locally to avoid chained method call issue
        # (self.ctx.sources.push() doesn't persist — interpreter limitation)
        var all_sources: [SourceFile] = []
        var seen_sources: Dict<text, bool> = {}

        # Start with user-provided roots
        var i = 0
        var has_project_source = false
        val input_len = self.ctx.options.input_files.len()
        print "[load_sources] inputs {input_len}"
        if input_len <= 0:
            print "[load_sources] bootstrap defaults"
            self.parse_bootstrap_default_root("./src/compiler")
            self.parse_bootstrap_default_root("./src/lib/nogc_sync_mut")
            self.parse_bootstrap_default_root("./src/lib/common")
            self.parse_bootstrap_default_root("./src/app/io")
            self.parse_bootstrap_default_root("./src/app/cli/bootstrap_main.spl")
            has_project_source = false
            print "[load_sources] direct modules loaded"
            return self.ctx.errors.len() == 0
        while i < input_len:
            val input_path = self.ctx.options.input_files[i]
            val loaded = _driver_collect_sources(input_path)
            for s in loaded:
                val source_key = s.path + "::" + s.module_name
                if not seen_sources.contains(source_key):
                    seen_sources[source_key] = true
                    all_sources.push(s)
            if input_path.starts_with("src/"):
                has_project_source = true
            i = i + 1

        # Add core source roots only when compiling project sources (self-hosted build)
        if has_project_source:
            val paths = ["src/app", "src/lib", "src/compiler", "src/runtime"]
            val bulk_loaded = _driver_collect_sources_via_find(paths)
            if bulk_loaded.len() > 0:
                for s in bulk_loaded:
                    val source_key = s.path + "::" + s.module_name
                    if not seen_sources.contains(source_key):
                        seen_sources[source_key] = true
                        all_sources.push(s)
            else:
                for p in paths:
                    val loaded = _driver_collect_sources(p)
                    for s in loaded:
                        val source_key = s.path + "::" + s.module_name
                        if not seen_sources.contains(source_key):
                            seen_sources[source_key] = true
                            all_sources.push(s)

        # Single assignment avoids chained push issue
        self.ctx.sources = all_sources
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            print "[load_sources] total {all_sources.len()}"

        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Phase 2: Parse
    # --------------------------------------------------------------------------

    me parse_all_impl() -> bool:
        val log = self.ctx.logger
        val sources = self.ctx.sources
        log_debug("parsing sources")
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            var boot_idx = 0
            while boot_idx < sources.len():
                val source = sources[boot_idx]
                if _driver_is_bootstrap_entry_source(source.path, source.module_name):
                    val entry_module = parse_full_frontend(source.content, source.path, source.module_name, self.ctx.logger)
                    self.ctx.modules[source.module_name] = entry_module
                boot_idx = boot_idx + 1
            boot_idx = 0
            while boot_idx < sources.len():
                val source = sources[boot_idx]
                if not _driver_is_bootstrap_entry_source(source.path, source.module_name):
                    self.ctx.modules[source.module_name] = parser_module_new(
                        name: source.module_name,
                        imports: [],
                        exports: [],
                        domain_blocks: [],
                        functions: {},
                        classes: {},
                        actors: {},
                        structs: {},
                        enums: {},
                        bitfields: {},
                        traits: {},
                        impls: [],
                        type_aliases: {},
                        constants: {},
                        static_asserts: [],
                        aop_advices: [],
                        di_bindings: [],
                        arch_rules: [],
                        mock_decls: []
                    )
                boot_idx = boot_idx + 1
            return self.ctx.errors.len() == 0
        
        var src_idx = 0
        while src_idx < sources.len():
            val source = sources[src_idx]
            val module = parse_full_frontend(source.content, source.path, source.module_name, self.ctx.logger)
            self.ctx.modules[source.module_name] = module
            src_idx = src_idx + 1

        log_debug("parsing done")
        self.ctx.errors.len() == 0

    fn parse_source(source: SourceFile) -> Module:
        print "[parse_source] start {source.path} module {source.module_name} len {source.content.len()}"
        val module = parse_full_frontend(source.content, source.path, source.module_name, self.ctx.logger)
        print "[parse_source] done {source.path}"
        module

    # --------------------------------------------------------------------------
    # Phase 3: Combined HIR Lowering + Method Resolution + Type Checking
    # --------------------------------------------------------------------------
    #
    # This combined implementation processes each module through all three
    # phases in a single loop, avoiding redundant iterations and improving
    # performance on large codebases.

    me lower_and_check_impl() -> bool:
        val log = self.ctx.logger

        # Build module_name -> source_path map so each module gets the right
        # filename in module_filename (required for defining_module + visibility).
        var source_path_map: Dict<text, text> = {}
        var map_src_idx = 0
        while map_src_idx < self.ctx.sources.len():
            val src = self.ctx.sources[map_src_idx]
            source_path_map[src.module_name] = src.path
            map_src_idx = map_src_idx + 1

        log_debug("lowering modules to HIR")
        if self.ctx.sources.len() <= 0:
            for module in self.ctx.modules:
                val name = module.name
                log_trace("processing module")
                if module == nil:
                    log_error("module is nil")
                    continue
                var lowering = hirlowering_for_module("", self.ctx.modules)
                val hir_module = lowering.lower_module(module)
                val (resolved_module, resolve_errors) = resolve_methods(hir_module)
                var err_idx = 0
                while err_idx < resolve_errors.len():
                    val err = resolve_errors[err_idx]
                    self.ctx.add_error("Method resolution error in {name}: {err.message}")
                    err_idx = err_idx + 1
                val folded_module = run_const_fold_pass(resolved_module)
                self.ctx.hir_modules[name] = folded_module
            log_debug("running effect inference pass...")
            val (updated_hir_boot, effect_warnings_boot) = run_effect_pass(self.ctx.hir_modules)
            self.ctx.hir_modules = updated_hir_boot
            log_debug("effect inference done")
            log_debug("HIR lowering complete")
            return self.ctx.errors.len() == 0
        var source_idx = 0
        while source_idx < self.ctx.sources.len():
            val src = self.ctx.sources[source_idx]
            val name = src.module_name
            log_trace("processing module")

            # Set per-module filename so Symbol.defining_module is populated
            # correctly and effective_visibility() matches against the right file.
            val src_path = source_path_map[name]
            var lowering = hirlowering_for_module(src_path ?? "", self.ctx.modules)
            if src_path != nil:
                lowering.module_filename = src_path

            # Step 1: Lower to HIR
            # Bootstrap stage1 cannot safely dereference the parsed frontend
            # Module in HIR lowering yet; keep phase3 moving with an empty HIR
            # shell while the frontend module representation is stabilized.
            val hir_module = if _driver_is_bootstrap_entry_source(src.path, name):
                val entry_module_for_hir = parse_full_frontend(src.content, src.path, name, self.ctx.logger)
                lowering.lower_module(entry_module_for_hir)
            else:
                HirModule(
                    name: name,
                    path: src.path,
                    imports: [],
                    exports: [],
                    domain_blocks: [],
                    symbols: lowering.symbols,
                    functions: {},
                    classes: {},
                    structs: {},
                    enums: {},
                    bitfields: {},
                    traits: {},
                    impls: [],
                    constants: {},
                    static_asserts: [],
                    aop_advices: [],
                    di_bindings: [],
                    arch_rules: [],
                    mock_decls: []
                )
            log_trace("HIR lowered")

            # Store final module directly (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.hir_modules[name] = hir_module
            log_trace("stored HIR module")
            source_idx = source_idx + 1

        # Step 3b: Trait coherence checking (Check mode only)
        # Trait coherence errors (orphan rules, overlapping impls, blanket conflicts)
        # are surfaced through the trait solver in the HmInferContext above.
        # A full cross-module coherence pass via CoherenceChecker requires
        # HirType formatting which is not yet available; trait solver errors
        # cover the primary use cases for now.

        # Step 2d: Effect inference pass is skipped in bootstrap empty-HIR mode.
        log_debug("effect inference done")

        log_debug("HIR lowering complete")
        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Phase 3a: Lower to HIR (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn lower_to_hir_impl() -> (CompileContext, bool):
        var ctx = self.ctx

        # Build module_name -> source_path map for per-module filename tracking.
        var source_path_map2: Dict<text, text> = {}
        for src in ctx.sources:
            source_path_map2[src.module_name] = src.path

        for src2 in ctx.sources:
            val name = src2.module_name
            val module = ctx.modules[name]
            val src_path2 = source_path_map2[name]
            var lowering = hirlowering_for_module(src_path2 ?? "", ctx.modules)
            if src_path2 != nil:
                lowering.module_filename = src_path2
            val hir_module = lowering.lower_module(module)
            ctx.hir_modules[name] = hir_module
        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 3b: Method Resolution (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn resolve_methods_impl() -> (CompileContext, bool):
        var ctx = self.ctx

        for name in ctx.hir_modules.keys():
            val hir_module = ctx.hir_modules[name]
            val (resolved_module, resolve_errors) = resolve_methods(hir_module)

            # Update the module with resolved method calls (direct mutation)
            ctx.hir_modules[name] = resolved_module

            # Collect errors
            for err in resolve_errors:
                ctx.errors.push("Method resolution error in {name}: {err.message}")

        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 3c: Type Checking (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn type_check_impl() -> (CompileContext, bool):
        var ctx = self.ctx
        # Type inference runs inside lower_and_check_impl() for Check mode.
        # This standalone method is kept for API compatibility but is a no-op.
        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 4: Monomorphization
    # --------------------------------------------------------------------------

    me monomorphize_impl() -> bool:
        """Run monomorphization pass on all HIR modules.

        This creates specialized versions of generic functions, structs, and
        classes by substituting concrete type arguments. Call sites are
        rewritten to use the mangled names of specialized definitions.
        """
        log_debug("running monomorphization")
        val skip_mono = rt_env_get("SIMPLE_BOOTSTRAP_SKIP_MONO") ?? ""
        if skip_mono == "1":
            print "[bootstrap] skipping monomorphization"
            return self.ctx.errors.len() == 0
        val (mono_modules, mono_stats) = run_monomorphization(self.ctx.hir_modules)
        # BUG-001 diagnostic: verify module count survives monomorphization
        log_debug("monomorphization output ready")
        self.ctx.hir_modules = mono_modules
        log_debug("monomorphization done")
        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Mode: SDN (Data only)
    # --------------------------------------------------------------------------

    fn process_sdn() -> CompileResult:
        val backend_port = self.ctx.backend
        val results: Dict<text, Any> = {}

        for name in self.ctx.hir_modules.keys():
            val hir_module = self.ctx.hir_modules[name]
            match backend_port.run_fn(hir_module):
                case Ok(value):
                    results[name] = value
                case Err(e):
                    return CompileResult.RuntimeError("SDN error in {name}: {e.message}")

        CompileResult.Success(results)

    # --------------------------------------------------------------------------
    # Mode: Interpret
    # --------------------------------------------------------------------------

    fn interpret() -> CompileResult:
        self.interpret_pipeline()

    fn interpret_pipeline() -> CompileResult:
        val log = self.ctx.logger
        val backend_port = self.ctx.backend
        var last_result: Any = BackendResult.Unit
        var has_result = false

        if self.ctx.sources.len() == 0:
            return CompileResult.RuntimeError("No source file specified for interpret mode")

        log_debug("interpret: running {self.ctx.sources.len()} modules through compiler frontend output")

        var src_idx = 0
        while src_idx < self.ctx.sources.len():
            val source = self.ctx.sources[src_idx]
            val name = source.module_name
            val hir_module = self.ctx.hir_modules[name]
            if hir_module == nil:
                src_idx = src_idx + 1
                continue

            match backend_port.run_fn(hir_module):
                case Ok(value):
                    last_result = value
                    has_result = true
                case Err(e):
                    return CompileResult.RuntimeError("Interpret error in {name}: {e.message}")
            src_idx = src_idx + 1

        if has_result:
            return CompileResult.Success(last_result)
        CompileResult.Success(BackendResult.Unit)

    fn run_module(backend: Backend, module: HirModule) -> CompileResult:
        match backend.process_module(module):
            case Ok(value): CompileResult.Success(value)
            case Err(e): CompileResult.RuntimeError(e)

    # --------------------------------------------------------------------------
    # Mode: JIT Compile and Run
    # --------------------------------------------------------------------------

    me jit_compile_and_run() -> CompileResult:
        # Lower to MIR
        if not self.lower_to_mir():
            val first_err = self.ctx.errors.first()
            val msg = if first_err != nil: first_err else: "MIR lowering failed"
            return CompileResult.CodegenError(msg)

        # Evict HIR modules (no longer needed after MIR lowering)
        if self.ctx.options.low_memory:
            self.ctx.evict_hir()

        # Borrow checking
        if not self.borrow_check():
            return CompileResult.BorrowError(self.ctx.errors)

        # Process async functions (generate state machines for await/yield)
        val _async_state_machines = self.process_async()

        # Optimize MIR (speed optimization for JIT)
        self.optimize_mir(optimizationconfig_speed())

        # AOP weaving (after optimization, before codegen)
        self.weave_aop()

        # Debug trace injection (after AOP, before codegen)
        self.apply_debug_trace()

        # JIT compile
        var pipeline = CodegenPipeline.jit()
        var last_compiled: CompiledModule? = nil

        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            match pipeline.compile_module(mir_module):
                case Ok(compiled):
                    last_compiled = Some(compiled)
                case Err(e):
                    return CompileResult.CodegenError("JIT compile error in {name}: {e.message}")

        if last_compiled == nil:
            return CompileResult.RuntimeError("No modules compiled")

        val compiled = last_compiled.unwrap()
        match compiled.call("main", []):
            case Ok(result):
                compiled.cleanup()
                CompileResult.Success(result)
            case Err(e):
                compiled.cleanup()
                CompileResult.RuntimeError(e.message)

    # --------------------------------------------------------------------------
    # Mode: SMF Exec (load and execute pre-compiled SMF)
    # --------------------------------------------------------------------------

    me execute_smf() -> CompileResult:
        """Load a pre-compiled SMF file and execute its main function.

        Uses JIT infrastructure to map SMF code into executable memory.
        Falls back to interpret mode if SMF loading fails.
        """
        val smf_path = self.ctx.options.input_files[0]
        log_debug("execute_smf: loading {smf_path}")

        # Use JIT pipeline to load and execute the SMF
        var pipeline = CodegenPipeline.jit()
        match pipeline.load_smf_and_execute(smf_path):
            case Ok(result):
                CompileResult.Success(result)
            case Err(e):
                # Fallback: log and return error (caller can retry with interpret)
                log_warn("SMF exec failed: {e}, falling back")
                CompileResult.RuntimeError("SMF execution failed: {e}")

    # --------------------------------------------------------------------------
    # Mode: AOT Compile
    # --------------------------------------------------------------------------

    me aot_compile() -> CompileResult:
        val log = self.ctx.logger

        # Lower to MIR
        log_phase("aot:lower_to_mir:start")
        var mir_ok = false
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            val (next_ctx, ok) = bootstrap_lower_to_mir_context(self.ctx)
            self.ctx = next_ctx
            mir_ok = ok
        else:
            mir_ok = self.lower_to_mir()
        if not mir_ok:
            for err in self.ctx.errors:
                log_error("MIR error: {err}")
            val first_err = self.ctx.errors.first()
            val msg = if first_err != nil: first_err else: "MIR lowering failed"
            return CompileResult.CodegenError(msg)
        log_phase("aot:lower_to_mir:done")

        # Evict HIR modules (no longer needed after MIR lowering)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting HIR modules")
            self.ctx.evict_hir()

        # Borrow checking
        log_phase("aot:borrow_check:start")
        if not self.borrow_check():
            for err in self.ctx.errors:
                log_error("Borrow error: {err}")
            return CompileResult.BorrowError(self.ctx.errors)
        log_phase("aot:borrow_check:done")

        # Process async functions (generate state machines for await/yield)
        log_phase("aot:process_async:start")
        val async_state_machines = self.process_async()
        log_phase("aot:process_async:done")

        # Optimize MIR (use optimization level from options)
        log_phase("aot:optimize_mir:start")
        val skip_mir_opt = rt_env_get("SIMPLE_BOOTSTRAP_SKIP_MIR_OPT") ?? ""
        if skip_mir_opt == "1":
            eprint("[BOOTSTRAP-PHASE] aot:optimize_mir:skipped")
        else:
            val opt_config = self.get_optimization_config()
            self.optimize_mir(opt_config)
        log_phase("aot:optimize_mir:done")

        # AOP weaving (after optimization, before codegen)
        log_phase("aot:weave_aop:start")
        self.weave_aop()
        log_phase("aot:weave_aop:done")

        # Debug trace injection (after AOP, before codegen)
        log_phase("aot:debug_trace:start")
        self.apply_debug_trace()
        log_phase("aot:debug_trace:done")

        # Determine output file
        log_phase("aot:output:start")
        val output = self.ctx.options.output_file ?? "a.out"
        log_phase("aot:output:done")

        # If backend is C, write C++ source instead of compiling to native
        log_phase("aot:backend_name:start")
        val backend_name = self.ctx.options.backend
        log_phase("aot:backend_name:done")
        if backend_name == "c" or backend_name == "cpp" or backend_name == "ccodegen":
            return self.compile_to_c(output)

        # If backend is CUDA/PTX, emit PTX assembly
        if backend_name == "cuda" or backend_name == "ptx":
            return self.compile_to_cuda(output)

        # If backend is VHDL, emit VHDL source instead of SMF/native output
        if backend_name == "vhdl":
            return self.compile_to_vhdl(output)

        if (rt_env_get("SIMPLE_BOOTSTRAP_DIRECT_IR") ?? "") == "1":
            log_phase("aot:bootstrap_native_dispatch")
            return bootstrap_compile_to_native_local(self.ctx, backend_name, output)

        # Dispatch based on output format
        log_phase("aot:format:start")
        val format = self.ctx.options.output_format
        log_phase("aot:format:done")
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            log_phase("aot:bootstrap_native_context_dispatch")
            return bootstrap_compile_context_to_native_local(self.ctx, backend_name, output)
        match format:
            case OutputFormat.Smf:
                return self.compile_to_smf(output)
            case OutputFormat.SelfContained:
                return self.compile_to_self_contained(output)
            case OutputFormat.Both:
                # Compile native (LLVM) first, then SMF (Cranelift) to cache
                val native_result = self.compile_to_native(output)
                if not native_result.is_success():
                    return native_result
                # SMF goes to build/smf/ cache directory
                use compiler.driver.cache.cache_validator.{source_to_cache_path}
                use compiler.driver.watcher.smf_manifest.{update_smf_manifest_entry}
                val source_path = self.ctx.options.input_files[0]
                val smf_cache_path = source_to_cache_path(source_path, "build/smf", ".smf")
                val smf_result = self.compile_to_smf(smf_cache_path)
                if smf_result.is_success():
                    extern fn rt_hash_text(s: text) -> i64
                    extern fn rt_file_read_text(path: text) -> text
                    val smf_opt_level = compileoptions_effective_mir_opt_level(self.ctx.options)
                    val src = rt_file_read_text(source_path) ?? ""
                    val src_hash = rt_hash_text(src)
                    update_smf_manifest_entry(
                        source_path,
                        smf_cache_path,
                        src_hash,
                        self.ctx.options.backend,
                        smf_opt_level,
                        self.ctx.options.release,
                        self.ctx.options.debug_info,
                        self.ctx.options.gc_off,
                        self.ctx.options.profile,
                        self.ctx.options.allowed_families
                    )
                return CompileResult.Success(output)
            case _:
                # Native (default)
                return self.compile_to_native(output)

    # --------------------------------------------------------------------------
    # MIR Lowering
    # --------------------------------------------------------------------------

    me lower_to_mir() -> bool:
        val skip_mir_lower = rt_env_get("SIMPLE_BOOTSTRAP_SKIP_MIR_LOWER") ?? ""
        if skip_mir_lower == "1":
            print "[bootstrap] skipping MIR lowering"
            var skip_idx = 0
            while skip_idx < self.ctx.sources.len():
                val src_skip = self.ctx.sources[skip_idx]
                val name_skip = src_skip.module_name
                val mir_skip = MirModule(
                    name: name_skip,
                    functions: {},
                    statics: {},
                    constants: {},
                    types: {}
                )
                self.ctx.mir_modules[name_skip] = mir_skip
                if _driver_is_bootstrap_entry_source(src_skip.path, name_skip):
                    self.ctx.bootstrap_entry_mir = Some(mir_skip)
                skip_idx = skip_idx + 1
            return self.ctx.errors.len() == 0

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[driver-mir] bootstrap fixed:start"
            var bootstrap_lowering = MirLowering.new(SymbolTable.new())
            var bootstrap_mir = bootstrap_lowering.lower_module(self.ctx.hir_modules["app.cli.bootstrap_main"])
            self.ctx.bootstrap_entry_mir = Some(bootstrap_mir)
            print "[driver-mir] bootstrap fixed:done"
            return self.ctx.errors.len() == 0

        if self.ctx.sources.len() > 0:
            var direct_idx = 0
            var direct_lowering = MirLowering(
                builder: MirBuilder(
                    module: MirModule(
                        name: "",
                        functions: {},
                        statics: {},
                        constants: {},
                        types: {}
                    ),
                    current_function: nil,
                    current_block: BlockId(id: 0),
                    next_local_id: 0,
                    next_block_id: 1,
                    locals: [],
                    blocks: [],
                    instructions: []
                ),
                symbols: SymbolTable.new(),
                local_map: {},
                loop_stack: [],
                errors: [],
                field_map: {}
            )
            while direct_idx < self.ctx.sources.len():
                val src_direct = self.ctx.sources[direct_idx]
                val name_direct = src_direct.module_name
                val mir_direct = if _driver_is_bootstrap_entry_source(src_direct.path, name_direct):
                    print "[driver-mir] bootstrap lower:start"
                    var lowered_entry = direct_lowering.lower_module(self.ctx.hir_modules[name_direct])
                    lowered_entry.name = name_direct
                    print "[driver-mir] bootstrap lower:done"
                    lowered_entry
                else:
                    MirModule(
                        name: name_direct,
                        functions: {},
                        statics: {},
                        constants: {},
                        types: {}
                    )
                self.ctx.mir_modules[name_direct] = mir_direct
                if _driver_is_bootstrap_entry_source(src_direct.path, name_direct):
                    self.ctx.bootstrap_entry_mir = Some(mir_direct)
                direct_idx = direct_idx + 1
            return self.ctx.errors.len() == 0

        var lowering = MirLowering(
            builder: MirBuilder(
                module: MirModule(
                    name: "",
                    functions: {},
                    statics: {},
                    constants: {},
                    types: {}
                ),
                current_function: nil,
                current_block: BlockId(id: 0),
                next_local_id: 0,
                next_block_id: 1,
                locals: [],
                blocks: [],
                instructions: []
            ),
            symbols: SymbolTable.new(),
            local_map: {},
            loop_stack: [],
            errors: [],
            field_map: {}
        )

        # BUG-001 diagnostic: log module count entering MIR lowering
        log_debug("[lower_to_mir] lowering to MIR")
        var lower_trace_count = 0
        if self.ctx.sources.len() <= 0:
            for hir_module in self.ctx.hir_modules:
                val name = hir_module.name
                var mir_module = lowering.lower_module(hir_module)
                mir_module.name = name
                self.ctx.mir_modules[name] = mir_module
                if name == "app.cli.bootstrap_main":
                    self.ctx.bootstrap_entry_mir = Some(mir_module)
            log_debug("[lower_to_mir] MIR done")
            return self.ctx.errors.len() == 0
        for src3 in self.ctx.sources:
            val name = src3.module_name
            val mir_module = MirModule(
                name: name,
                functions: {},
                statics: {},
                constants: {},
                types: {}
            )
            self.ctx.mir_modules[name] = mir_module
            if name == "app.cli.bootstrap_main":
                self.ctx.bootstrap_entry_mir = Some(mir_module)
            source_idx = source_idx + 1

        log_debug("[lower_to_mir] MIR done")
        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Borrow Checking
    # --------------------------------------------------------------------------

    me borrow_check() -> bool:
        """Run borrow checking on all MIR modules.

        Uses the NLL (Non-Lexical Lifetimes) borrow checker to detect:
        - Conflicting borrows (E0502)
        - Use after move
        - Assignment while borrowed
        Errors include relatedInformation for first borrow location.
        """
        if self.ctx.options.no_borrow_check:
            log_debug("borrow checking skipped (--no-borrow-check)")
            return true
        log_debug("running borrow check")
        var checker = BorrowChecker.create()
        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            val all_errors = check_mir_module(mir_module)
            for err in all_errors:
                self.ctx.add_error(_format_nll_error(err))
        self.ctx.errors.len() == 0

    fn format_borrow_error(err: NLLError) -> text:
        """Format a borrow error for display."""
        _format_nll_error(err)

    # --------------------------------------------------------------------------
    # Async Processing
    # --------------------------------------------------------------------------

    me process_async() -> Dict<text, AsyncStateMachine>:
        """Process async functions and generate state machines.

        This is called after MIR lowering to analyze and transform async functions.
        State machines are used by codegen for async execution.
        """
        val log = self.ctx.logger
        log_debug("processing async functions")

        val state_machines = process_async_mir(self.ctx.mir_modules)

        log_debug("generated async state machines")
        state_machines

    # --------------------------------------------------------------------------
    # MIR Optimization
    # --------------------------------------------------------------------------

    me optimize_mir(config: OptimizationConfig):
        """Apply MIR optimization passes to all modules."""
        val log = self.ctx.logger
        log_debug("optimizing MIR modules")

        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            val optimized = optimize_mir_module(mir_module, config)
            # Direct mutation (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.mir_modules[name] = optimized

    # --------------------------------------------------------------------------
    # AOP Weaving
    # --------------------------------------------------------------------------

    me weave_aop():
        """Apply AOP weaving to all MIR modules using advice from HIR modules."""
        # Collect all AOP advices from HIR modules
        var all_advices: [HirAopAdvice] = []
        for name in self.ctx.hir_modules.keys():
            val hir_mod = self.ctx.hir_modules[name]
            for advice in hir_mod.aop_advices:
                all_advices.push(advice)

        if all_advices.len() == 0:
            log_debug("AOP weaving: no advice declarations found, skipping")
            return

        # Validate predicates and advice forms
        for advice in all_advices:
            val pred_err = validate_predicate(advice.predicate_text)
            if pred_err.len() > 0:
                self.ctx.errors.push("[AOP] {pred_err} in advice '{advice.advice_function}'")
            val form_err = validate_advice_form(advice.form)
            if form_err.len() > 0:
                self.ctx.errors.push("[AOP] {form_err} in advice '{advice.advice_function}'")

        # Build weaving config from collected advices
        val config = weavingconfig_from_hir_advices(all_advices)
        if not config.enabled:
            return

        val all_rules = weavingconfig_all_rules(config)
        val rule_count = all_rules.len()
        log_debug("AOP weaving")

        # Detect advice conflicts (E1504, E1506)
        val conflicts = detect_advice_conflicts(all_rules)
        for conflict in conflicts:
            if conflict.is_error():
                self.ctx.errors.push("[AOP] {conflict.message}")
            elif conflict.is_warning():
                self.ctx.warnings.push("[AOP] {conflict.message}")

        # Weave each MIR function
        for mod_name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[mod_name]
            for func in mir_module.functions:
                # Extract block info for AOP matching
                val blocks = extract_mir_block_info(func.blocks)
                # Run weaving analysis
                val result = weave_function(config, func.name, mod_name, [], [], blocks)
                # Apply advice insertions to MIR
                if result.advices_inserted > 0:
                    val woven_func = apply_weaving_result(func, result)
                    mir_module.functions[func.name] = woven_func
                # Report diagnostics
                for diag in result.diagnostics:
                    if diag.is_error():
                        self.ctx.errors.push("[AOP] {diag.message}")
                    elif diag.is_warning():
                        self.ctx.warnings.push("[AOP] {diag.message}")

    # --------------------------------------------------------------------------
    # Debug Trace Injection
    # --------------------------------------------------------------------------

    me apply_debug_trace():
        """Apply semantic trace injection to all MIR modules.

        Reads self.ctx.options.debug_trace_level (text).  If empty or
        "none", this is a no-op.  Otherwise injects __spl_trace_* calls
        into every MIR function, gated by the requested level."""
        val level = self.ctx.options.debug_trace_level
        if level == "" or level == "none":
            return

        log_debug("debug trace injection: level={level}")
        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            val instrumented = inject_debug_trace(mir_module, level)
            self.ctx.mir_modules[name] = instrumented

    fn get_optimization_config() -> OptimizationConfig:
        """Get optimization config from compiler options."""
        optimizationconfig_speed()

pub fn compiler_driver_create(options: CompileOptions) -> CompilerDriver:
    val ctx = CompileContext.create(options)
    CompilerDriver(ctx: ctx)

pub fn compiler_driver_run_compile(driver: CompilerDriver) -> CompileResult:
    driver.compile()

# Stable facade helpers for `use compiler.driver.{...}` callers.
# These mirror driver_api.spl directly because direct script resolution does
# not reliably surface new driver_api exports through the package facade.
pub fn generate_headers(path: text, output_dir: text, lib_name: text, emit_c: bool, emit_cpp: bool) -> CompileResult:
    var options = driver_core_compile_options_default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    val driver = CompilerDriver.create(options)
    val result = driver.compile()

    match result:
        case CompileResult.Success(mir_module_any):
            if mir_module_any.?:
                val mir_module = mir_module_any as MirModule
                val gen = HeaderGenerator.create(mir_module)

                if not gen.has_exports():
                    print "[header-gen] Warning: no @export(\"C\") items found"
                    return result

                # Collect export names for validation
                var export_fn_names: [text] = []
                val fn_keys = mir_module.functions.keys()
                var fn_ki = 0
                while fn_ki < fn_keys.len():
                    val func: MirFunction = mir_module.functions[fn_keys[fn_ki]]
                    if func.is_export_c:
                        val fn_export = if func.export_name != "": func.export_name else: "spl_" + func.name
                        export_fn_names.push(fn_export)
                    fn_ki = fn_ki + 1
                var export_type_names: [text] = []
                val td_keys = mir_module.types.keys()
                var td_ki = 0
                while td_ki < td_keys.len():
                    val td: MirTypeDef = mir_module.types[td_keys[td_ki]]
                    if td.is_export_c:
                        val t_export = if td.export_name != "": td.export_name else: "spl_" + td.name
                        export_type_names.push(t_export)
                    td_ki = td_ki + 1

                rt_dir_create(output_dir, true)

                if emit_c:
                    val c_header = gen.generate_c_header(lib_name)
                    val c_path = rt_path_join(output_dir, lib_name + ".h")
                    rt_file_write_text(c_path, c_header)
                    print "[header-gen] Generated C header: {c_path}"

                    # Validate generated C header
                    val c_validation: ValidationResult = validate_generated_header(c_header, export_fn_names, export_type_names)
                    if not c_validation.is_valid:
                        var ei = 0
                        while ei < c_validation.errors.len():
                            log_warn("[header-gen] C header validation: {c_validation.errors[ei]}")
                            ei = ei + 1

                if emit_cpp:
                    val cpp_header = gen.generate_cpp_header(lib_name)
                    val cpp_path = rt_path_join(output_dir, lib_name + ".hpp")
                    rt_file_write_text(cpp_path, cpp_header)
                    print "[header-gen] Generated C++ header: {cpp_path}"

                    # Validate generated C++ header
                    val cpp_validation: ValidationResult = validate_generated_header(cpp_header, export_fn_names, export_type_names)
                    if not cpp_validation.is_valid:
                        var ei = 0
                        while ei < cpp_validation.errors.len():
                            log_warn("[header-gen] C++ header validation: {cpp_validation.errors[ei]}")
                            ei = ei + 1
            result
        case _:
            result

pub fn aot_shared_library(path: text, output: text) -> CompileResult:
    use compiler.tools.header_gen.shared_lib_flags.{get_shared_lib_flags}

    var options = driver_core_compile_options_default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    val cpp_output = output + ".simple_public.cpp"
    val source_obj = output + ".simple_public.o"
    val runtime_obj = output + ".runtime.o"
    options.output_file = Some(cpp_output)
    options.backend = "c"
    options.release = true
    options.optimize = true
    val driver = CompilerDriver.create(options)
    val compile_result = driver.compile()

    match compile_result:
        case CompileResult.Success(_):
            val flags = get_shared_lib_flags()

            var source_args: [text] = []
            var i = 0
            while i < flags.compile_flags.len():
                source_args.push(flags.compile_flags[i])
                i = i + 1
            i = 0
            while i < flags.defines.len():
                source_args.push("-D" + flags.defines[i])
                i = i + 1
            source_args.push("-c")
            source_args.push(cpp_output)
            source_args.push("-o")
            source_args.push(source_obj)

            val (src_out, src_err, src_code) = rt_process_run("c++", source_args)
            if src_code != 0:
                rt_file_delete(cpp_output)
                return CompileResult.CodegenError(_combine_process_error("C++ object compilation failed", src_out, src_err))

            var runtime_args: [text] = []
            i = 0
            while i < flags.compile_flags.len():
                runtime_args.push(flags.compile_flags[i])
                i = i + 1
            i = 0
            while i < flags.defines.len():
                runtime_args.push("-D" + flags.defines[i])
                i = i + 1
            runtime_args.push("-c")
            runtime_args.push("src/runtime/runtime.c")
            runtime_args.push("-I")
            runtime_args.push("src/runtime")
            runtime_args.push("-o")
            runtime_args.push(runtime_obj)

            val (rt_out, rt_err, rt_code) = rt_process_run("cc", runtime_args)
            if rt_code != 0:
                rt_file_delete(cpp_output)
                rt_file_delete(source_obj)
                return CompileResult.CodegenError(_combine_process_error("Runtime object compilation failed", rt_out, rt_err))

            var link_args: [text] = []
            i = 0
            while i < flags.link_flags.len():
                link_args.push(flags.link_flags[i])
                i = i + 1
            link_args.push(source_obj)
            link_args.push(runtime_obj)
            link_args.push("-o")
            link_args.push(output)

            val (link_out, link_err, link_code) = rt_process_run("c++", link_args)
            rt_file_delete(cpp_output)
            rt_file_delete(source_obj)
            rt_file_delete(runtime_obj)

            if link_code != 0:
                return CompileResult.CodegenError(_combine_process_error("Shared library link failed", link_out, link_err))

            # Diagnostic: check if @export("C") symbols appear in compiled shared library
            # Use nm -D to list dynamic symbols, and verify spl_ prefixed entries exist
            val (nm_out, _nm_err, nm_code) = rt_process_run("nm", ["-D", output])
            if nm_code == 0:
                # Read the generated C++ source to extract exported symbol names
                # Look for function names that follow the spl_ convention
                if not nm_out.contains("spl_library_init"):
                    log_warn("[shared-lib] spl_library_init not found in dynamic symbols — @export(\"C\") symbols may be missing")
                if not nm_out.contains("spl_library_shutdown"):
                    log_warn("[shared-lib] spl_library_shutdown not found in dynamic symbols — @export(\"C\") symbols may be missing")

            CompileResult.Success(output)
        case _:
            compile_result

fn _combine_process_error(prefix: text, stdout: text, stderr: text) -> text:
    var detail = stderr.trim()
    if detail == "":
        detail = stdout.trim()
    if detail == "":
        return prefix
    prefix + ": " + detail

