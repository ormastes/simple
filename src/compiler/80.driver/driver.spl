extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_path_join(a: text, b: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn compiler__driver__driver__CompilerDriver_dot_compile(driver: CompilerDriver) -> CompileResult

# Lightweight logging helpers (module-level free functions for simplicity)
fn log_debug(msg: text):
    ()
fn log_trace(msg: text):
    ()
fn log_info(msg: text):
    ()
fn log_warn(msg: text):
    print "[WARN] {msg}"
fn log_error(msg: text):
    print "[ERROR] {msg}"

class CheckBackendImpl(Backend):
    fn name() -> text:
        "check"

    fn is_allowed(op: text) -> bool:
        # Allow everything for type checking
        true

    fn process_module(module: HirModule) -> Result<Any, text>:
        # Just validate, don't execute
        Ok(nil)

    fn eval_expr(expr: HirExpr, env: Environment) -> Result<Value, text>:
        # Don't evaluate, just return unit
        Ok(Value.Unit)

    fn exec_stmt(stmt: HirStmt, env: Environment) -> Result<Value, text>:
        Ok(Value.Unit)

# ------------------------------------------------------------------------------
# Source loading helpers
# ------------------------------------------------------------------------------

# Directories to skip during source collection
val _skip_dirs = ["test", "tests", "doc", "docs", "examples", "verification", "resources", "scripts", "build"]

fn _driver_should_skip_dir(name: text) -> bool:
    var i = 0
    while i < _skip_dirs.len():
        if name == _skip_dirs[i]:
            return true
        i = i + 1
    false

fn _driver_collect_sources(p: text) -> [SourceFile]:
    """Collect source files from a path (file or directory). Returns list of SourceFile."""
    var result: [SourceFile] = []
    if p.ends_with(".spl"):
        # It's a source file
        if p.ends_with("/check.spl") or p.ends_with("\\check.spl"):
            return result
        if p.contains("/test/") or p.contains("/tests/") or p.contains("/doc/") or p.contains("/examples/") or p.contains("/verification/"):
            return result
        val content = rt_file_read_text(p) ?? ""
        if content != "":
            var mod_path = p
            if mod_path.starts_with("src/"):
                mod_path = mod_path.substring(4)
            mod_path = mod_path.replace(".spl", "")
            mod_path = mod_path.replace(".sdn", "")
            val module_name = mod_path.replace("/", ".")
            result = result.push(SourceFile(
                path: p,
                content: content,
                module_name: module_name
            ))
    else:
        # Treat as directory — depth-first traversal with pruning
        val entries = rt_dir_list(p) ?? []
        var idx = 0
        while idx < entries.len():
            val child = entries[idx]
            val child_path = "{p}/{child}"
            if _driver_should_skip_dir(child):
                idx = idx + 1
                continue
            val child_sources = _driver_collect_sources(child_path)
            for s in child_sources:
                result = result.push(s)
            idx = idx + 1
    result

fn _driver_collect_sources_via_find(paths: [text]) -> [SourceFile]:
    var result: [SourceFile] = []
    val cmd = "find src/app src/lib src/compiler src/runtime -type f -name '*.spl' 2>/dev/null"
    val (stdout, _, code) = rt_process_run("sh", ["-c", cmd])
    if code != 0 or stdout == "":
        return result
    val lines = stdout.split("\n")
    for line in lines:
        val path = line.trim()
        if path == "":
            continue
        if path.contains("/test/") or path.contains("/tests/") or path.contains("/doc/") or path.contains("/examples/") or path.contains("/verification/"):
            continue
        val loaded = _driver_collect_sources(path)
        for s in loaded:
            result = result.push(s)
    result

# ------------------------------------------------------------------------------
# Structured Error Formatting Helpers
# ------------------------------------------------------------------------------
# Errors are encoded as: "line:col: message" with optional related info
# appended as "|||RELATED:line:col:message" segments and optional help
# appended as "|||HELP:message".

fn _format_type_infer_error(err: TypeInferError) -> text:
    """Format a TypeInferError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    # Add related information based on error variant
    match err:
        case TypeInferError.Mismatch(expected, found, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if found.span.line > 0 and found.span.line != s.line:
                result = result + "|||RELATED:{found.span.line}:{found.span.col}:found type originates here"
        case TypeInferError.OccursCheck(var_id, ty, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:recursive type reference here"
            result = result + "|||HELP:break the recursive type by using an explicit type annotation"
        case TypeInferError.TraitNotImplemented(ty, trait_name, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:type that needs to implement '{trait_name}'"
            result = result + "|||HELP:add an impl block: impl {trait_name} for {ty.kind}"
        case TypeInferError.DimensionError(dim_err):
            for note in dim_err.notes:
                if note.span.?:
                    val note_span = note.span.unwrap()
                    result = result + "|||RELATED:{note_span.line}:{note_span.col}:{note.message}"
            if dim_err.help.?:
                result = result + "|||HELP:{dim_err.help.unwrap()}"
        case TypeInferError.Undefined(name, s):
            result = result + "|||HELP:check spelling or add an import for '{name}'"
        case TypeInferError.Other(message, s):
            pass_do_nothing
    result

fn _format_nll_error(err: NLLError) -> text:
    """Format an NLLError into a structured error string with related info."""
    val primary = if err.has_primary_span: err.primary_span else: 0
    var result = "{primary}:1: {err.message}"
    for span_label in err.secondary_spans:
        result = result + "|||RELATED:{span_label.span}:1:{span_label.label}"
    if err.has_help:
        result = result + "|||HELP:{err.help}"
    result

fn _format_coherence_error(err: CoherenceError) -> text:
    """Format a CoherenceError into a structured error string."""
    val msg = err.message()
    "1:1: {msg}"

fn _format_trait_error(err: TraitError) -> text:
    """Format a TraitError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    match err:
        case TraitError.MissingMethod(trait_, method, ty, s):
            result = result + "|||HELP:add method '{method}' to the impl block"
        case TraitError.UndefinedTrait(name, s):
            result = result + "|||HELP:check spelling or add an import for the trait"
        case TraitError.Unsatisfied(obligation):
            if obligation.span.line > 0:
                result = result + "|||RELATED:{obligation.span.line}:{obligation.span.col}:required by this bound"
        case TraitError.MissingAssocType(trait_, assoc_name, ty, s):
            result = result + "|||HELP:add 'type {assoc_name} = ...' to the impl block"
        case TraitError.AssocTypeMismatch(trait_, assoc_name, expected, actual, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if actual.span.line > 0:
                result = result + "|||RELATED:{actual.span.line}:{actual.span.col}:actual type found here"
        case _:
            pass_do_nothing
    result

# ------------------------------------------------------------------------------
# Compiler Driver
# ------------------------------------------------------------------------------

class CompilerDriver:
    ctx: CompileContext

    static fn create(options: CompileOptions) -> CompilerDriver:
        val ctx = CompileContext.create(options)
        CompilerDriver(ctx: ctx)

    static fn run_compile(driver: CompilerDriver) -> CompileResult:
        compiler__driver__driver__CompilerDriver_dot_compile(driver)

    # --------------------------------------------------------------------------
    # Main compilation entry point
    # --------------------------------------------------------------------------

    me compile() -> CompileResult:
        val log = self.ctx.logger

        # Phase 1: Load source files
        if not self.load_sources_impl():
            log_error("phase 1 FAILED")
            return CompileResult.ParseError(self.ctx.errors)

        # Phase 2: Parse all sources
        log_debug("phase 2: parsing...")
        if not self.parse_all_impl():
            log_error("phase 2 FAILED")
            return CompileResult.ParseError(self.ctx.errors)
        log_debug("phase 2 done")

        # Evict raw source text (no longer needed after parsing)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting source text")
            self.ctx.evict_sources()

        # Phase 3: Lower to HIR, resolve methods, and type check (combined loop)
        log_trace("BEFORE phase 3: hir_modules count = {self.ctx.hir_modules.keys().len()}")
        val analyze_ok = self.lower_and_check_impl()
        log_trace("AFTER phase 3: hir_modules count = {self.ctx.hir_modules.keys().len()}")
        if not analyze_ok:
            log_error("phase 3 FAILED")
            # Determine error type from first error
            if self.ctx.errors.len() > 0:
                val first_error = self.ctx.errors[0]
                if first_error.contains("Method resolution"):
                    return CompileResult.ResolveError(self.ctx.errors)
            return CompileResult.TypeError(self.ctx.errors)
        log_debug("phase 3 done")

        # Evict AST modules (no longer needed after HIR lowering)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting AST modules")
            self.ctx.evict_ast()

        # Phase 4: Monomorphization (specialize generic functions)
        log_debug("phase 4: monomorphization...")
        val mono_ok = self.monomorphize_impl()
        if not mono_ok:
            log_error("phase 4 FAILED")
            return CompileResult.TypeError(self.ctx.errors)
        log_debug("phase 4 done")

        # Phase 5: Mode-specific processing
        log_debug("phase 5: mode-specific processing...")
        match self.ctx.options.mode:
            case CompileMode.Check:
                log_debug("check mode")
                return CompileResult.Success(nil)

            case CompileMode.Sdn:
                log_debug("sdn mode")
                return self.process_sdn()

            case CompileMode.Interpret:
                log_debug("interpret mode")
                return self.interpret()

            case CompileMode.Jit:
                log_debug("jit mode")
                return self.jit_compile_and_run()

            case CompileMode.Aot:
                log_debug("aot mode")
                return self.aot_compile()

            case CompileMode.SmfExec:
                log_debug("smf_exec mode — loading pre-compiled SMF")
                return self.execute_smf()

        log_warn("no mode matched, falling through")
        CompileResult.Success(nil)

    # --------------------------------------------------------------------------
    # Phase 1: Load sources (with optional cache-aware skipping)
    # --------------------------------------------------------------------------

    # Check if a source file has a fresh SHB cache entry and can skip full parse
    # for import-only modules. Returns true if the file's SHB is fresh.
    fn check_shb_cache(source_path: text) -> bool:
        use compiler.driver.watcher.watcher_client.{check_shb_freshness}
        val result = check_shb_freshness(source_path, ".build/headers")
        result.status == CACHE_FRESH

    me load_sources_impl() -> bool:
        # Build sources list locally to avoid chained method call issue
        # (self.ctx.sources.push() doesn't persist — interpreter limitation)
        var all_sources: [SourceFile] = []

        # Start with user-provided roots
        var i = 0
        var has_project_source = false
        while i < self.ctx.options.input_files.len():
            val input_path = self.ctx.options.input_files[i]
            val loaded = _driver_collect_sources(input_path)
            for s in loaded:
                all_sources = all_sources.push(s)
            if input_path.starts_with("src/"):
                has_project_source = true
            i = i + 1

        # Add core source roots only when compiling project sources (self-hosted build)
        if has_project_source:
            val paths = ["src/app", "src/lib", "src/compiler", "src/runtime"]
            val bulk_loaded = _driver_collect_sources_via_find(paths)
            if bulk_loaded.len() > 0:
                for s in bulk_loaded:
                    all_sources = all_sources.push(s)
            else:
                for p in paths:
                    val loaded = _driver_collect_sources(p)
                    for s in loaded:
                        all_sources = all_sources.push(s)

        # Single assignment avoids chained push issue
        self.ctx.sources = all_sources

        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Phase 2: Parse
    # --------------------------------------------------------------------------

    me parse_all_impl() -> bool:
        val log = self.ctx.logger
        val sources = self.ctx.sources
        log_debug("parsing {sources.len()} sources")
        var src_idx = 0
        while src_idx < sources.len():
            val source = sources[src_idx]
            log_trace("parsing: {source.path} (module={source.module_name}, len={source.content.len()})")
            val module = self.parse_source(source)
            self.ctx.modules[source.module_name] = module
            log_trace("stored module, total={self.ctx.modules.keys().len()}")
            src_idx = src_idx + 1

        log_debug("parsing done, modules={self.ctx.modules.keys().len()}")
        self.ctx.errors.len() == 0

    fn parse_source(source: SourceFile) -> Module:
        parse_full_frontend(source.content, source.path, source.module_name, self.ctx.logger)

    # --------------------------------------------------------------------------
    # Phase 3: Combined HIR Lowering + Method Resolution + Type Checking
    # --------------------------------------------------------------------------
    #
    # This combined implementation processes each module through all three
    # phases in a single loop, avoiding redundant iterations and improving
    # performance on large codebases.

    me lower_and_check_impl() -> bool:
        val log = self.ctx.logger
        var lowering = hirlowering_new()

        val module_names = self.ctx.modules.keys()
        log_debug("lowering {module_names.len()} modules to HIR")
        for name in module_names:
            log_trace("processing module: {name}")
            val module = self.ctx.modules[name]
            if module == nil:
                log_error("module is nil for key {name}")
                continue

            # Step 1: Lower to HIR
            val hir_module = lowering.lower_module(module)
            log_trace("HIR lowered for {name}")

            # Step 2: Method resolution (UFCS)
            val (resolved_module, resolve_errors) = resolve_methods(hir_module)
            log_trace("methods resolved, errors={resolve_errors.len()}")

            # Collect method resolution errors
            var err_idx = 0
            while err_idx < resolve_errors.len():
                val err = resolve_errors[err_idx]
                self.ctx.add_error("Method resolution error in {name}: {err.message}")
                err_idx = err_idx + 1

            # Step 2b: Visibility checking (cross-module access validation)
            val vis_warnings = check_module_visibility(resolved_module, name)
            log_trace("visibility checked, warnings={vis_warnings.len()}")
            for vis_warn in vis_warnings:
                log_debug("visibility warning in {name}: {vis_warn}")

            # Step 2c: Evaluate static assertions
            for static_assert in resolved_module.static_asserts:
                val result = eval_static_assert(resolved_module, static_assert)
                match result:
                    case Err(err):
                        val msg = match err:
                            case ConstEvalError.NotConstant(expr, _):
                                "static assert condition is not constant: {expr}"
                            case ConstEvalError.TypeError(expected, got, _):
                                "static assert condition must be bool, got {got}"
                            case ConstEvalError.AssertionFailed(message, _):
                                if message.?:
                                    "static assertion failed: {message}"
                                else:
                                    "static assertion failed"
                            case _:
                                "static assert evaluation error"
                        self.ctx.add_error("Error in {name}: {msg}")
                    case _:
                        pass
            log_trace("static assertions evaluated")

            # Step 3: Type checking (HM inference)
            # Type inference only runs in Check mode to surface diagnostics.
            val _run_type_check = match self.ctx.options.mode:
                case CompileMode.Check: true
                case _: false
            if _run_type_check:
                var infer_ctx = HmInferContext.with_builtins()
                infer_ctx.infer_module(resolved_module)
                for infer_err in infer_ctx.errors:
                    self.ctx.add_error(_format_type_infer_error(infer_err))
                # Also collect trait solver errors from the inference context
                for trait_err in infer_ctx.trait_solver.errors:
                    self.ctx.add_error(_format_trait_error(trait_err))

            # Store final module directly (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.hir_modules[name] = resolved_module
            log_trace("stored HIR module '{name}', total={self.ctx.hir_modules.keys().len()}")

        # Step 3b: Trait coherence checking (Check mode only)
        # Trait coherence errors (orphan rules, overlapping impls, blanket conflicts)
        # are surfaced through the trait solver in the HmInferContext above.
        # A full cross-module coherence pass via CoherenceChecker requires
        # HirType formatting which is not yet available; trait solver errors
        # cover the primary use cases for now.

        # Step 2d: Effect inference pass (infer async effects across all modules)
        log_debug("running effect inference pass...")
        val (updated_hir, effect_warnings) = run_effect_pass(self.ctx.hir_modules)
        self.ctx.hir_modules = updated_hir
        log_debug("effect inference done, {effect_warnings.len()} warnings")

        log_debug("HIR lowering complete: {self.ctx.hir_modules.keys().len()} modules")
        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Phase 3a: Lower to HIR (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn lower_to_hir_impl() -> (CompileContext, bool):
        var lowering = hirlowering_new()
        var ctx = self.ctx

        val module_names = ctx.modules.keys()
        for name in module_names:
            val module = ctx.modules[name]
            val hir_module = lowering.lower_module(module)
            ctx.hir_modules[name] = hir_module
        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 3b: Method Resolution (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn resolve_methods_impl() -> (CompileContext, bool):
        var ctx = self.ctx

        for name in ctx.hir_modules.keys():
            val hir_module = ctx.hir_modules[name]
            val (resolved_module, resolve_errors) = resolve_methods(hir_module)

            # Update the module with resolved method calls (direct mutation)
            ctx.hir_modules[name] = resolved_module

            # Collect errors
            for err in resolve_errors:
                ctx.errors.push("Method resolution error in {name}: {err.message}")

        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 3c: Type Checking (standalone, kept for compatibility)
    # --------------------------------------------------------------------------

    fn type_check_impl() -> (CompileContext, bool):
        var ctx = self.ctx
        # Type inference runs inside lower_and_check_impl() for Check mode.
        # This standalone method is kept for API compatibility but is a no-op.
        (ctx, ctx.errors.len() == 0)

    # --------------------------------------------------------------------------
    # Phase 4: Monomorphization
    # --------------------------------------------------------------------------

    me monomorphize_impl() -> bool:
        """Run monomorphization pass on all HIR modules.

        This creates specialized versions of generic functions, structs, and
        classes by substituting concrete type arguments. Call sites are
        rewritten to use the mangled names of specialized definitions.
        """
        log_debug("running monomorphization on {self.ctx.hir_modules.keys().len()} modules")
        val (mono_modules, mono_stats) = run_monomorphization(self.ctx.hir_modules)
        self.ctx.hir_modules = mono_modules
        log_debug("monomorphization: {mono_stats.specializations_created} specializations created")
        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Mode: SDN (Data only)
    # --------------------------------------------------------------------------

    fn process_sdn() -> CompileResult:
        val backend_port = self.ctx.backend
        val results: Dict<text, Any> = {}

        for name in self.ctx.hir_modules.keys():
            val hir_module = self.ctx.hir_modules[name]
            match backend_port.run_fn(hir_module):
                case Ok(value):
                    results[name] = value
                case Err(e):
                    return CompileResult.RuntimeError("SDN error in {name}: {e.message}")

        CompileResult.Success(results)

    # --------------------------------------------------------------------------
    # Mode: Interpret
    # --------------------------------------------------------------------------

    fn interpret() -> CompileResult:
        self.interpret_pipeline()

    fn interpret_pipeline() -> CompileResult:
        val log = self.ctx.logger
        val backend_port = self.ctx.backend
        var last_result: Any = BackendResult.Unit
        var has_result = false

        if self.ctx.sources.len() == 0:
            return CompileResult.RuntimeError("No source file specified for interpret mode")

        log_debug("interpret: running {self.ctx.sources.len()} modules through compiler frontend output")

        var src_idx = 0
        while src_idx < self.ctx.sources.len():
            val source = self.ctx.sources[src_idx]
            val name = source.module_name
            val hir_module = self.ctx.hir_modules[name]
            if hir_module == nil:
                src_idx = src_idx + 1
                continue

            match backend_port.run_fn(hir_module):
                case Ok(value):
                    last_result = value
                    has_result = true
                case Err(e):
                    return CompileResult.RuntimeError("Interpret error in {name}: {e.message}")
            src_idx = src_idx + 1

        if has_result:
            return CompileResult.Success(last_result)
        CompileResult.Success(BackendResult.Unit)

    fn run_module(backend: Backend, module: HirModule) -> CompileResult:
        match backend.process_module(module):
            case Ok(value): CompileResult.Success(value)
            case Err(e): CompileResult.RuntimeError(e)

    # --------------------------------------------------------------------------
    # Mode: JIT Compile and Run
    # --------------------------------------------------------------------------

    me jit_compile_and_run() -> CompileResult:
        # Lower to MIR
        if not self.lower_to_mir():
            val first_err = self.ctx.errors.first()
            val msg = if first_err != nil: first_err else: "MIR lowering failed"
            return CompileResult.CodegenError(msg)

        # Evict HIR modules (no longer needed after MIR lowering)
        if self.ctx.options.low_memory:
            self.ctx.evict_hir()

        # Borrow checking
        if not self.borrow_check():
            return CompileResult.BorrowError(self.ctx.errors)

        # Process async functions (generate state machines for await/yield)
        val _async_state_machines = self.process_async()

        # Optimize MIR (speed optimization for JIT)
        self.optimize_mir(optimizationconfig_speed())

        # JIT compile
        var pipeline = CodegenPipeline.jit()
        var last_compiled: CompiledModule? = nil

        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            match pipeline.compile_module(mir_module):
                case Ok(compiled):
                    last_compiled = Some(compiled)
                case Err(e):
                    return CompileResult.CodegenError("JIT compile error in {name}: {e.message}")

        if last_compiled == nil:
            return CompileResult.RuntimeError("No modules compiled")

        val compiled = last_compiled.unwrap()
        match compiled.call("main", []):
            case Ok(result):
                compiled.cleanup()
                CompileResult.Success(result)
            case Err(e):
                compiled.cleanup()
                CompileResult.RuntimeError(e.message)

    # --------------------------------------------------------------------------
    # Mode: SMF Exec (load and execute pre-compiled SMF)
    # --------------------------------------------------------------------------

    me execute_smf() -> CompileResult:
        """Load a pre-compiled SMF file and execute its main function.

        Uses JIT infrastructure to map SMF code into executable memory.
        Falls back to interpret mode if SMF loading fails.
        """
        val smf_path = self.ctx.options.input_files[0]
        log_debug("execute_smf: loading {smf_path}")

        # Use JIT pipeline to load and execute the SMF
        var pipeline = CodegenPipeline.jit()
        match pipeline.load_smf_and_execute(smf_path):
            case Ok(result):
                CompileResult.Success(result)
            case Err(e):
                # Fallback: log and return error (caller can retry with interpret)
                log_warn("SMF exec failed: {e}, falling back")
                CompileResult.RuntimeError("SMF execution failed: {e}")

    # --------------------------------------------------------------------------
    # Mode: AOT Compile
    # --------------------------------------------------------------------------

    me aot_compile() -> CompileResult:
        val log = self.ctx.logger

        # Lower to MIR
        if not self.lower_to_mir():
            for err in self.ctx.errors:
                log_error("MIR error: {err}")
            val first_err = self.ctx.errors.first()
            val msg = if first_err != nil: first_err else: "MIR lowering failed"
            return CompileResult.CodegenError(msg)

        # Evict HIR modules (no longer needed after MIR lowering)
        if self.ctx.options.low_memory:
            log_debug("low-memory: evicting HIR modules")
            self.ctx.evict_hir()

        # Borrow checking
        if not self.borrow_check():
            for err in self.ctx.errors:
                log_error("Borrow error: {err}")
            return CompileResult.BorrowError(self.ctx.errors)

        # Process async functions (generate state machines for await/yield)
        val async_state_machines = self.process_async()

        # Optimize MIR (use optimization level from options)
        val opt_config = self.get_optimization_config()
        self.optimize_mir(opt_config)

        # Determine output file
        val output = self.ctx.options.output_file ?? "a.out"

        # If backend is C, write C++ source instead of compiling to native
        val backend_name = self.ctx.options.backend
        if backend_name == "c" or backend_name == "cpp" or backend_name == "ccodegen":
            return self.compile_to_c(output)

        # If backend is CUDA/PTX, emit PTX assembly
        if backend_name == "cuda" or backend_name == "ptx":
            return self.compile_to_cuda(output)

        # Dispatch based on output format
        val format = self.ctx.options.output_format
        match format:
            case OutputFormat.Smf:
                return self.compile_to_smf(output)
            case OutputFormat.SelfContained:
                return self.compile_to_self_contained(output)
            case OutputFormat.Both:
                # Compile native (LLVM) first, then SMF (Cranelift) to cache
                val native_result = CompilerDriver_dot_compile_to_native(self, output)
                if not native_result.is_success():
                    return native_result
                # SMF goes to build/smf/ cache directory
                use compiler.driver.cache.cache_validator.{source_to_cache_path}
                use compiler.driver.watcher.smf_manifest.{update_smf_manifest_entry}
                val source_path = self.ctx.options.input_files[0]
                val smf_cache_path = source_to_cache_path(source_path, "build/smf", ".smf")
                val smf_result = self.compile_to_smf(smf_cache_path)
                if smf_result.is_success():
                    extern fn rt_hash_text(s: text) -> i64
                    extern fn rt_file_read_text(path: text) -> text
                    val src = rt_file_read_text(source_path) ?? ""
                    val src_hash = rt_hash_text(src)
                    update_smf_manifest_entry(source_path, smf_cache_path, src_hash, "cranelift")
                return CompileResult.Success(output)
            case _:
                # Native (default)
                return CompilerDriver_dot_compile_to_native(self, output)

    # --------------------------------------------------------------------------
    # MIR Lowering
    # --------------------------------------------------------------------------

    me lower_to_mir() -> bool:
        var lowering = MirLowering(
            builder: MirBuilder(
                module: MirModule(
                    name: "",
                    functions: {},
                    statics: {},
                    constants: {},
                    types: {}
                ),
                current_function: nil,
                current_block: BlockId(id: 0),
                next_local_id: 0,
                next_block_id: 1,
                locals: [],
                blocks: [],
                instructions: []
            ),
            symbols: SymbolTable.new(),
            local_map: {},
            loop_stack: [],
            errors: [],
            field_map: {}
        )

        val hir_keys = self.ctx.hir_modules.keys()
        for name in hir_keys:
            val hir_module = self.ctx.hir_modules[name]
            var mir_module = lowering.lower_module(hir_module)
            # Ensure module name is set
            mir_module.name = name
            # Direct mutation (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.mir_modules[name] = mir_module

        self.ctx.errors.len() == 0

    # --------------------------------------------------------------------------
    # Borrow Checking
    # --------------------------------------------------------------------------

    me borrow_check() -> bool:
        """Run borrow checking on all MIR modules.

        Uses the NLL (Non-Lexical Lifetimes) borrow checker to detect:
        - Conflicting borrows (E0502)
        - Use after move
        - Assignment while borrowed
        Errors include relatedInformation for first borrow location.
        """
        if self.ctx.options.no_borrow_check:
            log_debug("borrow checking skipped (--no-borrow-check)")
            return true
        log_debug("running borrow check on {self.ctx.mir_modules.keys().len()} modules")
        var checker = BorrowChecker.create()
        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            val all_errors = check_mir_module(mir_module)
            for err in all_errors:
                self.ctx.add_error(_format_nll_error(err))
        self.ctx.errors.len() == 0

    fn format_borrow_error(err: NLLError) -> text:
        """Format a borrow error for display."""
        _format_nll_error(err)

    # --------------------------------------------------------------------------
    # Async Processing
    # --------------------------------------------------------------------------

    me process_async() -> Dict<text, AsyncStateMachine>:
        """Process async functions and generate state machines.

        This is called after MIR lowering to analyze and transform async functions.
        State machines are used by codegen for async execution.
        """
        val log = self.ctx.logger
        log_debug("processing async functions in {self.ctx.mir_modules.keys().len()} modules")

        val state_machines = process_async_mir(self.ctx.mir_modules)

        log_debug("generated {state_machines.keys().len()} async state machines")
        state_machines

    # --------------------------------------------------------------------------
    # MIR Optimization
    # --------------------------------------------------------------------------

    me optimize_mir(config: OptimizationConfig):
        """Apply MIR optimization passes to all modules."""
        val log = self.ctx.logger
        log_debug("optimizing {self.ctx.mir_modules.keys().len()} MIR modules")

        for name in self.ctx.mir_modules.keys():
            val mir_module = self.ctx.mir_modules[name]
            val optimized = optimize_mir_module(mir_module, config)
            # Direct mutation (avoids copy-modify-reassign bug in compiled mode)
            self.ctx.mir_modules[name] = optimized

    fn get_optimization_config() -> OptimizationConfig:
        """Get optimization config from compiler options."""
        # Check for explicit optimization level
        if self.ctx.options.opt_level.?:
            val level = self.ctx.options.opt_level ?? 0
            if level == 0:
                return optimizationconfig_debug()
            elif level == 1:
                return optimizationconfig_size()
            elif level == 2:
                return optimizationconfig_speed()
            elif level >= 3:
                return optimizationconfig_aggressive()

        # Check for release mode or optimize flag
        if self.ctx.options.release or self.ctx.options.optimize:
            optimizationconfig_speed()
        else:
            optimizationconfig_debug()

# Top-level wrapper providing a stable symbol for cross-module calls.
# Method calls across modules can import the wrong symbol name; this gives
# driver_api.spl a stable direct function symbol to call.
fn CompilerDriver_dot_compile(driver: CompilerDriver) -> CompileResult:
    driver.compile()

# Stable facade helpers for `use compiler.driver.{...}` callers.
# These mirror driver_api.spl directly because direct script resolution does
# not reliably surface new driver_api exports through the package facade.
fn generate_headers(path: text, output_dir: text, lib_name: text, emit_c: bool, emit_cpp: bool) -> CompileResult:
    use compiler.tools.header_gen.mod_.{HeaderGenerator}

    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.emit_header = emit_c
    options.emit_cxx_header = emit_cpp
    val driver = CompilerDriver.create(options)
    val result = CompilerDriver.run_compile(driver)

    match result:
        case CompileResult.Success(mir_module_any):
            if mir_module_any.?:
                val mir_module = mir_module_any as MirModule
                val gen = HeaderGenerator.create(mir_module)

                if not gen.has_exports():
                    print "[header-gen] Warning: no @export(\"C\") items found"
                    return result

                rt_dir_create(output_dir, true)

                if emit_c:
                    val c_header = gen.generate_c_header(lib_name)
                    val c_path = rt_path_join(output_dir, lib_name + ".h")
                    rt_file_write_text(c_path, c_header)
                    print "[header-gen] Generated C header: {c_path}"

                if emit_cpp:
                    val cpp_header = gen.generate_cpp_header(lib_name)
                    val cpp_path = rt_path_join(output_dir, lib_name + ".hpp")
                    rt_file_write_text(cpp_path, cpp_header)
                    print "[header-gen] Generated C++ header: {cpp_path}"
            result
        case _:
            result

fn aot_shared_library(path: text, output: text) -> CompileResult:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.shared = true
    options.release = true
    options.optimize = true
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

