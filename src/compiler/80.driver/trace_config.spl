# SReplay — Trace Level Configuration
#
# Controls which semantic trace events are emitted during compilation.
# Parsed from the --debug-trace=<level> CLI flag.

# ============================================================================
# Trace Level
# ============================================================================

enum TraceLevel:
    None       # no semantic trace
    Functions  # FunctionEnter/Exit only
    Objects    # + ObjectAlloc/Drop/OwnershipTransfer
    Full       # + VariableWrite, BorrowStart/End, async timeline

impl TraceLevel:
    fn to_i32() -> i32:
        match self:
            case TraceLevel.None: 0
            case TraceLevel.Functions: 1
            case TraceLevel.Objects: 2
            case TraceLevel.Full: 3

    static fn from_i32(v: i32) -> TraceLevel:
        match v:
            case 0: TraceLevel.None
            case 1: TraceLevel.Functions
            case 2: TraceLevel.Objects
            case 3: TraceLevel.Full
            case _: TraceLevel.None

    fn to_text() -> text:
        match self:
            case TraceLevel.None: "none"
            case TraceLevel.Functions: "functions"
            case TraceLevel.Objects: "objects"
            case TraceLevel.Full: "full"

# ============================================================================
# Trace Configuration
# ============================================================================

struct TraceConfig:
    level: TraceLevel
    output_path: text    # empty = derive from binary name
    buffer_size: i64     # ring buffer size in bytes, default 16MB

impl TraceConfig:
    static fn default() -> TraceConfig:
        TraceConfig(
            level: TraceLevel.None,
            output_path: "",
            buffer_size: 16777216  # 16 * 1024 * 1024
        )

    static fn from_flag(flag: text) -> TraceConfig:
        """Parse --debug-trace=functions|objects|full into a TraceConfig."""
        var value = flag
        if value.starts_with("--debug-trace="):
            value = value.replace("--debug-trace=", "")
        val level = match value:
            case "functions": TraceLevel.Functions
            case "objects": TraceLevel.Objects
            case "full": TraceLevel.Full
            case "none": TraceLevel.None
            case _: TraceLevel.None
        TraceConfig(
            level: level,
            output_path: "",
            buffer_size: 16777216
        )

    fn is_enabled() -> bool:
        self.level.to_i32() > 0
