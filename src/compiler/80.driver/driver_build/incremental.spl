# Incremental Compilation
#
# Hash-based change detection for avoiding unnecessary recompilation.
# Tracks file fingerprints, dependency relationships, and provides
# a build cache with integrity checking.

use std.common.sdn.parser (parse)
use std.common.sdn.value.{SdnValue}

# ============================================================================
# File Fingerprinting
# ============================================================================

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_size(path: text) -> i64
extern fn rt_file_read_text(path: text) -> text
extern fn rt_hash_text(content: text) -> i64
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_hash_sha256(path: text) -> text
extern fn rt_cli_get_args() -> [text]
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_getpid() -> i64
extern fn rt_dir_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_delete(path: text) -> bool

fn incremental_file_exists(path: text) -> bool:
    rt_file_exists(path)

fn incremental_file_size(path: text) -> i64:
    rt_file_size(path)

fn incremental_file_read_text(path: text) -> text:
    rt_file_read_text(path)

fn incremental_parse_file(path: text):
    parse(incremental_file_read_text(path))

fn incremental_hash_text(content: text) -> i64:
    rt_hash_text(content)

var _compiler_src_fingerprint_memo: text = "@@unset@@"

fn native_build_compiler_source_fingerprint() -> text:
    """Fingerprint of the live-interpreted compiler sources (src/compiler/**/*.spl).

    The executable sha256 in native_build_compiler_identity() does not change
    when the compiler runs its .spl sources interpreted — editing a lowering in
    src/compiler changed codegen while the cache scope stayed identical, so
    stale objects kept getting linked. Fingerprint the compiler tree: per-file
    "path|size|sha256" lines joined into a manifest, hashed via a temp file
    (rt_hash_text and rt_hash_sha256 are unavailable/broken under the seed
    interpreter). Measured ~90ms for ~2900 files. Traversal order follows
    rt_dir_list; any order instability only causes a safe cache miss
    ([text].sort() is a no-op under the seed interpreter). Returns "" when no
    src/compiler tree is visible from the build cwd (deployed binary outside
    a repo) — identity is then unchanged.
    """
    if _compiler_src_fingerprint_memo != "@@unset@@":
        return _compiler_src_fingerprint_memo
    val root = "src/compiler"
    if not rt_dir_exists(root):
        _compiler_src_fingerprint_memo = ""
        return ""
    var lines: [text] = []
    var dirs: [text] = [root]
    var i = 0
    while i < dirs.len():
        val dir = dirs[i]
        i = i + 1
        val entries = rt_dir_list(dir) ?? []
        for entry in entries:
            val full = dir + "/" + entry
            if rt_dir_exists(full):
                dirs = dirs.push(full)
            elif entry.ends_with(".spl"):
                lines = lines.push("{full}|{rt_file_size(full)}|{rt_file_hash_sha256(full)}")
    var fp = "unfingerprintable-{rt_getpid()}-{rt_time_now_unix_micros()}"
    rt_dir_create_all("build")
    val tmp = "build/.compiler_src_fp.{rt_getpid()}.tmp"
    if rt_file_write_text(tmp, lines.join("\n")):
        val digest = rt_file_hash_sha256(tmp)
        rt_file_delete(tmp)
        if digest.len() == 64:
            fp = "{digest.substring(0, 16)}n{lines.len()}"
    _compiler_src_fingerprint_memo = fp
    fp

fn native_build_compiler_identity() -> text:
    val src_fp = native_build_compiler_source_fingerprint()
    val args = rt_cli_get_args()
    if args.len() > 0:
        val hash = rt_file_hash_sha256(args[0])
        if hash.len() == 64:
            if src_fp == "":
                return hash
            return "{hash}+src{src_fp}"
    # Fail closed: an unknown compiler must not reuse another compiler's cache.
    "uncacheable-{rt_getpid()}-{rt_time_now_unix_micros()}"

fn native_build_cache_scope_key(backend: text?, target_cpu: text?, target_features: [text], optimization: i32, compiler_identity: text) -> text:
    val backend_text = match backend:
        case Some(name): name
        case nil: "smf"
    val cpu_text = match target_cpu:
        case Some(cpu): cpu
        case nil: "native"
    val feature_text = target_features.join(",")
    "backend={backend_text};cpu={cpu_text};features={feature_text};opt={optimization};compiler={compiler_identity}"

fn incremental_mkdir_p(path: text) -> bool:
    rt_dir_create_all(path)

fn incremental_file_write_text(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn incremental_parent_dir(path: text) -> text:
    val slash = path.last_index_of("/") ?? -1
    if slash <= 0:
        return ""
    path.substring(0, slash)

fn incremental_sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn incremental_sdn_text_array(values: [text]) -> text:
    var items: [text] = []
    for value in values:
        items = items.push("\"{incremental_sdn_escape(value)}\"")
    "[" + items.join(", ") + "]"

struct FileFingerprint:
    """Content hash + metadata for a source file."""
    path: text
    content_hash: text      # SHA-256 of file content
    modified_time: i64      # Unix timestamp
    size: i64               # File size in bytes

impl FileFingerprint:
    static fn from_file(path: text) -> FileFingerprint?:
        """Create fingerprint from a file on disk."""

        if not incremental_file_exists(path):
            return nil

        val content = incremental_file_read_text(path)
        val hash = incremental_hash_text(content).to_text()
        val size = incremental_file_size(path)
        val mtime = 0

        Some(FileFingerprint(path: path, content_hash: hash,
                             modified_time: mtime, size: size))

    static fn quick_changed(path: text, cached: FileFingerprint) -> bool:
        """Fast check using size only — avoids read+hash when size unchanged."""
        if not incremental_file_exists(path):
            return true
        val current_size = incremental_file_size(path)
        current_size != cached.size

    fn matches(other: FileFingerprint) -> bool:
        """Check if two fingerprints match (same content)."""
        self.content_hash == other.content_hash

    fn is_stale(other: FileFingerprint) -> bool:
        """Check if the other fingerprint is newer."""
        self.content_hash != other.content_hash

# ============================================================================
# Dependency Tracking
# ============================================================================

struct DependencyEntry:
    """Tracks what a file depends on."""
    source: text            # Source file path
    fingerprint: FileFingerprint
    dependencies: [text]    # Files this source imports/uses
    outputs: [text]         # Generated artifact paths

impl DependencyEntry:
    fn needs_recompile(current: FileFingerprint, dep_cache: {text: FileFingerprint}) -> bool:
        """Check if this entry needs recompilation."""
        # Source file changed
        val self_fp: FileFingerprint = self.fingerprint
        if self_fp.is_stale(current):
            return true
        # Any dependency changed — quick size check before full hash
        for dep in self.dependencies:
            if dep_cache.has(dep):
                val cached: FileFingerprint = dep_cache[dep]
                if FileFingerprint.quick_changed(dep, cached):
                    # Size changed — definitely stale, skip expensive hash
                    return true
                val fresh = FileFingerprint.from_file(dep)
                if val fresh_fingerprint = fresh:
                    if cached.is_stale(fresh_fingerprint):
                        return true
        false

# ============================================================================
# Change Detection
# ============================================================================

enum ChangeKind:
    Added
    Modified
    Deleted
    DependencyChanged

struct IncrChange:
    path: text
    kind: ChangeKind

struct IncrChangeSet:
    """Set of changes detected since last build."""
    changes: [IncrChange]

impl IncrChangeSet:
    static fn empty() -> IncrChangeSet:
        IncrChangeSet(changes: [])

    fn add(path: text, kind: ChangeKind) -> IncrChangeSet:
        IncrChangeSet(changes: self.changes.push(IncrChange(path: path, kind: kind)))

    fn is_empty() -> bool:
        self.changes.len() == 0

    fn changed_files() -> [text]:
        var out: [text] = []
        for item in self.changes:
            out = out.push(item.path)
        out

    fn added() -> [text]:
        var out: [text] = []
        for item in self.changes:
            if item.kind == ChangeKind.Added:
                out = out.push(item.path)
        out

    fn modified() -> [text]:
        var out: [text] = []
        for item in self.changes:
            if item.kind == ChangeKind.Modified:
                out = out.push(item.path)
        out

    fn deleted() -> [text]:
        var out: [text] = []
        for item in self.changes:
            if item.kind == ChangeKind.Deleted:
                out = out.push(item.path)
        out

struct IncrementalCompileResult:
    files: [text]
    changes: IncrChangeSet

# ============================================================================
# Build Cache
# ============================================================================

class BuildCache:
    """Persistent build cache with integrity checking.

    Stores fingerprints and dependency info between builds.
    Serialized to .build_cache.sdn in project root.
    """
    entries: {text: DependencyEntry}
    fingerprints: {text: FileFingerprint}
    cache_path: text
    version: i64

impl BuildCache:
    static fn empty(cache_path: text) -> BuildCache:
        BuildCache(entries: {}, fingerprints: {}, cache_path: cache_path, version: 0)

    static fn load(cache_path: text) -> BuildCache:
        """Load cache from disk, or create empty if not found."""
        if not incremental_file_exists(cache_path):
            return BuildCache.empty(cache_path)

        match incremental_parse_file(cache_path):
            case Ok(sdn_value):
                val ver = sdn_value.get("version")
                var version: i64 = 0
                if val ver_value_raw = ver:
                    val ver_value: SdnValue = ver_value_raw
                    val v = ver_value.as_i64()
                    if val parsed_version = v:
                        version = parsed_version

                var entries: {text: DependencyEntry} = {}
                var fingerprints: {text: FileFingerprint} = {}

                val entries_val = sdn_value.get("entries")
                if val entries_value_raw = entries_val:
                    val entries_value: SdnValue = entries_value_raw
                    val arr = entries_value.as_array()
                    if val entries_array = arr:
                        for item_raw in entries_array:
                            val item: SdnValue = item_raw
                            val src = item.get("source")
                            var source_value: SdnValue = item
                            if val source_entry_raw = src:
                                val source_entry: SdnValue = source_entry_raw
                                source_value = source_entry
                            else:
                                continue
                            val source_str = source_value.as_str()
                            var source = ""
                            if val source_text = source_str:
                                source = source_text
                            else:
                                continue

                            # Parse fingerprint
                            var fp_hash = ""
                            var fp_size: i64 = 0
                            var fp_mtime: i64 = 0
                            val fp_val = item.get("fingerprint")
                            if val fp_obj_raw = fp_val:
                                val fp_obj: SdnValue = fp_obj_raw
                                val h = fp_obj.get("hash")
                                if val hash_value_raw = h:
                                    val hash_value: SdnValue = hash_value_raw
                                    val hs = hash_value.as_str()
                                    if val hash_text = hs:
                                        fp_hash = hash_text
                                val s = fp_obj.get("size")
                                if val size_value_raw = s:
                                    val size_value: SdnValue = size_value_raw
                                    val si = size_value.as_i64()
                                    if val parsed_size = si:
                                        fp_size = parsed_size
                                val m = fp_obj.get("modified_time")
                                if val mtime_value_raw = m:
                                    val mtime_value: SdnValue = mtime_value_raw
                                    val mi = mtime_value.as_i64()
                                    if val parsed_mtime = mi:
                                        fp_mtime = parsed_mtime

                            val fp = FileFingerprint(
                                path: source, content_hash: fp_hash,
                                modified_time: fp_mtime, size: fp_size)

                            # Parse dependencies
                            var deps: [text] = []
                            val deps_val = item.get("dependencies")
                            if val deps_value_raw = deps_val:
                                val deps_value: SdnValue = deps_value_raw
                                val deps_arr = deps_value.as_array()
                                if val dep_items = deps_arr:
                                    for d_raw in dep_items:
                                        val d: SdnValue = d_raw
                                        val ds = d.as_str()
                                        if val dep_text = ds:
                                            deps = deps.push(dep_text)

                            # Parse outputs
                            var outs: [text] = []
                            val outs_val = item.get("outputs")
                            if val outs_value_raw = outs_val:
                                val outs_value: SdnValue = outs_value_raw
                                val outs_arr = outs_value.as_array()
                                if val out_items = outs_arr:
                                    for o_raw in out_items:
                                        val o: SdnValue = o_raw
                                        val os = o.as_str()
                                        if val out_text = os:
                                            outs = outs.push(out_text)

                            val entry = DependencyEntry(
                                source: source, fingerprint: fp,
                                dependencies: deps, outputs: outs)
                            entries[source] = entry
                            fingerprints[source] = fp

                BuildCache(entries: entries, fingerprints: fingerprints,
                           cache_path: cache_path, version: version)
            case Err(error):
                BuildCache.empty(cache_path)

    me save():
        """Persist cache to disk."""
        val dir = incremental_parent_dir(self.cache_path)
        if dir != "":
            incremental_mkdir_p(dir)
        var lines: [text] = [
            "version: {self.version + 1}",
            "entries: ["
        ]
        for source in self.entries.keys():
            val entry = self.entries[source]
            val fp = entry.fingerprint
            val source_text = incremental_sdn_escape(entry.source)
            val hash_text = incremental_sdn_escape(fp.content_hash)
            val deps_text = incremental_sdn_text_array(entry.dependencies)
            val outputs_text = incremental_sdn_text_array(entry.outputs)
            val fp_text = "{" + " hash: \"" + hash_text + "\", size: {fp.size}, modified_time: {fp.modified_time} " + "}"
            lines = lines.push("  " + "{" + " source: \"" + source_text + "\", fingerprint: " + fp_text + ", dependencies: " + deps_text + ", outputs: " + outputs_text + " " + "}")
        lines = lines.push("]")
        incremental_file_write_text(self.cache_path, lines.join("\n"))

    me update_entry(source: text, fingerprint: FileFingerprint,
                    dependencies: [text], outputs: [text]):
        """Update or create a cache entry."""
        self.fingerprints[source] = fingerprint
        self.entries[source] = DependencyEntry(
            source: source, fingerprint: fingerprint,
            dependencies: dependencies, outputs: outputs)

    me remove_entry(source: text):
        self.entries.remove(source)
        self.fingerprints.remove(source)

    fn has_cached_object(source: text) -> bool:
        """Check if source has a cached entry with fresh fingerprint and existing outputs."""
        if not self.entries.has(source):
            return false
        val entry: DependencyEntry = self.entries[source]
        # Check fingerprint is still fresh
        val fresh = FileFingerprint.from_file(source)
        var fresh_fingerprint = entry.fingerprint
        if val fingerprint = fresh:
            fresh_fingerprint = fingerprint
        else:
            return false
        if entry.fingerprint.is_stale(fresh_fingerprint):
            return false
        # Check all output files still exist on disk
        for out in entry.outputs:
            if not incremental_file_exists(out):
                return false
        true

    fn get_cached_outputs(source: text) -> [text]?:
        """Return cached output paths if entry is fresh, else nil."""
        if not self.has_cached_object(source):
            return nil
        Some(self.entries[source].outputs)

    me invalidate(source: text):
        """Remove a stale entry."""
        self.remove_entry(source)

    fn get_entry(source: text) -> DependencyEntry?:
        if self.entries.has(source):
            Some(self.entries[source])
        else:
            nil

    fn detect_changes(source_files: [text]) -> IncrChangeSet:
        """Detect changes since last build."""
        var changes = IncrChangeSet.empty()

        # Check for modified and added files
        for path in source_files:
            val fresh = FileFingerprint.from_file(path)
            var fresh_fingerprint = FileFingerprint(path: path, hash: "", size: 0, mtime: 0)
            if val fingerprint = fresh:
                fresh_fingerprint = fingerprint
            else:
                continue
            if not self.fingerprints.has(path):
                changes = changes.add(path, ChangeKind.Added)
            else:
                val cur_fp: FileFingerprint = self.fingerprints[path]
                if cur_fp.is_stale(fresh_fingerprint):
                    changes = changes.add(path, ChangeKind.Modified)

        # Check for deleted files
        for path in self.fingerprints.keys():
            if not source_files.contains(path):
                changes = changes.add(path, ChangeKind.Deleted)

        # Check transitive dependencies
        for change in changes.changes:
            val path = change.path
            match change.kind:
                case Added | Modified:
                    # Find all files that depend on this one
                    # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
                    for src in self.entries.keys():
                        val entry = self.entries[src]
                        if entry.dependencies.contains(path):
                            if not changes.changed_files().contains(src):
                                changes = changes.add(src, ChangeKind.DependencyChanged)
                case _: ()

        changes

    me invalidate_all():
        """Clear entire cache."""
        self.entries = {}
        self.fingerprints = {}
        self.version = self.version + 1

    fn integrity_check() -> bool:
        """Verify cache integrity."""
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for path in self.fingerprints.keys():
            val fp = self.fingerprints[path]
            val fresh = FileFingerprint.from_file(path)
            if not fresh.?:
                return false
        true

# ============================================================================
# Incremental Compiler
# ============================================================================

class IncrementalCompiler:
    """Orchestrates incremental compilation using build cache."""
    cache: BuildCache
    source_root: text
    symbol_hashes: {text: {text: text}}
    cached_mir_index: {text: [text]}

impl IncrementalCompiler:
    static fn create(source_root: text, cache_path: text) -> IncrementalCompiler:
        val cache = BuildCache.load(cache_path)
        IncrementalCompiler(cache: cache, source_root: source_root,
                            symbol_hashes: {}, cached_mir_index: {})

    me compile_incremental(source_files: [text]) -> IncrementalCompileResult:
        """Determine which files need recompilation.

        Returns (files_to_compile, change_set).
        """
        val changes = self.cache.detect_changes(source_files)

        if changes.is_empty():
            return IncrementalCompileResult(files: [], changes: changes)

        val to_compile = changes.changed_files()
        IncrementalCompileResult(files: to_compile, changes: changes)

    me record_compilation(source: text, dependencies: [text], outputs: [text]):
        """Record a successful compilation."""
        val fp = FileFingerprint.from_file(source)
        if val fingerprint = fp:
            self.cache.update_entry(source, fingerprint, dependencies, outputs)

    me finish():
        """Save cache after build."""
        self.cache.save()

    me clean():
        """Clear build cache."""
        self.cache.invalidate_all()
        self.symbol_hashes = {}
        self.cached_mir_index = {}
        self.cache.save()

    # --- Symbol-Level Incremental MIR Cache ---

    me update_symbol_hashes(source: text, hashes: {text: text}):
        """Store symbol hashes for a source file after compilation."""
        self.symbol_hashes[source] = hashes

    fn get_changed_symbols(source: text, new_hashes: {text: text}) -> [text]:
        """Compare new symbol hashes against cached ones, return changed symbol names."""
        if not self.symbol_hashes.has(source):
            # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
            var all_names: [text] = []
            for name in new_hashes.keys():
                all_names = all_names.push(name)
            return all_names

        val old_hashes = self.symbol_hashes[source]
        var changed: [text] = []

        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for name in new_hashes.keys():
            val new_hash = new_hashes[name]
            if old_hashes.has(name):
                if old_hashes[name] != new_hash:
                    changed = changed.push(name)
            else:
                changed = changed.push(name)

        for name in old_hashes.keys():
            if not new_hashes.has(name):
                changed = changed.push(name)

        changed

    fn get_cached_mir_functions(source: text):
        """Return cached MIR function SDN blobs for unchanged functions in a source file.

        Returns a dict mapping function name to serialized MIR text, or nil if no cache.
        Uses .build/mir_cache/ directory for per-function MIR storage.
        """

        if not self.cached_mir_index.has(source):
            return nil

        val func_names = self.cached_mir_index[source]
        var result: {text: text} = {}
        val cache_dir = ".build/mir_cache"

        for name in func_names:
            # Hoisted chain (stage-4 nested-call 'replace' gap, see cache_validator.spl).
            val slashless = name.replace("/", "_")
            val safe_name = slashless.replace(":", "_")
            val mir_path = "{cache_dir}/{safe_name}.sdn"
            if incremental_file_exists(mir_path):
                val content = incremental_file_read_text(mir_path)
                if content != "":
                    result[name] = content

        if result.len() == 0:
            return nil
        Some(result)

    me cache_mir_function(source: text, func_name: text, mir_sdn: text):
        """Cache a single function's MIR to disk."""
        val cache_dir = ".build/mir_cache"
        incremental_mkdir_p(cache_dir)

        # Hoisted chain (stage-4 nested-call 'replace' gap, see cache_validator.spl).
        val slashless2 = func_name.replace("/", "_")
        val safe_name = slashless2.replace(":", "_")
        val mir_path = "{cache_dir}/{safe_name}.sdn"
        incremental_file_write_text(mir_path, mir_sdn)

        if not self.cached_mir_index.has(source):
            self.cached_mir_index[source] = []
        val existing: [text] = self.cached_mir_index[source]
        if not existing.contains(func_name):
            self.cached_mir_index[source] = existing.push(func_name)

# ============================================================================
# MIR Merge (Symbol-Level)
# ============================================================================

fn merge_mir(cached_fns: {text: text}, new_fns: {text: text}) -> {text: text}:
    """Merge cached unchanged MIR functions with newly compiled changed functions.

    For each function, if it exists in new_fns (freshly compiled), use the new version.
    Otherwise, use the cached version. This allows symbol-level granularity:
    only changed functions are recompiled, unchanged ones reuse cached MIR.
    """
    var merged: {text: text} = {}

    # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
    for name in cached_fns.keys():
        merged[name] = cached_fns[name]

    for name in new_fns.keys():
        merged[name] = new_fns[name]

    merged

# ============================================================================
# Exports
# ============================================================================

export FileFingerprint, DependencyEntry, ChangeKind, IncrChangeSet
export BuildCache, IncrementalCompiler
export merge_mir, native_build_cache_scope_key, native_build_compiler_identity
