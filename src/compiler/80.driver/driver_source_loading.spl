# Driver — Source Loading and Error Formatting
#
# Extracted from driver.spl. Contains:
# - Source file collection from paths/directories
# - Module name derivation from file paths
# - Structured error formatting helpers for type, borrow, coherence, and trait errors

use compiler.common.driver_core_types.{SourceFile}
use compiler.types.type_infer.*
use compiler.types.dim_constraints_types.{DimError}
use compiler.borrow.borrow_check.*
use compiler.borrow.borrow_check.nll.{NLLError, nllerror_format_related}
use compiler.core.interpreter.hashmap.{hm_hash_text}
use compiler.traits.trait_coherence.{CoherenceError}
use compiler.traits.trait_validation.{TraitError}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# Directories to skip during source collection
val _skip_dirs = ["test", "tests", "doc", "docs", "verification", "resources", "scripts", "build"]

fn _driver_source_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

pub fn _driver_should_skip_dir(name: text) -> bool:
    var i = 0
    while i < _skip_dirs.len():
        if name == _skip_dirs[i]:
            return true
        i = i + 1
    false

pub fn _driver_is_bootstrap_entry_source(path: text, module_name: text) -> bool:
    val native_entry = rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY") ?? ""
    # Match the native-build entry by exact path or by tail segment, so a bare
    # or relative `--entry hello.spl` still matches the collected source path
    # `.../hello.spl` (and vice versa). Without this the entry module is stubbed
    # to an empty MirModule and `__simple_main` never gets emitted.
    if native_entry != "":
        # A caller-supplied --entry is authoritative: never also treat
        # bootstrap_main.spl (the historical default entry) as "an" entry
        # source. Bug #110 — with `--source src/app` (or any source root that
        # bulk-loads bootstrap_main.spl) and a distinct `--entry`, this used to
        # match BOTH files, so bootstrap_main.spl got fully parsed/lowered
        # alongside — and in some cases instead of — the requested entry,
        # silently building the wrong program. Only the exact/tail-matched
        # requested entry may qualify now.
        return path == native_entry or path.ends_with("/" + native_entry)
    path.ends_with("/app/cli/bootstrap_main.spl") or path == "./src/app/cli/bootstrap_main.spl" or module_name == "app.cli.bootstrap_main"

pub fn _driver_module_name_from_path(path: text) -> text:
    # THREE copies of this derivation exist and MUST stay byte-identical
    # (lower layers cannot import 80.driver): this one,
    # llvm_module_name_from_entry_path (70.backend _MirToLlvm/core_codegen.spl)
    # and hir_module_logical_name_from_path (20.hir _Items/module_lowering.spl).
    # 70a29867bc2 changed only this copy; the drift made entry_main_symbol
    # false for every out-of-tree entry -> no __simple_main -> 0/19 matrix.
    var mod_path = path.replace("\\", "/")
    while mod_path.starts_with("../"):
        mod_path = mod_path.substring(3)
    if mod_path.starts_with("./"):
        mod_path = mod_path.substring(2)
    # Explicitly resolved imports may arrive as absolute workspace paths.
    # Keep module identity repo-relative so temporary/worktree directory names
    # cannot leak '-' or other host-path punctuation into native symbols.
    val absolute_src = mod_path.find("/src/") ?? -1
    if absolute_src >= 0:
        mod_path = mod_path.substring(absolute_src + 5)
    else:
        val absolute_examples = mod_path.find("/examples/") ?? -1
        if absolute_examples >= 0:
            mod_path = mod_path.substring(absolute_examples + 1)
    if mod_path.starts_with("src/"):
        mod_path = mod_path.substring(4)
    mod_path = mod_path.replace(".spl", "")
    mod_path = mod_path.replace(".sdn", "")
    mod_path = mod_path.replace("-", "_")
    mod_path = mod_path.replace(" ", "_")
    mod_path.replace("/", ".")

pub fn _driver_canonical_source_path(path: text) -> text:
    """Lexically normalize a source path for physical-file identity.
    Source discovery is repo-local, so resolving `.`/`..`, repeated separators,
    and Windows separators is sufficient without filesystem/symlink I/O."""
    val normalized = path.replace("\\", "/")
    val absolute = normalized.starts_with("/")
    var parts: [text] = []
    for part in normalized.split("/"):
        if part == "" or part == ".":
            continue
        if part == ".." and parts.len() > 0 and parts[parts.len() - 1] != "..":
            parts = parts[0:parts.len() - 1]
        elif part == ".." and not absolute:
            parts = parts.push(part)
        elif part != "..":
            parts = parts.push(part)
    val joined = parts.join("/")
    if absolute:
        "/" + joined
    else:
        joined

fn _driver_text_bucket_index(key: text, bucket_count: i64) -> i64:
    val raw = hm_hash_text(key) % bucket_count
    if raw < 0:
        raw + bucket_count
    else:
        raw

pub fn _driver_text_bucket_set_new(bucket_count: i64) -> [text]:
    """Create a compiled-Simple-safe exact text set.
    Closure keys are source paths/module names and therefore cannot contain
    newlines; each hash bucket stores newline-delimited keys."""
    val count = if bucket_count > 0: bucket_count else: 1
    var buckets: [text] = []
    while buckets.len() < count:
        buckets = buckets.push("")
    buckets

pub fn _driver_text_bucket_set_has(buckets: [text], key: text) -> bool:
    if buckets.len() == 0:
        return false
    val bucket = buckets[_driver_text_bucket_index(key, buckets.len())]
    if bucket == "":
        return false
    val marker = key + "\n"
    bucket.starts_with(marker) or bucket.contains("\n" + marker)

pub fn _driver_text_bucket_set_add(buckets: [text], key: text) -> [text]:
    if buckets.len() == 0 or _driver_text_bucket_set_has(buckets, key):
        return buckets
    val index = _driver_text_bucket_index(key, buckets.len())
    var updated = buckets
    updated[index] = updated[index] + key + "\n"
    updated

pub fn _driver_unique_physical_sources(sources: [SourceFile]) -> [SourceFile]:
    """Keep the first logical source for each normalized physical path.
    Logical aliases remain in the caller's source list for module registration;
    this list is only the phase-2 parse plan."""
    var unique: [SourceFile] = []
    var seen = _driver_text_bucket_set_new(8192)
    for source in sources:
        val key = _driver_canonical_source_path(source.path)
        if not _driver_text_bucket_set_has(seen, key):
            seen = _driver_text_bucket_set_add(seen, key)
            unique = unique.push(source)
    unique

pub fn _driver_module_aliases(path: text, content: text, module_name: text) -> [SourceFile]:
    # Entry-closure loading adds the requested import name after resolution.
    # Do not invent lib.* -> std.* aliases here: real src/std mirrors may own them.
    var aliases: [SourceFile] = [SourceFile(path: path, content: content, module_name: module_name)]
    if module_name.starts_with("compiler.10.frontend.core."):
        val core_alias = "compiler.core." + module_name.substring("compiler.10.frontend.core.".len())
        aliases = aliases.push(SourceFile(path: path, content: content, module_name: core_alias))
    aliases

pub fn _driver_entry_import_dirname(path: text) -> text:
    """Directory part of a path ("" when the path has no directory)."""
    val parts = path.split("/")
    if parts.len() <= 1:
        return ""
    var dir = ""
    var i = 0
    while i < parts.len() - 1:
        if i > 0:
            dir = dir + "/"
        dir = dir + parts[i]
        i = i + 1
    dir

fn _driver_import_space(byte: u8) -> bool:
    byte == 32 or byte == 9 or byte == 11 or byte == 12 or byte == 13

fn _driver_import_path_token(bytes: [u8], start_in: i64, end_in: i64) -> text:
    # Dotted module path prefix of a use/import tail; "" when the tail is not
    # a plausible module path (guards against prose lines that begin with
    # "use " inside strings the docstring toggle missed).
    val word_chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_."
    var start = start_in
    var end_pos = end_in
    while start < end_pos and _driver_import_space(bytes[start]):
        start = start + 1
    while end_pos > start and _driver_import_space(bytes[end_pos - 1]):
        end_pos = end_pos - 1
    var cut = end_pos
    var i = start
    while i < end_pos:
        val byte = bytes[i]
        if byte == 32 or byte == 123 or byte == 40 or byte == 42 or byte == 35:
            cut = i
            break
        val is_word = (byte >= 97 and byte <= 122) or (byte >= 65 and byte <= 90) or (byte >= 48 and byte <= 57) or byte == 95 or byte == 46
        if not is_word:
            return ""
        i = i + 1
    while cut > start and bytes[cut - 1] == 46:
        cut = cut - 1
    var path_text = ""
    i = start
    while i < cut:
        val byte = bytes[i]
        var char_index = 63
        if byte >= 97 and byte <= 122:
            char_index = (byte as i64) - 97
        elif byte >= 65 and byte <= 90:
            char_index = (byte as i64) - 65 + 26
        elif byte >= 48 and byte <= 57:
            char_index = (byte as i64) - 48 + 52
        elif byte == 95:
            char_index = 62
        path_text = path_text + word_chars[char_index:char_index + 1]
        i = i + 1
    path_text

fn _driver_import_prefix_at(bytes: [u8], start: i64, end_pos: i64, prefix: [u8]) -> bool:
    if start + prefix.len() > end_pos:
        return false
    var i = 0
    while i < prefix.len():
        if bytes[start + i] != prefix[i]:
            return false
        i = i + 1
    true

pub fn _driver_entry_import_module_paths(content: text) -> [text]:
    """Dotted module paths of the use/export-use/import declarations in a
    source text. `use lazy` imports are dynamic-by-design and skipped.
    Docstring bodies are skipped via a triple-quote toggle."""
    var result: [text] = []
    var in_doc = false
    val bytes = content.bytes()
    val lazy_prefix = "use lazy ".bytes()
    val export_prefix = "export use ".bytes()
    val use_prefix = "use ".bytes()
    val import_prefix = "import ".bytes()
    var line_start = 0
    var scan_pos = 0
    while scan_pos <= bytes.len():
        if scan_pos < bytes.len() and bytes[scan_pos] != 10:
            scan_pos = scan_pos + 1
            continue
        val line_end = scan_pos
        var quote_count = 0
        var quote_pos = line_start
        var line_in_doc = in_doc
        while quote_pos + 2 < line_end:
            if not line_in_doc and bytes[quote_pos] == 35:
                quote_pos = line_end
            elif bytes[quote_pos] == 34 and bytes[quote_pos + 1] == 34 and bytes[quote_pos + 2] == 34:
                quote_count = quote_count + 1
                line_in_doc = not line_in_doc
                quote_pos = quote_pos + 3
            else:
                quote_pos = quote_pos + 1
        val was_in_doc = in_doc
        in_doc = line_in_doc
        if not was_in_doc and quote_count == 0:
            var decl_start = line_start
            while decl_start < line_end and _driver_import_space(bytes[decl_start]):
                decl_start = decl_start + 1
            var rest_start = -1
            if _driver_import_prefix_at(bytes, decl_start, line_end, lazy_prefix):
                rest_start = -1
            elif _driver_import_prefix_at(bytes, decl_start, line_end, export_prefix):
                rest_start = decl_start + export_prefix.len()
            elif _driver_import_prefix_at(bytes, decl_start, line_end, use_prefix):
                rest_start = decl_start + use_prefix.len()
            elif _driver_import_prefix_at(bytes, decl_start, line_end, import_prefix):
                rest_start = decl_start + import_prefix.len()
            if rest_start >= 0:
                val mp = _driver_import_path_token(bytes, rest_start, line_end)
                if mp != "":
                    result = result.push(mp)
        line_start = scan_pos + 1
        scan_pos = scan_pos + 1
    result

fn _driver_try_entry_import_rel(rel: text, entry_dir: text) -> text:
    var roots: [text] = ["", "src/"]
    if entry_dir != "":
        roots = roots.push(entry_dir + "/")
    for root in roots:
        val base = root + rel
        if rt_file_exists(base + ".spl"):
            return base + ".spl"
        if rt_file_exists(base + "/mod.spl"):
            return base + "/mod.spl"
        if rt_file_exists(base + "/__init__.spl"):
            return base + "/__init__.spl"
    ""

fn _driver_resolve_rewritten_import(module_path: text, prefix: text, rel_prefix: text, entry_dir: text) -> text:
    if module_path != prefix and not module_path.starts_with(prefix + "."):
        return ""
    var rel = rel_prefix
    if module_path.len() > prefix.len():
        rel = rel + "/" + module_path.substring(prefix.len() + 1).replace(".", "/")
    _driver_try_entry_import_rel(rel, entry_dir)

fn _driver_entry_import_parent(module_path: text) -> text:
    # Preserve the leading-dot relative-import marker and remove only a real
    # dotted path segment. `..backend_types.CompiledUnit` becomes
    # `..backend_types`, while `..backend_types` has no further parent.
    var leading = 0
    while leading < module_path.len() and module_path.substring(leading, leading + 1) == ".":
        leading = leading + 1
    var last = -1
    var i = leading
    while i < module_path.len():
        if module_path.substring(i, i + 1) == ".":
            last = i
        i = i + 1
    if last < 0:
        return ""
    module_path[0:last]

fn _driver_resolve_relative_entry_import(module_path: text, entry_dir: text) -> text:
    if not module_path.starts_with("."):
        return ""
    var dots = 0
    while dots < module_path.len() and module_path.substring(dots, dots + 1) == ".":
        dots = dots + 1
    if dots >= module_path.len():
        return ""
    var base_dir = entry_dir
    var up = 1
    while up < dots:
        base_dir = _driver_entry_import_dirname(base_dir)
        up = up + 1
    val rel = module_path.substring(dots).replace(".", "/")
    _driver_try_entry_import_rel(rel, base_dir)

fn _driver_resolve_entry_import_exact(module_path: text, entry_dir: text) -> text:
    val relative = _driver_resolve_relative_entry_import(module_path, entry_dir)
    if relative != "":
        return relative

    val rel = module_path.replace(".", "/")
    val direct = _driver_try_entry_import_rel(rel, entry_dir)
    if direct != "":
        return direct

    if not module_path.starts_with("std."):
        val lib_base = "src/lib/" + rel
        if rt_file_exists(lib_base + ".spl"):
            return lib_base + ".spl"
        if rt_file_exists(lib_base + "/mod.spl"):
            return lib_base + "/mod.spl"
        if rt_file_exists(lib_base + "/__init__.spl"):
            return lib_base + "/__init__.spl"
        for family in ["nogc_async_mut", "nogc_async_immut", "nogc_sync_immut", "nogc_sync_mut", "common", "gc_async_mut", "gc_async_immut", "gc_sync_mut", "gc_sync_immut", "nogc_async_mut_noalloc"]:
            val family_base = "src/lib/" + family + "/" + rel
            if rt_file_exists(family_base + ".spl"):
                return family_base + ".spl"
            if rt_file_exists(family_base + "/mod.spl"):
                return family_base + "/mod.spl"
            if rt_file_exists(family_base + "/__init__.spl"):
                return family_base + "/__init__.spl"
    if module_path.starts_with("std."):
        val lib_base = "src/lib/" + rel.substring(4)
        if rt_file_exists(lib_base + ".spl"):
            return lib_base + ".spl"
        if rt_file_exists(lib_base + "/mod.spl"):
            return lib_base + "/mod.spl"
        if rt_file_exists(lib_base + "/__init__.spl"):
            return lib_base + "/__init__.spl"
        val lib_subpath = rel.substring(4)
        for family in ["nogc_async_mut", "nogc_async_immut", "nogc_sync_immut", "nogc_sync_mut", "common", "gc_async_mut", "gc_async_immut", "gc_sync_mut", "gc_sync_immut", "nogc_async_mut_noalloc"]:
            val family_base = "src/lib/" + family + "/" + lib_subpath
            if rt_file_exists(family_base + ".spl"):
                return family_base + ".spl"
            if rt_file_exists(family_base + "/mod.spl"):
                return family_base + "/mod.spl"
            if rt_file_exists(family_base + "/__init__.spl"):
                return family_base + "/__init__.spl"

    # Match the canonical numbered compiler layout used by the interpreter's
    # module resolver. Some layers also retain a same-named wrapper directory;
    # try both forms without scanning the full source tree.
    var mapped = _driver_resolve_rewritten_import(module_path, "compiler.common", "compiler/00.common", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.core", "compiler/10.frontend/core", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.frontend", "compiler/10.frontend", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.blocks", "compiler/15.blocks/blocks", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.hir", "compiler/20.hir", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.traits", "compiler/25.traits", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.types", "compiler/30.types", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.semantics", "compiler/35.semantics", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.monomorphize", "compiler/40.mono/monomorphize", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "monomorphize", "compiler/40.mono/monomorphize", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.mir", "compiler/50.mir", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.borrow", "compiler/55.borrow", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.mir_opt", "compiler/60.mir_opt/mir_opt", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.backend", "compiler/70.backend", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.driver", "compiler/80.driver", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.shb", "compiler/80.driver/shb", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "compiler.interpreter", "compiler/95.interp/interpreter", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "linker", "compiler/70.backend/linker", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "app.ui.browser", "app/ui.browser", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "app.ui.render", "app/ui.render", entry_dir)
    if mapped != "":
        return mapped
    mapped = _driver_resolve_rewritten_import(module_path, "cmm_lsp", "examples/10_tooling/trace32_tools/cmm_lsp", entry_dir)
    if mapped != "":
        return mapped
    val backend_wrapped = _driver_resolve_rewritten_import(module_path, "compiler.backend", "compiler/70.backend/backend", entry_dir)
    if backend_wrapped != "":
        return backend_wrapped
    ""

pub fn _driver_resolve_entry_import(module_path: text, entry_dir: text) -> text:
    """File path backing a Simple import path, or "" when none exists.
    Exact modules are preferred. Dotted terminal names are then removed one at
    a time because Simple permits `use module.function` as a glob-style import
    of the containing source module."""
    var probe = module_path
    while probe != "":
        val resolved = _driver_resolve_entry_import_exact(probe, entry_dir)
        if resolved != "":
            return resolved
        probe = _driver_entry_import_parent(probe)
    ""

pub fn _driver_collect_entry_import_source(p: text) -> [SourceFile]:
    """Load one explicitly resolved closure import.
    Bulk collection exclusions must not hide a file named `check.spl` or an
    imported async lowering module. Test, fixture, doc, and verification trees
    remain excluded from production closure builds."""
    var result: [SourceFile] = []
    if not p.ends_with(".spl"):
        return result
    if p.contains("/test/") or p.contains("/tests/") or p.contains("/testdata/") or p.contains("/doc/") or p.contains("/verification/"):
        return result
    val content = rt_file_read_text(p) ?? ""
    if content == "":
        return result
    _driver_module_aliases(p, content, _driver_module_name_from_path(p))

fn _driver_is_filtered_test_helper_path(path: text) -> bool:
    val normalized = path.replace("\\", "/")
    normalized.contains("/test_") and not (
        normalized == "src/app/cli/test_entry.spl" or normalized.ends_with("/src/app/cli/test_entry.spl")
    )

pub fn _driver_collect_sources(p: text) -> [SourceFile]:
    """Collect source files from a path (file or directory). Returns list of SourceFile."""
    var result: [SourceFile] = []
    if _driver_source_trace_enabled():
        print "[collect_sources] path {p}"
    if p.ends_with(".spl"):
        if _driver_source_trace_enabled():
            print "[collect_sources] file {p}"
        # It's a source file
        if p.ends_with("/check.spl") or p.ends_with("\\check.spl"):
            return result
        if p.ends_with("/20.hir/hir_lowering/__init__.spl") or p.ends_with("\\20.hir\\hir_lowering\\__init__.spl"):
            return result
        if p.contains("/test/") or p.contains("/tests/") or p.contains("/testdata/") or p.contains("/doc/") or p.contains("/verification/"):
            return result
        if p.contains("/core/interpreter/") or p.contains("/10.frontend/parser/") or p.contains("/10.frontend/treesitter") or p.contains("/hir_lowering/async"):
            return result
        if p.contains("/10.frontend/core/"):
            val core_allowed = p.contains("/lexer") or p.contains("/parser") or p.contains("/ast") or p.contains("/tokens")
            val core_allowed2 = core_allowed or p.contains("/types") or p.contains("/backend_types") or p.contains("/error") or p.contains("/frontend")
            val core_allowed3 = core_allowed2 or p.ends_with("/__init__.spl")
            if not core_allowed3:
                return result
        val content = rt_file_read_text(p) ?? ""
        if _driver_source_trace_enabled():
            print "[collect_sources] content_len {content.len()}"
        if content != "":
            val module_name = _driver_module_name_from_path(p)
            val aliases = _driver_module_aliases(p, content, module_name)
            if _driver_source_trace_enabled():
                print "[collect_sources] file_result {aliases.len()}"
            return aliases
    else:
        if _driver_source_trace_enabled():
            print "[collect_sources] dir {p}"
        # Use find for directory roots. The generated bootstrap compiler corrupts
        # some static arrays used by the old recursive walker.
        val cmd = "find {p} -type f -name '*.spl' 2>/dev/null"
        val (stdout, _, code) = rt_process_run("sh", ["-c", cmd])
        if _driver_source_trace_enabled():
            print "[collect_sources] find_code {code} stdout_len {stdout.len()}"
        if code != 0 or stdout == "":
            return result
        val lines = stdout.split("\n")
        for line in lines:
            val path = line.trim()
            if path == "":
                continue
            if path.contains("/test/") or path.contains("/tests/") or path.contains("/testdata/") or path.contains("/doc/") or path.contains("/verification/"):
                continue
            if _driver_is_filtered_test_helper_path(path) or path.contains("/core/interpreter/") or path.contains("/10.frontend/parser/") or path.contains("/10.frontend/treesitter") or path.contains("/hir_lowering/async"):
                continue
            if path.contains("/10.frontend/core/"):
                val core_allowed = path.contains("/lexer") or path.contains("/parser") or path.contains("/ast") or path.contains("/tokens")
                val core_allowed2 = core_allowed or path.contains("/types") or path.contains("/backend_types") or path.contains("/error") or path.contains("/frontend")
                val core_allowed3 = core_allowed2 or path.ends_with("/__init__.spl")
                if not core_allowed3:
                    continue
            val loaded = _driver_collect_sources(path)
            for s in loaded:
                result = result.push(s)
    result

pub fn _driver_collect_sources_via_find(paths: [text]) -> [SourceFile]:
    var result: [SourceFile] = []
    for path in paths:
        val loaded = _driver_collect_sources(path)
        for s in loaded:
            result = result.push(s)
    result

# ------------------------------------------------------------------------------
# Structured Error Formatting Helpers
# ------------------------------------------------------------------------------
# Errors are encoded as: "line:col: message" with optional related info
# appended as "|||RELATED:line:col:message" segments and optional help
# appended as "|||HELP:message".

pub fn _format_type_infer_error(err: TypeInferError) -> text:
    """Format a TypeInferError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    # Add related information based on error variant
    match err:
        case TypeInferError.Mismatch(expected, found, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if found.span.line > 0 and found.span.line != s.line:
                result = result + "|||RELATED:{found.span.line}:{found.span.col}:found type originates here"
        case TypeInferError.OccursCheck(var_id, ty, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:recursive type reference here"
            result = result + "|||HELP:break the recursive type by using an explicit type annotation"
        case TypeInferError.TraitNotImplemented(ty, trait_name, s):
            if ty.span.line > 0:
                result = result + "|||RELATED:{ty.span.line}:{ty.span.col}:type that needs to implement '{trait_name}'"
            result = result + "|||HELP:add an impl block: impl {trait_name} for {ty.kind}"
        case TypeInferError.DimensionError(dim_err):
            val de: DimError = dim_err
            for note in de.notes:
                match note.span:
                    case Some(note_span):
                        result = result + "|||RELATED:{note_span.line}:{note_span.col}:{note.message}"
                    case nil:
                        pass
            match de.help:
                case Some(help):
                    result = result + "|||HELP:{help}"
                case nil:
                    pass
        case TypeInferError.Undefined(name, s):
            result = result + "|||HELP:check spelling or add an import for '{name}'"
        case TypeInferError.Other(message, s):
            pass_do_nothing
    result

pub fn _format_nll_error(err: NLLError) -> text:
    """Format an NLLError into a structured error string with related info."""
    val primary = if err.has_primary_span: err.primary_span else: 0
    var result = "{primary}:1: {err.message}"
    result = result + nllerror_format_related(err)
    if err.has_help:
        result = result + "|||HELP:{err.help}"
    result

pub fn _format_coherence_error(err: CoherenceError) -> text:
    """Format a CoherenceError into a structured error string."""
    val msg = err.message()
    "1:1: {msg}"

pub fn _format_trait_error(err: TraitError) -> text:
    """Format a TraitError into a structured error string with related info."""
    val span = err.span()
    val msg = err.message()
    var result = "{span.line}:{span.col}: {msg}"
    match err:
        case TraitError.MissingMethod(trait_, method, ty, s):
            result = result + "|||HELP:add method '{method}' to the impl block"
        case TraitError.UndefinedTrait(name, s):
            result = result + "|||HELP:check spelling or add an import for the trait"
        case TraitError.Unsatisfied(obligation):
            if obligation.span.line > 0:
                result = result + "|||RELATED:{obligation.span.line}:{obligation.span.col}:required by this bound"
        case TraitError.MissingAssocType(trait_, assoc_name, ty, s):
            result = result + "|||HELP:add 'type {assoc_name} = ...' to the impl block"
        case TraitError.AssocTypeMismatch(trait_, assoc_name, expected, actual, s):
            if expected.span.line > 0:
                result = result + "|||RELATED:{expected.span.line}:{expected.span.col}:expected type defined here"
            if actual.span.line > 0:
                result = result + "|||RELATED:{actual.span.line}:{actual.span.col}:actual type found here"
        case _:
            pass_do_nothing
    result
