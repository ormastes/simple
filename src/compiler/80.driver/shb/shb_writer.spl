# SHB Writer — Serialize ShbModuleInterface → .shb binary file
#
# Layout: [Header 64B] [SectionTable 64B] [Sections...] [StringTable]
# All integers little-endian.

use compiler.shb.shb_types.{
    ShbModuleInterface, ShbHeader, ShbSectionTable, ShbFnEntry, ShbStructEntry,
    ShbClassEntry, ShbEnumEntry, ShbTraitEntry, ShbReexportEntry,
    ShbTypeLayoutEntry, ShbDependencyEntry, ShbParam, ShbFieldEntry,
    ShbMethodRef,
    SHB_HEADER_SIZE, SHB_SECTION_TABLE_SIZE, SHB_SECTION_COUNT,
    SHB_SECTION_FUNCTIONS, SHB_SECTION_STRUCTS, SHB_SECTION_CLASSES,
    SHB_SECTION_TYPE_LAYOUTS, SHB_SECTION_ENUMS, SHB_SECTION_TRAITS,
    SHB_SECTION_REEXPORTS, SHB_SECTION_DEPENDENCIES,
    SHB_MAGIC_0, SHB_MAGIC_1, SHB_MAGIC_2, SHB_MAGIC_3
}
use compiler.shb.shb_string_table.{ShbStringTable}

# --- Main write function ---

fn shb_write(iface: ShbModuleInterface, path: text) -> bool:
    var strtab = ShbStringTable.create()
    var sections: [u8] = []

    # Pre-register all strings
    shb_register_strings(iface, strtab)

    # Build section data and record offsets
    var section_offsets: [i64] = []
    val data_base = SHB_HEADER_SIZE + SHB_SECTION_TABLE_SIZE

    # Functions
    section_offsets.push(data_base + sections.len())
    sections = shb_write_functions(iface.functions, strtab, sections)

    # Structs
    section_offsets.push(data_base + sections.len())
    sections = shb_write_structs(iface.structs, strtab, sections)

    # Classes
    section_offsets.push(data_base + sections.len())
    sections = shb_write_classes(iface.classes, strtab, sections)

    # Type layouts
    section_offsets.push(data_base + sections.len())
    sections = shb_write_type_layouts(iface.type_layouts, strtab, sections)

    # Enums
    section_offsets.push(data_base + sections.len())
    sections = shb_write_enums(iface.enums, strtab, sections)

    # Traits
    section_offsets.push(data_base + sections.len())
    sections = shb_write_traits(iface.traits, strtab, sections)

    # Reexports
    section_offsets.push(data_base + sections.len())
    sections = shb_write_reexports(iface.reexports, strtab, sections)

    # Dependencies
    section_offsets.push(data_base + sections.len())
    sections = shb_write_dependencies(iface.dependencies, strtab, sections)

    # String table offset
    val strtab_offset = data_base + sections.len()
    val strtab_size = strtab.size()

    # Module name offset
    val mod_name_off = strtab.get_offset("")

    # Build final binary
    var out: [u8] = []

    # --- Header (64 bytes) ---
    out = shb_push_u8(out, SHB_MAGIC_0)
    out = shb_push_u8(out, SHB_MAGIC_1)
    out = shb_push_u8(out, SHB_MAGIC_2)
    out = shb_push_u8(out, SHB_MAGIC_3)
    out = shb_push_u8(out, iface.header.version_major)
    out = shb_push_u8(out, iface.header.version_minor)
    out = shb_push_u8(out, iface.header.platform)
    out = shb_push_u8(out, iface.header.arch)
    out = shb_push_i64_le(out, iface.header.source_hash)
    out = shb_push_i64_le(out, iface.header.interface_hash)
    out = shb_push_i64_le(out, iface.header.write_timestamp)
    out = shb_push_u32_le(out, SHB_SECTION_COUNT)
    out = shb_push_u32_le(out, strtab_offset)
    out = shb_push_u32_le(out, strtab_size)
    out = shb_push_u32_le(out, iface.header.flags)
    out = shb_push_i64_le(out, mod_name_off)
    # Reserved 8 bytes
    out = shb_push_i64_le(out, 0)

    # --- Section offset table (64 bytes = 8 x 8) ---
    var si = 0
    while si < SHB_SECTION_COUNT:
        out = shb_push_i64_le(out, section_offsets[si])
        si = si + 1

    # --- Section data ---
    out = shb_push_bytes(out, sections)

    # --- String table ---
    out = shb_push_bytes(out, strtab.get_data())

    # --- Atomic write: temp + rename ---
    val tmp_path = path + ".tmp"
    rt_file_write_bytes(tmp_path, out)
    rt_file_move(tmp_path, path)
    true

fn shb_debug_string_table_size(iface: ShbModuleInterface) -> i64:
    var strtab = ShbStringTable.create()
    shb_register_strings(iface, strtab)
    strtab.size()

fn shb_debug_function_section_size(iface: ShbModuleInterface) -> i64:
    var strtab = ShbStringTable.create()
    shb_register_strings(iface, strtab)
    val section = shb_write_functions(iface.functions, strtab, [])
    section.len()

fn shb_debug_full_binary_size(iface: ShbModuleInterface) -> i64:
    var strtab = ShbStringTable.create()
    shb_register_strings(iface, strtab)

    var sections: [u8] = []
    var section_offsets: [i64] = []
    val data_base = SHB_HEADER_SIZE + SHB_SECTION_TABLE_SIZE

    section_offsets.push(data_base + sections.len())
    sections = shb_write_functions(iface.functions, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_structs(iface.structs, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_classes(iface.classes, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_type_layouts(iface.type_layouts, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_enums(iface.enums, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_traits(iface.traits, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_reexports(iface.reexports, strtab, sections)
    section_offsets.push(data_base + sections.len())
    sections = shb_write_dependencies(iface.dependencies, strtab, sections)

    var out: [u8] = []
    out = shb_push_u8(out, SHB_MAGIC_0)
    out = shb_push_u8(out, SHB_MAGIC_1)
    out = shb_push_u8(out, SHB_MAGIC_2)
    out = shb_push_u8(out, SHB_MAGIC_3)
    out = shb_push_u8(out, iface.header.version_major)
    out = shb_push_u8(out, iface.header.version_minor)
    out = shb_push_u8(out, iface.header.platform)
    out = shb_push_u8(out, iface.header.arch)
    out = shb_push_i64_le(out, iface.header.source_hash)
    out = shb_push_i64_le(out, iface.header.interface_hash)
    out = shb_push_i64_le(out, iface.header.write_timestamp)
    out = shb_push_u32_le(out, SHB_SECTION_COUNT)
    out = shb_push_u32_le(out, data_base + sections.len())
    out = shb_push_u32_le(out, strtab.size())
    out = shb_push_u32_le(out, iface.header.flags)
    out = shb_push_i64_le(out, strtab.get_offset(""))
    out = shb_push_i64_le(out, 0)

    var si = 0
    while si < SHB_SECTION_COUNT:
        out = shb_push_i64_le(out, section_offsets[si])
        si = si + 1

    out = shb_push_bytes(out, sections)
    out = shb_push_bytes(out, strtab.get_data())
    out.len()

# --- String registration (first pass) ---

fn shb_register_strings(iface: ShbModuleInterface, strtab: ShbStringTable):
    # Functions
    var fi = 0
    while fi < iface.functions.len():
        val f = iface.functions[fi]
        strtab.add(f.name)
        strtab.add(f.return_type)
        var pi = 0
        while pi < f.params.len():
            strtab.add(f.params[pi].name)
            strtab.add(f.params[pi].type_name)
            pi = pi + 1
        fi = fi + 1

    # Structs
    var si = 0
    while si < iface.structs.len():
        val s = iface.structs[si]
        strtab.add(s.name)
        var fli = 0
        while fli < s.fields.len():
            strtab.add(s.fields[fli].name)
            strtab.add(s.fields[fli].type_name)
            fli = fli + 1
        si = si + 1

    # Classes
    var ci = 0
    while ci < iface.classes.len():
        val c = iface.classes[ci]
        strtab.add(c.name)
        var fli = 0
        while fli < c.fields.len():
            strtab.add(c.fields[fli].name)
            strtab.add(c.fields[fli].type_name)
            fli = fli + 1
        var mi = 0
        while mi < c.methods.len():
            strtab.add(c.methods[mi].name)
            mi = mi + 1
        ci = ci + 1

    # Enums
    var ei = 0
    while ei < iface.enums.len():
        val e = iface.enums[ei]
        strtab.add(e.name)
        var vi = 0
        while vi < e.variants.len():
            strtab.add(e.variants[vi])
            vi = vi + 1
        ei = ei + 1

    # Traits
    var ti = 0
    while ti < iface.traits.len():
        val t = iface.traits[ti]
        strtab.add(t.name)
        var mi = 0
        while mi < t.methods.len():
            strtab.add(t.methods[mi])
            mi = mi + 1
        ti = ti + 1

    # Reexports
    var ri = 0
    while ri < iface.reexports.len():
        strtab.add(iface.reexports[ri].symbol_name)
        strtab.add(iface.reexports[ri].source_module)
        ri = ri + 1

    # Type layouts
    var tli = 0
    while tli < iface.type_layouts.len():
        strtab.add(iface.type_layouts[tli].type_name)
        tli = tli + 1

    # Dependencies
    var di = 0
    while di < iface.dependencies.len():
        strtab.add(iface.dependencies[di].module_path)
        di = di + 1

# --- Section writers ---

fn shb_write_functions(fns: [ShbFnEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, fns.len())
    var i = 0
    while i < fns.len():
        val f = fns[i]
        w = shb_push_u32_le(w, strtab.get_offset(f.name))
        w = shb_push_u16_le(w, f.params.len())
        w = shb_push_u32_le(w, strtab.get_offset(f.return_type))
        w = shb_push_u16_le(w, f.flags)
        # Params
        var pi = 0
        while pi < f.params.len():
            w = shb_push_u32_le(w, strtab.get_offset(f.params[pi].name))
            w = shb_push_u32_le(w, strtab.get_offset(f.params[pi].type_name))
            pi = pi + 1
        i = i + 1
    w

fn shb_write_structs(structs: [ShbStructEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, structs.len())
    var i = 0
    while i < structs.len():
        val s = structs[i]
        w = shb_push_u32_le(w, strtab.get_offset(s.name))
        w = shb_push_u16_le(w, s.fields.len())
        w = shb_push_u16_le(w, s.flags)
        var fi = 0
        while fi < s.fields.len():
            w = shb_push_u32_le(w, strtab.get_offset(s.fields[fi].name))
            w = shb_push_u32_le(w, strtab.get_offset(s.fields[fi].type_name))
            w = shb_push_u32_le(w, s.fields[fi].flags)
            fi = fi + 1
        i = i + 1
    w

fn shb_write_classes(classes: [ShbClassEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, classes.len())
    var i = 0
    while i < classes.len():
        val c = classes[i]
        w = shb_push_u32_le(w, strtab.get_offset(c.name))
        w = shb_push_u16_le(w, c.fields.len())
        w = shb_push_u16_le(w, c.flags)
        var fi = 0
        while fi < c.fields.len():
            w = shb_push_u32_le(w, strtab.get_offset(c.fields[fi].name))
            w = shb_push_u32_le(w, strtab.get_offset(c.fields[fi].type_name))
            w = shb_push_u32_le(w, c.fields[fi].flags)
            fi = fi + 1
        w = shb_push_u16_le(w, c.methods.len())
        var mi = 0
        while mi < c.methods.len():
            w = shb_push_u32_le(w, strtab.get_offset(c.methods[mi].name))
            mi = mi + 1
        i = i + 1
    w

fn shb_write_enums(enums: [ShbEnumEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, enums.len())
    var i = 0
    while i < enums.len():
        val e = enums[i]
        w = shb_push_u32_le(w, strtab.get_offset(e.name))
        w = shb_push_u16_le(w, e.variants.len())
        w = shb_push_u16_le(w, e.flags)
        var vi = 0
        while vi < e.variants.len():
            w = shb_push_u32_le(w, strtab.get_offset(e.variants[vi]))
            vi = vi + 1
        i = i + 1
    w

fn shb_write_traits(traits: [ShbTraitEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, traits.len())
    var i = 0
    while i < traits.len():
        val t = traits[i]
        w = shb_push_u32_le(w, strtab.get_offset(t.name))
        w = shb_push_u16_le(w, t.methods.len())
        w = shb_push_u16_le(w, t.flags)
        var mi = 0
        while mi < t.methods.len():
            w = shb_push_u32_le(w, strtab.get_offset(t.methods[mi]))
            mi = mi + 1
        i = i + 1
    w

fn shb_write_reexports(reexports: [ShbReexportEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, reexports.len())
    var i = 0
    while i < reexports.len():
        w = shb_push_u32_le(w, strtab.get_offset(reexports[i].symbol_name))
        w = shb_push_u32_le(w, strtab.get_offset(reexports[i].source_module))
        i = i + 1
    w

fn shb_write_type_layouts(layouts: [ShbTypeLayoutEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, layouts.len())
    var i = 0
    while i < layouts.len():
        val l = layouts[i]
        w = shb_push_u32_le(w, strtab.get_offset(l.type_name))
        w = shb_push_u32_le(w, l.size)
        w = shb_push_u32_le(w, l.alignment)
        w = shb_push_u32_le(w, l.flags)
        i = i + 1
    w

fn shb_write_dependencies(deps: [ShbDependencyEntry], strtab: ShbStringTable, out: [u8]) -> [u8]:
    var w = shb_push_u32_le(out, deps.len())
    var i = 0
    while i < deps.len():
        w = shb_push_u32_le(w, strtab.get_offset(deps[i].module_path))
        w = shb_push_i64_le(w, deps[i].interface_hash)
        i = i + 1
    w

fn shb_push_u8(out: [u8], value: u8) -> [u8]:
    var bytes = out
    bytes.push(value)
    bytes

fn shb_push_u16_le(out: [u8], value: i64) -> [u8]:
    var bytes = out
    bytes.push((value & 0xFF) as u8)
    bytes.push(((value >> 8) & 0xFF) as u8)
    bytes

fn shb_push_u32_le(out: [u8], value: i64) -> [u8]:
    var bytes = out
    bytes.push((value & 0xFF) as u8)
    bytes.push(((value >> 8) & 0xFF) as u8)
    bytes.push(((value >> 16) & 0xFF) as u8)
    bytes.push(((value >> 24) & 0xFF) as u8)
    bytes

fn shb_push_i64_le(out: [u8], value: i64) -> [u8]:
    var bytes = out
    bytes.push((value & 0xFF) as u8)
    bytes.push(((value >> 8) & 0xFF) as u8)
    bytes.push(((value >> 16) & 0xFF) as u8)
    bytes.push(((value >> 24) & 0xFF) as u8)
    bytes.push(((value >> 32) & 0xFF) as u8)
    bytes.push(((value >> 40) & 0xFF) as u8)
    bytes.push(((value >> 48) & 0xFF) as u8)
    bytes.push(((value >> 56) & 0xFF) as u8)
    bytes

fn shb_push_bytes(out: [u8], extra: [u8]) -> [u8]:
    var bytes = out
    var i = 0
    while i < extra.len():
        bytes.push(extra[i])
        i = i + 1
    bytes

# --- FFI ---

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_move(from: text, to: text) -> bool
