# Driver API Native Single [Tier 4] - Native single-file compilation helpers.
#
# Dependency rules:
#   - May import from: driver_api_types (Tier 0), driver_core_types
#   - Must NOT import from Tier 5 files
#   - Uses `use lazy` for CompilerDriver

use compiler.common.driver_core_types.{CompileOptions, CompileMode, CompileResult, OutputFormat}
use lazy compiler.driver.driver.{CompilerDriver}

fn aot_native_file_with_backend(path: text, output: text, backend: text) -> CompileResult:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = true
    options.optimize = true
    options.opt_level = 3
    val driver = CompilerDriver.create(options)
    driver.compile()

fn aot_llvm_native_file(path: text, output: text) -> CompileResult:
    var options = CompileOptions.default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = "llvm"
    options.release = true
    options.optimize = true
    options.opt_level = 3
    val driver = CompilerDriver.create(options)
    CompilerDriver.run_compile(driver)

export aot_native_file_with_backend, aot_llvm_native_file
