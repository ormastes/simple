#![allow(unnamed_duplicate_typed_args)]
use compiler.common.driver_core_types.{CompileResult}
use compiler.driver.driver_public_shared.{find_simple_binary, clean_child_output}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_path_join(a: text, b: text) -> text

# Lightweight bridge for public `compiler.driver.{...}` imports.
# `interpret_file` shells out to keep external script calls lightweight.
# The header helper uses a lightweight source parser because direct external
# execution of the full driver helper path is still unstable in interpreter mode.

fn interpret_file(path: text) -> CompileResult:
    val simple_bin = find_simple_binary()
    val (stdout, stderr, exit_code) = rt_process_run(simple_bin, [path])
    val combined = _clean_child_output(stdout, stderr)
    if _looks_like_driver_failure(combined):
        return CompileResult.RuntimeError(combined)
    if exit_code == 0 or combined == "":
        return CompileResult.Success(combined)
    CompileResult.Success(combined)

fn generate_headers(path: text, output_dir: text, lib_name: text, emit_c: bool, emit_cpp: bool) -> CompileResult:
    val source = rt_file_read_text(path) ?? ""
    if source.trim() == "":
        return CompileResult.RuntimeError("failed to read source file: {path}")

    val parsed = _parse_public_exports(source)
    if parsed.error != "":
        return CompileResult.RuntimeError(parsed.error)

    if parsed.exported_classes.len() == 0 and parsed.exported_functions.len() == 0:
        return CompileResult.RuntimeError("no @export(\"C\") items found in {path}")

    if not _ensure_output_dir(output_dir):
        return CompileResult.RuntimeError("failed to create output directory: {output_dir}")

    if emit_c:
        val c_header = _emit_public_c_header(lib_name, parsed.exported_functions, parsed.exported_classes)
        val c_path = rt_path_join(output_dir, lib_name + ".h")
        if not rt_file_write_text(c_path, c_header):
            return CompileResult.RuntimeError("failed to write generated header: {c_path}")
        if not rt_file_exists(c_path):
            return CompileResult.RuntimeError("generated header missing after write: {c_path}")

    if emit_cpp:
        val cpp_header = _emit_public_cpp_header(lib_name, parsed.exported_classes, parsed.exported_functions)
        val cpp_path = rt_path_join(output_dir, lib_name + ".hpp")
        if not rt_file_write_text(cpp_path, cpp_header):
            return CompileResult.RuntimeError("failed to write generated C++ header: {cpp_path}")
        if not rt_file_exists(cpp_path):
            return CompileResult.RuntimeError("generated C++ header missing after write: {cpp_path}")

    CompileResult.Success(nil)

fn _ensure_output_dir(path: text) -> bool:
    if rt_dir_create(path, true):
        return true
    val (_, _, exit_code) = rt_process_run("mkdir", ["-p", path])
    exit_code == 0

fn _clean_child_output(stdout: text, stderr: text) -> text:
    val base = clean_child_output(stdout, stderr)
    val lines = base.split("\n")
    var kept: [text] = []
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line != "__SIMPLE_DRIVER_OK__":
            kept = kept.push(line)
        i = i + 1
    kept.join("\n")

fn _looks_like_driver_failure(output: text) -> bool:
    val trimmed = output.trim()
    if trimmed == "":
        return false
    trimmed.contains("error:") or
    trimmed.contains("panic") or
        trimmed.contains("ParseError") or
        trimmed.contains("TypeError") or
        trimmed.contains("RuntimeError")

fn _escape_simple_text(value: text) -> text:
    val escaped_slashes = value.replace("\\", "\\\\")
    escaped_slashes.replace("\"", "\\\"")

fn _combine_process_error(prefix: text, stdout: text, stderr: text) -> text:
    var detail = stderr.trim()
    if detail == "":
        detail = stdout.trim()
    if detail == "":
        return prefix
    prefix + ": " + detail

struct PublicExportField:
    name: text
    type_name: text
    raw_decl: text
    has_bits: bool
    bits_width: text

struct PublicExportClass:
    name: text
    fields: [PublicExportField]
    methods: [PublicExportMethod]

struct PublicExportFunction:
    name: text
    params: [text]
    return_type: text

struct PublicExportMethod:
    name: text
    params: [text]
    return_type: text
    is_static: bool

struct PublicExportParse:
    exported_classes: [PublicExportClass]
    exported_functions: [PublicExportFunction]
    error: text

fn _parse_public_exports(source: text) -> PublicExportParse:
    val lines = source.split("\n")
    var classes: [PublicExportClass] = []
    var functions: [PublicExportFunction] = []
    var pending_export = false
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line == "":
            i = i + 1
            continue
        if line == "@export(\"C\")":
            pending_export = true
            i = i + 1
            continue
        if line.starts_with("@"):
            i = i + 1
            continue
        if pending_export and line.starts_with("class "):
            val class_name = _parse_class_name(line)
            if class_name == "":
                return PublicExportParse(exported_classes: classes, exported_functions: functions, error: "failed to parse exported class declaration")
            val class_result = _parse_export_class(lines, i + 1)
            if class_result.error != "":
                return PublicExportParse(exported_classes: classes, exported_functions: functions, error: class_result.error)
            classes = classes.push(PublicExportClass(name: class_name, fields: class_result.fields, methods: class_result.methods))
            pending_export = false
            i = class_result.next_index
            continue
        if pending_export and line.starts_with("fn "):
            val function_result = _parse_export_function(line)
            if function_result.error != "":
                return PublicExportParse(exported_classes: classes, exported_functions: functions, error: function_result.error)
            functions = functions.push(function_result.exported_fn)
            pending_export = false
            i = i + 1
            continue
        pending_export = false
        i = i + 1

    PublicExportParse(exported_classes: classes, exported_functions: functions, error: "")

struct PublicFieldParse:
    fields: [PublicExportField]
    methods: [PublicExportMethod]
    next_index: i64
    error: text

struct PublicFunctionParse:
    exported_fn: PublicExportFunction
    error: text

struct PublicMethodParse:
    exported_method: PublicExportMethod
    error: text

fn _parse_class_name(line: text) -> text:
    if not line.starts_with("class "):
        return ""
    val rest = line.substring(6).trim()
    val parts = rest.split(":")
    if parts.len() == 0:
        return rest
    parts[0].trim()

fn _leading_spaces(line: text) -> i64:
    var i = 0
    while i < line.len() and line[i:i + 1] == " ":
        i = i + 1
    i

fn _parse_export_class(lines: [text], start_index: i64) -> PublicFieldParse:
    var fields: [PublicExportField] = []
    var methods: [PublicExportMethod] = []
    var i = start_index
    while i < lines.len():
        val raw = lines[i]
        val trimmed = raw.trim()
        if trimmed == "":
            i = i + 1
            continue
        val indent = _leading_spaces(raw)
        if indent < 4:
            return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "")
        if indent > 4:
            i = i + 1
            continue
        if trimmed.starts_with("@"):
            i = i + 1
            continue
        if trimmed.starts_with("static fn ") or trimmed.starts_with("fn ") or trimmed.starts_with("me "):
            val method_result = _parse_export_method(trimmed)
            if method_result.error != "":
                return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: method_result.error)
            methods = methods.push(method_result.exported_method)
            i = i + 1
            continue
        if trimmed.starts_with("class "):
            return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "")
        val field_parts = trimmed.split(":")
        if field_parts.len() < 2:
            return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "failed to parse exported field: {trimmed}")
        val field_name = field_parts[0].trim()
        var type_part = field_parts[1].trim()
        var has_bits = false
        var bits_width = ""
        if type_part.contains("@bits("):
            has_bits = true
            val bits_parts = type_part.split("@bits(")
            if bits_parts.len() < 2:
                return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "failed to parse @bits width for field: {field_name}")
            val bits_text_parts = bits_parts[1].split(")")
            if bits_text_parts.len() == 0:
                return PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "failed to parse @bits width for field: {field_name}")
            bits_width = bits_text_parts[0].trim()
            type_part = bits_parts[0].trim()
        fields = fields.push(PublicExportField(name: field_name, type_name: type_part, raw_decl: trimmed, has_bits: has_bits, bits_width: bits_width))
        i = i + 1
    PublicFieldParse(fields: fields, methods: methods, next_index: i, error: "")

fn _parse_export_method(line: text) -> PublicMethodParse:
    val normalized = if line.starts_with("static fn "):
        line.substring(10).trim()
    elif line.starts_with("fn "):
        line.substring(3).trim()
    else:
        line.substring(3).trim()
    val parsed = _parse_signature_parts(normalized)
    if parsed.error != "":
        return PublicMethodParse(exported_method: PublicExportMethod(name: "", params: [], return_type: "", is_static: false), error: parsed.error)
    PublicMethodParse(
        exported_method: PublicExportMethod(
            name: parsed.name,
            params: parsed.params,
            return_type: parsed.return_type,
            is_static: line.starts_with("static fn ")
        ),
        error: ""
    )

fn _parse_export_function(line: text) -> PublicFunctionParse:
    val parsed = _parse_signature_parts(line.substring(3).trim())
    if parsed.error != "":
        return PublicFunctionParse(exported_fn: PublicExportFunction(name: "", params: [], return_type: ""), error: parsed.error)
    PublicFunctionParse(
        exported_fn: PublicExportFunction(name: parsed.name, params: parsed.params, return_type: parsed.return_type),
        error: ""
    )

struct PublicSignatureParse:
    name: text
    params: [text]
    return_type: text
    error: text

fn _parse_signature_parts(signature: text) -> PublicSignatureParse:
    val fn_parts = signature.split("(")
    if fn_parts.len() < 2:
        return PublicSignatureParse(name: "", params: [], return_type: "", error: "failed to parse exported function declaration")
    val fn_name = fn_parts[0].trim()
    val tail = fn_parts[1]
    val tail_parts = tail.split(")")
    if tail_parts.len() < 2:
        return PublicSignatureParse(name: "", params: [], return_type: "", error: "failed to parse exported function declaration")
    val params_text = tail_parts[0].trim()
    var params: [text] = []
    if params_text != "":
        val parts = params_text.split(",")
        var i = 0
        while i < parts.len():
            val param = parts[i].trim()
            val param_parts = param.split(":")
            if param_parts.len() < 2:
                return PublicSignatureParse(name: "", params: [], return_type: "", error: "failed to parse parameter in exported function: {fn_name}")
            params = params.push(param_parts[1].trim())
            i = i + 1
    val return_type = if tail_parts[1].contains("->"):
        val ret_parts = tail_parts[1].split("->")
        if ret_parts.len() < 2:
            "unit"
        else:
            val suffix = ret_parts[1].trim()
            val suffix_parts = suffix.split(":")
            suffix_parts[0].trim()
    else:
        "unit"
    PublicSignatureParse(name: fn_name, params: params, return_type: return_type, error: "")

fn _emit_public_c_header(lib_name: text, functions: [PublicExportFunction], classes: [PublicExportClass]) -> text:
    val guard_name = _public_guard_name(lib_name)
    var lines: [text] = []
    lines.push("#ifndef {guard_name}_H")
    lines.push("#define {guard_name}_H")
    lines.push("")
    lines.push("#include <stdint.h>")
    lines.push("#include <stddef.h>")
    lines.push("#include <stdbool.h>")
    lines.push("")
    lines.push("#ifdef __cplusplus")
    lines.push("extern \"C\" {")
    lines.push("#endif")
    lines.push("")
    lines.push("void spl_library_init(void);")
    lines.push("void spl_library_shutdown(void);")
    if _public_has_result_functions(functions):
        lines.push("typedef struct spl_error_t spl_error_t;")
        lines.push("const char* spl_error_message(const spl_error_t* err);")
        lines.push("void spl_error_free(spl_error_t* err);")
    lines.push("")

    var ci = 0
    while ci < classes.len():
        val class_ = classes[ci]
        val prefix = "spl_" + class_.name
        lines.push("typedef struct {prefix} {prefix}_t;")
        lines.push("")
        val create_method = _public_find_class_create_method(class_)
        if create_method.?:
            val method = create_method.unwrap()
            lines.push("{prefix}_t* {prefix}_create(" + _public_c_fn_param_list(method.params) + ");")
        else:
            lines.push("{prefix}_t* {prefix}_create(" + _public_ctor_params(class_.fields) + ");")
        lines.push("void {prefix}_destroy({prefix}_t* self);")
        var mi = 0
        while mi < class_.methods.len():
            val method = class_.methods[mi]
            if method.name != "create":
                lines.push(_public_c_method_decl(class_, method))
            mi = mi + 1
        lines.push("")
        lines.push("typedef struct {prefix}_layout {")
        var fi = 0
        while fi < class_.fields.len():
            val field = class_.fields[fi]
            lines.push("    " + _public_c_field_decl(field))
            fi = fi + 1
        lines.push("} {prefix}_layout;")
        lines.push("#ifdef __cplusplus")
        lines.push("static_assert(sizeof({prefix}_layout) >= 1, \"{class_.name} layout\");")
        lines.push("#else")
        lines.push("_Static_assert(sizeof({prefix}_layout) >= 1, \"{class_.name} layout\");")
        lines.push("#endif")
        lines.push("")
        ci = ci + 1

    var fi = 0
    while fi < functions.len():
        val func = functions[fi]
        lines.push(_public_c_fn_decl(func))
        fi = fi + 1

    if functions.len() > 0:
        lines.push("")
    lines.push("#ifdef __cplusplus")
    lines.push("}")
    lines.push("#endif")
    lines.push("")
    lines.push("#endif /* {guard_name}_H */")
    lines.join("\n")

fn _emit_public_cpp_header(lib_name: text, classes: [PublicExportClass], functions: [PublicExportFunction]) -> text:
    var lines: [text] = []
    lines.push("#pragma once")
    lines.push("")
    lines.push("#include \"{lib_name}.h\"")
    lines.push("")
    lines.push("#include <memory>")
    lines.push("#include <string>")
    lines.push("#include <utility>")
    lines.push("#include <cstddef>")
    lines.push("#ifdef SIMPLE_SFFI_ENABLE_CPP_EXCEPTIONS")
    lines.push("#include <stdexcept>")
    lines.push("#endif")
    lines.push("")
    lines.push("namespace spl {")
    lines.push("")
    lines.push("class Library {")
    lines.push("public:")
    lines.push("    Library() noexcept { spl_library_init(); }")
    lines.push("    ~Library() noexcept { spl_library_shutdown(); }")
    lines.push("    Library(const Library&) = delete;")
    lines.push("    Library& operator=(const Library&) = delete;")
    lines.push("};")
    lines.push("")

    var ci = 0
    while ci < classes.len():
        val class_ = classes[ci]
        val prefix = "spl_" + class_.name
        lines.push("class {class_.name} {")
        lines.push("    {prefix}_t* handle_;")
        lines.push("")
        lines.push("public:")
        lines.push("    explicit {class_.name}({prefix}_t* handle) noexcept : handle_(handle) {}")
        val create_method = _public_find_class_create_method(class_)
        if create_method.?:
            val method = create_method.unwrap()
            lines.push("    static {class_.name} create(" + _public_cpp_fn_params(method.params) + ") {")
            lines.push("        return {class_.name}({prefix}_create(" + _public_cpp_fn_args(method.params) + "));")
            lines.push("    }")
        lines.push("    ~{class_.name}() noexcept {")
        lines.push("        if (handle_) {prefix}_destroy(handle_);")
        lines.push("    }")
        lines.push("")
        lines.push("    {class_.name}(const {class_.name}&) = delete;")
        lines.push("    {class_.name}& operator=(const {class_.name}&) = delete;")
        lines.push("")
        lines.push("    {class_.name}({class_.name}&& other) noexcept : handle_(other.handle_) {")
        lines.push("        other.handle_ = nullptr;")
        lines.push("    }")
        lines.push("")
        lines.push("    {class_.name}& operator=({class_.name}&& other) noexcept {")
        lines.push("        if (this != &other) {")
        lines.push("            if (handle_) {prefix}_destroy(handle_);")
        lines.push("            handle_ = other.handle_;")
        lines.push("            other.handle_ = nullptr;")
        lines.push("        }")
        lines.push("        return *this;")
        lines.push("    }")
        var mi = 0
        while mi < class_.methods.len():
            val method = class_.methods[mi]
            if method.name != "create":
                val wrapper_lines = _public_cpp_method_wrapper(class_, method)
                var wi = 0
                while wi < wrapper_lines.len():
                    lines.push(wrapper_lines[wi])
                    wi = wi + 1
            mi = mi + 1
        lines.push("};")
        lines.push("")
        ci = ci + 1

    if functions.len() > 0:
        lines.push("// --- Free functions ---")
        lines.push("")
        var fi = 0
        while fi < functions.len():
            val func = functions[fi]
            val wrapper_lines = _public_cpp_free_function_wrapper(func)
            var wi = 0
            while wi < wrapper_lines.len():
                lines.push(wrapper_lines[wi])
                wi = wi + 1
            fi = fi + 1

    lines.push("} // namespace spl")
    lines.push("")
    lines.join("\n")

fn _public_guard_name(lib_name: text) -> text:
    var guard = lib_name.upper()
    guard = guard.replace("-", "_")
    guard = guard.replace(".", "_")
    guard = guard.replace(" ", "_")
    guard

fn _public_ctor_params(fields: [PublicExportField]) -> text:
    if fields.len() == 0:
        return "void"
    var params: [text] = []
    var i = 0
    while i < fields.len():
        val field = fields[i]
        params = params.push(_public_field_param_c_type(field) + " " + field.name)
        i = i + 1
    params.join(", ")

fn _public_cpp_ctor_params(fields: [PublicExportField]) -> text:
    if fields.len() == 0:
        return ""
    var params: [text] = []
    var i = 0
    while i < fields.len():
        val field = fields[i]
        params = params.push(_public_field_param_cpp_type(field) + " " + field.name)
        i = i + 1
    params.join(", ")

fn _public_cpp_ctor_args(fields: [PublicExportField]) -> text:
    var args: [text] = []
    var i = 0
    while i < fields.len():
        args = args.push(fields[i].name)
        i = i + 1
    args.join(", ")

fn _public_c_field_decl(field: PublicExportField) -> text:
    val c_type = _public_field_storage_c_type(field)
    if field.has_bits:
        return "{c_type} {field.name} : {field.bits_width};"
    "{c_type} {field.name};"

fn _public_c_fn_decl(func: PublicExportFunction) -> text:
    val export_name = func.name
    if _public_is_result_type(func.return_type):
        val ok_type = _public_result_ok_type(func.return_type)
        val base = _public_c_fn_param_list(func.params)
        val params = if base == "void": "spl_error_t** err_out" else: base + ", spl_error_t** err_out"
        return _public_c_type(ok_type) + " " + export_name + "(" + params + ");"
    val ret = _public_c_type(func.return_type)
    if func.params.len() == 0:
        return "{ret} {export_name}(void);"
    "{ret} {export_name}(" + _public_c_fn_param_list(func.params) + ");"

fn _public_c_method_decl(class_: PublicExportClass, method: PublicExportMethod) -> text:
    val prefix = "spl_" + class_.name
    val export_name = prefix + "_" + method.name
    val ret = if method.return_type == class_.name: prefix + "_t*" else: _public_c_type(method.return_type)
    var params: [text] = []
    if not method.is_static:
        params = params.push(prefix + "_t* self")
    var i = 0
    while i < method.params.len():
        params = params.push(_public_c_type(method.params[i]) + " arg" + "{i}")
        i = i + 1
    val params_str = if params.len() == 0: "void" else: params.join(", ")
    "{ret} {export_name}(" + params_str + ");"

fn _public_cpp_fn_params(params: [text]) -> text:
    if params.len() == 0:
        return ""
    var rendered: [text] = []
    var i = 0
    while i < params.len():
        rendered = rendered.push(_public_cpp_type(params[i]) + " arg" + "{i}")
        i = i + 1
    rendered.join(", ")

fn _public_cpp_fn_args(params: [text]) -> text:
    var args: [text] = []
    var i = 0
    while i < params.len():
        args = args.push("arg" + "{i}")
        i = i + 1
    args.join(", ")

fn _public_cpp_method_wrapper(class_: PublicExportClass, method: PublicExportMethod) -> [text]:
    val prefix = "spl_" + class_.name
    val export_name = prefix + "_" + method.name
    val cpp_ret = _public_cpp_type(method.return_type)
    val cpp_params = _public_cpp_fn_params(method.params)
    val call_args = if method.params.len() == 0:
        "handle_"
    else:
        "handle_, " + _public_cpp_fn_args(method.params)
    var lines: [text] = []
    lines.push("    " + cpp_ret + " " + method.name + "(" + cpp_params + ") {")
    if cpp_ret == "void":
        lines.push("        " + export_name + "(" + call_args + ");")
    else:
        lines.push("        return " + export_name + "(" + call_args + ");")
    lines.push("    }")
    lines.push("")
    lines

fn _public_cpp_free_function_wrapper(func: PublicExportFunction) -> [text]:
    if _public_is_result_type(func.return_type):
        return _public_cpp_result_wrapper(func)
    val cpp_ret = _public_cpp_type(func.return_type)
    val cpp_params = _public_cpp_fn_params(func.params)
    val c_args = _public_cpp_fn_args(func.params)
    var lines: [text] = []
    lines.push("inline {cpp_ret} {func.name}({cpp_params}) {")
    val call_expr = "::" + func.name + "(" + c_args + ")"
    if cpp_ret == "void":
        lines.push("    {call_expr};")
    else:
        lines.push("    return {call_expr};")
    lines.push("}")
    lines.push("")
    lines

fn _public_cpp_result_wrapper(func: PublicExportFunction) -> [text]:
    val ok_type = _public_cpp_type(_public_result_ok_type(func.return_type))
    val cpp_params = _public_cpp_fn_params(func.params)
    val c_args = _public_cpp_fn_args(func.params)
    var lines: [text] = []
    var params_with_outputs = if cpp_params == "": "" else: cpp_params + ", "
    params_with_outputs = params_with_outputs + ok_type + "* out_value, std::string* out_error = nullptr"
    lines.push("inline bool " + func.name + "(" + params_with_outputs + ") noexcept {")
    lines.push("    spl_error_t* err = nullptr;")
    val c_call_args = if c_args == "": "&err" else: c_args + ", &err"
    lines.push("    " + ok_type + " result = ::" + func.name + "(" + c_call_args + ");")
    lines.push("    if (err) {")
    lines.push("        if (out_error) {")
    lines.push("            *out_error = spl_error_message(err);")
    lines.push("        }")
    lines.push("        spl_error_free(err);")
    lines.push("        return false;")
    lines.push("    }")
    lines.push("    if (out_value) {")
    lines.push("        *out_value = result;")
    lines.push("    }")
    lines.push("    if (out_error) {")
    lines.push("        out_error->clear();")
    lines.push("    }")
    lines.push("    return true;")
    lines.push("}")
    lines.push("")
    lines.push("#ifdef SIMPLE_SFFI_ENABLE_CPP_EXCEPTIONS")
    lines.push("inline " + ok_type + " " + func.name + "_or_throw(" + cpp_params + ") {")
    lines.push("    " + ok_type + " value{};")
    lines.push("    std::string error;")
    val throw_args = if c_args == "": "&value, &error" else: c_args + ", &value, &error"
    lines.push("    if (!" + func.name + "(" + throw_args + ")) {")
    lines.push("        throw std::runtime_error(error);")
    lines.push("    }")
    lines.push("    return value;")
    lines.push("}")
    lines.push("#endif")
    lines.push("")
    lines

fn _public_find_class_create_method(class_: PublicExportClass) -> Option<PublicExportMethod>:
    var i = 0
    while i < class_.methods.len():
        val method = class_.methods[i]
        if method.is_static and method.name == "create":
            return Some(method)
        i = i + 1
    None

fn _public_c_fn_param_list(params: [text]) -> text:
    if params.len() == 0:
        return "void"
    var rendered: [text] = []
    var i = 0
    while i < params.len():
        rendered = rendered.push(_public_c_type(params[i]) + " arg" + "{i}")
        i = i + 1
    rendered.join(", ")

fn _public_is_result_type(type_name: text) -> bool:
    val normalized = type_name.trim()
    normalized.starts_with("Result<")

fn _public_result_ok_type(type_name: text) -> text:
    val normalized = type_name.trim()
    val inner = normalized.replace("Result<", "")
    val parts = inner.split(",")
    if parts.len() == 0:
        return "void*"
    val ok_type = parts[0].trim()
    ok_type.replace(">", "")

fn _public_has_result_functions(functions: [PublicExportFunction]) -> bool:
    var i = 0
    while i < functions.len():
        if _public_is_result_type(functions[i].return_type):
            return true
        i = i + 1
    false

fn _public_c_type(type_name: text) -> text:
    val normalized = type_name.trim()
    if normalized.starts_with("i8"):
        return "int8_t"
    if normalized.starts_with("i16"):
        return "int16_t"
    if normalized.starts_with("i32"):
        return "int32_t"
    if normalized.starts_with("i64"):
        return "int64_t"
    if normalized.starts_with("u8"):
        return "uint8_t"
    if normalized.starts_with("u16"):
        return "uint16_t"
    if normalized.starts_with("u32"):
        return "uint32_t"
    if normalized.starts_with("u64"):
        return "uint64_t"
    if normalized.starts_with("f32"):
        return "float"
    if normalized.starts_with("f64"):
        return "double"
    if normalized.starts_with("bool"):
        return "bool"
    if normalized.starts_with("text") or normalized.starts_with("str"):
        return "const char*"
    if normalized == "unit" or normalized == "()":
        return "void"
    "void*"

fn _public_cpp_type(type_name: text) -> text:
    match type_name:
        case "text" | "str": "const std::string&"
        case _: _public_c_type(type_name)

fn _public_field_storage_c_type(field: PublicExportField) -> text:
    val raw = field.raw_decl.trim()
    if raw.contains(": u8") or raw.contains(":u8"):
        return "uint8_t"
    if raw.contains(": u16") or raw.contains(":u16"):
        return "uint16_t"
    if raw.contains(": u32") or raw.contains(":u32"):
        return "uint32_t"
    if raw.contains(": u64") or raw.contains(":u64"):
        return "uint64_t"
    if raw.contains(": i8") or raw.contains(":i8"):
        return "int8_t"
    if raw.contains(": i16") or raw.contains(":i16"):
        return "int16_t"
    if raw.contains(": i32") or raw.contains(":i32"):
        return "int32_t"
    if raw.contains(": i64") or raw.contains(":i64"):
        return "int64_t"
    if raw.contains(": f32") or raw.contains(":f32"):
        return "float"
    if raw.contains(": f64") or raw.contains(":f64"):
        return "double"
    if raw.contains(": bool") or raw.contains(":bool"):
        if field.has_bits:
            return "uint8_t"
        return "bool"
    if raw.contains(": text") or raw.contains(":text") or raw.contains(": str") or raw.contains(":str"):
        return "const char*"
    _public_c_type(field.type_name)

fn _public_field_param_c_type(field: PublicExportField) -> text:
    val raw = field.raw_decl.trim()
    if raw.contains(": bool") or raw.contains(":bool"):
        return "bool"
    _public_field_storage_c_type(field)

fn _public_field_param_cpp_type(field: PublicExportField) -> text:
    val raw = field.raw_decl.trim()
    if raw.contains(": text") or raw.contains(":text") or raw.contains(": str") or raw.contains(":str"):
        return "const std::string&"
    _public_field_param_c_type(field)
