# Compatibility runtime module loader surface.
#
# This file preserves the older method/wrapper loader API re-exported by the
# root `compiler.loader` package. Newer curated loader consumers should prefer
# the `compiler.loader.runtime` package and its explicit surface.

extern fn rt_file_exists(path: text) -> bool
use compiler.loader.jit_instantiator.{JitInstantiator}
use compiler.loader.compiler_sffi.{TypeInfo, type_to_string}
use compiler.loader.metadata_symbols.{loaded_metadata_instantiation_symbol_names, loaded_metadata_remove_path}
use compiler.loader.unload_ownership.{owned_global_symbol_names, global_symbols_without_names}
use compiler.backend.linker.smf_reader_memory.{SmfReaderMemory}
use compiler.loader.smf_mmap_native.{native_alloc_exec_memory, native_write_exec_memory, native_make_executable, native_make_rw, native_flush_icache, native_reloc_write_i32, native_reloc_write_i64}
use std.io_runtime.{file_read_bytes}

fn _path_tag(path: text) -> text:
    val base = path.split("/").last() ?? path
    val stem = base.split(".").first() ?? base
    if stem.contains("_"):
        return stem.split("_").first() ?? stem
    stem

fn _symbol_matches_path(symbol: text, path: text) -> bool:
    val tag = _path_tag(path)
    if tag == "":
        return false
    symbol.starts_with(tag + "_") or symbol.contains("_" + tag + "_")

fn _name_in(list: [text], name: text) -> bool:
    for n in list:
        if n == name:
            return true
    false

fn _metadata_instantiation_symbols(self: ModuleLoader, path: text) -> [text]:
    loaded_metadata_instantiation_symbol_names(self.jit.loaded_metadata, path)

fn _jit_cache_owner(self: ModuleLoader, sym_name: text, rec_cache) -> text:
    if rec_cache.has("owner"):
        return rec_cache["owner"]
    val rec_opt = self.jit.exec_mapper.lookup(sym_name)
    if rec_opt.?:
        return rec_opt.unwrap().owner_id
    "__jit__"

fn _jit_cached_loaded_symbol(sym_name: text, rec_cache) -> LoadedSymbol:
    val code = rec_cache["code"]
    val addr = rec_cache["address"]
    LoadedSymbol(
        name: sym_name,
        address: addr,
        size: code.len() as i64,
        ty: SymbolType.Function,
        is_jit: true,
        file_offset: 0
    )

fn _collect_unload_jit_symbols(self: ModuleLoader, path: text) -> [text]:
    var remove_jit: [text] = []
    for sym_name in _metadata_instantiation_symbols(self, path):
        if not _name_in(remove_jit, sym_name):
            remove_jit.push(sym_name)

    for sym_name in self.jit.jit_cache.keys():
        val rec_cache = self.jit.jit_cache[sym_name]
        val owner = _jit_cache_owner(self, sym_name, rec_cache)

        if owner == path or (owner == "__jit__" and _symbol_matches_path(sym_name, path)):
            if not _name_in(remove_jit, sym_name):
                remove_jit.push(sym_name)
    remove_jit

me _moduleloader_unload_impl(self: ModuleLoader, path: text):
    val remove_jit = _collect_unload_jit_symbols(self, path)
    for sym_name in remove_jit:
        self.jit.drop_cached_symbol(sym_name)

    val owned_symbols = owned_global_symbol_names(self.global_symbols, path)
    val removed_symbols = owned_symbols + remove_jit
    var rebuilt_globals: Dict<text, (text, LoadedSymbol)> = global_symbols_without_names(self.global_symbols, removed_symbols)

    for sym_name in self.jit.jit_cache.keys():
        val rec_cache = self.jit.jit_cache[sym_name]
        val mapped_owner = _jit_cache_owner(self, sym_name, rec_cache)
        rebuilt_globals[sym_name] = (mapped_owner, _jit_cached_loaded_symbol(sym_name, rec_cache))

    self.global_symbols = rebuilt_globals
    self.jit.loaded_metadata = loaded_metadata_remove_path(self.jit.loaded_metadata, path)

    if self.modules.has(path):
        self.modules = self.modules.remove(path)

enum SymbolType:
    Function
    Data

struct LoadedSymbol:
    name: text
    address: i64
    size: i64
    ty: SymbolType
    is_jit: bool
    file_offset: i64

struct LoadedModule:
    path: text
    reader: text
    symbols: Dict<text, LoadedSymbol>
    load_time: i64
    version: i64

impl LoadedModule:
    fn has_symbol(name: text) -> bool:
        self.symbols.has(name)

    fn get_symbol(name: text):
        if self.symbols.has(name):
            return Some(self.symbols[name])
        nil

    fn exported_symbols() -> [LoadedSymbol]:
        var out: [LoadedSymbol] = []
        for item in self.symbols:
            out.push(item[1])
        out

struct ModuleLoaderConfig:
    enable_jit: bool
    enable_cache: bool
    max_cache_size: i64
    verbose: bool
    hot_reload: bool

impl ModuleLoaderConfig:
    static fn default() -> ModuleLoaderConfig:
        moduleloaderconfig_default()

struct LoaderStats:
    module_count: i64
    symbol_count: i64
    jit_stats: Dict<text, i64>
    cache_stats: Dict<text, i64>

enum LoadResult:
    Success(module: LoadedModule)
    AlreadyLoaded(module: LoadedModule)
    Error(message: text)

enum SymbolResult:
    Found(symbol: LoadedSymbol, code: [u8])
    JitCompiled(symbol: LoadedSymbol, code: [u8])
    NotFound(name: text)
    Error(message: text)

struct ModuleLoader:
    config: ModuleLoaderConfig
    modules: Dict<text, LoadedModule>
    global_symbols: Dict<text, (text, LoadedSymbol)>
    jit: JitInstantiator

fn _compat_load_smf(self: ModuleLoader, path: text) -> LoadResult:
    if self.modules.has(path):
        return LoadResult.AlreadyLoaded(module: self.modules[path])
    if not rt_file_exists(path):
        return LoadResult.Error(message: "module not found: " + path)

    val smf_bytes_result = file_read_bytes(path)
    if not smf_bytes_result.?:
        return LoadResult.Error(message: "failed to read module bytes: " + path)
    val smf_bytes = smf_bytes_result.unwrap()
    val reader_result = SmfReaderMemory.from_data(smf_bytes)
    if reader_result.is_err():
        return LoadResult.Error(message: reader_result.unwrap_err())
    val reader = reader_result.unwrap()

    var symbols: Dict<text, LoadedSymbol> = {}
    val exported_smf_symbols: [SmfSymbol] = reader.exported_symbols()
    for smf_sym in exported_smf_symbols:
        val code_result = reader.read_code(smf_sym)
        if code_result.is_err():
            return LoadResult.Error(message: code_result.unwrap_err())
        val code = code_result.unwrap()
        val addr = native_alloc_exec_memory(code.len() as i64)
        if addr == 0:
            return LoadResult.Error(message: "Failed to allocate executable memory for {smf_sym.name}")
        val written = native_write_exec_memory(addr, code, 0)
        if written != code.len() as i64:
            return LoadResult.Error(message: "Failed to copy executable bytes for {smf_sym.name}")
        if not native_make_executable(addr, code.len() as i64):
            return LoadResult.Error(message: "Failed to mark executable memory for {smf_sym.name}")
        native_flush_icache(addr, code.len() as i64)
        val symbol_size: i64 = smf_sym.size as i64
        val symbol_ty: SymbolType = smf_sym.ty
        val symbol_file_offset: i64 = smf_sym.offset as i64
        val loaded_sym = LoadedSymbol(
            name: smf_sym.name,
            address: addr,
            size: symbol_size,
            ty: symbol_ty,
            is_jit: false,
            file_offset: symbol_file_offset
        )
        symbols[smf_sym.name] = loaded_sym
        self.global_symbols[smf_sym.name] = (path, loaded_sym)

    val ordered_symbols_result = reader.symbols_in_table_order()
    if ordered_symbols_result.is_err():
        return LoadResult.Error(message: ordered_symbols_result.unwrap_err())
    val ordered_symbols = ordered_symbols_result.unwrap()
    val relocs_result = reader.read_relocations()
    if relocs_result.is_err():
        return LoadResult.Error(message: relocs_result.unwrap_err())
    val relocs = relocs_result.unwrap()
    if relocs.len() > 0:
        for sym_name in symbols.keys():
            val loaded_sym = symbols[sym_name]
            if not native_make_rw(loaded_sym.address, loaded_sym.size):
                return LoadResult.Error(message: "Failed to make memory writable for relocation at {sym_name}")
            for reloc in relocs:
                if reloc.offset < 0 or reloc.offset >= loaded_sym.size:
                    return LoadResult.Error(message: "Relocation offset {reloc.offset} out of bounds")
                var target_addr = 0i64
                if reloc.symbol_index >= 0 and reloc.symbol_index < ordered_symbols.len():
                    val target_name = ordered_symbols[reloc.symbol_index].name
                    if symbols.has(target_name):
                        target_addr = symbols[target_name].address
                    else:
                        if self.global_symbols.has(target_name):
                            target_addr = self.global_symbols[target_name][1].address
                if target_addr == 0:
                    return LoadResult.Error(message: "Unresolved symbol at index {reloc.symbol_index}")
                match reloc.reloc_type:
                    1:
                        native_reloc_write_i64(loaded_sym.address, reloc.offset, target_addr + reloc.addend)
                    2:
                        native_reloc_write_i32(loaded_sym.address, reloc.offset, (target_addr - (loaded_sym.address + reloc.offset) + reloc.addend) as i32)
                    3:
                        native_reloc_write_i32(loaded_sym.address, reloc.offset, (target_addr - (loaded_sym.address + reloc.offset) + reloc.addend) as i32)
                    4:
                        native_reloc_write_i32(loaded_sym.address, reloc.offset, (target_addr - (loaded_sym.address + reloc.offset) + reloc.addend) as i32)
                    5:
                        native_reloc_write_i32(loaded_sym.address, reloc.offset, (target_addr + reloc.addend) as i32)
                    _:
                        return LoadResult.Error(message: "Unknown relocation type: {reloc.reloc_type}")
            if not native_make_executable(loaded_sym.address, loaded_sym.size):
                return LoadResult.Error(message: "Failed to restore executable memory for {sym_name}")
            native_flush_icache(loaded_sym.address, loaded_sym.size)

    val metadata_result = self.jit.load_smf_metadata(path)
    if metadata_result.is_err() and symbols.len() == 0:
        return LoadResult.Error(message: metadata_result.unwrap_err())

    val m = LoadedModule(path: path, reader: "", symbols: symbols, load_time: 0, version: 1)
    self.modules[path] = m
    LoadResult.Success(module: m)

impl ModuleLoader:
    static fn new(config: ModuleLoaderConfig) -> ModuleLoader:
        moduleloader_new(config)

    static fn with_defaults() -> ModuleLoader:
        moduleloader_with_defaults()

    fn stats() -> LoaderStats:
        LoaderStats(
            module_count: self.modules.len() as i64,
            symbol_count: self.global_symbols.len() as i64,
            jit_stats: {"cached_count": self.jit.jit_cache.len() as i64},
            cache_stats: {"template_count": 0, "instance_count": 0}
        )

    fn is_loaded(path: text) -> bool:
        self.modules.has(path)

    fn loaded_modules() -> [text]:
        var out: [text] = []
        for path in self.modules.keys():
            out.push(path)
        out

    me load(path: text) -> LoadResult:
        _compat_load_smf(self, path)

    me reload(path: text) -> LoadResult:
        self.unload(path)
        if self.modules.has(path):
            self.modules = self.modules.remove(path)
        self.load(path)

    me unload(path: text):
        if not self.modules.has(path):
            return
        val remove_jit = _collect_unload_jit_symbols(self, path)
        for sym_name in remove_jit:
            self.jit.drop_cached_symbol(sym_name)

        val owned_symbols = owned_global_symbol_names(self.global_symbols, path)
        val removed_symbols = owned_symbols + remove_jit
        var rebuilt_globals: Dict<text, (text, LoadedSymbol)> = global_symbols_without_names(self.global_symbols, removed_symbols)

        for sym_name in self.jit.jit_cache.keys():
            val rec_cache = self.jit.jit_cache[sym_name]
            val mapped_owner = _jit_cache_owner(self, sym_name, rec_cache)
            rebuilt_globals[sym_name] = (mapped_owner, _jit_cached_loaded_symbol(sym_name, rec_cache))

        self.global_symbols = rebuilt_globals
        self.jit.loaded_metadata = loaded_metadata_remove_path(self.jit.loaded_metadata, path)

        if self.modules.has(path):
            self.modules = self.modules.remove(path)

    me resolve_symbol(name: text) -> SymbolResult:
        if self.global_symbols.has(name):
            val pair = self.global_symbols[name]
            return SymbolResult.Found(symbol: pair[1], code: [])

        if self.jit.jit_cache.has(name):
            val rec_cache = self.jit.jit_cache[name]
            val code = rec_cache["code"]
            val owner = _jit_cache_owner(self, name, rec_cache)
            val sym = _jit_cached_loaded_symbol(name, rec_cache)
            self.global_symbols[name] = (owner, sym)
            return SymbolResult.JitCompiled(symbol: sym, code: code)

        match self.jit.try_jit_instantiate(name):
            case JitInstantiationResult.Success(code, sym_name, address):
                val addr = if address.?:
                    address.unwrap()
                else:
                    0
                var owner = "__jit__"
                val rec = self.jit.exec_mapper.lookup(sym_name)
                if rec.?:
                    owner = rec.unwrap().owner_id
                val sym = LoadedSymbol(
                    name: sym_name,
                    address: addr,
                    size: code.len() as i64,
                    ty: SymbolType.Function,
                    is_jit: true,
                    file_offset: 0
                )
                self.global_symbols[sym_name] = (owner, sym)
                return SymbolResult.JitCompiled(symbol: sym, code: code)
            case JitInstantiationResult.NotFound(_):
                return SymbolResult.NotFound(name: name)
            case JitInstantiationResult.CompilationError(message):
                return SymbolResult.Error(message: message)
            case JitInstantiationResult.CircularDependency(cycle):
                return SymbolResult.Error(message: "circular JIT dependency: " + cycle.join(","))
            case JitInstantiationResult.UpdateFailed(symbol, error):
                return SymbolResult.Error(message: "JIT update failed for {symbol}: {error}")

        SymbolResult.NotFound(name: name)

    fn resolve_generic(name: text, type_args: [TypeInfo]) -> SymbolResult:
        self.resolve_symbol(mangle_name(name, type_args))

    fn get_module(path: text):
        if self.modules.has(path):
            return Some(self.modules[path])
        nil

fn moduleloaderconfig_default() -> ModuleLoaderConfig:
    ModuleLoaderConfig(
        enable_jit: true,
        enable_cache: true,
        max_cache_size: 100,
        verbose: false,
        hot_reload: false
    )

fn moduleloader_new(config: ModuleLoaderConfig) -> ModuleLoader:
    ModuleLoader(
        config: config,
        modules: {},
        global_symbols: {},
        jit: JitInstantiator.new(JitInstantiatorConfig(
            update_smf: config.enable_cache,
            max_depth: 50,
            enabled: config.enable_jit,
            verbose: config.verbose
        ))
    )

fn moduleloader_with_defaults() -> ModuleLoader:
    moduleloader_new(moduleloaderconfig_default())

fn moduleloader_load(self: ModuleLoader, path: text) -> LoadResult:
    _compat_load_smf(self, path)

fn moduleloader_reload(self: ModuleLoader, path: text) -> LoadResult:
    moduleloader_unload(self, path)
    if self.modules.has(path):
        self.modules = self.modules.remove(path)
    moduleloader_load(self, path)

fn moduleloader_unload(self: ModuleLoader, path: text):
    if not self.modules.has(path):
        return
    _moduleloader_unload_impl(self, path)

fn moduleloader_resolve_symbol(self: ModuleLoader, name: text) -> SymbolResult:
    self.resolve_symbol(name)

fn moduleloader_resolve_generic(self: ModuleLoader, name: text, type_args: [TypeInfo]) -> SymbolResult:
    self.resolve_symbol(mangle_name(name, type_args))

fn mangle_name(base: text, type_args: [TypeInfo]) -> text:
    if type_args.len() == 0:
        return base

    var names: [text] = []
    for t in type_args:
        names.push(type_to_string(t))
    base + "$" + names.join("_")

fn moduleloader_stats(self: ModuleLoader) -> LoaderStats:
    self.stats()
