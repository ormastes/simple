# Compatibility compiler_sffi surface for interpreter/test runner.

class TypeInfo:
    type_name: text

class CompilerContext:
    alive: bool

    static fn create() -> CompilerContext:
        CompilerContext(alive: true)

fn make_int_type(bits: i64, signed: bool) -> TypeInfo:
    if signed:
        return TypeInfo(type_name: "i" + bits.to_string())
    TypeInfo(type_name: "u" + bits.to_string())

fn make_float_type(bits: i64) -> TypeInfo:
    TypeInfo(type_name: "f" + bits.to_string())

fn make_bool_type() -> TypeInfo:
    TypeInfo(type_name: "bool")

fn make_string_type() -> TypeInfo:
    TypeInfo(type_name: "string")

fn make_named_type(name: text) -> TypeInfo:
    TypeInfo(type_name: name)

fn type_to_string(t: TypeInfo) -> text:
    t.type_name

fn type_args_is_empty(args: [TypeInfo]) -> bool:
    args.len() == 0

fn code_bytes_len(code: [u8]) -> i64:
    code.len() as i64

fn code_len(code: [u8]) -> i64:
    code.len() as i64

fn bytes_len(code: [u8]) -> i64:
    code.len() as i64

fn compiler_create_context() -> i64:
    0

fn compiler_destroy_context(handle: i64):
    pass_dn

fn compiler_infer_types(handle: i64, code: [u8]) -> text:
    "{}"

fn compiler_instantiate_template(handle: i64, name: text, args: [TypeInfo]) -> text:
    "{}"

fn compiler_get_stats(handle: i64) -> text:
    "{}"

fn serialize_types_json(types: [TypeInfo]) -> text:
    "[]"

fn parse_types_json(json_text: text) -> [TypeInfo]:
    []

fn compiler_result_json_success(json_text: text) -> bool:
    false

fn compiler_result_json_code(json_text: text) -> [u8]:
    []

fn compiler_result_json_error(json_text: text) -> text:
    ""

export TypeInfo, CompilerContext
export make_int_type, make_float_type, make_bool_type, make_string_type, make_named_type
export type_to_string, type_args_is_empty
export code_bytes_len, code_len, bytes_len
export compiler_create_context, compiler_destroy_context
export compiler_infer_types, compiler_instantiate_template, compiler_get_stats
export serialize_types_json, parse_types_json
export compiler_result_json_success, compiler_result_json_code, compiler_result_json_error
