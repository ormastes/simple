# Shared unload-ownership helpers for loader refactors.

fn _name_in(list: [text], name: text) -> bool:
    for n in list:
        if n == name:
            return true
    false

fn owned_global_symbol_names(global_symbols, path: text) -> [text]:
    var names: [text] = []
    for item in global_symbols:
        val sym_name = item[0]
        val owner_pair = item[1]
        val owner = owner_pair[0]
        if owner == path:
            names.push(sym_name)
    names

fn global_symbols_without_names(global_symbols, names: [text]):
    var kept = {}
    for item in global_symbols:
        val sym_name = item[0]
        val owner_pair = item[1]
        if not _name_in(names, sym_name):
            kept[sym_name] = owner_pair
    kept
