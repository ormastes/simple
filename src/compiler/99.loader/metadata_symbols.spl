# Shared metadata-symbol helpers for loader refactors.

fn metadata_instantiation_symbol_names(metadata) -> [text]:
    var names: [text] = []
    for inst in metadata.instantiations:
        names.push(inst.mangled_name)
    names

fn loaded_metadata_instantiation_symbol_names(loaded_metadata, path: text) -> [text]:
    if not loaded_metadata.has(path):
        return []
    metadata_instantiation_symbol_names(loaded_metadata[path])

fn loaded_metadata_remove_path(loaded_metadata, path: text):
    if not loaded_metadata.has(path):
        return loaded_metadata
    loaded_metadata.remove(path)
