#![allow(export_outside_init)]
# Forwarding module: compiler.compiler_services -> compiler.common.compiler_services
#
# Many test files import `compiler.compiler_services.{create_default_services, ...}`.
# The actual definition lives in `compiler/00.common/compiler_services.spl` which
# resolves as `compiler.common.compiler_services`. This file re-exports everything
# so the shorter import path works.

use compiler.common.compiler_services.{
    LexerPort,
    ParserPort,
    DesugarPort,
    TypeCheckPort,
    HirLowerPort,
    MirLowerPort,
    LoggerPort,
    ModuleLoaderPort,
    CompilerServices,
    create_default_services,
    logger_debug,
    logger_info,
    logger_warn,
    logger_error
}

export LexerPort
export ParserPort
export DesugarPort
export TypeCheckPort
export HirLowerPort
export MirLowerPort
export LoggerPort
export ModuleLoaderPort
export CompilerServices
export create_default_services
export logger_debug
export logger_info
export logger_warn
export logger_error
