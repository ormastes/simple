use std.io_runtime

class PlatformAttrKey:
    key: text
    is_valid: bool

    static fn cpu() -> PlatformAttrKey:
        return PlatformAttrKey(key: "cpu", is_valid: true)

    static fn os() -> PlatformAttrKey:
        return PlatformAttrKey(key: "os", is_valid: true)

    static fn abi() -> PlatformAttrKey:
        return PlatformAttrKey(key: "abi", is_valid: true)

    static fn bit() -> PlatformAttrKey:
        return PlatformAttrKey(key: "bit", is_valid: true)

    static fn from_text(k: text) -> PlatformAttrKey:
        if k == "cpu":
            return PlatformAttrKey(key: k, is_valid: true)
        if k == "os":
            return PlatformAttrKey(key: k, is_valid: true)
        if k == "abi":
            return PlatformAttrKey(key: k, is_valid: true)
        if k == "bit":
            return PlatformAttrKey(key: k, is_valid: true)
        return PlatformAttrKey(key: k, is_valid: false)


class PlatformAttrValue:
    key: text
    value: text
    is_valid: bool

    static fn create(k: text, v: text) -> PlatformAttrValue:
        val parsed_key = PlatformAttrKey.from_text(k)
        if parsed_key.is_valid == false:
            return PlatformAttrValue(key: k, value: v, is_valid: false)
        if k == "bit":
            if v == "32":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "64":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            return PlatformAttrValue(key: k, value: v, is_valid: false)
        if k == "cpu":
            if v == "x86_64":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "aarch64":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "riscv32":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "riscv64":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "arm":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "wasm32":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            return PlatformAttrValue(key: k, value: v, is_valid: false)
        if k == "os":
            if v == "linux":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "macos":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "windows":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "freebsd":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "simpleos":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "none":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            return PlatformAttrValue(key: k, value: v, is_valid: false)
        if k == "abi":
            if v == "gnu":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "musl":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "msvc":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "eabi":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            if v == "none":
                return PlatformAttrValue(key: k, value: v, is_valid: true)
            return PlatformAttrValue(key: k, value: v, is_valid: false)
        return PlatformAttrValue(key: k, value: v, is_valid: false)

    me key_matches(other_key: text) -> bool:
        return self.key == other_key


class PlatformAttrForm:
    form: text
    has_default: bool
    bit_value: text
    cpu_value: text
    os_value: text
    abi_value: text
    key_count: i32

    static fn bare() -> PlatformAttrForm:
        return PlatformAttrForm(
            form: "bare",
            has_default: false,
            bit_value: "",
            cpu_value: "",
            os_value: "",
            abi_value: "",
            key_count: 0
        )

    static fn bit_only(bit: text) -> PlatformAttrForm:
        return PlatformAttrForm(
            form: "bit_only",
            has_default: false,
            bit_value: bit,
            cpu_value: "",
            os_value: "",
            abi_value: "",
            key_count: 1
        )

    static fn default_bit(bit: text) -> PlatformAttrForm:
        return PlatformAttrForm(
            form: "default_bit",
            has_default: true,
            bit_value: bit,
            cpu_value: "",
            os_value: "",
            abi_value: "",
            key_count: 1
        )

    static fn full(cpu: text, os: text, abi: text, bit: text) -> PlatformAttrForm:
        return PlatformAttrForm(
            form: "full",
            has_default: false,
            bit_value: bit,
            cpu_value: cpu,
            os_value: os,
            abi_value: abi,
            key_count: 4
        )

    me is_default() -> bool:
        return self.has_default

    me specificity() -> i32:
        return self.key_count


class AttrValidationResult:
    is_valid: bool
    error_kind: text
    error_detail: text

    static fn ok() -> AttrValidationResult:
        return AttrValidationResult(is_valid: true, error_kind: "", error_detail: "")

    static fn unknown_key(key: text) -> AttrValidationResult:
        return AttrValidationResult(
            is_valid: false,
            error_kind: "unknown_key",
            error_detail: "unknown key: " + key
        )

    static fn unknown_value(key: text, value: text) -> AttrValidationResult:
        return AttrValidationResult(
            is_valid: false,
            error_kind: "unknown_value",
            error_detail: "unknown value for key '" + key + "': " + value
        )

    static fn duplicate_predicate(key: text) -> AttrValidationResult:
        return AttrValidationResult(
            is_valid: false,
            error_kind: "duplicate_predicate",
            error_detail: "duplicate predicate for key: " + key
        )

    static fn duplicate_default() -> AttrValidationResult:
        return AttrValidationResult(
            is_valid: false,
            error_kind: "duplicate_default",
            error_detail: "duplicate default in @platform attribute"
        )
