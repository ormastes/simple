# Part 1 of src/compiler/30.types/type_layout.spl
use compiler.types.type_layout.*
# Type Layout Computation
#
# Computes memory layout for types including:
# - Size in bytes
# - Alignment requirements
# - Field offsets
# - Padding
#
# Supports layout attributes:
# - @repr("C")   - C-compatible layout
# - @repr("packed") or @packed - No padding between fields
# - @repr("transparent") - Same layout as single field
# - @align(N)    - Minimum alignment (power of 2)
#
# Architecture-aware sizing:
# - usize/isize scale with pointer size (8/16/32/64-bit)
# - Alignment rules vary by architecture
#
# Example:
#   @repr("C")
#   @align(16)
#   struct AlignedData:
#       x: i32
#       y: i32

use compiler.hir.hir_types.{HirType, SymbolId}
use compiler.hir.hir_definitions.{HirStruct, HirClass, HirField}
use compiler.common.diagnostics.span.{Span}
use std.common.target.{TargetArch}


# Platform predicate model for @platform layout variants.
enum PlatformAbi:
    Any
    Gnu
    Musl
    Msvc
    Eabi
    Sysv
    None_

enum PlatformBit:
    Pointer
    Bits16
    Bits32
    Bits64

struct PlatformPredicate:
    has_default: bool
    has_cpu: bool
    cpu: text
    has_os: bool
    os: text
    has_abi: bool
    abi: PlatformAbi
    has_bit: bool
    bit: PlatformBit

struct PlatformVariant:
    predicate: PlatformPredicate
    has_explicit_size: bool
    explicit_size: i64
    has_explicit_align: bool
    explicit_align: i64
    span: Span

enum PlatformDiagnosticLevel:
    Error
    Warning

enum PlatformLayoutDiagnostic:
    DuplicatePredicate(predicate: text, span: Span, previous_span: Span)
    DuplicateDefault(span: Span, previous_span: Span)
    AmbiguousPredicate(predicate: text, span: Span, previous_span: Span)
    MissingExplicitLayoutHint(span: Span)
    UnknownKey(key: text, span: Span)
    UnknownValue(key: text, value: text, span: Span)

impl PlatformLayoutDiagnostic:
    fn level() -> PlatformDiagnosticLevel:
        match self:
            case PlatformLayoutDiagnostic.MissingExplicitLayoutHint(_):
                PlatformDiagnosticLevel.Warning
            case _:
                PlatformDiagnosticLevel.Error

    fn message() -> text:
        match self:
            case PlatformLayoutDiagnostic.DuplicatePredicate(predicate, _, _):
                "duplicate @platform predicate '{predicate}'"
            case PlatformLayoutDiagnostic.DuplicateDefault(_, _):
                "duplicate @platform default fallback"
            case PlatformLayoutDiagnostic.AmbiguousPredicate(predicate, _, _):
                "ambiguous @platform predicate '{predicate}'"
            case PlatformLayoutDiagnostic.MissingExplicitLayoutHint(_):
                "@platform variant should spell out bit, size, or align explicitly"
            case PlatformLayoutDiagnostic.UnknownKey(key, _):
                "unknown @platform key '{key}'"
            case PlatformLayoutDiagnostic.UnknownValue(key, value, _):
                "unknown @platform value '{value}' for key '{key}'"

    fn span() -> Span:
        match self:
            case PlatformLayoutDiagnostic.DuplicatePredicate(_, span, _): span
            case PlatformLayoutDiagnostic.DuplicateDefault(span, _): span
            case PlatformLayoutDiagnostic.AmbiguousPredicate(_, span, _): span
            case PlatformLayoutDiagnostic.MissingExplicitLayoutHint(span): span
            case PlatformLayoutDiagnostic.UnknownKey(_, span): span
            case PlatformLayoutDiagnostic.UnknownValue(_, _, span): span

struct PlatformParseResult:
    variants: [PlatformVariant]
    diagnostics: [PlatformLayoutDiagnostic]


# Layout kind (from @repr attribute)
enum LayoutKind:
    Simple      # Default Simple language layout (like Rust)
    C           # C ABI compatible layout
    Packed      # No padding (alignment = 1)
    Transparent # Same layout as inner type


# ============================================================================
# LayoutKind Methods (was: impl LayoutKind:)
# ============================================================================

# Layout attributes for a type
struct LayoutAttr:
    layout_kind: LayoutKind   # Layout kind
    # # DESUGARED: explicit_align: i64
    has_explicit_align: bool
    explicit_align: i64
    is_packed: bool         # @packed shorthand
    is_preserve_order: bool # @preserve_order — keep declaration order
    is_compactq: bool       # @compactq — tight-pack (ignore word straddle)


# ============================================================================
# LayoutAttr Methods (was: impl LayoutAttr:)
# ============================================================================

fn layoutattr_default_() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.Simple,
            #  # DESUGARED: explicit_align: nil
            is_packed: false,
            is_preserve_order: false,
            is_compactq: false
        )


fn layoutattr_c_repr() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.C,
            #  # DESUGARED: explicit_align: nil
            is_packed: false,
            is_preserve_order: true,
            is_compactq: false
        )


fn layoutattr_packed() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.Packed,
            #  # DESUGARED: explicit_align: nil
            is_packed: true,
            is_preserve_order: false,
            is_compactq: false
        )


# Single field layout information
struct FieldLayout:
    name: text
    type_: HirType
    offset: i64     # Byte offset from struct start
    size: i64       # Size of field in bytes
    align: i64      # Alignment of field
    has_bits: bool
    bits_width: i64
    bit_offset: i64 # Bit offset within the storage unit when has_bits is true


# ============================================================================
# FieldLayout Methods (was: impl FieldLayout:)
# ============================================================================

# Complete type layout
struct TypeLayout:
    size: i64               # Total size in bytes
    align: i64              # Required alignment
    fields: [FieldLayout]   # Field layouts (for struct/class)
    stride: i64             # Size when used in array (size rounded up to align)


# ============================================================================
# TypeLayout Methods (was: impl TypeLayout:)
# ============================================================================

# Primitive type sizes (in bytes)
fn primitive_size(type_name: text) -> has_i64:
    match type_name:
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "i64": 8  # Assuming 64-bit
        case "u64": 8  # Assuming 64-bit
        case "f64": 8  # Assuming 64-bit
        case "isize": 8  # Assuming 64-bit
        case "usize": 8  # Assuming 64-bit
        case "i128": 16
        case "u128": 16
        case "()": 0
        case "unit": 0
        case "void": 0
        case _: nil

# Primitive type alignment (in bytes)
fn primitive_align(type_name: text) -> has_i64:
    match type_name:
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "i64": 8
        case "u64": 8
        case "f64": 8
        case "isize": 8
        case "usize": 8
        case "i128": 16
        case "u128": 16
        case "()": 1  # ZST has alignment 1
        case "unit": 1  # ZST has alignment 1
        case "void": 1  # ZST has alignment 1
        case _: nil

# Convert HirType to its primitive name for use with primitive_size/primitive_align
fn type__to_text(type_: HirType) -> text:
    match type_.kind:
        case HirTypeKind.Int(bits, signed):
            if signed:
                "i{bits}"
            else:
                "u{bits}"
        case HirTypeKind.Float(bits):
            "f{bits}"
        case HirTypeKind.Bool:
            "bool"
        case HirTypeKind.Char:
            "char"
        case HirTypeKind.Unit:
            "unit"
        case _:
            ""

# Return effective alignment: explicit if set, else the natural max_align
fn attr_effective_align(attr: LayoutAttr, max_align: i64) -> i64:
    if attr.has_explicit_align:
        attr.explicit_align
    else:
        max_align

fn platform_abi_from_text(name: text) -> PlatformAbi?:
    match name.lower():
        case "gnu" | "gnuabi" | "gnueabihf": Some(PlatformAbi.Gnu)
        case "musl": Some(PlatformAbi.Musl)
        case "msvc": Some(PlatformAbi.Msvc)
        case "eabi": Some(PlatformAbi.Eabi)
        case "sysv": Some(PlatformAbi.Sysv)
        case "none" | "baremetal": Some(PlatformAbi.None_)
        case _: nil

fn platform_bit_from_text(name: text) -> PlatformBit?:
    match name.lower():
        case "pointer" | "ptr" | "word": Some(PlatformBit.Pointer)
        case "16" | "bits16" | "bit16": Some(PlatformBit.Bits16)
        case "32" | "bits32" | "bit32": Some(PlatformBit.Bits32)
        case "64" | "bits64" | "bit64": Some(PlatformBit.Bits64)
        case _: nil

fn platform_cpu_from_text(name: text) -> text?:
    match name.lower():
        case "x86_64" | "amd64" | "x64": Some("x86_64")
        case "x86" | "i386" | "i686": Some("x86")
        case "aarch64" | "arm64": Some("aarch64")
        case "arm" | "armv7" | "armv6": Some("arm")
        case "riscv64" | "riscv64gc" | "rv64": Some("riscv64")
        case "riscv32" | "riscv32gc" | "rv32": Some("riscv32")
        case "wasm32" | "wasm": Some("wasm32")
        case "wasm64": Some("wasm64")
        case "avr" | "atmega" | "attiny": Some("avr")
        case "mcs51" | "mcs-51" | "8051": Some("mcs51")
        case "i8086" | "8086" | "8088": Some("i8086")
        case "msp430": Some("msp430")
        case _: nil

fn platform_os_from_text(name: text) -> text?:
    match name.lower():
        case "linux": Some("linux")
        case "windows" | "win" | "windows_nt": Some("windows")
        case "macos" | "darwin" | "mac": Some("macos")
        case "freebsd": Some("freebsd")
        case "openbsd": Some("openbsd")
        case "netbsd": Some("netbsd")
        case "android": Some("android")
        case "unix": Some("unix")
        case "none" | "baremetal": Some("none")
        case _: nil

fn platform_abi_to_text(abi: PlatformAbi) -> text:
    match abi:
        case PlatformAbi.Any: "any"
        case PlatformAbi.Gnu: "gnu"
        case PlatformAbi.Musl: "musl"
        case PlatformAbi.Msvc: "msvc"
        case PlatformAbi.Eabi: "eabi"
        case PlatformAbi.Sysv: "sysv"
        case PlatformAbi.None_: "none"

fn platform_bit_to_text(bit: PlatformBit) -> text:
    match bit:
        case PlatformBit.Pointer: "pointer"
        case PlatformBit.Bits16: "16"
        case PlatformBit.Bits32: "32"
        case PlatformBit.Bits64: "64"

fn platform_predicate_default() -> PlatformPredicate:
    PlatformPredicate(
        has_default: false,
        has_cpu: false,
        cpu: "",
        has_os: false,
        os: "",
        has_abi: false,
        abi: PlatformAbi.Any,
        has_bit: false,
        bit: PlatformBit.Pointer
    )

fn platform_predicate_signature(pred: PlatformPredicate) -> text:
    var parts: [text] = []
    if pred.has_default:
        parts.push("default")
    if pred.has_cpu:
        parts.push("cpu={pred.cpu.lower()}")
    if pred.has_os:
        parts.push("os={pred.os.lower()}")
    if pred.has_abi:
        parts.push("abi={platform_abi_to_text(pred.abi)}")
    if pred.has_bit:
        parts.push("bit={platform_bit_to_text(pred.bit)}")
    parts.join("|")

fn platform_variant_signature(variant: PlatformVariant) -> text:
    var parts: [text] = []
    val pred = variant.predicate
    parts.push(platform_predicate_signature(pred))
    if variant.has_explicit_size:
        parts.push("size={variant.explicit_size}")
    if variant.has_explicit_align:
        parts.push("align={variant.explicit_align}")
    parts.join("|")

fn platform_variant_has_layout_hint(variant: PlatformVariant) -> bool:
    variant.predicate.has_bit or variant.has_explicit_size or variant.has_explicit_align

fn platform_variant_is_default(variant: PlatformVariant) -> bool:
    variant.predicate.has_default

fn platform_variant_is_ambiguous(left: PlatformVariant, right: PlatformVariant) -> bool:
    val same_predicate = platform_predicate_signature(left.predicate) == platform_predicate_signature(right.predicate)
    val same_layout = platform_variant_signature(left) == platform_variant_signature(right)
    same_predicate and not same_layout

fn platform_cpu_for_arch(arch: TargetArch) -> text:
    match arch:
        case TargetArch.X86_64: "x86_64"
        case TargetArch.X86: "x86"
        case TargetArch.Aarch64: "aarch64"
        case TargetArch.Arm: "arm"
        case TargetArch.Riscv64: "riscv64"
        case TargetArch.Riscv32: "riscv32"
        case TargetArch.Wasm64: "wasm64"
        case TargetArch.Wasm32: "wasm32"
        case TargetArch.AVR: "avr"
        case TargetArch.MCS51: "mcs51"
        case TargetArch.I8086: "i8086"
        case TargetArch.MSP430: "msp430"

fn platform_pointer_bit_for_arch(arch: TargetArch) -> PlatformBit:
    match arch.pointer_size().bits():
        case 16: PlatformBit.Bits16
        case 32: PlatformBit.Bits32
        case 64: PlatformBit.Bits64
        case _: PlatformBit.Pointer

fn platform_bit_matches_arch(bit: PlatformBit, arch: TargetArch) -> bool:
    match bit:
        case PlatformBit.Pointer: true
        case _:
            bit == platform_pointer_bit_for_arch(arch)

fn platform_predicate_matches_arch(pred: PlatformPredicate, arch: TargetArch) -> bool:
    if pred.has_cpu and pred.cpu != platform_cpu_for_arch(arch):
        return false
    if pred.has_bit and not platform_bit_matches_arch(pred.bit, arch):
        return false
    true

fn platform_predicate_specificity(pred: PlatformPredicate) -> i64:
    var score: i64 = 0
    if pred.has_cpu:
        score = score + 1
    if pred.has_os:
        score = score + 1
    if pred.has_abi:
        score = score + 1
    if pred.has_bit:
        score = score + 1
    score

fn platform_select_variant_for_arch(variants: [PlatformVariant], arch: TargetArch) -> PlatformVariant?:
    var best: PlatformVariant? = nil
    var best_score: i64 = -1
    var fallback: PlatformVariant? = nil

    for variant in variants:
        if variant.predicate.has_default:
            if not fallback.?:
                fallback = Some(variant)
            continue

        if platform_predicate_matches_arch(variant.predicate, arch):
            val score = platform_predicate_specificity(variant.predicate)
            if score > best_score:
                best = Some(variant)
                best_score = score

    if best.?:
        return best
    fallback

fn platform_validate_variants(variants: [PlatformVariant]) -> [PlatformLayoutDiagnostic]:
    var diagnostics: [PlatformLayoutDiagnostic] = []
    var seen_keys: [text] = []
    var seen_spans: [Span] = []
    var seen_default = false
    var seen_default_span: Span? = nil

    var vi = 0
    while vi < variants.len():
        val variant = variants[vi]
        val key = platform_predicate_signature(variant.predicate)
        var is_duplicate_default = false

        if variant.predicate.has_default:
            if seen_default:
                diagnostics.push(PlatformLayoutDiagnostic.DuplicateDefault(
                    span: variant.span,
                    previous_span: seen_default_span ?? variant.span
                ))
                is_duplicate_default = true
            else:
                seen_default = true
                seen_default_span = variant.span

        if not is_duplicate_default:
            var si = 0
            while si < seen_keys.len():
                if seen_keys[si] == key:
                    val previous_span = seen_spans[si]
                    if platform_variant_is_ambiguous(variants[si], variant):
                        diagnostics.push(PlatformLayoutDiagnostic.AmbiguousPredicate(
                            predicate: key,
                            span: variant.span,
                            previous_span: previous_span
                        ))
                    else:
                        diagnostics.push(PlatformLayoutDiagnostic.DuplicatePredicate(
                            predicate: key,
                            span: variant.span,
                            previous_span: previous_span
                        ))
                    break
                si = si + 1
        if not platform_variant_has_layout_hint(variant):
            diagnostics.push(PlatformLayoutDiagnostic.MissingExplicitLayoutHint(
                span: variant.span
            ))

        seen_keys.push(key)
        seen_spans.push(variant.span)
        vi = vi + 1

    diagnostics

# Get size of a type
fn size_of_type(type_: HirType) -> i64:
    val name = type__to_text(type_)
    primitive_size(name) ?? 8  # Default to pointer size

# Get alignment of a type
fn align_of_type(type_: HirType) -> i64:
    val name = type__to_text(type_)
    primitive_align(name) ?? 8  # Default to pointer alignment

# Reorder struct fields by size descending (insertion sort, stable).
fn reorder_fields_by_size(fields: [HirField]) -> [HirField]:
    var indices: [i64] = []
    var sizes: [i64] = []
    var i: i64 = 0
    while i < fields.len():
        indices.push(i)
        sizes.push(size_of_type(fields[i].type_))
        i = i + 1

    i = 1
    while i < indices.len():
        var j = i
        while j > 0 and sizes[indices[j - 1]] < sizes[indices[j]]:
            val tmp = indices[j]
            indices[j] = indices[j - 1]
            indices[j - 1] = tmp
            j = j - 1
        i = i + 1

    var result: [HirField] = []
    for idx in indices:
        result.push(fields[idx])
    result

# Compute layout for a struct
fn compute_struct_layout(fields: [HirField], attr: LayoutAttr) -> TypeLayout:
    match attr.layout_kind:
        case LayoutKind.Packed:
            compute_packed_layout(fields)
        case LayoutKind.C:
            compute_c_layout(fields, attr)
        case LayoutKind.Transparent:
            compute_transparent_layout(fields)
        case LayoutKind.Simple:
            if attr.is_compactq:
                compute_packed_layout(if attr.is_preserve_order: fields else: reorder_fields_by_size(fields))
            elif attr.is_preserve_order:
                compute_c_layout(fields, attr)
            else:
                compute_c_layout(reorder_fields_by_size(fields), attr)

# Packed layout: no padding, alignment = 1
fn compute_packed_layout(fields: [HirField]) -> TypeLayout:
    var field_layouts: [FieldLayout] = []
    var offset: i64 = 0

    for field in fields:
        val size = size_of_type(field.type_)
        field_layouts.push(FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: offset,
            size: size,
            align: 1,
            has_bits: field.has_bits_attr,
            bits_width: if field.has_bits_attr: field.bits_width else: 0,
            bit_offset: 0
        ))
        offset = offset + size

    TypeLayout(
        size: offset,
        align: 1,
        fields: field_layouts,
        stride: offset
    )

# C ABI layout: fields in order, each aligned
