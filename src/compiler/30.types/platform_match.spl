"""
Platform Match — AC-3, AC-4, AC-5

AC-3: Match filtering — evaluate each predicate against a CompileTarget.
AC-4: Specificity selection — choose the highest-specificity matched variant.
AC-5: Default fallback — fall back to default when no specific match found.
"""

use std.io_runtime


# ─── CompileTarget ────────────────────────────────────────────────────────────

class CompileTarget:
    cpu: text
    os: text
    abi: text
    bit: text

impl CompileTarget:
    static fn create(cpu: text, os: text, abi: text, bit: text) -> CompileTarget:
        CompileTarget(cpu: cpu, os: os, abi: abi, bit: bit)

    static fn x86_64_linux() -> CompileTarget:
        CompileTarget(cpu: "x86_64", os: "linux", abi: "gnu", bit: "64")

    static fn aarch64_linux() -> CompileTarget:
        CompileTarget(cpu: "aarch64", os: "linux", abi: "gnu", bit: "64")

    static fn riscv32_none() -> CompileTarget:
        CompileTarget(cpu: "riscv32", os: "none", abi: "eabi", bit: "32")


# ─── PlatformPredMatch ────────────────────────────────────────────────────────

class PlatformPredMatch:
    key: text
    expected: text
    actual: text
    matched: bool

impl PlatformPredMatch:
    static fn check(key: text, expected: text, target_value: text) -> PlatformPredMatch:
        val did_match = expected == "" or expected == target_value
        PlatformPredMatch(key: key, expected: expected, actual: target_value, matched: did_match)

    me contributed() -> bool:
        return self.expected != ""


# ─── VariantMatch ─────────────────────────────────────────────────────────────

class VariantMatch:
    variant_id: text
    is_default: bool
    all_matched: bool
    specificity: i32
    cpu_matched: bool
    os_matched: bool
    abi_matched: bool
    bit_matched: bool

impl VariantMatch:
    static fn evaluate(vid: text, is_def: bool, cpu: text, os: text, abi: text, bit: text, target: CompileTarget) -> VariantMatch:
        val cpu_pred = PlatformPredMatch.check("cpu", cpu, target.cpu)
        val os_pred = PlatformPredMatch.check("os", os, target.os)
        val abi_pred = PlatformPredMatch.check("abi", abi, target.abi)
        val bit_pred = PlatformPredMatch.check("bit", bit, target.bit)

        val all_ok = cpu_pred.matched and os_pred.matched and abi_pred.matched and bit_pred.matched

        var spec: i32 = 0
        if cpu_pred.matched and cpu_pred.contributed():
            spec = spec + 1
        if os_pred.matched and os_pred.contributed():
            spec = spec + 1
        if abi_pred.matched and abi_pred.contributed():
            spec = spec + 1
        if bit_pred.matched and bit_pred.contributed():
            spec = spec + 1

        VariantMatch(
            variant_id: vid,
            is_default: is_def,
            all_matched: all_ok,
            specificity: spec,
            cpu_matched: cpu_pred.matched,
            os_matched: os_pred.matched,
            abi_matched: abi_pred.matched,
            bit_matched: bit_pred.matched
        )

    me is_candidate() -> bool:
        return self.all_matched


# ─── MatchSelector ────────────────────────────────────────────────────────────

class MatchSelector:
    v0_id: text
    v0_matched: bool
    v0_specificity: i32
    v0_is_default: bool

    v1_id: text
    v1_matched: bool
    v1_specificity: i32
    v1_is_default: bool

    v2_id: text
    v2_matched: bool
    v2_specificity: i32
    v2_is_default: bool

    v3_id: text
    v3_matched: bool
    v3_specificity: i32
    v3_is_default: bool

    total: i32

impl MatchSelector:
    static fn from_four(v0: VariantMatch, v1: VariantMatch, v2: VariantMatch, v3: VariantMatch) -> MatchSelector:
        MatchSelector(
            v0_id: v0.variant_id,
            v0_matched: v0.all_matched,
            v0_specificity: v0.specificity,
            v0_is_default: v0.is_default,
            v1_id: v1.variant_id,
            v1_matched: v1.all_matched,
            v1_specificity: v1.specificity,
            v1_is_default: v1.is_default,
            v2_id: v2.variant_id,
            v2_matched: v2.all_matched,
            v2_specificity: v2.specificity,
            v2_is_default: v2.is_default,
            v3_id: v3.variant_id,
            v3_matched: v3.all_matched,
            v3_specificity: v3.specificity,
            v3_is_default: v3.is_default,
            total: 4
        )

    me best_id() -> text:
        # Find highest specificity among matched candidates (non-default preferred)
        # Tiebreak: lowest slot index wins; is_ambiguous() separately signals ties
        var best_id: text = ""
        var best_spec: i32 = -1

        if self.v0_matched:
            if self.v0_specificity > best_spec:
                best_spec = self.v0_specificity
                best_id = self.v0_id

        if self.v1_matched:
            if self.v1_specificity > best_spec:
                best_spec = self.v1_specificity
                best_id = self.v1_id

        if self.v2_matched:
            if self.v2_specificity > best_spec:
                best_spec = self.v2_specificity
                best_id = self.v2_id

        if self.v3_matched:
            if self.v3_specificity > best_spec:
                best_spec = self.v3_specificity
                best_id = self.v3_id

        # No match found — fall back to first default variant
        if best_id == "":
            if self.v0_is_default:
                return self.v0_id
            if self.v1_is_default:
                return self.v1_id
            if self.v2_is_default:
                return self.v2_id
            if self.v3_is_default:
                return self.v3_id

        return best_id

    me is_ambiguous() -> bool:
        # Two or more matched non-default candidates share the highest specificity
        var top_spec: i32 = -1

        if self.v0_matched and self.v0_is_default == false:
            if self.v0_specificity > top_spec:
                top_spec = self.v0_specificity
        if self.v1_matched and self.v1_is_default == false:
            if self.v1_specificity > top_spec:
                top_spec = self.v1_specificity
        if self.v2_matched and self.v2_is_default == false:
            if self.v2_specificity > top_spec:
                top_spec = self.v2_specificity
        if self.v3_matched and self.v3_is_default == false:
            if self.v3_specificity > top_spec:
                top_spec = self.v3_specificity

        if top_spec < 0:
            return false

        var count: i32 = 0
        if self.v0_matched and self.v0_is_default == false and self.v0_specificity == top_spec:
            count = count + 1
        if self.v1_matched and self.v1_is_default == false and self.v1_specificity == top_spec:
            count = count + 1
        if self.v2_matched and self.v2_is_default == false and self.v2_specificity == top_spec:
            count = count + 1
        if self.v3_matched and self.v3_is_default == false and self.v3_specificity == top_spec:
            count = count + 1

        return count > 1

    me has_default() -> bool:
        return self.v0_is_default or self.v1_is_default or self.v2_is_default or self.v3_is_default

    me default_count() -> i32:
        var n: i32 = 0
        if self.v0_is_default:
            n = n + 1
        if self.v1_is_default:
            n = n + 1
        if self.v2_is_default:
            n = n + 1
        if self.v3_is_default:
            n = n + 1
        return n


# ─── MatchResult ──────────────────────────────────────────────────────────────

class MatchResult:
    selected_id: text
    is_ambiguous: bool
    used_default: bool
    multiple_defaults: bool
    specificity: i32

impl MatchResult:
    static fn from_selector(sel: MatchSelector) -> MatchResult:
        val chosen = sel.best_id()
        val ambig = sel.is_ambiguous()
        val multi_def = sel.default_count() > 1

        # Determine if the chosen id corresponds to a default slot (used_default)
        var used_def: bool = false
        if chosen != "":
            if chosen == sel.v0_id and sel.v0_is_default:
                used_def = true
            if chosen == sel.v1_id and sel.v1_is_default:
                used_def = true
            if chosen == sel.v2_id and sel.v2_is_default:
                used_def = true
            if chosen == sel.v3_id and sel.v3_is_default:
                used_def = true

        # Look up specificity of chosen slot
        var spec: i32 = 0
        if chosen != "":
            if chosen == sel.v0_id:
                spec = sel.v0_specificity
            if chosen == sel.v1_id and chosen != sel.v0_id:
                spec = sel.v1_specificity
            if chosen == sel.v2_id and chosen != sel.v0_id and chosen != sel.v1_id:
                spec = sel.v2_specificity
            if chosen == sel.v3_id and chosen != sel.v0_id and chosen != sel.v1_id and chosen != sel.v2_id:
                spec = sel.v3_specificity

        MatchResult(
            selected_id: chosen,
            is_ambiguous: ambig,
            used_default: used_def,
            multiple_defaults: multi_def,
            specificity: spec
        )

    me is_ok() -> bool:
        return self.selected_id != "" and self.is_ambiguous == false and self.multiple_defaults == false

    me error_kind() -> text:
        if self.is_ambiguous:
            return "ambiguous"
        if self.multiple_defaults:
            return "multiple_defaults"
        if self.selected_id == "":
            return "no_match"
        return ""
