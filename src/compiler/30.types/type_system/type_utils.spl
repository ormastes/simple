# Type System Utilities
#
# Shared helpers for type inference modules.

use compiler.frontend.parser_types_expr.{Expr, CallArg as Argument, LambdaParam}
use compiler.hir.inference.types.*
use compiler.hir.inference.infer.{InferenceEngine}
use compiler.types.type_system.module_check.{ast_type_to_inference_type_engine}

fn call_arg_value(arg: Argument) -> Expr:
    arg.value

fn lambda_param_type_or_fresh(param: LambdaParam, engine: InferenceEngine) -> Type:
    if param.has_type_:
        ast_type_to_inference_type_engine(param.type_, engine)
    else:
        engine_fresh_var(engine)
