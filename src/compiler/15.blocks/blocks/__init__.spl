# WS3: Minimal explicit re-exports for compiler.blocks.blocks.
#
# This package is used as the stable public surface for block infrastructure
# by HIR lowering, driver wiring, and builtin block definitions themselves.
# Keep it limited to the core, non-cyclic symbols that builtin definitions
# depend on. Re-exporting builtin definitions from here creates a recursive
# import path:
#   compiler.blocks.blocks -> builtin_* -> compiler.blocks.blocks

# Re-exported from registry.spl
export BlockRegistry, RegistryBuilder
export block_registry, register_block, unregister_block, is_block
export get_block, list_blocks, is_block_registered, with_block

# Re-exported from mod.spl
export enable_block, disable_block, block_info, BlockInfo
export init_blocks, reset_blocks

# Re-exported from definition.spl
export BlockDefinition
export HighlightToken, HighlightKind
export Completion, CompletionKind
export HoverInfo, SignatureHelp, Signature, Parameter
export ConstValue, Type, BlockExample

# Re-exported from context.spl
export BlockContext, BlockError, BlockErrorKind
export Diagnostic, DiagnosticLevel

# Re-exported from modes.spl
export LexerMode, LexerConfig, SyntaxFeatures, Span
export TextSpan, PreLexInfo
export BlockSkipPolicy, BlockOutlineInfo
export BlockToken, BlockTokenKind

# Re-exported from value.spl
export BlockValue, ResolvedBlock
export ShellCommands, ShellCommand, Redirect, RedirectKind
export SqlQuery, SqlKind, SqlParam
export RegexPattern
export JsonValue, JsonKind
export MarkdownDoc, MarkdownBlock
export GraphDiagram, GraphKind, GraphNode, GraphEdge

# Re-exported from builder.spl
export BlockBuilder

# Re-exported from easy.spl
export define_block
export validated_block
export define_const_block
export block
export block_with_validation
export const_block

# Re-exported from resolver.spl
export BlockResolver, ResolvedModule, ResolutionResult
export resolve_blocks, resolve_blocks_with_registry, make_block_resolver

# Re-exported from error_helpers.spl
export error_at, error_span, errors_from_strings
