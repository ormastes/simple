# Block Context - Re-export stub
#
# BlockContext, BlockError, BlockErrorKind, Diagnostic, DiagnosticLevel
# are defined in compiler.semantics.macro_validation.
#
# This file exists so that `use compiler.blocks.context.{BlockContext, ...}`
# resolves for modules in the blocks layer. The module resolver treats
# wildcard imports transitively, so importing from the defining module
# and re-exporting here keeps the public API stable.
use compiler.semantics.macro_validation.{BlockContext}

