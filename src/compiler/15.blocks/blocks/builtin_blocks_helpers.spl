# Builtin Block Helpers - Stub implementations (real code in .smf binary)
# These stubs allow the module to export the expected symbols for type-checking.

use compiler.blocks.registry.{BlockRegistry, register_block}
use compiler.blocks.definition.{ConstValue}
use compiler.blocks.value.{BlockValue}

fn sql_keywords() -> [text]:
    ["SELECT", "FROM", "WHERE", "INSERT", "UPDATE", "DELETE", "CREATE", "DROP",
     "TABLE", "INTO", "VALUES", "JOIN", "ON", "AND", "OR", "NOT", "NULL",
     "ORDER", "BY", "GROUP", "HAVING", "LIMIT", "OFFSET", "AS", "DISTINCT"]

fn parse_shell_commands(payload: text) -> [text]:
    [payload]

fn parse_sql_query(payload: text) -> text:
    payload

fn validate_regex(pattern: text) -> Result<bool, text>:
    Ok(true)

fn parse_json(payload: text) -> Result<text, text>:
    Ok(payload)

fn json_to_const(json_value: text) -> ConstValue:
    ConstValue.Text(json_value)

fn register_builtin_blocks(registry: BlockRegistry) -> BlockRegistry:
    registry

export sql_keywords, parse_shell_commands, parse_sql_query
export validate_regex, parse_json, json_to_const
export register_builtin_blocks
