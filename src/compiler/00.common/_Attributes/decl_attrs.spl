# Declaration attribute types and parsers (volatile, export, driver, vhdl, function, gpu, task).
use compiler.common.attributes.*
# Attribute Parsing - Parse and Validate Attributes
#
# Handles parsing of layout-related attributes:
# - @repr("C")         - C ABI compatible layout
# - @repr("packed")    - No padding between fields
# - @repr("transparent") - Single-field wrapper layout
# - @packed            - Shorthand for @repr("packed")
# - @align(N)          - Minimum alignment (must be power of 2)
#
# Handles parsing of volatile attributes:
# - @volatile          - Full volatile (reads and writes)
# - @volatile_read     - Read-only volatile
# - @volatile_write    - Write-only volatile
# - @nonvolatile       - Explicitly non-volatile (override)
#
# Returns a LayoutAttr for use in type layout computation.

# bypass: parsing functions need L1 (Attribute/Expr) and L3 (LayoutAttr/TypeLayoutKind) types.
# Split deferred — spawn_analysis.spl (L1) consumes parse_function_attrs/parse_task_attr,
# so moving parsing fns to L2 would create a new L1→L2 violation.
use compiler.frontend.parser_types.{Attribute}
use compiler.frontend.parser_types_expr.{Expr, ExprKind, expr_kind}
use compiler.types.type_layout.{
    LayoutAttr, TypeLayoutKind,
    PlatformAbi, PlatformBit, PlatformPredicate, PlatformVariant, PlatformParseResult,
    PlatformLayoutDiagnostic, platform_abi_from_text, platform_bit_from_text,
    platform_cpu_from_text, platform_os_from_text,
    platform_predicate_default, platform_validate_variants
}
use compiler.common.diagnostics.span.{Span}


# ============================================================================
# Volatile Attribute Types
# ============================================================================

"""Volatile access mode for memory-mapped I/O."""
enum VolatileMode:
    None_            # Normal (not volatile)
    Full            # Full volatile (reads and writes)
    ReadOnly        # Volatile reads, normal writes
    WriteOnly       # Volatile writes, normal reads
    Explicit        # Explicitly non-volatile (override)

struct VolatileAttr:
    """Volatile attribute configuration."""
    mode: VolatileMode
    address: i64?          # Fixed address for memory-mapped variable (@ addr)
    barriers: bool         # Insert memory barriers around access

# ============================================================================
# Volatile Attribute Parsing
# ============================================================================

fn parse_volatile_attrs(attrs: [Attribute]) -> VolatileAttr:
    """Extract volatile attributes from a list of attributes."""
    var mode = VolatileMode.None_
    var has_address = false
    var address_value: i64 = 0
    var barriers = false

    for attr in attrs:
        if attr.name == "volatile":
            mode = VolatileMode.Full
            # Check for @volatile(barriers: true)
            if attr.args.len() > 0:
                barriers = extract_barriers_arg(attr.args)
        elif attr.name == "volatile_read":
            mode = VolatileMode.ReadOnly
        elif attr.name == "volatile_write":
            mode = VolatileMode.WriteOnly
        elif attr.name == "nonvolatile":
            mode = VolatileMode.Explicit
        elif attr.name == "address" or attr.name == "addr":
            # @address(0x40020000) - fixed memory address
            if attr.args.len() > 0:
                val parsed_address = extract_int_arg(attr.args[0])
                if parsed_address.?:
                    match parsed_address:
                        Some(value):
                            has_address = true
                            address_value = value
                        None:
                            pass_do_nothing

    VolatileAttr(
        mode: mode,
        address: if has_address: Some(address_value) else: nil,
        barriers: barriers
    )

fn is_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile access is required."""
    (attr.mode == VolatileMode.Full or
    attr.mode == VolatileMode.ReadOnly or
    attr.mode == VolatileMode.WriteOnly)

fn is_read_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile reads are required."""
    attr.mode == VolatileMode.Full or attr.mode == VolatileMode.ReadOnly

fn is_write_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile writes are required."""
    attr.mode == VolatileMode.Full or attr.mode == VolatileMode.WriteOnly

# ============================================================================
# Export Attribute Types
# ============================================================================

struct ExportAttr:
    """Export attribute for C ABI interop.

    Marks a class or function for export with C-compatible ABI.
    Used by @export("C") annotation to generate C ABI wrappers,
    C headers, and C++ wrapper headers.

    Fields:
        is_export_c: Whether to export with C ABI
        export_name: Custom C symbol name (empty = use default mangled name)
    """
    is_export_c: bool
    export_name: text

enum DriverManifestAttrKind:
    Driver
    NativeLib

struct DriverManifestAttr:
    """Parsed @driver(...) / @native_lib(...) manifest attribute.

    `driver_class` stores the DriverClass ordinal to keep this compiler-common
    type independent from std.driver. `device_ids` stores the device id list
    exactly as it will be encoded into the DRVS record.
    """
    kind: DriverManifestAttrKind
    driver_class: i64
    vendor: i64
    device_ids: [i64]
    version: text
    abi: text

enum VhdlResetPolarity:
    ActiveLow
    ActiveHigh

enum VhdlResetSynchrony:
    Async
    Sync
    None_

struct VhdlClockedMetadata:
    """Structured @clocked(...) metadata for hardware VHDL lowering."""
    clock_signal: text
    reset_signal: text
    has_reset: bool
    reset_polarity: VhdlResetPolarity
    reset_synchrony: VhdlResetSynchrony
    domain: text
    is_valid: bool
    validation_errors: [text]

struct VhdlGenericMetadata:
    """Structured @generic(...) item preserved for VHDL entity generation."""
    name: text
    type_text: text
    default_text: text

struct VhdlReturnFieldMetadata:
    """Structured labeled return field metadata for VHDL output ports."""
    label: text
    type_text: text

struct VhdlHardwareMetadata:
    """Function-level structured metadata for pure-Simple VHDL lowering."""
    is_hardware: bool
    generics: [VhdlGenericMetadata]
    has_clocked: bool
    clocked: VhdlClockedMetadata
    return_fields: [VhdlReturnFieldMetadata]
    flatten_struct_output: bool

struct VhdlHardwareMetadataFlatRow:
    """Transport-safe flat representation of VHDL hardware metadata."""
    module_name: text
    function_name: text
    generic_names: [text]
    generic_type_texts: [text]
    generic_default_texts: [text]
    has_clocked: i64
    clock_signal: text
    reset_signal: text
    has_reset: i64
    reset_polarity: i64
    reset_synchrony: i64
    domain: text
    clocked_is_valid: i64
    clocked_validation_errors: [text]
    return_field_labels: [text]
    return_field_type_texts: [text]
    flatten_struct_output: i64

# ============================================================================
# SIMD/GPU Optimization Requirement Attributes
# ============================================================================

"""Optimization backend requirement level."""
enum OptimizationReqLevel:
    None_              # No requirement
    Must               # @must(backend) - Error if not applied
    Prefer             # @prefer(backend) - Warn if not applied
    ErrorNot           # @error_not(backend) - Explicit error if not applied
    WarnNot            # @warn_not(backend) - Explicit warning if not applied

"""Known optimization backends."""
enum OptimizationBackend:
    Unknown            # Unrecognized backend
    Simd               # Any SIMD (AVX2/AVX-512/SSE/NEON/RISC-V V)
    Avx2               # x86 AVX2
    Avx512             # x86 AVX-512
    Sse                # x86 SSE
    Neon               # ARM NEON
    RiscvV             # RISC-V Vector extension
    Cuda               # NVIDIA CUDA
    Metal              # Apple Metal
    OpenCL             # OpenCL
    Gpu                # Any GPU backend

struct OptimizationReq:
    """Optimization requirement from @must/@prefer/@error_not/@warn_not attributes.

    Examples:
        @must(simd)              # Require SIMD, error if not applied
        @prefer(avx512)          # Prefer AVX-512, warn if unavailable
        @error_not(cuda)         # Error if CUDA not used
        @warn_not(metal)         # Warn if Metal not used
    """
    level: OptimizationReqLevel
    backend: OptimizationBackend

# ============================================================================
# Named Argument Extraction Helpers
# ============================================================================

# Import shared helpers from attributes.spl
export use compiler.common.attributes.{NamedArg, extract_named_args, get_named_string_arg, get_named_int_arg, get_named_int_array_arg}

# Re-export for backward compatibility
export NamedArg, extract_named_args, get_named_string_arg, get_named_int_arg, get_named_int_array_arg

# Local implementations removed - use shared versions from attributes.spl

# ============================================================================

fn backend_from_text(name: text) -> OptimizationBackend:
    """Convert backend name to OptimizationBackend enum."""
    if name == "simd": OptimizationBackend.Simd
    elif name == "avx2": OptimizationBackend.Avx2
    elif name == "avx512" or name == "avx-512": OptimizationBackend.Avx512
    elif name == "sse": OptimizationBackend.Sse
    elif name == "neon": OptimizationBackend.Neon
    elif name == "riscv_v" or name == "riscv-v": OptimizationBackend.RiscvV
    elif name == "cuda": OptimizationBackend.Cuda
    elif name == "metal": OptimizationBackend.Metal
    elif name == "opencl": OptimizationBackend.OpenCL
    elif name == "gpu": OptimizationBackend.Gpu
    else: OptimizationBackend.Unknown

fn parse_optimization_req_attrs(attrs: [Attribute]) -> OptimizationReq:
    """Extract optimization requirement attributes from a list.

    Scans for @must, @prefer, @error_not, @warn_not with backend argument.
    Returns OptimizationReq(None_, Unknown) if none found.

    Examples:
        @must(simd)              → OptimizationReq(Must, Simd)
        @prefer(avx512)          → OptimizationReq(Prefer, Avx512)
        @error_not(cuda)         → OptimizationReq(ErrorNot, Cuda)
    """
    var level = OptimizationReqLevel.None_
    var backend = OptimizationBackend.Unknown

    for attr in attrs:
        if attr.name == "must":
            level = OptimizationReqLevel.Must
            if attr.args.len() > 0:
                val backend_name = extract_string_arg(attr.args[0])
                backend = backend_from_text(backend_name)
            else:
                # @must without args defaults to requiring any SIMD
                backend = OptimizationBackend.Simd
        elif attr.name == "prefer":
            level = OptimizationReqLevel.Prefer
            if attr.args.len() > 0:
                val backend_name = extract_string_arg(attr.args[0])
                backend = backend_from_text(backend_name)
            else:
                backend = OptimizationBackend.Simd
        elif attr.name == "error_not":
            level = OptimizationReqLevel.ErrorNot
            if attr.args.len() > 0:
                val backend_name = extract_string_arg(attr.args[0])
                backend = backend_from_text(backend_name)
        elif attr.name == "warn_not":
            level = OptimizationReqLevel.WarnNot
            if attr.args.len() > 0:
                val backend_name = extract_string_arg(attr.args[0])
                backend = backend_from_text(backend_name)

    OptimizationReq(level: level, backend: backend)

fn has_optimization_req(req: OptimizationReq) -> bool:
    """Check if there's any optimization requirement."""
    req.level != OptimizationReqLevel.None_

fn is_required_backend(req: OptimizationReq) -> bool:
    """Check if backend is required (must error if not applied)."""
    req.level == OptimizationReqLevel.Must or req.level == OptimizationReqLevel.ErrorNot

fn is_preferred_backend(req: OptimizationReq) -> bool:
    """Check if backend is preferred (warn if not applied)."""
    req.level == OptimizationReqLevel.Prefer or req.level == OptimizationReqLevel.WarnNot

# ============================================================================
# Export Attribute Parsing
# ============================================================================

fn parse_export_attrs(attrs: [Attribute]) -> ExportAttr?:
    """Extract @export attributes from a list of attributes.

    Scans for @export("C") with optional name: kwarg.
    Returns nil if no @export found.

    Examples:
        @export("C")                    # Export with C ABI, default name
        @export("C", name: "my_func")   # Export with custom C symbol name
    """
    var found = false
    var is_export_c = false
    var export_name = ""

    for attr in attrs:
        if attr.name == "export":
            if attr.args.len() > 0:
                # First arg should be the ABI string, e.g. "C"
                val abi = extract_string_arg(attr.args[0])
                if abi == "C":
                    found = true
                    is_export_c = true

                    # Check remaining args for name: kwarg
                    var ai = 1
                    while ai < attr.args.len():
                        val arg = attr.args[ai]
                        match arg.kind:
                            case Assign(left, op, right):
                                match left.kind:
                                    case Ident(name):
                                        if name == "name":
                                            val n = extract_string_arg(right)
                                            if n.len() > 0:
                                                export_name = n
                                    case _: ()
                            case _: ()
                        ai = ai + 1

    if not found:
        return nil

    ExportAttr(
        is_export_c: is_export_c,
        export_name: export_name
    )

fn parse_driver_manifest_attrs(attrs: [Attribute]) -> DriverManifestAttr?:
    """Extract @driver(...) or @native_lib(...) from declaration attributes.

    Supports both the design's named form and the current positional form:
      @driver(class = 0, vendor = 0x8086, device = [0x2922], version = "1.0")
      @driver(0, 0x8086, [0x2922], "1.0")
      @native_lib(abi = "simple", version = "1.0")
      @native_lib("simple", "1.0")
    """
    for attr in attrs:
        if attr.name == "driver":
            var driver_class: i64 = 0
            var vendor: i64 = 0
            var device_ids: [i64] = []
            var version = ""

            if attr.args.len() >= 4:
                driver_class = extract_int_arg(attr.args[0]) ?? 0
                vendor = extract_int_arg(attr.args[1]) ?? 0
                device_ids = extract_int_array_arg(attr.args[2])
                version = extract_string_arg(attr.args[3])

            val named_args = extract_named_args(attr)
            if named_args.has("class") or named_args.has("dclass"):
                driver_class = get_named_int_arg(named_args, "class", driver_class)
                driver_class = get_named_int_arg(named_args, "dclass", driver_class)
            if named_args.has("vendor"):
                vendor = get_named_int_arg(named_args, "vendor", vendor)
            if named_args.has("device") or named_args.has("devices"):
                device_ids = get_named_int_array_arg(named_args, "device")
                if device_ids.len() == 0:
                    device_ids = get_named_int_array_arg(named_args, "devices")
            if named_args.has("version"):
                version = get_named_string_arg(named_args, "version", version)

            return DriverManifestAttr(
                kind: DriverManifestAttrKind.Driver,
                driver_class: driver_class,
                vendor: vendor,
                device_ids: device_ids,
                version: version,
                abi: ""
            )

        elif attr.name == "native_lib":
            var abi = "simple"
            var version = ""
            if attr.args.len() >= 1:
                val a = extract_string_arg(attr.args[0])
                if a.len() > 0:
                    abi = a
            if attr.args.len() >= 2:
                version = extract_string_arg(attr.args[1])

            val named_args = extract_named_args(attr)
            abi = get_named_string_arg(named_args, "abi", abi)
            version = get_named_string_arg(named_args, "version", version)

            return DriverManifestAttr(
                kind: DriverManifestAttrKind.NativeLib,
                driver_class: 15,
                vendor: 0,
                device_ids: [],
                version: version,
                abi: abi
            )

    nil

fn vhdl_clocked_metadata_default() -> VhdlClockedMetadata:
    VhdlClockedMetadata(
        clock_signal: "",
        reset_signal: "",
        has_reset: false,
        reset_polarity: VhdlResetPolarity.ActiveLow,
        reset_synchrony: VhdlResetSynchrony.None_,
        domain: "",
        is_valid: true,
        validation_errors: []
    )

fn vhdl_hardware_metadata_default() -> VhdlHardwareMetadata:
    VhdlHardwareMetadata(
        is_hardware: false,
        generics: [],
        has_clocked: false,
        clocked: vhdl_clocked_metadata_default(),
        return_fields: [],
        flatten_struct_output: false
    )

fn vhdl_hardware_metadata_flat_row_is_valid(row: VhdlHardwareMetadataFlatRow) -> bool:
    (row.generic_names.len() == row.generic_type_texts.len() and
    row.generic_names.len() == row.generic_default_texts.len() and
    row.return_field_labels.len() == row.return_field_type_texts.len() and
    row.has_clocked >= 0 and row.has_clocked <= 1 and
    row.has_reset >= 0 and row.has_reset <= 1 and
    row.reset_polarity >= 0 and row.reset_polarity <= 1 and
    row.reset_synchrony >= 0 and row.reset_synchrony <= 2 and
    row.clocked_is_valid >= 0 and row.clocked_is_valid <= 1 and
    row.flatten_struct_output >= 0 and row.flatten_struct_output <= 1)

fn parse_vhdl_hardware_attrs(attrs: [Attribute]) -> VhdlHardwareMetadata:
    """Extract structured VHDL hardware metadata from function attributes.

    This intentionally preserves the existing syntax as metadata instead of
    making the VHDL backend rescan source text for @hardware/@generic/@clocked.
    """
    var meta = vhdl_hardware_metadata_default()

    for attr in attrs:
        if attr.name == "hardware":
            meta.is_hardware = true
        elif attr.name == "generic":
            meta.generics = _parse_vhdl_generic_args(attr.args)
        elif attr.name == "clocked":
            meta.has_clocked = true
            meta.clocked = _parse_vhdl_clocked_args(attr.args)
        elif attr.name == "flatten_struct_output":
            meta.flatten_struct_output = true

    meta

fn vhdl_hardware_metadata_with_return_fields(meta: VhdlHardwareMetadata, fields: [VhdlReturnFieldMetadata]) -> VhdlHardwareMetadata:
    VhdlHardwareMetadata(
        is_hardware: meta.is_hardware,
        generics: meta.generics,
        has_clocked: meta.has_clocked,
        clocked: meta.clocked,
        return_fields: fields,
        flatten_struct_output: meta.flatten_struct_output
    )

fn _parse_vhdl_generic_args(args: [Expr]) -> [VhdlGenericMetadata]:
    var generics: [VhdlGenericMetadata] = []
    for arg in args:
        match arg.kind:
            case Assign(left, op, right):
                val name = extract_text_arg(left)
                val default_text = extract_text_arg(right)
                if name != "":
                    generics.push(VhdlGenericMetadata(
                        name: name,
                        type_text: "",
                        default_text: default_text
                    ))
            case Ident(name):
                generics.push(VhdlGenericMetadata(
                    name: name,
                    type_text: "",
                    default_text: ""
                ))
            case _:
                val text_value = extract_text_arg(arg)
                if text_value != "":
                    generics.push(VhdlGenericMetadata(
                        name: text_value,
                        type_text: "",
                        default_text: ""
                    ))
    generics

fn _parse_vhdl_clocked_args(args: [Expr]) -> VhdlClockedMetadata:
    var clock_signal = ""
    var reset_signal = ""
    var has_reset = false
    var polarity = VhdlResetPolarity.ActiveLow
    var synchrony = VhdlResetSynchrony.Async
    var domain = ""
    var errors: [text] = []
    var positional = 0
    var has_explicit_synchrony = false

    for arg in args:
        match arg.kind:
            case Assign(left, op, right):
                val key = extract_text_arg(left).lower()
                val value = extract_text_arg(right)
                val lower_value = value.lower()
                if key == "clock" or key == "clk":
                    clock_signal = value
                elif key == "reset" or key == "rst":
                    if _vhdl_clocked_value_is_no_reset(lower_value):
                        reset_signal = ""
                        has_reset = false
                    else:
                        reset_signal = value
                        has_reset = value != ""
                elif key == "domain":
                    domain = value
                elif key == "polarity" or key == "reset_polarity":
                    if lower_value == "active_high" or lower_value == "high":
                        polarity = VhdlResetPolarity.ActiveHigh
                    elif lower_value == "active_low" or lower_value == "low":
                        polarity = VhdlResetPolarity.ActiveLow
                    else:
                        errors.push("unknown @clocked reset_polarity '{value}'")
                elif key == "sync" or key == "synchrony" or key == "reset_sync":
                    has_explicit_synchrony = true
                    if lower_value == "sync" or lower_value == "synchronous" or lower_value == "true":
                        synchrony = VhdlResetSynchrony.Sync
                    elif lower_value == "async" or lower_value == "asynchronous" or lower_value == "false":
                        synchrony = VhdlResetSynchrony.Async
                    elif _vhdl_clocked_value_is_no_reset(lower_value):
                        synchrony = VhdlResetSynchrony.None_
                    else:
                        errors.push("unknown @clocked reset_sync '{value}'")
            case _:
                val token = extract_text_arg(arg)
                val lower_token = token.lower()
                if positional == 0:
                    clock_signal = token
                elif positional == 1:
                    if _vhdl_clocked_value_is_no_reset(lower_token):
                        reset_signal = ""
                        has_reset = false
                    else:
                        reset_signal = token
                        has_reset = token != ""
                else:
                    if lower_token == "active_high" or lower_token == "high" or lower_token == "reset_high":
                        polarity = VhdlResetPolarity.ActiveHigh
                    elif lower_token == "active_low" or lower_token == "low" or lower_token == "reset_low":
                        polarity = VhdlResetPolarity.ActiveLow
                    elif lower_token == "sync" or lower_token == "synchronous":
                        synchrony = VhdlResetSynchrony.Sync
                        has_explicit_synchrony = true
                    elif lower_token == "async" or lower_token == "asynchronous":
                        synchrony = VhdlResetSynchrony.Async
                        has_explicit_synchrony = true
                    elif _vhdl_clocked_value_is_no_reset(lower_token):
                        synchrony = VhdlResetSynchrony.None_
                        has_explicit_synchrony = true
                    elif lower_token.starts_with("domain="):
                        domain = token.substring(7, token.len())
                positional = positional + 1

    if not has_reset and not has_explicit_synchrony:
        synchrony = VhdlResetSynchrony.None_

    if clock_signal.trim() == "":
        errors.push("@clocked requires a clock signal")

    if domain.trim() == "" and clock_signal.trim() != "":
        domain = clock_signal

    if domain.trim() != "" and not _vhdl_clocked_domain_name_is_valid(domain):
        errors.push("@clocked domain '{domain}' contains unsupported characters")

    if synchrony == VhdlResetSynchrony.None_ and has_reset:
        errors.push("@clocked reset_sync 'none' cannot be used with a reset signal")
    elif synchrony != VhdlResetSynchrony.None_ and not has_reset and has_explicit_synchrony:
        errors.push("@clocked reset_sync '{_vhdl_reset_synchrony_name(synchrony)}' requires a reset signal")

    VhdlClockedMetadata(
        clock_signal: clock_signal,
        reset_signal: reset_signal,
        has_reset: has_reset,
        reset_polarity: polarity,
        reset_synchrony: synchrony,
        domain: domain,
        is_valid: errors.len() == 0,
        validation_errors: errors
    )

fn _vhdl_clocked_value_is_no_reset(value: text) -> bool:
    value == "" or value == "none" or value == "no_reset" or value == "no-reset"

fn _vhdl_clocked_domain_name_is_valid(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed.len() == 0:
        return false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.substring(i, i + 1)
        val ok = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "-" or ch == "."
        if not ok:
            return false
        i = i + 1
    true

fn _vhdl_reset_synchrony_name(synchrony: VhdlResetSynchrony) -> text:
    match synchrony:
        case Async: "async"
        case Sync: "sync"
        case None_: "none"

# ============================================================================
# Function Attribute Types
# ============================================================================

struct FunctionAttr:
    """Function-level attributes for code generation."""
    is_entry: bool          # @entry - bare-metal entry point
    is_naked: bool          # @naked - no prologue/epilogue
    is_noreturn: bool       # @noreturn - function never returns
    section: text?          # @section("X") - ELF section placement
    is_interrupt: bool      # @interrupt - interrupt handler
    is_boot: bool           # @boot - init-phase function (runs before scheduler)
    is_alloc: bool          # @alloc - function performs allocation
    is_no_alloc: bool       # @no_alloc - function must not allocate
    is_gpu_kernel: bool     # @gpu_kernel - GPU kernel function (emitted as .entry in PTX)
    gpu_target: text        # @gpu/@gpu_kernel target metadata: cuda, opencl, auto, etc.
    gpu_backends: text      # Optional ordered backend list, comma-separated text.
    is_simd: bool           # @simd - auto-vectorized loop with GPU grid/bounds
    has_fast_math: bool     # @fast_math - permits reassociation-sensitive FP transforms
    simd_enable: bool       # @simd(enable) or bare @simd
    simd_disable: bool      # @simd(disable)
    simd_prefer_scalable: bool  # @simd(prefer_scalable)
    # SIMD/GPU optimization requirements (Phase 1)
    optimization_req: OptimizationReq  # @must/@prefer/@error_not/@warn_not
    # FPGA kernel attributes (W3.2) — 0 = absent/default
    unroll_factor: i64      # @unroll(n) — structural unroll factor; 0 = no unroll
    pipeline_ii: i64        # @pipeline(n) / @pipeline(ii=n) — initiation interval; 0 = no pipeline
    memory_banks: i64       # @memory(n) / @memory(banks=n) — array port banking; 0 = no banking

impl FunctionAttr:
    static fn default() -> FunctionAttr:
        """Default function attributes (no special attributes)."""
        FunctionAttr(
            is_entry: false,
            is_naked: false,
            is_noreturn: false,
            section: nil,
            is_interrupt: false,
            is_boot: false,
            is_alloc: false,
            is_no_alloc: false,
            is_gpu_kernel: false,
            gpu_target: "",
            gpu_backends: "",
            is_simd: false,
            has_fast_math: false,
            simd_enable: false,
            simd_disable: false,
            simd_prefer_scalable: false,
            optimization_req: OptimizationReq(level: OptimizationReqLevel.None_, backend: OptimizationBackend.Unknown),
            unroll_factor: 0,
            pipeline_ii: 0,
            memory_banks: 0
        )

fn parse_function_attrs(attrs: [Attribute]) -> FunctionAttr:
    """Extract function attributes from a list of attributes."""
    var is_entry = false
    var is_naked = false
    var is_noreturn = false
    var has_section = false
    var section_value = ""
    var is_interrupt = false
    var is_boot = false
    var is_alloc = false
    var is_no_alloc = false
    var is_gpu_kernel = false
    var gpu_target = ""
    var gpu_backends = ""
    var is_simd = false
    var has_fast_math = false
    var simd_enable = false
    var simd_disable = false
    var simd_prefer_scalable = false
    var unroll_factor: i64 = 0
    var pipeline_ii: i64 = 0
    var memory_banks: i64 = 0

    for attr in attrs:
        if attr.name == "entry":
            is_entry = true
        elif attr.name == "naked":
            is_naked = true
        elif attr.name == "noreturn":
            is_noreturn = true
        elif attr.name == "section":
            if attr.args.len() > 0:
                val section_name = extract_string_arg(attr.args[0])
                if section_name.len() > 0:
                    has_section = true
                    section_value = section_name
        elif attr.name == "interrupt":
            is_interrupt = true
        elif attr.name == "boot":
            is_boot = true
        elif attr.name == "alloc":
            is_alloc = true
        elif attr.name == "no_alloc":
            is_no_alloc = true
        elif attr.name == "gpu_kernel" or attr.name == "gpu":
            is_gpu_kernel = true
            val parsed = parse_gpu_function_attr_args(attr)
            if parsed.gpu_target.len() > 0:
                gpu_target = parsed.gpu_target
            if parsed.gpu_backends.len() > 0:
                gpu_backends = parsed.gpu_backends
        elif attr.name == "fast_math":
            has_fast_math = true
        elif attr.name == "unroll":
            if attr.args.len() > 0:
                val n = extract_int_arg(attr.args[0]) ?? 0
                if n > 0:
                    unroll_factor = n
        elif attr.name == "pipeline":
            if attr.args.len() > 0:
                val n = extract_fpga_named_or_positional_i64(attr.args[0])
                if n > 0:
                    pipeline_ii = n
        elif attr.name == "memory":
            if attr.args.len() > 0:
                val n = extract_fpga_named_or_positional_i64(attr.args[0])
                if n > 0:
                    memory_banks = n
        elif attr.name == "simd":
            is_simd = true
            if attr.args.len() == 0:
                simd_enable = true
            else:
                for arg in attr.args:
                    val simd_arg = extract_text_arg(arg)
                    if simd_arg == "enable":
                        simd_enable = true
                    elif simd_arg == "disable":
                        simd_disable = true
                    elif simd_arg == "prefer_scalable":
                        simd_prefer_scalable = true

    # Parse optimization requirements (@must, @prefer, @error_not, @warn_not)
    val optimization_req = parse_optimization_req_attrs(attrs)

    FunctionAttr(
        is_entry: is_entry,
        is_naked: is_naked,
        is_noreturn: is_noreturn,
        section: if has_section: Some(section_value) else: nil,
        is_interrupt: is_interrupt,
        is_boot: is_boot,
        is_alloc: is_alloc,
        is_no_alloc: is_no_alloc,
        is_gpu_kernel: is_gpu_kernel,
        gpu_target: gpu_target,
        gpu_backends: gpu_backends,
        is_simd: is_simd,
        has_fast_math: has_fast_math,
        simd_enable: simd_enable,
        simd_disable: simd_disable,
        simd_prefer_scalable: simd_prefer_scalable,
        optimization_req: optimization_req,
        unroll_factor: unroll_factor,
        pipeline_ii: pipeline_ii,
        memory_banks: memory_banks
    )

struct GpuFunctionAttrArgs:
    gpu_target: text
    gpu_backends: text

fn parse_gpu_function_attr_args(attr: Attribute) -> GpuFunctionAttrArgs:
    var gpu_target = ""
    var gpu_backends = ""
    if attr.args.len() > 0:
        val first = extract_text_arg(attr.args[0])
        if first.len() > 0:
            gpu_target = first

    val named_args = extract_named_args(attr)
    val target_arg = get_named_string_arg(named_args, "target", "")
    val backend_arg = get_named_string_arg(named_args, "backend", "")
    if target_arg.len() > 0:
        gpu_target = target_arg
    elif backend_arg.len() > 0:
        gpu_target = backend_arg
    gpu_backends = get_named_string_arg(named_args, "backends", gpu_backends)
    GpuFunctionAttrArgs(gpu_target: gpu_target, gpu_backends: gpu_backends)

fn extract_fpga_named_or_positional_i64(expr: Expr) -> i64:
    """Extract an i64 from a positional integer literal or a named-arg assignment (e.g. ii=3, banks=2)."""
    match expr.kind:
        case Assign(left, op, right):
            extract_int_arg(right) ?? 0
        case _:
            extract_int_arg(expr) ?? 0

# ============================================================================
# Task Attribute Types
# ============================================================================

struct TaskAttr:
    """Task-level attributes from @task annotation.

    Used by spawn boundedness analysis (Pass B) to verify that task pools
    are correctly sized for baremetal strict mode.

    Fields:
        instances: Maximum number of concurrent instances (from @task(instances=N))
        group: Optional task group name (from @task(group="name"))
        frame: Optional declared frame size in bytes (from @task(frame=N))
        wait_nodes: Number of wait-queue nodes (from @task(wait_nodes=N), default 0)
        policy: Scheduler policy name (fair/background/rt_fifo/rt_rr/deadline)
    """
    instances: i64
    group: text?
    frame: i64?
    wait_nodes: i64
    policy: text
    weight: i64?
    priority: i64?
    latency_hint: text?
    runtime_ns: i64?
    period_ns: i64?
    deadline_ns: i64?

struct TaskPolicyDiagnostic:
    """A diagnostic from @task scheduler policy validation."""
    level: text
    message: text
