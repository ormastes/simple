# Shared GPU target metadata helpers.
#
# Used by semantic @gpu validation and backend MIR acceptance so target aliases
# and default backend ordering do not drift across compiler layers.

fn normalize_gpu_target_metadata_name(name: text) -> text:
    val lower = name.trim().lower()
    if lower == "" or lower == "default":
        return "auto"
    if lower == "auto":
        return "auto"
    if lower == "cuda" or lower == "ptx" or lower == "nvptx":
        return "cuda"
    if lower == "opencl" or lower == "opencl-c" or lower == "opencl-spirv" or lower == "cl":
        return "opencl"
    if lower == "hip" or lower == "hip-cpp" or lower == "hsaco" or lower == "rocm":
        return "hip"
    if lower == "vulkan" or lower == "vulkan-spirv" or lower == "spirv":
        return "vulkan"
    lower

fn gpu_target_metadata_default_backend_order() -> text:
    "cuda,hip,opencl"

fn gpu_target_metadata_is_supported_backend_name(normalized: text) -> bool:
    normalized == "cuda" or normalized == "hip" or normalized == "opencl" or normalized == "vulkan" or normalized == "auto"

fn gpu_target_metadata_backend_order_for_target(normalized: text) -> text:
    if normalized == "auto":
        return gpu_target_metadata_default_backend_order()
    if gpu_target_metadata_is_supported_backend_name(normalized):
        return normalized
    ""
