# Source Location Tracking
#
# Tracks source code positions for error reporting.
# This is the CANONICAL Span definition for the entire compiler.

# Source location span (start, end, line, col)
struct Span:
    start: i64    # Start byte offset
    end: i64      # End byte offset
    line: i64     # Line number (1-indexed)
    col: i64      # Column number (1-indexed)

impl Span:
    # Create a new span
    static fn new(start: i64, end: i64, line: i64, col: i64) -> Span:
        Span(start: start, end: end, line: line, col: col)

    # Create a zero-length span at the given position
    static fn at(pos: i64, line: i64, col: i64) -> Span:
        Span(start: pos, end: pos, line: line, col: col)

    # Create a span at line 1, col 1 (default)
    static fn default() -> Span:
        Span(start: 0, end: 0, line: 1, col: 1)

    # Create an empty span (line 0, col 0)
    static fn empty() -> Span:
        Span(start: 0, end: 0, line: 0, col: 0)

    # Combine two spans into one covering both
    fn to(other: Span) -> Span:
        val min_start = if self.start < other.start: self.start else: other.start
        val max_end = if self.end > other.end: self.end else: other.end
        val min_line = if self.line < other.line: self.line else: other.line

        Span(
            start: min_start,
            end: max_end,
            line: min_line,
            col: self.col
        )

    # Merge two spans (compatible with lexer_types Span.merge)
    fn merge(other: Span) -> Span:
        val new_start = if self.start < other.start: self.start else: other.start
        val new_end = if self.end > other.end: self.end else: other.end
        val new_line = if self.line < other.line: self.line else: other.line
        val new_col = if self.line <= other.line: self.col else: other.col
        Span.new(new_start, new_end, new_line, new_col)

    # Get the length of this span
    fn len() -> i64:
        self.end - self.start

    # Check if this span is empty (zero-length)
    fn is_empty() -> bool:
        self.start == self.end

    # Format span as "line:col"
    fn to_string() -> text:
        "{self.line}:{self.col}"

    # Format span as "line:col-end_col"
    fn to_range_string() -> text:
        if self.is_empty():
            "{self.line}:{self.col}"
        else:
            val end_col = self.col + (self.end - self.start)
            "{self.line}:{self.col}-{end_col}"

# Public exports
