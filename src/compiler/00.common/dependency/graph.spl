# Import Graph - Dependency tracking and graph algorithms
#
# This module provides import graph construction for tracking module dependencies.
# Graph algorithms: cycle detection via iterative DFS (modeled on call_graph.spl).
#
# Corresponds to Rust: src/rust/dependency_tracker/src/graph.rs

# The kind of import
enum ImportKind:
    UseImport        # Regular `use` import
    CommonUse        # `common use` directory prelude
    ExportUse        # `export use` re-export
    TypeUse          # Type-only import (`use type`) - doesn't create runtime dependency


# ============================================================================
# ImportKind Methods (was: impl ImportKind:)
# ============================================================================

# An edge in the import graph
struct ImportEdge:
    from: text        # The importing module
    to: text          # The imported module
    kind: ImportKind  # The kind of import


# ============================================================================
# ImportEdge Methods (was: impl ImportEdge:)
# ============================================================================

fn importedge_new(from: text, to: text, kind: ImportKind) -> ImportEdge:
        ImportEdge(from: from, to: to, kind: kind)


# Circular dependency error
struct CyclicDependencyError:
    cycle: [text]  # The cycle path (module names)


# ============================================================================
# CyclicDependencyError Methods (was: impl CyclicDependencyError:)
# ============================================================================

fn cyclicdependencyerror_new(cycle: [text]) -> CyclicDependencyError:
        CyclicDependencyError(cycle: cycle)


# An import graph tracking module dependencies
#
# Uses an adjacency list representation:
# - edges: HashMap<text, HashSet<text>> - module -> set of imported modules
# - detailed_edges: [ImportEdge] - all edges with import kind information
struct ImportGraph:
    edges: Dict<text, [text]>     # Adjacency list for cycle detection
    detailed_edges: [ImportEdge]  # All edges with kind info


# ============================================================================
# ImportGraph Methods (was: impl ImportGraph:)
# ============================================================================

fn importgraph_new() -> ImportGraph:
        ImportGraph(edges: {}, detailed_edges: [])

# Add a directed edge from -> to with the given import kind.
# Deduplicates edges in the adjacency list.
fn importgraph_add_edge(g: ImportGraph, from: text, to: text, kind: ImportKind) -> ImportGraph:
    val edge = importedge_new(from, to, kind)
    var new_detailed = g.detailed_edges
    new_detailed.push(edge)
    var existing: [text] = if g.edges.has(from): g.edges[from] else: []
    var already = false
    for e in existing:
        if e == to:
            already = true
    if not already:
        existing.push(to)
    var new_edges = g.edges
    new_edges[from] = existing
    # Ensure the 'to' node exists as a key (so cycle detection visits it)
    if not new_edges.has(to):
        var empty: [text] = []
        new_edges[to] = empty
    ImportGraph(edges: new_edges, detailed_edges: new_detailed)

# Module-level DFS state (shared across importgraph_find_cycles calls — not reentrant)
var _ig_node_names: [text] = []
var _ig_node_index: [i64] = []   # parallel array: index i -> node index (flattened from dict)
var _ig_index_keys: [text] = []  # parallel array: key i -> node name (for lookup)

# Lookup node index by name using parallel arrays (avoids dict->int type confusion)
fn _ig_node_idx_of(name: text) -> i64:
    for ki in range(0, _ig_index_keys.len()):
        if _ig_index_keys[ki] == name:
            return _ig_node_index[ki]
    -1

# Detect cycles in the import graph using an iterative DFS (gray/black coloring).
# Returns one CyclicDependencyError per detected back-edge cycle.
# Modeled on src/compiler/10.frontend/core/call_graph.spl detect_cycles/dfs_detect_cycle.
fn importgraph_find_cycles(g: ImportGraph) -> [CyclicDependencyError]:
    _ig_node_names = g.edges.keys()
    val node_count = _ig_node_names.len()
    # color: 0=white, 1=gray, 2=black
    var colors: [i64] = []
    for _i in range(0, node_count):
        colors.push(0)
    # Build parallel-array index lookup (explicit i64 return type via _ig_node_idx_of)
    _ig_index_keys = []
    _ig_node_index = []
    for i in range(0, node_count):
        _ig_index_keys.push(_ig_node_names[i])
        _ig_node_index.push(i)
    var found_cycles: [CyclicDependencyError] = []
    for i in range(0, node_count):
        if colors[i] == 0:
            # Iterative DFS: stack of (node_index, child_position)
            var stack_nodes: [i64] = []
            var stack_positions: [i64] = []
            stack_nodes.push(i)
            stack_positions.push(0)
            colors[i] = 1
            var done = false
            for _iter in range(0, 500000):
                if done:
                    break
                if stack_nodes.len() == 0:
                    done = true
                    break
                val depth = stack_nodes.len() - 1
                val node = stack_nodes[depth]
                val pos = stack_positions[depth]
                val node_name = _ig_node_names[node]
                val children = if g.edges.has(node_name): g.edges[node_name] else: []
                if pos >= children.len():
                    colors[node] = 2
                    var new_nodes: [i64] = []
                    var new_positions: [i64] = []
                    for j in range(0, depth):
                        new_nodes.push(stack_nodes[j])
                        new_positions.push(stack_positions[j])
                    stack_nodes = new_nodes
                    stack_positions = new_positions
                else:
                    stack_positions[depth] = pos + 1
                    val child_name = children[pos]
                    val child_idx = _ig_node_idx_of(child_name)
                    if child_idx < 0:
                        # External node not in graph, skip
                        continue
                    if colors[child_idx] == 1:
                        # Back edge: child_idx is gray -> cycle found
                        # Reconstruct cycle path from stack
                        var cycle_path: [text] = []
                        var in_cycle = false
                        for k in range(0, stack_nodes.len()):
                            val sn = stack_nodes[k]
                            if sn == child_idx:
                                in_cycle = true
                            if in_cycle:
                                cycle_path.push(_ig_node_names[sn])
                        cycle_path.push(child_name)
                        found_cycles.push(cyclicdependencyerror_new(cycle_path))
                    elif colors[child_idx] == 0:
                        colors[child_idx] = 1
                        stack_nodes.push(child_idx)
                        stack_positions.push(0)
    found_cycles


# Public exports: importgraph_new, importgraph_add_edge, importgraph_find_cycles,
# importedge_new, cyclicdependencyerror_new, ImportGraph, ImportEdge, ImportKind, CyclicDependencyError
