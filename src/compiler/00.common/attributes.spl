# Attribute Parsing - Parse and Validate Attributes
#
# Handles parsing of layout-related attributes:
# - @repr("C")         - C ABI compatible layout
# - @repr("packed")    - No padding between fields
# - @repr("transparent") - Single-field wrapper layout
# - @packed            - Shorthand for @repr("packed")
# - @align(N)          - Minimum alignment (must be power of 2)
#
# Handles parsing of volatile attributes:
# - @volatile          - Full volatile (reads and writes)
# - @volatile_read     - Read-only volatile
# - @volatile_write    - Write-only volatile
# - @nonvolatile       - Explicitly non-volatile (override)
#
# Returns a LayoutAttr for use in type layout computation.

# bypass: parsing functions need L1 (Attribute/Expr) and L3 (LayoutAttr/LayoutKind) types.
# Split deferred — spawn_analysis.spl (L1) consumes parse_function_attrs/parse_task_attr,
# so moving parsing fns to L2 would create a new L1→L2 violation.
use compiler.frontend.parser_types.{Attribute, Expr, ExprKind}
use compiler.types.type_layout.{
    LayoutAttr, LayoutKind,
    PlatformAbi, PlatformBit, PlatformPredicate, PlatformVariant, PlatformParseResult,
    PlatformLayoutDiagnostic, platform_abi_from_text, platform_bit_from_text,
    platform_cpu_from_text, platform_os_from_text,
    platform_predicate_default, platform_validate_variants
}
use compiler.common.diagnostics.span.{Span}


# ============================================================================
# Volatile Attribute Types
# ============================================================================

"""Volatile access mode for memory-mapped I/O."""
enum VolatileMode:
    None_            # Normal (not volatile)
    Full            # Full volatile (reads and writes)
    ReadOnly        # Volatile reads, normal writes
    WriteOnly       # Volatile writes, normal reads
    Explicit        # Explicitly non-volatile (override)

struct VolatileAttr:
    """Volatile attribute configuration."""
    mode: VolatileMode
    address: i64?          # Fixed address for memory-mapped variable (@ addr)
    barriers: bool         # Insert memory barriers around access

# ============================================================================
# Volatile Attribute Parsing
# ============================================================================

fn parse_volatile_attrs(attrs: [Attribute]) -> VolatileAttr:
    """Extract volatile attributes from a list of attributes."""
    var mode = VolatileMode.None_
    var address: i64? = nil
    var barriers = false

    for attr in attrs:
        if attr.name == "volatile":
            mode = VolatileMode.Full
            # Check for @volatile(barriers: true)
            if attr.args.len() > 0:
                barriers = extract_barriers_arg(attr.args)
        elif attr.name == "volatile_read":
            mode = VolatileMode.ReadOnly
        elif attr.name == "volatile_write":
            mode = VolatileMode.WriteOnly
        elif attr.name == "nonvolatile":
            mode = VolatileMode.Explicit
        elif attr.name == "address" or attr.name == "addr":
            # @address(0x40020000) - fixed memory address
            if attr.args.len() > 0:
                address = extract_int_arg(attr.args[0])

    VolatileAttr(
        mode: mode,
        address: address,
        barriers: barriers
    )

fn is_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile access is required."""
    (attr.mode == VolatileMode.Full or
    attr.mode == VolatileMode.ReadOnly or
    attr.mode == VolatileMode.WriteOnly)

fn is_read_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile reads are required."""
    attr.mode == VolatileMode.Full or attr.mode == VolatileMode.ReadOnly

fn is_write_volatile(attr: VolatileAttr) -> bool:
    """Check if volatile writes are required."""
    attr.mode == VolatileMode.Full or attr.mode == VolatileMode.WriteOnly

# ============================================================================
# Export Attribute Types
# ============================================================================

struct ExportAttr:
    """Export attribute for C ABI interop.

    Marks a class or function for export with C-compatible ABI.
    Used by @export("C") annotation to generate C ABI wrappers,
    C headers, and C++ wrapper headers.

    Fields:
        is_export_c: Whether to export with C ABI
        export_name: Custom C symbol name (empty = use default mangled name)
    """
    is_export_c: bool
    export_name: text

# ============================================================================
# Export Attribute Parsing
# ============================================================================

fn parse_export_attrs(attrs: [Attribute]) -> ExportAttr?:
    """Extract @export attributes from a list of attributes.

    Scans for @export("C") with optional name: kwarg.
    Returns nil if no @export found.

    Examples:
        @export("C")                    # Export with C ABI, default name
        @export("C", name: "my_func")   # Export with custom C symbol name
    """
    var found = false
    var is_export_c = false
    var export_name = ""

    for attr in attrs:
        if attr.name == "export":
            if attr.args.len() > 0:
                # First arg should be the ABI string, e.g. "C"
                val abi = extract_string_arg(attr.args[0])
                if abi == "C":
                    found = true
                    is_export_c = true

                    # Check remaining args for name: kwarg
                    var ai = 1
                    while ai < attr.args.len():
                        val arg = attr.args[ai]
                        match arg.kind:
                            case Assign(left, op, right):
                                match left.kind:
                                    case Ident(name):
                                        if name == "name":
                                            val n = extract_string_arg(right)
                                            if n.len() > 0:
                                                export_name = n
                                    case _: ()
                            case _: ()
                        ai = ai + 1

    if not found:
        return nil

    ExportAttr(
        is_export_c: is_export_c,
        export_name: export_name
    )

# ============================================================================
# Function Attribute Types
# ============================================================================

struct FunctionAttr:
    """Function-level attributes for code generation."""
    is_entry: bool          # @entry - bare-metal entry point
    is_naked: bool          # @naked - no prologue/epilogue
    is_noreturn: bool       # @noreturn - function never returns
    section: text?          # @section("X") - ELF section placement
    is_interrupt: bool      # @interrupt - interrupt handler
    is_boot: bool           # @boot - init-phase function (runs before scheduler)
    is_alloc: bool          # @alloc - function performs allocation
    is_no_alloc: bool       # @no_alloc - function must not allocate
    is_gpu_kernel: bool     # @gpu_kernel - GPU kernel function (emitted as .entry in PTX)
    is_simd: bool           # @simd - auto-vectorized loop with GPU grid/bounds

impl FunctionAttr:
    static fn default() -> FunctionAttr:
        """Default function attributes (no special attributes)."""
        FunctionAttr(
            is_entry: false,
            is_naked: false,
            is_noreturn: false,
            section: nil,
            is_interrupt: false,
            is_boot: false,
            is_alloc: false,
            is_no_alloc: false,
            is_gpu_kernel: false,
            is_simd: false
        )

fn parse_function_attrs(attrs: [Attribute]) -> FunctionAttr:
    """Extract function attributes from a list of attributes."""
    var is_entry = false
    var is_naked = false
    var is_noreturn = false
    var section: text? = nil
    var is_interrupt = false
    var is_boot = false
    var is_alloc = false
    var is_no_alloc = false
    var is_gpu_kernel = false
    var is_simd = false

    for attr in attrs:
        if attr.name == "entry":
            is_entry = true
        elif attr.name == "naked":
            is_naked = true
        elif attr.name == "noreturn":
            is_noreturn = true
        elif attr.name == "section":
            if attr.args.len() > 0:
                val section_name = extract_string_arg(attr.args[0])
                if section_name.len() > 0:
                    section = section_name
        elif attr.name == "interrupt":
            is_interrupt = true
        elif attr.name == "boot":
            is_boot = true
        elif attr.name == "alloc":
            is_alloc = true
        elif attr.name == "no_alloc":
            is_no_alloc = true
        elif attr.name == "gpu_kernel":
            is_gpu_kernel = true
        elif attr.name == "simd":
            is_simd = true

    FunctionAttr(
        is_entry: is_entry,
        is_naked: is_naked,
        is_noreturn: is_noreturn,
        section: section,
        is_interrupt: is_interrupt,
        is_boot: is_boot,
        is_alloc: is_alloc,
        is_no_alloc: is_no_alloc,
        is_gpu_kernel: is_gpu_kernel,
        is_simd: is_simd
    )

# ============================================================================
# Task Attribute Types
# ============================================================================

struct TaskAttr:
    """Task-level attributes from @task annotation.

    Used by spawn boundedness analysis (Pass B) to verify that task pools
    are correctly sized for baremetal strict mode.

    Fields:
        instances: Maximum number of concurrent instances (from @task(instances=N))
        group: Optional task group name (from @task(group="name"))
        frame: Optional declared frame size in bytes (from @task(frame=N))
        wait_nodes: Number of wait-queue nodes (from @task(wait_nodes=N), default 0)
        policy: Scheduler policy name (fair/background/rt_fifo/rt_rr/deadline)
    """
    instances: i64
    group: text?
    frame: i64?
    wait_nodes: i64
    policy: text
    weight: i64?
    priority: i64?
    latency_hint: text?
    runtime_ns: i64?
    period_ns: i64?
    deadline_ns: i64?

struct TaskPolicyDiagnostic:
    """A diagnostic from @task scheduler policy validation."""
    level: text
    message: text

struct TaskPolicyValidation:
    """Validation result for @task scheduler policy metadata."""
    diagnostics: [TaskPolicyDiagnostic]
    has_errors: bool

fn parse_task_attr(attrs: [Attribute]) -> TaskAttr?:
    """Extract @task attributes from a list of attributes."""
    var found = false
    var instances = 1
    var group: text? = nil
    var frame: i64? = nil
    var wait_nodes = 0
    var policy = "fair"
    var weight: i64? = nil
    var priority: i64? = nil
    var latency_hint: text? = nil
    var runtime_ns: i64? = nil
    var period_ns: i64? = nil
    var deadline_ns: i64? = nil

    for attr in attrs:
        if attr.name == "task":
            found = true
            for arg in attr.args:
                match arg.kind:
                    case Assign(left, op, right):
                        match left.kind:
                            case Ident(name):
                                if name == "instances":
                                    val v = extract_int_arg(right)
                                    if v != nil:
                                        instances = v ?? 1
                                elif name == "group":
                                    val g = extract_string_arg(right)
                                    if g.len() > 0:
                                        group = g
                                elif name == "frame":
                                    frame = extract_int_arg(right)
                                elif name == "wait_nodes":
                                    val w = extract_int_arg(right)
                                    if w != nil:
                                        wait_nodes = w ?? 0
                                elif name == "policy":
                                    val p = extract_string_arg(right)
                                    if p.len() > 0:
                                        policy = p
                                elif name == "weight":
                                    weight = extract_int_arg(right)
                                elif name == "priority":
                                    priority = extract_int_arg(right)
                                elif name == "latency_hint":
                                    val h = extract_string_arg(right)
                                    if h.len() > 0:
                                        latency_hint = h
                                elif name == "runtime":
                                    runtime_ns = extract_int_arg(right)
                                elif name == "period":
                                    period_ns = extract_int_arg(right)
                                elif name == "deadline":
                                    deadline_ns = extract_int_arg(right)
                            case _: ()
                    case IntLit(value):
                        # Bare integer: @task(4) means instances=4
                        instances = value
                    case _: ()

    if not found:
        return nil

    TaskAttr(
        instances: instances,
        group: group,
        frame: frame,
        wait_nodes: wait_nodes,
        policy: policy,
        weight: weight,
        priority: priority,
        latency_hint: latency_hint,
        runtime_ns: runtime_ns,
        period_ns: period_ns,
        deadline_ns: deadline_ns
    )

fn validate_task_policy_attr(attr: TaskAttr, runtime_family: text, effects: [text]) -> TaskPolicyValidation:
    """Validate @task scheduler policy against runtime family/effects.

    Fair/background policies are valid in any runtime family. RT and deadline
    policies require noalloc runtime code; deadline additionally requires a
    valid runtime/period/deadline tuple for scheduler admission.
    """
    var diagnostics: [TaskPolicyDiagnostic] = []
    var has_errors = false

    val is_rt = attr.policy == "rt_fifo" or attr.policy == "rt_rr"
    val is_deadline = attr.policy == "deadline"
    val is_supported = (
        attr.policy == "fair" or attr.policy == "background" or
        attr.policy == "rt_fifo" or attr.policy == "rt_rr" or
        attr.policy == "deadline"
    )

    if not is_supported:
        diagnostics.push(TaskPolicyDiagnostic(
            level: "error",
            message: "unknown @task scheduler policy '{attr.policy}'"
        ))
        has_errors = true

    if is_rt or is_deadline:
        if runtime_family != "nogc_async_mut_noalloc":
            diagnostics.push(TaskPolicyDiagnostic(
                level: "error",
                message: "@task(policy='{attr.policy}') requires nogc_async_mut_noalloc runtime family"
            ))
            has_errors = true

    if is_deadline:
        if attr.runtime_ns == nil or attr.period_ns == nil or attr.deadline_ns == nil:
            diagnostics.push(TaskPolicyDiagnostic(
                level: "error",
                message: "@task(policy='deadline') requires runtime, period, and deadline parameters"
            ))
            has_errors = true
        else:
            val runtime = attr.runtime_ns ?? 0
            val period = attr.period_ns ?? 0
            val deadline = attr.deadline_ns ?? 0
            if runtime <= 0 or period <= 0 or deadline <= 0:
                diagnostics.push(TaskPolicyDiagnostic(
                    level: "error",
                    message: "@task(policy='deadline') requires positive runtime, period, and deadline parameters"
                ))
                has_errors = true
            elif runtime > deadline:
                diagnostics.push(TaskPolicyDiagnostic(
                    level: "error",
                    message: "@task(policy='deadline') requires runtime <= deadline"
                ))
                has_errors = true
            elif deadline > period:
                diagnostics.push(TaskPolicyDiagnostic(
                    level: "error",
                    message: "@task(policy='deadline') requires deadline <= period"
                ))
                has_errors = true

    if is_rt or is_deadline:
        for effect in effects:
            if effect == "gc" or effect == "alloc" or effect == "unbounded_block":
                diagnostics.push(TaskPolicyDiagnostic(
                    level: "error",
                    message: "@task(policy='{attr.policy}') cannot use effect '{effect}'"
                ))
                has_errors = true

    TaskPolicyValidation(
        diagnostics: diagnostics,
        has_errors: has_errors
    )

# ============================================================================
# Layout Attribute Parsing
# ============================================================================

fn parse_layout_attrs(attrs: [Attribute]) -> LayoutAttr:
    """Extract layout attributes from a list of attributes."""
    var layout_kind = LayoutKind.Simple
    var explicit_align: i64? = nil
    var is_packed = false

    for attr in attrs:
        if attr.name == "repr":
            if attr.args.len() > 0:
                val repr_kind = extract_string_arg(attr.args[0])
                if repr_kind == "C":
                    layout_kind = LayoutKind.C
                elif repr_kind == "packed":
                    layout_kind = LayoutKind.Packed
                    is_packed = true
                elif repr_kind == "transparent":
                    layout_kind = LayoutKind.Transparent
        elif attr.name == "packed":
            layout_kind = LayoutKind.Packed
            is_packed = true
        elif attr.name == "align":
            if attr.args.len() > 0:
                val align_val = extract_int_arg(attr.args[0])
                if align_val.? and is_power_of_two(align_val.unwrap()):
                    explicit_align = align_val

    LayoutAttr(
        layout_kind: layout_kind,
        explicit_align: explicit_align,
        is_packed: is_packed
    )

fn parse_platform_attrs(attrs: [Attribute]) -> PlatformParseResult:
    """Extract @platform attributes from a list of attributes.

    Parses each @platform occurrence into a typed PlatformVariant and
    collects diagnostics for unknown keys, duplicate predicates, duplicate
    defaults, ambiguous variants, and missing explicit layout hints.
    """
    var variants: [PlatformVariant] = []
    var diagnostics: [PlatformLayoutDiagnostic] = []

    for attr in attrs:
        if attr.name != "platform":
            continue

        var predicate = platform_predicate_default()
        var has_explicit_size = false
        var explicit_size = 0
        var has_explicit_align = false
        var explicit_align = 0

        if attr.args.len() == 0:
            predicate.has_default = true

        for arg in attr.args:
            match arg.kind:
                case Ident(name):
                    if name == "default":
                        predicate.has_default = true
                    elif name == "bit":
                        predicate.has_bit = true
                        predicate.bit = PlatformBit.Pointer
                    else:
                        diagnostics.push(PlatformLayoutDiagnostic.UnknownKey(
                            key: name,
                            span: arg.span
                        ))
                case IntLit(value):
                    if not predicate.has_bit:
                        predicate.has_bit = true
                        if value == 16:
                            predicate.bit = PlatformBit.Bits16
                        elif value == 32:
                            predicate.bit = PlatformBit.Bits32
                        elif value == 64:
                            predicate.bit = PlatformBit.Bits64
                        else:
                            diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                key: "bit",
                                value: "{value}",
                                span: arg.span
                            ))
                    else:
                        diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                            key: "platform",
                            value: "{value}",
                            span: arg.span
                        ))
                case Assign(left, op, right):
                    match left.kind:
                        case Ident(name):
                            if name == "default":
                                match right.kind:
                                    case BoolLit(v):
                                        predicate.has_default = v
                                    case Ident(text_value):
                                        if text_value == "true":
                                            predicate.has_default = true
                                        elif text_value == "false":
                                            predicate.has_default = false
                                        else:
                                            diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                                key: "default",
                                                value: text_value,
                                                span: right.span
                                            ))
                                    case _:
                                        diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                            key: "default",
                                            value: "",
                                            span: right.span
                                        ))
                            elif name == "cpu":
                                val cpu_name = extract_text_arg(right)
                                val cpu = platform_cpu_from_text(cpu_name)
                                if cpu.?:
                                    predicate.has_cpu = true
                                    predicate.cpu = cpu.unwrap()
                                else:
                                    diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                        key: "cpu",
                                        value: cpu_name,
                                        span: right.span
                                    ))
                            elif name == "os":
                                val os_name = extract_text_arg(right)
                                val os = platform_os_from_text(os_name)
                                if os.?:
                                    predicate.has_os = true
                                    predicate.os = os.unwrap()
                                else:
                                    diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                        key: "os",
                                        value: os_name,
                                        span: right.span
                                    ))
                            elif name == "abi":
                                val abi_name = extract_text_arg(right)
                                val abi = platform_abi_from_text(abi_name)
                                if abi.?:
                                    predicate.has_abi = true
                                    predicate.abi = abi.unwrap()
                                else:
                                    diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                        key: "abi",
                                        value: abi_name,
                                        span: right.span
                                    ))
                            elif name == "bit":
                                match right.kind:
                                    case IntLit(v):
                                        predicate.has_bit = true
                                        if v == 16:
                                            predicate.bit = PlatformBit.Bits16
                                        elif v == 32:
                                            predicate.bit = PlatformBit.Bits32
                                        elif v == 64:
                                            predicate.bit = PlatformBit.Bits64
                                        else:
                                            diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                                key: "bit",
                                                value: "{v}",
                                                span: right.span
                                            ))
                                    case Ident(text_value):
                                        val bit = platform_bit_from_text(text_value)
                                        if bit.?:
                                            predicate.has_bit = true
                                            predicate.bit = bit.unwrap()
                                        else:
                                            diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                                key: "bit",
                                                value: text_value,
                                                span: right.span
                                            ))
                                    case _:
                                        diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                            key: "bit",
                                            value: "",
                                            span: right.span
                                        ))
                            elif name == "size":
                                val size_val = extract_int_arg(right)
                                if size_val.? and size_val.unwrap() > 0:
                                    has_explicit_size = true
                                    explicit_size = size_val.unwrap()
                                else:
                                    diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                        key: "size",
                                        value: extract_text_arg(right),
                                        span: right.span
                                    ))
                            elif name == "align":
                                val align_val = extract_int_arg(right)
                                if align_val.? and align_val.unwrap() > 0:
                                    has_explicit_align = true
                                    explicit_align = align_val.unwrap()
                                else:
                                    diagnostics.push(PlatformLayoutDiagnostic.UnknownValue(
                                        key: "align",
                                        value: extract_text_arg(right),
                                        span: right.span
                                    ))
                            else:
                                diagnostics.push(PlatformLayoutDiagnostic.UnknownKey(
                                    key: name,
                                    span: left.span
                                ))
                        case _:
                            diagnostics.push(PlatformLayoutDiagnostic.UnknownKey(
                                key: extract_text_arg(left),
                                span: left.span
                            ))
                case _:
                    diagnostics.push(PlatformLayoutDiagnostic.UnknownKey(
                        key: extract_text_arg(arg),
                        span: arg.span
                    ))

        variants.push(PlatformVariant(
            predicate: predicate,
            has_explicit_size: has_explicit_size,
            explicit_size: explicit_size,
            has_explicit_align: has_explicit_align,
            explicit_align: explicit_align,
            span: attr.span
        ))

    val validation = platform_validate_variants(variants)
    for diag in validation:
        diagnostics.push(diag)

    PlatformParseResult(
        variants: variants,
        diagnostics: diagnostics
    )

# Extract string value from an expression (for @repr("C"))
fn extract_string_arg(expr: Expr) -> text:
    match expr.kind:
        case StringLit(value, _):
            value
        case _:
            ""

fn extract_text_arg(expr: Expr) -> text:
    match expr.kind:
        case StringLit(value, _):
            value
        case Ident(name):
            name
        case IntLit(value):
            "{value}"
        case BoolLit(value):
            if value: "true" else: "false"
        case _:
            ""

# Extract barriers option from attribute args
# Handles: @volatile(true), @volatile(barriers: true)
fn extract_barriers_arg(args: [Expr]) -> bool:
    for arg in args:
        # Check for bare true literal: @volatile(true)
        match arg.kind:
            case BoolLit(v):
                return v
            case Assign(left, op, right):
                # Check for named arg: barriers = true
                match left.kind:
                    case Ident(name):
                        if name == "barriers":
                            match right.kind:
                                case BoolLit(v):
                                    return v
                                case _: ()
                    case _: ()
            case _: ()
    false

# Extract integer value from an expression (for @align(16))
fn extract_int_arg(expr: Expr) -> i64?:
    match expr.kind:
        case IntLit(value):
            Some(value)
        case _:
            nil

# Check if a number is a power of 2
fn is_power_of_two(n: i64) -> bool:
    """Check if n is a power of 2.

    Uses bitwise trick: n & (n-1) == 0 for powers of 2.
    """
    n > 0 and (n & (n - 1)) == 0

# Validate alignment value
fn validate_alignment(align: i64, span: Span) -> Result<i64, text>:
    """Validate that alignment is a positive power of 2.

    Returns the alignment if valid, or an error message.
    """
    if align <= 0:
        Err("alignment must be positive, got {align}")
    elif not is_power_of_two(align):
        Err("alignment must be a power of 2, got {align}")
    else:
        Ok(align)
