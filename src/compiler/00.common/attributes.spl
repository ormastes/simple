# Attribute Parsing - Parse and Validate Attributes
#
# Handles parsing of layout-related attributes:
# - @repr("C")         - C ABI compatible layout
# - @repr("packed")    - No padding between fields
# - @repr("transparent") - Single-field wrapper layout
# - @packed            - Shorthand for @repr("packed")
# - @align(N)          - Minimum alignment (must be power of 2)
#
# Handles parsing of volatile attributes:
# - @volatile          - Full volatile (reads and writes)
# - @volatile_read     - Read-only volatile
# - @volatile_write    - Write-only volatile
# - @nonvolatile       - Explicitly non-volatile (override)
#
# Returns a LayoutAttr for use in type layout computation.

# bypass: parsing functions need L1 (Attribute/Expr) and L3 (LayoutAttr/LayoutKind) types.
# Split deferred — spawn_analysis.spl (L1) consumes parse_function_attrs/parse_task_attr,
# so moving parsing fns to L2 would create a new L1→L2 violation.

# Split from src/compiler/00.common/attributes.spl to keep module cohesion under the 800-line source limit.
export use compiler.common._Attributes.decl_attrs.{VolatileMode, VolatileAttr, parse_volatile_attrs, is_volatile, is_read_volatile, is_write_volatile, ExportAttr, DriverManifestAttrKind, DriverManifestAttr, VhdlResetPolarity, VhdlResetSynchrony, VhdlClockedMetadata, VhdlGenericMetadata, VhdlReturnFieldMetadata, VhdlHardwareMetadata, parse_export_attrs, parse_driver_manifest_attrs, vhdl_clocked_metadata_default, vhdl_hardware_metadata_default, parse_vhdl_hardware_attrs, vhdl_hardware_metadata_with_return_fields, _parse_vhdl_generic_args, _parse_vhdl_clocked_args, _vhdl_clocked_value_is_no_reset, _vhdl_clocked_domain_name_is_valid, _vhdl_reset_synchrony_name, FunctionAttr, parse_function_attrs, GpuFunctionAttrArgs, parse_gpu_function_attr_args, extract_fpga_named_or_positional_i64, TaskAttr, TaskPolicyDiagnostic}
export use compiler.common._Attributes.layout_attrs.{TaskPolicyValidation, parse_task_attr, validate_task_policy_attr, parse_layout_attrs, parse_platform_attrs, extract_string_arg, extract_text_arg, extract_int_array_arg, extract_barriers_arg, extract_int_arg, is_power_of_two, validate_alignment}
