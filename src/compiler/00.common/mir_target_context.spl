# Pure target context shared by the driver and MIR lowering.

struct MirTargetContext:
    arch: text
    os: text
    abi: text
    backend: text
    version: i64

fn mir_target_context_normalize_arch(value: text) -> text:
    val arch = value.trim().lower()
    if arch == "amd64" or arch == "x64":
        return "x86_64"
    if arch == "i386" or arch == "i486" or arch == "i586" or arch == "i686":
        return "x86"
    if arch == "arm64":
        return "aarch64"
    if arch.starts_with("armv") or arch.starts_with("thumbv"):
        return "arm"
    if arch.starts_with("rv32") or arch.starts_with("riscv32"):
        return "riscv32"
    if arch.starts_with("rv64") or arch.starts_with("riscv64"):
        return "riscv64"
    arch

fn mir_target_context_normalize_os(value: text) -> text:
    val os = value.trim().lower()
    if os == "darwin" or os == "macos":
        return "macos"
    if os == "win" or os == "win32" or os == "win64" or os == "windows_nt":
        return "windows"
    if os == "none":
        return "baremetal"
    os

fn mir_target_context_uses_host(target: text) -> bool:
    target == "" or target == "host" or target == "native"

fn mir_target_context_os_from(target: text, host_os: text) -> text:
    if mir_target_context_uses_host(target):
        return mir_target_context_normalize_os(host_os)
    if target.contains("simpleos"):
        return "simpleos"
    if target.contains("baremetal") or target.contains("-none"):
        return "baremetal"
    if target.contains("darwin") or target.contains("macos"):
        return "macos"
    if target.contains("windows") or target.contains("mingw"):
        return "windows"
    if target.contains("freebsd"):
        return "freebsd"
    if target.contains("linux"):
        return "linux"
    mir_target_context_normalize_os(host_os)

fn mir_target_context_abi_from(target: text, os: text) -> text:
    if target.contains("mingw"):
        return "gnu"
    if target.contains("eabihf"):
        return "eabihf"
    if target.contains("musl"):
        return "musl"
    if target.contains("msvc"):
        return "msvc"
    if target.contains("macho"):
        return "macho"
    if target.contains("sysv"):
        return "sysv"
    if target.contains("lp64d"):
        return "lp64d"
    if target.contains("ilp32d"):
        return "ilp32d"
    if target.contains("ilp32"):
        return "ilp32"
    if target.contains("gnu"):
        return "gnu"
    if target.contains("eabi"):
        return "eabi"
    if os == "macos":
        return "macho"
    if os == "windows":
        return "msvc"
    if os == "freebsd":
        return "sysv"
    if os == "linux":
        return "gnu"
    "none"

fn mir_target_context_backend_from(value: text) -> text:
    val backend = value.trim().lower()
    if backend == "cranelift":
        return "cranelift"
    if backend == "native" or backend == "c" or backend == "cuda" or backend == "hip":
        return backend
    if backend == "opencl" or backend == "vhdl" or backend == "irtc" or backend == "lua":
        return backend
    "llvm"

fn mir_target_context_from(
    target_triple: text,
    host_arch: text,
    host_os: text,
    backend: text,
    version: i64
) -> MirTargetContext:
    val target = target_triple.trim().lower()
    val arch = if mir_target_context_uses_host(target):
        mir_target_context_normalize_arch(host_arch)
    elif target == "simpleos":
        "x86_64"
    else:
        mir_target_context_normalize_arch(target.split("-")[0])
    val os = mir_target_context_os_from(target, host_os)
    MirTargetContext(
        arch: arch,
        os: os,
        abi: mir_target_context_abi_from(target, os),
        backend: mir_target_context_backend_from(backend),
        version: version
    )
