# MIR → Backend adapter (hub)
#
# Re-exports MirProgram and MirDebugInfo from individual files.
# Prefer importing from individual files directly to avoid
# the runtime limitation where only the first struct works.
# Design: doc/research/compiler_mdsoc_design.md Section 4.3

use compiler.transform.feature.mir_to_backend.entity_view.MirProgram.{MirProgram}
use compiler.transform.feature.mir_to_backend.entity_view.MirDebugInfo.{MirDebugInfo}

export MirProgram, MirDebugInfo
