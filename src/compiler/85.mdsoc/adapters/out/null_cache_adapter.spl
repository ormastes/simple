# Null Cache Adapter (--no-cache mode)
#
# Implements CachePort with all operations as no-ops.
# Used when caching is disabled via --no-cache flag.
#
# Phase 5: Cache Port Unification

use compiler.mdsoc.feature.cache.cache_port.{CachePort, CacheCheckStatus, CacheStats, create_noop_cache_port}

fn create_null_cache_adapter() -> CachePort:
    """Create a null cache adapter (all operations are no-ops).

    Always returns cache miss. Useful for --no-cache mode.
    """
    create_noop_cache_port()
