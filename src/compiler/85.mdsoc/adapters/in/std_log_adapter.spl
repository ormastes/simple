# Standard Log Adapter
#
# Implements LoggerPort from compiler_services.spl using print-based logging.
# Replaces ad-hoc print/println calls with unified logging port.
#
# Phase 3: LoggerPort Consolidation

use compiler.common.compiler_services.{LoggerPort}

# Module-level log state (workaround for nested closure limitation)
var _log_level: i64 = 4  # Default: Info (1=Error, 2=Warn, 4=Info, 10=Debug, 20=Trace)

fn _std_log_debug(msg: text):
    if _log_level >= 10:
        print "[DEBUG] {msg}"

fn _std_log_info(msg: text):
    if _log_level >= 4:
        print "[INFO] {msg}"

fn _std_log_warn(msg: text):
    if _log_level >= 2:
        print "[WARN] {msg}"

fn _std_log_error(msg: text):
    if _log_level >= 1:
        print "[ERROR] {msg}"

fn set_log_level(level: i64):
    _log_level = level

fn create_std_log_adapter() -> LoggerPort:
    """Create a standard log adapter that prints to stdout with level filtering."""
    LoggerPort(
        name: "std-log",
        debug_fn: _std_log_debug,
        info_fn: _std_log_info,
        warn_fn: _std_log_warn,
        error_fn: _std_log_error
    )

fn create_std_log_adapter_with_level(level: i64) -> LoggerPort:
    """Create a standard log adapter with a specific log level."""
    _log_level = level
    create_std_log_adapter()

fn create_silent_log_adapter() -> LoggerPort:
    """Create a silent log adapter (no output)."""
    fn _silent(msg: text): ()
    LoggerPort(
        name: "silent-log",
        debug_fn: _silent,
        info_fn: _silent,
        warn_fn: _silent,
        error_fn: _silent
    )
