# MDSOC Dimension Map
#
# Maps a dimension selector to allowed caret roots.

export DimensionMap

struct DimensionMap:
    """Maps a dimension selector to allowed caret roots."""
    selector: text
    roots: [text]

impl DimensionMap:
    static fn new(selector: text, roots: [text]) -> DimensionMap:
        DimensionMap(selector: selector, roots: roots)
