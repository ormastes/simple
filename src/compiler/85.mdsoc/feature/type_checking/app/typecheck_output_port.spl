# Type Checking Stage — TypeCheckOutputPort
#
# Typed AST context produced by type checking.

use compiler.mdsoc.feature.type_checking.app.diagnostic.{Diagnostic}

struct TypeCheckOutputPort:
    """Typed AST context produced by type checking."""
    inferred_types: [i64]
    diagnostics: [Diagnostic]
    error_count: i64
    symbol_count: i64

