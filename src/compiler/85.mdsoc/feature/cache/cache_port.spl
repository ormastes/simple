# Cache Port — Typed Contract for Compiler Caching
#
# Unifies 9 independent cache implementations under a single abstraction.
# Supports check, store, invalidate operations + stats collection.
#
# Phase 5: Cache Port Unification

struct CacheCheckStatus:
    """Result of a cache freshness check."""
    is_fresh: bool
    reason: text

struct CacheStats:
    """Statistics about cache usage."""
    hits: i64
    misses: i64
    stores: i64
    invalidations: i64

    fn hit_ratio() -> f64:
        val total = self.hits + self.misses
        if total == 0:
            return 0.0
        self.hits.to_f64() / total.to_f64()

struct CachePort:
    """Typed contract for compiler caching.

    Provides check, store, invalidate, and stats operations.
    Swappable: FileCacheAdapter (production), NullCacheAdapter (--no-cache).
    """
    name: text
    check_fn: fn(text, text) -> CacheCheckStatus
    store_fn: fn(text, text, text)
    invalidate_fn: fn(text)
    get_stats_fn: fn() -> CacheStats

fn _noop_cache_check(key: text, hash: text) -> CacheCheckStatus:
    CacheCheckStatus(is_fresh: false, reason: "no-cache")

fn _noop_cache_store(key: text, hash: text, data: text): ()

fn _noop_cache_invalidate(key: text): ()

fn _noop_cache_stats() -> CacheStats:
    CacheStats(hits: 0, misses: 0, stores: 0, invalidations: 0)

fn create_noop_cache_port() -> CachePort:
    """Create a no-op cache port (all misses, no storage)."""
    CachePort(
        name: "noop-cache",
        check_fn: _noop_cache_check,
        store_fn: _noop_cache_store,
        invalidate_fn: _noop_cache_invalidate,
        get_stats_fn: _noop_cache_stats
    )
