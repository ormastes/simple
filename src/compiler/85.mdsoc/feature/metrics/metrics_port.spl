# Metrics Port — Typed Contract for Compiler Metrics
#
# Zero-cost metrics collection for compilation pipeline.
# Supports counters, gauges, and timing records.
#
# Phase 6: Metrics Port

struct MetricsPort:
    """Typed contract for compiler metrics collection.

    Three metric types:
    - Counters: monotonically increasing (e.g., files_parsed)
    - Gauges: point-in-time values (e.g., memory_used)
    - Timing: duration records (e.g., parse_duration_ms)
    """
    name: text
    record_counter_fn: fn(text, i64)
    record_gauge_fn: fn(text, i64)
    record_timing_fn: fn(text, i64)
    get_counter_fn: fn(text) -> i64
    get_gauge_fn: fn(text) -> i64
    get_timing_fn: fn(text) -> i64

fn _noop_record(name: text, value: i64): ()
fn _noop_get(name: text) -> i64: 0

fn create_noop_metrics_port() -> MetricsPort:
    """Create a no-op metrics port (zero cost, discards all metrics)."""
    MetricsPort(
        name: "noop-metrics",
        record_counter_fn: _noop_record,
        record_gauge_fn: _noop_record,
        record_timing_fn: _noop_record,
        get_counter_fn: _noop_get,
        get_gauge_fn: _noop_get,
        get_timing_fn: _noop_get
    )
