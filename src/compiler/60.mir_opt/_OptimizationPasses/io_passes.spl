# Optimization Passes — io_passes: standalone optimize_*/count_* IO and bulk-memory passes
#
# Standalone optimize_* and count_* functions for general IO optimization passes:
# - Write coalescing (bulk_store_hint)
# - Read-ahead hoisting (loop-invariant loads/calls)
# - Syscall batching (call_batch_hint)
# - Bulk copy recognition (bulk_copy_hint)
# - Bulk fill recognition (bulk_fill_hint)
# - Bulk compare recognition (bulk_cmp_hint)
# - Endian load recognition (endian_load_hint)
# - Endian store recognition (endian_store_hint)
#
# Split from optimization_passes.spl to keep module cohesion under the 800-line source limit.

use mir_data.*
use compiler.mir_opt._OptimizationPasses.engine.*

# ============================================================================
# General IO Optimization Passes
# ============================================================================

fn optimize_write_coalesce(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            # Guard: seed JIT Dict<i64,_> corruption can hand back a
                            # nil-payload operand here (doc/08_tracking/bug/
                            # seed_jit_int_keyed_dict_broken_2026-07-02.md). `local` is
                            # never semantically nil for a real Copy/Move operand; skip
                            # rather than crash so bootstrap surfaces the next issue.
                            if local.?:
                                gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if local.? and gep_base.has(local.id):
                                val base_id = gep_base[local.id]
                                val prev = base_store_count[base_id] ?? 0
                                base_store_count[base_id] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_coalesce = false
        val ks = base_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if base_store_count[ks[ki]] >= 2:
                any_coalesce = true
            ki = ki + 1
        if any_coalesce:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                # Guard: see seed JIT Dict<i64,_> corruption note above.
                                if local.?:
                                    gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if local.? and gep_base2.has(local.id):
                                    val base_id: i64 = gep_base2[local.id] ?? 0
                                    val sc: i64 = base_store_count[base_id] ?? 0
                                    if sc >= 2 and not hint_emitted.has(base_id):
                                        val base_lid = LocalId(id: base_id)
                                        val base_op = MirOperand(kind: MirOperandKind.Copy(base_lid))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(sc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_store_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[base_id] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn optimize_read_ahead_hoist(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    """Detect loop-invariant Load/Call instructions; count hoist candidates.

    Identifies basic blocks inside loops (targeted by back-edges from Goto
    or If terminators) and scans for Load/Call instructions whose operands
    are all defined before the loop.  These are candidates for hoisting to
    the loop preheader — applicable to any repeated IO inside a loop.
    """
    if func.blocks.len() < 2:
        return func
    var loop_body: Dict<i64, bool> = {}
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        match block.terminator:
            case Goto(target):
                if target.id <= block.id.id:
                    var li = target.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case If(cond, then_, else_):
                if then_.id <= block.id.id:
                    var li = then_.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
                if else_.id <= block.id.id:
                    var li = else_.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case _:
                pass
        bi = bi + 1
    var pre_loop_defs: Dict<i64, bool> = {}
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if not loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Const(dest, _, _) | Copy(dest, _) | Move(dest, _) | BinOp(dest, _, _, _) | UnaryOp(dest, _, _) | Cast(dest, _, _) | Load(dest, _) | Alloc(dest, _) | GetElementPtr(dest, _, _) | GetField(dest, _, _) | Aggregate(dest, _, _):
                        pre_loop_defs[dest.id] = true
                    case Call(dest, _, _):
                        if val call_dest = dest:
                            pre_loop_defs[call_dest.id] = true
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if pre_loop_defs.has(local.id):
                                    pass
                            case Const(_, _):
                                stats.read_ahead_hoist_count = stats.read_ahead_hoist_count + 1
                            case _:
                                pass
                    case Call(dest, func_op, args):
                        var all_invariant = true
                        match func_op.kind:
                            case Copy(local) | Move(local):
                                if not pre_loop_defs.has(local.id):
                                    all_invariant = false
                            case _:
                                pass
                        var ai = 0
                        while ai < args.len() and all_invariant:
                            match args[ai].kind:
                                case Copy(local) | Move(local):
                                    if not pre_loop_defs.has(local.id):
                                        all_invariant = false
                                case _:
                                    pass
                            ai = ai + 1
                        if all_invariant:
                            stats.read_ahead_hoist_count = stats.read_ahead_hoist_count + 1
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    func

fn optimize_syscall_batch(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var batch_starts: Dict<i64, i64> = {}
        var batch_fids: Dict<i64, i64> = {}
        var prev_func_id: i64 = -1
        var run_length: i64 = 0
        var run_start: i64 = 0
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case Call(dest, func_op, args):
                    var fid: i64 = -1
                    match func_op.kind:
                        case Copy(local) | Move(local):
                            fid = local.id
                        case _:
                            pass
                    if fid >= 0 and fid == prev_func_id:
                        run_length = run_length + 1
                    else:
                        if run_length >= 2:
                            batch_starts[run_start] = run_length
                            batch_fids[run_start] = prev_func_id
                        prev_func_id = fid
                        run_start = ii
                        run_length = 1
                case _:
                    if run_length >= 2:
                        batch_starts[run_start] = run_length
                        batch_fids[run_start] = prev_func_id
                    prev_func_id = -1
                    run_length = 0
            ii = ii + 1
        if run_length >= 2:
            batch_starts[run_start] = run_length
            batch_fids[run_start] = prev_func_id
        val bk = batch_starts.keys()
        if bk.len() > 0:
            modified = true
            var new_insts: [MirInst] = []
            ii = 0
            while ii < block.instructions.len():
                if batch_starts.has(ii):
                    val fid_val: i64 = batch_fids[ii] ?? 0
                    val run_val: i64 = batch_starts[ii] ?? 0
                    val func_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: fid_val)))
                    val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(run_val), MirType.i64()))
                    var hint_args: [MirOperand] = []
                    hint_args = hint_args.push(func_op)
                    hint_args = hint_args.push(cnt_op)
                    val hint = MirInst(
                        kind: MirInstKind.Intrinsic(nil, "call_batch_hint", hint_args),
                        span: nil
                    )
                    new_insts = new_insts.push(hint)
                new_insts = new_insts.push(block.instructions[ii])
                ii = ii + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_write_coalesce(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            # Guard: seed JIT Dict<i64,_> corruption can hand back a
                            # nil-payload operand here (doc/08_tracking/bug/
                            # seed_jit_int_keyed_dict_broken_2026-07-02.md). `local` is
                            # never semantically nil for a real Copy/Move operand; skip
                            # rather than crash so bootstrap surfaces the next issue.
                            if local.?:
                                gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if local.? and gep_base.has(local.id):
                                val base_id = gep_base[local.id]
                                val prev = base_store_count[base_id] ?? 0
                                base_store_count[base_id] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = base_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if base_store_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

fn count_read_ahead_hoist(func: MirFunction) -> i64:
    if func.blocks.len() < 2:
        return 0
    var count = 0
    var loop_body: Dict<i64, bool> = {}
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        match block.terminator:
            case Goto(tgt):
                if tgt.id <= block.id.id:
                    var li = tgt.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case If(cond, tb, eb):
                if tb.id <= block.id.id:
                    var li = tb.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
                if eb.id <= block.id.id:
                    var li = eb.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case _:
                pass
        bi = bi + 1
    var pre_loop_defs: Dict<i64, bool> = {}
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if not loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Const(dest, _, _) | Copy(dest, _) | Move(dest, _) | BinOp(dest, _, _, _) | UnaryOp(dest, _, _) | Cast(dest, _, _) | Load(dest, _) | Alloc(dest, _) | GetElementPtr(dest, _, _) | GetField(dest, _, _) | Aggregate(dest, _, _):
                        pre_loop_defs[dest.id] = true
                    case Call(dest, _, _):
                        if val call_dest = dest:
                            pre_loop_defs[call_dest.id] = true
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if pre_loop_defs.has(local.id):
                                    count = count + 1
                            case Const(_, _):
                                count = count + 1
                            case _:
                                pass
                    case Call(dest, func_op, args):
                        var all_invariant = true
                        match func_op.kind:
                            case Copy(local) | Move(local):
                                if not pre_loop_defs.has(local.id):
                                    all_invariant = false
                            case _:
                                pass
                        var ai = 0
                        while ai < args.len() and all_invariant:
                            match args[ai].kind:
                                case Copy(local) | Move(local):
                                    if not pre_loop_defs.has(local.id):
                                        all_invariant = false
                                case _:
                                    pass
                            ai = ai + 1
                        if all_invariant:
                            count = count + 1
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    count

fn count_syscall_batch(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var prev_func_id: i64 = -1
        var run_len: i64 = 0
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case Call(dest, func_op, args):
                    var fid: i64 = -1
                    match func_op.kind:
                        case Copy(local) | Move(local):
                            fid = local.id
                        case _:
                            pass
                    if fid >= 0 and fid == prev_func_id:
                        run_len = run_len + 1
                    else:
                        if run_len >= 2:
                            count = count + 1
                        prev_func_id = fid
                        run_len = 1
                case _:
                    if run_len >= 2:
                        count = count + 1
                    prev_func_id = -1
                    run_len = 0
            ii = ii + 1
        if run_len >= 2:
            count = count + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Copy Recognizer — Load+Store pairs from different GEP bases
# ============================================================================

fn optimize_bulk_copy(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    # SG-1.3 WARNING — index-blind recognizer. This pass is ADDITIVE: it inserts the
    # advisory `bulk_copy_hint` and KEEPS every original GEP/Load/Store, so it is
    # semantics-preserving by construction (the hint lowers to a NO-OP in the C backend).
    # It counts Stores of the shape `dst[anyGEP] = Load(src[anyGEP])` (src_base != dst_base)
    # and fires at count >= 2 — it does NOT verify the indices match (dst[i]==src[i]), are
    # contiguous 0..count-1, or that the matched ops form a consecutive uninterrupted run.
    # Therefore the hint must NEVER be renamed/lowered to the active `bulk_copy` intrinsic
    # (which emits a real memmove) without first adding that guard — doing so would
    # miscompile e.g. `dst[5]=src[2]; dst[9]=src[7]` into a copy of dst[0..1].
    # See bug doc sg13_bulk_copy_recognizer_index_blind and emit_bulk_copy's precondition.
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_src_base: Dict<i64, i64> = {}
        var copy_count: Dict<i64, i64> = {}
        var copy_src: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_src_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val dst_base = gep_base[local.id]
                                match value.kind:
                                    case Copy(vlocal) | Move(vlocal):
                                        if load_src_base.has(vlocal.id):
                                            val src_base = load_src_base[vlocal.id]
                                            if src_base != dst_base:
                                                val prev = copy_count[dst_base] ?? 0
                                                copy_count[dst_base] = prev + 1
                                                if not copy_src.has(dst_base):
                                                    copy_src[dst_base] = src_base
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_copy = false
        val ks = copy_count.keys()
        var ki = 0
        while ki < ks.len():
            if copy_count[ks[ki]] >= 2:
                any_copy = true
            ki = ki + 1
        if any_copy:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var load_src2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    load_src2[dest.id] = gep_base2[local.id]
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    val dst_base: i64 = gep_base2[local.id] ?? 0
                                    val cc: i64 = copy_count[dst_base] ?? 0
                                    if cc >= 2 and not hint_emitted.has(dst_base):
                                        val src_b: i64 = copy_src[dst_base] ?? 0
                                        val src_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: src_b)))
                                        val dst_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: dst_base)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(cc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(src_op)
                                        hint_args = hint_args.push(dst_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_copy_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[dst_base] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

# ── SG-1.3 SOUND bulk-copy elision (C backend + SIMPLE_MIR_BULK_OPS=1 only) ──────────────
# Replaces a canonical element-copy run with the active `bulk_copy` intrinsic that the C
# backend lowers to a real memmove. SOUND BY STRICTNESS — fires ONLY when ALL hold:
#   (struct)   consecutive 4-instr units `GEP gs=src[i]; Load ld=*gs; GEP gd=dst[i]; Store *gd=ld`
#              for i=0..k-1, k>=2, same src_base != dst_base, indices contiguous from 0, di==si==i;
#   (H1)       every unit temp (gs/ld/gd) is DEAD outside the matched run — no other instruction
#              or terminator references it (else deleting its def is a dangling-local miscompile);
#   (H2)       every loaded element is EXACTLY 8 bytes — the memmove copies count*8 bytes, but a
#              sub-8-byte element Store writes only sizeof(ty), so memmove would clobber gap bytes.
# H1/H2 were surfaced by adversarial review; the non-firing specs in bulk_copy_elision_spec.spl
# exercise each guard. Erring toward NOT firing is safe (a miss is a perf miss, never a miscompile).

struct CopyUnit:
    ok: bool
    src_base: i64
    dst_base: i64
    gs: i64
    ld: i64
    gd: i64

fn elide_operand_local(operand: MirOperand) -> i64:
    match operand.kind:
        case Copy(local) | Move(local):
            local.id
        case _:
            -1

fn elide_single_const_index(indices: [MirOperand]) -> i64:
    if indices.len() != 1:
        -1
    else:
        match indices[0].kind:
            case Const(cv, _):
                match cv:
                    case Int(n): n
                    case _: -1
            case _: -1

fn elide_any_op(ops: [MirOperand], consumed: Dict<i64, bool>) -> bool:
    var found = false
    var i = 0
    while i < ops.len():
        if consumed.has(elide_operand_local(ops[i])):
            found = true
        i = i + 1
    found

# True if `inst` references any local id in `consumed`. Conservative: instruction kinds whose
# operands are not enumerated here fall to `case _: true` (treated as a potential reference, so
# the elision is blocked) — sound, never optimistic.
fn elide_inst_refs(inst: MirInst, consumed: Dict<i64, bool>) -> bool:
    match inst.kind:
        case Copy(_, src): consumed.has(src.id)
        case Move(_, src): consumed.has(src.id)
        case BinOp(_, _, l, r): consumed.has(elide_operand_local(l)) or consumed.has(elide_operand_local(r))
        case CheckedBinOp(_, _, l, r): consumed.has(elide_operand_local(l)) or consumed.has(elide_operand_local(r))
        case UnaryOp(_, _, o): consumed.has(elide_operand_local(o))
        case Load(_, ptr): consumed.has(elide_operand_local(ptr))
        case Store(ptr, v): consumed.has(elide_operand_local(ptr)) or consumed.has(elide_operand_local(v))
        case GetElementPtr(_, base, idxs): consumed.has(elide_operand_local(base)) or elide_any_op(idxs, consumed)
        case Call(_, f, args): consumed.has(elide_operand_local(f)) or elide_any_op(args, consumed)
        case CallIndirect(_, ptr, args, _): consumed.has(elide_operand_local(ptr)) or elide_any_op(args, consumed)
        case Cast(_, o, _): consumed.has(elide_operand_local(o))
        case Bitcast(_, o, _): consumed.has(elide_operand_local(o))
        case Aggregate(_, _, ops): elide_any_op(ops, consumed)
        case GetField(_, base, _): consumed.has(elide_operand_local(base))
        case SetField(base, _, v): consumed.has(elide_operand_local(base)) or consumed.has(elide_operand_local(v))
        case Intrinsic(_, _, args): elide_any_op(args, consumed)
        case PipeForward(_, v, f): consumed.has(elide_operand_local(v)) or consumed.has(elide_operand_local(f))
        case Const(_, _, _): false
        case Alloc(_, _): false
        case _: true

fn elide_term_refs(term: MirTerminator, consumed: Dict<i64, bool>) -> bool:
    match term:
        case Goto(_): false
        case Unreachable: false
        case Abort(_): false
        case Ret(v):
            if val ret_value = v:
                consumed.has(elide_operand_local(ret_value))
            else:
                false
        case If(cond, _, _): consumed.has(elide_operand_local(cond))
        case Switch(value, _, _): consumed.has(elide_operand_local(value))
        case _: true

# H1: true iff none of the run's temporaries are referenced anywhere outside the matched range
# [lo,hi) in block `bi_run` — across all blocks' instructions and terminators.
fn elide_run_dead_out(func: MirFunction, bi_run: i64, lo: i64, hi: i64, consumed: Dict<i64, bool>) -> bool:
    var clean = true
    var b = 0
    while b < func.blocks.len():
        val blk = func.blocks[b]
        var ix = 0
        while ix < blk.instructions.len():
            if b == bi_run and ix >= lo and ix < hi:
                pass
            else:
                if elide_inst_refs(blk.instructions[ix], consumed):
                    clean = false
            ix = ix + 1
        if elide_term_refs(blk.terminator, consumed):
            clean = false
        b = b + 1
    clean

# H2: true iff the local's element type is POSITIVELY confirmed to be exactly 8 bytes. Default
# is false (require proof): an absent/non-primitive/sub-8-byte type blocks the elision, because
# the C lowering hardcodes a count*8 memmove and a sub-8-byte element Store writes fewer bytes.
# Erring toward not-firing is the safe direction.
fn elide_value_is_8byte(func: MirFunction, id: i64) -> bool:
    var result = false
    for local in func.locals:
        if local.id.id == id:
            match local.type_.primitive_size():
                case Some(n): result = n == 8
                case _: result = false
    result

fn elide_match_copy_unit(insts: [MirInst], p: i64, ei: i64) -> CopyUnit:
    val fail = CopyUnit(ok: false, src_base: -1, dst_base: -1, gs: -1, ld: -1, gd: -1)
    if p + 3 >= insts.len():
        fail
    else:
        match insts[p].kind:
            case GetElementPtr(gs_dest, base_s, idx_s):
                val src_local = elide_operand_local(base_s)
                val si = elide_single_const_index(idx_s)
                if src_local < 0 or si != ei:
                    fail
                else:
                    match insts[p + 1].kind:
                        case Load(ld_dest, ptr_l):
                            if elide_operand_local(ptr_l) != gs_dest.id:
                                fail
                            else:
                                match insts[p + 2].kind:
                                    case GetElementPtr(gd_dest, base_d, idx_d):
                                        val dst_local = elide_operand_local(base_d)
                                        val di = elide_single_const_index(idx_d)
                                        if dst_local < 0 or di != ei or dst_local == src_local:
                                            fail
                                        else:
                                            match insts[p + 3].kind:
                                                case Store(ptr_st, sval):
                                                    if elide_operand_local(ptr_st) == gd_dest.id and elide_operand_local(sval) == ld_dest.id:
                                                        CopyUnit(ok: true, src_base: src_local, dst_base: dst_local, gs: gs_dest.id, ld: ld_dest.id, gd: gd_dest.id)
                                                    else:
                                                        fail
                                                case _: fail
                                    case _: fail
                        case _: fail
            case _: fail

fn elide_bulk_copy(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var new_insts: [MirInst] = []
        var j = 0
        while j < block.instructions.len():
            val first = elide_match_copy_unit(block.instructions, j, 0)
            if first.ok:
                val src_b = first.src_base
                val dst_b = first.dst_base
                var units: [CopyUnit] = []
                units = units.push(first)
                var k = 1
                var cont = true
                while cont:
                    val nxt = elide_match_copy_unit(block.instructions, j + k * 4, k)
                    if nxt.ok and nxt.src_base == src_b and nxt.dst_base == dst_b:
                        units = units.push(nxt)
                        k = k + 1
                    else:
                        cont = false
                var fire = k >= 2
                # H2 — every loaded element is exactly 8 bytes.
                if fire:
                    var u2 = 0
                    while u2 < units.len():
                        if not elide_value_is_8byte(func, units[u2].ld):
                            fire = false
                        u2 = u2 + 1
                # H1 — run temporaries dead outside the matched range.
                if fire:
                    var consumed: Dict<i64, bool> = {}
                    var u1 = 0
                    while u1 < units.len():
                        consumed[units[u1].gs] = true
                        consumed[units[u1].ld] = true
                        consumed[units[u1].gd] = true
                        u1 = u1 + 1
                    if not elide_run_dead_out(func, bi, j, j + k * 4, consumed):
                        fire = false
                if fire:
                    val src_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: src_b)))
                    val dst_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: dst_b)))
                    val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(k), MirType.i64()))
                    var bargs: [MirOperand] = []
                    bargs = bargs.push(src_op)
                    bargs = bargs.push(dst_op)
                    bargs = bargs.push(cnt_op)
                    val bc = MirInst(kind: MirInstKind.Intrinsic(nil, "bulk_copy", bargs), span: nil)
                    new_insts = new_insts.push(bc)
                    modified = true
                    j = j + k * 4
                else:
                    new_insts = new_insts.push(block.instructions[j])
                    j = j + 1
            else:
                new_insts = new_insts.push(block.instructions[j])
                j = j + 1
        new_blocks = new_blocks.push(MirBlock(
            id: block.id, label: block.label,
            instructions: new_insts, terminator: block.terminator
        ))
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_copy(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_src_base: Dict<i64, i64> = {}
        var copy_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_src_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val dst_base = gep_base[local.id]
                                match value.kind:
                                    case Copy(vlocal) | Move(vlocal):
                                        if load_src_base.has(vlocal.id):
                                            val src_base = load_src_base[vlocal.id]
                                            if src_base != dst_base:
                                                val prev = copy_count[dst_base] ?? 0
                                                copy_count[dst_base] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = copy_count.keys()
        var ki = 0
        while ki < ks.len():
            if copy_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Fill Recognizer — Store of same constant to contiguous GEP offsets
# ============================================================================

fn optimize_bulk_fill(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_const_store: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                match value.kind:
                                    case Const(_, _):
                                        val base_id = gep_base[local.id]
                                        val prev = base_const_store[base_id] ?? 0
                                        base_const_store[base_id] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_fill = false
        val ks = base_const_store.keys()
        var ki = 0
        while ki < ks.len():
            if base_const_store[ks[ki]] >= 2:
                any_fill = true
            ki = ki + 1
        if any_fill:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    val base_id: i64 = gep_base2[local.id] ?? 0
                                    val fc: i64 = base_const_store[base_id] ?? 0
                                    if fc >= 2 and not hint_emitted.has(base_id):
                                        val base_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: base_id)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(fc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_fill_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[base_id] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_fill(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_const_store: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                match value.kind:
                                    case Const(_, _):
                                        val base_id = gep_base[local.id]
                                        val prev = base_const_store[base_id] ?? 0
                                        base_const_store[base_id] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = base_const_store.keys()
        var ki = 0
        while ki < ks.len():
            if base_const_store[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Compare Recognizer — Load+Load+Compare from two GEP bases
# ============================================================================

fn optimize_bulk_cmp(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_base: Dict<i64, i64> = {}
        var cmp_pair_count: Dict<i64, i64> = {}
        var cmp_pair_other: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case BinOp(dest, op, left, right):
                    match op:
                        case Eq | Ne:
                            var lbase: i64 = -1
                            var rbase: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    if load_base.has(ll.id):
                                        lbase = load_base[ll.id]
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    if load_base.has(rl.id):
                                        rbase = load_base[rl.id]
                                case _:
                                    pass
                            if lbase >= 0 and rbase >= 0 and lbase != rbase:
                                val prev = cmp_pair_count[lbase] ?? 0
                                cmp_pair_count[lbase] = prev + 1
                                if not cmp_pair_other.has(lbase):
                                    cmp_pair_other[lbase] = rbase
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_cmp = false
        val ks = cmp_pair_count.keys()
        var ki = 0
        while ki < ks.len():
            if cmp_pair_count[ks[ki]] >= 2:
                any_cmp = true
            ki = ki + 1
        if any_cmp:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var load_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    load_base2[dest.id] = gep_base2[local.id]
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case BinOp(dest, op, left, right):
                        match op:
                            case Eq | Ne:
                                var lbase: i64 = -1
                                match left.kind:
                                    case Copy(ll) | Move(ll):
                                        if load_base2.has(ll.id):
                                            lbase = load_base2[ll.id]
                                    case _:
                                        pass
                                if lbase >= 0:
                                    val cc: i64 = cmp_pair_count[lbase] ?? 0
                                    if cc >= 2 and not hint_emitted.has(lbase):
                                        val other_b: i64 = cmp_pair_other[lbase] ?? 0
                                        val base_a_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: lbase)))
                                        val base_b_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: other_b)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(cc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_a_op)
                                        hint_args = hint_args.push(base_b_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_cmp_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[lbase] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_cmp(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_base: Dict<i64, i64> = {}
        var cmp_pair_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case BinOp(dest, op, left, right):
                    match op:
                        case Eq | Ne:
                            var lbase: i64 = -1
                            var rbase: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    if load_base.has(ll.id):
                                        lbase = load_base[ll.id]
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    if load_base.has(rl.id):
                                        rbase = load_base[rl.id]
                                case _:
                                    pass
                            if lbase >= 0 and rbase >= 0 and lbase != rbase:
                                val prev = cmp_pair_count[lbase] ?? 0
                                cmp_pair_count[lbase] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = cmp_pair_count.keys()
        var ki = 0
        while ki < ks.len():
            if cmp_pair_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Endian Load Recognizer — byte-shift-OR patterns assembling multi-byte values
# ============================================================================

fn optimize_endian_load(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shift_8_count: Dict<i64, i64> = {}
        var shift_8_src: Dict<i64, i64> = {}
        var or_chain_root: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shl:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shift_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitOr:
                            var left_id: i64 = -1
                            var right_id: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    left_id = ll.id
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    right_id = rl.id
                                case _:
                                    pass
                            if (left_id >= 0 and shift_8_src.has(right_id)) or (right_id >= 0 and shift_8_src.has(left_id)):
                                var root = dest.id
                                if or_chain_root.has(left_id):
                                    root = or_chain_root[left_id]
                                elif or_chain_root.has(right_id):
                                    root = or_chain_root[right_id]
                                or_chain_root[dest.id] = root
                                val prev = shift_8_count[root] ?? 0
                                shift_8_count[root] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_endian = false
        val ks = shift_8_count.keys()
        var ki = 0
        while ki < ks.len():
            if shift_8_count[ks[ki]] >= 2:
                any_endian = true
            ki = ki + 1
        if any_endian:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var shift_src2: Dict<i64, i64> = {}
            var or_root2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case BinOp(dest, op, left, right):
                        match op:
                            case Shl:
                                match right.kind:
                                    case Const(MirConstValue.Int(n), _):
                                        if n > 0 and n % 8 == 0:
                                            match left.kind:
                                                case Copy(src) | Move(src):
                                                    shift_src2[dest.id] = src.id
                                                case _:
                                                    pass
                                    case _:
                                        pass
                            case BitOr:
                                var left_id: i64 = -1
                                var right_id: i64 = -1
                                match left.kind:
                                    case Copy(ll) | Move(ll):
                                        left_id = ll.id
                                    case _:
                                        pass
                                match right.kind:
                                    case Copy(rl) | Move(rl):
                                        right_id = rl.id
                                    case _:
                                        pass
                                if (left_id >= 0 and shift_src2.has(right_id)) or (right_id >= 0 and shift_src2.has(left_id)):
                                    var root = dest.id
                                    if or_root2.has(left_id):
                                        root = or_root2[left_id]
                                    elif or_root2.has(right_id):
                                        root = or_root2[right_id]
                                    or_root2[dest.id] = root
                                    val ec: i64 = shift_8_count[root] ?? 0
                                    if ec >= 2 and not hint_emitted.has(root):
                                        val root_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: root)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(ec), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(root_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "endian_load_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[root] = true
                            case _:
                                pass
                    case _:
                        pass
                new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_endian_load(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shift_8_src: Dict<i64, i64> = {}
        var or_chain_root: Dict<i64, i64> = {}
        var shift_8_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shl:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shift_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitOr:
                            var left_id: i64 = -1
                            var right_id: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    left_id = ll.id
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    right_id = rl.id
                                case _:
                                    pass
                            if (left_id >= 0 and shift_8_src.has(right_id)) or (right_id >= 0 and shift_8_src.has(left_id)):
                                var root = dest.id
                                if or_chain_root.has(left_id):
                                    root = or_chain_root[left_id]
                                elif or_chain_root.has(right_id):
                                    root = or_chain_root[right_id]
                                or_chain_root[dest.id] = root
                                val prev = shift_8_count[root] ?? 0
                                shift_8_count[root] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = shift_8_count.keys()
        var ki = 0
        while ki < ks.len():
            if shift_8_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Endian Store Recognizer — shift-AND-Store patterns splitting values into bytes
# ============================================================================

fn optimize_endian_store(func: MirFunction, mut stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shr_8_src: Dict<i64, i64> = {}
        var masked_src: Dict<i64, i64> = {}
        var src_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shr:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shr_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitAnd:
                            match right.kind:
                                case Const(MirConstValue.Int(255), _):
                                    match left.kind:
                                        case Copy(ll) | Move(ll):
                                            if shr_8_src.has(ll.id):
                                                masked_src[dest.id] = shr_8_src[ll.id]
                                        case _:
                                            pass
                                case _:
                                    pass
                        case _:
                            pass
                case Store(ptr, value):
                    match value.kind:
                        case Copy(vl) | Move(vl):
                            if masked_src.has(vl.id):
                                val orig_src = masked_src[vl.id]
                                val prev = src_store_count[orig_src] ?? 0
                                src_store_count[orig_src] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_endian = false
        val ks = src_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if src_store_count[ks[ki]] >= 2:
                any_endian = true
            ki = ki + 1
        if any_endian:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var shr_src2: Dict<i64, i64> = {}
            var masked2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case BinOp(dest, op, left, right):
                        match op:
                            case Shr:
                                match right.kind:
                                    case Const(MirConstValue.Int(n), _):
                                        if n > 0 and n % 8 == 0:
                                            match left.kind:
                                                case Copy(src) | Move(src):
                                                    shr_src2[dest.id] = src.id
                                                case _:
                                                    pass
                                    case _:
                                        pass
                            case BitAnd:
                                match right.kind:
                                    case Const(MirConstValue.Int(255), _):
                                        match left.kind:
                                            case Copy(ll) | Move(ll):
                                                if shr_src2.has(ll.id):
                                                    masked2[dest.id] = shr_src2[ll.id]
                                            case _:
                                                pass
                                    case _:
                                        pass
                            case _:
                                pass
                    case Store(ptr, value):
                        match value.kind:
                            case Copy(vl) | Move(vl):
                                if masked2.has(vl.id):
                                    val orig_src: i64 = masked2[vl.id] ?? 0
                                    val sc: i64 = src_store_count[orig_src] ?? 0
                                    if sc >= 2 and not hint_emitted.has(orig_src):
                                        val src_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: orig_src)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(sc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(src_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "endian_store_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[orig_src] = true
                            case _:
                                pass
                    case _:
                        pass
                new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_endian_store(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shr_8_src: Dict<i64, i64> = {}
        var masked_src: Dict<i64, i64> = {}
        var src_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shr:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shr_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitAnd:
                            match right.kind:
                                case Const(MirConstValue.Int(255), _):
                                    match left.kind:
                                        case Copy(ll) | Move(ll):
                                            if shr_8_src.has(ll.id):
                                                masked_src[dest.id] = shr_8_src[ll.id]
                                        case _:
                                            pass
                                case _:
                                    pass
                        case _:
                            pass
                case Store(ptr, value):
                    match value.kind:
                        case Copy(vl) | Move(vl):
                            if masked_src.has(vl.id):
                                val orig_src = masked_src[vl.id]
                                val prev = src_store_count[orig_src] ?? 0
                                src_store_count[orig_src] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = src_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if src_store_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

