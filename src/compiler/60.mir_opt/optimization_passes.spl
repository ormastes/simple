# Optimization Passes - Real Optimization Logic in Simple
#
# Implements sophisticated compiler optimizations entirely in Simple:
# - Constant folding and propagation
# - Strength reduction (x * 2 → x << 1)
# - Algebraic simplifications (x + 0 → x, x * 1 → x)
# - Common subexpression elimination
# - Dead code elimination
# - Peephole optimizations
#
# All optimization intelligence lives in Simple, not SFFI.

use mir_data.*


# ============================================================================
# Optimization Configuration
# ============================================================================

enum OptimizationLevel:
    """Optimization level."""
    None_        # No optimizations
    Basic       # Constant folding, simple algebraic
    Standard    # + CSE, strength reduction
    Aggressive  # + peephole, advanced algebraic

impl OptimizationLevel:
    fn to_text() -> text:
        match self:
            case nil: "none"
            case Basic: "basic"
            case Standard: "standard"
            case Aggressive: "aggressive"

# ============================================================================
# Optimization Statistics
# ============================================================================

class OptimizationStats:
    """Track optimization results."""
    # Constant optimizations
    constants_folded: i64
    constant_propagations: i64

    # Algebraic optimizations
    identity_eliminations: i64      # x + 0, x * 1, etc.
    zero_eliminations: i64          # x * 0, 0 / x, etc.
    strength_reductions: i64        # x * 2 → x << 1

    # Code structure optimizations
    common_subexpressions: i64
    dead_instructions: i64
    redundant_casts: i64
    redundant_loads: i64

    # Advanced optimizations
    peephole_improvements: i64
    algebraic_simplifications: i64

    # General IO optimizations
    write_coalesce_count: i64
    read_ahead_hoist_count: i64
    syscall_batch_count: i64
    bulk_copy_count: i64
    bulk_fill_count: i64
    bulk_cmp_count: i64
    endian_load_count: i64
    endian_store_count: i64

impl OptimizationStats:
    static fn create() -> OptimizationStats:
        OptimizationStats(
            constants_folded: 0,
            constant_propagations: 0,
            identity_eliminations: 0,
            zero_eliminations: 0,
            strength_reductions: 0,
            common_subexpressions: 0,
            dead_instructions: 0,
            redundant_casts: 0,
            redundant_loads: 0,
            peephole_improvements: 0,
            algebraic_simplifications: 0,
            write_coalesce_count: 0,
            read_ahead_hoist_count: 0,
            syscall_batch_count: 0,
            bulk_copy_count: 0,
            bulk_fill_count: 0,
            bulk_cmp_count: 0,
            endian_load_count: 0,
            endian_store_count: 0
        )

    fn total() -> i64:
        """Total number of optimizations applied."""
        (self.constants_folded +
        self.constant_propagations +
        self.identity_eliminations +
        self.zero_eliminations +
        self.strength_reductions +
        self.common_subexpressions +
        self.dead_instructions +
        self.redundant_casts +
        self.redundant_loads +
        self.peephole_improvements +
        self.algebraic_simplifications)

    fn to_text() -> text:
        """Format statistics as text."""
        val total = self.total()
        """Optimization Statistics:
  Total optimizations: {total}

  Constant Optimizations:
    Constants folded: {self.constants_folded}
    Constant propagations: {self.constant_propagations}

  Algebraic Optimizations:
    Identity eliminations: {self.identity_eliminations}
    Zero eliminations: {self.zero_eliminations}
    Strength reductions: {self.strength_reductions}
    Algebraic simplifications: {self.algebraic_simplifications}

  Code Structure:
    Common subexpressions: {self.common_subexpressions}
    Dead instructions: {self.dead_instructions}
    Redundant casts: {self.redundant_casts}
    Redundant loads: {self.redundant_loads}

  Advanced:
    Peephole improvements: {self.peephole_improvements}"""

# ============================================================================
# Optimization Engine
# ============================================================================

class OptimizationEngine:
    """
    Main optimization engine.

    Runs multiple optimization passes over MIR to improve code quality.
    All logic implemented in Simple.
    """
    level: OptimizationLevel
    stats: OptimizationStats

    # Analysis data
    const_map: {i64: MirConstValue}   # LocalId -> known constant
    type_map: {i64: MirType}          # LocalId -> inferred type
    def_map: {i64: MirInst}           # LocalId -> defining instruction
    use_count: {i64: i64}             # LocalId -> number of uses

    # CSE tracking
    expr_map: {text: i64}             # expression signature -> LocalId

impl OptimizationEngine:
    static fn create(level: OptimizationLevel) -> OptimizationEngine:
        """Create optimization engine with specified level."""
        OptimizationEngine(
            level: level,
            stats: OptimizationStats.create(),
            const_map: {},
            type_map: {},
            def_map: {},
            use_count: {},
            expr_map: {}
        )

    # ========================================================================
    # Main Optimization Entry Point
    # ========================================================================

    me optimize_function(func: MirFunction) -> MirFunction:
        """
        Optimize a MIR function.

        Returns optimized version of the function.
        """
        if self.level == OptimizationLevel.None_:
            return func

        # Phase 1: Analysis
        self.analyze_function(func)

        # Phase 2: Optimize instructions
        var optimized_blocks: [MirBlock] = []
        for block in func.blocks:
            val opt_block = self.optimize_block(block)
            optimized_blocks = optimized_blocks.push(opt_block)

        # Phase 3: Dead code elimination
        if self.level != OptimizationLevel.Basic:
            optimized_blocks = self.eliminate_dead_code(optimized_blocks)

        # Return optimized function
        MirFunction(..func, blocks: optimized_blocks)

    # ========================================================================
    # Analysis Phase
    # ========================================================================

    me analyze_function(func: MirFunction):
        """Analyze function to build optimization data structures."""
        # Build type map from locals
        for local in func.locals:
            self.type_map[local.id.id] = local.type_

        # Analyze all blocks
        for block in func.blocks:
            self.analyze_block(block)

    me analyze_block(block: MirBlock):
        """Analyze single block."""
        for inst in block.instructions:
            self.analyze_instruction(inst)

    me analyze_instruction(inst: MirInst):
        """Analyze single instruction for optimization opportunities."""
        match inst.kind:
            case Const(dest, value, type_):
                # Track constant
                self.const_map[dest.id] = value
                self.type_map[dest.id] = type_
                self.def_map[dest.id] = inst

            case Copy(dest, src) | Move(dest, src):
                # Propagate constant
                if self.const_map.has(src.id):
                    self.const_map[dest.id] = self.const_map[src.id]
                # Propagate type
                if self.type_map.has(src.id):
                    self.type_map[dest.id] = self.type_map[src.id]
                # Track use
                self.increment_use(src.id)
                self.def_map[dest.id] = inst

            case BinOp(dest, op, left, right):
                self.track_operand_use(left)
                self.track_operand_use(right)
                self.def_map[dest.id] = inst
                # Try to infer result type
                val left_type = self.get_operand_type(left)
                if left_type.?:
                    self.type_map[dest.id] = left_type.unwrap()

            case UnaryOp(dest, op, operand):
                self.track_operand_use(operand)
                self.def_map[dest.id] = inst
                val operand_type = self.get_operand_type(operand)
                if operand_type.?:
                    self.type_map[dest.id] = operand_type.unwrap()

            case _:
                # Generic instruction tracking
                pass

    # ========================================================================
    # Optimization Phase
    # ========================================================================

    me optimize_block(block: MirBlock) -> MirBlock:
        """Optimize all instructions in a block."""
        var optimized: [MirInst] = []

        for inst in block.instructions:
            val opt_inst = self.optimize_instruction(inst)
            if opt_inst.?:
                optimized = optimized.push(opt_inst.unwrap())
            else:
                # Instruction was eliminated
                self.stats.dead_instructions = self.stats.dead_instructions + 1

        MirBlock(
            id: block.id,
            label: block.label,
            instructions: optimized,
            terminator: block.terminator
        )

    me optimize_instruction(inst: MirInst) -> MirInst?:
        """
        Optimize a single instruction.

        Returns Some(optimized_inst) or nil if instruction is eliminated.
        """
        match inst.kind:
            case BinOp(dest, op, left, right):
                self.optimize_binop(dest, op, left, right, inst.span)

            case UnaryOp(dest, op, operand):
                self.optimize_unaryop(dest, op, operand, inst.span)

            case Cast(dest, operand, target):
                self.optimize_cast(dest, operand, target, inst.span)

            case Copy(dest, src):
                self.optimize_copy(dest, src, inst.span)

            case _:
                # No optimization for this instruction
                Some(inst)

    # ========================================================================
    # Binary Operation Optimizations
    # ========================================================================

    me optimize_binop(dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand, span: Span?) -> MirInst?:
        """
        Optimize binary operation.

        Applies:
        - Constant folding
        - Algebraic identities (x + 0, x * 1, etc.)
        - Strength reduction (x * 2 → x << 1)
        - Zero eliminations (x * 0 → 0)
        """
        # Try constant folding first
        val folded = self.try_fold_binop(op, left, right)
        if folded.?:
            self.stats.constants_folded = self.stats.constants_folded + 1
            val const_val = folded.unwrap()
            val type_ = self.type_map[dest.id] ?? MirType.i64()
            return Some(MirInst(
                kind: MirInstKind.Const(dest, const_val, type_),
                span: span
            ))

        # Try algebraic simplifications
        val simplified = self.simplify_binop(dest, op, left, right, span)
        if simplified.?:
            return simplified

        # Try strength reduction
        if self.level != OptimizationLevel.Basic:
            val reduced = self.strength_reduce_binop(dest, op, left, right, span)
            if reduced.?:
                return reduced

        # No optimization applied
        Some(MirInst(
            kind: MirInstKind.BinOp(dest, op, left, right),
            span: span
        ))

    me simplify_binop(dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand, span: Span?) -> MirInst?:
        """
        Apply algebraic simplifications.

        Examples:
        - x + 0 → x
        - x * 1 → x
        - x * 0 → 0
        - x - x → 0
        - x & 0 → 0
        - x | 0 → x
        """
        val left_const = self.get_operand_const(left)
        val right_const = self.get_operand_const(right)

        match op:
            # Addition identities
            case Add:
                # x + 0 → x
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))
                # 0 + x → x
                if left_const.? and self.is_zero(left_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(right)),
                        span: span
                    ))

            # Multiplication identities
            case Mul:
                # x * 1 → x
                if right_const.? and self.is_one(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))
                # 1 * x → x
                if left_const.? and self.is_one(left_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(right)),
                        span: span
                    ))
                # x * 0 → 0
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.zero_eliminations = self.stats.zero_eliminations + 1
                    val type_ = self.type_map[dest.id] ?? MirType.i64()
                    return Some(MirInst(
                        kind: MirInstKind.Const(dest, MirConstValue.Int(0), type_),
                        span: span
                    ))
                # 0 * x → 0
                if left_const.? and self.is_zero(left_const.unwrap()):
                    self.stats.zero_eliminations = self.stats.zero_eliminations + 1
                    val type_ = self.type_map[dest.id] ?? MirType.i64()
                    return Some(MirInst(
                        kind: MirInstKind.Const(dest, MirConstValue.Int(0), type_),
                        span: span
                    ))

            # Bitwise identities
            case BitAnd:
                # x & 0 → 0
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.zero_eliminations = self.stats.zero_eliminations + 1
                    val type_ = self.type_map[dest.id] ?? MirType.i64()
                    return Some(MirInst(
                        kind: MirInstKind.Const(dest, MirConstValue.Int(0), type_),
                        span: span
                    ))
                # x & -1 → x (all bits set)
                if right_const.? and self.is_all_ones(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))

            case BitOr:
                # x | 0 → x
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))

            case BitXor:
                # x ^ 0 → x
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))

            case Shl | Shr:
                # x << 0 → x, x >> 0 → x
                if right_const.? and self.is_zero(right_const.unwrap()):
                    self.stats.identity_eliminations = self.stats.identity_eliminations + 1
                    return Some(MirInst(
                        kind: MirInstKind.Copy(dest, self.operand_to_local(left)),
                        span: span
                    ))

            case _:
                pass

        nil

    me strength_reduce_binop(dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand, span: Span?) -> MirInst?:
        """
        Strength reduction: replace expensive ops with cheaper ones.

        Examples:
        - x * 2 → x << 1
        - x * 4 → x << 2
        - x / 2 → x >> 1 (signed)
        - x * 3 → (x << 1) + x
        """
        val right_const = self.get_operand_const(right)
        if not right_const.?:
            return nil

        match op:
            case Mul:
                # x * power_of_2 → x << log2(n)
                match right_const.unwrap():
                    case Int(n):
                        val shift_amt = self.log2_if_power_of_2(n)
                        if shift_amt.?:
                            self.stats.strength_reductions = self.stats.strength_reductions + 1
                            # Create shift instruction
                            val shift_operand = MirOperand.const_int(shift_amt.unwrap())
                            return Some(MirInst(
                                kind: MirInstKind.BinOp(dest, MirBinOp.Shl, left, shift_operand),
                                span: span
                            ))
                    case _:
                        pass

            case Div:
                # x / power_of_2 → x >> log2(n) (for unsigned)
                match right_const.unwrap():
                    case Int(n):
                        if n > 0:
                            val shift_amt = self.log2_if_power_of_2(n)
                            if shift_amt.?:
                                self.stats.strength_reductions = self.stats.strength_reductions + 1
                                val shift_operand = MirOperand.const_int(shift_amt.unwrap())
                                return Some(MirInst(
                                    kind: MirInstKind.BinOp(dest, MirBinOp.Shr, left, shift_operand),
                                    span: span
                                ))
                    case _:
                        pass

            case _:
                pass

        nil

    # ========================================================================
    # Unary Operation Optimizations
    # ========================================================================

    me optimize_unaryop(dest: LocalId, op: MirUnaryOp, operand: MirOperand, span: Span?) -> MirInst?:
        """Optimize unary operation."""
        # Try constant folding
        val folded = self.try_fold_unaryop(op, operand)
        if folded.?:
            self.stats.constants_folded = self.stats.constants_folded + 1
            val type_ = self.type_map[dest.id] ?? MirType.i64()
            return Some(MirInst(
                kind: MirInstKind.Const(dest, folded.unwrap(), type_),
                span: span
            ))

        # Try simplifications
        match op:
            case Not:
                # !!x → x (double negation)
                val operand_def = self.get_defining_instruction(operand)
                if operand_def.?:
                    match operand_def.unwrap().kind:
                        case UnaryOp(_, Not, inner_operand):
                            self.stats.algebraic_simplifications = self.stats.algebraic_simplifications + 1
                            return Some(MirInst(
                                kind: MirInstKind.Copy(dest, self.operand_to_local(inner_operand)),
                                span: span
                            ))
                        case _:
                            pass

            case _:
                pass

        # No optimization
        Some(MirInst(
            kind: MirInstKind.UnaryOp(dest, op, operand),
            span: span
        ))

    # ========================================================================
    # Cast Optimizations
    # ========================================================================

    me optimize_cast(dest: LocalId, operand: MirOperand, target: MirType, span: Span?) -> MirInst?:
        """Optimize type cast."""
        val src_type = self.get_operand_type(operand)

        # No-op cast elimination
        if src_type.? and self.types_equal(src_type.unwrap(), target):
            self.stats.redundant_casts = self.stats.redundant_casts + 1
            return Some(MirInst(
                kind: MirInstKind.Copy(dest, self.operand_to_local(operand)),
                span: span
            ))

        # No optimization
        Some(MirInst(
            kind: MirInstKind.Cast(dest, operand, target),
            span: span
        ))

    me optimize_copy(dest: LocalId, src: LocalId, span: Span?) -> MirInst?:
        """Optimize copy instruction."""
        # If source is never used again, this is dead (will be eliminated later)
        # For now, keep it
        Some(MirInst(
            kind: MirInstKind.Copy(dest, src),
            span: span
        ))

    # ========================================================================
    # Dead Code Elimination
    # ========================================================================

    me eliminate_dead_code(blocks: [MirBlock]) -> [MirBlock]:
        """Remove instructions that are never used."""
        var optimized: [MirBlock] = []

        for block in blocks:
            var live_insts: [MirInst] = []

            for inst in block.instructions:
                if self.is_live_instruction(inst):
                    live_insts = live_insts.push(inst)
                else:
                    self.stats.dead_instructions = self.stats.dead_instructions + 1

            optimized = optimized.push(MirBlock(
                id: block.id,
                label: block.label,
                instructions: live_insts,
                terminator: block.terminator
            ))

        optimized

    fn is_live_instruction(inst: MirInst) -> bool:
        """Check if instruction has side effects or is used."""
        match inst.kind:
            case Const(dest, _, _) | Copy(dest, _) | Move(dest, _) | BinOp(dest, _, _, _) | UnaryOp(dest, _, _) | Cast(dest, _, _):
                (self.use_count[dest.id] ?? 0) > 0

            case Store(_, _) | Call(_, _, _):
                # Side effects - always live
                true

            case _:
                # Conservative: keep unknown instructions
                true

    # ========================================================================
    # Helper Methods
    # ========================================================================

    fn try_fold_binop(op: MirBinOp, left: MirOperand, right: MirOperand) -> MirConstValue?:
        """Try to fold binary operation at compile time."""
        val left_const = self.get_operand_const(left)
        val right_const = self.get_operand_const(right)

        if not left_const.? or not right_const.?:
            return nil

        mir_fold_binop(op, left_const.unwrap(), right_const.unwrap())

    fn try_fold_unaryop(op: MirUnaryOp, operand: MirOperand) -> MirConstValue?:
        """Try to fold unary operation at compile time."""
        val const_val = self.get_operand_const(operand)
        if not const_val.?:
            return nil

        match const_val.unwrap():
            case Int(v):
                val result = match op:
                    case Neg: -v
                    case Not: if v == 0: 1 else: 0
                    case BitNot: ~v
                    case _: return nil
                Some(MirConstValue.Int(result))

            case Float(v):
                val result = match op:
                    case Neg: -v
                    case _: return nil
                Some(MirConstValue.Float(result))

            case _:
                nil

    fn get_operand_const(operand: MirOperand) -> MirConstValue?:
        """Get constant value if operand is constant."""
        match operand.kind:
            case Const(value, _):
                Some(value)
            case Copy(local) | Move(local):
                if self.const_map.has(local.id):
                    Some(self.const_map[local.id])
                else:
                    nil

    fn get_operand_type(operand: MirOperand) -> MirType?:
        """Get type of operand."""
        match operand.kind:
            case Const(_, type_):
                Some(type_)
            case Copy(local) | Move(local):
                if self.type_map.has(local.id):
                    Some(self.type_map[local.id])
                else:
                    nil

    fn get_defining_instruction(operand: MirOperand) -> MirInst?:
        """Get the instruction that defined this operand."""
        match operand.kind:
            case Copy(local) | Move(local):
                if self.def_map.has(local.id):
                    Some(self.def_map[local.id])
                else:
                    nil
            case Const(_, _):
                nil

    fn operand_to_local(operand: MirOperand) -> LocalId:
        """Extract LocalId from operand (assumes Copy or Move)."""
        match operand.kind:
            case Copy(local) | Move(local):
                local
            case Const(_, _):
                # Shouldn't happen - caller should check
                LocalId(id: 0)

    me track_operand_use(operand: MirOperand):
        """Track operand use for dead code analysis."""
        match operand.kind:
            case Copy(local) | Move(local):
                self.increment_use(local.id)
            case Const(_, _):
                pass

    me increment_use(local_id: i64):
        """Increment use count for a local."""
        val current = self.use_count[local_id] ?? 0
        self.use_count[local_id] = current + 1

    fn types_equal(a: MirType, b: MirType) -> bool:
        """Check if two types are equal."""
        a.kind == b.kind

    fn is_zero(value: MirConstValue) -> bool:
        """Check if constant value is zero."""
        match value:
            case Int(0): true
            case Float(f): f == 0.0
            case _: false

    fn is_one(value: MirConstValue) -> bool:
        """Check if constant value is one."""
        match value:
            case Int(1): true
            case Float(f): f == 1.0
            case _: false

    fn is_all_ones(value: MirConstValue) -> bool:
        """Check if all bits are set (-1 for signed)."""
        match value:
            case Int(n):
                n == -1
            case _:
                false

    fn log2_if_power_of_2(n: i64) -> i64?:
        """
        If n is a power of 2, return log2(n).
        Otherwise return nil.
        """
        if n <= 0:
            return nil

        # Check if n is power of 2: n & (n-1) == 0
        if (n & (n - 1)) != 0:
            return nil

        # Count trailing zeros to get log2
        var count = 0
        var temp = n
        while (temp & 1) == 0:
            count = count + 1
            temp = temp >> 1

        Some(count)

# ============================================================================
# General IO Optimization Passes
# ============================================================================

fn optimize_write_coalesce(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val base_id = gep_base[local.id]
                                val prev = base_store_count[base_id] ?? 0
                                base_store_count[base_id] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_coalesce = false
        val ks = base_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if base_store_count[ks[ki]] >= 2:
                any_coalesce = true
            ki = ki + 1
        if any_coalesce:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    val base_id: i64 = gep_base2[local.id] ?? 0
                                    val sc: i64 = base_store_count[base_id] ?? 0
                                    if sc >= 2 and not hint_emitted.has(base_id):
                                        val base_lid = LocalId(id: base_id)
                                        val base_op = MirOperand(kind: MirOperandKind.Copy(base_lid))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(sc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_store_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[base_id] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn optimize_read_ahead_hoist(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    """Detect loop-invariant Load/Call instructions; count hoist candidates.

    Identifies basic blocks inside loops (targeted by back-edges from Goto
    or If terminators) and scans for Load/Call instructions whose operands
    are all defined before the loop.  These are candidates for hoisting to
    the loop preheader — applicable to any repeated IO inside a loop.
    """
    if func.blocks.len() < 2:
        return func
    var loop_body: Dict<i64, bool> = {}
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        match block.terminator:
            case Goto(target):
                if target.id <= block.id.id:
                    var li = target.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case If(cond, then_, else_):
                if then_.id <= block.id.id:
                    var li = then_.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
                if else_.id <= block.id.id:
                    var li = else_.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case _:
                pass
        bi = bi + 1
    var pre_loop_defs: Dict<i64, bool> = {}
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if not loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Const(dest, _, _) | Copy(dest, _) | Move(dest, _) | BinOp(dest, _, _, _) | UnaryOp(dest, _, _) | Cast(dest, _, _) | Load(dest, _) | Alloc(dest, _) | GetElementPtr(dest, _, _) | GetField(dest, _, _) | Aggregate(dest, _, _):
                        pre_loop_defs[dest.id] = true
                    case Call(dest, _, _):
                        if dest.?:
                            pre_loop_defs[dest.unwrap().id] = true
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if pre_loop_defs.has(local.id):
                                    pass
                            case Const(_, _):
                                stats.read_ahead_hoist_count = stats.read_ahead_hoist_count + 1
                            case _:
                                pass
                    case Call(dest, func_op, args):
                        var all_invariant = true
                        match func_op.kind:
                            case Copy(local) | Move(local):
                                if not pre_loop_defs.has(local.id):
                                    all_invariant = false
                            case _:
                                pass
                        var ai = 0
                        while ai < args.len() and all_invariant:
                            match args[ai].kind:
                                case Copy(local) | Move(local):
                                    if not pre_loop_defs.has(local.id):
                                        all_invariant = false
                                case _:
                                    pass
                            ai = ai + 1
                        if all_invariant:
                            stats.read_ahead_hoist_count = stats.read_ahead_hoist_count + 1
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    func

fn optimize_syscall_batch(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var batch_starts: Dict<i64, i64> = {}
        var batch_fids: Dict<i64, i64> = {}
        var prev_func_id: i64 = -1
        var run_length: i64 = 0
        var run_start: i64 = 0
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case Call(dest, func_op, args):
                    var fid: i64 = -1
                    match func_op.kind:
                        case Copy(local) | Move(local):
                            fid = local.id
                        case _:
                            pass
                    if fid >= 0 and fid == prev_func_id:
                        run_length = run_length + 1
                    else:
                        if run_length >= 2:
                            batch_starts[run_start] = run_length
                            batch_fids[run_start] = prev_func_id
                        prev_func_id = fid
                        run_start = ii
                        run_length = 1
                case _:
                    if run_length >= 2:
                        batch_starts[run_start] = run_length
                        batch_fids[run_start] = prev_func_id
                    prev_func_id = -1
                    run_length = 0
            ii = ii + 1
        if run_length >= 2:
            batch_starts[run_start] = run_length
            batch_fids[run_start] = prev_func_id
        val bk = batch_starts.keys()
        if bk.len() > 0:
            modified = true
            var new_insts: [MirInst] = []
            ii = 0
            while ii < block.instructions.len():
                if batch_starts.has(ii):
                    val fid_val: i64 = batch_fids[ii] ?? 0
                    val run_val: i64 = batch_starts[ii] ?? 0
                    val func_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: fid_val)))
                    val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(run_val), MirType.i64()))
                    var hint_args: [MirOperand] = []
                    hint_args = hint_args.push(func_op)
                    hint_args = hint_args.push(cnt_op)
                    val hint = MirInst(
                        kind: MirInstKind.Intrinsic(nil, "call_batch_hint", hint_args),
                        span: nil
                    )
                    new_insts = new_insts.push(hint)
                new_insts = new_insts.push(block.instructions[ii])
                ii = ii + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_write_coalesce(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val base_id = gep_base[local.id]
                                val prev = base_store_count[base_id] ?? 0
                                base_store_count[base_id] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = base_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if base_store_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

fn count_read_ahead_hoist(func: MirFunction) -> i64:
    if func.blocks.len() < 2:
        return 0
    var count = 0
    var loop_body: Dict<i64, bool> = {}
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        match block.terminator:
            case Goto(tgt):
                if tgt.id <= block.id.id:
                    var li = tgt.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case If(cond, tb, eb):
                if tb.id <= block.id.id:
                    var li = tb.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
                if eb.id <= block.id.id:
                    var li = eb.id
                    while li <= block.id.id:
                        loop_body[li] = true
                        li = li + 1
            case _:
                pass
        bi = bi + 1
    var pre_loop_defs: Dict<i64, bool> = {}
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if not loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Const(dest, _, _) | Copy(dest, _) | Move(dest, _) | BinOp(dest, _, _, _) | UnaryOp(dest, _, _) | Cast(dest, _, _) | Load(dest, _) | Alloc(dest, _) | GetElementPtr(dest, _, _) | GetField(dest, _, _) | Aggregate(dest, _, _):
                        pre_loop_defs[dest.id] = true
                    case Call(dest, _, _):
                        if dest.?:
                            pre_loop_defs[dest.unwrap().id] = true
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if loop_body.has(block.id.id):
            var ii = 0
            while ii < block.instructions.len():
                val inst = block.instructions[ii]
                match inst.kind:
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if pre_loop_defs.has(local.id):
                                    count = count + 1
                            case Const(_, _):
                                count = count + 1
                            case _:
                                pass
                    case Call(dest, func_op, args):
                        var all_invariant = true
                        match func_op.kind:
                            case Copy(local) | Move(local):
                                if not pre_loop_defs.has(local.id):
                                    all_invariant = false
                            case _:
                                pass
                        var ai = 0
                        while ai < args.len() and all_invariant:
                            match args[ai].kind:
                                case Copy(local) | Move(local):
                                    if not pre_loop_defs.has(local.id):
                                        all_invariant = false
                                case _:
                                    pass
                            ai = ai + 1
                        if all_invariant:
                            count = count + 1
                    case _:
                        pass
                ii = ii + 1
        bi = bi + 1
    count

fn count_syscall_batch(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var prev_func_id: i64 = -1
        var run_len: i64 = 0
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case Call(dest, func_op, args):
                    var fid: i64 = -1
                    match func_op.kind:
                        case Copy(local) | Move(local):
                            fid = local.id
                        case _:
                            pass
                    if fid >= 0 and fid == prev_func_id:
                        run_len = run_len + 1
                    else:
                        if run_len >= 2:
                            count = count + 1
                        prev_func_id = fid
                        run_len = 1
                case _:
                    if run_len >= 2:
                        count = count + 1
                    prev_func_id = -1
                    run_len = 0
            ii = ii + 1
        if run_len >= 2:
            count = count + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Copy Recognizer — Load+Store pairs from different GEP bases
# ============================================================================

fn optimize_bulk_copy(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_src_base: Dict<i64, i64> = {}
        var copy_count: Dict<i64, i64> = {}
        var copy_src: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_src_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val dst_base = gep_base[local.id]
                                match value.kind:
                                    case Copy(vlocal) | Move(vlocal):
                                        if load_src_base.has(vlocal.id):
                                            val src_base = load_src_base[vlocal.id]
                                            if src_base != dst_base:
                                                val prev = copy_count[dst_base] ?? 0
                                                copy_count[dst_base] = prev + 1
                                                if not copy_src.has(dst_base):
                                                    copy_src[dst_base] = src_base
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_copy = false
        val ks = copy_count.keys()
        var ki = 0
        while ki < ks.len():
            if copy_count[ks[ki]] >= 2:
                any_copy = true
            ki = ki + 1
        if any_copy:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var load_src2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    load_src2[dest.id] = gep_base2[local.id]
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    val dst_base: i64 = gep_base2[local.id] ?? 0
                                    val cc: i64 = copy_count[dst_base] ?? 0
                                    if cc >= 2 and not hint_emitted.has(dst_base):
                                        val src_b: i64 = copy_src[dst_base] ?? 0
                                        val src_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: src_b)))
                                        val dst_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: dst_base)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(cc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(src_op)
                                        hint_args = hint_args.push(dst_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_copy_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[dst_base] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_copy(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_src_base: Dict<i64, i64> = {}
        var copy_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_src_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                val dst_base = gep_base[local.id]
                                match value.kind:
                                    case Copy(vlocal) | Move(vlocal):
                                        if load_src_base.has(vlocal.id):
                                            val src_base = load_src_base[vlocal.id]
                                            if src_base != dst_base:
                                                val prev = copy_count[dst_base] ?? 0
                                                copy_count[dst_base] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = copy_count.keys()
        var ki = 0
        while ki < ks.len():
            if copy_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Fill Recognizer — Store of same constant to contiguous GEP offsets
# ============================================================================

fn optimize_bulk_fill(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_const_store: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                match value.kind:
                                    case Const(_, _):
                                        val base_id = gep_base[local.id]
                                        val prev = base_const_store[base_id] ?? 0
                                        base_const_store[base_id] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_fill = false
        val ks = base_const_store.keys()
        var ki = 0
        while ki < ks.len():
            if base_const_store[ks[ki]] >= 2:
                any_fill = true
            ki = ki + 1
        if any_fill:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Store(ptr, value):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    val base_id: i64 = gep_base2[local.id] ?? 0
                                    val fc: i64 = base_const_store[base_id] ?? 0
                                    if fc >= 2 and not hint_emitted.has(base_id):
                                        val base_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: base_id)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(fc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_fill_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[base_id] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_fill(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var base_const_store: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Store(ptr, value):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                match value.kind:
                                    case Const(_, _):
                                        val base_id = gep_base[local.id]
                                        val prev = base_const_store[base_id] ?? 0
                                        base_const_store[base_id] = prev + 1
                                    case _:
                                        pass
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = base_const_store.keys()
        var ki = 0
        while ki < ks.len():
            if base_const_store[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Bulk Compare Recognizer — Load+Load+Compare from two GEP bases
# ============================================================================

fn optimize_bulk_cmp(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_base: Dict<i64, i64> = {}
        var cmp_pair_count: Dict<i64, i64> = {}
        var cmp_pair_other: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case BinOp(dest, op, left, right):
                    match op:
                        case Eq | Ne:
                            var lbase: i64 = -1
                            var rbase: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    if load_base.has(ll.id):
                                        lbase = load_base[ll.id]
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    if load_base.has(rl.id):
                                        rbase = load_base[rl.id]
                                case _:
                                    pass
                            if lbase >= 0 and rbase >= 0 and lbase != rbase:
                                val prev = cmp_pair_count[lbase] ?? 0
                                cmp_pair_count[lbase] = prev + 1
                                if not cmp_pair_other.has(lbase):
                                    cmp_pair_other[lbase] = rbase
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_cmp = false
        val ks = cmp_pair_count.keys()
        var ki = 0
        while ki < ks.len():
            if cmp_pair_count[ks[ki]] >= 2:
                any_cmp = true
            ki = ki + 1
        if any_cmp:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var gep_base2: Dict<i64, i64> = {}
            var load_base2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case GetElementPtr(dest, base, indices):
                        match base.kind:
                            case Copy(local) | Move(local):
                                gep_base2[dest.id] = local.id
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case Load(dest, ptr):
                        match ptr.kind:
                            case Copy(local) | Move(local):
                                if gep_base2.has(local.id):
                                    load_base2[dest.id] = gep_base2[local.id]
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case BinOp(dest, op, left, right):
                        match op:
                            case Eq | Ne:
                                var lbase: i64 = -1
                                match left.kind:
                                    case Copy(ll) | Move(ll):
                                        if load_base2.has(ll.id):
                                            lbase = load_base2[ll.id]
                                    case _:
                                        pass
                                if lbase >= 0:
                                    val cc: i64 = cmp_pair_count[lbase] ?? 0
                                    if cc >= 2 and not hint_emitted.has(lbase):
                                        val other_b: i64 = cmp_pair_other[lbase] ?? 0
                                        val base_a_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: lbase)))
                                        val base_b_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: other_b)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(cc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(base_a_op)
                                        hint_args = hint_args.push(base_b_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "bulk_cmp_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[lbase] = true
                            case _:
                                pass
                        new_insts = new_insts.push(inst)
                    case _:
                        new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_bulk_cmp(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var gep_base: Dict<i64, i64> = {}
        var load_base: Dict<i64, i64> = {}
        var cmp_pair_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case GetElementPtr(dest, base, indices):
                    match base.kind:
                        case Copy(local) | Move(local):
                            gep_base[dest.id] = local.id
                        case _:
                            pass
                case Load(dest, ptr):
                    match ptr.kind:
                        case Copy(local) | Move(local):
                            if gep_base.has(local.id):
                                load_base[dest.id] = gep_base[local.id]
                        case _:
                            pass
                case BinOp(dest, op, left, right):
                    match op:
                        case Eq | Ne:
                            var lbase: i64 = -1
                            var rbase: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    if load_base.has(ll.id):
                                        lbase = load_base[ll.id]
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    if load_base.has(rl.id):
                                        rbase = load_base[rl.id]
                                case _:
                                    pass
                            if lbase >= 0 and rbase >= 0 and lbase != rbase:
                                val prev = cmp_pair_count[lbase] ?? 0
                                cmp_pair_count[lbase] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = cmp_pair_count.keys()
        var ki = 0
        while ki < ks.len():
            if cmp_pair_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Endian Load Recognizer — byte-shift-OR patterns assembling multi-byte values
# ============================================================================

fn optimize_endian_load(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shift_8_count: Dict<i64, i64> = {}
        var shift_8_src: Dict<i64, i64> = {}
        var or_chain_root: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shl:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shift_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitOr:
                            var left_id: i64 = -1
                            var right_id: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    left_id = ll.id
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    right_id = rl.id
                                case _:
                                    pass
                            if (left_id >= 0 and shift_8_src.has(right_id)) or (right_id >= 0 and shift_8_src.has(left_id)):
                                var root = dest.id
                                if or_chain_root.has(left_id):
                                    root = or_chain_root[left_id]
                                elif or_chain_root.has(right_id):
                                    root = or_chain_root[right_id]
                                or_chain_root[dest.id] = root
                                val prev = shift_8_count[root] ?? 0
                                shift_8_count[root] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_endian = false
        val ks = shift_8_count.keys()
        var ki = 0
        while ki < ks.len():
            if shift_8_count[ks[ki]] >= 2:
                any_endian = true
            ki = ki + 1
        if any_endian:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var shift_src2: Dict<i64, i64> = {}
            var or_root2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case BinOp(dest, op, left, right):
                        match op:
                            case Shl:
                                match right.kind:
                                    case Const(MirConstValue.Int(n), _):
                                        if n > 0 and n % 8 == 0:
                                            match left.kind:
                                                case Copy(src) | Move(src):
                                                    shift_src2[dest.id] = src.id
                                                case _:
                                                    pass
                                    case _:
                                        pass
                            case BitOr:
                                var left_id: i64 = -1
                                var right_id: i64 = -1
                                match left.kind:
                                    case Copy(ll) | Move(ll):
                                        left_id = ll.id
                                    case _:
                                        pass
                                match right.kind:
                                    case Copy(rl) | Move(rl):
                                        right_id = rl.id
                                    case _:
                                        pass
                                if (left_id >= 0 and shift_src2.has(right_id)) or (right_id >= 0 and shift_src2.has(left_id)):
                                    var root = dest.id
                                    if or_root2.has(left_id):
                                        root = or_root2[left_id]
                                    elif or_root2.has(right_id):
                                        root = or_root2[right_id]
                                    or_root2[dest.id] = root
                                    val ec: i64 = shift_8_count[root] ?? 0
                                    if ec >= 2 and not hint_emitted.has(root):
                                        val root_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: root)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(ec), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(root_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "endian_load_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[root] = true
                            case _:
                                pass
                    case _:
                        pass
                new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_endian_load(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shift_8_src: Dict<i64, i64> = {}
        var or_chain_root: Dict<i64, i64> = {}
        var shift_8_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shl:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shift_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitOr:
                            var left_id: i64 = -1
                            var right_id: i64 = -1
                            match left.kind:
                                case Copy(ll) | Move(ll):
                                    left_id = ll.id
                                case _:
                                    pass
                            match right.kind:
                                case Copy(rl) | Move(rl):
                                    right_id = rl.id
                                case _:
                                    pass
                            if (left_id >= 0 and shift_8_src.has(right_id)) or (right_id >= 0 and shift_8_src.has(left_id)):
                                var root = dest.id
                                if or_chain_root.has(left_id):
                                    root = or_chain_root[left_id]
                                elif or_chain_root.has(right_id):
                                    root = or_chain_root[right_id]
                                or_chain_root[dest.id] = root
                                val prev = shift_8_count[root] ?? 0
                                shift_8_count[root] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = shift_8_count.keys()
        var ki = 0
        while ki < ks.len():
            if shift_8_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

# ============================================================================
# Endian Store Recognizer — shift-AND-Store patterns splitting values into bytes
# ============================================================================

fn optimize_endian_store(func: MirFunction, stats: OptimizationStats) -> MirFunction:
    var new_blocks: [MirBlock] = []
    var modified = false
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shr_8_src: Dict<i64, i64> = {}
        var masked_src: Dict<i64, i64> = {}
        var src_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shr:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shr_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitAnd:
                            match right.kind:
                                case Const(MirConstValue.Int(255), _):
                                    match left.kind:
                                        case Copy(ll) | Move(ll):
                                            if shr_8_src.has(ll.id):
                                                masked_src[dest.id] = shr_8_src[ll.id]
                                        case _:
                                            pass
                                case _:
                                    pass
                        case _:
                            pass
                case Store(ptr, value):
                    match value.kind:
                        case Copy(vl) | Move(vl):
                            if masked_src.has(vl.id):
                                val orig_src = masked_src[vl.id]
                                val prev = src_store_count[orig_src] ?? 0
                                src_store_count[orig_src] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        var any_endian = false
        val ks = src_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if src_store_count[ks[ki]] >= 2:
                any_endian = true
            ki = ki + 1
        if any_endian:
            modified = true
            var new_insts: [MirInst] = []
            var hint_emitted: Dict<i64, bool> = {}
            var shr_src2: Dict<i64, i64> = {}
            var masked2: Dict<i64, i64> = {}
            var jj = 0
            while jj < block.instructions.len():
                val inst = block.instructions[jj]
                match inst.kind:
                    case BinOp(dest, op, left, right):
                        match op:
                            case Shr:
                                match right.kind:
                                    case Const(MirConstValue.Int(n), _):
                                        if n > 0 and n % 8 == 0:
                                            match left.kind:
                                                case Copy(src) | Move(src):
                                                    shr_src2[dest.id] = src.id
                                                case _:
                                                    pass
                                    case _:
                                        pass
                            case BitAnd:
                                match right.kind:
                                    case Const(MirConstValue.Int(255), _):
                                        match left.kind:
                                            case Copy(ll) | Move(ll):
                                                if shr_src2.has(ll.id):
                                                    masked2[dest.id] = shr_src2[ll.id]
                                            case _:
                                                pass
                                    case _:
                                        pass
                            case _:
                                pass
                    case Store(ptr, value):
                        match value.kind:
                            case Copy(vl) | Move(vl):
                                if masked2.has(vl.id):
                                    val orig_src: i64 = masked2[vl.id] ?? 0
                                    val sc: i64 = src_store_count[orig_src] ?? 0
                                    if sc >= 2 and not hint_emitted.has(orig_src):
                                        val src_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: orig_src)))
                                        val cnt_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(sc), MirType.i64()))
                                        var hint_args: [MirOperand] = []
                                        hint_args = hint_args.push(src_op)
                                        hint_args = hint_args.push(cnt_op)
                                        val hint = MirInst(
                                            kind: MirInstKind.Intrinsic(nil, "endian_store_hint", hint_args),
                                            span: nil
                                        )
                                        new_insts = new_insts.push(hint)
                                        hint_emitted[orig_src] = true
                            case _:
                                pass
                    case _:
                        pass
                new_insts = new_insts.push(inst)
                jj = jj + 1
            new_blocks = new_blocks.push(MirBlock(
                id: block.id, label: block.label,
                instructions: new_insts, terminator: block.terminator
            ))
        else:
            new_blocks = new_blocks.push(block)
        bi = bi + 1
    if modified:
        MirFunction.with_blocks(func, new_blocks)
    else:
        func

fn count_endian_store(func: MirFunction) -> i64:
    var count = 0
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        var shr_8_src: Dict<i64, i64> = {}
        var masked_src: Dict<i64, i64> = {}
        var src_store_count: Dict<i64, i64> = {}
        var ii = 0
        while ii < block.instructions.len():
            val inst = block.instructions[ii]
            match inst.kind:
                case BinOp(dest, op, left, right):
                    match op:
                        case Shr:
                            match right.kind:
                                case Const(MirConstValue.Int(n), _):
                                    if n > 0 and n % 8 == 0:
                                        match left.kind:
                                            case Copy(src) | Move(src):
                                                shr_8_src[dest.id] = src.id
                                            case _:
                                                pass
                                case _:
                                    pass
                        case BitAnd:
                            match right.kind:
                                case Const(MirConstValue.Int(255), _):
                                    match left.kind:
                                        case Copy(ll) | Move(ll):
                                            if shr_8_src.has(ll.id):
                                                masked_src[dest.id] = shr_8_src[ll.id]
                                        case _:
                                            pass
                                case _:
                                    pass
                        case _:
                            pass
                case Store(ptr, value):
                    match value.kind:
                        case Copy(vl) | Move(vl):
                            if masked_src.has(vl.id):
                                val orig_src = masked_src[vl.id]
                                val prev = src_store_count[orig_src] ?? 0
                                src_store_count[orig_src] = prev + 1
                        case _:
                            pass
                case _:
                    pass
            ii = ii + 1
        val ks = src_store_count.keys()
        var ki = 0
        while ki < ks.len():
            if src_store_count[ks[ki]] >= 2:
                count = count + 1
            ki = ki + 1
        bi = bi + 1
    count

