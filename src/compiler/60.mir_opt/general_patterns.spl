    val provider = backend_plugin_provider(
        "simple-hot-call-inline",
        ["typed_mir", "profile.hot_call", "inline_budget"],
        ["canonical_mir", "hot_call_inlined"],
        "profile-budget-guarded"
    )
    val policy = optimization_backend_policy_skip(
        [OptimizerBackendKind.Llvm],
        "llvm_runs_inliner_pipeline"
    )
    backend_recommendation(
        "simple-hot-call-inline",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Runs Simple-side hot-call inlining for non-LLVM JIT/backend paths only when profile and inline-budget facts prove the call expansion is worth the compile-time and code-size cost; LLVM should use its inliner pipeline.",
        "LLVM pass documentation includes function inlining passes, and the New Pass Manager default pipelines are intended to compose normal optimization pipelines.",
        "high"
    )

fn llvm_default_pipeline_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "llvm-default-pipeline",
        ["llvm_backend_available"],
        ["backend_pipeline_selected"],
        "backend-managed"
    )
    val policy = optimization_backend_policy_only(
        [OptimizerBackendKind.Llvm],
        "llvm_default_pipeline_only"
    )
    backend_recommendation(
        "llvm-default-pipeline",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Uses LLVM's default optimization pipeline instead of duplicating low-level scalar, loop, and cleanup passes in Simple plugins.",
        "LLVM New Pass Manager: PassBuilder default pipelines are the intended way to construct normal optimization pipelines.",
        "high"
    )

fn all_backend_optimization_recommendations() -> [BackendOptimizationRecommendation]:
    [
        ssa_var_canon_recommendation(),
        llvm_entry_alloca_shaping_recommendation(),
        early_dead_code_recommendation(),
        cranelift_local_licm_recommendation(),
        simple_loop_unroll_recommendation(),
        simple_predicate_promote_recommendation(),
        simple_strength_reduce_recommendation(),
        bounds_check_elim_recommendation(),
        byte_scan_recommendation(),
        checksum_reducer_recommendation(),
        simple_scalar_cleanup_recommendation(),
        simple_auto_vectorize_recommendation(),
        simple_hot_call_inline_recommendation(),
        llvm_default_pipeline_recommendation()
    ]

fn backend_optimization_recommendations_for(backend_name: text) -> [BackendOptimizationRecommendation]:
    var selected: [BackendOptimizationRecommendation] = []
    for rec in all_backend_optimization_recommendations():
        if optimization_rule_provider_applies_to_backend_name(rec.provider, backend_name):
            selected = selected.push(rec)
    selected

fn backend_optimization_recommendation_names(backend_name: text) -> [text]:
    var names: [text] = []
    for rec in backend_optimization_recommendations_for(backend_name):
        names = names.push(rec.stable_name)
    names

fn backend_optimization_recommendations_for_budget(backend_name: text, max_cost_class: text) -> [BackendOptimizationRecommendation]:
    var selected: [BackendOptimizationRecommendation] = []
    for rec in backend_optimization_recommendations_for(backend_name):
        if backend_optimization_cost_allowed(rec.cost_class, max_cost_class):
            selected = selected.push(rec)
    selected

fn backend_optimization_decision(rec: BackendOptimizationRecommendation, backend_name: text, max_cost_class: text) -> BackendOptimizationDecision:
    if not optimization_rule_provider_applies_to_backend_name(rec.provider, backend_name):
        return BackendOptimizationDecision(rec.stable_name, backend_name, max_cost_class, rec.cost_class, false, rec.provider.backend_policy.reason)
    if not backend_optimization_cost_allowed(rec.cost_class, max_cost_class):
        return BackendOptimizationDecision(rec.stable_name, backend_name, max_cost_class, rec.cost_class, false, "cost budget exceeded")
    BackendOptimizationDecision(rec.stable_name, backend_name, max_cost_class, rec.cost_class, true, "ready")

fn backend_optimization_decision_with_facts(rec: BackendOptimizationRecommendation, backend_name: text, max_cost_class: text, available_facts: [text]) -> BackendOptimizationDecision:
    val base = backend_optimization_decision(rec, backend_name, max_cost_class)
    if not base.applies:
        return base
    val missing = optimization_rule_provider_missing_fact(rec.provider, available_facts)
    if missing.?:
        return BackendOptimizationDecision(rec.stable_name, backend_name, max_cost_class, rec.cost_class, false, "missing " + missing.unwrap())
    base

fn backend_optimization_decisions_for_budget(backend_name: text, max_cost_class: text) -> [BackendOptimizationDecision]:
    var decisions: [BackendOptimizationDecision] = []
    for rec in all_backend_optimization_recommendations():
        decisions = decisions.push(backend_optimization_decision(rec, backend_name, max_cost_class))
    decisions

fn backend_optimization_decisions_for_budget_with_facts(backend_name: text, max_cost_class: text, available_facts: [text]) -> [BackendOptimizationDecision]:
    var decisions: [BackendOptimizationDecision] = []
    for rec in all_backend_optimization_recommendations():
        decisions = decisions.push(backend_optimization_decision_with_facts(rec, backend_name, max_cost_class, available_facts))
    decisions

fn backend_optimization_skipped_decisions_for_budget(backend_name: text, max_cost_class: text) -> [BackendOptimizationDecision]:
    var skipped: [BackendOptimizationDecision] = []
    for decision in backend_optimization_decisions_for_budget(backend_name, max_cost_class):
        if not decision.applies:
            skipped = skipped.push(decision)
    skipped

fn backend_optimization_skipped_decisions_for_budget_with_facts(backend_name: text, max_cost_class: text, available_facts: [text]) -> [BackendOptimizationDecision]:
    var skipped: [BackendOptimizationDecision] = []
    for decision in backend_optimization_decisions_for_budget_with_facts(backend_name, max_cost_class, available_facts):
        if not decision.applies:
            skipped = skipped.push(decision)
    skipped

fn backend_optimization_backend_is_llvm(backend_name: text) -> bool:
    optimization_backend_kind_from_text(backend_name) == OptimizerBackendKind.Llvm

fn backend_optimization_backend_is_simple_low_tier_jit(backend_name: text) -> bool:
    val kind = optimization_backend_kind_from_text(backend_name)
    kind == OptimizerBackendKind.Cranelift or kind == OptimizerBackendKind.Interpreter

fn backend_optimization_plan_add_entry(
    names: [text],
    skipped: [BackendOptimizationDecision],
    stable_name: text,
    backend_name: text,
    max_cost_class: text,
    cost_class: text,
    backend_applies: bool,
    skip_reason: text
) -> ([text], [BackendOptimizationDecision]):
    if not backend_applies:
        return (names, skipped.push(BackendOptimizationDecision(stable_name, backend_name, max_cost_class, cost_class, false, skip_reason)))
    if not backend_optimization_cost_allowed(cost_class, max_cost_class):
        return (names, skipped.push(BackendOptimizationDecision(stable_name, backend_name, max_cost_class, cost_class, false, "cost budget exceeded")))
    (names.push(stable_name), skipped)

fn backend_optimization_plan_for_budget(backend_name: text, max_cost_class: text) -> BackendOptimizationPlan:
    var names: [text] = []
    var skipped: [BackendOptimizationDecision] = []
    val is_llvm = backend_optimization_backend_is_llvm(backend_name)
    val is_low_tier_jit = backend_optimization_backend_is_simple_low_tier_jit(backend_name)
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "ssa-var-canon", backend_name, max_cost_class, "low", not is_llvm, "llvm_backend_runs_mem2reg_sroa_pipeline")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "llvm-entry-alloca-shaping", backend_name, max_cost_class, "low", is_llvm, "llvm_frontend_alloca_promotion_shape")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "early-dead-code-prune", backend_name, max_cost_class, "low", true, "")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "cranelift-local-licm", backend_name, max_cost_class, "medium", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-loop-unroll", backend_name, max_cost_class, "medium", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-predicate-promote", backend_name, max_cost_class, "high", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-strength-reduce", backend_name, max_cost_class, "medium", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "bounds-check-elim", backend_name, max_cost_class, "medium", true, "")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "byte-scan-to-delimiter", backend_name, max_cost_class, "medium", true, "")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "checksum-reducer", backend_name, max_cost_class, "medium", true, "")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-scalar-cleanup", backend_name, max_cost_class, "medium", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-auto-vectorize", backend_name, max_cost_class, "high", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "simple-hot-call-inline", backend_name, max_cost_class, "high", is_low_tier_jit, "backend_not_simple_low_tier_jit")
    (names, skipped) = backend_optimization_plan_add_entry(names, skipped, "llvm-default-pipeline", backend_name, max_cost_class, "high", is_llvm, "llvm_default_pipeline_only")
    BackendOptimizationPlan(names, skipped)

fn backend_optimization_plan_for_budget_with_facts(backend_name: text, max_cost_class: text, available_facts: [text]) -> BackendOptimizationPlan:
    var names: [text] = []
    var skipped: [BackendOptimizationDecision] = []
    for decision in backend_optimization_decisions_for_budget_with_facts(backend_name, max_cost_class, available_facts):
        if decision.applies:
            names = names.push(decision.stable_name)
        else:
            skipped = skipped.push(decision)
    BackendOptimizationPlan(names, skipped)

fn backend_optimization_recommendation_names_for_budget(backend_name: text, max_cost_class: text) -> [text]:
    var names: [text] = []
    for rec in backend_optimization_recommendations_for_budget(backend_name, max_cost_class):
        names = names.push(rec.stable_name)
    names

fn backend_optimization_has_recommendation(backend_name: text, stable_name: text) -> bool:
    for name in backend_optimization_recommendation_names(backend_name):
        if name == stable_name:
            return true
    false

