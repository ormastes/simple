# General MIR Optimization Patterns
#
# Seven general-purpose MIR optimization patterns registered as dynamic-pass
# manifest entries, plus optimization facts that bridge recognizers to the
# CLib parity rewrite layer. These are NOT domain-specific — they recognize
# common code patterns that appear across filesystem, database, webserver,
# and SimpleOS hot paths, but apply anywhere the same structure occurs.
#
# Patterns:
#   1. byte-scan-to-delimiter  — loop scanning bytes until a sentinel
#   2. switch-on-short-string  — dispatch on short fixed strings
#   3. capability-guarded-fast-path — skip buffer copy when capability is set
#   4. bit-unpack-fixed-table  — bit extraction with fixed lookup table
#   5. checksum-reducer        — accumulator loop folding bytes into checksum
#   6. prefix-scan-table       — prefix/trie-based table lookup
#   7. wal-batch-flush         — write batching before single flush/sync

use compiler.mir_opt.optimizer_manifest.{
    ManifestPassEntry, ManifestPassContract, OptimizerManifest,
    ManifestSchemaVersion, ManifestError, manifest_error_message,
    load_manifest_v1_from_parsed_with_rules,
    DynamicPassRegistry, dynamic_pass_registry_register,
    manifest_pass_entry_new
}
use compiler.mir_opt.mir_opt.mod.{PassScope}
use compiler.mir_opt.mir_opt.pattern.rule_engine.{
    OptimizationRuleProvider, OptimizerProviderKind, OptimizerRuleLookupKind,
    OptimizerBackendKind,
    optimization_backend_policy_all, optimization_backend_policy_only,
    optimization_backend_policy_skip,
    optimization_rule_provider_builtin_with_contract,
    optimization_rule_provider_with_backend_policy,
    optimization_rule_provider_applies_to_backend_name
}
use compiler.mir_opt.mir_opt.pattern.pattern_rule_pass.{
    PatternRule, PatternRuleSet, pattern_rule_set_new,
    MirPattern, MirPatternSlot, MirRewrite
}

# ============================================================================
# Pattern Descriptors
# ============================================================================

struct GeneralPatternInfo:
    name: text
    description: text
    match_criteria: text
    example_sites: [text]

fn byte_scan_to_delimiter_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "byte-scan-to-delimiter",
        description: "Recognizes loops that scan a byte buffer until a delimiter character is found. Candidate for SIMD vectorization or memchr intrinsic replacement.",
        match_criteria: "while-loop with byte index increment, body contains single-byte compare against constant, loop exits on match or end-of-buffer",
        example_sites: ["HTTP header line scan", "CSV field delimiter", "line-oriented text parsing"]
    )

fn switch_on_short_string_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "switch-on-short-string",
        description: "Recognizes chains of string equality checks against short fixed literals. Candidate for hash-switch or prefix-trie lowering.",
        match_criteria: "if-elif chain where each branch compares the same variable against a string literal of length <= 16, minimum 4 branches",
        example_sites: ["HTTP method dispatch", "route path matching", "command name dispatch"]
    )

fn capability_guarded_fast_path_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "capability-guarded-fast-path",
        description: "Recognizes a boolean/capability guard that selects between a zero-copy fast path and a buffer-copy fallback. Candidate for branch-weight annotation and copy-elision.",
        match_criteria: "if-else where the condition is a boolean field or capability check, true-branch avoids allocation/copy, false-branch performs explicit buffer copy",
        example_sites: ["sendfile vs read+write", "DMA capable vs memcpy", "zero-copy network send"]
    )

fn bit_unpack_fixed_table_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "bit-unpack-fixed-table",
        description: "Recognizes loops that extract bits from a packed buffer and look up each extracted value in a fixed table. Candidate for batch-decode intrinsic or lookup-table flattening.",
        match_criteria: "while-loop with bit-position counter, body contains shift+mask to extract N bits, result used as index into a fixed-size array",
        example_sites: ["Huffman decoding", "variable-length integer decoding", "bitfield unpacking"]
    )

fn checksum_reducer_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "checksum-reducer",
        description: "Recognizes accumulator loops that fold bytes into a running checksum value. Candidate for hardware CRC intrinsic, vectorized hash, or table-driven reduction.",
        match_criteria: "while-loop or for-loop with running accumulator variable, body XORs/adds/shifts input bytes into accumulator, loop iterates over contiguous byte range",
        example_sites: ["FS metadata checksum verification", "database page checksum", "HTTP content integrity", "network protocol CRC"]
    )

fn prefix_scan_table_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "prefix-scan-table",
        description: "Recognizes prefix or trie-based table lookups for name resolution. Candidate for radix-tree lowering, hash-prefix shortcut, or binary-search rewrite.",
        match_criteria: "loop or recursive descent that walks a sorted table or trie structure comparing key prefixes, exits on mismatch or exact match",
        example_sites: ["FS dentry prefix lookup", "database index prefix scan", "URL route prefix matching", "symbol table resolution"]
    )

fn wal_batch_flush_info() -> GeneralPatternInfo:
    GeneralPatternInfo(
        name: "wal-batch-flush",
        description: "Recognizes write-ahead-log style batching where multiple small writes are coalesced into a buffer before a single flush or sync call. Candidate for batch-size tuning, write-combining, or deferred-sync annotation.",
        match_criteria: "loop appending to a buffer or log structure, followed by a single flush/sync/commit call outside the loop, buffer size bounded by constant or threshold",
        example_sites: ["FS journal batch write", "database WAL checkpoint", "HTTP response buffering", "SimpleOS syscall batching"]
    )

fn all_general_pattern_infos() -> [GeneralPatternInfo]:
    [
        byte_scan_to_delimiter_info(),
        switch_on_short_string_info(),
        capability_guarded_fast_path_info(),
        bit_unpack_fixed_table_info(),
        checksum_reducer_info(),
        prefix_scan_table_info(),
        wal_batch_flush_info()
    ]

# ============================================================================
# Manifest Entry Construction
# ============================================================================

fn general_pattern_contract() -> ManifestPassContract:
    ManifestPassContract(
        inputs: ["typed_mir"],
        outputs: ["canonical_mir"],
        purity: "pure"
    )

fn pattern_info_to_manifest_entry(info: GeneralPatternInfo) -> ManifestPassEntry:
    manifest_pass_entry_new(
        info.name,
        [],
        PassScope.Function,
        [],
        general_pattern_contract(),
        "general_pattern_" + info.name.replace("-", "_")
    )

fn general_pattern_manifest_entries() -> [ManifestPassEntry]:
    var entries: [ManifestPassEntry] = []
    for info in all_general_pattern_infos():
        entries = entries.push(pattern_info_to_manifest_entry(info))
    entries

# ============================================================================
# Pattern Rule Construction
# ============================================================================

fn make_pattern_rule(name: text, match_slot_kind: text, rewrite_kind: text) -> PatternRule:
    val slot = MirPatternSlot(
        kind_tag: match_slot_kind,
        operand_0: Some("$src"),
        operand_1: Some("$const"),
        dest: Some("$dest")
    )
    val pattern = MirPattern(inst_count: 1, slots: [slot])
    val rewrite = MirRewrite(kind_tag: rewrite_kind, dest: "$dest", operands: ["$src", "$const"])
    PatternRule(
        name: name,
        pattern: pattern,
        rewrite: rewrite,
        cost_delta: -1,
        safety: "safe"
    )

fn byte_scan_to_delimiter_rule() -> PatternRule:
    make_pattern_rule("byte-scan-to-delimiter", "Intrinsic", "Intrinsic")

fn switch_on_short_string_rule() -> PatternRule:
    make_pattern_rule("switch-on-short-string", "BinOp", "Intrinsic")

fn capability_guarded_fast_path_rule() -> PatternRule:
    make_pattern_rule("capability-guarded-fast-path", "Copy", "Copy")

fn bit_unpack_fixed_table_rule() -> PatternRule:
    make_pattern_rule("bit-unpack-fixed-table", "Load", "Intrinsic")

fn checksum_reducer_rule() -> PatternRule:
    make_pattern_rule("checksum-reducer", "BinOp", "Intrinsic")

fn prefix_scan_table_rule() -> PatternRule:
    make_pattern_rule("prefix-scan-table", "Load", "Intrinsic")

fn wal_batch_flush_rule() -> PatternRule:
    make_pattern_rule("wal-batch-flush", "Store", "Intrinsic")

fn general_pattern_rules() -> [PatternRule]:
    [
        byte_scan_to_delimiter_rule(),
        switch_on_short_string_rule(),
        capability_guarded_fast_path_rule(),
        bit_unpack_fixed_table_rule(),
        checksum_reducer_rule(),
        prefix_scan_table_rule(),
        wal_batch_flush_rule()
    ]

# ============================================================================
# Manifest Construction and Registration
# ============================================================================

fn general_patterns_manifest_name() -> text:
    "simple.opt.general-patterns"

fn general_patterns_manifest_version() -> text:
    "1.0.0"

fn load_general_patterns_manifest() -> Result<OptimizerManifest, text>:
    val result = load_manifest_v1_from_parsed_with_rules(
        1,
        "simple.opt.mir.v1",
        general_patterns_manifest_name(),
        general_patterns_manifest_version(),
        "0.9.0",
        general_pattern_manifest_entries(),
        general_pattern_rules()
    )
    match result:
        case Ok(manifest): Ok(manifest)
        case Err(err):
            Err("failed to load general patterns manifest: " + manifest_error_message(err))

fn register_general_patterns(registry: DynamicPassRegistry) -> Result<DynamicPassRegistry, text>:
    val manifest_result = load_general_patterns_manifest()
    match manifest_result:
        case Err(msg): return Err(msg)
        case Ok(manifest):
            val reg_result = dynamic_pass_registry_register(registry, manifest)
            match reg_result:
                case Ok(updated): Ok(updated)
                case Err(err):
                    Err("failed to register general patterns: " + manifest_error_message(err))

# ============================================================================
# Pattern Matching Verification (general recognizers)
# ============================================================================

fn is_byte_scan_loop(loop_body: text) -> bool:
    val has_index_increment = loop_body.contains("+ 1") or loop_body.contains("+= 1")
    val has_byte_compare = loop_body.contains("==") and (loop_body.contains("[") and loop_body.contains("]"))
    val has_break = loop_body.contains("break")
    has_index_increment and has_byte_compare and has_break

fn is_short_string_switch(code: text) -> bool:
    var branch_count = 0
    val lines = code.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("if ") or trimmed.starts_with("elif "):
            if trimmed.contains("==") and trimmed.contains("\""):
                branch_count = branch_count + 1
    branch_count >= 4

fn is_capability_guard(code: text) -> bool:
    val has_if_else = code.contains("if ") and code.contains("else:")
    val has_copy_fallback = code.contains("copy") or code.contains("alloc") or code.contains("buffer")
    has_if_else and has_copy_fallback

fn is_bit_unpack_loop(code: text) -> bool:
    val has_shift = code.contains(">>") or code.contains("<<")
    val has_mask = code.contains("&")
    val has_table_lookup = code.contains("[") and code.contains("]")
    val has_bit_counter = code.contains("bit_pos") or code.contains("bit_offset")
    has_shift and has_mask and has_table_lookup and has_bit_counter

fn is_checksum_reducer_loop(code: text) -> bool:
    val has_accumulator = code.contains("^=") or code.contains("^") or code.contains("xor")
    val has_loop = code.contains("while") or code.contains("for ")
    val has_byte_access = code.contains("[") and code.contains("]")
    has_accumulator and has_loop and has_byte_access

fn is_prefix_scan_lookup(code: text) -> bool:
    val has_prefix_compare = code.contains("starts_with") or code.contains("prefix")
    val has_lookup = code.contains("[") and code.contains("]")
    val has_iteration = code.contains("while") or code.contains("for ")
    has_prefix_compare and has_lookup and has_iteration

fn is_wal_batch_flush(code: text) -> bool:
    val has_append = code.contains("append") or code.contains("push") or code.contains("write")
    val has_flush = code.contains("flush") or code.contains("sync") or code.contains("commit")
    val has_loop = code.contains("while") or code.contains("for ")
    has_append and has_flush and has_loop

# ============================================================================
# Optimization Facts for Web Hot Paths
# ============================================================================

struct OptimizationFact:
    key: text
    description: text
    general_recognizer: text

struct BackendOptimizationRecommendation:
    stable_name: text
    provider: OptimizationRuleProvider
    rationale: text
    source_hint: text
    cost_class: text

fn backend_optimization_cost_rank(cost_class: text) -> i64:
    if cost_class == "free":
        0
    elif cost_class == "low":
        1
    elif cost_class == "medium":
        2
    elif cost_class == "high":
        3
    else:
        99

fn backend_optimization_cost_allowed(cost_class: text, max_cost_class: text) -> bool:
    backend_optimization_cost_rank(cost_class) <= backend_optimization_cost_rank(max_cost_class)

fn web_hot_path_facts() -> [OptimizationFact]:
    [
        OptimizationFact(
            key: "bounded_scan_terminates",
            description: "Byte-scan loop has bounded length or sentinel — safe for SIMD memchr replacement",
            general_recognizer: "byte-scan-to-delimiter"
        ),
        OptimizationFact(
            key: "dispatch_branches_exhaustive",
            description: "Short-string switch covers all expected inputs — safe for hash-switch lowering",
            general_recognizer: "switch-on-short-string"
        ),
        OptimizationFact(
            key: "copy_guard_fast_path_safe",
            description: "Capability guard selects zero-copy path when available — safe for copy elision",
            general_recognizer: "capability-guarded-fast-path"
        ),
        OptimizationFact(
            key: "bit_extract_table_fixed",
            description: "Bit-extraction loop uses fixed lookup table — safe for batch decode intrinsic",
            general_recognizer: "bit-unpack-fixed-table"
        ),
        OptimizationFact(
            key: "checksum_associative",
            description: "Checksum accumulator is associative — safe for vectorized reduction",
            general_recognizer: "checksum-reducer"
        ),
        OptimizationFact(
            key: "prefix_table_sorted",
            description: "Prefix lookup table is sorted — safe for binary-search or radix rewrite",
            general_recognizer: "prefix-scan-table"
        ),
        OptimizationFact(
            key: "batch_flush_bounded",
            description: "Write batch has bounded size before flush — safe for write-combining annotation",
            general_recognizer: "wal-batch-flush"
        )
    ]

fn fact_for_recognizer(recognizer_name: text) -> OptimizationFact?:
    val facts = web_hot_path_facts()
    var i = 0
    while i < facts.len():
        if facts[i].general_recognizer == recognizer_name:
            return Some(facts[i])
        i = i + 1
    nil

fn all_fact_keys() -> [text]:
    val facts = web_hot_path_facts()
    var keys: [text] = []
    for f in facts:
        keys = keys.push(f.key)
    keys

# ============================================================================
# Backend-aware plugin recommendations
# ============================================================================

fn backend_plugin_provider(
    name: text,
    required_facts: [text],
    produced_facts: [text],
    safety_class: text
) -> OptimizationRuleProvider:
    optimization_rule_provider_builtin_with_contract(
        "simple.opt.general." + name,
        OptimizerProviderKind.Mir,
        OptimizerRuleLookupKind.PipelinePass,
        true,
        required_facts,
        produced_facts,
        safety_class
    )

fn backend_recommendation(
    stable_name: text,
    provider: OptimizationRuleProvider,
    rationale: text,
    source_hint: text,
    cost_class: text
) -> BackendOptimizationRecommendation:
    BackendOptimizationRecommendation(stable_name, provider, rationale, source_hint, cost_class)

fn ssa_var_canon_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "ssa-var-canon",
        ["typed_mir", "ssa.var_transform", "escape.no_escape", "borrow.reassign_safe"],
        ["canonical_mir", "jit.hotspot_var_ready"],
        "escape-borrow-guarded"
    )
    val policy = optimization_backend_policy_skip(
        [OptimizerBackendKind.Llvm],
        "llvm_backend_runs_mem2reg_sroa_pipeline"
    )
    backend_recommendation(
        "ssa-var-canon",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Canonicalizes reassigned Simple var storage before Cranelift/interpreter JIT planning; LLVM should receive promotable IR and let SROA/mem2reg run.",
        "LLVM frontend performance tips: SROA and Mem2Reg promote entry-block allocas; Cranelift frontend uses variables/block params for SSA values.",
        "low"
    )

fn llvm_entry_alloca_shaping_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "llvm-entry-alloca-shaping",
        ["typed_mir", "var.reassignment", "escape.no_escape", "borrow.reassign_safe"],
        ["llvm.promotable_allocas", "backend_pipeline_selected"],
        "escape-borrow-guarded"
    )
    val policy = optimization_backend_policy_only(
        [OptimizerBackendKind.Llvm],
        "llvm_frontend_alloca_promotion_shape"
    )
    backend_recommendation(
        "llvm-entry-alloca-shaping",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Keeps reassigned var storage in the LLVM-promotable shape instead of running Simple-side SSA canonicalization that duplicates LLVM SROA/mem2reg.",
        "LLVM frontend performance tips document that SROA and Mem2Reg only eliminate allocas they can promote, with entry-block allocas being the key frontend shape.",
        "low"
    )

fn early_dead_code_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "early-dead-code-prune",
        ["typed_mir"],
        ["canonical_mir", "dead_code_pruned"],
        "pure"
    )
    backend_recommendation(
        "early-dead-code-prune",
        optimization_rule_provider_with_backend_policy(provider, optimization_backend_policy_all()),
        "Prunes obviously dead MIR before backend optimization so later scalar promotion and pattern passes do less work.",
        "LLVM new pass pipeline guidance favors canonical cleanup around scalar optimization pipelines.",
        "low"
    )

fn cranelift_local_licm_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "cranelift-local-licm",
        ["typed_mir", "loop_preheader", "alias_stable"],
        ["loop_invariants_hoisted"],
        "alias-proof-guarded"
    )
    val policy = optimization_backend_policy_skip(
        [OptimizerBackendKind.Llvm],
        "llvm_default_pipeline_runs_loop_optimizations"
    )
    backend_recommendation(
        "cranelift-local-licm",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Hoists cheap loop-invariant MIR work for Cranelift and interpreter JIT paths where Simple owns more of the mid-end; LLVM should use its loop pipeline.",
        "LLVM pass documentation includes loop optimization passes such as LICM in the backend pipeline family.",
        "medium"
    )

fn bounds_check_elim_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "bounds-check-elim",
        ["typed_mir", "range_facts"],
        ["canonical_mir", "bounds_checks_elided"],
        "range-proof-guarded"
    )
    backend_recommendation(
        "bounds-check-elim",
        optimization_rule_provider_with_backend_policy(provider, optimization_backend_policy_all()),
        "Keeps Simple range proofs visible before lowering; backend optimizers cannot reliably reconstruct language-level bounds facts after runtime-call lowering.",
        "General compiler practice: preserve high-level range facts before lowering to low-level IR.",
        "medium"
    )

fn byte_scan_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "byte-scan-to-delimiter",
        ["typed_mir", "bounded_scan_terminates"],
        ["canonical_mir", "byte_scan_intrinsic"],
        "proof-guarded"
    )
    backend_recommendation(
        "byte-scan-to-delimiter",
        optimization_rule_provider_with_backend_policy(provider, optimization_backend_policy_all()),
        "Recognizes delimiter scans while buffer and sentinel facts are still explicit, enabling memchr/SIMD or backend-specific lowering.",
        "LLVM pass catalog includes loop/vector/scalar cleanup, but high-level delimiter intent is frontend-owned.",
        "medium"
    )

fn checksum_reducer_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "checksum-reducer",
        ["typed_mir", "checksum_associative"],
        ["canonical_mir", "checksum_reduction_intrinsic"],
        "proof-guarded"
    )
    backend_recommendation(
        "checksum-reducer",
        optimization_rule_provider_with_backend_policy(provider, optimization_backend_policy_all()),
        "Keeps checksum associativity and reduction shape explicit for hardware CRC, vector reduction, or table-driven lowering.",
        "Backend vectorizers help after lowering, but checksum semantics are easier to prove in MIR.",
        "medium"
    )

fn llvm_default_pipeline_recommendation() -> BackendOptimizationRecommendation:
    val provider = backend_plugin_provider(
        "llvm-default-pipeline",
        ["llvm_backend_available"],
        ["backend_pipeline_selected"],
        "backend-managed"
    )
    val policy = optimization_backend_policy_only(
        [OptimizerBackendKind.Llvm],
        "llvm_default_pipeline_only"
    )
    backend_recommendation(
        "llvm-default-pipeline",
        optimization_rule_provider_with_backend_policy(provider, policy),
        "Uses LLVM's default optimization pipeline instead of duplicating low-level scalar, loop, and cleanup passes in Simple plugins.",
        "LLVM New Pass Manager: PassBuilder default pipelines are the intended way to construct normal optimization pipelines.",
        "high"
    )

fn all_backend_optimization_recommendations() -> [BackendOptimizationRecommendation]:
    [
        ssa_var_canon_recommendation(),
        llvm_entry_alloca_shaping_recommendation(),
        early_dead_code_recommendation(),
        cranelift_local_licm_recommendation(),
        bounds_check_elim_recommendation(),
        byte_scan_recommendation(),
        checksum_reducer_recommendation(),
        llvm_default_pipeline_recommendation()
    ]

fn backend_optimization_recommendations_for(backend_name: text) -> [BackendOptimizationRecommendation]:
    var selected: [BackendOptimizationRecommendation] = []
    for rec in all_backend_optimization_recommendations():
        if optimization_rule_provider_applies_to_backend_name(rec.provider, backend_name):
            selected = selected.push(rec)
    selected

fn backend_optimization_recommendation_names(backend_name: text) -> [text]:
    var names: [text] = []
    for rec in backend_optimization_recommendations_for(backend_name):
        names = names.push(rec.stable_name)
    names

fn backend_optimization_recommendations_for_budget(backend_name: text, max_cost_class: text) -> [BackendOptimizationRecommendation]:
    var selected: [BackendOptimizationRecommendation] = []
    for rec in backend_optimization_recommendations_for(backend_name):
        if backend_optimization_cost_allowed(rec.cost_class, max_cost_class):
            selected = selected.push(rec)
    selected

fn backend_optimization_recommendation_names_for_budget(backend_name: text, max_cost_class: text) -> [text]:
    var names: [text] = []
    for rec in backend_optimization_recommendations_for_budget(backend_name, max_cost_class):
        names = names.push(rec.stable_name)
    names

fn backend_optimization_has_recommendation(backend_name: text, stable_name: text) -> bool:
    for name in backend_optimization_recommendation_names(backend_name):
        if name == stable_name:
            return true
    false

