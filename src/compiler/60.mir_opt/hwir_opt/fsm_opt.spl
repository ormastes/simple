# HWIR FSM optimization.

use compiler.mir.hwir.types.{HwModule, HwFsm}
use compiler.mir_opt.hwir_opt.pass_model.{HwirOptPassResult, hwir_cost_with_resource_delta}

class HwirFsmOptPlan:
    """FSM optimization decision."""
    fsm: HwFsm
    unreachable_states: i32
    encoding: text

    me reachable_states() -> i32:
        return self.fsm.state_count - self.unreachable_states

fn hwir_choose_fsm_encoding(state_count: i32, profile: text) -> text:
    if profile == "speed":
        return "one_hot"
    if state_count <= 4:
        return "binary"
    if profile == "area":
        return "binary"
    return "gray"

fn hwir_fsm_opt_pass(module: HwModule, plan: HwirFsmOptPlan) -> HwirOptPassResult:
    if plan.unreachable_states == 0 and plan.encoding == plan.fsm.encoding:
        return HwirOptPassResult.unchanged("fsm_opt", module, "fsm already minimized")
    val ff_delta = 0 - plan.unreachable_states
    return HwirOptPassResult.changed("fsm_opt", module, hwir_cost_with_resource_delta(module.cost, 0, ff_delta, 0, 0, 0), plan.unreachable_states, 0, 0, 0, "removed unreachable states and selected " + plan.encoding + " encoding")
