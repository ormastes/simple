# HWIR DSP inference.

use compiler.mir.hwir.types.{HwModule}
use compiler.mir_opt.hwir_opt.pass_model.{HwirOptPassResult, hwir_cost_with_resource_delta}

class HwirDspPattern:
    """Recognized DSP-capable arithmetic pattern."""
    node_id: text
    pattern_kind: text
    operand_width: i32
    term_count: i32
    prefer_lut: bool

    me uses_dsp() -> bool:
        return not self.prefer_lut and self.operand_width >= 8

fn hwir_dsp_inference_pass(module: HwModule, patterns: [HwirDspPattern]) -> HwirOptPassResult:
    if patterns.len() == 0:
        return HwirOptPassResult.unchanged("dsp_inference", module, "no DSP-capable arithmetic patterns")
    var dsp_count = 0
    var lut_reduction = 0
    for pattern in patterns:
        if pattern.uses_dsp():
            dsp_count = dsp_count + 1
            lut_reduction = lut_reduction + (pattern.operand_width * pattern.term_count)
    if dsp_count == 0:
        return HwirOptPassResult.unchanged("dsp_inference", module, "patterns prefer LUT binding")
    return HwirOptPassResult.changed("dsp_inference", module, hwir_cost_with_resource_delta(module.cost, 0 - lut_reduction, 0, dsp_count, 0, 1), 0, 0, 0, 0, "bound multiply/MAC/dot-product patterns to DSP resources")
