# Correctness gate for the MIR bulk-op recognizers (SG-1.3).
#
# These recognizers (optimize_bulk_copy/fill/cmp) are ADVISORY: they insert a
# `bulk_*_hint` Intrinsic marker but KEEP every original Load/Store/GEP, so they
# are semantics-preserving by construction. This spec pins that invariant so that
# a future "landing" (wiring + backend lowering) cannot silently regress: the
# recognizer must emit exactly one hint AND preserve all original memory ops.
#
# Run:  bin/simple run src/compiler/60.mir_opt/bulk_ops_recognizer_spec.spl

use compiler.mir.mir_instructions.{
    MirFunction, MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind, BlockId
}
use compiler.mir.mir_types.{
    MirType, MirTypeKind, MirSignature, MirConstValue, LocalId
}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir_opt._OptimizationPasses.io_passes.{optimize_bulk_copy, count_bulk_copy}
use compiler.mir_opt.optimization_passes.{OptimizationStats}

fn _copy_op(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(LocalId(id: id)))

fn _const_idx(v: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(v), MirType(kind: MirTypeKind.I64)))

# Build a function whose single block copies two elements from base-local 10 to
# base-local 20 — the pattern the bulk-copy recognizer fires on (>= 2 copies).
fn _make_bulk_copy_function() -> MirFunction:
    val i64t = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64t, is_variadic: false)
    var insts: [MirInst] = []
    insts = insts.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 1), _copy_op(10), [_const_idx(0)]), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.Load(LocalId(id: 2), _copy_op(1)), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 3), _copy_op(20), [_const_idx(0)]), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.Store(_copy_op(3), _copy_op(2)), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 5), _copy_op(10), [_const_idx(1)]), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.Load(LocalId(id: 6), _copy_op(5)), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 7), _copy_op(20), [_const_idx(1)]), span: nil))
    insts = insts.push(MirInst(kind: MirInstKind.Store(_copy_op(7), _copy_op(6)), span: nil))
    val block = MirBlock(
        id: BlockId(id: 0), label: Some("bb0"),
        instructions: insts, terminator: MirTerminator.Ret(nil)
    )
    MirFunction(
        symbol: SymbolId.new(0), name: "bulk_copy_fn", signature: sig,
        locals: [], blocks: [block], entry_block: BlockId.new(0),
        span: nil, generic_params: [], is_generic_template: false,
        specialization_of: nil, type_bindings: {}
    )

fn _count_kind(func: MirFunction, which: text) -> i64:
    var n = 0
    var bi = 0
    while bi < func.blocks.len():
        val insts = func.blocks[bi].instructions
        var ii = 0
        while ii < insts.len():
            match insts[ii].kind:
                case GetElementPtr(_, _, _):
                    if which == "gep": n = n + 1
                case Load(_, _):
                    if which == "load": n = n + 1
                case Store(_, _):
                    if which == "store": n = n + 1
                case Intrinsic(_, nm, _):
                    if which == "hint" and nm == "bulk_copy_hint": n = n + 1
                case _:
                    pass
            ii = ii + 1
        bi = bi + 1
    n

describe "MIR bulk_copy recognizer — semantics-preserving gate (SG-1.3)":
    it "detects the bulk-copy pattern":
        val func = _make_bulk_copy_function()
        expect(count_bulk_copy(func)).to_equal(1)

    it "emits exactly one bulk_copy_hint marker":
        val func = _make_bulk_copy_function()
        val stats = OptimizationStats.create()
        val after = optimize_bulk_copy(func, stats)
        expect(_count_kind(after, "hint")).to_equal(1)

    it "preserves every original GEP / Load / Store (no op removed)":
        val func = _make_bulk_copy_function()
        val stats = OptimizationStats.create()
        val after = optimize_bulk_copy(func, stats)
        expect(_count_kind(after, "gep")).to_equal(4)
        expect(_count_kind(after, "load")).to_equal(2)
        expect(_count_kind(after, "store")).to_equal(2)

    it "is a no-op on a function without the pattern":
        val i64t = MirType(kind: MirTypeKind.I64)
        val sig = MirSignature(params: [], return_type: i64t, is_variadic: false)
        val empty_block = MirBlock(
            id: BlockId(id: 0), label: Some("bb0"),
            instructions: [], terminator: MirTerminator.Ret(nil)
        )
        val func = MirFunction(
            symbol: SymbolId.new(0), name: "empty_fn", signature: sig,
            locals: [], blocks: [empty_block], entry_block: BlockId.new(0),
            span: nil, generic_params: [], is_generic_template: false,
            specialization_of: nil, type_bindings: {}
        )
        expect(count_bulk_copy(func)).to_equal(0)
