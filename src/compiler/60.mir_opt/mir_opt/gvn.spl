# Global Value Numbering (GVN)
#
# Assigns value numbers to expressions and replaces redundant computations.
# Subsumes CSE for cross-block cases and handles algebraic identities.
#
# Algorithm:
# 1. Assign value numbers: same opcode + same operand value numbers = same VN
# 2. First occurrence of a VN is the "leader"
# 3. Subsequent occurrences are replaced with Copy from leader
#
# Example:
#   %a = BinOp(Add, %x, %y)   # VN=1, leader=%a
#   ... (other code) ...
#   %b = BinOp(Add, %x, %y)   # VN=1, redundant → replaced with Copy(%a)
#
# Handles:
# - Arithmetic expressions (BinOp, UnaryOp)
# - Field access (GetField)
# - Cast expressions
# - Commutative ops: Add(%x,%y) == Add(%y,%x)

use compiler.mir.mir_data.*
use compiler.mir.mir.*

# ============================================================================
# Value Numbering Table
# ============================================================================

class ValueNumberTable:
    """Maps expression signatures to value numbers and leader locals."""
    # expr_signature -> value_number
    sig_to_vn: Dict<text, i64>
    # local_id -> value_number
    local_to_vn: Dict<i64, i64>
    # value_number -> leader local_id (first computation)
    vn_to_leader: Dict<i64, i64>
    next_vn: i64

impl ValueNumberTable:
    static fn new() -> ValueNumberTable:
        ValueNumberTable(
            sig_to_vn: {},
            local_to_vn: {},
            vn_to_leader: {},
            next_vn: 0
        )

    me get_or_assign_vn(signature: text, local_id: i64) -> i64:
        """Get existing VN for signature, or assign new one."""
        if self.sig_to_vn.contains_key(signature):
            val vn = self.sig_to_vn[signature]
            self.local_to_vn[local_id] = vn
            return vn
        # New value number
        val vn = self.next_vn
        self.next_vn = self.next_vn + 1
        self.sig_to_vn[signature] = vn
        self.local_to_vn[local_id] = vn
        self.vn_to_leader[vn] = local_id
        vn

    fn get_local_vn(local_id: i64) -> i64:
        """Get value number for a local, or return -1 if not numbered."""
        if self.local_to_vn.contains_key(local_id):
            return self.local_to_vn[local_id]
        -1

    fn get_leader(vn: i64) -> i64:
        """Get leader local ID for a value number, or -1."""
        if self.vn_to_leader.contains_key(vn):
            return self.vn_to_leader[vn]
        -1

    fn is_redundant(signature: text, local_id: i64) -> bool:
        """Check if this expression already has a leader (i.e., is redundant)."""
        if self.sig_to_vn.contains_key(signature):
            val vn = self.sig_to_vn[signature]
            val leader = self.vn_to_leader[vn]
            return leader != local_id
        false

# ============================================================================
# GVN Pass
# ============================================================================

class GlobalValueNumbering:
    """
    GVN optimization pass.

    Replaces redundant computations with copies from the first computation.
    More powerful than CSE because it works across basic blocks and handles
    algebraic properties (commutativity, identity).
    """
    eliminated_expressions: i64
    analyzed_functions: i64

impl GlobalValueNumbering:
    static fn new() -> GlobalValueNumbering:
        GlobalValueNumbering(
            eliminated_expressions: 0,
            analyzed_functions: 0
        )

    fn name() -> text:
        "global_value_numbering"

    fn description() -> text:
        "Eliminates redundant computations via value numbering"

    fn is_analysis_pass() -> bool:
        false

    fn dependencies() -> [text]:
        ["constant_folding"]  # Run after const fold for best results

    me run_on_function(func: MirFunction) -> MirFunction:
        """
        Run GVN on a function.

        1. Walk all blocks in dominator order (approximated by block order)
        2. Assign value numbers to instructions
        3. Replace redundant instructions with copies
        """
        self.analyzed_functions = self.analyzed_functions + 1

        var vn_table = ValueNumberTable.new()

        # Process all blocks
        var new_blocks: [MirBlock] = []
        for block in func.blocks:
            val optimized = self.process_block(block, vn_table)
            new_blocks = new_blocks.push(optimized)

        MirFunction(..func, blocks: new_blocks)

    me process_block(block: MirBlock, vn_table: ValueNumberTable) -> MirBlock:
        """Process a single block — assign VNs and eliminate redundancy."""
        var new_insts: [MirInst] = []

        for inst in block.instructions:
            val result = self.process_instruction(inst, vn_table)
            new_insts = new_insts.push(result)

        MirBlock(
            id: block.id,
            label: block.label,
            instructions: new_insts,
            terminator: block.terminator
        )

    me process_instruction(inst: MirInst, vn_table: ValueNumberTable) -> MirInst:
        """Process one instruction — value number and optionally replace."""
        match inst.kind:
            case BinOp(dest, op, left, right):
                val sig = self.binop_signature(op, left, right, vn_table)
                if vn_table.is_redundant(sig, dest.id):
                    # Replace with copy from leader
                    val vn = vn_table.get_or_assign_vn(sig, dest.id)
                    val leader_id = vn_table.get_leader(vn)
                    self.eliminated_expressions = self.eliminated_expressions + 1
                    MirInst(
                        kind: Copy(dest, LocalId(id: leader_id)),
                        span: inst.span
                    )
                else:
                    vn_table.get_or_assign_vn(sig, dest.id)
                    inst

            case UnaryOp(dest, op, operand):
                val sig = self.unaryop_signature(op, operand, vn_table)
                if vn_table.is_redundant(sig, dest.id):
                    val vn = vn_table.get_or_assign_vn(sig, dest.id)
                    val leader_id = vn_table.get_leader(vn)
                    self.eliminated_expressions = self.eliminated_expressions + 1
                    MirInst(
                        kind: Copy(dest, LocalId(id: leader_id)),
                        span: inst.span
                    )
                else:
                    vn_table.get_or_assign_vn(sig, dest.id)
                    inst

            case GetField(dest, base, field):
                val sig = self.field_signature(base, field, vn_table)
                if vn_table.is_redundant(sig, dest.id):
                    val vn = vn_table.get_or_assign_vn(sig, dest.id)
                    val leader_id = vn_table.get_leader(vn)
                    self.eliminated_expressions = self.eliminated_expressions + 1
                    MirInst(
                        kind: Copy(dest, LocalId(id: leader_id)),
                        span: inst.span
                    )
                else:
                    vn_table.get_or_assign_vn(sig, dest.id)
                    inst

            case Cast(dest, value, type_):
                val sig = self.cast_signature(value, type_, vn_table)
                if vn_table.is_redundant(sig, dest.id):
                    val vn = vn_table.get_or_assign_vn(sig, dest.id)
                    val leader_id = vn_table.get_leader(vn)
                    self.eliminated_expressions = self.eliminated_expressions + 1
                    MirInst(
                        kind: Copy(dest, LocalId(id: leader_id)),
                        span: inst.span
                    )
                else:
                    vn_table.get_or_assign_vn(sig, dest.id)
                    inst

            case Const(dest, value, type_):
                # Constants get unique VN by their value
                val sig = "const:{value}"
                vn_table.get_or_assign_vn(sig, dest.id)
                inst

            case Copy(dest, src):
                # Copy gets same VN as source
                val src_vn = vn_table.get_local_vn(src.id)
                if src_vn >= 0:
                    vn_table.local_to_vn[dest.id] = src_vn
                inst

            case Move(dest, src):
                val src_vn = vn_table.get_local_vn(src.id)
                if src_vn >= 0:
                    vn_table.local_to_vn[dest.id] = src_vn
                inst

            case _:
                # Side-effectful or unknown — don't eliminate
                inst

    # ========================================================================
    # Signature Building
    # ========================================================================

    fn operand_vn(operand: MirOperand, vn_table: ValueNumberTable) -> text:
        """Get value number string for an operand."""
        match operand.kind:
            case Copy(src):
                val vn = vn_table.get_local_vn(src.id)
                if vn >= 0: "v{vn}" else: "l{src.id}"
            case Move(src):
                val vn = vn_table.get_local_vn(src.id)
                if vn >= 0: "v{vn}" else: "l{src.id}"
            case Constant(val_):
                "c:{val_}"

    fn binop_signature(op, left: MirOperand, right: MirOperand, vn_table: ValueNumberTable) -> text:
        """Build canonical signature for binary operation."""
        val lhs = self.operand_vn(left, vn_table)
        val rhs = self.operand_vn(right, vn_table)
        val op_name = "{op}"
        # Commutative ops: normalize operand order for more hits
        if self.is_commutative(op_name):
            if lhs > rhs:
                return "binop:{op_name}:{rhs}:{lhs}"
        "binop:{op_name}:{lhs}:{rhs}"

    fn unaryop_signature(op, operand: MirOperand, vn_table: ValueNumberTable) -> text:
        """Build signature for unary operation."""
        val opnd = self.operand_vn(operand, vn_table)
        "unaryop:{op}:{opnd}"

    fn field_signature(base: MirOperand, field, vn_table: ValueNumberTable) -> text:
        """Build signature for field access."""
        val b = self.operand_vn(base, vn_table)
        "field:{b}:{field}"

    fn cast_signature(value: MirOperand, type_, vn_table: ValueNumberTable) -> text:
        """Build signature for cast."""
        val v = self.operand_vn(value, vn_table)
        "cast:{v}:{type_}"

    fn is_commutative(op_name: text) -> bool:
        """Check if binary operator is commutative."""
        match op_name:
            case "Add": true
            case "Mul": true
            case "BitAnd": true
            case "BitOr": true
            case "BitXor": true
            case "Eq": true
            case "Ne": true
            case _: false

    fn stats_summary() -> text:
        "GVN: eliminated {self.eliminated_expressions} redundant expressions in {self.analyzed_functions} functions"

# ============================================================================
# Factory Function
# ============================================================================

fn create_gvn_pass() -> GlobalValueNumbering:
    GlobalValueNumbering.new()

fn gvn_run_on_function(pass: GlobalValueNumbering, func: MirFunction) -> MirFunction:
    pass.run_on_function(func)
