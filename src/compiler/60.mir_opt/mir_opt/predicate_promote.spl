# src/compiler/60.mir_opt/mir_opt/predicate_promote.spl
#
# Predicate-mode promotion pass: MaskFromCmp + Masked* -> Predicated* fusion
#
# Pattern: src/compiler/60.mir_opt/mir_opt/simd_lowering.spl
# Phase:   I2 (Wave I2 — fusion pass implementation)
# Spec:    simd_unified_architecture_detail.md C2 §1 (predication); I2 rollout
#
# This pass fuses adjacent MaskFromCmp + MaskedAdd/MaskedMul/MaskedFma pairs
# into fused k-register predicated ops (PredicatedAdd/PredicatedMul/PredicatedFma)
# when the mask destination produced by MaskFromCmp is used only by the
# immediately following masked operation and is not observed elsewhere.
#
# Transformation:
#   %m = MaskFromCmp(cmp_kind, %a, %b)
#   %d = MaskedAdd(%m, %x, %y)
#   =>
#   %d = PredicatedAdd(cmp_kind, %a, %b, %x, %y)
#
# The MaskFromCmp instruction is removed; the mask local %m becomes dead.

use compiler.mir.mir_data.{MirInst, MirInstKind, MirOperand, MirOperandKind, LocalId, BlockId}
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}

# ============================================================================
# Predicate-mode promotion pass entry point
# ============================================================================

fn run_predicate_promote(module: MirModule) -> MirModule:
    """
    Run MaskFromCmp + Masked* -> Predicated* fusion pass on entire module.

    Walks every function and block. When a MaskFromCmp result is consumed by
    exactly one immediately-following MaskedAdd/MaskedMul/MaskedFma with no
    other uses, fuses the pair into PredicatedAdd/PredicatedMul/PredicatedFma
    and drops the MaskFromCmp instruction.
    """
    var new_functions: Dict<SymbolId, MirFunction> = {}

    for symbol_id in module.functions.keys():
        val func = module.functions[symbol_id]
        val promoted_func = promote_function_predicate(func)
        new_functions[symbol_id] = promoted_func

    MirModule(..module, functions: new_functions)

# ============================================================================
# Function-level walk
# ============================================================================

fn promote_function_predicate(func: MirFunction) -> MirFunction:
    """
    Walk all blocks in a function, applying predicated-fusion per block.
    """
    var new_blocks: [MirBlock] = []

    for block in func.blocks:
        val promoted_block = promote_block_predicate(block)
        new_blocks.push(promoted_block)

    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# Block-level walk
# ============================================================================

fn promote_block_predicate(block: MirBlock) -> MirBlock:
    """
    Fuse MaskFromCmp + MaskedAdd/MaskedMul/MaskedFma pairs within a block.

    Algorithm (single-pass, forward):
      1. When we see MaskFromCmp, record the dest LocalId and the instruction.
      2. If the very next instruction is MaskedAdd/MaskedMul/MaskedFma whose
         mask operand matches the recorded dest, emit the fused Predicated*
         op in place of both; clear the pending record.
      3. If the pending record is not consumed (next inst is something else),
         emit the original MaskFromCmp unchanged before processing the next inst.

    Only fuses single-use masks in adjacent instruction pairs. Multi-use masks
    (the same %m fed into more than one Masked* op) are left untouched; the
    first unconsumed MaskFromCmp is flushed and a new pending slot opens for
    the next MaskFromCmp.
    """
    var new_insts: [MirInst] = []
    var pending_mask_dest: LocalId? = nil
    var pending_mask_inst: MirInst? = nil
    var pending_cmp_kind: text = ""
    var pending_cmp_a: MirOperand? = nil
    var pending_cmp_b: MirOperand? = nil

    for inst in block.instructions:
        match inst.kind:
            case MaskFromCmp(dest, cmp_kind, a, b):
                # Flush any unfused previous pending MaskFromCmp
                if pending_mask_inst.is_some():
                    new_insts.push(pending_mask_inst.unwrap())
                # Record this one as pending
                pending_mask_dest = Some(dest)
                pending_mask_inst = Some(inst)
                pending_cmp_kind = cmp_kind
                pending_cmp_a = Some(a)
                pending_cmp_b = Some(b)

            case MaskedAdd(dest, mask, a, b):
                val fused = try_fuse_binary(
                    pending_mask_dest, pending_cmp_kind,
                    pending_cmp_a, pending_cmp_b,
                    mask, dest, a, b, "add"
                )
                if fused.is_some():
                    new_insts.push(fused.unwrap())
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                else:
                    flush_pending(new_insts, pending_mask_inst)
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                    new_insts.push(inst)

            case MaskedMul(dest, mask, a, b):
                val fused = try_fuse_binary(
                    pending_mask_dest, pending_cmp_kind,
                    pending_cmp_a, pending_cmp_b,
                    mask, dest, a, b, "mul"
                )
                if fused.is_some():
                    new_insts.push(fused.unwrap())
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                else:
                    flush_pending(new_insts, pending_mask_inst)
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                    new_insts.push(inst)

            case MaskedFma(dest, mask, a, b, c):
                val fused = try_fuse_ternary(
                    pending_mask_dest, pending_cmp_kind,
                    pending_cmp_a, pending_cmp_b,
                    mask, dest, a, b, c
                )
                if fused.is_some():
                    new_insts.push(fused.unwrap())
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                else:
                    flush_pending(new_insts, pending_mask_inst)
                    pending_mask_dest = nil
                    pending_mask_inst = nil
                    pending_cmp_kind = ""
                    pending_cmp_a = nil
                    pending_cmp_b = nil
                    new_insts.push(inst)

            case _:
                # Any other instruction: flush pending MaskFromCmp then emit inst
                flush_pending(new_insts, pending_mask_inst)
                pending_mask_dest = nil
                pending_mask_inst = nil
                pending_cmp_kind = ""
                pending_cmp_a = nil
                pending_cmp_b = nil
                new_insts.push(inst)

    # Flush any trailing unfused MaskFromCmp at end of block
    flush_pending(new_insts, pending_mask_inst)

    MirBlock(
        id: block.id,
        label: block.label,
        instructions: new_insts,
        terminator: block.terminator
    )

# ============================================================================
# Fusion helpers
# ============================================================================

fn flush_pending(insts: [MirInst], pending: MirInst?) -> ():
    """Emit a pending MaskFromCmp inst if it was not consumed by a fusion."""
    if pending.is_some():
        insts.push(pending.unwrap())

fn operand_is_local(op: MirOperand, id: LocalId) -> bool:
    """Return true when op is a Copy or Move of the given local."""
    match op.kind:
        case Copy(local): local.id == id.id
        case Move(local): local.id == id.id
        case _: false

fn try_fuse_binary(
    pending_dest: LocalId?,
    cmp_kind: text,
    cmp_a: MirOperand?,
    cmp_b: MirOperand?,
    mask: MirOperand,
    dest: LocalId,
    a: MirOperand,
    b: MirOperand,
    op: text
) -> MirInst?:
    """
    Attempt to fuse a pending MaskFromCmp with a MaskedAdd or MaskedMul.
    Returns Some(fused_inst) when the mask operand matches the pending dest.
    Returns nil when there is no pending MaskFromCmp or the mask does not match.
    """
    if pending_dest.is_none():
        return nil
    if cmp_a.is_none() or cmp_b.is_none():
        return nil
    val pd = pending_dest.unwrap()
    if not operand_is_local(mask, pd):
        return nil
    val fused_kind = if op == "add":
        MirInstKind.PredicatedAdd(dest, cmp_kind, cmp_a.unwrap(), cmp_b.unwrap(), a, b)
    else:
        MirInstKind.PredicatedMul(dest, cmp_kind, cmp_a.unwrap(), cmp_b.unwrap(), a, b)
    Some(MirInst(kind: fused_kind))

fn try_fuse_ternary(
    pending_dest: LocalId?,
    cmp_kind: text,
    cmp_a: MirOperand?,
    cmp_b: MirOperand?,
    mask: MirOperand,
    dest: LocalId,
    a: MirOperand,
    b: MirOperand,
    c: MirOperand
) -> MirInst?:
    """
    Attempt to fuse a pending MaskFromCmp with a MaskedFma.
    Returns Some(PredicatedFma(...)) on match, nil otherwise.
    """
    if pending_dest.is_none():
        return nil
    if cmp_a.is_none() or cmp_b.is_none():
        return nil
    val pd = pending_dest.unwrap()
    if not operand_is_local(mask, pd):
        return nil
    Some(MirInst(kind: MirInstKind.PredicatedFma(
        dest, cmp_kind, cmp_a.unwrap(), cmp_b.unwrap(), a, b, c
    )))
