# src/compiler/60.mir_opt/mir_opt/predicate_promote.spl
#
# Predicate-mode promotion pass: MaskFromCmp + Masked* -> Predicated* fusion
#
# Pattern: src/compiler/60.mir_opt/mir_opt/simd_lowering.spl
# Phase:   I2 (Wave I2 — fusion pass implementation)
# Spec:    simd_unified_architecture_detail.md C2 §1 (predication); I2 rollout
#
# This pass fuses adjacent MaskFromCmp + MaskedAdd/MaskedMul/MaskedFma pairs
# into fused k-register predicated ops (PredicatedAdd/PredicatedMul/PredicatedFma)
# when the mask destination produced by MaskFromCmp is used by the immediately
# following masked operation.
#
# Transformation:
#   %m = MaskFromCmp(cmp_kind, %a, %b)
#   %d = MaskedAdd(%m, %x, %y)
#   =>
#   %d = PredicatedAdd(cmp_kind, %a, %b, %x, %y)
#
# The MaskFromCmp instruction is removed; the mask local %m becomes dead.

use compiler.mir.mir_data.{MirInst, MirInstKind, MirOperand, MirOperandKind, LocalId, BlockId}
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}

export run_predicate_promote
export promote_function_predicate, promote_block_predicate
export operand_is_local, try_fuse_binary, try_fuse_ternary

# ============================================================================
# Predicate-mode promotion pass entry point
# ============================================================================

fn run_predicate_promote(module: MirModule) -> MirModule:
    """
    Run MaskFromCmp + Masked* -> Predicated* fusion pass on entire module.

    Walks every function and block. When a MaskFromCmp result is consumed by
    exactly one immediately-following MaskedAdd/MaskedMul/MaskedFma, fuses the
    pair into PredicatedAdd/PredicatedMul/PredicatedFma and drops the MaskFromCmp.
    """
    var new_functions: Dict<SymbolId, MirFunction> = {}

    for func in module.functions.values():
        val promoted_func = promote_function_predicate(func)
        new_functions[promoted_func.symbol] = promoted_func

    MirModule(name: module.name, functions: new_functions, statics: module.statics, constants: module.constants, types: module.types)

# ============================================================================
# Function-level walk
# ============================================================================

fn promote_function_predicate(func: MirFunction) -> MirFunction:
    """Walk all blocks in a function, applying predicated-fusion per block."""
    var new_blocks: [MirBlock] = []

    for block in func.blocks:
        val promoted_block = promote_block_predicate(block)
        new_blocks.push(promoted_block)

    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# Block-level walk
# ============================================================================

fn promote_block_predicate(block: MirBlock) -> MirBlock:
    """
    Fuse MaskFromCmp + MaskedAdd/MaskedMul/MaskedFma pairs within a block.

    Algorithm (single-pass, forward):
      1. When we see MaskFromCmp, record dest LocalId + cmp fields as pending.
      2. If the very next instruction is MaskedAdd/MaskedMul/MaskedFma whose
         mask operand matches the pending dest, emit the fused Predicated* op
         in place of both and clear the pending record.
      3. If the pending record is not consumed (next inst is something else or
         the mask local does not match), flush the pending MaskFromCmp unchanged
         before processing the new instruction.

    Multi-use or non-adjacent MaskFromCmp instructions are preserved verbatim.
    """
    var new_insts: [MirInst] = []
    var i: i64 = 0

    while i < block.instructions.len():
        val inst = block.instructions[i]
        match inst.kind:
            case MaskFromCmp(mask_dest, cmp_kind, cmp_a, cmp_b):
                if i + 1 < block.instructions.len():
                    val next_inst = block.instructions[i + 1]
                    val fused = match next_inst.kind:
                        case MaskedAdd(dest, mask, a, b):
                            try_fuse_binary(Some(mask_dest), cmp_kind, Some(cmp_a), Some(cmp_b), mask, dest, a, b, "add")
                        case MaskedMul(dest, mask, a, b):
                            try_fuse_binary(Some(mask_dest), cmp_kind, Some(cmp_a), Some(cmp_b), mask, dest, a, b, "mul")
                        case MaskedFma(dest, mask, a, b, c):
                            try_fuse_ternary(Some(mask_dest), cmp_kind, Some(cmp_a), Some(cmp_b), mask, dest, a, b, c)
                        case _:
                            nil
                    if fused.?:
                        new_insts.push(fused.unwrap())
                        i = i + 2
                    else:
                        new_insts.push(inst)
                        i = i + 1
                else:
                    new_insts.push(inst)
                    i = i + 1

            case _:
                new_insts.push(inst)
                i = i + 1

    MirBlock(
        id: block.id,
        label: block.label,
        instructions: new_insts,
        terminator: block.terminator
    )

# ============================================================================
# Fusion helpers
# ============================================================================

fn operand_is_local(op: MirOperand, id: LocalId) -> bool:
    """Return true when op is a Copy or Move of the given local."""
    match op.kind:
        case Copy(local): local.id == id.id
        case Move(local): local.id == id.id
        case _: false

fn try_fuse_binary(
    pending_dest: LocalId?,
    cmp_kind: text,
    cmp_a: MirOperand?,
    cmp_b: MirOperand?,
    mask: MirOperand,
    dest: LocalId,
    a: MirOperand,
    b: MirOperand,
    op: text
) -> MirInst?:
    """
    Attempt to fuse a pending MaskFromCmp with a MaskedAdd or MaskedMul.
    Returns Some(fused_inst) when the mask operand matches the pending dest.
    Returns nil when there is no pending MaskFromCmp or the mask does not match.
    """
    if val pd = pending_dest:
        if val cmp_left = cmp_a:
            if val cmp_right = cmp_b:
                if not operand_is_local(mask, pd):
                    return nil
                val fused_kind = if op == "add":
                    MirInstKind.PredicatedAdd(dest, cmp_kind, cmp_left, cmp_right, a, b)
                else:
                    MirInstKind.PredicatedMul(dest, cmp_kind, cmp_left, cmp_right, a, b)
                Some(MirInst(kind: fused_kind))
            else:
                nil
        else:
            nil
    else:
        nil

fn try_fuse_ternary(
    pending_dest: LocalId?,
    cmp_kind: text,
    cmp_a: MirOperand?,
    cmp_b: MirOperand?,
    mask: MirOperand,
    dest: LocalId,
    a: MirOperand,
    b: MirOperand,
    c: MirOperand
) -> MirInst?:
    """
    Attempt to fuse a pending MaskFromCmp with a MaskedFma.
    Returns Some(PredicatedFma(...)) on match, nil otherwise.
    """
    if val pd = pending_dest:
        if val cmp_left = cmp_a:
            if val cmp_right = cmp_b:
                if not operand_is_local(mask, pd):
                    return nil
                Some(MirInst(kind: MirInstKind.PredicatedFma(
                    dest, cmp_kind, cmp_left, cmp_right, a, b, c
                )))
            else:
                nil
        else:
            nil
    else:
        nil
