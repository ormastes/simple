use compiler.mir.mir_instructions.{MirBlock, MirInst, MirInstKind, MirOperand, MirOperandKind, MirTerminator}
use compiler.mir.mir_types.{BlockId, LocalId, MirConstValue, MirType}
use compiler.interp.execution.tiered_jit.{JitHotspotSpecializationProvider, jit_hotspot_specialization_provider_from_analysis}
use compiler.mir_opt.mir_opt.pattern.rule_engine.{OptimizerBackendKind, optimization_backend_kind_from_text, optimization_backend_kind_name}
use compiler.mir_opt.mir_opt.var_reassign_analysis.{
    analyze_var_reassign_blocks,
    local_count_index,
    local_list_contains,
    local_list_push_unique,
    var_reassign_analysis_hotspot_facts,
    var_reassign_operand_local,
    var_reassign_written_local
}

extern fn rt_env_get(key: text) -> text

fn ssa_debug_enabled() -> bool:
    (rt_env_get("SIMPLE_BOOTSTRAP_DEBUG") ?? "") == "1"

struct SsaVarTransformResult:
    applied: bool
    reason: text
    blocks: [MirBlock]
    renamed_count: i64
    next_local_id: i64
    phi_required_count: i64
    phi_required_locals: [i64]

struct SsaPhiPlan:
    join_block_id: i64
    original_local_id: i64
    then_block_id: i64
    then_value_local_id: i64
    else_block_id: i64
    else_value_local_id: i64
    phi_dest_local_id: i64

struct SsaPhiMaterializeResult:
    applied: bool
    reason: text
    blocks: [MirBlock]
    phi_count: i64
    next_local_id: i64

enum SsaPhiLoweringKind:
    CraneliftBlockParam
    LlvmPhiNode
    InterpreterFallback
    Unsupported

struct SsaPhiLoweringPolicy:
    backend_name: text
    lowering_kind: SsaPhiLoweringKind
    can_lower: bool
    reason: text

fn ssa_phi_lowering_kind_name(kind: SsaPhiLoweringKind) -> text:
    match kind:
        case CraneliftBlockParam: "cranelift_block_param"
        case LlvmPhiNode: "llvm_phi_node"
        case InterpreterFallback: "interpreter_fallback"
        case Unsupported: "unsupported"

fn ssa_phi_normalize_backend_name(backend_name: text) -> text:
    val kind = optimization_backend_kind_from_text(backend_name)
    if kind == OptimizerBackendKind.Any:
        backend_name
    else:
        optimization_backend_kind_name(kind)

fn ssa_phi_lowering_policy_for_backend(backend_name: text) -> SsaPhiLoweringPolicy:
    val normalized = ssa_phi_normalize_backend_name(backend_name)
    if normalized == "cranelift":
        return SsaPhiLoweringPolicy(normalized, SsaPhiLoweringKind.CraneliftBlockParam, true, "lower_to_block_params")
    if normalized == "llvm":
        return SsaPhiLoweringPolicy(normalized, SsaPhiLoweringKind.LlvmPhiNode, true, "lower_to_phi_nodes")
    if normalized == "interpreter":
        return SsaPhiLoweringPolicy(normalized, SsaPhiLoweringKind.InterpreterFallback, true, "execute_pseudo_intrinsic_fallback")
    SsaPhiLoweringPolicy(normalized, SsaPhiLoweringKind.Unsupported, false, "backend_must_reject_pseudo_phi")

fn ssa_phi_backend_can_lower(backend_name: text) -> bool:
    ssa_phi_lowering_policy_for_backend(backend_name).can_lower

fn jit_hotspot_specialization_provider_from_var_reassign_analysis(
    name: text,
    specialized_source: text,
    blocks: [MirBlock],
    base_facts: [text]
) -> JitHotspotSpecializationProvider:
    val transform = ssa_var_transform_blocks(blocks)
    if not transform.applied:
        return jit_hotspot_specialization_provider_from_analysis(name, "", base_facts)
    val analysis = analyze_var_reassign_blocks(transform.blocks)
    val facts = var_reassign_analysis_hotspot_facts(base_facts, analysis)
    jit_hotspot_specialization_provider_from_analysis(name, specialized_source, facts)

fn ssa_local_map_get(keys: [i64], values: [i64], local_id: i64) -> i64:
    val idx = local_count_index(keys, local_id)
    if idx < 0:
        local_id
    else:
        values[idx]

fn ssa_local_map_set(keys: [i64], values: [i64], local_id: i64, latest_id: i64) -> ([i64], [i64]):
    val idx = local_count_index(keys, local_id)
    if idx < 0:
        (keys.push(local_id), values.push(latest_id))
    else:
        var updated: [i64] = []
        var i = 0
        while i < values.len():
            if i == idx:
                updated = updated.push(latest_id)
            else:
                updated = updated.push(values[i])
            i = i + 1
        (keys, updated)

fn ssa_local(local_id: i64) -> LocalId:
    LocalId(id: local_id)

fn ssa_local_id_value(local: LocalId) -> i64:
    match local:
        case LocalId(raw_id): raw_id
        case _: 0

fn ssa_block_id_value(block: BlockId) -> i64:
    match block:
        case BlockId(raw_id): raw_id
        case _: 0

fn ssa_rewrite_operand(operand: MirOperand, keys: [i64], values: [i64]) -> MirOperand:
    match operand.kind:
        case Copy(local):
            MirOperand(kind: MirOperandKind.Copy(ssa_local(ssa_local_map_get(keys, values, ssa_local_id_value(local)))))
        case Move(local):
            MirOperand(kind: MirOperandKind.Move(ssa_local(ssa_local_map_get(keys, values, ssa_local_id_value(local)))))
        case Const(value, type_):
            MirOperand(kind: MirOperandKind.Const(value, type_))

fn ssa_replace_operand_local(operand: MirOperand, original_id: i64, replacement_id: i64) -> MirOperand:
    match operand.kind:
        case Copy(local):
            if ssa_local_id_value(local) == original_id:
                MirOperand(kind: MirOperandKind.Copy(ssa_local(replacement_id)))
            else:
                operand
        case Move(local):
            if ssa_local_id_value(local) == original_id:
                MirOperand(kind: MirOperandKind.Move(ssa_local(replacement_id)))
            else:
                operand
        case Const(_, _):
            operand

fn ssa_max_local_from_operand(current: i64, operand: MirOperand) -> i64:
    val local = var_reassign_operand_local(operand)
    if local.?:
        val local_id = local.unwrap()
        if local_id > current:
            local_id
        else:
            current
    else:
        current

fn ssa_max_local_from_inst(current: i64, inst: MirInst) -> i64:
    var max_id = current
    val written = var_reassign_written_local(inst)
    if written.?:
        val written_id = written.unwrap()
        if written_id > max_id:
            max_id = written_id
    match inst.kind:
        case Copy(_, src):
            val src_id = ssa_local_id_value(src)
            if src_id > max_id:
                max_id = src_id
        case Move(_, src):
            val src_id = ssa_local_id_value(src)
            if src_id > max_id:
                max_id = src_id
        case BinOp(_, _, left, right):
            max_id = ssa_max_local_from_operand(max_id, left)
            max_id = ssa_max_local_from_operand(max_id, right)
        case UnaryOp(_, _, operand):
            max_id = ssa_max_local_from_operand(max_id, operand)
        case CheckedBinOp(_, _, left, right):
            max_id = ssa_max_local_from_operand(max_id, left)
            max_id = ssa_max_local_from_operand(max_id, right)
        case Load(_, ptr):
            max_id = ssa_max_local_from_operand(max_id, ptr)
        case Store(ptr, value):
            max_id = ssa_max_local_from_operand(max_id, ptr)
            max_id = ssa_max_local_from_operand(max_id, value)
        case GetElementPtr(_, base, indices):
            max_id = ssa_max_local_from_operand(max_id, base)
            for index in indices:
                max_id = ssa_max_local_from_operand(max_id, index)
        case Aggregate(_, _, operands):
            for operand in operands:
                max_id = ssa_max_local_from_operand(max_id, operand)
        case GetField(_, base, _):
            max_id = ssa_max_local_from_operand(max_id, base)
        case SetField(base, _, value):
            max_id = ssa_max_local_from_operand(max_id, base)
            max_id = ssa_max_local_from_operand(max_id, value)
        case Cast(_, operand, _):
            max_id = ssa_max_local_from_operand(max_id, operand)
        case Bitcast(_, operand, _):
            max_id = ssa_max_local_from_operand(max_id, operand)
        case Call(_, func, args):
            max_id = ssa_max_local_from_operand(max_id, func)
            for arg in args:
                max_id = ssa_max_local_from_operand(max_id, arg)
        case Intrinsic(_, _, args):
            for arg in args:
                max_id = ssa_max_local_from_operand(max_id, arg)
        case _:
            pass_do_nothing
    max_id

fn ssa_max_local_from_term(current: i64, term: MirTerminator) -> i64:
    match term:
        case Ret(value):
            if value.?:
                val ret_value = value.unwrap()
                ssa_max_local_from_operand(current, ret_value)
            else:
                current
        case If(cond, _, _):
            ssa_max_local_from_operand(current, cond)
        case Switch(value, _, _):
            ssa_max_local_from_operand(current, value)
        case CallTerminator(dest, func, args, _, _):
            var max_id = current
            if dest.?:
                val term_dest = dest.unwrap()
                val term_dest_id = ssa_local_id_value(term_dest)
                if term_dest_id > max_id:
                    max_id = term_dest_id
            max_id = ssa_max_local_from_operand(max_id, func)
            for arg in args:
                max_id = ssa_max_local_from_operand(max_id, arg)
            max_id
        case _:
            current

fn ssa_var_transform_inst_supported(inst: MirInst) -> bool:
    match inst.kind:
        case Const(_, _, _): true
        case Copy(_, _): true
        case Move(_, _): true
        case BinOp(_, _, _, _): true
        case UnaryOp(_, _, _): true
        case CheckedBinOp(_, _, _, _): true
        case Load(_, _): true
        case GetElementPtr(_, _, _): true
        case Aggregate(_, _, _): true
        case GetField(_, _, _): true
        case Cast(_, _, _): true
        case Bitcast(_, _, _): true
        case Nop: true
        case DebugValue(_, _): true
        case _: false

fn ssa_var_transform_term_supported(term: MirTerminator) -> bool:
    match term:
        case Ret(_): true
        case _: false

fn ssa_rewrite_dest(original_dest: LocalId, keys: [i64], values: [i64], next_local_id: i64) -> (LocalId, [i64], [i64], i64, bool):
    val original_id = ssa_local_id_value(original_dest)
    val seen = local_count_index(keys, original_id) >= 0
    val dest_id = if seen: next_local_id else: original_id
    val next_id = if seen: next_local_id + 1 else: next_local_id
    val next_map = ssa_local_map_set(keys, values, original_id, dest_id)
    (ssa_local(dest_id), next_map[0], next_map[1], next_id, seen)

fn ssa_rewrite_inst(inst: MirInst, keys: [i64], values: [i64], next_local_id: i64) -> (MirInst, [i64], [i64], i64, bool):
    match inst.kind:
        case Const(dest, value, type_):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.Const(next[0], value, type_), span: inst.span), next[1], next[2], next[3], next[4])
        case Copy(dest, src):
            val rewritten_src = ssa_local(ssa_local_map_get(keys, values, ssa_local_id_value(src)))
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.Copy(next[0], rewritten_src), span: inst.span), next[1], next[2], next[3], next[4])
        case Move(dest, src):
            val rewritten_src = ssa_local(ssa_local_map_get(keys, values, ssa_local_id_value(src)))
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.Move(next[0], rewritten_src), span: inst.span), next[1], next[2], next[3], next[4])
        case BinOp(dest, op, left, right):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            val new_left = ssa_rewrite_operand(left, keys, values)
            val new_right = ssa_rewrite_operand(right, keys, values)
            (MirInst(kind: MirInstKind.BinOp(next[0], op, new_left, new_right), span: inst.span), next[1], next[2], next[3], next[4])
        case UnaryOp(dest, op, operand):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            val new_operand = ssa_rewrite_operand(operand, keys, values)
            (MirInst(kind: MirInstKind.UnaryOp(next[0], op, new_operand), span: inst.span), next[1], next[2], next[3], next[4])
        case CheckedBinOp(dest, op, left, right):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            val new_left = ssa_rewrite_operand(left, keys, values)
            val new_right = ssa_rewrite_operand(right, keys, values)
            (MirInst(kind: MirInstKind.CheckedBinOp(next[0], op, new_left, new_right), span: inst.span), next[1], next[2], next[3], next[4])
        case Load(dest, ptr):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            val new_ptr = ssa_rewrite_operand(ptr, keys, values)
            (MirInst(kind: MirInstKind.Load(next[0], new_ptr), span: inst.span), next[1], next[2], next[3], next[4])
        case GetElementPtr(dest, base, indices):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            var new_indices: [MirOperand] = []
            for index in indices:
                new_indices = new_indices.push(ssa_rewrite_operand(index, keys, values))
            (MirInst(kind: MirInstKind.GetElementPtr(next[0], ssa_rewrite_operand(base, keys, values), new_indices), span: inst.span), next[1], next[2], next[3], next[4])
        case Aggregate(dest, kind, operands):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            var new_operands: [MirOperand] = []
            for operand in operands:
                new_operands = new_operands.push(ssa_rewrite_operand(operand, keys, values))
            (MirInst(kind: MirInstKind.Aggregate(next[0], kind, new_operands), span: inst.span), next[1], next[2], next[3], next[4])
        case GetField(dest, base, field):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.GetField(next[0], ssa_rewrite_operand(base, keys, values), field), span: inst.span), next[1], next[2], next[3], next[4])
        case Cast(dest, operand, target):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.Cast(next[0], ssa_rewrite_operand(operand, keys, values), target), span: inst.span), next[1], next[2], next[3], next[4])
        case Bitcast(dest, operand, target):
            val next = ssa_rewrite_dest(dest, keys, values, next_local_id)
            (MirInst(kind: MirInstKind.Bitcast(next[0], ssa_rewrite_operand(operand, keys, values), target), span: inst.span), next[1], next[2], next[3], next[4])
        case _:
            (inst, keys, values, next_local_id, false)

fn ssa_rewrite_term(term: MirTerminator, keys: [i64], values: [i64]) -> MirTerminator:
    match term:
        case Ret(value):
            if value.?:
                val ret_value = value.unwrap()
                MirTerminator.Ret(Some(ssa_rewrite_operand(ret_value, keys, values)))
            else:
                term
        case _:
            term

fn ssa_replace_inst_dest_for_local(inst: MirInst, original_id: i64, replacement_id: i64) -> MirInst:
    match inst.kind:
        case Const(dest, value, type_):
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Const(ssa_local(replacement_id), value, type_), span: inst.span)
            else:
                inst
        case Copy(dest, src):
            val new_src = ssa_replace_operand_local(MirOperand(kind: MirOperandKind.Copy(src)), original_id, replacement_id)
            val rewritten_src = match new_src.kind:
                case Copy(local): local
                case _: src
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Copy(ssa_local(replacement_id), rewritten_src), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Copy(dest, rewritten_src), span: inst.span)
        case Move(dest, src):
            val new_src = ssa_replace_operand_local(MirOperand(kind: MirOperandKind.Move(src)), original_id, replacement_id)
            val rewritten_src = match new_src.kind:
                case Move(local): local
                case _: src
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Move(ssa_local(replacement_id), rewritten_src), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Move(dest, rewritten_src), span: inst.span)
        case BinOp(dest, op, left, right):
            val new_left = ssa_replace_operand_local(left, original_id, replacement_id)
            val new_right = ssa_replace_operand_local(right, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.BinOp(ssa_local(replacement_id), op, new_left, new_right), span: inst.span)
            else:
                MirInst(kind: MirInstKind.BinOp(dest, op, new_left, new_right), span: inst.span)
        case UnaryOp(dest, op, operand):
            val new_operand = ssa_replace_operand_local(operand, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.UnaryOp(ssa_local(replacement_id), op, new_operand), span: inst.span)
            else:
                MirInst(kind: MirInstKind.UnaryOp(dest, op, new_operand), span: inst.span)
        case CheckedBinOp(dest, op, left, right):
            val new_left = ssa_replace_operand_local(left, original_id, replacement_id)
            val new_right = ssa_replace_operand_local(right, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.CheckedBinOp(ssa_local(replacement_id), op, new_left, new_right), span: inst.span)
            else:
                MirInst(kind: MirInstKind.CheckedBinOp(dest, op, new_left, new_right), span: inst.span)
        case Load(dest, ptr):
            val new_ptr = ssa_replace_operand_local(ptr, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Load(ssa_local(replacement_id), new_ptr), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Load(dest, new_ptr), span: inst.span)
        case GetElementPtr(dest, base, indices):
            val new_base = ssa_replace_operand_local(base, original_id, replacement_id)
            var new_indices: [MirOperand] = []
            for index in indices:
                new_indices = new_indices.push(ssa_replace_operand_local(index, original_id, replacement_id))
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.GetElementPtr(ssa_local(replacement_id), new_base, new_indices), span: inst.span)
            else:
                MirInst(kind: MirInstKind.GetElementPtr(dest, new_base, new_indices), span: inst.span)
        case Aggregate(dest, kind, operands):
            var new_operands: [MirOperand] = []
            for operand in operands:
                new_operands = new_operands.push(ssa_replace_operand_local(operand, original_id, replacement_id))
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Aggregate(ssa_local(replacement_id), kind, new_operands), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Aggregate(dest, kind, new_operands), span: inst.span)
        case GetField(dest, base, field):
            val new_base = ssa_replace_operand_local(base, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.GetField(ssa_local(replacement_id), new_base, field), span: inst.span)
            else:
                MirInst(kind: MirInstKind.GetField(dest, new_base, field), span: inst.span)
        case Cast(dest, operand, target):
            val new_operand = ssa_replace_operand_local(operand, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Cast(ssa_local(replacement_id), new_operand, target), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Cast(dest, new_operand, target), span: inst.span)
        case Bitcast(dest, operand, target):
            val new_operand = ssa_replace_operand_local(operand, original_id, replacement_id)
            if ssa_local_id_value(dest) == original_id:
                MirInst(kind: MirInstKind.Bitcast(ssa_local(replacement_id), new_operand, target), span: inst.span)
            else:
                MirInst(kind: MirInstKind.Bitcast(dest, new_operand, target), span: inst.span)
        case _:
            inst

fn ssa_replace_inst_operands_for_local(inst: MirInst, original_id: i64, replacement_id: i64) -> MirInst:
    match inst.kind:
        case BinOp(dest, op, left, right):
            MirInst(kind: MirInstKind.BinOp(dest, op, ssa_replace_operand_local(left, original_id, replacement_id), ssa_replace_operand_local(right, original_id, replacement_id)), span: inst.span)
        case UnaryOp(dest, op, operand):
            MirInst(kind: MirInstKind.UnaryOp(dest, op, ssa_replace_operand_local(operand, original_id, replacement_id)), span: inst.span)
        case CheckedBinOp(dest, op, left, right):
            MirInst(kind: MirInstKind.CheckedBinOp(dest, op, ssa_replace_operand_local(left, original_id, replacement_id), ssa_replace_operand_local(right, original_id, replacement_id)), span: inst.span)
        case Load(dest, ptr):
            MirInst(kind: MirInstKind.Load(dest, ssa_replace_operand_local(ptr, original_id, replacement_id)), span: inst.span)
        case GetElementPtr(dest, base, indices):
            var new_indices: [MirOperand] = []
            for index in indices:
                new_indices = new_indices.push(ssa_replace_operand_local(index, original_id, replacement_id))
            MirInst(kind: MirInstKind.GetElementPtr(dest, ssa_replace_operand_local(base, original_id, replacement_id), new_indices), span: inst.span)
        case Aggregate(dest, kind, operands):
            var new_operands: [MirOperand] = []
            for operand in operands:
                new_operands = new_operands.push(ssa_replace_operand_local(operand, original_id, replacement_id))
            MirInst(kind: MirInstKind.Aggregate(dest, kind, new_operands), span: inst.span)
        case GetField(dest, base, field):
            MirInst(kind: MirInstKind.GetField(dest, ssa_replace_operand_local(base, original_id, replacement_id), field), span: inst.span)
        case Cast(dest, operand, target):
            MirInst(kind: MirInstKind.Cast(dest, ssa_replace_operand_local(operand, original_id, replacement_id), target), span: inst.span)
        case Bitcast(dest, operand, target):
            MirInst(kind: MirInstKind.Bitcast(dest, ssa_replace_operand_local(operand, original_id, replacement_id), target), span: inst.span)
        case Intrinsic(dest, name, args):
            var new_args: [MirOperand] = []
            for arg in args:
                new_args = new_args.push(ssa_replace_operand_local(arg, original_id, replacement_id))
            MirInst(kind: MirInstKind.Intrinsic(dest, name, new_args), span: inst.span)
        case _:
            inst

fn ssa_replace_term_operands_for_local(term: MirTerminator, original_id: i64, replacement_id: i64) -> MirTerminator:
    match term:
        case Ret(value):
            if value.?:
                val ret_value = value.unwrap()
                MirTerminator.Ret(Some(ssa_replace_operand_local(ret_value, original_id, replacement_id)))
            else:
                term
        case If(cond, then_, else_):
            MirTerminator.If(ssa_replace_operand_local(cond, original_id, replacement_id), then_, else_)
        case Switch(value, targets, default):
            MirTerminator.Switch(ssa_replace_operand_local(value, original_id, replacement_id), targets, default)
        case _:
            term

fn ssa_block_by_id(blocks: [MirBlock], id: i64) -> MirBlock?:
    for block in blocks:
        if ssa_block_id_value(block.id) == id:
            return Some(block)
    nil

fn ssa_block_written_locals(block: MirBlock) -> [i64]:
    var locals: [i64] = []
    for inst in block.instructions:
        val written = var_reassign_written_local(inst)
        if written.?:
            val written_id = written.unwrap()
            locals = local_list_push_unique(locals, written_id)
    locals

fn ssa_common_locals(left: [i64], right: [i64]) -> [i64]:
    var shared_locals: [i64] = []
    for local_id in left:
        if local_list_contains(right, local_id):
            shared_locals = local_list_push_unique(shared_locals, local_id)
    shared_locals

fn ssa_phi_required_locals_for_blocks(blocks: [MirBlock]) -> [i64]:
    if blocks.len() < 4:
        return []
    var required: [i64] = []
    for entry in blocks:
        match entry.terminator:
            case If(_, then_block, else_block):
                val then_opt = ssa_block_by_id(blocks, ssa_block_id_value(then_block))
                val else_opt = ssa_block_by_id(blocks, ssa_block_id_value(else_block))
                if then_opt.?:
                    val then_body = then_opt.unwrap()
                    if else_opt.?:
                        val else_body = else_opt.unwrap()
                        match then_body.terminator:
                            case Goto(then_join):
                                match else_body.terminator:
                                    case Goto(else_join):
                                        if ssa_block_id_value(then_join) == ssa_block_id_value(else_join):
                                            val locals = ssa_common_locals(ssa_block_written_locals(then_body), ssa_block_written_locals(else_body))
                                            for local_id in locals:
                                                required = local_list_push_unique(required, local_id)
                                    case _:
                                        pass_do_nothing
                            case _:
                                pass_do_nothing
            case _:
                pass_do_nothing
    required

fn ssa_append_phi_plans_for_if(blocks: [MirBlock], then_block: BlockId, else_block: BlockId, next_local_start: i64, plans_in: [SsaPhiPlan]) -> ([SsaPhiPlan], i64):
    var plans = plans_in
    var next_local = next_local_start
    val then_opt = ssa_block_by_id(blocks, ssa_block_id_value(then_block))
    val else_opt = ssa_block_by_id(blocks, ssa_block_id_value(else_block))
    if then_opt.?:
        val then_body = then_opt.unwrap()
        if else_opt.?:
            val else_body = else_opt.unwrap()
            match then_body.terminator:
                case Goto(then_join):
                    match else_body.terminator:
                        case Goto(else_join):
                            if ssa_block_id_value(then_join) != ssa_block_id_value(else_join):
                                return (plans, next_local)
                            val locals = ssa_common_locals(ssa_block_written_locals(then_body), ssa_block_written_locals(else_body))
                            for local_id in locals:
                                val then_value = next_local
                                val else_value = next_local + 1
                                val phi_dest = next_local + 2
                                plans = plans.push(SsaPhiPlan(
                                    join_block_id: ssa_block_id_value(then_join),
                                    original_local_id: local_id,
                                    then_block_id: ssa_block_id_value(then_block),
                                    then_value_local_id: then_value,
                                    else_block_id: ssa_block_id_value(else_block),
                                    else_value_local_id: else_value,
                                    phi_dest_local_id: phi_dest
                                ))
                                next_local = next_local + 3
                        case _:
                            pass_do_nothing
                case _:
                    pass_do_nothing
    (plans, next_local)

fn ssa_max_local_from_blocks(blocks: [MirBlock]) -> i64:
    var max_local = -1
    for block in blocks:
        for inst in block.instructions:
            max_local = ssa_max_local_from_inst(max_local, inst)
        max_local = ssa_max_local_from_term(max_local, block.terminator)
    max_local

fn ssa_phi_plans_for_blocks(blocks: [MirBlock]) -> [SsaPhiPlan]:
    if blocks.len() < 4:
        return []
    var plans: [SsaPhiPlan] = []
    var next_local = ssa_max_local_from_blocks(blocks) + 1
    for block in blocks:
        match block.terminator:
            case If(_, then_block, else_block):
                val appended = ssa_append_phi_plans_for_if(blocks, then_block, else_block, next_local, plans)
                plans = appended[0]
                next_local = appended[1]
            case _:
                pass_do_nothing
    plans

fn ssa_phi_instruction(plan: SsaPhiPlan) -> MirInst:
    MirInst(
        kind: MirInstKind.Intrinsic(
            Some(ssa_local(plan.phi_dest_local_id)),
            "__simple_ssa_phi",
            [
                MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(plan.then_block_id), MirType.i64())),
                MirOperand(kind: MirOperandKind.Copy(ssa_local(plan.then_value_local_id))),
                MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(plan.else_block_id), MirType.i64())),
                MirOperand(kind: MirOperandKind.Copy(ssa_local(plan.else_value_local_id)))
            ]
        ),
        span: nil
    )

fn ssa_instructions_supported_for_phi(blocks: [MirBlock]) -> bool:
    for block in blocks:
        for inst in block.instructions:
            if not ssa_var_transform_inst_supported(inst):
                return false
    true

fn ssa_apply_phi_plan_to_block(block: MirBlock, plan: SsaPhiPlan) -> MirBlock:
    if ssa_block_id_value(block.id) == plan.then_block_id:
        var new_insts: [MirInst] = []
        for inst in block.instructions:
            new_insts = new_insts.push(ssa_replace_inst_dest_for_local(inst, plan.original_local_id, plan.then_value_local_id))
        return MirBlock(id: block.id, label: block.label, instructions: new_insts, terminator: block.terminator)
    if ssa_block_id_value(block.id) == plan.else_block_id:
        var new_insts: [MirInst] = []
        for inst in block.instructions:
            new_insts = new_insts.push(ssa_replace_inst_dest_for_local(inst, plan.original_local_id, plan.else_value_local_id))
        return MirBlock(id: block.id, label: block.label, instructions: new_insts, terminator: block.terminator)
    if ssa_block_id_value(block.id) == plan.join_block_id:
        var join_insts: [MirInst] = [ssa_phi_instruction(plan)]
        for inst in block.instructions:
            join_insts = join_insts.push(ssa_replace_inst_operands_for_local(inst, plan.original_local_id, plan.phi_dest_local_id))
        val new_term = ssa_replace_term_operands_for_local(block.terminator, plan.original_local_id, plan.phi_dest_local_id)
        return MirBlock(id: block.id, label: block.label, instructions: join_insts, terminator: new_term)
    block

fn ssa_apply_phi_plan(blocks: [MirBlock], plan: SsaPhiPlan) -> [MirBlock]:
    var result: [MirBlock] = []
    for block in blocks:
        result = result.push(ssa_apply_phi_plan_to_block(block, plan))
    result

fn ssa_materialize_phi_plans_for_blocks(blocks: [MirBlock]) -> SsaPhiMaterializeResult:
    val plans = ssa_phi_plans_for_blocks(blocks)
    if plans.len() == 0:
        return SsaPhiMaterializeResult(false, "no phi plan", blocks, 0, ssa_max_local_from_blocks(blocks) + 1)
    var rewritten = blocks
    var max_next = ssa_max_local_from_blocks(blocks) + 1
    for plan in plans:
        rewritten = ssa_apply_phi_plan(rewritten, plan)
        if plan.phi_dest_local_id >= max_next:
            max_next = plan.phi_dest_local_id + 1
    SsaPhiMaterializeResult(true, "ready", rewritten, plans.len(), max_next)

fn ssa_var_transform_reject(reason: text, blocks: [MirBlock], phi_locals: [i64]) -> SsaVarTransformResult:
    SsaVarTransformResult(false, reason, blocks, 0, 0, phi_locals.len(), phi_locals)

fn ssa_var_transform_blocks(blocks: [MirBlock]) -> SsaVarTransformResult:
    if blocks.len() != 1:
        val phi_locals = ssa_phi_required_locals_for_blocks(blocks)
        if ssa_debug_enabled():
            print "[ssa-var] blocks={blocks.len()} phi_locals={phi_locals.len()}"
        if phi_locals.len() > 0:
            val analysis = analyze_var_reassign_blocks(blocks)
            if not analysis.ssa_transform_safe and analysis.reason != "escape.reassigned_storage":
                return ssa_var_transform_reject(analysis.reason, blocks, phi_locals)
            if not ssa_instructions_supported_for_phi(blocks):
                return ssa_var_transform_reject("unsupported instruction", blocks, phi_locals)
            val materialized = ssa_materialize_phi_plans_for_blocks(blocks)
            if ssa_debug_enabled():
                print "[ssa-var] materialized applied={materialized.applied} phi={materialized.phi_count} reason={materialized.reason}"
            if materialized.applied:
                val materialized_analysis = analyze_var_reassign_blocks(materialized.blocks)
                if not materialized_analysis.ssa_transform_safe:
                    return ssa_var_transform_reject(materialized_analysis.reason, blocks, phi_locals)
                return SsaVarTransformResult(true, "ready", materialized.blocks, materialized.phi_count, materialized.next_local_id, 0, [])
            return ssa_var_transform_reject(materialized.reason, blocks, phi_locals)
        return ssa_var_transform_reject("unsupported cfg", blocks, [])
    val analysis = analyze_var_reassign_blocks(blocks)
    if not analysis.has_var_reassignment:
        return ssa_var_transform_reject("no var reassignment", blocks, [])
    if not analysis.ssa_transform_safe:
        return ssa_var_transform_reject(analysis.reason, blocks, [])
    val block = blocks[0]
    if not ssa_var_transform_term_supported(block.terminator):
        return ssa_var_transform_reject("requires phi nodes", blocks, [])
    var max_local = -1
    for inst in block.instructions:
        if not ssa_var_transform_inst_supported(inst):
            return ssa_var_transform_reject("unsupported instruction", blocks, [])
        max_local = ssa_max_local_from_inst(max_local, inst)
    max_local = ssa_max_local_from_term(max_local, block.terminator)

    var keys: [i64] = []
    var values: [i64] = []
    var next_local_id = max_local + 1
    var renamed_count = 0
    var rewritten_insts: [MirInst] = []
    for inst in block.instructions:
        val rewritten = ssa_rewrite_inst(inst, keys, values, next_local_id)
        rewritten_insts = rewritten_insts.push(rewritten[0])
        keys = rewritten[1]
        values = rewritten[2]
        next_local_id = rewritten[3]
        if rewritten[4]:
            renamed_count = renamed_count + 1

    val rewritten_block = MirBlock(
        id: block.id,
        label: block.label,
        instructions: rewritten_insts,
        terminator: ssa_rewrite_term(block.terminator, keys, values)
    )
    SsaVarTransformResult(true, "ready", [rewritten_block], renamed_count, next_local_id, 0, [])
