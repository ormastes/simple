# Target Profitability — L4 Profitability Layer
#
# Scores whether a target-specific rewrite is profitable.

use compiler.mir_opt.mir_opt.instruction_family.{InstructionFamily}
use compiler.mir_opt.mir_opt.target_family.{TargetFeatureSet}

# ============================================================================
# Profitability scoring
# ============================================================================

pub fn profitability_score(family: InstructionFamily, features: TargetFeatureSet) -> i64:
    """Return a profitability score for applying a family's rewrite.

    Positive scores are profitable; zero or negative are not.
    Score is based on family cost (lower is cheaper rewrite = more profitable),
    and opt_level (higher opt = more aggressive).
    """
    # Base profit: inverse of cost, scaled by opt level
    val base = 10 - family.cost
    val level_bonus = features.opt_level
    base + level_bonus

pub fn should_rewrite(score: i64) -> bool:
    """True if the profitability score exceeds the rewrite threshold."""
    score > 0
