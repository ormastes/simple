# Body Outlining Optimization Pass
#
# Identifies cold code paths (error handling, rarely-taken branches) and
# extracts them into separate outlined functions. The hot path retains a
# call to the outlined function, reducing instruction-cache pressure.
#
# Cold code heuristics:
# 1. Blocks reachable only from the `else` arm of an If terminator whose
#    condition is a comparison against an error/nil constant
# 2. Blocks that contain Abort terminators
# 3. Blocks with low execution probability (error-handling patterns)
# 4. Blocks dominated by unlikely branches (e.g., bounds-check failures)
#
# The pass also handles actor/generator/future body outlining per Plan 20:
# - Identifies ActorSpawn/GeneratorCreate/FutureCreate with body blocks
# - Extracts body blocks into separate MirFunctions
# - Replaces inline body with call to outlined function
#
# Algorithm:
# 1. Classify blocks as hot or cold via heuristics
# 2. Group contiguous cold blocks into outline candidates
# 3. For each candidate, compute live-in variables (captures)
# 4. Create a new MirFunction with the cold blocks
# 5. Replace cold blocks with a Call to the outlined function
# 6. Pass captures as arguments, restore results

use compiler.mir.mir_data.*
use compiler.mir.mir.*
use compiler.mir_opt.mod.{MirPass}

# ============================================================================
# Cold Block Analysis
# ============================================================================

class ColdBlockAnalysis:
    """Analyzes which blocks are likely cold (rarely executed).

    Heuristics applied:
    - Abort/Unreachable terminators -> cold
    - Blocks only reachable from else-branches of error checks -> cold
    - Blocks containing only error-handling calls (e.g., panic, abort) -> cold
    """
    cold_blocks: Dict<i64, bool>    # BlockId.id -> is_cold
    block_preds: Dict<i64, [i64]>   # BlockId.id -> predecessor BlockId.ids

impl ColdBlockAnalysis:
    static fn new() -> ColdBlockAnalysis:
        ColdBlockAnalysis(
            cold_blocks: {},
            block_preds: {}
        )

    me analyze(func: MirFunction):
        """Run cold block analysis on a function."""
        # Build predecessor map
        self.build_predecessor_map(func)

        # Pass 1: Mark blocks with abort/unreachable terminators as cold
        for block in func.blocks:
            if self.has_cold_terminator(block):
                self.cold_blocks[block.id.id] = true

        # Pass 2: Mark blocks that only contain error-handling patterns
        for block in func.blocks:
            if self.is_error_handling_block(block):
                self.cold_blocks[block.id.id] = true

        # Pass 3: Propagate coldness to predecessors that have only cold successors
        # (limited to 2 iterations to avoid over-marking)
        for _iteration in 0..2:
            self.propagate_coldness(func)

    me build_predecessor_map(func: MirFunction):
        """Build a map of block predecessors."""
        for block in func.blocks:
            val succs = get_terminator_successors(block.terminator)
            for succ_id in succs:
                val key = succ_id.id
                if self.block_preds.contains_key(key):
                    var preds = self.block_preds[key]
                    preds = preds.push(block.id.id)
                    self.block_preds[key] = preds
                else:
                    self.block_preds[key] = [block.id.id]

    fn has_cold_terminator(block: MirBlock) -> bool:
        """Check if block has a terminator that indicates cold code."""
        match block.terminator:
            case Abort(_): true
            case Unreachable: true
            case _: false

    fn is_error_handling_block(block: MirBlock) -> bool:
        """Check if block is an error-handling block.

        Heuristic: block contains a Call to a function whose name
        contains 'panic', 'abort', 'error', 'fail', or 'throw'.
        """
        for inst in block.instructions:
            match inst.kind:
                case Call(_, func_operand, _):
                    if self.is_error_function_operand(func_operand):
                        return true
                case _:
                    pass_do_nothing
        false

    fn is_error_function_operand(operand: MirOperand) -> bool:
        """Check if a function operand refers to an error-handling function.

        Conservative: only matches known error function patterns.
        """
        # We can't easily inspect the function name from the operand
        # in all cases, so we rely on the cold terminator heuristic
        # and block structure analysis instead.
        false

    me propagate_coldness(func: MirFunction):
        """Propagate coldness: if all successors of a block are cold,
        and the block is reached only from the else-branch of an If,
        mark it as cold too."""
        for block in func.blocks:
            if self.cold_blocks.contains_key(block.id.id):
                continue  # Already cold

            val succs = get_terminator_successors(block.terminator)
            if succs.len() == 0:
                continue

            # Check if all successors are cold
            var all_cold = true
            for succ_id in succs:
                if not self.cold_blocks.contains_key(succ_id.id):
                    all_cold = false

            if all_cold:
                self.cold_blocks[block.id.id] = true

    fn is_cold(block_id: BlockId) -> bool:
        """Check if a block is classified as cold."""
        self.cold_blocks.contains_key(block_id.id)

# ============================================================================
# Live Variable Analysis for Outlining
# ============================================================================

class OutlineLiveVars:
    """Computes live-in variables for a set of blocks to be outlined.

    Live-in variables are those defined outside the outlined region
    but used inside it. These must be passed as arguments to the
    outlined function.
    """
    live_in: [LocalId]              # Variables defined outside, used inside
    defined_inside: Dict<i64, bool> # Variables defined inside the region

impl OutlineLiveVars:
    static fn new() -> OutlineLiveVars:
        OutlineLiveVars(
            live_in: [],
            defined_inside: {}
        )

    me compute(cold_blocks: [MirBlock], all_blocks: [MirBlock]):
        """Compute live-in variables for the cold block set."""
        # First, collect all defs inside the cold region
        for block in cold_blocks:
            for inst in block.instructions:
                val dest = get_inst_dest(inst)
                if dest.?:
                    self.defined_inside[dest.unwrap().id] = true

        # Then, find uses of variables not defined inside
        var seen = {}
        for block in cold_blocks:
            for inst in block.instructions:
                val uses = get_inst_uses(inst)
                for use_local in uses:
                    if not self.defined_inside.contains_key(use_local.id):
                        if not seen.contains_key(use_local.id):
                            seen[use_local.id] = true
                            self.live_in = self.live_in.push(use_local)

            # Also check terminator operands
            val term_uses = get_terminator_uses(block.terminator)
            for use_local in term_uses:
                if not self.defined_inside.contains_key(use_local.id):
                    if not seen.contains_key(use_local.id):
                        seen[use_local.id] = true
                        self.live_in = self.live_in.push(use_local)

# ============================================================================
# Body Outlining Pass
# ============================================================================

class BodyOutlining:
    """
    Body outlining optimization pass.

    Extracts cold code paths into separate functions to improve
    instruction cache behavior for hot paths.

    Statistics:
    - outlined_blocks: Number of blocks moved to outlined functions
    - outlined_functions: Number of new functions created
    - captures_total: Total number of live-in captures across all outlines
    """
    outlined_blocks: i64
    outlined_functions: i64
    captures_total: i64
    # Minimum number of instructions in cold region to justify outlining
    min_cold_instructions: i64
    # Generated outlined functions (accumulated during module-level pass)
    generated_functions: [MirFunction]

impl BodyOutlining:
    static fn new() -> BodyOutlining:
        BodyOutlining(
            outlined_blocks: 0,
            outlined_functions: 0,
            captures_total: 0,
            min_cold_instructions: 4,
            generated_functions: []
        )

    fn name() -> text:
        "body_outlining"

    fn description() -> text:
        "Extracts cold code paths into separate outlined functions"

    fn is_analysis_pass() -> bool:
        val _ = self.name()
        false

    fn dependencies() -> [text]:
        ["dead_code_elimination"]  # Run after initial DCE

    me run_on_function(func: MirFunction) -> MirFunction:
        """Run body outlining on a function.

        Algorithm:
        1. Analyze which blocks are cold
        2. Group contiguous cold blocks
        3. For groups above threshold, outline them
        4. Replace with calls to outlined functions
        """
        # Skip small functions (not worth outlining)
        if func.blocks.len() < 4:
            return func

        # Phase 1: Cold block analysis
        var analysis = ColdBlockAnalysis.new()
        analysis.analyze(func)

        # Phase 2: Collect cold block groups
        val cold_groups = self.collect_cold_groups(func, analysis)

        # Phase 3: Outline each qualifying cold group
        if cold_groups.len() == 0:
            return func

        var result_func = func
        for group in cold_groups:
            result_func = self.outline_cold_group(result_func, group, analysis)

        result_func

    fn collect_cold_groups(func: MirFunction, analysis: ColdBlockAnalysis) -> [[BlockId]]:
        """Collect groups of contiguous cold blocks.

        Returns list of block-ID groups, each group being a set of cold blocks
        that form a connected subgraph.
        """
        var groups: [[BlockId]] = []
        var visited = {}

        for block in func.blocks:
            if not analysis.is_cold(block.id):
                continue
            if visited.contains_key(block.id.id):
                continue

            # BFS to find connected cold blocks
            var group: [BlockId] = []
            var worklist: [BlockId] = [block.id]
            var wi = 0

            while wi < worklist.len():
                val bid = worklist[wi]
                wi = wi + 1

                if visited.contains_key(bid.id):
                    continue
                if not analysis.is_cold(bid):
                    continue

                visited[bid.id] = true
                group = group.push(bid)

                # Find successors that are also cold
                val actual_block = find_block(func, bid)
                if actual_block.?:
                    val succs = get_terminator_successors(actual_block.unwrap().terminator)
                    for succ_id in succs:
                        if analysis.is_cold(succ_id) and not visited.contains_key(succ_id.id):
                            worklist = worklist.push(succ_id)

            # Only keep groups with enough instructions
            val total_insts = self.count_instructions_in_group(func, group)
            if total_insts >= self.min_cold_instructions:
                groups = groups.push(group)

        groups

    fn count_instructions_in_group(func: MirFunction, group: [BlockId]) -> i64:
        """Count total instructions in a block group."""
        var count = 0
        for bid in group:
            val block = find_block(func, bid)
            if block.?:
                count = count + block.unwrap().instructions.len()
        count

    me outline_cold_group(
        func: MirFunction,
        group: [BlockId],
        analysis: ColdBlockAnalysis
    ) -> MirFunction:
        """Outline a cold block group into a separate function.

        Steps:
        1. Compute live-in variables for the group
        2. Create outlined function with those as parameters
        3. Replace cold blocks with a single call block
        4. Remap block IDs in the outlined function
        """
        # Collect the actual cold blocks
        var cold_blocks: [MirBlock] = []
        var cold_set = {}
        for bid in group:
            cold_set[bid.id] = true
            val block = find_block(func, bid)
            if block.?:
                cold_blocks = cold_blocks.push(block.unwrap())

        if cold_blocks.len() == 0:
            return func

        # Compute live-in variables
        var live_analysis = OutlineLiveVars.new()
        live_analysis.compute(cold_blocks, func.blocks)

        val captures = live_analysis.live_in
        self.captures_total = self.captures_total + captures.len()

        # Build the outlined function
        val outlined_name = "{func.name}__outlined_{self.outlined_functions}"

        # Create parameter types from captures
        var param_types: [MirType] = []
        var outlined_locals: [MirLocal] = []

        # Add capture parameters
        for i in 0..(captures.len()):
            val capture = captures[i]
            # Find the type of this local in the original function
            val local_type = find_local_type(func, capture)
            param_types = param_types.push(local_type)
            outlined_locals = outlined_locals.push(MirLocal(
                id: capture,
                name: Some("cap_{i}"),
                type_: local_type,
                kind: LocalKind.Arg(index: i)
            ))

        # Add other locals defined inside the cold blocks
        for block in cold_blocks:
            for inst in block.instructions:
                val dest = get_inst_dest(inst)
                if dest.?:
                    val dest_local = dest.unwrap()
                    val already_added = self.local_in_list(outlined_locals, dest_local)
                    if not already_added:
                        val local_type = find_local_type(func, dest_local)
                        outlined_locals = outlined_locals.push(MirLocal(
                            id: dest_local,
                            name: nil,
                            type_: local_type,
                            kind: LocalKind.Temp
                        ))

        # Create the outlined function
        val outlined_sig = MirSignature(
            params: param_types,
            return_type: MirType.unit(),
            is_variadic: false
        )

        val outlined_entry = cold_blocks[0].id

        # Remap terminators in cold blocks: any jump to a non-cold block
        # becomes a Return (the outlined function returns to caller)
        var remapped_blocks: [MirBlock] = []
        for block in cold_blocks:
            val remapped = self.remap_exits(block, cold_set)
            remapped_blocks = remapped_blocks.push(remapped)

        val outlined_func = MirFunction(
            symbol: func.symbol,  # Will be assigned a new symbol during codegen
            name: outlined_name,
            signature: outlined_sig,
            locals: outlined_locals,
            blocks: remapped_blocks,
            entry_block: outlined_entry,
            span: func.span,
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )

        self.generated_functions = self.generated_functions.push(outlined_func)
        self.outlined_functions = self.outlined_functions + 1
        self.outlined_blocks = self.outlined_blocks + cold_blocks.len()

        # Remove cold blocks from original function and add a call block
        # at the entry point of the cold group
        var new_blocks: [MirBlock] = []
        val call_block_id = group[0]

        for block in func.blocks:
            if cold_set.contains_key(block.id.id):
                # Replace the first cold block with a call to the outlined function
                if block.id.id == call_block_id.id:
                    # Build call arguments from captures
                    var call_args: [MirOperand] = []
                    for capture in captures:
                        call_args = call_args.push(mir_operand_copy(capture))

                    # Create a call instruction to the outlined function
                    val call_inst = MirInst(
                        kind: MirInstKind.Call(
                            dest: nil,
                            func: mir_operand_const_int(0),  # Placeholder - resolved at codegen
                            args: call_args
                        ),
                        span: block.instructions[0].span ?? nil
                    )

                    # The call block keeps the original terminator's "exit" path
                    # Find where the cold group would have exited to
                    val exit_target = self.find_group_exit(func, cold_set)

                    val call_block = MirBlock(
                        id: block.id,
                        label: Some("outlined_call"),
                        instructions: [call_inst],
                        terminator: match exit_target:
                            case Some(target): MirTerminator.Goto(target)
                            case nil: MirTerminator.Return(nil)
                    )
                    new_blocks = new_blocks.push(call_block)
                # else: skip other cold blocks (they're in the outlined function now)
            else:
                new_blocks = new_blocks.push(block)

        MirFunction(..func, blocks: new_blocks)

    fn remap_exits(block: MirBlock, cold_set: Dict<i64, bool>) -> MirBlock:
        """Remap exits from cold region: jumps to non-cold blocks become returns."""
        val new_term = match block.terminator:
            case Goto(target):
                if not cold_set.contains_key(target.id):
                    MirTerminator.Return(nil)
                else:
                    block.terminator
            case If(cond, then_, else_):
                val then_cold = cold_set.contains_key(then_.id)
                val else_cold = cold_set.contains_key(else_.id)
                if not then_cold and not else_cold:
                    # Both exits leave the cold region - return
                    MirTerminator.Return(nil)
                else:
                    block.terminator
            case _:
                block.terminator

        MirBlock(..block, terminator: new_term)

    fn find_group_exit(func: MirFunction, cold_set: Dict<i64, bool>) -> BlockId?:
        """Find where the cold group exits to (first non-cold successor)."""
        for block in func.blocks:
            if not cold_set.contains_key(block.id.id):
                continue
            val succs = get_terminator_successors(block.terminator)
            for succ in succs:
                if not cold_set.contains_key(succ.id):
                    return Some(succ)
        nil

    fn local_in_list(locals: [MirLocal], target: LocalId) -> bool:
        """Check if a local ID is already in the locals list."""
        for local in locals:
            if local.id.id == target.id:
                return true
        false

    fn stats_summary() -> text:
        """Generate summary of optimization work."""
        "Outline: {self.outlined_functions} functions created, {self.outlined_blocks} blocks outlined, {self.captures_total} captures"

# ============================================================================
# Helper Functions
# ============================================================================

fn get_terminator_successors(term: MirTerminator) -> [BlockId]:
    """Get successor block IDs from a terminator."""
    match term:
        case Goto(target):
            [target]
        case If(_, then_, else_):
            [then_, else_]
        case Switch(_, targets, default):
            var succs: [BlockId] = [default]
            for case_item in targets:
                succs = succs.push(case_item.target)
            succs
        case CallTerminator(_, _, _, normal, unwind):
            if unwind.?:
                [normal, unwind.unwrap()]
            else:
                [normal]
        case Return(_):
            []
        case Unreachable:
            []
        case Abort(_):
            []

fn get_inst_dest(inst: MirInst) -> LocalId?:
    """Extract destination local from an instruction."""
    match inst.kind:
        case Const(dest, _, _): Some(dest)
        case Copy(dest, _): Some(dest)
        case Move(dest, _): Some(dest)
        case BinOp(dest, _, _, _): Some(dest)
        case UnaryOp(dest, _, _): Some(dest)
        case CheckedBinOp(dest, _, _, _): Some(dest)
        case Alloc(dest, _): Some(dest)
        case Load(dest, _): Some(dest)
        case GetField(dest, _, _): Some(dest)
        case Aggregate(dest, _, _): Some(dest)
        case Cast(dest, _, _): Some(dest)
        case Bitcast(dest, _, _): Some(dest)
        case Call(dest, _, _): dest
        case CallIndirect(dest, _, _, _): dest
        case Intrinsic(dest, _, _): dest
        case GetElementPtr(dest, _, _): Some(dest)
        case _: nil

fn get_inst_uses(inst: MirInst) -> [LocalId]:
    """Extract all locals used by an instruction."""
    var uses: [LocalId] = []
    match inst.kind:
        case Copy(_, src): uses = uses.push(src)
        case Move(_, src): uses = uses.push(src)
        case BinOp(_, _, left, right):
            uses = add_operand_uses(uses, left)
            uses = add_operand_uses(uses, right)
        case UnaryOp(_, _, operand):
            uses = add_operand_uses(uses, operand)
        case CheckedBinOp(_, _, left, right):
            uses = add_operand_uses(uses, left)
            uses = add_operand_uses(uses, right)
        case Load(_, ptr):
            uses = add_operand_uses(uses, ptr)
        case Store(ptr, value):
            uses = add_operand_uses(uses, ptr)
            uses = add_operand_uses(uses, value)
        case Call(_, func, args):
            uses = add_operand_uses(uses, func)
            for arg in args:
                uses = add_operand_uses(uses, arg)
        case CallIndirect(_, ptr, args, _):
            uses = add_operand_uses(uses, ptr)
            for arg in args:
                uses = add_operand_uses(uses, arg)
        case GetField(_, base, _):
            uses = add_operand_uses(uses, base)
        case SetField(base, _, value):
            uses = add_operand_uses(uses, base)
            uses = add_operand_uses(uses, value)
        case Cast(_, operand, _):
            uses = add_operand_uses(uses, operand)
        case Bitcast(_, operand, _):
            uses = add_operand_uses(uses, operand)
        case Aggregate(_, _, operands):
            for op in operands:
                uses = add_operand_uses(uses, op)
        case GetElementPtr(_, base, indices):
            uses = add_operand_uses(uses, base)
            for idx in indices:
                uses = add_operand_uses(uses, idx)
        case Yield(value):
            if value.?:
                uses = add_operand_uses(uses, value.unwrap())
        case Await(_, promise):
            uses = add_operand_uses(uses, promise)
        case Spawn(_, handler, args):
            uses = add_operand_uses(uses, handler)
            for arg in args:
                uses = add_operand_uses(uses, arg)
        case Send(target, message):
            uses = add_operand_uses(uses, target)
            uses = add_operand_uses(uses, message)
        case Receive(_, timeout):
            if timeout.?:
                uses = add_operand_uses(uses, timeout.unwrap())
        case _:
            pass_do_nothing
    uses

fn add_operand_uses(uses: [LocalId], operand: MirOperand) -> [LocalId]:
    """Add local from operand to uses list if it references a local."""
    match operand.kind:
        case Copy(local): uses.push(local)
        case Move(local): uses.push(local)
        case _: uses

fn get_terminator_uses(term: MirTerminator) -> [LocalId]:
    """Extract locals used by a terminator."""
    var uses: [LocalId] = []
    match term:
        case Return(value):
            if value.?:
                uses = add_operand_uses(uses, value.unwrap())
        case If(cond, _, _):
            uses = add_operand_uses(uses, cond)
        case Switch(value, _, _):
            uses = add_operand_uses(uses, value)
        case CallTerminator(_, func, args, _, _):
            uses = add_operand_uses(uses, func)
            for arg in args:
                uses = add_operand_uses(uses, arg)
        case _:
            pass_do_nothing
    uses

fn find_block(func: MirFunction, block_id: BlockId) -> MirBlock?:
    """Find a block by ID in a function."""
    for block in func.blocks:
        if block.id.id == block_id.id:
            return Some(block)
    nil

fn find_local_type(func: MirFunction, local_id: LocalId) -> MirType:
    """Find the type of a local variable in a function."""
    for local in func.locals:
        if local.id.id == local_id.id:
            return local.type_
    # Fallback: return i64 type
    MirType.i64()

# ============================================================================
# Factory Function
# ============================================================================

fn create_outline_pass() -> BodyOutlining:
    """Create a new body outlining pass instance."""
    BodyOutlining.new()

# ============================================================================
# Exports
# ============================================================================

fn outline_run_on_function(pass: BodyOutlining, func: MirFunction) -> MirFunction:
    """Free-function wrapper for body outlining pass dispatch."""
    pass.run_on_function(func)

fn outline_run_on_module(pass: BodyOutlining, module: MirModule) -> MirModule:
    """Run body outlining on all functions in a module.

    This is a module-level pass because outlining creates new functions
    that must be added to the module's function table.
    """
    var result_module = module

    for sym in module.functions.keys():
        result_module.functions[sym] = pass.run_on_function(result_module.functions[sym])

    # Add any generated outlined functions to the module
    for outlined_func in pass.generated_functions:
        result_module.functions[outlined_func.symbol] = outlined_func

    result_module
