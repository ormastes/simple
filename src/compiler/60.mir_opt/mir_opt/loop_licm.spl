# Loop-Invariant Code Motion (LICM)
#
# Moves loop-invariant code out of loops.
#
# An instruction is loop-invariant if:
# 1. All operands are defined outside loop, OR
# 2. All operands are themselves loop-invariant
#
# Algorithm:
# 1. Identify loop-invariant instructions
# 2. Hoist to loop preheader (block before loop)
# 3. Update uses

use compiler.mir.mir_data.*
use compiler.mir.mir.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, BlockId, MirTerminator, SwitchCase}
use compiler.mir_opt.mir_opt.loop_detect.{LoopInfo, LoopDetector}

# ============================================================================
# Loop-Invariant Code Motion (LICM)
# ============================================================================

class LoopInvariantMotion:
    """
    Moves loop-invariant code out of loops.

    An instruction is loop-invariant if:
    1. All operands are defined outside loop, OR
    2. All operands are themselves loop-invariant

    Algorithm:
    1. Identify loop-invariant instructions
    2. Hoist to loop preheader (block before loop)
    3. Update uses
    """
    detector: LoopDetector
    hoisted_count: i64

impl LoopInvariantMotion:
    static fn new() -> LoopInvariantMotion:
        LoopInvariantMotion(
            detector: LoopDetector.new(),
            hoisted_count: 0
        )

    me optimize_function(func: MirFunction) -> MirFunction:
        """Run LICM on function."""
        # Detect loops
        self.detector.detect_loops(func)

        if self.detector.loops.len() == 0:
            # No loops to optimize
            return func

        # For each loop, identify and hoist invariant code
        var optimized_blocks = func.blocks

        for loop_info in self.detector.loops:
            optimized_blocks = self.hoist_invariants(optimized_blocks, loop_info)

        MirFunction.with_blocks(func, optimized_blocks)

    me hoist_invariants(blocks: [MirBlock], the_loop: LoopInfo) -> [MirBlock]:
        """Hoist loop-invariant instructions out of loop."""
        # Pre-compute loop block membership set for O(1) lookup
        var loop_block_set = {}
        loop_block_set[the_loop.header.id] = true
        for bid in the_loop.body:
            loop_block_set[bid.id] = true

        # Build set of locals defined inside the loop
        var loop_defs: Dict<i64, bool> = {}
        for block in blocks:
            if loop_block_set.has(block.id.id):
                for inst in block.instructions:
                    val dest = self.inst_dest(inst)
                    if val def_dest = dest:
                        loop_defs[def_dest.id] = true

        # Collect store targets in loop for load-hoisting safety
        var loop_stores: Dict<i64, bool> = {}
        for block in blocks:
            if loop_block_set.has(block.id.id):
                for inst in block.instructions:
                    val st = self.store_target(inst)
                    if val store_dest = st:
                        loop_stores[store_dest.id] = true

        # Find invariant instructions (all operands defined outside loop)
        var invariant_insts: [MirInst] = []
        var hoisted_ids: Dict<i64, bool> = {}

        for block in blocks:
            if loop_block_set.has(block.id.id):
                for inst in block.instructions:
                    if self.is_loop_invariant(inst, loop_defs, hoisted_ids, loop_stores):
                        invariant_insts = invariant_insts.push(inst)
                        val dest = self.inst_dest(inst)
                        if val hoisted_dest = dest:
                            hoisted_ids[hoisted_dest.id] = true

        if invariant_insts.len() == 0:
            return blocks

        self.hoisted_count = self.hoisted_count + invariant_insts.len()

        # Pre-build invariant set for O(1) lookup (keyed on "dest_id:span_start:span_end")
        var invariant_set: {text: bool} = {}
        for inv_inst in invariant_insts:
            val inv_dest = self.inst_dest(inv_inst)
            if val invariant_dest = inv_dest:
                var key = "{invariant_dest.id}:0:0"
                if val inv_span = inv_inst.span:
                    key = "{invariant_dest.id}:{inv_span.start}:{inv_span.end}"
                invariant_set[key] = true

        # Generate preheader block ID
        var max_id: i64 = 0
        for block in blocks:
            if block.id.id > max_id:
                max_id = block.id.id
        val preheader_id = BlockId.new(max_id + 1)

        val preheader = MirBlock(
            id: preheader_id, label: nil,
            instructions: invariant_insts,
            terminator: MirTerminator.Goto(the_loop.header)
        )

        var new_blocks: [MirBlock] = []

        for block in blocks:
            if block.id.id == the_loop.header.id:
                # Insert preheader before header, remove hoisted from header
                new_blocks = new_blocks.push(preheader)
                var kept: [MirInst] = []
                for inst in block.instructions:
                    if not self.is_in_invariant_set(inst, invariant_set):
                        kept = kept.push(inst)
                new_blocks = new_blocks.push(MirBlock(
                    id: block.id, label: block.label,
                    instructions: kept, terminator: block.terminator
                ))
            elif loop_block_set.has(block.id.id):
                # Remove hoisted instructions from loop body
                var kept: [MirInst] = []
                for inst in block.instructions:
                    if not self.is_in_invariant_set(inst, invariant_set):
                        kept = kept.push(inst)
                new_blocks = new_blocks.push(MirBlock(
                    id: block.id, label: block.label,
                    instructions: kept, terminator: block.terminator
                ))
            else:
                # Redirect non-loop predecessors to preheader
                val new_term = self.redirect_to_preheader(block.terminator, the_loop.header, preheader_id)
                new_blocks = new_blocks.push(MirBlock(
                    id: block.id, label: block.label,
                    instructions: block.instructions, terminator: new_term
                ))

        new_blocks

    fn is_loop_invariant(inst: MirInst, loop_defs: Dict<i64, bool>, hoisted: Dict<i64, bool>, loop_stores: Dict<i64, bool>) -> bool:
        match inst.kind:
            case Const(_, _, _): true
            case BinOp(_, _, left, right):
                (self.operand_invariant(left, loop_defs, hoisted) and
                 self.operand_invariant(right, loop_defs, hoisted))
            case UnaryOp(_, _, operand):
                self.operand_invariant(operand, loop_defs, hoisted)
            case Copy(_, src):
                self.operand_invariant(mir_operand_copy(src), loop_defs, hoisted)
            case GetElementPtr(_, base, indices):
                if not self.operand_invariant(base, loop_defs, hoisted):
                    return false
                var all_inv = true
                for idx in indices:
                    if not self.operand_invariant(idx, loop_defs, hoisted):
                        all_inv = false
                all_inv
            case Load(_, ptr):
                if not self.operand_invariant(ptr, loop_defs, hoisted):
                    return false
                val ptr_local = self.operand_local(ptr)
                if val ptr_id = ptr_local:
                    return not loop_stores.has(ptr_id.id)
                false
            case GetField(_, base, _):
                self.operand_invariant(base, loop_defs, hoisted)
            case Cast(_, operand, _):
                self.operand_invariant(operand, loop_defs, hoisted)
            case _: false

    fn operand_invariant(op: MirOperand, loop_defs: Dict<i64, bool>, hoisted: Dict<i64, bool>) -> bool:
        """Check if operand is defined outside the loop or already hoisted."""
        match op.kind:
            case Copy(local):
                val in_loop = loop_defs.has(local.id)
                val was_hoisted = hoisted.has(local.id)
                (not in_loop) or was_hoisted
            case Move(local):
                val in_loop = loop_defs.has(local.id)
                val was_hoisted = hoisted.has(local.id)
                (not in_loop) or was_hoisted
            case Const(_, _): true  # Constants are always invariant

    fn inst_dest(inst: MirInst) -> LocalId?:
        match inst.kind:
            case Const(dest, _, _): dest
            case BinOp(dest, _, _, _): dest
            case UnaryOp(dest, _, _): dest
            case Copy(dest, _): dest
            case GetElementPtr(dest, _, _): dest
            case Load(dest, _): dest
            case GetField(dest, _, _): dest
            case Cast(dest, _, _): dest
            case _: nil

    fn operand_local(op: MirOperand) -> LocalId?:
        match op.kind:
            case Copy(local): local
            case Move(local): local
            case _: nil

    fn store_target(inst: MirInst) -> LocalId?:
        match inst.kind:
            case Store(ptr, _): self.operand_local(ptr)
            case _: nil

    fn redirect_to_preheader(term: MirTerminator, header: BlockId, preheader: BlockId) -> MirTerminator:
        match term:
            case Goto(target):
                if target.id == header.id:
                    return MirTerminator.Goto(preheader)
                term
            case If(cond, then_, else_):
                var new_then = then_
                var new_else = else_
                if then_.id == header.id:
                    new_then = preheader
                if else_.id == header.id:
                    new_else = preheader
                if new_then.id != then_.id or new_else.id != else_.id:
                    return MirTerminator.If(cond, new_then, new_else)
                term
            case Switch(value, targets, default_):
                var new_targets: [SwitchCase] = []
                var changed = false
                for sc in targets:
                    if sc.target.id == header.id:
                        new_targets = new_targets.push(SwitchCase(value: sc.value, target: preheader))
                        changed = true
                    else:
                        new_targets = new_targets.push(sc)
                var new_default = default_
                if default_.id == header.id:
                    new_default = preheader
                    changed = true
                if changed:
                    return MirTerminator.Switch(value, new_targets, new_default)
                term
            case CallTerminator(dest, func_op, args, normal, unwind):
                if normal.id == header.id:
                    return MirTerminator.CallTerminator(dest, func_op, args, preheader, unwind)
                term
            case _: term

    fn is_in_invariant_set(inst: MirInst, invariant_set: {text: bool}) -> bool:
        val dest = self.inst_dest(inst)
        if val inst_dest = dest:
            var key = "{inst_dest.id}:0:0"
            if val inst_span = inst.span:
                key = "{inst_dest.id}:{inst_span.start}:{inst_span.end}"
            return invariant_set.has(key)
        false

# ============================================================================
# Exports
# ============================================================================
