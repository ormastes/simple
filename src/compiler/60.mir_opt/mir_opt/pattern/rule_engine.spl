# Pattern Rule Engine — Schema
#
# Generic rule type and match-outcome record for the MIR pattern-idiom pass.
# Phase 3 delivers the data schema only; the DP tree-cover matcher is wired
# in a later phase.

struct Rule:
    name:           text
    intrinsic:      text
    requires:       text
    cost_delta:     i64
    software_cost:  i64

struct MatchHit:
    rule_name:  text
    intrinsic:  text
    call_site:  text

enum OptimizerRuleLoadMode:
    Builtin
    DynamicLibrary

enum OptimizerRuleLookupKind:
    DirectExact
    IndexedExact
    DynamicExact
    PipelinePass

enum OptimizerProviderKind:
    Syntax
    Hir
    Mir
    Pattern
    Interpreter
    JitHotspot
    BackendMetadata
    CLibParityHotspot

struct OptimizationRuleProvider:
    name:        text
    version:     text
    kind:        OptimizerProviderKind
    load_mode:   OptimizerRuleLoadMode
    lookup_kind: OptimizerRuleLookupKind
    path:        text
    hot_path:    bool
    enabled:     bool
    required_facts: [text]
    produced_facts: [text]
    safety_class: text

struct ExactRuleBinding:
    key:  text
    rule: Rule

struct RuleLookupStats:
    lookups: i64
    hits:    i64
    misses:  i64

struct OptimizationProviderStats:
    scopes:   i64
    rewrites: i64
    skipped:  i64

fn create_rule(name: text, intrinsic: text, requires: text, cost_delta: i64) -> Rule:
    Rule(name, intrinsic, requires, cost_delta, 1000)

fn create_rule_with_cost(name: text, intrinsic: text, requires: text, cost_delta: i64, software_cost: i64) -> Rule:
    Rule(name, intrinsic, requires, cost_delta, software_cost)

fn optimization_rule_provider_builtin(name: text, hot_path: bool) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        version: "1.0.0",
        kind: OptimizerProviderKind.Pattern,
        load_mode: OptimizerRuleLoadMode.Builtin,
        lookup_kind: OptimizerRuleLookupKind.DirectExact,
        path: "",
        hot_path: hot_path,
        enabled: true,
        required_facts: [],
        produced_facts: [],
        safety_class: "pure"
    )

fn optimization_rule_provider_builtin_with_contract(
    name: text,
    kind: OptimizerProviderKind,
    lookup_kind: OptimizerRuleLookupKind,
    hot_path: bool,
    required_facts: [text],
    produced_facts: [text],
    safety_class: text
) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        version: "1.0.0",
        kind: kind,
        load_mode: OptimizerRuleLoadMode.Builtin,
        lookup_kind: lookup_kind,
        path: "",
        hot_path: hot_path,
        enabled: true,
        required_facts: required_facts,
        produced_facts: produced_facts,
        safety_class: safety_class
    )

fn optimization_rule_provider_dynamic(name: text, path: text) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        version: "1.0.0",
        kind: OptimizerProviderKind.Pattern,
        load_mode: OptimizerRuleLoadMode.DynamicLibrary,
        lookup_kind: OptimizerRuleLookupKind.DynamicExact,
        path: path,
        hot_path: false,
        enabled: true,
        required_facts: [],
        produced_facts: [],
        safety_class: "experimental"
    )

fn optimization_rule_provider_should_embed(provider: OptimizationRuleProvider) -> bool:
    provider.enabled and provider.hot_path and provider.load_mode == OptimizerRuleLoadMode.Builtin

fn optimization_rule_provider_uses_direct_lookup(provider: OptimizationRuleProvider) -> bool:
    provider.lookup_kind == OptimizerRuleLookupKind.DirectExact

fn optimization_rule_provider_is_pipeline_pass(provider: OptimizationRuleProvider) -> bool:
    provider.lookup_kind == OptimizerRuleLookupKind.PipelinePass

fn optimization_rule_provider_is_runtime_hotspot(provider: OptimizationRuleProvider) -> bool:
    provider.kind == OptimizerProviderKind.JitHotspot and provider.hot_path

fn optimization_rule_provider_builtin_jit_hotspot(
    name: text,
    required_facts: [text],
    produced_facts: [text],
    safety_class: text
) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        version: "1.0.0",
        kind: OptimizerProviderKind.JitHotspot,
        load_mode: OptimizerRuleLoadMode.Builtin,
        lookup_kind: OptimizerRuleLookupKind.PipelinePass,
        path: "",
        hot_path: true,
        enabled: true,
        required_facts: required_facts,
        produced_facts: produced_facts,
        safety_class: safety_class
    )

fn optimization_rule_provider_has_required_fact(provider: OptimizationRuleProvider, fact: text) -> bool:
    var i = 0
    while i < provider.required_facts.len():
        if provider.required_facts[i] == fact:
            return true
        i = i + 1
    false

fn optimization_fact_list_contains(facts: [text], fact: text) -> bool:
    var i = 0
    while i < facts.len():
        if facts[i] == fact:
            return true
        i = i + 1
    false

fn optimization_rule_provider_missing_fact(provider: OptimizationRuleProvider, available_facts: [text]) -> text?:
    var i = 0
    while i < provider.required_facts.len():
        val required = provider.required_facts[i]
        if not optimization_fact_list_contains(available_facts, required):
            return Some(required)
        i = i + 1
    nil

fn optimization_rule_provider_can_run(provider: OptimizationRuleProvider, available_facts: [text]) -> bool:
    provider.enabled and not optimization_rule_provider_missing_fact(provider, available_facts).?

fn create_exact_rule_binding(key: text, rule: Rule) -> ExactRuleBinding:
    ExactRuleBinding(key, rule)

fn lookup_exact_rule_binding(bindings: [ExactRuleBinding], key: text) -> Rule?:
    var i = 0
    while i < bindings.len():
        val binding = bindings[i]
        if binding.key == key:
            return Some(binding.rule)
        i = i + 1
    nil

fn rule_lookup_stats_zero() -> RuleLookupStats:
    RuleLookupStats(0, 0, 0)

fn rule_lookup_stats_record(stats: RuleLookupStats, hit: bool) -> RuleLookupStats:
    if hit:
        RuleLookupStats(stats.lookups + 1, stats.hits + 1, stats.misses)
    else:
        RuleLookupStats(stats.lookups + 1, stats.hits, stats.misses + 1)

fn optimization_provider_stats_zero() -> OptimizationProviderStats:
    OptimizationProviderStats(0, 0, 0)

fn optimization_provider_stats_record_scope(stats: OptimizationProviderStats, rewrites: i64) -> OptimizationProviderStats:
    if rewrites > 0:
        OptimizationProviderStats(stats.scopes + 1, stats.rewrites + rewrites, stats.skipped)
    else:
        OptimizationProviderStats(stats.scopes + 1, stats.rewrites, stats.skipped + 1)

fn optimization_rule_provider_clib_parity(name: text, hot_path: bool) -> OptimizationRuleProvider:
    optimization_rule_provider_builtin_with_contract(
        name,
        OptimizerProviderKind.CLibParityHotspot,
        OptimizerRuleLookupKind.PipelinePass,
        hot_path,
        ["typed_mir", "loop_bounds_proof"],
        ["clib_parity_rewrite"],
        "pure"
    )

fn rule_summary(r: Rule) -> text:
    var name_part = r.name
    var intrinsic_part = r.intrinsic
    var requires_part = r.requires
    var delta_val = r.cost_delta
    var delta_part = "{delta_val}"
    var sw_val = r.software_cost
    var sw_part = "{sw_val}"
    "rule(" + name_part + ") -> " + intrinsic_part + " [requires=" + requires_part + ", delta=" + delta_part + ", sw_cost=" + sw_part + "]"
