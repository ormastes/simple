# Pattern Rule Engine — Schema
#
# Generic rule type and match-outcome record for the MIR pattern-idiom pass.
# Phase 3 delivers the data schema only; the DP tree-cover matcher is wired
# in a later phase.

struct Rule:
    name:           text
    intrinsic:      text
    requires:       text
    cost_delta:     i64
    software_cost:  i64

struct MatchHit:
    rule_name:  text
    intrinsic:  text
    call_site:  text

enum OptimizerRuleLoadMode:
    Builtin
    DynamicLibrary

enum OptimizerRuleLookupKind:
    DirectExact
    IndexedExact
    DynamicExact

struct OptimizationRuleProvider:
    name:        text
    load_mode:   OptimizerRuleLoadMode
    lookup_kind: OptimizerRuleLookupKind
    path:        text
    hot_path:    bool
    enabled:     bool

struct ExactRuleBinding:
    key:  text
    rule: Rule

struct RuleLookupStats:
    lookups: i64
    hits:    i64
    misses:  i64

fn create_rule(name: text, intrinsic: text, requires: text, cost_delta: i64) -> Rule:
    Rule(name, intrinsic, requires, cost_delta, 1000)

fn create_rule_with_cost(name: text, intrinsic: text, requires: text, cost_delta: i64, software_cost: i64) -> Rule:
    Rule(name, intrinsic, requires, cost_delta, software_cost)

fn optimization_rule_provider_builtin(name: text, hot_path: bool) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        load_mode: OptimizerRuleLoadMode.Builtin,
        lookup_kind: OptimizerRuleLookupKind.DirectExact,
        path: "",
        hot_path: hot_path,
        enabled: true
    )

fn optimization_rule_provider_dynamic(name: text, path: text) -> OptimizationRuleProvider:
    OptimizationRuleProvider(
        name: name,
        load_mode: OptimizerRuleLoadMode.DynamicLibrary,
        lookup_kind: OptimizerRuleLookupKind.DynamicExact,
        path: path,
        hot_path: false,
        enabled: true
    )

fn optimization_rule_provider_should_embed(provider: OptimizationRuleProvider) -> bool:
    provider.enabled and provider.hot_path and provider.load_mode == OptimizerRuleLoadMode.Builtin

fn optimization_rule_provider_uses_direct_lookup(provider: OptimizationRuleProvider) -> bool:
    provider.lookup_kind == OptimizerRuleLookupKind.DirectExact

fn create_exact_rule_binding(key: text, rule: Rule) -> ExactRuleBinding:
    ExactRuleBinding(key, rule)

fn lookup_exact_rule_binding(bindings: [ExactRuleBinding], key: text) -> Rule?:
    var i = 0
    while i < bindings.len():
        val binding = bindings[i]
        if binding.key == key:
            return Some(binding.rule)
        i = i + 1
    nil

fn rule_lookup_stats_zero() -> RuleLookupStats:
    RuleLookupStats(0, 0, 0)

fn rule_lookup_stats_record(stats: RuleLookupStats, hit: bool) -> RuleLookupStats:
    if hit:
        RuleLookupStats(stats.lookups + 1, stats.hits + 1, stats.misses)
    else:
        RuleLookupStats(stats.lookups + 1, stats.hits, stats.misses + 1)

fn rule_summary(r: Rule) -> text:
    var name_part = r.name
    var intrinsic_part = r.intrinsic
    var requires_part = r.requires
    var delta_val = r.cost_delta
    var delta_part = "{delta_val}"
    var sw_val = r.software_cost
    var sw_part = "{sw_val}"
    "rule(" + name_part + ") -> " + intrinsic_part + " [requires=" + requires_part + ", delta=" + delta_part + ", sw_cost=" + sw_part + "]"
