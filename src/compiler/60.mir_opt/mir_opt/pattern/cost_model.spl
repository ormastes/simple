# Pattern Cost Model
#
# Multi-objective cost tuple for cipher / SIMD idiom rewrites.
# Used by the pattern-idiom pass to decide whether a recognised
# software routine is worth replacing with an intrinsic call given the
# combined latency, code-size, register-pressure, and tail-handling costs.

struct PatternCost:
    latency:       i64
    code_size:     i64
    reg_pressure:  i64
    tail_cost:     i64

fn pattern_cost_default() -> PatternCost:
    PatternCost(0, 0, 0, 0)

fn pattern_cost_better(a: PatternCost, b: PatternCost) -> bool:
    if a.latency != b.latency:
        return a.latency < b.latency
    if a.code_size != b.code_size:
        return a.code_size < b.code_size
    if a.reg_pressure != b.reg_pressure:
        return a.reg_pressure < b.reg_pressure
    a.tail_cost < b.tail_cost

fn pattern_cost_total(c: PatternCost) -> i64:
    (c.latency * 4) + c.code_size + (c.reg_pressure * 2) + c.tail_cost
