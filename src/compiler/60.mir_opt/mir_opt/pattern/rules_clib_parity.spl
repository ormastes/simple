# CLib Parity Hotspot Rules — Recogniser Table
#
# Hardcoded rule registry for C-library-shape and provider-parity patterns that
# the pure-Simple compiler can recognise and replace with optimised intrinsics.
# This stays general-purpose: storage, DB, web, and SimpleOS/QEMU rules all use
# the same proof-gated provider contract instead of bespoke optimizers.

use compiler.mir_opt.mir_opt.pattern.rule_engine.{
    Rule, OptimizationRuleProvider,
    create_rule_with_cost,
    optimization_rule_provider_clib_parity
}

enum CLibPatternKind:
    ByteCopy
    EndianLoad
    ChecksumReducer
    DirectoryScan
    ClusterChain
    PrefixLookup
    WalBatch
    HeaderScan
    RouteLookup
    MmioPoll
    SerialMarkerScan
    ProviderGrantCheck
    CopyGuard
    BitExtractTable
    FtsMatch
    ContainsSearch
    PageSummaryScan
    CacheInvalidation
    ReopenRecovery
    DictLookupFusion
    ArrayLenHoist
    DeadBranchElim
    StringConcatReduce
    IntCmpStrengthReduce
    ScanResultCache
    VisibilityBatchPrecompute
    CopyElisionPointLookup
    FlatKeyIndex
    TextCmpStrengthReduce
    LoopInvariantDictHoist
    CoAllocatedArrayBCE
    DbHelperInlineForce

struct CLibParityRule:
    name: text
    pattern_kind: CLibPatternKind
    domain: text
    intrinsic: text
    requires: text
    required_proof: text
    cost_delta: i64
    software_cost: i64

struct CLibParityRewriteDecision:
    rule_name: text
    intrinsic: text
    eligible: bool
    reason: text

fn clib_parity_rule(
    name: text,
    pattern_kind: CLibPatternKind,
    domain: text,
    intrinsic: text,
    requires: text,
    required_proof: text,
    cost_delta: i64,
    software_cost: i64
) -> CLibParityRule:
    CLibParityRule(name, pattern_kind, domain, intrinsic, requires, required_proof, cost_delta, software_cost)

fn clib_parity_rule_table() -> [CLibParityRule]:
    [
        clib_parity_rule("match_memcpy_loop",       CLibPatternKind.ByteCopy,           "general",    "clib_memcpy",              "none",             "alias_non_overlap_or_memmove", -5, 800),
        clib_parity_rule("match_memmove_loop",      CLibPatternKind.ByteCopy,           "general",    "clib_memmove",             "none",             "alias_safe_copy",              -4, 900),
        clib_parity_rule("match_memset_loop",       CLibPatternKind.ByteCopy,           "general",    "clib_memset",              "none",             "bounds_cover_written_range",   -4, 700),
