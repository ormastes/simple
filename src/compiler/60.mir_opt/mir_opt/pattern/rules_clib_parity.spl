# CLib Parity Hotspot Rules — Recogniser Table
#
# Hardcoded rule registry for C-library-shape patterns that the
# pure-Simple compiler can recognise and replace with optimised intrinsics.
# Three pattern families: byte-copy, endian-load, checksum-reducer.

use compiler.mir_opt.mir_opt.pattern.rule_engine.{
    Rule, OptimizationRuleProvider,
    create_rule_with_cost,
    optimization_rule_provider_clib_parity
}

enum CLibPatternKind:
    ByteCopy
    EndianLoad
    ChecksumReducer

struct CLibParityRule:
    name: text
    pattern_kind: CLibPatternKind
    intrinsic: text
    requires: text
    cost_delta: i64
    software_cost: i64

fn clib_parity_rule(name: text, pattern_kind: CLibPatternKind, intrinsic: text, requires: text, cost_delta: i64, software_cost: i64) -> CLibParityRule:
    CLibParityRule(name, pattern_kind, intrinsic, requires, cost_delta, software_cost)

fn clib_parity_rule_table() -> [CLibParityRule]:
    [
        clib_parity_rule("match_memcpy_loop",       CLibPatternKind.ByteCopy,        "clib_memcpy",        "none", -5, 800),
        clib_parity_rule("match_memmove_loop",      CLibPatternKind.ByteCopy,        "clib_memmove",       "none", -4, 900),
        clib_parity_rule("match_memset_loop",       CLibPatternKind.ByteCopy,        "clib_memset",        "none", -4, 700),
        clib_parity_rule("match_le16_load",         CLibPatternKind.EndianLoad,      "clib_load_le16",     "none", -2, 500),
        clib_parity_rule("match_le32_load",         CLibPatternKind.EndianLoad,      "clib_load_le32",     "none", -2, 500),
        clib_parity_rule("match_be32_load",         CLibPatternKind.EndianLoad,      "clib_load_be32",     "none", -2, 500),
        clib_parity_rule("match_be64_load",         CLibPatternKind.EndianLoad,      "clib_load_be64",     "none", -2, 500),
        clib_parity_rule("match_checksum_fold",     CLibPatternKind.ChecksumReducer, "clib_checksum_fold", "none", -6, 1200),
        clib_parity_rule("match_crc32_reduce",      CLibPatternKind.ChecksumReducer, "clib_crc32_reduce",  "crc32", -4, 1000),
        clib_parity_rule("match_adler32_reduce",    CLibPatternKind.ChecksumReducer, "clib_adler32_reduce","none", -3, 900)
    ]

fn clib_parity_rule_provider() -> OptimizationRuleProvider:
    optimization_rule_provider_clib_parity("clib-parity-hotspot-rules", true)
