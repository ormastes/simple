# Cipher Pattern Rules — Recogniser Table
#
# Hardcoded rule registry for recognised software cipher routines.
# Each entry maps a well-known callee symbol (exact string match) to the
# canonical MirInstKind.Intrinsic name that replaces it when the target's
# TargetCaps include the required capability flag.

use compiler.mir.intrinsics.{
    CRYPTO_AES_ROUND,
    CRYPTO_AES_ROUND_LAST,
    CRYPTO_AES_INV_ROUND,
    CRYPTO_AES_INV_ROUND_LAST,
    CRYPTO_AES_IMC,
    CRYPTO_AES_KEYGEN_ASSIST,
    CRYPTO_SHA256_RNDS2,
    CRYPTO_SHA256_MSG1,
    CRYPTO_SHA256_MSG2,
    CRYPTO_SHA512_RNDS2,
    CRYPTO_SHA512_MSG1,
    CRYPTO_SHA512_MSG2,
    CRC32_U8,
    CRC32_U32,
    CRC32_U64,
    CLMUL_LO,
    CLMUL_HI,
    BIT_ROTATE_LEFT,
    BIT_ROTATE_RIGHT,
    BIT_POPCOUNT,
    BIT_CLZ,
    BIT_CTZ,
    BIT_BITREVERSE,
    BIT_PARITY
}

use compiler.mir_opt.mir_opt.pattern.rule_engine.{Rule, create_rule}

let SYM_AES_ROUND:           text = "std.common.aes.cipher.aes_round_software"
let SYM_AES_ROUND_LAST:      text = "std.common.aes.cipher.aes_round_last_software"
let SYM_AES_INV_ROUND:       text = "std.common.aes.cipher.aes_inv_round_software"
let SYM_AES_INV_ROUND_LAST:  text = "std.common.aes.cipher.aes_inv_round_last_software"
let SYM_AES_IMC:             text = "std.common.aes.cipher.aes_imc_software"
let SYM_AES_KEYGEN_ASSIST:   text = "std.common.aes.cipher.aes_keygen_assist_software"
let SYM_SHA256_COMPRESS:     text = "std.common.crypto.sha256.compress_block"
let SYM_SHA256_MSG1:         text = "std.common.crypto.sha256.msg_schedule1"
let SYM_SHA256_MSG2:         text = "std.common.crypto.sha256.msg_schedule2"
let SYM_CRC32_UPDATE_BYTE:   text = "std.common.crypto.crc32.update_byte"
let SYM_CRC32_UPDATE_U32:    text = "std.common.crypto.crc32.update_u32"
let SYM_CRC32_UPDATE_U64:    text = "std.common.crypto.crc32.update_u64"
let SYM_CLMUL_LO:            text = "std.common.crypto.clmul.clmul_lo"
let SYM_CLMUL_HI:            text = "std.common.crypto.clmul.clmul_hi"
let SYM_ROTATE_LEFT:         text = "std.common.bitwise_utils.rotate_left"
let SYM_ROTATE_RIGHT:        text = "std.common.bitwise_utils.rotate_right"
let SYM_COUNT_ONES:          text = "std.common.bitwise_utils.count_ones"
let SYM_LEADING_ZEROS:       text = "std.common.bitwise_utils.leading_zeros"
let SYM_TRAILING_ZEROS:      text = "std.common.bitwise_utils.trailing_zeros"
let SYM_REVERSE_BITS:        text = "std.common.bitwise_utils.reverse_bits"
let SYM_PARITY:              text = "std.common.bitwise_utils.parity"
let SYM_SHA512_ROUND:        text = "std.common.crypto.sha512.sha512_round"
let SYM_SHA512_MSG1:         text = "std.common.crypto.sha512.sha512_msg_schedule_1"
let SYM_SHA512_MSG2:         text = "std.common.crypto.sha512.sha512_msg_schedule_2"

fn cipher_rule_table() -> [Rule]:
    [
        create_rule("match_aes_round_software",          CRYPTO_AES_ROUND,          "aes",    -3),
        create_rule("match_aes_round_last_software",     CRYPTO_AES_ROUND_LAST,     "aes",    -3),
        create_rule("match_aes_inv_round_software",      CRYPTO_AES_INV_ROUND,      "aes",    -3),
        create_rule("match_aes_inv_round_last_software", CRYPTO_AES_INV_ROUND_LAST, "aes",    -3),
        create_rule("match_aes_imc_software",            CRYPTO_AES_IMC,            "aes",    -2),
        create_rule("match_aes_keygen_assist_software",  CRYPTO_AES_KEYGEN_ASSIST,  "aes",    -2),
        create_rule("match_sha256_compress_block",       CRYPTO_SHA256_RNDS2,       "sha2",   -8),
        create_rule("match_sha256_msg_schedule1",        CRYPTO_SHA256_MSG1,        "sha2",   -4),
        create_rule("match_sha256_msg_schedule2",        CRYPTO_SHA256_MSG2,        "sha2",   -4),
        create_rule("match_crc32_update_byte",           CRC32_U8,                  "crc32",  -2),
        create_rule("match_crc32_update_u32",            CRC32_U32,                 "crc32",  -2),
        create_rule("match_crc32_update_u64",            CRC32_U64,                 "crc32",  -3),
        create_rule("match_clmul_lo",                    CLMUL_LO,                  "pclmul", -5),
        create_rule("match_clmul_hi",                    CLMUL_HI,                  "pclmul", -5),
        create_rule("match_rotate_left",                 BIT_ROTATE_LEFT,           "bitmanip", -2),
        create_rule("match_rotate_right",                BIT_ROTATE_RIGHT,          "bitmanip", -2),
        create_rule("match_count_ones",                  BIT_POPCOUNT,              "popcnt",   -3),
        create_rule("match_leading_zeros",               BIT_CLZ,                   "bitmanip", -3),
        create_rule("match_trailing_zeros",              BIT_CTZ,                   "bitmanip", -3),
        create_rule("match_reverse_bits",                BIT_BITREVERSE,            "bitmanip", -3),
        create_rule("match_parity",                      BIT_PARITY,               "popcnt",   -3),
        create_rule("match_sha512_round",                CRYPTO_SHA512_RNDS2,       "sha512",   -8),
        create_rule("match_sha512_msg1",                 CRYPTO_SHA512_MSG1,        "sha512",   -4),
        create_rule("match_sha512_msg2",                 CRYPTO_SHA512_MSG2,        "sha512",   -4)
    ]

fn lookup_rule_for_callee(callee_symbol: text) -> Rule?:
    val table = cipher_rule_table()
    match callee_symbol:
        case SYM_AES_ROUND:          Some(table[0])
        case SYM_AES_ROUND_LAST:     Some(table[1])
        case SYM_AES_INV_ROUND:      Some(table[2])
        case SYM_AES_INV_ROUND_LAST: Some(table[3])
        case SYM_AES_IMC:            Some(table[4])
        case SYM_AES_KEYGEN_ASSIST:  Some(table[5])
        case SYM_SHA256_COMPRESS:    Some(table[6])
        case SYM_SHA256_MSG1:        Some(table[7])
        case SYM_SHA256_MSG2:        Some(table[8])
        case SYM_CRC32_UPDATE_BYTE:  Some(table[9])
        case SYM_CRC32_UPDATE_U32:   Some(table[10])
        case SYM_CRC32_UPDATE_U64:   Some(table[11])
        case SYM_CLMUL_LO:           Some(table[12])
        case SYM_CLMUL_HI:           Some(table[13])
        case SYM_ROTATE_LEFT:        Some(table[14])
        case SYM_ROTATE_RIGHT:       Some(table[15])
        case SYM_COUNT_ONES:         Some(table[16])
        case SYM_LEADING_ZEROS:      Some(table[17])
        case SYM_TRAILING_ZEROS:     Some(table[18])
        case SYM_REVERSE_BITS:       Some(table[19])
        case SYM_PARITY:             Some(table[20])
        case SYM_SHA512_ROUND:       Some(table[21])
        case SYM_SHA512_MSG1:        Some(table[22])
        case SYM_SHA512_MSG2:        Some(table[23])
        case _:                      nil
