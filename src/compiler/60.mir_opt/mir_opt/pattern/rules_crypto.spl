# Cipher Pattern Rules — Recogniser Table
#
# Hardcoded rule registry for recognised software cipher routines.
# Each entry maps a well-known callee symbol (exact string match) to the
# canonical MirInstKind.Intrinsic name that replaces it when the target's
# TargetCaps include the required capability flag.

use compiler.mir.intrinsics.{
    CRYPTO_AES_ROUND,
    CRYPTO_AES_ROUND_LAST,
    CRYPTO_AES_INV_ROUND,
    CRYPTO_AES_INV_ROUND_LAST,
    CRYPTO_AES_IMC,
    CRYPTO_AES_KEYGEN_ASSIST,
    CRYPTO_SHA256_RNDS2,
    CRYPTO_SHA256_MSG1,
    CRYPTO_SHA256_MSG2,
    CRYPTO_SHA512_RNDS2,
    CRYPTO_SHA512_MSG1,
    CRYPTO_SHA512_MSG2,
    CRC32_U8,
    CRC32_U32,
    CRC32_U64,
    CLMUL_LO,
    CLMUL_HI,
    BIT_ROTATE_LEFT,
    BIT_ROTATE_RIGHT,
    BIT_POPCOUNT,
    BIT_CLZ,
    BIT_CTZ,
    BIT_BITREVERSE,
    BIT_PARITY
}

use compiler.mir_opt.mir_opt.pattern.rule_engine.{Rule, OptimizationRuleProvider, create_rule, optimization_rule_provider_builtin}

let SYM_AES_ROUND:           text = "std.common.aes.cipher.aes_round_software"
let SYM_AES_ROUND_LAST:      text = "std.common.aes.cipher.aes_round_last_software"
let SYM_AES_INV_ROUND:       text = "std.common.aes.cipher.aes_inv_round_software"
let SYM_AES_INV_ROUND_LAST:  text = "std.common.aes.cipher.aes_inv_round_last_software"
let SYM_AES_IMC:             text = "std.common.aes.cipher.aes_imc_software"
let SYM_AES_KEYGEN_ASSIST:   text = "std.common.aes.cipher.aes_keygen_assist_software"
let SYM_SHA256_COMPRESS:     text = "std.common.crypto.sha256.compress_block"
let SYM_SHA256_MSG1:         text = "std.common.crypto.sha256.msg_schedule1"
let SYM_SHA256_MSG2:         text = "std.common.crypto.sha256.msg_schedule2"
let SYM_CRC32_UPDATE_BYTE:   text = "std.common.crypto.crc32.update_byte"
let SYM_CRC32_UPDATE_U32:    text = "std.common.crypto.crc32.update_u32"
let SYM_CRC32_UPDATE_U64:    text = "std.common.crypto.crc32.update_u64"
let SYM_CLMUL_LO:            text = "std.common.crypto.clmul.clmul_lo"
let SYM_CLMUL_HI:            text = "std.common.crypto.clmul.clmul_hi"
let SYM_ROTATE_LEFT:         text = "std.common.bitwise_utils.rotate_left"
let SYM_ROTATE_RIGHT:        text = "std.common.bitwise_utils.rotate_right"
let SYM_COUNT_ONES:          text = "std.common.bitwise_utils.count_ones"
let SYM_LEADING_ZEROS:       text = "std.common.bitwise_utils.leading_zeros"
let SYM_TRAILING_ZEROS:      text = "std.common.bitwise_utils.trailing_zeros"
let SYM_REVERSE_BITS:        text = "std.common.bitwise_utils.reverse_bits"
let SYM_PARITY:              text = "std.common.bitwise_utils.parity"
let SYM_SHA512_ROUND:        text = "std.common.crypto.sha512.sha512_round"
let SYM_SHA512_MSG1:         text = "std.common.crypto.sha512.sha512_msg_schedule_1"
let SYM_SHA512_MSG2:         text = "std.common.crypto.sha512.sha512_msg_schedule_2"

let SYM_CRYPTO_ROTR32:      text = "std.common.crypto.types.rotr32"
let SYM_CRYPTO_ROTL32:      text = "std.common.crypto.types.rotl32"
let SYM_CRYPTO_ROTR64:      text = "std.common.crypto.types.rotr64"
let SYM_CRYPTO_ROTL64:      text = "std.common.crypto.types.rotl64"

fn cipher_rule_table() -> [Rule]:
    [
        create_rule("match_aes_round_software",          CRYPTO_AES_ROUND,          "aes",    -3),
        create_rule("match_aes_round_last_software",     CRYPTO_AES_ROUND_LAST,     "aes",    -3),
        create_rule("match_aes_inv_round_software",      CRYPTO_AES_INV_ROUND,      "aes",    -3),
        create_rule("match_aes_inv_round_last_software", CRYPTO_AES_INV_ROUND_LAST, "aes",    -3),
        create_rule("match_aes_imc_software",            CRYPTO_AES_IMC,            "aes",    -2),
        create_rule("match_aes_keygen_assist_software",  CRYPTO_AES_KEYGEN_ASSIST,  "aes",    -2),
        create_rule("match_sha256_compress_block",       CRYPTO_SHA256_RNDS2,       "sha2",   -8),
        create_rule("match_sha256_msg_schedule1",        CRYPTO_SHA256_MSG1,        "sha2",   -4),
        create_rule("match_sha256_msg_schedule2",        CRYPTO_SHA256_MSG2,        "sha2",   -4),
        create_rule("match_crc32_update_byte",           CRC32_U8,                  "crc32",  -2),
        create_rule("match_crc32_update_u32",            CRC32_U32,                 "crc32",  -2),
        create_rule("match_crc32_update_u64",            CRC32_U64,                 "crc32",  -3),
        create_rule("match_clmul_lo",                    CLMUL_LO,                  "pclmul", -5),
        create_rule("match_clmul_hi",                    CLMUL_HI,                  "pclmul", -5),
        create_rule("match_rotate_left",                 BIT_ROTATE_LEFT,           "bitmanip", -2),
        create_rule("match_rotate_right",                BIT_ROTATE_RIGHT,          "bitmanip", -2),
        create_rule("match_count_ones",                  BIT_POPCOUNT,              "popcnt",   -3),
        create_rule("match_leading_zeros",               BIT_CLZ,                   "bitmanip", -3),
        create_rule("match_trailing_zeros",              BIT_CTZ,                   "bitmanip", -3),
        create_rule("match_reverse_bits",                BIT_BITREVERSE,            "bitmanip", -3),
        create_rule("match_parity",                      BIT_PARITY,               "popcnt",   -3),
        create_rule("match_sha512_round",                CRYPTO_SHA512_RNDS2,       "sha512",   -8),
        create_rule("match_sha512_msg1",                 CRYPTO_SHA512_MSG1,        "sha512",   -4),
        create_rule("match_sha512_msg2",                 CRYPTO_SHA512_MSG2,        "sha512",   -4),
        create_rule("match_crypto_rotr32",               BIT_ROTATE_RIGHT,          "bitmanip", -2),
        create_rule("match_crypto_rotl32",               BIT_ROTATE_LEFT,           "bitmanip", -2),
        create_rule("match_crypto_rotr64",               BIT_ROTATE_RIGHT,          "bitmanip", -2),
        create_rule("match_crypto_rotl64",               BIT_ROTATE_LEFT,           "bitmanip", -2)
    ]

fn cipher_rule_provider() -> OptimizationRuleProvider:
    optimization_rule_provider_builtin("cipher-pattern-rules", true)

fn lookup_rule_for_callee(callee_symbol: text) -> Rule?:
    if callee_symbol == SYM_AES_ROUND:
        return Some(create_rule("match_aes_round_software", CRYPTO_AES_ROUND, "aes", -3))
    if callee_symbol == SYM_AES_ROUND_LAST:
        return Some(create_rule("match_aes_round_last_software", CRYPTO_AES_ROUND_LAST, "aes", -3))
    if callee_symbol == SYM_AES_INV_ROUND:
        return Some(create_rule("match_aes_inv_round_software", CRYPTO_AES_INV_ROUND, "aes", -3))
    if callee_symbol == SYM_AES_INV_ROUND_LAST:
        return Some(create_rule("match_aes_inv_round_last_software", CRYPTO_AES_INV_ROUND_LAST, "aes", -3))
    if callee_symbol == SYM_AES_IMC:
        return Some(create_rule("match_aes_imc_software", CRYPTO_AES_IMC, "aes", -2))
    if callee_symbol == SYM_AES_KEYGEN_ASSIST:
        return Some(create_rule("match_aes_keygen_assist_software", CRYPTO_AES_KEYGEN_ASSIST, "aes", -2))
    if callee_symbol == SYM_SHA256_COMPRESS:
        return Some(create_rule("match_sha256_compress_block", CRYPTO_SHA256_RNDS2, "sha2", -8))
    if callee_symbol == SYM_SHA256_MSG1:
        return Some(create_rule("match_sha256_msg_schedule1", CRYPTO_SHA256_MSG1, "sha2", -4))
    if callee_symbol == SYM_SHA256_MSG2:
        return Some(create_rule("match_sha256_msg_schedule2", CRYPTO_SHA256_MSG2, "sha2", -4))
    if callee_symbol == SYM_CRC32_UPDATE_BYTE:
        return Some(create_rule("match_crc32_update_byte", CRC32_U8, "crc32", -2))
    if callee_symbol == SYM_CRC32_UPDATE_U32:
        return Some(create_rule("match_crc32_update_u32", CRC32_U32, "crc32", -2))
    if callee_symbol == SYM_CRC32_UPDATE_U64:
        return Some(create_rule("match_crc32_update_u64", CRC32_U64, "crc32", -3))
    if callee_symbol == SYM_CLMUL_LO:
        return Some(create_rule("match_clmul_lo", CLMUL_LO, "pclmul", -5))
    if callee_symbol == SYM_CLMUL_HI:
        return Some(create_rule("match_clmul_hi", CLMUL_HI, "pclmul", -5))
    if callee_symbol == SYM_ROTATE_LEFT:
        return Some(create_rule("match_rotate_left", BIT_ROTATE_LEFT, "bitmanip", -2))
    if callee_symbol == SYM_ROTATE_RIGHT:
        return Some(create_rule("match_rotate_right", BIT_ROTATE_RIGHT, "bitmanip", -2))
    if callee_symbol == SYM_COUNT_ONES:
        return Some(create_rule("match_count_ones", BIT_POPCOUNT, "popcnt", -3))
    if callee_symbol == SYM_LEADING_ZEROS:
        return Some(create_rule("match_leading_zeros", BIT_CLZ, "bitmanip", -3))
    if callee_symbol == SYM_TRAILING_ZEROS:
        return Some(create_rule("match_trailing_zeros", BIT_CTZ, "bitmanip", -3))
    if callee_symbol == SYM_REVERSE_BITS:
        return Some(create_rule("match_reverse_bits", BIT_BITREVERSE, "bitmanip", -3))
    if callee_symbol == SYM_PARITY:
        return Some(create_rule("match_parity", BIT_PARITY, "popcnt", -3))
    if callee_symbol == SYM_SHA512_ROUND:
        return Some(create_rule("match_sha512_round", CRYPTO_SHA512_RNDS2, "sha512", -8))
    if callee_symbol == SYM_SHA512_MSG1:
        return Some(create_rule("match_sha512_msg1", CRYPTO_SHA512_MSG1, "sha512", -4))
    if callee_symbol == SYM_SHA512_MSG2:
        return Some(create_rule("match_sha512_msg2", CRYPTO_SHA512_MSG2, "sha512", -4))
    if callee_symbol == SYM_CRYPTO_ROTR32:
        return Some(create_rule("match_crypto_rotr32", BIT_ROTATE_RIGHT, "bitmanip", -2))
    if callee_symbol == SYM_CRYPTO_ROTL32:
        return Some(create_rule("match_crypto_rotl32", BIT_ROTATE_LEFT, "bitmanip", -2))
    if callee_symbol == SYM_CRYPTO_ROTR64:
        return Some(create_rule("match_crypto_rotr64", BIT_ROTATE_RIGHT, "bitmanip", -2))
    if callee_symbol == SYM_CRYPTO_ROTL64:
        return Some(create_rule("match_crypto_rotl64", BIT_ROTATE_LEFT, "bitmanip", -2))
    nil
