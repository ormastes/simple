# ============================================================================
# Target Optimization Context
# ============================================================================

struct TargetOptContext:
    x86_caps: X86Caps
    cipher_remark: bool
    caps_kind: TargetCapsKind

fn target_opt_context_default() -> TargetOptContext:
    val caps = X86Caps(false, false, false, false, false, false, false, false, false)
    TargetOptContext(x86_caps: caps, cipher_remark: false, caps_kind: TargetCapsKind.None_)

# ============================================================================
# Optimization Level
# ============================================================================

enum OptLevel:
    """Optimization level for compilation."""
    NoOpt       # No optimization (fastest compile, slowest runtime)
    Size        # Optimize for binary size
    Speed       # Optimize for execution speed (default for release)
    Aggressive  # Maximum optimization (slowest compile, fastest runtime)


# ============================================================================
# OptLevel Methods (was: impl OptLevel:)
# ============================================================================

# ============================================================================
# Optimization Pass Trait
# ============================================================================

trait MirPass:
    """
    Optimization pass over MIR.

    Each pass transforms a MirFunction and returns a modified version.
    Passes should be idempotent when possible.
    """

    fn name() -> text:
        """Human-readable pass name."""

    fn description() -> text:
        """Brief description of what this pass does."""

    me run_on_function(func: MirFunction) -> MirFunction:
        """
        Run optimization pass on a single function.

        Args:
            func: Function to optimize

        Returns:
            Optimized function (may be same object if no changes)
        """

    fn is_analysis_pass() -> bool:
        """Whether this pass only analyzes (doesn't modify IR)."""
        false

    fn dependencies() -> [text]:
        """List of pass names this pass depends on."""
        []

# ============================================================================
# PassKind — typed pass identity (replaces string matching in dispatch)
# ============================================================================

enum PassKind:
    """Typed identity for each known optimization pass.

    Replaces string-based dispatch in run_named_pass / run_pass_on_module.
    Public pass names (stable_name + aliases) remain unchanged for callers.
    """
    DeadCodeElimination
    ConstantFolding
    CopyPropagation
    CommonSubexprElim
    InlineSmallFunctions
    InlineFunctions
    InlineAggressive
    LoopInvariantMotion
    LoopUnroll
    BoundsCheckElimination
    StrengthReduction
    CollectionOpt
    StringBuilderOpt
    BodyOutlining
    GeneratorStateMachine
    TailCallOptimization
    GlobalValueNumbering
    PatternIdiom
    AutoVectorize
    PredicatePromote
    TargetNarrowForm
    WriteCoalesce
    ReadAheadHoist
    SyscallBatch
    TypedByteCanon

enum PassScope:
    """Whether a pass operates per-function or on the whole module."""
    Function   # pass runs independently on each MirFunction
    Module     # pass needs the whole MirModule (may add/remove functions)
    FsDriver   # pass targets filesystem-driver IO patterns

struct MirPassDescriptor:
    stable_name: text
    aliases: [text]
    provider: OptimizationRuleProvider
    kind: PassKind
    scope: PassScope
    cost_class: text

struct MirPassBackendDecision:
    pass_name: text
    backend_name: text
    max_cost_class: text
    cost_class: text
    applies: bool
    reason: text

struct MirPipelineBackendPlan:
    passes: [text]
    skipped_passes: [MirPassBackendDecision]

fn mir_pipeline_provider(name: text, hot_path: bool) -> OptimizationRuleProvider:
    optimization_rule_provider_builtin_with_contract(
        "simple.opt.mir." + name,
        OptimizerProviderKind.Mir,
        OptimizerRuleLookupKind.PipelinePass,
        hot_path,
        ["typed_mir"],
        ["canonical_mir"],
        "pure"
    )

fn mir_pipeline_provider_skip_llvm(name: text, hot_path: bool, reason: text) -> OptimizationRuleProvider:
    optimization_rule_provider_with_backend_policy(
        mir_pipeline_provider(name, hot_path),
        optimization_backend_policy_skip([OptimizerBackendKind.Llvm], reason)
    )

fn mir_pass_descriptor(stable_name: text, aliases: [text], provider: OptimizationRuleProvider, kind: PassKind, scope: PassScope) -> MirPassDescriptor:
    MirPassDescriptor(stable_name: stable_name, aliases: aliases, provider: provider, kind: kind, scope: scope, cost_class: "medium")

fn mir_pass_descriptor_with_cost(stable_name: text, aliases: [text], provider: OptimizationRuleProvider, kind: PassKind, scope: PassScope, cost_class: text) -> MirPassDescriptor:
    MirPassDescriptor(stable_name: stable_name, aliases: aliases, provider: provider, kind: kind, scope: scope, cost_class: cost_class)

fn mir_pass_descriptor_registry() -> [MirPassDescriptor]:
    [
        mir_pass_descriptor_with_cost("dead_code_elimination", ["dce"], mir_pipeline_provider("dead_code_elimination", false), PassKind.DeadCodeElimination, PassScope.Function, "low"),
        mir_pass_descriptor_with_cost("constant_folding", ["const_fold"], mir_pipeline_provider("constant_folding", false), PassKind.ConstantFolding, PassScope.Function, "low"),
        mir_pass_descriptor_with_cost("copy_propagation", [], mir_pipeline_provider("copy_propagation", false), PassKind.CopyPropagation, PassScope.Function, "low"),
        mir_pass_descriptor("common_subexpr_elim", [], mir_pipeline_provider_skip_llvm("common_subexpr_elim", false, "llvm_runs_gvn_and_scalar_cleanup"), PassKind.CommonSubexprElim, PassScope.Function),
        mir_pass_descriptor_with_cost("inline_small_functions", [], mir_pipeline_provider("inline_small_functions", false), PassKind.InlineSmallFunctions, PassScope.Module, "low"),
        mir_pass_descriptor("inline_functions", [], mir_pipeline_provider_skip_llvm("inline_functions", false, "llvm_runs_inliner_pipeline"), PassKind.InlineFunctions, PassScope.Module),
        mir_pass_descriptor_with_cost("inline_aggressive", [], mir_pipeline_provider_skip_llvm("inline_aggressive", false, "llvm_runs_inliner_pipeline"), PassKind.InlineAggressive, PassScope.Module, "high"),
        mir_pass_descriptor("loop_invariant_motion", [], mir_pipeline_provider("loop_invariant_motion", false), PassKind.LoopInvariantMotion, PassScope.Function),
        mir_pass_descriptor("loop_unroll", [], mir_pipeline_provider_skip_llvm("loop_unroll", false, "llvm_runs_loop_unroll_pipeline"), PassKind.LoopUnroll, PassScope.Function),
        mir_pass_descriptor("bounds_check_elimination", [], mir_pipeline_provider("bounds_check_elimination", false), PassKind.BoundsCheckElimination, PassScope.Function),
        mir_pass_descriptor("strength_reduction", [], optimization_rule_provider_with_backend_policy(strength_reduction_provider(), optimization_backend_policy_skip([OptimizerBackendKind.Llvm], "llvm_runs_scalar_strength_reduction")), PassKind.StrengthReduction, PassScope.Function),
        mir_pass_descriptor("collection_opt", ["collection_optimization"], collection_optimization_provider(), PassKind.CollectionOpt, PassScope.Function),
        mir_pass_descriptor("string_builder_opt", [], mir_pipeline_provider("string_builder_opt", false), PassKind.StringBuilderOpt, PassScope.Function),
        mir_pass_descriptor("body_outlining", [], mir_pipeline_provider("body_outlining", false), PassKind.BodyOutlining, PassScope.Module),
        mir_pass_descriptor("generator_state_machine", [], mir_pipeline_provider("generator_state_machine", false), PassKind.GeneratorStateMachine, PassScope.Function),
        mir_pass_descriptor("tail_call_optimization", [], mir_pipeline_provider("tail_call_optimization", false), PassKind.TailCallOptimization, PassScope.Function),
        mir_pass_descriptor("global_value_numbering", [], mir_pipeline_provider_skip_llvm("global_value_numbering", false, "llvm_runs_gvn_and_scalar_cleanup"), PassKind.GlobalValueNumbering, PassScope.Function),
        mir_pass_descriptor("pattern_idiom", [], mir_pipeline_provider("pattern_idiom", true), PassKind.PatternIdiom, PassScope.Module),
        mir_pass_descriptor_with_cost("auto_vectorize", ["vectorization"], mir_pipeline_provider_skip_llvm("auto_vectorize", false, "llvm_runs_vectorizer_pipeline"), PassKind.AutoVectorize, PassScope.Module, "high"),
        mir_pass_descriptor_with_cost("predicate_promote", [], mir_pipeline_provider_skip_llvm("predicate_promote", false, "llvm_runs_if_conversion_and_select_promotion"), PassKind.PredicatePromote, PassScope.Module, "high"),
        mir_pass_descriptor("target_narrow_form", [], mir_pipeline_provider("target_narrow_form", false), PassKind.TargetNarrowForm, PassScope.Module),
        mir_pass_descriptor("write_coalesce", [], mir_pipeline_provider("write_coalesce", false), PassKind.WriteCoalesce, PassScope.FsDriver),
        mir_pass_descriptor("read_ahead_hoist", [], mir_pipeline_provider("read_ahead_hoist", false), PassKind.ReadAheadHoist, PassScope.FsDriver),
        mir_pass_descriptor("syscall_batch", [], mir_pipeline_provider("syscall_batch", false), PassKind.SyscallBatch, PassScope.FsDriver),
        mir_pass_descriptor("typed_byte_canon", [], mir_pipeline_provider("typed_byte_canon", false), PassKind.TypedByteCanon, PassScope.Function)
    ]

fn mir_pass_provider_registry() -> [OptimizationRuleProvider]:
    var providers: [OptimizationRuleProvider] = []
    for descriptor in mir_pass_descriptor_registry():
        providers.push(descriptor.provider)
    providers

fn mir_pass_descriptor_for_name(pass_name: text) -> MirPassDescriptor?:
    if pass_name == "dead_code_elimination" or pass_name == "dce":
        return Some(mir_pass_descriptor_with_cost("dead_code_elimination", ["dce"], mir_pipeline_provider("dead_code_elimination", false), PassKind.DeadCodeElimination, PassScope.Function, "low"))
    if pass_name == "constant_folding" or pass_name == "const_fold":
        return Some(mir_pass_descriptor_with_cost("constant_folding", ["const_fold"], mir_pipeline_provider("constant_folding", false), PassKind.ConstantFolding, PassScope.Function, "low"))
    if pass_name == "copy_propagation":
        return Some(mir_pass_descriptor_with_cost("copy_propagation", [], mir_pipeline_provider("copy_propagation", false), PassKind.CopyPropagation, PassScope.Function, "low"))
    if pass_name == "common_subexpr_elim":
        return Some(mir_pass_descriptor("common_subexpr_elim", [], mir_pipeline_provider_skip_llvm("common_subexpr_elim", false, "llvm_runs_gvn_and_scalar_cleanup"), PassKind.CommonSubexprElim, PassScope.Function))
    if pass_name == "inline_small_functions":
        return Some(mir_pass_descriptor_with_cost("inline_small_functions", [], mir_pipeline_provider("inline_small_functions", false), PassKind.InlineSmallFunctions, PassScope.Module, "low"))
    if pass_name == "inline_functions":
        return Some(mir_pass_descriptor("inline_functions", [], mir_pipeline_provider_skip_llvm("inline_functions", false, "llvm_runs_inliner_pipeline"), PassKind.InlineFunctions, PassScope.Module))
    if pass_name == "inline_aggressive":
        return Some(mir_pass_descriptor_with_cost("inline_aggressive", [], mir_pipeline_provider_skip_llvm("inline_aggressive", false, "llvm_runs_inliner_pipeline"), PassKind.InlineAggressive, PassScope.Module, "high"))
    if pass_name == "loop_invariant_motion":
        return Some(mir_pass_descriptor("loop_invariant_motion", [], mir_pipeline_provider("loop_invariant_motion", false), PassKind.LoopInvariantMotion, PassScope.Function))
    if pass_name == "loop_unroll":
        return Some(mir_pass_descriptor("loop_unroll", [], mir_pipeline_provider_skip_llvm("loop_unroll", false, "llvm_runs_loop_unroll_pipeline"), PassKind.LoopUnroll, PassScope.Function))
    if pass_name == "bounds_check_elimination":
        return Some(mir_pass_descriptor("bounds_check_elimination", [], mir_pipeline_provider("bounds_check_elimination", false), PassKind.BoundsCheckElimination, PassScope.Function))
    if pass_name == "strength_reduction":
        return Some(mir_pass_descriptor("strength_reduction", [], optimization_rule_provider_with_backend_policy(strength_reduction_provider(), optimization_backend_policy_skip([OptimizerBackendKind.Llvm], "llvm_runs_scalar_strength_reduction")), PassKind.StrengthReduction, PassScope.Function))
    if pass_name == "collection_opt" or pass_name == "collection_optimization":
        return Some(mir_pass_descriptor("collection_opt", ["collection_optimization"], collection_optimization_provider(), PassKind.CollectionOpt, PassScope.Function))
    if pass_name == "string_builder_opt":
        return Some(mir_pass_descriptor("string_builder_opt", [], mir_pipeline_provider("string_builder_opt", false), PassKind.StringBuilderOpt, PassScope.Function))
    if pass_name == "body_outlining":
        return Some(mir_pass_descriptor("body_outlining", [], mir_pipeline_provider("body_outlining", false), PassKind.BodyOutlining, PassScope.Module))
    if pass_name == "generator_state_machine":
        return Some(mir_pass_descriptor("generator_state_machine", [], mir_pipeline_provider("generator_state_machine", false), PassKind.GeneratorStateMachine, PassScope.Function))
    if pass_name == "tail_call_optimization":
        return Some(mir_pass_descriptor("tail_call_optimization", [], mir_pipeline_provider("tail_call_optimization", false), PassKind.TailCallOptimization, PassScope.Function))
    if pass_name == "global_value_numbering":
        return Some(mir_pass_descriptor("global_value_numbering", [], mir_pipeline_provider_skip_llvm("global_value_numbering", false, "llvm_runs_gvn_and_scalar_cleanup"), PassKind.GlobalValueNumbering, PassScope.Function))
    if pass_name == "pattern_idiom":
        return Some(mir_pass_descriptor("pattern_idiom", [], mir_pipeline_provider("pattern_idiom", true), PassKind.PatternIdiom, PassScope.Module))
    if pass_name == "auto_vectorize" or pass_name == "vectorization":
        return Some(mir_pass_descriptor_with_cost("auto_vectorize", ["vectorization"], mir_pipeline_provider_skip_llvm("auto_vectorize", false, "llvm_runs_vectorizer_pipeline"), PassKind.AutoVectorize, PassScope.Module, "high"))
    if pass_name == "predicate_promote":
        return Some(mir_pass_descriptor_with_cost("predicate_promote", [], mir_pipeline_provider_skip_llvm("predicate_promote", false, "llvm_runs_if_conversion_and_select_promotion"), PassKind.PredicatePromote, PassScope.Module, "high"))
    if pass_name == "target_narrow_form":
        return Some(mir_pass_descriptor("target_narrow_form", [], mir_pipeline_provider("target_narrow_form", false), PassKind.TargetNarrowForm, PassScope.Module))
    if pass_name == "write_coalesce":
        return Some(mir_pass_descriptor("write_coalesce", [], mir_pipeline_provider("write_coalesce", false), PassKind.WriteCoalesce, PassScope.FsDriver))
    if pass_name == "read_ahead_hoist":
        return Some(mir_pass_descriptor("read_ahead_hoist", [], mir_pipeline_provider("read_ahead_hoist", false), PassKind.ReadAheadHoist, PassScope.FsDriver))
    if pass_name == "syscall_batch":
        return Some(mir_pass_descriptor("syscall_batch", [], mir_pipeline_provider("syscall_batch", false), PassKind.SyscallBatch, PassScope.FsDriver))
    if pass_name == "typed_byte_canon":
        return Some(mir_pass_descriptor("typed_byte_canon", [], mir_pipeline_provider("typed_byte_canon", false), PassKind.TypedByteCanon, PassScope.Function))
    nil

fn mir_pass_provider_name(pass_name: text) -> text:
    val descriptor = mir_pass_descriptor_for_name(pass_name)
    if descriptor.?:
        descriptor.unwrap().provider.name
    else:
        ""

fn mir_pass_uses_pipeline_provider(pass_name: text) -> bool:
    val descriptor = mir_pass_descriptor_for_name(pass_name)
    descriptor.? and optimization_rule_provider_is_pipeline_pass(descriptor.unwrap().provider)

# ============================================================================
# Pass Manager
# ============================================================================

class PassManager:
    """
    Manages optimization passes and their execution order.

    Handles:
    - Pass dependencies
    - Pass ordering
    - Pass statistics
    """
    passes: [text]  # Pass instances (placeholder - should be [Box<dyn MirPass>])
    stats: PassStatistics


# ============================================================================
# PassManager Methods (was: impl PassManager:)
# ============================================================================

fn passmanager_new() -> PassManager:
        PassManager(
            passes: [],
            stats: passstatistics_new()
        )


me passmanager_run_on_module(self: PassManager, module: MirModule) -> MirModule:
        """
        Run all passes on a module.

        Processes each function in the module through the pass pipeline.
        Iterates passes in the outer loop to avoid repeated name-dispatch
        overhead per function.
        """
        var optimized_module = module

        # Run each pass across all functions (outer=pass, inner=function)
        for pass_name in self.passes:
            optimized_module = run_pass_on_module(pass_name, optimized_module)
            self.stats = passstatistics_record_pass_run(self.stats, pass_name)

        optimized_module


class PassStatistics:
    """Statistics about pass execution."""
    pass_run_count: Dict<text, i64>
    total_runs: i64


# ============================================================================
# PassStatistics Methods (was: impl PassStatistics:)
# ============================================================================

fn passstatistics_new() -> PassStatistics:
        PassStatistics(
            pass_run_count: {},
            total_runs: 0
        )


fn passstatistics_record_pass_run(stats: PassStatistics, pass_name: text) -> PassStatistics:
        var pass_run_count = stats.pass_run_count
        var current_count = 0
        if pass_run_count.has(pass_name):
            current_count = pass_run_count[pass_name]
        pass_run_count[pass_name] = current_count + 1
        PassStatistics(
            pass_run_count: pass_run_count,
            total_runs: stats.total_runs + 1
        )


# ============================================================================
# Optimization Pipeline
# ============================================================================

class OptimizationPipeline:
    """
    Standard optimization pipelines for different levels.

    Provides pre-configured pass sequences for common optimization scenarios.
    """
    level: OptLevel
    passes: [text]  # Pass names
    target_ctx: TargetOptContext


# ============================================================================
# OptimizationPipeline Methods (was: impl OptimizationPipeline:)
# ============================================================================

fn optimizationpipeline_pass_names_for_level(level: OptLevel) -> [text]:
    match level:
        case NoOpt:
            []
        case Size:
            [
                "dead_code_elimination",
                "constant_folding",
                "copy_propagation",
                "global_value_numbering",
                "collection_optimization",
                "string_builder_opt",
                "inline_small_functions",
                "body_outlining",
                "dead_code_elimination"
            ]
        case Speed:
            [
                "generator_state_machine",
                "dead_code_elimination",
                "constant_folding",
                "copy_propagation",
                "global_value_numbering",
                "common_subexpr_elim",
                "tail_call_optimization",
                "target_narrow_form",
                "pattern_idiom",
                "inline_functions",
                "constant_folding",
                "body_outlining",
                "loop_invariant_motion",
                "bounds_check_elimination",
                "auto_vectorize",
                "collection_opt",
                "string_builder_opt",
                "write_coalesce",
                "syscall_batch",
                "dead_code_elimination"
            ]
        case Aggressive:
            [
                "generator_state_machine",
                "dead_code_elimination",
                "constant_folding",
                "copy_propagation",
                "global_value_numbering",
                "common_subexpr_elim",
                "tail_call_optimization",
                "target_narrow_form",
                "pattern_idiom",
                "inline_aggressive",
                "body_outlining",
                "loop_invariant_motion",
                "bounds_check_elimination",
                "auto_vectorize",
                "predicate_promote",
                "collection_opt",
                "string_builder_opt",
                "write_coalesce",
                "syscall_batch",
                "loop_unroll",
                "strength_reduction",
                "global_value_numbering",
                "constant_folding",
                "dead_code_elimination"
            ]

fn optimizationpipeline_for_level(level: OptLevel) -> OptimizationPipeline:
        """
        Create pipeline for given optimization level.

        Pass ordering matters! Passes are run in the order they appear.

        General strategy:
        1. Cleanup passes (DCE, simplify)
        2. Analysis passes (alias analysis, escape analysis)
        3. Transform passes (inline, unroll, vectorize)
        4. Final cleanup (DCE again)
        """
        val ctx = target_opt_context_default()
        OptimizationPipeline(level: level, passes: optimizationpipeline_pass_names_for_level(level), target_ctx: ctx)


# ============================================================================
# Helper Functions
# ============================================================================

fn optlevel_name(level: OptLevel) -> text:
    match level:
        case NoOpt: "none"
        case Size: "basic"
        case Speed: "standard"
        case Aggressive: "aggressive"

fn optimizationpipeline_passes_for_level(level: OptLevel) -> [text]:
    optimizationpipeline_pass_names_for_level(level)

fn mir_pass_cost_rank(cost_class: text) -> i64:
    if cost_class == "free":
        0
    elif cost_class == "low":
        1
    elif cost_class == "medium":
        2
    elif cost_class == "high":
        3
    else:
        99

fn mir_pass_cost_allowed(cost_class: text, max_cost_class: text) -> bool:
    mir_pass_cost_rank(cost_class) <= mir_pass_cost_rank(max_cost_class)

fn mir_backend_is_llvm(backend_name: text) -> bool:
    optimization_backend_kind_from_text(backend_name) == OptimizerBackendKind.Llvm

fn mir_pass_known_fast(pass_name: text) -> bool:
    if pass_name == "dead_code_elimination" or pass_name == "dce":
        return true
    if pass_name == "constant_folding" or pass_name == "const_fold":
        return true
    if pass_name == "copy_propagation":
        return true
    if pass_name == "common_subexpr_elim":
        return true
    if pass_name == "inline_small_functions":
        return true
    if pass_name == "inline_functions":
        return true
    if pass_name == "inline_aggressive":
        return true
    if pass_name == "loop_invariant_motion":
        return true
    if pass_name == "loop_unroll":
        return true
    if pass_name == "bounds_check_elimination":
        return true
    if pass_name == "strength_reduction":
        return true
    if pass_name == "collection_opt" or pass_name == "collection_optimization":
        return true
    if pass_name == "string_builder_opt":
        return true
    if pass_name == "body_outlining":
        return true
    if pass_name == "generator_state_machine":
        return true
    if pass_name == "tail_call_optimization":
        return true
    if pass_name == "global_value_numbering":
        return true
    if pass_name == "pattern_idiom":
        return true
    if pass_name == "auto_vectorize" or pass_name == "vectorization":
        return true
    if pass_name == "predicate_promote":
        return true
    if pass_name == "target_narrow_form":
        return true
    if pass_name == "write_coalesce":
        return true
    if pass_name == "read_ahead_hoist":
        return true
    if pass_name == "syscall_batch":
        return true
    pass_name == "typed_byte_canon"

fn mir_pass_cost_class(pass_name: text) -> text:
    if pass_name == "dead_code_elimination" or pass_name == "dce":
        return "low"
    if pass_name == "constant_folding" or pass_name == "const_fold":
        return "low"
    if pass_name == "copy_propagation":
        return "low"
    if pass_name == "inline_small_functions":
        return "low"
    if pass_name == "inline_aggressive":
        return "high"
    if pass_name == "auto_vectorize" or pass_name == "vectorization":
        return "high"
    if pass_name == "predicate_promote":
        return "high"
    if mir_pass_known_fast(pass_name):
        return "medium"
    "unknown"

fn mir_pass_backend_skip_reason_fast(pass_name: text, backend_name: text) -> text?:
    if not mir_backend_is_llvm(backend_name):
        return nil
    if pass_name == "common_subexpr_elim":
        return Some("llvm_runs_gvn_and_scalar_cleanup")
    if pass_name == "inline_functions" or pass_name == "inline_aggressive":
        return Some("llvm_runs_inliner_pipeline")
    if pass_name == "loop_unroll":
        return Some("llvm_runs_loop_unroll_pipeline")
    if pass_name == "strength_reduction":
        return Some("llvm_runs_scalar_strength_reduction")
    if pass_name == "global_value_numbering":
        return Some("llvm_runs_gvn_and_scalar_cleanup")
    if pass_name == "auto_vectorize" or pass_name == "vectorization":
        return Some("llvm_runs_vectorizer_pipeline")
    if pass_name == "predicate_promote":
        return Some("llvm_runs_if_conversion_and_select_promotion")
    nil

fn mir_pass_applies_to_backend(pass_name: text, backend_name: text) -> bool:
    mir_pass_backend_skip_reason_fast(pass_name, backend_name).? == false

fn mir_pass_applies_to_backend_budget(pass_name: text, backend_name: text, max_cost_class: text) -> bool:
    mir_pass_applies_to_backend(pass_name, backend_name) and mir_pass_cost_allowed(mir_pass_cost_class(pass_name), max_cost_class)

fn mir_pass_backend_decision(pass_name: text, backend_name: text, max_cost_class: text) -> MirPassBackendDecision:
    if not mir_pass_known_fast(pass_name):
        return MirPassBackendDecision(pass_name, backend_name, max_cost_class, "unknown", false, "unknown pass")
    val cost_class = mir_pass_cost_class(pass_name)
    val backend_skip = mir_pass_backend_skip_reason_fast(pass_name, backend_name)
    if backend_skip.?:
        return MirPassBackendDecision(pass_name, backend_name, max_cost_class, cost_class, false, backend_skip.unwrap())
    if not mir_pass_cost_allowed(cost_class, max_cost_class):
        return MirPassBackendDecision(pass_name, backend_name, max_cost_class, cost_class, false, "cost budget exceeded")
    MirPassBackendDecision(pass_name, backend_name, max_cost_class, cost_class, true, "ready")

fn optimizationpipeline_for_backend(level: OptLevel, backend_name: text) -> OptimizationPipeline:
    var pipeline = optimizationpipeline_for_level(level)
    var filtered: [text] = []
    for pass_name in pipeline.passes:
        if mir_pass_applies_to_backend(pass_name, backend_name):
            filtered = filtered.push(pass_name)
    pipeline.passes = filtered
    pipeline

fn optimizationpipeline_passes_for_backend(level: OptLevel, backend_name: text) -> [text]:
    optimizationpipeline_for_backend(level, backend_name).passes

fn optimizationpipeline_for_backend_budget(level: OptLevel, backend_name: text, max_cost_class: text) -> OptimizationPipeline:
    var pipeline = optimizationpipeline_for_level(level)
    var filtered: [text] = []
    for pass_name in pipeline.passes:
        if mir_pass_applies_to_backend_budget(pass_name, backend_name, max_cost_class):
            filtered = filtered.push(pass_name)
    pipeline.passes = filtered
    pipeline

fn optimizationpipeline_passes_for_backend_budget(level: OptLevel, backend_name: text, max_cost_class: text) -> [text]:
    optimizationpipeline_for_backend_budget(level, backend_name, max_cost_class).passes

fn optimizationpipeline_backend_plan_for_budget(level: OptLevel, backend_name: text, max_cost_class: text) -> MirPipelineBackendPlan:
    var passes: [text] = []
    var skipped: [MirPassBackendDecision] = []
    for pass_name in optimizationpipeline_pass_names_for_level(level):
        val decision = mir_pass_backend_decision(pass_name, backend_name, max_cost_class)
        if decision.applies:
            passes = passes.push(pass_name)
        else:
            skipped = skipped.push(decision)
    MirPipelineBackendPlan(passes, skipped)

fn optimizationpipeline_decisions_for_backend_budget(level: OptLevel, backend_name: text, max_cost_class: text) -> [MirPassBackendDecision]:
    var decisions: [MirPassBackendDecision] = []
    for pass_name in optimizationpipeline_pass_names_for_level(level):
        decisions = decisions.push(mir_pass_backend_decision(pass_name, backend_name, max_cost_class))
    decisions

fn optimizationpipeline_skipped_decisions_for_backend_budget(level: OptLevel, backend_name: text, max_cost_class: text) -> [MirPassBackendDecision]:
    var skipped: [MirPassBackendDecision] = []
    for decision in optimizationpipeline_decisions_for_backend_budget(level, backend_name, max_cost_class):
        if not decision.applies:
            skipped = skipped.push(decision)
    skipped

fn optimizationpipeline_inventory_lines() -> [text]:
    var lines: [text] = []
    val levels = [OptLevel.Size, OptLevel.Speed, OptLevel.Aggressive]
    for level in levels:
        val level_name = optlevel_name(level)
        for pass_name in optimizationpipeline_passes_for_level(level):
            lines.push("  - [mir] {pass_name} ({level_name}, canonical-pipeline)")
    lines

fn optimize_module(module: MirModule, level: OptLevel) -> MirModule:
    """
    Convenience function to optimize a module.

    Example:
        val optimized = optimize_module(mir_module, OptLevel.Speed)
    """
    val pipeline = optimizationpipeline_for_level(level)
    pipeline_optimize(pipeline, module)

fn optimize_module_for_backend(module: MirModule, level: OptLevel, backend_name: text) -> MirModule:
    val pipeline = optimizationpipeline_for_backend(level, backend_name)
    pipeline_optimize(pipeline, module)

fn optimize_module_for_backend_budget(module: MirModule, level: OptLevel, backend_name: text, max_cost_class: text) -> MirModule:
    val pipeline = optimizationpipeline_for_backend_budget(level, backend_name, max_cost_class)
    pipeline_optimize(pipeline, module)

fn optimize_module_with_caps(module: MirModule, level: OptLevel, caps: X86Caps, cipher_remark: bool) -> MirModule:
    val ctx = TargetOptContext(x86_caps: caps, cipher_remark: cipher_remark, caps_kind: TargetCapsKind.X86(caps))
    optimize_module_with_context(module, level, ctx)

fn optimize_module_with_context(module: MirModule, level: OptLevel, ctx: TargetOptContext) -> MirModule:
    """Optimize a module with an explicit TargetOptContext carrying target capabilities."""
    var pipeline = optimizationpipeline_for_level(level)
    pipeline.target_ctx = ctx
    pipeline_optimize(pipeline, module)

fn optimize_function(func: MirFunction, passes: [text]) -> MirFunction:
    """
    Run specific passes on a function.

    Example:
        val optimized = optimize_function(func, ["dead_code_elimination", "constant_folding"])
    """
    var result = func

    for pass_name in passes:
        result = run_named_pass(pass_name, result)

    result

# ============================================================================
# Pass Dispatch
# ============================================================================

fn run_named_pass(pass_name: text, func: MirFunction) -> MirFunction:
    """Dispatch optimization pass by name using typed PassKind."""
    val descriptor = mir_pass_descriptor_for_name(pass_name)
    if not descriptor.?:
        return func
    run_typed_pass_on_function(descriptor.unwrap().kind, func)

fn run_typed_pass_on_function(kind: PassKind, func: MirFunction) -> MirFunction:
    """Run a per-function pass identified by PassKind.
    Module-scope passes (PatternIdiom, AutoVectorize, etc.) are no-ops here;
    callers must use run_typed_pass_on_module for those.
    """
    match kind:
        case DeadCodeElimination:
            var dce = create_dce_pass()
            dce_run_on_function(dce, func)
        case ConstantFolding:
            var cf = create_const_fold_pass()
            cf_run_on_function(cf, func)
        case CopyPropagation:
            var cp = create_copy_prop_pass()
            copypropagation_run_on_function(cp, func)
        case CommonSubexprElim:
            var cse = create_cse_pass()
            cse_run_on_function(cse, func)
        case InlineSmallFunctions:
            var inl_s = create_inline_small_pass()
            inline_run_on_function(inl_s, func)
        case InlineFunctions:
            var inl_f = create_inline_pass()
            inline_run_on_function(inl_f, func)
        case InlineAggressive:
            var inl_a = create_inline_aggressive_pass()
            inline_run_on_function(inl_a, func)
        case LoopInvariantMotion:
            var lo = create_loop_opt_conservative()
            loop_opt_run_on_function(lo, func)
        case LoopUnroll:
            var lo = create_loop_opt_pass()
            loop_opt_run_on_function(lo, func)
        case BoundsCheckElimination:
            var bce = create_bounds_check_elim_pass()
            bounds_check_elim_run_on_function(bce, func)
        case StrengthReduction:
            var sr = create_strength_reduction_pass()
            strength_reduction_run_on_function(sr, func)
        case CollectionOpt:
            var co = create_collection_opt_pass()
            collection_opt_run_on_function(co, func)
        case StringBuilderOpt:
            var sb = create_string_builder_opt_pass()
            string_builder_opt_run_on_function(sb, func)
        case BodyOutlining:
            var ol = create_outline_pass()
            outline_run_on_function(ol, func)
        case GeneratorStateMachine:
            var gsm = create_generator_sm_pass()
            generator_sm_run_on_function(gsm, func)
        case TailCallOptimization:
            var tco = create_tco_pass()
            tco_run_on_function(tco, func)
        case GlobalValueNumbering:
            var gvn = create_gvn_pass()
            gvn_run_on_function(gvn, func)
        case PatternIdiom:
            # Module-level pass — no-op per function
            func
        case AutoVectorize:
            # Module-level pass — no-op per function
            func
        case PredicatePromote:
            # Module-level pass — no-op per function
            func
        case TargetNarrowForm:
            # Module-level pass — no-op per function
            func
        case WriteCoalesce:
            var wc_stats = OptimizationStats.create()
            optimize_write_coalesce(func, wc_stats)
        case ReadAheadHoist:
            var rah_stats = OptimizationStats.create()
            optimize_read_ahead_hoist(func, rah_stats)
        case SyscallBatch:
            var sb_stats = OptimizationStats.create()
            optimize_syscall_batch(func, sb_stats)
        case TypedByteCanon:
            var tbc = create_typed_byte_canon_pass()
            typed_byte_canon_run_on_function(tbc, func)

fn pipeline_optimize(pipeline: OptimizationPipeline, module: MirModule) -> MirModule:
    """Run pipeline passes on all functions in a module.

    Target-aware passes (vectorization) read pipeline.target_ctx for
    capability gating.  All other passes are target-independent.
    """
    var optimized_module = module
    val ctx = pipeline.target_ctx
    for pass_name in pipeline.passes:
        if pass_name == "pattern_idiom":
            match ctx.caps_kind:
                case None_:
                    optimized_module = run_pattern_idiom_pass_x86(optimized_module, ctx.x86_caps, ctx.cipher_remark)
                case _:
                    optimized_module = run_pattern_idiom_pass_generic(optimized_module, ctx.caps_kind, ctx.cipher_remark)
        elif pass_name == "target_narrow_form":
            optimized_module = run_narrow_form_pass(optimized_module, ctx.caps_kind)
        else:
            optimized_module = run_pass_on_module(pass_name, optimized_module)
    optimized_module


fn run_pass_on_module(pass_name: text, module: MirModule) -> MirModule:
    """Apply a single named pass to a module.

    The pass name is resolved to a typed PassKind once, then run_typed_pass_on_module
    handles dispatch.  Per-function passes create a fresh pass instance per function
    (passes accumulate per-function analysis state via `me` methods).
    """
    val descriptor = mir_pass_descriptor_for_name(pass_name)
    if not descriptor.?:
        return module
    run_typed_pass_on_module(descriptor.unwrap().kind, module)

fn run_typed_pass_on_module(kind: PassKind, module: MirModule) -> MirModule:
    """Typed module-level pass runner.  Dispatches on PassKind, not strings."""
    var result_module = module
    match kind:
        case DeadCodeElimination:
            for sym in module.functions.keys():
                var p = create_dce_pass()
                result_module.functions[sym] = dce_run_on_function(p, result_module.functions[sym])
        case ConstantFolding:
            for sym in module.functions.keys():
                var p = create_const_fold_pass()
                result_module.functions[sym] = cf_run_on_function(p, result_module.functions[sym])
        case CopyPropagation:
            for sym in module.functions.keys():
                var p = create_copy_prop_pass()
                result_module.functions[sym] = copypropagation_run_on_function(p, result_module.functions[sym])
        case CommonSubexprElim:
            for sym in module.functions.keys():
                var p = create_cse_pass()
                result_module.functions[sym] = cse_run_on_function(p, result_module.functions[sym])
        case InlineSmallFunctions:
            var p = create_inline_small_pass()
            result_module = inline_run_on_module(p, result_module)
        case InlineFunctions:
            var p = create_inline_pass()
            result_module = inline_run_on_module(p, result_module)
        case InlineAggressive:
            var p = create_inline_aggressive_pass()
            result_module = inline_run_on_module(p, result_module)
        case LoopInvariantMotion:
            for sym in module.functions.keys():
                var p = create_loop_opt_conservative()
                result_module.functions[sym] = loop_opt_run_on_function(p, result_module.functions[sym])
        case LoopUnroll:
            for sym in module.functions.keys():
                var p = create_loop_opt_pass()
                result_module.functions[sym] = loop_opt_run_on_function(p, result_module.functions[sym])
        case BoundsCheckElimination:
            for sym in module.functions.keys():
                var p = create_bounds_check_elim_pass()
                result_module.functions[sym] = bounds_check_elim_run_on_function(p, result_module.functions[sym])
        case StrengthReduction:
            for sym in module.functions.keys():
                var p = create_strength_reduction_pass()
                result_module.functions[sym] = strength_reduction_run_on_function(p, result_module.functions[sym])
        case CollectionOpt:
            for sym in module.functions.keys():
                var p = create_collection_opt_pass()
                result_module.functions[sym] = collection_opt_run_on_function(p, result_module.functions[sym])
        case StringBuilderOpt:
            for sym in module.functions.keys():
                var p = create_string_builder_opt_pass()
                result_module.functions[sym] = string_builder_opt_run_on_function(p, result_module.functions[sym])
        case BodyOutlining:
            # Module-level pass: outlining creates new functions
            var ol = create_outline_pass()
            result_module = outline_run_on_module(ol, result_module)
        case GeneratorStateMachine:
            for sym in module.functions.keys():
                var p = create_generator_sm_pass()
                result_module.functions[sym] = generator_sm_run_on_function(p, result_module.functions[sym])
        case TailCallOptimization:
            for sym in module.functions.keys():
                var p = create_tco_pass()
                result_module.functions[sym] = tco_run_on_function(p, result_module.functions[sym])
        case GlobalValueNumbering:
            for sym in module.functions.keys():
                var p = create_gvn_pass()
                result_module.functions[sym] = gvn_run_on_function(p, result_module.functions[sym])
        case PredicatePromote:
            result_module = run_predicate_promote(result_module)
        case AutoVectorize:
            # Module-level pass: pattern-match + log; no MIR rewrite in Wave K3.
            # See: doc/05_design/simd_auto_vectorize_design.md §2, §10
            result_module = run_auto_vectorize(result_module)
        case PatternIdiom:
            # pattern_idiom with no loaded rules is a no-op (empty PatternRulePass
            # returns module unchanged).  Pipeline callers supply rules via
            # DynamicPassRegistry; bare callers here get an empty pass.
            val prp = pattern_rule_pass_new()
            result_module = pattern_rule_pass_run(prp, result_module)
        case TargetNarrowForm:
            # target_narrow_form is dispatched by pipeline_optimize with target context;
            # bare run_pass_on_module callers without context get a no-op.
            pass_do_nothing
        case WriteCoalesce:
            for sym in module.functions.keys():
                var wc_stats = OptimizationStats.create()
                result_module.functions[sym] = optimize_write_coalesce(result_module.functions[sym], wc_stats)
        case ReadAheadHoist:
            for sym in module.functions.keys():
                var rah_stats = OptimizationStats.create()
                result_module.functions[sym] = optimize_read_ahead_hoist(result_module.functions[sym], rah_stats)
        case SyscallBatch:
            for sym in module.functions.keys():
                var sb_stats = OptimizationStats.create()
                result_module.functions[sym] = optimize_syscall_batch(result_module.functions[sym], sb_stats)
        case TypedByteCanon:
            for sym in module.functions.keys():
                var tbc = create_typed_byte_canon_pass()
                result_module.functions[sym] = typed_byte_canon_run_on_function(tbc, result_module.functions[sym])
    result_module

