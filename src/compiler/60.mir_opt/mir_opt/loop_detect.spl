# Loop Detection
#
# Detects loops in MIR via backedge analysis.
#
# Provides:
#   - LoopInfo: Information about a detected loop
#   - LoopDetector: Finds loops in a MirFunction
#   - EdgePair: Represents an edge between two blocks
#
# Algorithm:
#   1. Build CFG (control flow graph)
#   2. Find backedges (edges to earlier blocks)
#   3. Identify natural loops (blocks reachable from backedge sources)

use compiler.mir.mir_data.*
use compiler.mir.mir.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}

# ============================================================================
# Edge Pair
# ============================================================================

struct EdgePair:
    """Represents an edge between two blocks."""
    from: BlockId
    to: BlockId

# ============================================================================
# Loop Info
# ============================================================================

class LoopInfo:
    """
    Information about a loop in the MIR.

    A loop is a set of basic blocks with:
    - Header: Entry point (dominates all blocks in loop)
    - Backedges: Edges that jump back to header
    - Body: All blocks in the loop
    - Exit edges: Edges leaving the loop
    - Trip count: Constant iteration count if determinable
    """
    header: BlockId
    body: [BlockId]
    backedges: [BlockId]  # Blocks that jump back to header
    exit_edges: [EdgePair]  # Edges leaving the loop
    trip_count: i64?       # Constant iteration count (if determinable)

impl LoopInfo:
    fn contains_block(block_id: BlockId) -> bool:
        """Check if block is in this loop."""
        if block_id.id == self.header.id:
            return true

        for body_block in self.body:
            if body_block.id == block_id.id:
                return true

        false

    fn iteration_count() -> i64?:
        """
        Try to determine constant iteration count.

        Returns Some(n) if loop has constant iteration count.
        The trip count is computed during loop detection by analyzing
        exit edge comparison instructions (e.g., i < N where N is constant).
        """
        self.trip_count

# ============================================================================
# Loop Detector
# ============================================================================

class LoopDetector:
    """
    Detects loops in MIR via backedge analysis.

    Algorithm:
    1. Build CFG (control flow graph)
    2. Find strongly connected components (SCCs)
    3. Identify natural loops (single-entry SCCs with backedges)
    """
    loops: [LoopInfo]

impl LoopDetector:
    static fn new() -> LoopDetector:
        LoopDetector(loops: [])

    me detect_loops(func: MirFunction):
        """
        Detect all loops in function.

        For now, simple heuristic:
        - Look for blocks that jump backwards (to earlier block)
        - These indicate potential loops
        """
        # Reset loops
        self.loops = []

        # Pre-compute block index map for O(1) lookup
        var block_idx_map = {}
        for i in 0..(func.blocks.len()):
            block_idx_map[func.blocks[i].id.id] = i

        # Find potential loop headers (blocks jumped to from later blocks)
        var potential_headers: [BlockId] = []
        var header_set = {}

        for block in func.blocks:
            val successors = self.get_successors(block.terminator)
            for succ in successors:
                # Check if successor appears earlier in block list (O(1) lookup)
                val succ_idx = block_idx_map[succ.id] ?? -1
                val block_idx = block_idx_map[block.id.id] ?? -1
                if succ_idx <= block_idx:
                    # Potential backedge
                    if not header_set.has(succ.id):
                        header_set[succ.id] = true
                        potential_headers = potential_headers.push(succ)

        # Build LoopInfo for each header. build_loop_info returns nil when the
        # candidate has no genuine backedge (a block-order "backedge" that is
        # really a forward edge, e.g. `break` jumping to an earlier-listed exit
        # block) so such pseudo-loops are dropped instead of driving unsound
        # loop transforms (bug #160).
        for header in potential_headers:
            val loop_info_opt = self.build_loop_info(func, header)
            if loop_info_opt.?:
                self.loops = self.loops.push(loop_info_opt.unwrap())

    # WORKAROUND VERSION:
    fn get_successors(term: MirTerminator) -> [BlockId]:
        """Get successor blocks from terminator."""
        val empty: [BlockId] = []
        match term:
            case Ret(_): empty
            case Unreachable: empty
            case Goto(target): [target]
            case If(_, then_, else_): [then_, else_]
            case Switch(_, targets, default):
                var succs: [BlockId] = []
                for case_item in targets:
                    val sc: SwitchCase = case_item
                    succs = succs.push(sc.target)
                succs = succs.push(default)
                succs
            case CallTerminator(_, _, _, normal, unwind):
                if val unwind_target = unwind:
                    [normal, unwind_target]
                else:
                    [normal]
            case _: empty

    me reachable_from(func: MirFunction, start: BlockId) -> Dict<i64, bool>:
        """Blocks reachable from `start` via one or more CFG edges. `start`
        itself is marked only if it lies on a cycle."""
        var succ_map: Dict<i64, [BlockId]> = {}
        for block in func.blocks:
            succ_map[block.id.id] = self.get_successors(block.terminator)
        var visited: Dict<i64, bool> = {}
        var stack: [BlockId] = []
        for s in (succ_map[start.id] ?? []):
            stack = stack.push(s)
        while stack.len() > 0:
            val cur = stack[stack.len() - 1]
            stack = stack[0 : stack.len() - 1]
            if visited.has(cur.id):
                continue
            visited[cur.id] = true
            for s in (succ_map[cur.id] ?? []):
                if not visited.has(s.id):
                    stack = stack.push(s)
        visited

    me can_reach_target(func: MirFunction, target: BlockId) -> Dict<i64, bool>:
        """Blocks that can reach `target` via one or more CFG edges."""
        var preds: Dict<i64, [i64]> = {}
        for block in func.blocks:
            for s in self.get_successors(block.terminator):
                var lst = preds[s.id] ?? []
                lst = lst.push(block.id.id)
                preds[s.id] = lst
        var visited: Dict<i64, bool> = {}
        var stack: [i64] = []
        for p in (preds[target.id] ?? []):
            stack = stack.push(p)
        while stack.len() > 0:
            val cur = stack[stack.len() - 1]
            stack = stack[0 : stack.len() - 1]
            if visited.has(cur):
                continue
            visited[cur] = true
            for p in (preds[cur] ?? []):
                if not visited.has(p):
                    stack = stack.push(p)
        visited

    fn build_loop_info(func: MirFunction, header: BlockId) -> LoopInfo?:
        """Build LoopInfo for the natural loop with the given header.

        Bug #160: the previous heuristic treated any block whose successor
        appears earlier in the block list as a backedge and set the loop body
        to just the blocks jumping directly to the header. With `break`, a
        forward edge to an earlier-listed exit block was misread as a backedge
        (spurious loop), and the body under-approximated the real loop, so
        collection_opt's loop-invariant hoist wrongly moved a body instruction
        into a bogus header and produced a silent miscompile.

        Correct natural loop: the header must have a genuine backedge (a
        predecessor the header can actually reach, forming a cycle), and the
        body is exactly the blocks that are both reachable FROM the header and
        can reach BACK to the header. That excludes break/exit blocks and the
        preheader, and includes every real loop-body block."""
        val reach_fwd = self.reachable_from(func, header)
        val reach_bwd = self.can_reach_target(func, header)

        # A genuine backedge is an edge p -> header where the header can reach p
        # (or p is the header itself, a self-loop). Absent one, this is not a
        # real loop and must be dropped.
        var backedges: [BlockId] = []
        var has_real_backedge = false
        for block in func.blocks:
            val succs_bk = self.get_successors(block.terminator)
            for succ in succs_bk:
                if succ.id == header.id:
                    if block.id.id == header.id or reach_fwd.has(block.id.id):
                        has_real_backedge = true
                        backedges = backedges.push(block.id)
        if not has_real_backedge:
            return nil

        # Natural loop body: blocks (other than the header) that the header can
        # reach and that can reach the header — i.e. the cycle region.
        var body: [BlockId] = []
        var body_set = {}
        for block in func.blocks:
            if block.id.id == header.id:
                continue
            if reach_fwd.has(block.id.id) and reach_bwd.has(block.id.id):
                body_set[block.id.id] = true
                body = body.push(block.id)

        # Build all_body set for O(1) membership checks
        var all_body_set = {}
        all_body_set[header.id] = true
        for bid in body:
            all_body_set[bid.id] = true

        # Detect exit edges: edges from body blocks to non-body blocks
        var exit_edges: [BlockId] = []
        var exit_set = {}
        val all_body = [header] + body
        for block in func.blocks:
            if not all_body_set.has(block.id.id):
                continue
            val successors = self.get_successors(block.terminator)
            for succ in successors:
                if not all_body_set.has(succ.id):
                    if not exit_set.has(succ.id):
                        exit_set[succ.id] = true
                        exit_edges = exit_edges.push(succ)

        # Analyze iteration count from exit conditions
        # Look at conditional terminators in loop blocks that branch out
        val trip_count = self.analyze_trip_count(func, header, all_body)

        Some(LoopInfo(
            header: header,
            body: body,
            backedges: backedges,
            exit_edges: exit_edges,
            trip_count: trip_count
        ))

    fn analyze_trip_count(func: MirFunction, header: BlockId, loop_blocks: [BlockId]) -> i64?:
        """
        Analyze loop exit conditions to determine constant trip count.

        Looks for patterns like:
        - Header block has If terminator comparing a local against a constant
        - The comparison is Lt (i < N) where N is a constant integer
        - One branch exits the loop, the other stays in

        Returns Some(N) if a constant bound is found, nil otherwise.
        """
        # Build loop block set for O(1) lookup
        var loop_block_set = {}
        for lb in loop_blocks:
            loop_block_set[lb.id] = true

        # Check each block in the loop for conditional exits
        for block in func.blocks:
            if not loop_block_set.has(block.id.id):
                continue

            # Look for If terminators that compare against a constant
            match block.terminator:
                case If(cond, then_, else_):
                    # Check if one target exits the loop and the other stays
                    val then_in_loop = loop_block_set.has(then_.id)
                    val else_in_loop = loop_block_set.has(else_.id)

                    # Exactly one branch should exit for a counted loop
                    # NOTE: explicit match, not `if bound.?:` -- a constant
                    # trip count of 0 is legitimate (a loop that never
                    # executes), and `.?` truthiness on a boxed `i64?`
                    # collapses `Some(0)` to falsy in the bootstrap seed
                    # interpreter (same class of bug as the landed
                    # var_reassign_written_local fix). Safe direction here
                    # (a miss just skips the trip-count-based optimization)
                    # but the identical landmine, fixed for consistency.
                    if then_in_loop and not else_in_loop:
                        # else_ is the exit branch; cond being true continues
                        match self.extract_comparison_bound(block.instructions, cond):
                            case Some(bound_val):
                                return Some(bound_val)
                            case nil:
                                pass_do_nothing
                    elif not then_in_loop and else_in_loop:
                        # then_ is the exit branch; cond being false continues
                        match self.extract_comparison_bound(block.instructions, cond):
                            case Some(bound_val):
                                return Some(bound_val)
                            case nil:
                                pass_do_nothing
                case _:
                    pass

        nil

    fn extract_comparison_bound(instructions: [MirInst], cond: MirOperand) -> i64?:
        """
        Extract constant bound from a comparison used as loop exit condition.

        Looks for BinOp instructions that define the condition operand and have
        a comparison op (Lt, Le, Gt, Ge) with a constant integer operand.

        For `i < N` returns N, for `i <= N` returns N + 1.
        """
        # Find which local the condition references
        val cond_local_id = match cond.kind:
            case Copy(local): Some(local.id)
            case Move(local): Some(local.id)
            case _: nil

        # NOTE: explicit match, not `if not cond_local_id.?:` -- local id 0
        # landmine, see the trip-count note in analyze_trip_count above.
        val target_id = match cond_local_id:
            case Some(id): id
            case nil: return nil

        # Scan instructions for the BinOp that defines this local
        for inst in instructions:
            match inst.kind:
                case BinOp(dest, op, left, right):
                    if dest.id == target_id:
                        # Found the comparison instruction
                        # Check if it's a comparison with a constant bound.
                        # NOTE: explicit match, not `if const_val.?:` -- a
                        # constant bound of 0 is legitimate, same landmine.
                        match self.operand_const_int(right):
                            case Some(const_val):
                                match op:
                                    case Lt:
                                        # i < N -> trip count is N
                                        return Some(const_val)
                                    case Le:
                                        # i <= N -> trip count is N + 1
                                        return Some(const_val + 1)
                                    case _:
                                        pass
                            case nil:
                                pass_do_nothing

                        # Also check left operand (for reversed comparisons like N > i)
                        match self.operand_const_int(left):
                            case Some(const_val_l):
                                match op:
                                    case Gt:
                                        # N > i -> trip count is N
                                        return Some(const_val_l)
                                    case Ge:
                                        # N >= i -> trip count is N + 1
                                        return Some(const_val_l + 1)
                                    case _:
                                        pass
                            case nil:
                                pass_do_nothing
                case _:
                    pass

        nil

    fn operand_const_int(op: MirOperand) -> i64?:
        """Extract constant integer value from operand, if it is one."""
        match op.kind:
            case Const(value, _):
                match value:
                    case Int(n): Some(n)
                    case _: nil
            case _: nil

    fn block_index(func: MirFunction, block_id: BlockId) -> i64:
        """Find index of block in function."""
        var idx = 0
        for block in func.blocks:
            if block.id.id == block_id.id:
                return idx
            idx = idx + 1
        -1

    fn is_block_in_list(block_id: BlockId, list: [BlockId]) -> bool:
        """Check if block is in list."""
        for item in list:
            if item.id == block_id.id:
                return true
        false

    fn find_loop_for_block(block_id: BlockId) -> LoopInfo?:
        """Find innermost loop containing block."""
        for loop_info in self.loops:
            if loop_info.contains_block(block_id):
                return Some(loop_info)
        nil

# ============================================================================
# Exports
# ============================================================================
