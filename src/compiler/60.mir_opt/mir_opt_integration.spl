# MIR Optimization Integration
#
# Integration module for the MIR optimization framework.
# Provides simple interface for pipeline to call optimization passes.
#
# The pass manager in mir_opt.mod dispatches to individual passes
# (DCE, const fold, copy prop, CSE, inlining, loop opts, etc.).
# llc -O3 in the LLVM backend provides additional low-level optimization.

use mir.MirModule
use compiler.mir_opt.mod.{optimize_module, OptLevel}

# ============================================================================
# Optimization Configuration
# ============================================================================

enum OptimizationConfig:
    """Configuration for MIR optimization."""
    Disabled                    # No optimization (debug builds)
    Enabled(level: i64)         # Optimize with specified level (0=none, 1=size, 2=speed, 3=aggressive)


# ============================================================================
# OptimizationConfig Methods
# ============================================================================

impl OptimizationConfig:
    static fn none() -> OptimizationConfig:
        """No optimization (debug mode)."""
        OptimizationConfig.Disabled

    static fn debug() -> OptimizationConfig:
        """Debug mode (no optimization)."""
        OptimizationConfig.Disabled

    static fn size() -> OptimizationConfig:
        """Optimize for binary size."""
        OptimizationConfig.Enabled(level: 1)

    static fn speed() -> OptimizationConfig:
        """Optimize for speed (default release)."""
        OptimizationConfig.Enabled(level: 2)

    static fn aggressive() -> OptimizationConfig:
        """Aggressive optimization (maximum performance)."""
        OptimizationConfig.Enabled(level: 3)

fn optimizationconfig_none() -> OptimizationConfig:
    """No optimization (debug mode)."""
    OptimizationConfig.none()

fn optimizationconfig_debug() -> OptimizationConfig:
    """Debug mode (no optimization)."""
    OptimizationConfig.debug()

fn optimizationconfig_size() -> OptimizationConfig:
    """Optimize for binary size."""
    OptimizationConfig.size()

fn optimizationconfig_speed() -> OptimizationConfig:
    """Optimize for speed (default release)."""
    OptimizationConfig.speed()

fn optimizationconfig_aggressive() -> OptimizationConfig:
    """Aggressive optimization (maximum performance)."""
    OptimizationConfig.aggressive()


# ============================================================================
# Optimization Entry Point
# ============================================================================

fn _config_to_opt_level(config: OptimizationConfig) -> OptLevel:
    """Convert OptimizationConfig to the pass manager's OptLevel."""
    match config:
        case OptimizationConfig.Disabled:
            OptLevel.NoOpt
        case OptimizationConfig.Enabled(level):
            match level:
                case 0: OptLevel.NoOpt
                case 1: OptLevel.Size
                case 2: OptLevel.Speed
                case _: OptLevel.Aggressive

fn optimize_mir_module(
    mir: MirModule,
    config: OptimizationConfig
) -> MirModule:
    """Optimize MIR module according to configuration.

    Dispatches to the MIR optimization pass manager which runs
    DCE, const folding, copy propagation, CSE, inlining, and
    loop optimizations based on the configured level.
    """
    val opt_level = _config_to_opt_level(config)
    match opt_level:
        case OptLevel.NoOpt:
            mir
        case _:
            optimize_module(mir, opt_level)

fn optimize_mir_module_with_stats(
    mir: MirModule,
    config: OptimizationConfig,
    show_stats: bool
) -> MirModule:
    """Optimize MIR module and optionally display statistics."""
    val opt_level = _config_to_opt_level(config)
    if show_stats:
        match config:
            case OptimizationConfig.Disabled:
                print "MIR Optimization: Disabled"
            case OptimizationConfig.Enabled(level):
                val level_name = match level:
                    case 0: "None"
                    case 1: "Size"
                    case 2: "Speed"
                    case _: "Aggressive"
                val func_count = mir.functions.keys().len()
                print "MIR Optimization: {level_name} ({func_count} functions)"
    val result = match opt_level:
        case OptLevel.NoOpt:
            mir
        case _:
            optimize_module(mir, opt_level)
    if show_stats:
        match config:
            case OptimizationConfig.Enabled(level):
                if level > 0:
                    print "MIR Optimization: Complete"
            case _:
                pass_do_nothing
    result

# ============================================================================
# Convenience Functions
# ============================================================================

fn optimize_mir_debug(mir: MirModule) -> MirModule:
    """Optimize for debug (no optimization)."""
    optimize_mir_module(mir, optimizationconfig_debug())

fn optimize_mir_size(mir: MirModule) -> MirModule:
    """Optimize for binary size."""
    optimize_mir_module(mir, optimizationconfig_size())

fn optimize_mir_speed(mir: MirModule) -> MirModule:
    """Optimize for speed (default release)."""
    optimize_mir_module(mir, optimizationconfig_speed())

fn optimize_mir_aggressive(mir: MirModule) -> MirModule:
    """Optimize aggressively (maximum performance)."""
    optimize_mir_module(mir, optimizationconfig_aggressive())

# ============================================================================
# Exports
# ============================================================================

