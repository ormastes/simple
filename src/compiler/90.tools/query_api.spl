# Compiler Query API for IDE Integration
#
# This API provides query capabilities for Language Server Protocol (LSP)
# and other IDE tooling. It allows on-demand querying of compiler state,
# symbol information, type inference results, and diagnostics.
#
# Design Philosophy:
# - Incremental: Parse only what's needed
# - Fast: Cache results, avoid redundant computation
# - Resilient: Work with partial/broken code
# - Thread-safe: Multiple queries can run concurrently

import compiler.common.dependency.symbol.{DepSymbolTable}
import compiler.frontend.treesitter_types.{ParseError}
# Local LSP edit type (no lib.common.report.emitter.lsp module exists)
struct LspTextEdit:
    range: Range
    new_text: text
import app.io  # For file I/O functions

use query_types.*
use query_helpers.*


# --- Compiler Query Context ---

# Main query context - maintains cached state for a project
class CompilerQueryContext:
    # Cached parse trees (file path -> AST)
    cached_asts: Dict<text, AST>

    # Cached symbol tables (file path -> symbol table)
    cached_symbols: Dict<text, DepSymbolTable>

    # Cached type inference results (file path -> type map)
    cached_types: Dict<text, TypeMap>

    # Cached diagnostics (file path -> diagnostics)
    cached_diagnostics: Dict<text, [Diagnostic]>

    # File modification times for cache invalidation
    file_mtimes: Dict<text, i64>

    # Project root directory
    project_root: text

    # Whether to enable incremental parsing
    incremental: bool

    # Initialize context for a project
    static fn create(project_root: text) -> CompilerQueryContext:
        CompilerQueryContext(
            cached_asts: {},
            cached_symbols: {},
            cached_types: {},
            cached_diagnostics: {},
            file_mtimes: {},
            project_root: project_root,
            incremental: true,
        )

    # --- Cache Management ---

    # Invalidate cache for a file (called when file changes)
    me invalidate_file(file_path: text):
        self.cached_asts.remove(file_path)
        self.cached_symbols.remove(file_path)
        self.cached_types.remove(file_path)
        self.cached_diagnostics.remove(file_path)
        self.file_mtimes.remove(file_path)

    # Check if cache is valid for a file
    fn is_cache_valid(file_path: text) -> bool:
        if not self.file_mtimes.contains(file_path):
            return false

        val cached_mtime = self.file_mtimes[file_path]
        val current_mtime = get_file_mtime(file_path)

        cached_mtime == current_mtime

    # --- Parsing ---

    # Parse a file and cache the result
    me parse_file(file_path: text) -> Result<AST, ParseError>:
        # Check cache
        if self.is_cache_valid(file_path) and self.cached_asts.contains(file_path):
            return Ok(self.cached_asts[file_path])

        # Parse file
        val source = file_read(file_path)
        val result = parse_source(source, file_path)

        # Update cache
        match result:
            Ok(ast):
                self.cached_asts[file_path] = ast
                self.file_mtimes[file_path] = get_file_mtime(file_path)
            Err(_):
                pass

        result

    # Parse source text (not from file)
    fn parse_source_text(source: text, file_path: text) -> Result<AST, ParseError>:
        parse_source(source, file_path)

    # --- Symbol Resolution ---

    # Get symbol table for a file
    me get_symbol_table(file_path: text) -> Result<DepSymbolTable, Error>:
        # Check cache
        if self.is_cache_valid(file_path) and self.cached_symbols.contains(file_path):
            return Ok(self.cached_symbols[file_path])

        # Parse first
        val ast_result = self.parse_file(file_path)
        if not ast_result.is_ok():
            return Err(Error("Failed to parse file"))

        val ast = match ast_result:
            Ok(value):
                value
            Err(_):
                return Err(Error("Failed to parse file"))

        # Build symbol table
        val symbol_table = build_symbol_table(ast)

        # Cache result
        self.cached_symbols[file_path] = symbol_table

        Ok(symbol_table)

    # Find symbol at a specific position
    fn symbol_at(file_path: text, pos: Position) -> Option<Symbol>:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.is_ok():
            return nil

        val symbol_table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return nil
        find_symbol_at_position(symbol_table, pos)

    # Find symbol at a specific position with scoped visibility metadata
    fn symbol_at_v2(file_path: text, pos: Position) -> Option<SymbolV2>:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.is_ok():
            return nil

        val symbol_table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return nil
        find_symbol_at_position_v2(symbol_table, pos)

    # Find all references to a symbol
    fn find_references(file_path: text, symbol: Symbol) -> [Location]:
        # Determine which files to search based on symbol kind
        val candidate_files = match symbol.kind:
            case SymbolKind.Variable, SymbolKind.Parameter:
                # Variables are file-scoped, only search current file
                [file_path]

            case SymbolKind.Function, SymbolKind.Method:
                # Functions can be imported, search importing files
                find_files_that_might_import(file_path, self.project_root)

            case SymbolKind.Class, SymbolKind.Struct, SymbolKind.Enum, SymbolKind.Trait:
                # Types can be used widely, search all files
                find_source_files(self.project_root)

            case _:
                # Default: search all files
                find_source_files(self.project_root)

        # Search each candidate file for references
        var all_refs = []
        for file in candidate_files:
            val symbol_table_result = self.get_symbol_table(file)
            match symbol_table_result:
                Ok(table):
                    val refs = find_symbol_references(table, symbol.name)
                    all_refs.extend(refs)
                Err(_):
                    pass

        all_refs

    fn find_references_v2(file_path: text, symbol: SymbolV2) -> [Location]:
        val candidate_files = match symbol.kind:
            case SymbolKind.Variable, SymbolKind.Parameter:
                [file_path]

            case SymbolKind.Function, SymbolKind.Method:
                find_files_that_might_import(file_path, self.project_root)

            case SymbolKind.Class, SymbolKind.Struct, SymbolKind.Enum, SymbolKind.Trait:
                find_source_files(self.project_root)

            case _:
                find_source_files(self.project_root)

        var all_refs: [Location] = []
        for file in candidate_files:
            val symbol_table_result = self.get_symbol_table(file)
            match symbol_table_result:
                Ok(table):
                    val refs = find_symbol_references(table, symbol.name)
                    all_refs.extend(refs)
                Err(_):
                    pass

        all_refs

    # Find definition of symbol at position
    fn find_definition(file_path: text, pos: Position) -> Option<DefinitionResult>:
        val symbol_opt = self.symbol_at(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil

        # Return the definition location
        Some(DefinitionResult(
            locations: [symbol.location],
            symbol: Some(symbol),
        ))

    # Find definition of symbol at position with scoped visibility metadata
    fn find_definition_v2(file_path: text, pos: Position) -> Option<DefinitionResultV2>:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil

        Some(DefinitionResultV2(
            locations: [symbol.location],
            symbol: Some(symbol),
        ))

    # --- Type Information ---

    # Get type information at a position
    fn type_at(file_path: text, pos: Position) -> Option<text>:
        # Check symbol first (fast path)
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        match symbol_opt:
            Some(symbol):
                return symbol.type_info
            None:
                pass

        # Try to infer type from AST
        val ast_result = self.parse_file(file_path)
        if not ast_result.is_ok():
            return nil

        val ast = match ast_result:
            Ok(value):
                value
            Err(_):
                return nil

        # Full expression type inference requires type checker integration.
        # This would involve:
        # 1. Finding the expression node at the position
        # 2. Building a type inference context with surrounding scope
        # 3. Running Hindley-Milner type inference (Algorithm W)
        # 4. Formatting the inferred type for display
        eprint("query_api: full expression type inference not yet integrated with type checker")

        nil

    # --- Completions ---

    # Get completions at a position
    fn completions_at(file_path: text, pos: Position) -> [Completion]:
        # Get symbol table for context
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.is_ok():
            return []

        val symbol_table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []

        # Get scope at position
        val scope = get_scope_at_position(symbol_table, pos)
        val scope_v2 = get_scope_at_position_v2(symbol_table, pos)

        # Build completions from:
        # 1. Variables/functions in scope
        # 2. Keywords
        # 3. Imported modules
        # 4. Struct/enum members (if in member access context)

        val completions = []

        # Add visible symbols
        for sym in scope_v2.visible_symbols:
            completions.push(symbol_to_completion_v2(sym))

        # Add keywords
        for kw in get_context_keywords(pos, scope):
            completions.push(Completion(
                label: kw,
                kind: CompletionKind.Keyword,
                detail: nil,
                documentation: nil,
                insert_text: kw,
                sort_priority: 10,
            ))

        completions

    # --- Hover Information ---

    # Get hover information at a position
    fn hover_at(file_path: text, pos: Position) -> Option<HoverInfo>:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil

        # Build markdown content
        var content = "```simple\n"
        content = content + symbol.name

        match symbol.type_info:
            Some(type_info):
                content = content + ": " + type_info
            None:
                pass

        content = content + "\n```\n"

        match symbol.doc_comment:
            Some(doc_comment):
                content = content + "\n" + doc_comment
            None:
                pass

        Some(HoverInfo(
            range: position_to_range(pos),
            contents: content,
            type_info: symbol.type_info,
        ))

    # --- Diagnostics ---

    # Get diagnostics for a file
    me get_diagnostics(file_path: text) -> [Diagnostic]:
        # Check cache
        if self.is_cache_valid(file_path) and self.cached_diagnostics.contains(file_path):
            return self.cached_diagnostics[file_path]

        var diagnostics = []

        # Parse and collect parse errors
        val ast_result = self.parse_file(file_path)
        match ast_result:
            Ok(ast):
                val type_errors = type_check_ast(ast)
                for err in type_errors:
                    diagnostics.push(type_error_to_diagnostic(err))
            Err(parse_error):
                diagnostics.push(parse_error_to_diagnostic(parse_error))

        # Cache result
        self.cached_diagnostics[file_path] = diagnostics

        diagnostics

    # --- Document Symbols ---

    # Get all symbols in a document (for outline view)
    fn document_symbols(file_path: text) -> [Symbol]:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.is_ok():
            return []

        val symbol_table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []
        extract_all_symbols(symbol_table)

    # Get all symbols in a document with scoped visibility metadata
    fn document_symbols_v2(file_path: text) -> [SymbolV2]:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.is_ok():
            return []

        val symbol_table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []
        extract_all_symbols_v2(symbol_table)

    # --- Workspace Symbols ---

    # Search for symbols across the workspace
    fn workspace_symbols(query: text) -> [Symbol]:
        # Get all source files in project
        val files = find_source_files(self.project_root)

        # Search each file for matching symbols
        var matches = []
        for file in files:
            val symbols = self.document_symbols(file)
            for symbol in symbols:
                if symbol_matches_query(symbol.name, query):
                    matches.push(symbol)

        # Rank results by match quality
        matches.sort_by(rank_symbol_match(_, query))

        # Limit to top 100 results
        if matches.len() > 100:
            matches[0:100]
        else:
            matches

    # Search for symbols across the workspace with scoped visibility metadata
    fn workspace_symbols_v2(query: text) -> [SymbolV2]:
        val files = find_source_files(self.project_root)

        var matches: [SymbolV2] = []
        for file in files:
            val symbols = self.document_symbols_v2(file)
            for symbol in symbols:
                if symbol_matches_query(symbol.name, query):
                    matches.push(symbol)

        matches.sort_by(rank_symbol_match_v2(_, query))

        if matches.len() > 100:
            matches[0:100]
        else:
            matches

    # --- Signature Help ---

    fn signature_help(file_path: text, pos: Position) -> Option<SignatureHelp>:
        # Find the function being called at the cursor position
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil
        if symbol.kind != SymbolKind.Function and symbol.kind != SymbolKind.Method:
            return nil

        # Build parameter info from type signature
        var params: [ParameterInfo] = []
        var signature_suffix = ""
        match symbol.type_info:
            Some(sig):
                # Parse parameter names from type signature (e.g., "fn(x: i64, y: text) -> bool")
                params.push(ParameterInfo(label: sig, documentation: nil))
                signature_suffix = ": " + sig
            None:
                pass

        val sig_info = SignatureInfo(
            label: symbol.name + signature_suffix,
            documentation: symbol.doc_comment,
            parameters: params
        )

        Some(SignatureHelp(
            signatures: [sig_info],
            active_signature: 0,
            active_parameter: 0
        ))

    # --- Rename ---

    fn prepare_rename(file_path: text, pos: Position) -> Option<Range>:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil
        # Return the range of the symbol name at the definition
        Some(Range(
            start: symbol.location.start,
            end: Position(
                line: symbol.location.start.line,
                column: symbol.location.start.column + symbol.name.len()
            )
        ))

    me rename(file_path: text, pos: Position, new_name: text) -> Option<WorkspaceEdit>:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return nil
        val refs = self.find_references_v2(file_path, symbol)

        var edits: [RenameEdit] = []
        for loc in refs:
            edits.push(RenameEdit(
                file: loc.file,
                range: Range(start: loc.start, end: loc.end),
                new_text: new_name
            ))

        Some(WorkspaceEdit(edits: edits))

    # --- Code Actions ---

    fn code_actions(file_path: text, range_val: Range) -> [CodeAction]:
        var actions: [CodeAction] = []

        # Check diagnostics in range to offer quick fixes
        val diagnostics = self.get_diagnostics(file_path)
        for diag in diagnostics:
            if diag.range.start.line >= range_val.start.line and diag.range.end.line <= range_val.end.line:
                # Offer "add import" action for "not found" errors
                if diag.message.contains("not found"):
                    actions.push(CodeAction(
                        title: "Add import for missing symbol",
                        kind: "quickfix",
                        edits: [],
                        is_preferred: true,
                        diagnostics: [diag]
                    ))

        actions

    # --- Call Hierarchy ---

    fn call_hierarchy_prepare(file_path: text, pos: Position) -> [CallHierarchyItem]:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return []
        if symbol.kind != SymbolKind.Function and symbol.kind != SymbolKind.Method:
            return []

        [CallHierarchyItem(
            name: symbol.name,
            kind: symbol.kind,
            location: symbol.location,
            detail: symbol.type_info
        )]

    fn call_hierarchy_incoming(item: CallHierarchyItem) -> [CallHierarchyIncomingCall]:
        # Search all files for call sites of this function
        val all_files = find_source_files(self.project_root)
        var incoming: [CallHierarchyIncomingCall] = []

        for file in all_files:
            val symbol_table_result = self.get_symbol_table(file)
            match symbol_table_result:
                Ok(table):
                    val refs = find_symbol_references(table, item.name)
                    for ref_loc in refs:
                        # Each reference is a potential call site
                        val caller = CallHierarchyItem(
                            name: file,
                            kind: SymbolKind.Function,
                            location: ref_loc,
                            detail: nil
                        )
                        incoming.push(CallHierarchyIncomingCall(
                            from_item: caller,
                            from_ranges: [Range(start: ref_loc.start, end: ref_loc.end)]
                        ))
                Err(_):
                    pass

        incoming

    fn call_hierarchy_outgoing(item: CallHierarchyItem) -> [CallHierarchyOutgoingCall]:
        # Find functions called within this function's body
        val file_path = item.location.file
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.ok.?:
            return []

        val table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []
        val all_symbols = extract_all_symbols_v2(table)

        var outgoing: [CallHierarchyOutgoingCall] = []
        for sym in all_symbols:
            if sym.kind == SymbolKind.Function or sym.kind == SymbolKind.Method:
                val refs = find_symbol_references(table, sym.name)
                for ref_loc in refs:
                    # Check if reference is within the item's function body
                    if (ref_loc.start.line >= item.location.start.line and
                        ref_loc.end.line <= item.location.end.line):
                        val callee = CallHierarchyItem(
                            name: sym.name,
                            kind: sym.kind,
                            location: sym.location,
                            detail: sym.type_info
                        )
                        outgoing.push(CallHierarchyOutgoingCall(
                            to_item: callee,
                            from_ranges: [Range(start: ref_loc.start, end: ref_loc.end)]
                        ))

        outgoing

    # --- Type Hierarchy ---

    fn type_hierarchy_prepare(file_path: text, pos: Position) -> [TypeHierarchyItem]:
        val symbol_opt = self.symbol_at_v2(file_path, pos)
        val symbol = match symbol_opt:
            Some(value):
                value
            None:
                return []
        match symbol.kind:
            case SymbolKind.Class | SymbolKind.Struct | SymbolKind.Enum | SymbolKind.Trait:
                [TypeHierarchyItem(
                    name: symbol.name,
                    kind: symbol.kind,
                    location: symbol.location,
                    detail: symbol.type_info
                )]
            case _:
                []

    fn type_hierarchy_supertypes(item: TypeHierarchyItem) -> [TypeHierarchyItem]:
        # Search for trait implementations (impl Trait for Type)
        val all_files = find_source_files(self.project_root)
        var supertypes: [TypeHierarchyItem] = []

        for file in all_files:
            if io.file_exists(file):
                val content = io.file_read(file)
                # Look for "impl TraitName for item.name" patterns
                if content.contains("impl ") and content.contains(item.name):
                    val symbol_table_result = self.get_symbol_table(file)
                    match symbol_table_result:
                        Ok(table):
                            val symbols = extract_all_symbols_v2(table)
                            for sym in symbols:
                                if sym.kind == SymbolKind.Trait:
                                    supertypes.push(TypeHierarchyItem(
                                        name: sym.name,
                                        kind: sym.kind,
                                        location: sym.location,
                                        detail: sym.type_info
                                    ))
                        Err(_):
                            pass

        supertypes

    fn type_hierarchy_subtypes(item: TypeHierarchyItem) -> [TypeHierarchyItem]:
        # Search for types implementing this trait
        val all_files = find_source_files(self.project_root)
        var subtypes: [TypeHierarchyItem] = []

        for file in all_files:
            if io.file_exists(file):
                val content = io.file_read(file)
                # Look for "impl item.name for TypeName" patterns
                if content.contains("impl {item.name}"):
                    val symbol_table_result = self.get_symbol_table(file)
                    match symbol_table_result:
                        Ok(table):
                            val symbols = extract_all_symbols_v2(table)
                            for sym in symbols:
                                if (sym.kind == SymbolKind.Class or
                                    sym.kind == SymbolKind.Struct or
                                    sym.kind == SymbolKind.Enum):
                                    subtypes.push(TypeHierarchyItem(
                                        name: sym.name,
                                        kind: sym.kind,
                                        location: sym.location,
                                        detail: sym.type_info
                                    ))
                        Err(_):
                            pass

        subtypes

    # --- Semantic Tokens ---

    fn semantic_tokens_full(file_path: text) -> [SemanticToken]:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.ok.?:
            return []

        val table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []
        val symbols = extract_all_symbols_v2(table)

        var tokens: [SemanticToken] = []
        var prev_line: i64 = 0
        var prev_start: i64 = 0

        for sym in symbols:
            val token_type = match sym.kind:
                case SymbolKind.Function | SymbolKind.Method: SemanticTokenType.Function
                case SymbolKind.Class: SemanticTokenType.Class
                case SymbolKind.Struct: SemanticTokenType.Struct
                case SymbolKind.Enum: SemanticTokenType.Enum
                case SymbolKind.Trait: SemanticTokenType.Type
                case SymbolKind.Variable: SemanticTokenType.Variable
                case SymbolKind.Parameter: SemanticTokenType.Parameter
                case SymbolKind.Field: SemanticTokenType.Property
                case SymbolKind.EnumVariant: SemanticTokenType.EnumMember
                case SymbolKind.Module: SemanticTokenType.Namespace
                case _: SemanticTokenType.Variable

            val delta_line = sym.location.start.line - prev_line
            val delta_start = if delta_line == 0: sym.location.start.column - prev_start else: sym.location.start.column

            tokens.push(SemanticToken(
                delta_line: delta_line,
                delta_start: delta_start,
                length: sym.name.len(),
                token_type: token_type,
                token_modifiers: 0
            ))

            prev_line = sym.location.start.line
            prev_start = sym.location.start.column

        tokens

    fn semantic_tokens_range(file_path: text, range_val: Range) -> [SemanticToken]:
        val all_tokens = self.semantic_tokens_full(file_path)
        # Filter tokens within range by reconstructing absolute positions
        var filtered: [SemanticToken] = []
        var current_line: i64 = 0
        var current_start: i64 = 0

        for token in all_tokens:
            current_line = current_line + token.delta_line
            current_start = if token.delta_line == 0: current_start + token.delta_start else: token.delta_start

            if (current_line >= range_val.start.line and
                current_line <= range_val.end.line):
                filtered.push(token)

        filtered

    # --- Inlay Hints ---

    fn inlay_hints(file_path: text, range_val: Range) -> [InlayHint]:
        val symbol_table_result = self.get_symbol_table(file_path)
        if not symbol_table_result.ok.?:
            return []

        val table = match symbol_table_result:
            Ok(value):
                value
            Err(_):
                return []
        val symbols = extract_all_symbols_v2(table)

        var hints: [InlayHint] = []
        for sym in symbols:
            # Only emit type hints for variables with inferred types
            if sym.kind == SymbolKind.Variable:
                match sym.type_info:
                    Some(type_info):
                        val line = sym.location.start.line
                        if line >= range_val.start.line and line <= range_val.end.line:
                            hints.push(InlayHint(
                                position: Position(
                                    line: line,
                                    column: sym.location.end.column
                                ),
                                label: ": " + type_info,
                                kind: InlayHintKind.TypeHint
                            ))
                    None:
                        pass

        hints

    # --- Selection Range ---

    fn selection_ranges(file_path: text, positions: [Position]) -> [SelectionRangeEntry]:
        val ast_result = self.parse_file(file_path)
        if not ast_result.is_ok():
            return []

        var entries: [SelectionRangeEntry] = []

        for pos in positions:
            # Find the innermost symbol at this position and build hierarchy
            val symbol_opt = self.symbol_at_v2(file_path, pos)
            match symbol_opt:
                Some(sym):
                    # Innermost range: the symbol itself
                    val inner_idx = entries.len()
                    entries.push(SelectionRangeEntry(
                        range: Range(start: sym.location.start, end: sym.location.end),
                        parent_index: -1
                    ))
                None:
                    # No symbol found — return the full line range
                    entries.push(SelectionRangeEntry(
                        range: Range(
                            start: Position(line: pos.line, column: 0),
                            end: Position(line: pos.line + 1, column: 0)
                        ),
                        parent_index: -1
                    ))

        entries

    # --- Document Formatting ---

    fn format_document(file_path: text) -> [LspTextEdit]:
        # Read file and apply basic formatting: normalize indentation and trailing whitespace
        if not io.file_exists(file_path):
            return []

        val content = io.file_read(file_path)
        val lines = content.split("\n")
        var edits: [LspTextEdit] = []

        var line_num: i64 = 0
        for line in lines:
            # Trim trailing whitespace
            val trimmed = line.trim_end()
            if trimmed != line:
                edits.push(LspTextEdit(
                    range: Range(
                        start: Position(line: line_num, column: trimmed.len()),
                        end: Position(line: line_num, column: line.len())
                    ),
                    new_text: ""
                ))
            line_num = line_num + 1

        edits
