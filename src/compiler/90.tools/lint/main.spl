# Simple Language Linter
# Semantic lints for code quality and safety
# Usage: simple_lint <file.spl> [--deny-all] [--warn-all]

# I/O imports
use std.nogc_sync_mut.io.file_ops (file_read, file_exists, file_write)
use std.nogc_sync_mut.io.dir_ops (is_dir)
use app.io.cli_ops (get_args)

# Logging imports
use std.log.{error, info}

# Import EasyFix data types from stdlib
use std.tooling.easy_fix.*
use common.ui.theme_package.{validate_default_theme_package}

# Async file I/O wrapper
async fn read_file(path: String) -> Result<String, String>:
    val file_content = file_read(path)
    if file_content == "":
        return Err("Failed to read file: {path}")
    return Ok(file_content)

# Lint levels
enum LintLevel:
    Allow
    Warn
    Deny

# All configurable lint names.
fn all_lint_names() -> [text]:
    ["primitive_api", "bare_bool", "print_in_test_spec", "todo_format",
     "spipe_no_print_based_tests", "spipe_missing_docstrings",
     "spipe_minimal_docstrings", "spipe_manual_assertions",
     "spipe_placeholder_tests", "spipe_empty_examples",
     "spipe_boolean_wrapper_assertions",
     "unnamed_duplicate_typed_args", "resource_leak",
     "wildcard_match", "non_exhaustive_match",
     "export_outside_init", "init_boundary_violation",
     "bypass_with_code_files", "unknown_decorator", "stub_impl",
     "unknown_attribute", "too_many_arguments",
     "required_comment",
     "ui_no_raw_widget_kind", "ui_no_raw_variant", "ui_no_raw_theme_name"]

# Build the default levels dict for all configurable lint names.
# Most are Warn; exceptions: spipe_no_print_based_tests=Deny,
# spipe_placeholder_tests=Deny, spipe_empty_examples=Deny,
# spipe_boolean_wrapper_assertions=Deny, export_outside_init=Deny,
# stub_impl=Deny, wildcard_match=Allow.
fn build_default_levels() -> Dict<String, String>:
    var levels: Dict<String, String> = {}
    levels["primitive_api"] = "warn"
    levels["bare_bool"] = "warn"
    levels["print_in_test_spec"] = "warn"
    levels["todo_format"] = "warn"
    levels["spipe_no_print_based_tests"] = "deny"
    levels["spipe_missing_docstrings"] = "warn"
    levels["spipe_minimal_docstrings"] = "warn"
    levels["spipe_manual_assertions"] = "warn"
    levels["spipe_placeholder_tests"] = "deny"
    levels["spipe_empty_examples"] = "deny"
    levels["spipe_boolean_wrapper_assertions"] = "deny"
    levels["unnamed_duplicate_typed_args"] = "warn"
    levels["resource_leak"] = "warn"
    levels["wildcard_match"] = "allow"
    levels["non_exhaustive_match"] = "warn"
    levels["export_outside_init"] = "deny"
    levels["init_boundary_violation"] = "warn"
    levels["bypass_with_code_files"] = "warn"
    levels["unknown_decorator"] = "warn"
    levels["stub_impl"] = "deny"
    levels["unknown_attribute"] = "warn"
    levels["too_many_arguments"] = "warn"
    levels["required_comment"] = "warn"
    levels["ui_no_raw_widget_kind"] = "warn"
    levels["ui_no_raw_variant"] = "warn"
    levels["ui_no_raw_theme_name"] = "warn"
    levels

# Parse a level string ("allow", "warn", "deny") into LintLevel.
# Returns nil for unknown strings.
fn parse_lint_level(level_str: String) -> Option<LintLevel>:
    val lower = level_str.lower()
    if lower == "allow":
        return Some(LintLevel.Allow)
    if lower == "warn":
        return Some(LintLevel.Warn)
    if lower == "deny":
        return Some(LintLevel.Deny)
    nil

# Lint configuration — overrides for lint levels.
# Loaded from simple.sdn [lints] section and/or file-level attributes.
class LintConfig:
    levels: Dict<String, String>

    # Create a default config (all defaults, no overrides).
    static fn new() -> LintConfig:
        LintConfig(levels: {})

    # Load config from an SDN file.  Parses the [lints] section.
    static fn from_sdn_file(path: String) -> LintConfig:
        if not file_exists(path):
            return LintConfig.new()
        val content = file_read(path)
        if content == "":
            return LintConfig.new()
        LintConfig.from_sdn_string(content)

    # Parse config from an SDN string.
    static fn from_sdn_string(content: String) -> LintConfig:
        var config = LintConfig.new()
        var in_lints_section = false

        val lines = content.split("\n")
        for line in lines:
            val trimmed = line.trim()

            # Skip empty lines and comments
            if trimmed == "" or trimmed.starts_with("#"):
                continue

            # Check for [lints] section header
            if trimmed == "[lints]":
                in_lints_section = true
                continue

            # Any other section header exits [lints]
            if trimmed.starts_with("[") and trimmed.ends_with("]"):
                in_lints_section = false
                continue

            # Parse lint = "level" entries inside [lints]
            if in_lints_section and trimmed.contains("="):
                val parts = trimmed.split("=")
                if parts.len() >= 2:
                    val lint_name = parts[0].trim()
                    var level_str = parts[1].trim()
                    # Strip surrounding quotes
                    level_str = level_str.replace("\"", "").replace("'", "").trim()

                    # Validate the lint name is known
                    if all_lint_names().contains(lint_name):
                        config.levels[lint_name] = level_str
                    elif lint_name == "unknown_annotation":
                        # Meta-lint: sets both unknown_decorator and unknown_attribute
                        config.levels["unknown_decorator"] = level_str
                        config.levels["unknown_attribute"] = level_str

        config

    # Get the effective level for a lint name.
    # Checks overrides first, then falls back to built-in defaults.
    fn get_level(lint_name: String) -> LintLevel:
        var level_str = ""
        if self.levels.has(lint_name):
            level_str = self.levels[lint_name]
        else:
            val defaults = build_default_levels()
            if defaults.has(lint_name):
                level_str = defaults[lint_name]
            else:
                return LintLevel.Warn  # Unknown lint defaults to Warn

        val parsed = parse_lint_level(level_str)
        match parsed:
            case Some(level):
                return level
            case nil:
                return LintLevel.Warn

    # Set the level for a specific lint name.
    me set_level(lint_name: String, level: LintLevel):
        match level:
            case Allow:
                self.levels[lint_name] = "allow"
            case Warn:
                self.levels[lint_name] = "warn"
            case Deny:
                self.levels[lint_name] = "deny"

    # Apply file-level attribute overrides.
    # Scans the first N lines (before first definition) for:
    #   @allow(lint1, lint2)
    #   @warn(lint1, lint2)
    #   @deny(lint1, lint2)
    #   @allow(lint1)  (inner attribute)
    me apply_file_attributes(content: String):
        val lines = content.split("\n")
        for line in lines:
            val trimmed = line.trim()

            # Stop scanning at the first definition (fn, class, enum, struct, trait, etc.)
            if trimmed.starts_with("fn ") or trimmed.starts_with("me ") or trimmed.starts_with("class ") or trimmed.starts_with("enum ") or trimmed.starts_with("struct ") or trimmed.starts_with("trait "):
                return

            # Also stop at module-level val/var assignments that aren't attributes
            # but continue past use/import and comments
            if trimmed.starts_with("val ") or trimmed.starts_with("var "):
                return

            # Match @allow(...), @warn(...), @deny(...)
            var attr_line = trimmed

            if not attr_line.starts_with("@"):
                continue

            # Parse @allow(...), @warn(...), @deny(...)
            var level_opt: Option<LintLevel> = nil
            var inner_start = 0

            if attr_line.starts_with("@allow("):
                level_opt = Some(LintLevel.Allow)
                inner_start = 7
            elif attr_line.starts_with("@warn("):
                level_opt = Some(LintLevel.Warn)
                inner_start = 6
            elif attr_line.starts_with("@deny("):
                level_opt = Some(LintLevel.Deny)
                inner_start = 6

            match level_opt:
                case nil:
                    continue
                case Some(level):
                    # Extract the content between parens
                    val close_paren = attr_line.find(")")
                    if close_paren < 0:
                        continue
                    val lint_list_str = attr_line.slice(inner_start, close_paren)
                    val lint_names = lint_list_str.split(",")
                    for name in lint_names:
                        val clean_name = name.trim()
                        if clean_name == "":
                            continue
                        # Handle meta-lint unknown_annotation
                        if clean_name == "unknown_annotation":
                            self.set_level("unknown_decorator", level)
                            self.set_level("unknown_attribute", level)
                        elif all_lint_names().contains(clean_name):
                            self.set_level(clean_name, level)

    # Create a child config that inherits all current settings.
    fn child() -> LintConfig:
        var new_levels: Dict<String, String> = {}
        for key in self.levels.keys():
            new_levels[key] = self.levels[key]
        LintConfig(levels: new_levels)

# Check if a lint result should be suppressed based on config.
# Returns true if the result should be kept (not suppressed).
fn should_keep_lint_result(config: LintConfig, lint_code: String) -> Bool:
    # Map internal lint codes to config lint names where possible
    val config_name = map_lint_code_to_config_name(lint_code)
    if config_name == "":
        return true  # Unknown lint code — keep it
    val level = config.get_level(config_name)
    match level:
        case Allow:
            return false  # Suppressed
        case Warn:
            return true
        case Deny:
            return true

# Override lint level from config if Deny.
fn apply_config_level(config: LintConfig, lint_code: String, original_level: LintLevel) -> LintLevel:
    val config_name = map_lint_code_to_config_name(lint_code)
    if config_name == "":
        return original_level
    val config_level = config.get_level(config_name)
    match config_level:
        case Deny:
            return LintLevel.Deny
        case Allow:
            return original_level  # Suppression handled by should_keep_lint_result
        case Warn:
            return original_level

# Map internal lint code (e.g. "T001") to config name (e.g. "todo_format").
# Returns "" for codes with no direct mapping.
fn map_lint_code_to_config_name(code: String) -> String:
    if code == "primitive_api":
        return "primitive_api"
    if code == "bare_bool":
        return "bare_bool"
    if code == "T001" or code == "T002" or code == "T003" or code == "T004":
        return "todo_format"
    if code == "ARG001" or code == "ARG002":
        return "too_many_arguments"
    if code == "STUB001" or code == "STUB002" or code == "STUB003":
        return "stub_impl"
    if code == "SPIPE001" or code == "SPIPE002" or code == "SPIPE003":
        return "spipe_placeholder_tests"
    if code == "SPIPE004":
        return "spipe_no_print_based_tests"
    if code == "SPIPE005":
        return "spipe_empty_examples"
    if code == "SPIPE006":
        return "spipe_boolean_wrapper_assertions"
    if code == "I001" or code == "I002" or code == "I003":
        return "init_boundary_violation"
    if code == "D001":
        return ""  # database lint has no config mapping
    if code == "W001" or code == "W002" or code == "W003":
        return ""  # unused variable/import/dead code — no config mapping
    if code == "ST001" or code == "ST002" or code == "ST003":
        return ""  # style lints — no config mapping
    if code == "C002":
        return "non_exhaustive_match"
    if (code == "MEXH001" or code == "MEXH002" or code == "MEXH003" or
        code == "MEXH004" or code == "MEXH005"):
        return "non_exhaustive_match"
    if code == "S001" or code == "S002" or code == "S003":
        return ""  # safety lints — no config mapping
    if code == "CC001" or code == "CC002":
        return ""  # concurrency lints — no config mapping
    if code == "CLOS001":
        return ""  # closure capture — no config mapping
    if code == "RET001":
        return ""  # ignored return — no config mapping
    if code == "BOOL001":
        return ""  # multiline bool — no config mapping
    if code == "REQC001" or code == "REQC002" or code == "REQC003" or code == "REQC004":
        return "required_comment"
    if code == "SAFE001" or code == "SAFE003":
        return ""  # safety — no config mapping
    if code == "W0401" or code == "W0402" or code == "W0403":
        return ""  # visibility — no config mapping
    if code == "UI001":
        return "ui_no_raw_widget_kind"
    if code == "UI002":
        return "ui_no_raw_variant"
    if code == "UI003":
        return "ui_no_raw_theme_name"
    ""

# Try to find simple.sdn by walking up from a file path.
fn find_project_sdn(file_path: String) -> String:
    # Try to find simple.sdn in parent directories
    var dir = get_parent_directory(file_path)
    var depth = 0
    while depth < 10:
        val candidate = "{dir}/simple.sdn"
        if file_exists(candidate):
            return candidate
        val parent = get_parent_directory(dir)
        if parent == dir:
            return ""  # Reached root
        dir = parent
        depth = depth + 1
    ""

# Lint categories
enum LintCategory:
    Safety      # Memory safety, null checks
    Correctness # Logic errors, type mismatches
    Warning     # Potential issues
    Style       # Code style recommendations
    Concurrency # Concurrency-related issues

class Lint:
    code: String
    level: LintLevel
    category: LintCategory
    message: String
    fix_hint: Option<String>
    easy_fix: Option<EasyFix>

    fn new(code: String, level: LintLevel, category: LintCategory, message: String) -> Lint:
        Lint(
            code: code,
            level: level,
            category: category,
            message: message,
            fix_hint: nil,
            easy_fix: nil
        )

    fn with_fix(hint: String) -> Lint:
        Lint(
            code: self.code,
            level: self.level,
            category: self.category,
            message: self.message,
            fix_hint: Some(hint),
            easy_fix: self.easy_fix
        )

    fn with_easy_fix(fix: EasyFix) -> Lint:
        Lint(
            code: self.code,
            level: self.level,
            category: self.category,
            message: self.message,
            fix_hint: self.fix_hint,
            easy_fix: Some(fix)
        )

class LintResult:
    file_path: String
    line: Int
    column: Int
    lint: Lint

    fn new(file_path: String, line: Int, column: Int, lint: Lint) -> LintResult:
        LintResult(
            file_path: file_path,
            line: line,
            column: column,
            lint: lint
        )

    fn format() -> String:
        var level_str = "unknown"
        match self.lint.level:
            case Allow:
                level_str = "allow"
            case Warn:
                level_str = "warning"
            case Deny:
                level_str = "error"

        var output = self.file_path + ":" + self.line.to_string() + ":" + self.column.to_string() + ": " + level_str + "[" + self.lint.code + "]: " + self.lint.message

        match self.lint.fix_hint:
            case Some(hint):
                output = output + "\n" + "  hint: " + hint
            case nil:
                val _ = 0

        match self.lint.easy_fix:
            case Some(fix):
                output = output + "\n" + "  fix: available [{fix.id}] ({fix.confidence_str()})"
            case nil:
                val _ = 0

        return output

    fn has_easy_fix() -> Bool:
        self.lint.easy_fix.? == true

# Valid TODO areas and priorities
fn _todo_areas() -> [text]:
    ["runtime", "codegen", "compiler", "parser", "type",
     "stdlib", "gpu", "ui", "test", "driver", "loader", "pkg", "sdn"]

fn _todo_priorities() -> [text]:
    ["P0", "P1", "P2", "P3", "critical", "high", "medium", "low"]

class Linter:
    lints: [Lint]
    results: [LintResult]
    config: LintConfig

    static fn new() -> Linter:
        var lints = []

        # Safety lints
        lints.push(Lint.new("S001", LintLevel.Deny, LintCategory.Safety,
            "Unused Result type (must use .unwrap(), .expect(), or match)"))
        lints.push(Lint.new("S002", LintLevel.Deny, LintCategory.Safety,
            "Potential null pointer dereference"))
        lints.push(Lint.new("S003", LintLevel.Warn, LintCategory.Safety,
            "Unsafe block without safety comment"))

        # Correctness lints
        lints.push(Lint.new("C001", LintLevel.Deny, LintCategory.Correctness,
            "Unreachable code after return/break/continue"))
        lints.push(Lint.new("C002", LintLevel.Warn, LintCategory.Correctness,
            "Non-exhaustive match (add catch-all case)"))
        lints.push(Lint.new("MEXH001", LintLevel.Warn, LintCategory.Correctness,
            "Non-exhaustive match on enum: missing variant(s)"))
        lints.push(Lint.new("MEXH002", LintLevel.Warn, LintCategory.Correctness,
            "Match expression has no wildcard/default case"))
        lints.push(Lint.new("MEXH003", LintLevel.Warn, LintCategory.Correctness,
            "Non-exhaustive boolean match: missing true or false"))
        lints.push(Lint.new("MEXH004", LintLevel.Warn, LintCategory.Correctness,
            "Unreachable match arm (after wildcard or duplicate pattern)"))
        lints.push(Lint.new("MEXH005", LintLevel.Warn, LintCategory.Correctness,
            "Non-exhaustive Option/Result match: missing variant(s)"))
        lints.push(Lint.new("C003", LintLevel.Warn, LintCategory.Correctness,
            "Comparison of incompatible types"))

        # Warning lints
        lints.push(Lint.new("W001", LintLevel.Warn, LintCategory.Warning,
            "Unused variable (prefix with _ to silence)"))
        lints.push(Lint.new("W002", LintLevel.Warn, LintCategory.Warning,
            "Unused import"))
        lints.push(Lint.new("W003", LintLevel.Warn, LintCategory.Warning,
            "Dead code"))

        # Style lints
        lints.push(Lint.new("ST001", LintLevel.Allow, LintCategory.Style,
            "Function name should be snake_case"))
        lints.push(Lint.new("ST002", LintLevel.Allow, LintCategory.Style,
            "Class name should be PascalCase"))
        lints.push(Lint.new("ST003", LintLevel.Allow, LintCategory.Style,
            "Constant should be UPPER_SNAKE_CASE"))

        # Concurrency lints
        lints.push(Lint.new("CC001", LintLevel.Deny, LintCategory.Concurrency,
            "Shared mutable state without synchronization"))
        lints.push(Lint.new("CC002", LintLevel.Warn, LintCategory.Concurrency,
            "Send type used without thread safety guarantee"))

        # Database lints (D00x rules)
        lints.push(Lint.new("D001", LintLevel.Deny, LintCategory.Correctness,
            "Direct .sdn file write detected. Use lib.database instead."))

        # TODO/FIXME format lints (T00x rules)
        lints.push(Lint.new("T001", LintLevel.Warn, LintCategory.Style,
            "TODO/FIXME missing [area][priority] format"))
        lints.push(Lint.new("T002", LintLevel.Warn, LintCategory.Style,
            "TODO/FIXME has invalid area"))
        lints.push(Lint.new("T003", LintLevel.Warn, LintCategory.Style,
            "TODO/FIXME has invalid priority"))
        lints.push(Lint.new("T004", LintLevel.Deny, LintCategory.Style,
            "P0/critical TODO must have issue number"))

        # Import/Module lints (I00x rules)
        lints.push(Lint.new("I001", LintLevel.Deny, LintCategory.Correctness,
            "Unfold subpackage directory does not exist"))
        lints.push(Lint.new("I002", LintLevel.Deny, LintCategory.Correctness,
            "Unfold subpackage missing __init__.spl"))
        lints.push(Lint.new("I003", LintLevel.Deny, LintCategory.Correctness,
            "Unfold declaration in non-directory module"))

        # Stub implementation lints (STUB00x rules)
        lints.push(Lint.new("STUB001", LintLevel.Deny, LintCategory.Warning,
            "Function with params returns trivial value (params unused) — possible stub"))
        lints.push(Lint.new("STUB002", LintLevel.Allow, LintCategory.Warning,
            "Zero-param function returns default value — possible stub"))
        lints.push(Lint.new("STUB003", LintLevel.Deny, LintCategory.Warning,
            "Explicit pass_todo placeholder in production code"))

        # SPipe quality lints (SPIPE00x rules)
        lints.push(Lint.new("SPIPE001", LintLevel.Deny, LintCategory.Correctness,
            "Tautological SPipe assertion — replace placeholder success with a real assertion"))
        lints.push(Lint.new("SPIPE002", LintLevel.Deny, LintCategory.Correctness,
            "Placeholder pass helper in SPipe example — use skip: or assert a real capability/result"))
        lints.push(Lint.new("SPIPE003", LintLevel.Deny, LintCategory.Correctness,
            "Placeholder success arm in SPipe match — assert returned data or use skip:"))
        lints.push(Lint.new("SPIPE004", LintLevel.Deny, LintCategory.Correctness,
            "Print-based skip placeholder in SPipe example — use skip: instead of print-and-return"))
        lints.push(Lint.new("SPIPE005", LintLevel.Deny, LintCategory.Correctness,
            "SPipe example has no real assertion or sanctioned skip"))
        lints.push(Lint.new("SPIPE006", LintLevel.Deny, LintCategory.Correctness,
            "Boolean-wrapper assertion in SPipe example — assert the concrete value directly"))

        # Argument count lints (ARG00x rules)
        lints.push(Lint.new("ARG001", LintLevel.Warn, LintCategory.Style,
            "Function has too many parameters (> 7) — consider grouping into struct"))
        lints.push(Lint.new("ARG002", LintLevel.Deny, LintCategory.Style,
            "Function has too many parameters (> 12) — must refactor"))

        # Required comment lints (REQC00x rules)
        lints.push(Lint.new("REQC001", LintLevel.Warn, LintCategory.Warning,
            "pass_* used without a comment string"))
        lints.push(Lint.new("REQC002", LintLevel.Warn, LintCategory.Warning,
            "Dangerous keyword used without a comment string"))
        lints.push(Lint.new("REQC003", LintLevel.Warn, LintCategory.Warning,
            "todo used without what-remains and next-step strings"))
        lints.push(Lint.new("REQC004", LintLevel.Warn, LintCategory.Warning,
            "Wildcard match arm used without a rationale"))

        # UI typed-API lints (UI00x rules)
        lints.push(Lint.new("UI001", LintLevel.Warn, LintCategory.Style,
            "Raw string literal passed as WidgetNode kind — use WidgetKind.X.to_wire()"))
        lints.push(Lint.new("UI002", LintLevel.Warn, LintCategory.Style,
            "Raw string literal in action position — use with_on_typed_action with Action or CommonAction"))
        lints.push(Lint.new("UI003", LintLevel.Warn, LintCategory.Style,
            "Raw theme-name string literal — use ThemeId enum variant"))

        # Try to load project-level lint config from simple.sdn
        # Search in common project root locations
        var config = LintConfig.new()
        val sdn_path = find_project_sdn(".")
        if sdn_path != "":
            config = LintConfig.from_sdn_file(sdn_path)

        Linter(lints: lints, results: [], config: config)
    
    fn lint_source(self, path: String, content: String) -> [LintResult]:
        self.results = []

        # Apply file-level attribute overrides to a child config so they don't
        # leak between files.
        var file_config = self.config.child()
        file_config.apply_file_attributes(content)

        # Also try to find simple.sdn relative to this file
        val sdn_for_file = find_project_sdn(path)
        if sdn_for_file != "":
            val file_sdn_config = LintConfig.from_sdn_file(sdn_for_file)
            for key in file_sdn_config.levels.keys():
                # Only apply if not already overridden by file-level attrs
                if not file_config.levels.has(key):
                    file_config.levels[key] = file_sdn_config.levels[key]

        # Run simple pattern-based lints
        val lines = content.split("\n")
        var line_num = 1

        for line in lines:
            self.check_line(path, line_num, line)
            line_num = line_num + 1

        self.check_spipe_quality(path, content)
        self.check_ui_raw_widget_kind(path, content)
        self.check_ui_raw_variant(path, content)
        self.check_ui_raw_theme_name(path, content)
        self.check_theme_package(path)

        # Run shared EasyFix rules and attach as lint results
        val shared_fixes = check_all_rules(content, path)
        for fix in shared_fixes:
            val rule_id = fix.id.split(":")[1]
            val lint = Lint.new(rule_id, LintLevel.Warn, LintCategory.Warning, fix.description)
                .with_easy_fix(fix)
            # Extract line from first replacement
            var fix_line = 1
            if fix.replacements.len() > 0:
                fix_line = fix.replacements[0].line
            self.results.push(LintResult.new(path, fix_line, 0, lint))

        # Filter and adjust results based on config
        var filtered_results: [LintResult] = []
        for result in self.results:
            if should_keep_lint_result(file_config, result.lint.code):
                # Apply config-level override (e.g. promote to Deny)
                val adjusted_level = apply_config_level(file_config, result.lint.code, result.lint.level)
                if adjusted_level != result.lint.level:
                    val adjusted_lint = Lint(
                        code: result.lint.code,
                        level: adjusted_level,
                        category: result.lint.category,
                        message: result.lint.message,
                        fix_hint: result.lint.fix_hint,
                        easy_fix: result.lint.easy_fix
                    )
                    filtered_results.push(LintResult(
                        file_path: result.file_path,
                        line: result.line,
                        column: result.column,
                        lint: adjusted_lint
                    ))
                else:
                    filtered_results.push(result)

        self.results = filtered_results
        self.results

    async fn lint_file(self, path: String) -> Result<[LintResult], String>:
        # Read file using async file I/O
        val file_content = await read_file(path)
        match file_content:
            case Err(e):
                return Err(e)
            case Ok(content):
                return Ok(self.lint_source(path, content))

    me check_theme_package(path: String):
        if not path.starts_with("config/themes/"):
            return
        val issues = validate_default_theme_package()
        for issue in issues:
            val lint = Lint.new("THEME001", LintLevel.Deny, LintCategory.Correctness,
                "{issue.path} {issue.key}: {issue.message}")
                .with_fix("Fix config/themes/theme.sdn or the referenced theme package file")
            self.results.push(LintResult.new(path, 1, 0, lint))
    
    me check_line(path: String, line_num: Int, line: String):
        val trimmed = line.trim()
        if trimmed == "":
            return

        # First-character dispatch to skip irrelevant branches early.
        # Most lines start with identifiers/keywords — only a few prefixes matter.
        val first = trimmed[0]

        if first == "v":
            # Check for unused variables (simple heuristic)
            if trimmed.starts_with("val ") and not trimmed.contains("="):
                val lint = Lint.new("W001", LintLevel.Warn, LintCategory.Warning,
                    "Variable declared but never assigned")
                    .with_fix("Remove declaration or assign a value")
                self.results.push(LintResult.new(path, line_num, 0, lint))

        if first == "f":
            # Check naming conventions for functions
            if trimmed.starts_with("fn "):
                val fn_name = self.extract_function_name(trimmed)
                if not self.is_snake_case(fn_name):
                    val lint = Lint.new("ST001", LintLevel.Allow, LintCategory.Style,
                        "Function name '{fn_name}' should be snake_case")
                        .with_fix("Rename to '{self.to_snake_case(fn_name)}'")
                    self.results.push(LintResult.new(path, line_num, 0, lint))

        if first == "c":
            if trimmed.starts_with("class "):
                val class_name = self.extract_class_name(trimmed)
                if not self.is_pascal_case(class_name):
                    val lint = Lint.new("ST002", LintLevel.Allow, LintCategory.Style,
                        "Class name '{class_name}' should be PascalCase")
                    self.results.push(LintResult.new(path, line_num, 0, lint))

        if first == "u":
            # Check unfold declaration (only in __init__.spl files)
            if trimmed.starts_with("unfold ") and trimmed.contains("{"):
                self.check_unfold_declaration(path, line_num, trimmed)

        # These checks examine content (comments, strings) — always run
        val normalized = trimmed.replace(" ", "").replace("\t", "")
        val has_production_pass_todo =
            normalized == "pass_todo" or
            normalized.starts_with("pass_todo(") or
            normalized.contains(":pass_todo") or
            normalized.contains("=pass_todo")
        if not is_test_like_file(path) and has_production_pass_todo:
            val lint = Lint.new("STUB003", LintLevel.Deny, LintCategory.Warning,
                "Explicit pass_todo placeholder in production code")
                .with_fix("Replace pass_todo with a real implementation or return an explicit unsupported error")
            self.results.push(LintResult.new(path, line_num, 0, lint))
        self.check_required_comment_source(path, line_num, trimmed)
        self.check_todo_format(path, line_num, trimmed)
        self.check_sdn_write(path, line_num, trimmed)

    fn required_comment_is_weak(text_value: String) -> Bool:
        val t = text_value.trim().lower()
        if t == "":
            return true
        if t.len() < 10:
            return true
        if t == "todo" or t == "fix" or t == "later" or t == "unknown":
            return true
        if t == "because" or t == "n/a" or t == "na":
            return true
        false

    fn first_string_arg(line: String) -> String:
        val first_quote = line.find("\"")
        if first_quote < 0:
            return ""
        val rest = line.slice(first_quote + 1)
        val second_quote = rest.find("\"")
        if second_quote < 0:
            return ""
        rest.slice(0, second_quote)

    fn second_string_arg(line: String) -> String:
        val first_quote = line.find("\"")
        if first_quote < 0:
            return ""
        val rest = line.slice(first_quote + 1)
        val second_quote = rest.find("\"")
        if second_quote < 0:
            return ""
        val after_second = rest.slice(second_quote + 1)
        val third_quote = after_second.find("\"")
        if third_quote < 0:
            return ""
        val rest2 = after_second.slice(third_quote + 1)
        val fourth_quote = rest2.find("\"")
        if fourth_quote < 0:
            return ""
        rest2.slice(0, fourth_quote)

    me check_required_comment_source(path: String, line_num: Int, line: String):
        if line.starts_with("#"):
            return
        val normalized = line.replace(" ", "").replace("\t", "")
        if normalized == "pass_todo" or normalized == "pass_do_nothing" or normalized == "pass_dn":
            val lint = Lint.new("REQC001", LintLevel.Warn, LintCategory.Warning,
                "pass_* used without a rationale")
                .with_fix("Use pass_todo(\"what remains\", \"hint or issue\") or pass_do_nothing(\"why no-op is correct\")")
            self.results.push(LintResult.new(path, line_num, 0, lint))
        if normalized.starts_with("pass_todo(") or normalized.starts_with("pass_do_nothing(") or normalized.starts_with("pass_dn("):
            val reason = self.first_string_arg(line)
            if self.required_comment_is_weak(reason):
                val lint = Lint.new("REQC001", LintLevel.Warn, LintCategory.Warning,
                    "pass_* used without a useful rationale")
                    .with_fix("Use pass_todo(\"what remains\", \"hint or issue\") or pass_do_nothing(\"why no-op is correct\")")
                self.results.push(LintResult.new(path, line_num, 0, lint))
        if normalized.starts_with("todo(") or normalized.contains(":todo(") or normalized.contains("=todo("):
            val what = self.first_string_arg(line)
            val hint = self.second_string_arg(line)
            if self.required_comment_is_weak(what) or self.required_comment_is_weak(hint):
                val lint = Lint.new("REQC003", LintLevel.Warn, LintCategory.Warning,
                    "todo used without what-remains and next-step strings")
                    .with_fix("Use todo(\"what remains\", \"hint or issue\")")
                self.results.push(LintResult.new(path, line_num, 0, lint))
        val dangerous_call = normalized.starts_with("dangerous_token_but_needs(") or
            normalized.starts_with("loss(") or
            normalized.starts_with("unsafe_cast(") or
            normalized.starts_with("raw_pointer(") or
            normalized.starts_with("unchecked(")
        if dangerous_call:
            val reason = self.first_string_arg(line)
            if self.required_comment_is_weak(reason):
                val lint = Lint.new("REQC002", LintLevel.Warn, LintCategory.Warning,
                    "dangerous keyword used without a useful rationale")
                    .with_fix("Add a first string argument explaining why the escape hatch is correct")
                self.results.push(LintResult.new(path, line_num, 0, lint))
        if normalized.starts_with("case_:") or normalized.starts_with("case_->") or normalized.starts_with("case_=>"):
            val lint = Lint.new("REQC004", LintLevel.Warn, LintCategory.Warning,
                "wildcard match arm used without a rationale")
                .with_fix("Use case _(\"why catch-all is correct\"):")
            self.results.push(LintResult.new(path, line_num, 0, lint))
        if normalized.starts_with("case_(\""):
            val reason = self.first_string_arg(line)
            if self.required_comment_is_weak(reason):
                val lint = Lint.new("REQC004", LintLevel.Warn, LintCategory.Warning,
                    "wildcard match arm used without a useful rationale")
                    .with_fix("Use case _(\"why catch-all is correct\"):")
                self.results.push(LintResult.new(path, line_num, 0, lint))
    
    fn extract_function_name(line: String) -> String:
        # Extract function name from "fn name(...)" pattern
        val parts = line.split("(")
        if parts.len() > 0:
            val name_part = parts[0].replace("fn ", "").trim()
            return name_part
        ""
    
    fn extract_class_name(line: String) -> String:
        # Extract class name from "class Name:" pattern
        val parts = line.replace("class ", "").split(":")
        if parts.len() > 0:
            return parts[0].trim()
        ""
    
    fn is_snake_case(name: String) -> Bool:
        # Simple check: lowercase with underscores
        name == name.lower() and not name.contains("-")
    
    fn is_pascal_case(name: String) -> Bool:
        # Simple check: starts with uppercase
        if name.is_empty():
            return false
        val first_char = name.get(0)
        match first_char:
            case Some(c): c.is_uppercase()
            case nil: false
    
    fn to_snake_case(name: String) -> String:
        # Convert to snake_case (simplified)
        name.lower()

    me check_todo_format(path: String, line_num: Int, line: String):
        # Check if line contains TODO or FIXME
        val has_todo = line.contains("TODO")
        val has_fixme = line.contains("FIXME")

        if not has_todo and not has_fixme:
            return

        val keyword = if has_fixme then "FIXME" else "TODO"
        val idx = line.find(keyword)
        val after_keyword = line.slice(idx + keyword.len()).strip()

        # Check if it starts with : (standard format)
        if not after_keyword.starts_with(":"):
            return  # Not a standard comment format

        val content = after_keyword.slice(1).strip()

        # Check for new format: [area][priority]
        if not content.starts_with("["):
            # Missing format - provide an EasyFix
            var fix = EasyFix.create(
                id: "L:todo_format:{line_num}",
                description: "add [area][priority] format to {keyword} comment",
                confidence: FixConfidence.Uncertain
            )
            # Insert [runtime][P2] before the description text
            val colon_pos = line.find(keyword) + keyword.len() + 1
            fix.add_replacement(Replacement.create(
                file: path,
                start: colon_pos + 1,
                end: colon_pos + 1,
                line: line_num,
                column: colon_pos + 2,
                new_text: "[runtime][P2] "
            ))
            val lint = Lint.new("T001", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME missing [area][priority] format")
                .with_fix("Use: {keyword}: [area][P0-P3] description")
                .with_easy_fix(fix)
            self.results.push(LintResult.new(path, line_num, idx, lint))
            return

        # Parse [area][priority]
        val first_close = content.find("]")
        if first_close < 0:
            val lint = Lint.new("T001", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME has malformed [area] tag")
            self.results.push(LintResult.new(path, line_num, idx, lint))
            return

        val area = content.slice(1, first_close)

        # Validate area
        if not _todo_areas().contains(area):
            val lint = Lint.new("T002", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME has invalid area '{area}'")
                .with_fix("Valid areas: runtime, codegen, compiler, parser, type, stdlib, gpu, ui, test, driver, loader, pkg, sdn")
            self.results.push(LintResult.new(path, line_num, idx, lint))

        # Check for priority
        val after_area = content.slice(first_close + 1).strip()
        if not after_area.starts_with("["):
            val lint = Lint.new("T001", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME missing [priority] after [area]")
                .with_fix("Use: {keyword}: [{area}][P0-P3] description")
            self.results.push(LintResult.new(path, line_num, idx, lint))
            return

        val second_close = after_area.find("]")
        if second_close < 0:
            val lint = Lint.new("T001", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME has malformed [priority] tag")
            self.results.push(LintResult.new(path, line_num, idx, lint))
            return

        val priority = after_area.slice(1, second_close)

        # Validate priority
        if not _todo_priorities().contains(priority):
            val lint = Lint.new("T003", LintLevel.Warn, LintCategory.Style,
                "TODO/FIXME has invalid priority '{priority}'")
                .with_fix("Valid priorities: P0/critical, P1/high, P2/medium, P3/low")
            self.results.push(LintResult.new(path, line_num, idx, lint))

        # Check P0/critical requires issue number
        if priority == "P0" or priority == "critical":
            val rest = after_area.slice(second_close + 1)
            if not rest.contains("[#"):
                val lint = Lint.new("T004", LintLevel.Deny, LintCategory.Style,
                    "P0/critical TODO must have issue number")
                    .with_fix("Add issue: {keyword}: [{area}][{priority}] description [#123]")
                self.results.push(LintResult.new(path, line_num, idx, lint))

    me check_unfold_declaration(path: String, line_num: Int, line: String):
        # Validate unfold declaration: unfold {subpkg1, subpkg2, ...}
        # Check that:
        # 1. File is __init__.spl (directory module)
        # 2. Each subpackage exists as a directory
        # 3. Each subpackage has __init__.spl

        # Check if this is a directory module (__init__.spl)
        if not path.ends_with("__init__.spl"):
            val lint = Lint.new("I003", LintLevel.Deny, LintCategory.Correctness,
                "unfold declaration only allowed in __init__.spl (directory modules)")
                .with_fix("Move unfold declaration to the package's __init__.spl file")
            self.results.push(LintResult.new(path, line_num, 0, lint))
            return

        # Get base directory of this module
        val base_dir = get_parent_directory(path)

        # Extract subpackages from "unfold {a, b, c}"
        val subpackages = extract_unfold_subpackages(line)

        # Validate each subpackage
        for subpkg in subpackages:
            val subpkg_dir = "{base_dir}/{subpkg}"
            val init_file = "{subpkg_dir}/__init__.spl"

            if not is_dir(subpkg_dir):
                val lint = Lint.new("I001", LintLevel.Deny, LintCategory.Correctness,
                    "unfold subpackage '{subpkg}' directory does not exist: {subpkg_dir}")
                    .with_fix("Create directory: mkdir -p {subpkg_dir}")
                self.results.push(LintResult.new(path, line_num, 0, lint))
            elif not file_exists(init_file):
                val lint = Lint.new("I002", LintLevel.Deny, LintCategory.Correctness,
                    "unfold subpackage '{subpkg}' missing __init__.spl in {subpkg_dir}")
                    .with_fix("Create file: touch {init_file}")
                self.results.push(LintResult.new(path, line_num, 0, lint))

    me check_sdn_write(path: String, line_num: Int, line: String):
        # Detect direct database file writes
        # Specifically checks for writes to:
        # - doc/08_tracking/bug/bug_db.sdn
        # - doc/08_tracking/test/test_db.sdn
        # - doc/02_requirements/feature/feature_db.sdn

        # Skip this check if we're in the database library itself
        if path.contains("src/lib/database/") or path.contains("src/app/lint/"):
            return

        # Check for file write function calls
        val has_file_write = line.contains("file_write(") or line.contains("rt_file_write(") or line.contains("file_atomic_write(")

        if not has_file_write:
            return

        # Check if the line contains database file paths
        val is_bug_db = line.contains("bug_db.sdn") or line.contains("doc/08_tracking/bug/")
        val is_test_db = line.contains("test_db.sdn") or line.contains("doc/08_tracking/test/")
        val is_feature_db = line.contains("feature_db.sdn") or line.contains("doc/02_requirements/feature/")

        if is_bug_db or is_test_db or is_feature_db:
            var db_type = "bug"
            if is_test_db:
                db_type = "test"
            elif is_feature_db:
                db_type = "feature"

            val lint = Lint.new("D001", LintLevel.Deny, LintCategory.Correctness,
                "Direct database file write detected. Use lib.database.{db_type} instead.")
                .with_fix("Import: use std.database.{db_type} (create_{db_type}_database), then use db.save()")
            self.results.push(LintResult.new(path, line_num, 0, lint))

    me check_spipe_quality(path: String, content: String):
        if not is_test_like_file(path):
            return

        val lines = content.split("\n")
        var line_num = 1
        for line in lines:
            val trimmed = line.trim()
            if trimmed == "" or trimmed.starts_with("#"):
                line_num = line_num + 1
                continue

            val normalized = normalize_lint_line(trimmed)

            val has_literal_tautology =
                normalized.contains("expect(true).to_equal(true)") or
                normalized.contains("expect(false).to_equal(false)") or
                normalized.contains("expect(true).to_be(true)") or
                normalized.contains("expect(false).to_be(false)")

            if has_literal_tautology:
                val lint = Lint.new("SPIPE001", LintLevel.Deny, LintCategory.Correctness,
                    "Tautological assertion in spec/example")
                    .with_fix("Assert returned data, state, or capability outcome instead of a literal boolean")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            val has_pass_helper =
                normalized == "pass_todo" or
                normalized == "pass_do_nothing" or
                normalized == "pass_dn" or
                normalized.starts_with("pass_todo(") or
                normalized.starts_with("pass_do_nothing(") or
                normalized.starts_with("pass_dn(") or
                normalized.contains(":pass_todo") or
                normalized.contains(":pass_do_nothing") or
                normalized.contains(":pass_dn") or
                normalized.contains("=pass_todo") or
                normalized.contains("=pass_do_nothing") or
                normalized.contains("=pass_dn")

            if has_pass_helper:
                val lint = Lint.new("SPIPE002", LintLevel.Deny, LintCategory.Correctness,
                    "Placeholder pass helper in spec/example")
                    .with_fix("Use skip: for unsupported environments, or assert a real result")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            val is_match_arm = trimmed.starts_with("Ok(") or trimmed.starts_with("Err(") or
                trimmed.starts_with("case Ok(") or trimmed.starts_with("case Err(")
            val has_match_placeholder = has_literal_tautology or
                normalized.contains(":pass_todo") or
                normalized.contains(":pass_do_nothing") or
                normalized.contains(":pass_dn")
            val is_match_placeholder = is_match_arm and has_match_placeholder

            if is_match_placeholder:
                val lint = Lint.new("SPIPE003", LintLevel.Deny, LintCategory.Correctness,
                    "Placeholder success/failure arm in match-based spec assertion")
                    .with_fix("Assert concrete fields from Ok/Err, or use skip: before the match")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            if is_boolean_wrapper_assertion(normalized):
                val lint = Lint.new("SPIPE006", LintLevel.Deny, LintCategory.Correctness,
                    "Boolean-wrapper assertion in spec/example")
                    .with_fix("Assert the underlying value or capability result instead of expect(<comparison>).to_equal(true/false)")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            val has_print_skip =
                normalized.contains("print(\"[skip]") or
                normalized.contains("print'[skip]") or
                normalized.contains("print\"[skip]") or
                normalized.contains("print(\"skip:") or
                normalized.contains("print\"skip:") or
                normalized.contains("print'[skip]")

            if has_print_skip:
                val lint = Lint.new("SPIPE004", LintLevel.Deny, LintCategory.Correctness,
                    "Print-based skip placeholder in spec/example")
                    .with_fix("Use skip: for sanctioned environment skips instead of print-and-return")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            line_num = line_num + 1

        self.check_spipe_example_bodies(path, lines)

    me check_spipe_example_bodies(path: String, lines: [String]):
        var i = 0
        while i < lines.len():
            val line = lines[i]
            val trimmed = line.trim()
            if not (trimmed.starts_with("it \"") or trimmed.starts_with("slow_it \"")):
                i = i + 1
                continue

            val header_indent = indent_width(line)
            var j = i + 1
            var body: [String] = []
            while j < lines.len():
                val body_line = lines[j]
                val body_trimmed = body_line.trim()
                if body_trimmed != "" and not body_trimmed.starts_with("#") and indent_width(body_line) <= header_indent:
                    break
                body.push(body_line)
                j = j + 1

            var statements: [String] = []
            for body_line in body:
                val body_trimmed = body_line.trim()
                if body_trimmed != "" and not body_trimmed.starts_with("#"):
                    statements.push(body_trimmed)

            val line_num = i + 1
            if statements.len() == 0:
                val lint = Lint.new("SPIPE005", LintLevel.Deny, LintCategory.Correctness,
                    "SPipe example has no body")
                    .with_fix("Add a real assertion or use skip: for a sanctioned skip")
                self.results.push(LintResult.new(path, line_num, 0, lint))
                i = j
                continue

            var has_real_assertion = false
            var has_sanctioned_skip = false
            for stmt in statements:
                val normalized = normalize_lint_line(stmt)
                val assertion_like =
                    normalized.contains("expect(") or
                    normalized.contains("to_equal(") or
                    normalized.contains("to_be(") or
                    normalized.contains("to_contain(") or
                    normalized.contains("to_start_with(") or
                    normalized.contains("to_end_with(") or
                    normalized.contains("to_be_greater_than(") or
                    normalized.contains("to_be_less_than(")
                if assertion_like:
                    has_real_assertion = true
                val sanctioned_skip =
                    normalized == "skip:" or
                    normalized.starts_with("skip:") or
                    normalized.contains("return\"skip:") or
                    normalized.contains("return'skip:")
                if sanctioned_skip:
                    has_sanctioned_skip = true
            if not has_real_assertion and not has_sanctioned_skip:
                val lint = Lint.new("SPIPE005", LintLevel.Deny, LintCategory.Correctness,
                    "SPipe example has no real assertion or sanctioned skip")
                    .with_fix("Assert a concrete result, or use skip: when the environment legitimately cannot run the example")
                self.results.push(LintResult.new(path, line_num, 0, lint))

            i = j

    # -----------------------------------------------------------------------
    # UI typed-API lint helpers
    # -----------------------------------------------------------------------

    # Rule UI001 — ui_no_raw_widget_kind
    # Flag string literals in the kind arg of WidgetNode.new(id, "<literal>").
    #
    # Allowlisted paths (legitimate bridge points where text kind is required):
    #   common/ui/parse/       — SDN/HTML parsers receive kind from user input
    #   common/ui/builder.spl  — top-level builder wraps WidgetNode.new
    #   common/ui/ios/builder.spl, common/ui/glass/builder.spl — typed already
    #   os/services/llm/widget_eval.spl — runtime eval from user input
    me check_ui_raw_widget_kind(path: String, content: String):
        val is_allowlisted = (
            path.contains("common/ui/parse/") or
            path.contains("os/services/llm/widget_eval") or
            path.ends_with("common/ui/builder.spl") or
            path.ends_with("common/ui/ios/builder.spl") or
            path.ends_with("common/ui/glass/builder.spl")
        )
        if is_allowlisted:
            return

        val lines = content.split("\n")
        var line_num = 0
        for line in lines:
            line_num = line_num + 1
            val trimmed = line.trim()
            if not trimmed.contains("WidgetNode.new("):
                continue
            # Only flag when the second argument is a string literal (starts with `"`)
            # Pattern: WidgetNode.new(<expr>, "<literal>")
            # Find the second comma after the opening paren, then check for `"`
            val call_start = trimmed.find("WidgetNode.new(")
            if call_start < 0:
                continue
            val after_paren = trimmed.slice(call_start + 15)
            # Find first comma (separates id from kind)
            val comma = after_paren.find(",")
            if comma < 0:
                continue
            val kind_part = after_paren.slice(comma + 1).trim()
            if kind_part.starts_with("\""):
                val lint = Lint.new("UI001", LintLevel.Warn, LintCategory.Style,
                    "Raw string literal as WidgetNode kind — use WidgetKind.X.to_wire()")
                    .with_fix("Replace string literal with WidgetKind.<Variant>.to_wire(), e.g. WidgetKind.Panel.to_wire()")
                self.results.push(LintResult.new(path, line_num, 0, lint))

    # Rule UI002 — ui_no_raw_variant
    # Flag string literals in the action position of with_on_typed_action calls
    # and in the variant position of toast().
    #
    # Allowlisted paths:
    #   common/ui/builder.spl  — defines with_on_action (the legacy wrapper fn)
    #   common/ui/glass/builder.spl — defines toast()
    me check_ui_raw_variant(path: String, content: String):
        val is_allowlisted = (
            path.ends_with("common/ui/builder.spl") or
            path.ends_with("common/ui/glass/builder.spl")
        )
        if is_allowlisted:
            return

        val lines = content.split("\n")
        var line_num = 0
        for line in lines:
            line_num = line_num + 1
            val trimmed = line.trim()

            # with_on_typed_action(node, "<literal>") — second arg is a string
            if trimmed.contains("with_on_typed_action("):
                val call_start = trimmed.find("with_on_typed_action(")
                if call_start >= 0:
                    val after_paren = trimmed.slice(call_start + 21)
                    val comma = after_paren.find(",")
                    if comma >= 0:
                        val action_part = after_paren.slice(comma + 1).trim()
                        if action_part.starts_with("\""):
                            val lint = Lint.new("UI002", LintLevel.Warn, LintCategory.Style,
                                "Raw string literal in action position of with_on_typed_action — use Action or CommonAction")
                                .with_fix("Use with_on_typed_action(node, CommonAction.Save.into_action()) or Action.Custom(name: \"...\")")
                            self.results.push(LintResult.new(path, line_num, 0, lint))

            # toast(id, message, "<variant_literal>") — third arg is a string literal
            if trimmed.contains("toast("):
                val call_start = trimmed.find("toast(")
                if call_start >= 0:
                    val after_paren = trimmed.slice(call_start + 6)
                    # Find second comma (skip id and message)
                    val first_comma = after_paren.find(",")
                    if first_comma >= 0:
                        val after_first = after_paren.slice(first_comma + 1)
                        val second_comma = after_first.find(",")
                        if second_comma >= 0:
                            val variant_part = after_first.slice(second_comma + 1).trim()
                            if variant_part.starts_with("\""):
                                val lint = Lint.new("UI002", LintLevel.Warn, LintCategory.Style,
                                    "Raw string variant in toast() — use a typed variant constant")
                                    .with_fix("Replace string variant with a typed constant, e.g. StatusVariant.Success.to_wire() once available")
                                self.results.push(LintResult.new(path, line_num, 0, lint))

    # Rule UI003 — ui_no_raw_theme_name
    # Flag raw theme-name string literals passed to theme_by_name() or stored
    # in theme-name fields.
    #
    # Allowlisted paths:
    #   common/ui/style.spl    — from_name() match arm dispatches on runtime text
    #   test files             — may verify theme-name parsing
    me check_ui_raw_theme_name(path: String, content: String):
        val is_allowlisted = (
            path.ends_with("common/ui/style.spl") or
            is_test_like_file(path)
        )
        if is_allowlisted:
            return

        val theme_names = [
            "ios_" + "light",
            "ios_" + "dark",
            "glass_" + "light",
            "glass_" + "dark",
            "glass_" + "obsidian_dark",
            "simple_" + "dark",
            "simple_" + "light"
        ]

        val lines = content.split("\n")
        var line_num = 0
        for line in lines:
            line_num = line_num + 1
            val trimmed = line.trim()
            if trimmed == "" or trimmed.starts_with("#"):
                continue
            # Only flag string literals (content inside double-quotes)
            for theme_name in theme_names:
                val quoted = "\"{theme_name}\""
                if trimmed.contains(quoted):
                    val lint = Lint.new("UI003", LintLevel.Warn, LintCategory.Style,
                        "Raw theme-name string \"{theme_name}\" — use ThemeId enum variant")
                        .with_fix("Replace \"{theme_name}\" with the ThemeId variant, e.g. ThemeId.IOSLight")
                    self.results.push(LintResult.new(path, line_num, 0, lint))
                    break  # one diagnostic per line is enough


# Helper: Get parent directory from file path
fn get_parent_directory(path: String) -> String:
    val last_slash = path.rfind("/")
    if last_slash >= 0:
        return path.slice(0, last_slash)
    "."

# Helper: Extract subpackage names from "unfold {a, b, c}"
fn extract_unfold_subpackages(line: String) -> [String]:
    var subpackages: [String] = []

    val start = line.find("{")
    val end = line.find("}")

    if start < 0 or end < 0 or end <= start:
        return subpackages

    val content = line.slice(start + 1, end).trim()
    if content.is_empty():
        return subpackages

    val parts = content.split(",")
    for part in parts:
        val trimmed = part.trim()
        if not trimmed.is_empty():
            subpackages.push(trimmed)

    subpackages

fn is_test_like_file(path: String) -> Bool:
    path.ends_with("_spec.spl") or path.contains("/test/") or path.starts_with("test/")

fn normalize_lint_line(line: String) -> String:
    line.replace(" ", "").replace("\t", "")

fn extract_expect_subject(normalized: String) -> String:
    val start = normalized.find("expect(")
    if start < 0:
        return ""
    val tail = normalized.slice(start + 7)
    val end_equal = tail.find(").to_equal(")
    if end_equal >= 0:
        return tail.slice(0, end_equal)
    val end_be = tail.find(").to_be(")
    if end_be >= 0:
        return tail.slice(0, end_be)
    ""

fn is_boolean_wrapper_assertion(normalized: String) -> Bool:
    val compares_to_bool =
        normalized.contains(").to_equal(true)") or
        normalized.contains(").to_equal(false)") or
        normalized.contains(").to_be(true)") or
        normalized.contains(").to_be(false)")
    if not compares_to_bool:
        return false

    val subject = extract_expect_subject(normalized)
    if subject == "" or subject == "true" or subject == "false":
        return false

    subject.contains("==") or
        subject.contains("!=") or
        subject.contains(">=") or
        subject.contains("<=") or
        subject.contains(">") or
        subject.contains("<")

fn indent_width(line: String) -> Int:
    var width = 0
    for ch in line:
        if ch == " ":
            width = width + 1
            continue
        if ch == "\t":
            width = width + 4
            continue
        break
    width


async fn main() -> Int:
    val args = get_args()

    if args.len() < 2:
        print("Usage: simple_lint <file.spl> [options]")
        print("")
        print("Options:")
        print("  --deny-all        Treat all warnings as errors")
        print("  --warn-all        Enable all style lints")
        print("  --json            Output in JSON format")
        print("  --fix             Apply safe auto-fixes")
        print("  --fix-all         Apply all fixes regardless of confidence")
        print("  --fix-dry-run     Show what would be fixed without applying")
        print("  --fix-interactive Prompt for each fix")
        print("")
        print("Lint categories:")
        print("  Safety (S): Memory safety and null checks")
        print("  Correctness (C): Logic errors")
        print("  Warning (W): Potential issues")
        print("  Style (ST): Code style")
        print("  Concurrency (CC): Thread safety")
        print("  TODO (T): TODO/FIXME format [area][priority]")
        print("  Stub (STUB): Trivial/dummy implementations")
        return 1

    val file_path = args[1]
    val deny_all = args.contains("--deny-all")
    val fix_mode = args.contains("--fix")
    val fix_all = args.contains("--fix-all")
    val fix_dry_run = args.contains("--fix-dry-run")
    val fix_interactive = args.contains("--fix-interactive")

    # Verify file exists
    if not file_exists(file_path):
        error("lint", "File not found: " + file_path)
        return 1

    # Run linter (loads config from simple.sdn automatically)
    var linter = Linter.new()

    # Try to load config relative to the target file
    val sdn_path = find_project_sdn(file_path)
    if sdn_path != "":
        linter.config = LintConfig.from_sdn_file(sdn_path)

    val lint_result = await linter.lint_file(file_path)
    match lint_result:
        case Ok(results):
            if results.is_empty():
                info("lint", "No issues found in " + file_path)
                return 0
            else:
                var error_count = 0
                var warning_count = 0
                var fix_count = 0

                for lint_item in results:
                    print(lint_item.format())

                    match lint_item.lint.level:
                        case Deny:
                            error_count = error_count + 1
                        case Warn:
                            warning_count = warning_count + 1
                            if deny_all:
                                error_count = error_count + 1
                        case Allow:
                            val _ = 0

                    if lint_item.has_easy_fix():
                        fix_count = fix_count + 1

                print("")
                print("Found {error_count} error(s), {warning_count} warning(s), {fix_count} auto-fix(es) available")

                # Apply fixes if requested
                if (fix_mode or fix_all) and fix_count > 0:
                    val fixes_to_apply = collect_easy_fixes(results, fix_all)
                    if not fixes_to_apply.is_empty():
                        apply_collected_fixes(file_path, fixes_to_apply, fix_dry_run)

                if error_count > 0:
                    return 1
                else:
                    return 0

        case Err(error):
            error("lint", error)
            return 1

    return 0

fn collect_easy_fixes(results: [LintResult], include_all: Bool) -> [EasyFix]:
    var fixes: [EasyFix] = []
    for result in results:
        match result.lint.easy_fix:
            case Some(fix):
                if include_all or fix.is_safe():
                    fixes.push(fix)
            case nil:
                val _ = 0
    fixes

fn apply_collected_fixes(file_path: String, fixes: [EasyFix], dry_run: Bool):
    val source = file_read(file_path)
    if source == "":
        error("lint", "reading file for fix failed: {file_path}")
        return

    var sources: Dict<String, String> = {}
    sources[file_path] = source

    # Sort replacements by position descending and apply
    var all_replacements: [Replacement] = []
    for fix in fixes:
        for rep in fix.replacements:
            all_replacements.push(rep)

    all_replacements = all_replacements.sort_by(\a, b: b.start - a.start)

    var new_source = source
    for rep in all_replacements:
        if rep.start <= new_source.len() and rep.end <= new_source.len():
            new_source = new_source.slice(0, rep.start) + rep.new_text + new_source.slice(rep.end)

    if dry_run:
        print("\nDry run - would apply {fixes.len()} fix(es):")
        for fix in fixes:
            print("  [{fix.id}] {fix.description}")
    else:
        file_write(file_path, new_source)
        print("\nApplied {fixes.len()} fix(es):")
        for fix in fixes:
            print("  [{fix.id}] {fix.description}")
