# Lint config, levels, profiles, and the Lint/LintResult/Linter model.
use compiler.tools.lint.main.*
# Simple Language Linter
# Semantic lints for code quality and safety
# Usage: simple_lint <file.spl> [--deny-all] [--warn-all]

# I/O imports
use std.nogc_sync_mut.io.file_ops (file_read, file_exists, file_write)
use std.nogc_sync_mut.io.dir_ops (is_dir)
use app.io.cli_ops (get_args)

# Logging imports
use std.log.{error, info}

# Import EasyFix data types from stdlib
use std.tooling.easy_fix.*
use nogc_sync_mut.ui.theme_package.{validate_default_theme_package}
use compiler.semantics.lint.riscv_rtl_debuggability_lint.{lint_riscv_rtl_debuggability}

# File I/O wrapper

enum LintReadFileResult:
    ReadFileOk(String)
    ReadFileErr(String)

fn lint_read_file(path: String) -> LintReadFileResult:
    val file_content = file_read(path)
    if file_content == "":
        return LintReadFileResult.ReadFileErr("Failed to read file: {path}")
    return LintReadFileResult.ReadFileOk(file_content)

# Lint levels
enum LintLevel:
    Allow
    Warn
    Deny

# Strictness tiers (script modes) — the lint-tier axis, orthogonal to the stdlib
# memory tiers (nogc_sync_mut, ...). See
# doc/03_plan/compiler/reliable_mode/reliable_mode_plan.md and glossary.md.
#   moderate  — relaxed: deny defaults downgraded to warn (advisory only)
#   lib       — current defaults (the regression-safe baseline)
#   reliable  — strictest: public-surface + safety/correctness lints raised to deny
enum LintProfile:
    Moderate
    Lib
    Reliable

# Parse a profile string into LintProfile. Returns nil for unknown strings.
fn parse_lint_profile(profile_str: String) -> Option<LintProfile>:
    val lower = profile_str.lower()
    if lower == "moderate":
        return Some(LintProfile.Moderate)
    if lower == "lib":
        return Some(LintProfile.Lib)
    if lower == "reliable":
        return Some(LintProfile.Reliable)
    nil

# All configurable lint names.
fn all_lint_names() -> [text]:
    ["primitive_api", "bare_bool", "simple_script_required", "print_in_test_spec", "todo_format",
     "spipe_no_print_based_tests", "spipe_missing_docstrings",
     "spipe_minimal_docstrings", "spipe_manual_assertions",
     "spipe_placeholder_tests", "spipe_empty_examples",
     "spipe_boolean_wrapper_assertions", "spipe_false_boolean_wrapper_assertions",
     "unnamed_duplicate_typed_args", "resource_leak",
     "wildcard_match", "non_exhaustive_match",
     "export_outside_init", "init_boundary_violation",
     "bypass_with_code_files", "unknown_decorator", "stub_impl",
     "unknown_attribute", "too_many_arguments", "dummy_accessor",
     "similar_parent_method_name",
     "required_comment",
     "ui_no_raw_widget_kind", "ui_no_raw_variant", "ui_no_raw_theme_name",
     "stale_md_diagrams", "hash_bracket_attribute", "llvm_backend_type_safety",
     # Newly-configurable families (previously unmapped — see
     # map_lint_code_to_config_name). Default warn (regression-safe).
     "unused_code", "style_convention", "unsafe_pattern", "concurrency_misuse",
     "closure_capture", "ignored_return", "multiline_bool", "memory_safety",
     "visibility_boundary", "database_integrity", "tracking_traceability",
     # Freestanding/kernel-risk entry-closure codegen defect avoidance
     # (C1/C4/C5/C7) — scoped to src/os/** and examples/09_embedded/**.
     "freestanding_enum_eq", "freestanding_anon_tuple_return",
     "freestanding_bare_conversion", "freestanding_global_call_init",
     "module_init_literal", "raw_rt_access"]

# Build the default levels dict for all configurable lint names.
# Most are Warn; exceptions: spipe_no_print_based_tests=Deny,
# spipe_placeholder_tests=Deny, spipe_empty_examples=Deny,
# export_outside_init=Deny,
# stub_impl=Deny, wildcard_match=Allow, style_convention=Allow.
fn build_default_levels() -> Dict<String, String>:
    var levels: Dict<String, String> = {}
    levels["primitive_api"] = "deny"
    levels["bare_bool"] = "warn"
    levels["simple_script_required"] = "warn"
    levels["print_in_test_spec"] = "warn"
    levels["todo_format"] = "warn"
    levels["spipe_no_print_based_tests"] = "deny"
    levels["spipe_missing_docstrings"] = "warn"
    levels["spipe_minimal_docstrings"] = "warn"
    levels["spipe_manual_assertions"] = "warn"
    levels["spipe_placeholder_tests"] = "deny"
    levels["spipe_empty_examples"] = "deny"
    levels["spipe_boolean_wrapper_assertions"] = "warn"
    levels["spipe_false_boolean_wrapper_assertions"] = "warn"
    levels["unnamed_duplicate_typed_args"] = "warn"
    levels["resource_leak"] = "warn"
    levels["wildcard_match"] = "allow"
    levels["non_exhaustive_match"] = "warn"
    levels["export_outside_init"] = "deny"
    levels["init_boundary_violation"] = "warn"
    levels["bypass_with_code_files"] = "warn"
    levels["unknown_decorator"] = "warn"
    levels["stub_impl"] = "deny"
    levels["unknown_attribute"] = "warn"
    levels["too_many_arguments"] = "warn"
    levels["dummy_accessor"] = "warn"
    levels["similar_parent_method_name"] = "warn"
    levels["required_comment"] = "warn"
    levels["ui_no_raw_widget_kind"] = "warn"
    levels["ui_no_raw_variant"] = "warn"
    levels["ui_no_raw_theme_name"] = "warn"
    levels["stale_md_diagrams"] = "warn"
    levels["llvm_backend_type_safety"] = "deny"
    levels["hash_bracket_attribute"] = "warn"
    # Newly-configurable families. Preserve the original suppression level for
    # style diagnostics until --warn-all or an explicit config promotes them.
    levels["unused_code"] = "warn"
    levels["style_convention"] = "allow"
    levels["unsafe_pattern"] = "warn"
    levels["concurrency_misuse"] = "warn"
    levels["closure_capture"] = "warn"
    levels["ignored_return"] = "warn"
    levels["multiline_bool"] = "warn"
    levels["memory_safety"] = "warn"
    levels["visibility_boundary"] = "warn"
    levels["database_integrity"] = "warn"
    levels["tracking_traceability"] = "warn"
    levels["freestanding_enum_eq"] = "warn"
    levels["freestanding_anon_tuple_return"] = "warn"
    levels["freestanding_bare_conversion"] = "warn"
    levels["freestanding_global_call_init"] = "warn"
    levels["module_init_literal"] = "warn"
    levels["raw_rt_access"] = "warn"
    levels

# Per-tier default levels, layered on top of build_default_levels().
#   Lib      = current defaults (regression-safe baseline)
#   Moderate = advisory: every "deny" default downgraded to "warn"
#   Reliable = strict: public-surface + safety/correctness lints elevated to "deny"
fn profile_default_levels(profile: LintProfile) -> Dict<String, String>:
    val levels = build_default_levels()
    match profile:
        case Lib:
            return levels
        case Moderate:
            var out: Dict<String, String> = {}
            for key in levels.keys():
                if levels[key] == "deny":
                    out[key] = "warn"
                else:
                    out[key] = levels[key]
            return out
        case Reliable:
            var strict = levels
            strict["primitive_api"] = "deny"
            strict["unsafe_pattern"] = "deny"
            strict["memory_safety"] = "deny"
            strict["concurrency_misuse"] = "deny"
            strict["visibility_boundary"] = "deny"
            strict["non_exhaustive_match"] = "deny"
            strict["resource_leak"] = "deny"
            strict["init_boundary_violation"] = "deny"
            return strict
    levels

# Parse a level string ("allow", "warn", "deny") into LintLevel.
# Returns nil for unknown strings.
fn parse_lint_level(level_str: String) -> Option<LintLevel>:
    val lower = level_str.lower()
    if lower == "allow":
        return Some(LintLevel.Allow)
    if lower == "warn":
        return Some(LintLevel.Warn)
    if lower == "deny":
        return Some(LintLevel.Deny)
    nil

# Lint configuration — overrides for lint levels.
# Loaded from simple.sdn [lints] section and/or file-level attributes.
class LintConfig:
    levels: Dict<String, String>
    # Selected strictness tier; nil = unset (legacy build_default_levels behavior).
    profile: Option<LintProfile>

    # Create a default config (all defaults, no overrides).
impl LintConfig:
    static fn new() -> LintConfig:
        LintConfig(levels: {}, profile: nil)

    # Load config from an SDN file.  Parses the [lints] section.
    static fn from_sdn_file(path: String) -> LintConfig:
        if not file_exists(path):
            return LintConfig.new()
        val content = file_read(path)
        if content == "":
            return LintConfig.new()
        LintConfig.from_sdn_string(content)

    # Parse config from an SDN string.
    static fn from_sdn_string(content: String) -> LintConfig:
        var config = LintConfig.new()
        var in_lints_section = false

        val lines = content.split("\n")
        for line in lines:
            val trimmed = line.trim()

            # Skip empty lines and comments
            if trimmed == "" or trimmed.starts_with("#"):
                continue

            # Check for [lints] section header
            if trimmed == "[lints]":
                in_lints_section = true
                continue

            # Any other section header exits [lints]
            if trimmed.starts_with("[") and trimmed.ends_with("]"):
                in_lints_section = false
                continue

            # Parse lint = "level" entries inside [lints]
            if in_lints_section and trimmed.contains("="):
                val parts = trimmed.split("=")
                if parts.len() >= 2:
                    val lint_name = parts[0].trim()
                    var level_str = parts[1].trim()
                    # Strip surrounding quotes
                    level_str = level_str.replace("\"", "")
                    level_str = level_str.replace("'", "")
                    level_str = level_str.trim()

                    # profile=<tier> selects the strictness tier (not a lint name).
                    # Handle it BEFORE the all_lint_names() gate or it is dropped.
                    if lint_name == "profile":
                        config.set_profile_from_string(level_str)
                    # Validate the lint name is known
                    elif all_lint_names().contains(lint_name):
                        config.levels[lint_name] = level_str
                    elif lint_name == "unknown_annotation":
                        # Meta-lint: sets both unknown_decorator and unknown_attribute
                        config.levels["unknown_decorator"] = level_str
                        config.levels["unknown_attribute"] = level_str

        config

    # Get the effective level for a lint name.
    # Checks overrides first, then falls back to built-in defaults.
    fn get_level(lint_name: String) -> LintLevel:
        var level_str = ""
        if self.levels.has(lint_name):
            level_str = self.levels[lint_name]
        else:
            # Fall back to tier defaults when a profile is selected, else the
            # legacy global defaults (nil profile == today's exact behavior).
            var defaults: Dict<String, String> = build_default_levels()
            match self.profile:
                case Some(p):
                    defaults = profile_default_levels(p)
                case nil:
                    val _ = 0
            if defaults.has(lint_name):
                level_str = defaults[lint_name]
            else:
                return LintLevel.Warn  # Unknown lint defaults to Warn

        val parsed = parse_lint_level(level_str)
        match parsed:
            case Some(level):
                return level
            case nil:
                return LintLevel.Warn

    # Select the strictness tier directly.
    me set_profile(profile: LintProfile):
        self.profile = Some(profile)

    # Select the strictness tier from a string; unknown strings are ignored.
    me set_profile_from_string(profile_str: String):
        val parsed = parse_lint_profile(profile_str)
        match parsed:
            case Some(p):
                self.profile = Some(p)
            case nil:
                val _ = 0

    # Set the level for a specific lint name.
    me set_level(lint_name: String, level: LintLevel):
        match level:
            case Allow:
                self.levels[lint_name] = "allow"
            case Warn:
                self.levels[lint_name] = "warn"
            case Deny:
                self.levels[lint_name] = "deny"

    # Apply file-level attribute overrides.
    # Scans the first N lines (before first definition) for:
    #   @allow(lint1, lint2)
    #   @warn(lint1, lint2)
    #   @deny(lint1, lint2)
    #   @allow(lint1)  (inner attribute)
    me apply_file_attributes(content: String):
        val lines = content.split("\n")
        for line in lines:
            val trimmed = line.trim()

            # Stop scanning at the first definition (fn, class, enum, struct, trait, etc.)
            if trimmed.starts_with("fn ") or trimmed.starts_with("me ") or trimmed.starts_with("class ") or trimmed.starts_with("enum ") or trimmed.starts_with("struct ") or trimmed.starts_with("trait "):
                return

            # Also stop at module-level val/var assignments that aren't attributes
            # but continue past use/import and comments
            if trimmed.starts_with("val ") or trimmed.starts_with("var "):
                return

            # Match @allow(...), @warn(...), @deny(...)
            var attr_line = trimmed

            if not attr_line.starts_with("@"):
                continue

            # @lint_profile(<tier>) selects the strictness tier for this file.
            # Distinct from the R9 must-use `@profile(critical)` annotation.
            # Most-local-wins: a file attribute overrides the project sdn profile.
            if attr_line.starts_with("@lint_profile("):
                val close_prof = attr_line.find(")")
                if close_prof >= 14:
                    val prof_str = attr_line.slice(14, close_prof).trim()
                    self.set_profile_from_string(prof_str)
                continue

            # Parse @allow(...), @warn(...), @deny(...)
            var level_opt: Option<LintLevel> = nil
            var inner_start = 0

            if attr_line.starts_with("@allow("):
                level_opt = Some(LintLevel.Allow)
                inner_start = 7
            elif attr_line.starts_with("@warn("):
                level_opt = Some(LintLevel.Warn)
                inner_start = 6
            elif attr_line.starts_with("@deny("):
                level_opt = Some(LintLevel.Deny)
                inner_start = 6

            match level_opt:
                case nil:
                    continue
                case Some(level):
                    # Extract the content between parens
                    val close_paren = attr_line.find(")")
                    if close_paren < 0:
                        continue
                    val lint_list_str = attr_line.slice(inner_start, close_paren)
                    val lint_names = lint_list_str.split(",")
                    for name in lint_names:
                        val clean_name = name.trim()
                        if clean_name == "":
                            continue
                        # Handle meta-lint unknown_annotation
                        if clean_name == "unknown_annotation":
                            self.set_level("unknown_decorator", level)
                            self.set_level("unknown_attribute", level)
                        elif all_lint_names().contains(clean_name):
                            self.set_level(clean_name, level)

    # Create a child config that inherits all current settings.
    fn child() -> LintConfig:
        var new_levels: Dict<String, String> = {}
        val src_levels = self.levels
        if src_levels != nil:
            val src_keys = src_levels.keys()
            if src_keys != nil:
                for key in src_keys:
                    new_levels[key] = src_levels[key]
        LintConfig(levels: new_levels, profile: self.profile)

fn resolve_lint_config(base: LintConfig, path: String, content: String) -> LintConfig:
    var config = base.child()
    config.apply_file_attributes(content)

    val sdn_path = find_project_sdn(path)
    if sdn_path != "":
        val file_config = LintConfig.from_sdn_file(sdn_path)
        for key in file_config.levels.keys():
            if not config.levels.has(key):
                config.levels[key] = file_config.levels[key]
    config

# Check if a lint result should be suppressed based on config.
# Returns true if the result should be kept (not suppressed).
fn should_keep_lint_result(config: LintConfig, lint_code: String) -> Bool:
    # Map internal lint codes to config lint names where possible
    val config_name = map_lint_code_to_config_name(lint_code)
    if config_name == "":
        return true  # Unknown lint code — keep it
    val level = config.get_level(config_name)
    match level:
        case Allow:
            return false  # Suppressed
        case Warn:
            return true
        case Deny:
            return true

# Promote lint levels according to config without downgrading stricter diagnostics.
fn apply_config_level(config: LintConfig, lint_code: String, original_level: LintLevel) -> LintLevel:
    val config_name = map_lint_code_to_config_name(lint_code)
    if config_name == "":
        return original_level
    val config_level = config.get_level(config_name)
    match config_level:
        case Deny:
            return LintLevel.Deny
        case Allow:
            return original_level  # Suppression handled by should_keep_lint_result
        case Warn:
            if original_level == LintLevel.Allow:
                return LintLevel.Warn
            return original_level

# Map internal lint code (e.g. "T001") to config name (e.g. "todo_format").
# Returns "" for codes with no direct mapping.
fn map_lint_code_to_config_name(code: String) -> String:
    if code == "primitive_api":
        return "primitive_api"
    if code == "bare_bool":
        return "bare_bool"
    if code == "simple_script_required":
        return "simple_script_required"
    if code == "T001" or code == "T002" or code == "T003" or code == "T004":
        return "todo_format"
    if code == "ARG001" or code == "ARG002":
        return "too_many_arguments"
    if code == "unnamed_duplicate_typed_args":
        return "unnamed_duplicate_typed_args"
    if code == "ACC001":
        return "dummy_accessor"
    if code == "NAME001":
        return "similar_parent_method_name"
    if code == "STUB001" or code == "STUB002" or code == "STUB003":
        return "stub_impl"
    if code == "SPIPE001" or code == "SPIPE002" or code == "SPIPE003":
        return "spipe_placeholder_tests"
    if code == "SPIPE004":
        return "spipe_no_print_based_tests"
    if code == "SPIPE005":
        return "spipe_empty_examples"
    if code == "SPIPE006":
        return "spipe_boolean_wrapper_assertions"
    if code == "SPIPE007":
        return "spipe_false_boolean_wrapper_assertions"
    if code == "I001" or code == "I002" or code == "I003":
        return "init_boundary_violation"
    if code == "D001":
        return "database_integrity"
    if code == "TRK001":
        return "tracking_traceability"
    if code == "W001" or code == "W002" or code == "W003":
        return "unused_code"  # unused variable/import/dead code
    if code == "ST001" or code == "ST002" or code == "ST003":
        return "style_convention"  # style lints
    if code == "C002":
        return "non_exhaustive_match"
    if (code == "MEXH001" or code == "MEXH002" or code == "MEXH003" or
        code == "MEXH004" or code == "MEXH005"):
        return "non_exhaustive_match"
    if code == "S001" or code == "S002" or code == "S003":
        return "unsafe_pattern"  # safety lints
    if code == "CC001" or code == "CC002":
        return "concurrency_misuse"  # concurrency lints
    if code == "CLOS001":
        return "closure_capture"
    if code == "RET001":
        return "ignored_return"
    if code == "BOOL001":
        return "multiline_bool"
    if code == "REQC001" or code == "REQC002" or code == "REQC003" or code == "REQC004":
        return "required_comment"
    if code == "SAFE001" or code == "SAFE003":
        return "memory_safety"  # safety
    if code == "W0401" or code == "W0402" or code == "W0403" or code == "W0404":
        return "visibility_boundary"  # visibility
    if code == "UI001":
        return "ui_no_raw_widget_kind"
    if code == "UI002":
        return "ui_no_raw_variant"
    if code == "UI003":
        return "ui_no_raw_theme_name"
    if code == "DIAG001":
        return "stale_md_diagrams"
    if code == "LLVM001":
        return "llvm_backend_type_safety"
    if code == "FSK001":
        return "freestanding_enum_eq"
    if code == "FSK002":
        return "freestanding_anon_tuple_return"
    if code == "FSK003":
        return "freestanding_bare_conversion"
    if code == "FSK004":
        return "freestanding_global_call_init"
    if code == "MODINIT001":
        return "module_init_literal"
    if code == "RAW-RT-001":
        return "raw_rt_access"
    ""

# Try to find simple.sdn by walking up from a file path.
fn find_project_sdn(file_path: String) -> String:
    # Try to find simple.sdn in parent directories
    var dir = get_parent_directory(file_path)
    var depth = 0
    while depth < 10:
        val candidate = "{dir}/simple.sdn"
        if file_exists(candidate):
            return candidate
        val parent = get_parent_directory(dir)
        if parent == dir:
            return ""  # Reached root
        dir = parent
        depth = depth + 1
    ""

# Lint categories
enum LintCategory:
    Safety      # Memory safety, null checks
    Correctness # Logic errors, type mismatches
    Warning     # Potential issues
    Style       # Code style recommendations
    Concurrency # Concurrency-related issues

class Lint:
    code: String
    level: LintLevel
    category: LintCategory
    message: String
    fix_hint: Option<String>
    easy_fix: Option<EasyFix>

impl Lint:
    fn new(code: String, level: LintLevel, category: LintCategory, message: String) -> Lint:
        Lint(
            code: code,
            level: level,
            category: category,
            message: message,
            fix_hint: nil,
            easy_fix: nil
        )

    fn with_fix(hint: String) -> Lint:
        Lint(
            code: self.code,
            level: self.level,
            category: self.category,
            message: self.message,
            fix_hint: Some(hint),
            easy_fix: self.easy_fix
        )

    fn with_easy_fix(fix: EasyFix) -> Lint:
        Lint(
            code: self.code,
            level: self.level,
            category: self.category,
            message: self.message,
            fix_hint: self.fix_hint,
            easy_fix: Some(fix)
        )

class LintResult:
    file_path: String
    line: Int
    column: Int
    lint: Lint

impl LintResult:
    fn new(file_path: String, line: Int, column: Int, lint: Lint) -> LintResult:
        LintResult(
            file_path: file_path,
            line: line,
            column: column,
            lint: lint
        )

    fn format() -> String:
        var level_str = "unknown"
        match self.lint.level:
            case Allow:
                level_str = "allow"
            case Warn:
                level_str = "warning"
            case Deny:
                level_str = "error"

        var output = self.file_path + ":" + self.line.to_string() + ":" + self.column.to_string() + ": " + level_str + "[" + self.lint.code + "]: " + self.lint.message

        match self.lint.fix_hint:
            case Some(hint):
                output = output + "\n" + "  hint: " + hint
            case nil:
                val _ = 0

        match self.lint.easy_fix:
            case Some(fix):
                output = output + "\n" + "  fix: available [{fix.id}] ({fix.confidence_str()})"
            case nil:
                val _ = 0

        return output

    fn has_easy_fix() -> Bool:
        self.lint.easy_fix.? == true

enum LintFileResult:
    LintFileOk([LintResult])
    LintFileErr(String)

# Valid TODO areas and priorities
fn _todo_areas() -> [text]:
    ["runtime", "codegen", "compiler", "parser", "type",
     "stdlib", "gpu", "ui", "test", "driver", "loader", "pkg", "sdn"]

fn _todo_priorities() -> [text]:
    ["P0", "P1", "P2", "P3", "critical", "high", "medium", "low"]

class Linter:
    lints: [Lint]
    results: [LintResult]
    config: LintConfig
