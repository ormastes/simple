# Linter main() entry and easy-fix collection/application.
use compiler.tools.lint.main.*
# Simple Language Linter
# Semantic lints for code quality and safety
# Usage: simple_lint <file.spl> [--deny-all] [--warn-all]

# I/O imports
use std.nogc_sync_mut.io.file_ops (file_read, file_exists, file_atomic_write)
use std.nogc_sync_mut.io.dir_ops (is_dir)
use app.io.cli_ops (get_args)

# Logging imports
use std.log.{error, info}

# Import EasyFix data types from stdlib
use std.tooling.easy_fix.*
use common.text.{escape_json}
use nogc_sync_mut.ui.theme_package.{validate_default_theme_package}
use compiler.semantics.lint.riscv_rtl_debuggability_lint.{lint_riscv_rtl_debuggability}
use compiler.core.ast.{module_get_decls}
use compiler.core.parser.{parse_module_silent, parser_has_errors, parser_set_had_error}
use compiler.semantics.lint.argument_count.{check_argument_count}
use compiler.semantics.lint.collection_patterns.{check_collection_patterns}
use compiler.semantics.lint.star_import.{check_star_export_file}
use compiler.semantics.lint.stub_impl.{check_stub_impl}
use compiler.semantics.lint.wide_public.{check_wide_public_file}

# File I/O wrapper

fn lint_cli_source(linter: Linter, path: String, content: String) -> [LintResult]:
    var results = linter.lint_source(path, content)
    if not path.ends_with(".spl"):
        return results

    val previous_parse_error = parser_has_errors()
    parse_module_silent(content, path)
    val parse_failed = parser_has_errors()
    parser_set_had_error(previous_parse_error)
    if parse_failed:
        val lint = Lint.new("PARSE001", LintLevel.Deny, LintCategory.Correctness, "Source did not parse")
        results.push(LintResult.new(path, 1, 0, lint))
        return results

    val config = resolve_lint_config(linter.config, path, content)
    val decls = module_get_decls()
    val lines = content.split("\n")
    for warning in check_argument_count(decls):
        if not should_keep_lint_result(config, warning.code):
            continue
        val base_level = if warning.code == "ARG002": LintLevel.Deny else: LintLevel.Warn
        val level = apply_config_level(config, warning.code, base_level)
        val lint = Lint.new(warning.code, level, LintCategory.Style, warning.message)
            .with_fix(warning.hint)
        results.push(LintResult.new(path, warning.line, 0, lint))
    for warning in check_collection_patterns(decls):
        if not should_keep_lint_result(config, warning.code):
            continue
        val base_level = if warning.code == "COLL001" or warning.code == "COLL006": LintLevel.Deny else: LintLevel.Warn
        val level = apply_config_level(config, warning.code, base_level)
        val lint = Lint.new(warning.code, level, LintCategory.Warning, warning.message)
            .with_fix(warning.hint)
        results.push(LintResult.new(path, lint_cli_find_fn_line(lines, warning.item_name), 0, lint))
    for warning in check_stub_impl(decls):
        # STUB003 remains the generic source lint so one placeholder emits once.
        if warning.code != "STUB001" and warning.code != "STUB002":
            continue
        if not should_keep_lint_result(config, warning.code):
            continue
        val base_level = if warning.code == "STUB001": LintLevel.Warn else: LintLevel.Allow
        val level = apply_config_level(config, warning.code, base_level)
        val lint = Lint.new(warning.code, level, LintCategory.Warning, warning.message)
            .with_fix(warning.hint)
        results.push(LintResult.new(path, warning.line, 0, lint))
    # W0406 already comes from the text EasyFix owner. Add only the parsed
    # export sibling here so wildcard imports are not reported twice.
    for warning in check_star_export_file(decls, path):
        if not should_keep_lint_result(config, warning.code):
            continue
        val level = apply_config_level(config, warning.code, LintLevel.Warn)
        val lint = Lint.new(warning.code, level, LintCategory.Warning, warning.message)
        results.push(LintResult.new(path, lint_cli_find_decl_line(lines, "export ", warning.module_path), 0, lint))
    for warning in check_wide_public_file(decls, path):
        if not should_keep_lint_result(config, warning.code):
            continue
        val level = apply_config_level(config, warning.code, LintLevel.Warn)
        val message = "{warning.message} ({warning.export_count} symbols, threshold {warning.threshold})"
        val lint = Lint.new(warning.code, level, LintCategory.Warning, message)
        results.push(LintResult.new(path, warning.line, 0, lint))
    results

fn lint_cli_find_decl_line(lines: [text], prefix: text, module_path: text) -> i64:
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed.starts_with(prefix) and trimmed.contains(module_path):
            return i + 1
        i = i + 1
    1

# Locate a declaration line without mistaking comment or string decoys for a function.
fn lint_cli_find_fn_line(lines: [text], fn_name: text) -> i64:
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        val is_fn_decl = trimmed.starts_with("fn ") or trimmed.starts_with("pub fn ") or trimmed.starts_with("static fn ") or trimmed.starts_with("pub static fn ") or trimmed.starts_with("async fn ") or trimmed.starts_with("pub async fn ")
        if is_fn_decl:
            if trimmed.contains("fn {fn_name}(") or trimmed.contains("fn {fn_name}<"):
                return i + 1
        i = i + 1
    0

fn main() -> Int:
    val args = get_args()
    val json_output = args.contains("--json")

    if args.len() < 2:
        if json_output:
            print("{\"type\":\"lint-error\",\"message\":\"no input files\"}")
            return 2
        print("Usage: simple_lint <file.spl> [options]")
        print("")
        print("Options:")
        print("  --deny-all        Treat all warnings as errors")
        print("  --warn-all        Enable all style lints")
        print("  --profile=<tier>  Strictness tier: moderate | lib | reliable")
        print("  --json            Output in JSON format")
        print("  --fix             Apply safe auto-fixes")
        print("  --fix-all         Apply all fixes regardless of confidence")
        print("  --fix-dry-run     Show what would be fixed without applying")
        print("  --fix-interactive Prompt for each fix")
        print("")
        print("Lint categories:")
        print("  Safety (S): Memory safety and null checks")
        print("  Correctness (C): Logic errors")
        print("  Warning (W): Potential issues")
        print("  Style (ST): Code style")
        print("  Concurrency (CC): Thread safety")
        print("  TODO (T): TODO/FIXME format [area][priority]")
        print("  Stub (STUB): Trivial/dummy implementations")
        return 1

    val file_path = args[1]

    # Verify file exists
    if not file_exists(file_path):
        if json_output:
            print("{\"type\":\"lint-error\",\"file\":\"{escape_json(file_path)}\",\"message\":\"file not found\"}")
        else:
            error("lint", "File not found: " + file_path)
        return 1

    run_lint_file(file_path, args)

# Lint a single file and print a report, shared by the standalone
# `simple_lint` entry above and the `simple lint` CLI wrapper
# (app.io.cli_lint_commands.run_lint_command). Returns 0 when the file is
# clean (or only warnings, unless --deny-all is set), 1 otherwise.
fn run_lint_file(file_path: String, args: [text]) -> Int:
    val deny_all = args.contains("--deny-all")
    val warn_all = args.contains("--warn-all")
    val json_output = args.contains("--json")
    val fix_mode = args.contains("--fix")
    val fix_all = args.contains("--fix-all")
    val fix_dry_run = args.contains("--fix-dry-run")

    # Run linter (loads config from simple.sdn automatically)
    var linter = Linter.new()

    # Try to load config relative to the target file
    val sdn_path = find_project_sdn(file_path)
    if sdn_path != "":
        linter.config = LintConfig.from_sdn_file(sdn_path)
    if linter.config.error != "":
        if json_output:
            print("{\"type\":\"lint-error\",\"message\":\"{escape_json(linter.config.error)}\"}")
        else:
            error("lint", linter.config.error)
        return 2

    # --profile=<tier> selects the strictness tier (moderate|lib|reliable).
    # A file-header @profile() may still override this (most-local-wins).
    for arg in args:
        if arg.starts_with("--profile="):
            val prof_str = arg.slice(10, arg.len())
            match parse_lint_profile(prof_str):
                case Some(profile):
                    linter.config.set_profile(profile)
                case nil:
                    if json_output:
                        print("{\"type\":\"lint-error\",\"message\":\"unknown profile: {escape_json(prof_str)}\"}")
                    else:
                        error("lint", "Unknown profile: " + prof_str)
                    return 2

    if warn_all:
        for lint_name in all_lint_names():
            match linter.config.get_level(lint_name):
                case Allow:
                    linter.config.set_level(lint_name, LintLevel.Warn)
                case _:
                    val _ = 0

    var lint_result = LintFileResult.LintFileErr("Failed to read file: {file_path}")
    match lint_read_file(file_path):
        case LintReadFileResult.ReadFileErr(error):
            lint_result = LintFileResult.LintFileErr(error)
        case LintReadFileResult.ReadFileOk(content):
            lint_result = LintFileResult.LintFileOk(lint_cli_source(linter, file_path, content))
    match lint_result:
        case LintFileResult.LintFileOk(results):
            if results.is_empty():
                if json_output:
                    print("{\"type\":\"lint-file-summary\",\"file\":\"{escape_json(file_path)}\",\"errors\":0,\"warnings\":0,\"fixes\":0}")
                else:
                    info("lint", "No issues found in " + file_path)
                return 0
            else:
                var error_count = 0
                var warning_count = 0
                var fix_count = 0

                for lint_item in results:
                    if json_output:
                        var level_text = "allow"
                        match lint_item.lint.level:
                            case Deny: level_text = "error"
                            case Warn: level_text = "warning"
                            case Allow: val _ = 0
                        print("{\"type\":\"lint-diagnostic\",\"file\":\"{escape_json(lint_item.file_path)}\",\"line\":{lint_item.line},\"column\":{lint_item.column},\"level\":\"{level_text}\",\"code\":\"{escape_json(lint_item.lint.code)}\",\"message\":\"{escape_json(lint_item.lint.message)}\"}")
                    else:
                        print(lint_item.format())

                    match lint_item.lint.level:
                        case Deny:
                            error_count = error_count + 1
                        case Warn:
                            warning_count = warning_count + 1
                            if deny_all:
                                error_count = error_count + 1
                        case Allow:
                            val _ = 0

                    if lint_item.has_easy_fix():
                        fix_count = fix_count + 1

                if json_output:
                    print("{\"type\":\"lint-file-summary\",\"file\":\"{escape_json(file_path)}\",\"errors\":{error_count},\"warnings\":{warning_count},\"fixes\":{fix_count}}")
                else:
                    print("")
                    print("Found {error_count} error(s), {warning_count} warning(s), {fix_count} auto-fix(es) available")

                # Apply fixes if requested
                if (fix_mode or fix_all or fix_dry_run) and fix_count > 0:
                    val fixes_to_apply = collect_easy_fixes(results, fix_all)
                    if not fixes_to_apply.is_empty():
                        if not apply_collected_fixes(file_path, fixes_to_apply, fix_dry_run, json_output):
                            return 1

                if error_count > 0:
                    return 1
                else:
                    return 0

        case LintFileResult.LintFileErr(error):
            if json_output:
                print("{\"type\":\"lint-error\",\"file\":\"{escape_json(file_path)}\",\"message\":\"{escape_json(error)}\"}")
            else:
                error("lint", error)
            return 1

    return 0

fn collect_easy_fixes(results: [LintResult], include_all: Bool) -> [EasyFix]:
    var fixes: [EasyFix] = []
    for result in results:
        match result.lint.easy_fix:
            case Some(fix):
                if include_all or fix.is_safe():
                    fixes.push(fix)
            case nil:
                val _ = 0
    fixes

fn apply_collected_fixes(file_path: String, fixes: [EasyFix], dry_run: Bool, json_output: Bool) -> Bool:
    val source = file_read(file_path)
    if source == "":
        if json_output:
            print("{\"type\":\"lint-error\",\"file\":\"{escape_json(file_path)}\",\"message\":\"reading file for fix failed\"}")
        else:
            error("lint", "reading file for fix failed: {file_path}")
        return false

    # Sort replacements by position descending and apply
    var all_replacements: [Replacement] = []
    for fix in fixes:
        for rep in easyfix_replacements(fix):
            all_replacements.push(rep)

    var sort_i = 0
    while sort_i < all_replacements.len():
        var sort_j = sort_i + 1
        while sort_j < all_replacements.len():
            val left = all_replacements[sort_i]
            val right = all_replacements[sort_j]
            if left.start < right.start:
                all_replacements[sort_i] = right
                all_replacements[sort_j] = left
            sort_j = sort_j + 1
        sort_i = sort_i + 1

    var new_source = source
    for rep in all_replacements:
        if rep.start <= new_source.len() and rep.end <= new_source.len():
            new_source = new_source.slice(0, rep.start) + rep.new_text + new_source.slice(rep.end)

    if dry_run:
        if json_output:
            print("{\"type\":\"lint-fix-summary\",\"file\":\"{escape_json(file_path)}\",\"mode\":\"dry-run\",\"fixes\":{fixes.len()}}")
        else:
            print("\nDry run - would apply {fixes.len()} fix(es):")
            for fix in fixes:
                print("  [{easyfix_id(fix)}] {easyfix_description(fix)}")
    else:
        if not file_atomic_write(file_path, new_source):
            if json_output:
                print("{\"type\":\"lint-error\",\"file\":\"{escape_json(file_path)}\",\"message\":\"atomic fix write failed\"}")
            else:
                error("lint", "atomic fix write failed: {file_path}")
            return false
        if json_output:
            print("{\"type\":\"lint-fix-summary\",\"file\":\"{escape_json(file_path)}\",\"mode\":\"applied\",\"fixes\":{fixes.len()}}")
        else:
            print("\nApplied {fixes.len()} fix(es):")
            for fix in fixes:
                print("  [{easyfix_id(fix)}] {easyfix_description(fix)}")
    true
