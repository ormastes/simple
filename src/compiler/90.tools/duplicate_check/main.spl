#!/usr/bin/env simple
# Duplication detection CLI

use compiler.tools.duplicate_check.config (load_config, DuplicationConfig)
use compiler.tools.duplicate_check.detector.{collect_files, find_duplicates_in_file, find_duplicates_in_file_with_hash_filter, collect_repeated_hashes, group_by_hash, refine_groups_with_similarity, sort_by_impact, new_token_interner, HashScanSummary, DuplicateGroup, DuplicateBlock}
use compiler.tools.duplicate_check.formatter (print_text_report, print_json_report, write_sdn_database)
use compiler.tools.duplicate_check.debug (init_debug)
use compiler.tools.duplicate_check.cache.{new_token_cache_manager, get_cache_stats}
use compiler.tools.duplicate_check.parallel.{process_files_parallel, ParallelConfig}
use compiler.tools.duplicate_check.incremental.{load_incremental_cache, process_files_incremental, format_incremental_stats, normalize_block_hashes}
use compiler.tools.duplicate_check.semantic.{run_semantic_analysis}
use compiler.tools.duplicate_check.semantic_formatter.{print_semantic_text_report, print_semantic_json_report}
use std.ffi.cli.{cli_get_args, cli_exit}

fn normalize_argv(all_args: [text]) -> [text]:
    var args: [text] = []
    var entry_idx = -1
    var command_idx = -1

    var i = 0
    while i < all_args.len():
        val arg = all_args[i]
        if command_idx < 0 and arg == "duplicate-check":
            command_idx = i
        if entry_idx < 0 and arg.ends_with("duplicate_check/main.spl"):
            entry_idx = i
        elif entry_idx < 0 and arg.ends_with("main.spl"):
            entry_idx = i
        i = i + 1

    var start_idx = 0
    if command_idx >= 0:
        start_idx = command_idx
    elif entry_idx >= 0:
        start_idx = entry_idx + 1
        args.push("duplicate-check")
    elif all_args.len() > 0:
        start_idx = 1
        args.push("duplicate-check")

    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn collect_command_args(all_args: [text]) -> [text]:
    val argv = normalize_argv(all_args)
    if argv.len() <= 1:
        return []

    var cmd_args = []
    var i = 1
    while i < argv.len():
        cmd_args.push(argv[i])
        i = i + 1
    cmd_args

fn build_groups_from_blocks(all_blocks: [DuplicateBlock], config: DuplicationConfig, cache_manager) -> [DuplicateGroup]:
    val exact_groups = group_by_hash(all_blocks, config)
    val refined_groups = if config.use_cosine_similarity:
        refine_groups_with_similarity(exact_groups, all_blocks, config, cache_manager)
    else:
        exact_groups
    sort_by_impact(refined_groups)

fn scan_files_sequential(files: [text], config: DuplicationConfig, cache_manager) -> [DuplicateBlock]:
    var all_blocks: [DuplicateBlock] = []
    val interner = new_token_interner()
    val hash_scan = if config.use_cosine_similarity:
        HashScanSummary(repeated_hashes: {}, candidate_files: {})
    else:
        collect_repeated_hashes(files, config, cache_manager, interner)

    for file in files:
        if not config.use_cosine_similarity and not hash_scan.candidate_files.contains_key(file):
            continue
        val blocks = if config.use_cosine_similarity:
            find_duplicates_in_file(file, config, cache_manager, interner)
        else:
            find_duplicates_in_file_with_hash_filter(file, config, cache_manager, interner, hash_scan.repeated_hashes)
        all_blocks.merge(blocks)

    normalize_block_hashes(all_blocks)

fn scan_files(files: [text], config: DuplicationConfig, cache_manager) -> ([DuplicateBlock], text):
    if config.use_incremental:
        val incremental_cache = load_incremental_cache(config.incremental_cache_path, config)
        val result = process_files_incremental(files, config, incremental_cache, cache_manager)
        val blocks = result.0
        val stats = format_incremental_stats(result.1)
        return (blocks, stats)

    if config.use_parallel:
        val parallel_config = ParallelConfig(
            num_workers: config.num_workers,
            batch_size: 10,
            enabled: true
        )
        val blocks = process_files_parallel(files, parallel_config, cache_manager, config)
        return (blocks, "")

    (scan_files_sequential(files, config, cache_manager), "")

fn print_usage():
    print "Usage: simple duplicate-check [path] [options]"
    print ""
    print "Options:"
    print "  --min-tokens N      Minimum tokens per duplicate (default: 30)"
    print "  --min-lines N       Minimum lines per duplicate (default: 5)"
    print "  --min-impact N      Minimum impact score to report (default: 50)"
    print "  --format FORMAT     Output format: text, json, sdn (default: text)"
    print "  --exclude PATTERN   Exclude files matching pattern"
    print "  --verbose, -v       Show detailed progress information"
    print "  --quiet, -q         Suppress all output except results"
    print "  --cosine            Enable cosine similarity for fuzzy matching"
    print "  --parallel          Enable parallel processing"
    print "  --jobs N            Number of parallel workers (implies --parallel)"
    print "  --no-cache          Disable incremental cache"
    print "  --cache-path PATH   Path to incremental cache (enables caching)"
    print "  --semantic          Enable semantic doc similarity analysis"
    print "  --semantic-threshold N  Similarity threshold (default: 0.90)"
    print "  --semantic-model NAME   Ollama model (default: nomic-embed-text)"
    print "  --ollama-url URL    Ollama base URL (default: http://localhost:11434)"
    print "  --rebuild-embeddings  Force rebuild embedding cache"
    print "  --benchmark         Run performance benchmark"
    print "  --benchmark-iterations N  Number of benchmark iterations (default: 3)"
    print "  --benchmark-save PATH     Save benchmark results to file"
    print "  --benchmark-compare PATH  Compare with previous benchmark"
    print "  --help, -h          Show this help"

fn parse_args(args: [text]) -> DuplicationConfig:
    var config = load_config()

    var i = 0
    while i < args.len():
        val arg = args[i]

        if arg == "--min-tokens" and i + 1 < args.len():
            config.min_tokens = int(args[i + 1])
            i = i + 2
        elif arg == "--min-lines" and i + 1 < args.len():
            config.min_lines = int(args[i + 1])
            i = i + 2
        elif arg == "--min-impact" and i + 1 < args.len():
            config.min_impact = int(args[i + 1])
            i = i + 2
        elif arg == "--format" and i + 1 < args.len():
            config.output_format = args[i + 1]
            i = i + 2
        elif arg == "--exclude" and i + 1 < args.len():
            config.exclude_patterns.push(args[i + 1])
            i = i + 2
        elif arg == "--verbose" or arg == "-v":
            config.verbose = true
            i = i + 1
        elif arg == "--quiet" or arg == "-q":
            config.quiet = true
            i = i + 1
        elif arg == "--parallel":
            config.use_parallel = true
            i = i + 1
        elif arg == "--jobs" and i + 1 < args.len():
            config.use_parallel = true
            config.num_workers = int(args[i + 1])
            i = i + 2
        elif arg == "--cosine":
            config.use_cosine_similarity = true
            # Cosine mode needs lexical detail to avoid collapsing unrelated
            # helper bodies into the same structural feature vectors.
            config.ignore_identifiers = false
            config.ignore_literals = false
            i = i + 1
        elif arg == "--semantic":
            config.use_semantic = true
            i = i + 1
        elif arg == "--semantic-threshold" and i + 1 < args.len():
            config.semantic_threshold = float(args[i + 1])
            i = i + 2
        elif arg == "--semantic-model" and i + 1 < args.len():
            config.semantic_model = args[i + 1]
            i = i + 2
        elif arg == "--ollama-url" and i + 1 < args.len():
            config.ollama_url = args[i + 1]
            i = i + 2
        elif arg == "--rebuild-embeddings":
            config.rebuild_embeddings = true
            i = i + 1
        elif arg == "--no-cache":
            config.use_incremental = false
            i = i + 1
        elif arg == "--cache-path" and i + 1 < args.len():
            config.use_incremental = true
            config.incremental_cache_path = args[i + 1]
            i = i + 2
        elif arg == "--help" or arg == "-h":
            print_usage()
            cli_exit(0)
        elif not arg.starts_with("-"):
            i = i + 1
        else:
            i = i + 1

    config

fn main():
    init_debug()

    val raw_args = cli_get_args() ?? []
    val argv = normalize_argv(raw_args)
    if argv.len() <= 1:
        print_usage()
        cli_exit(0)

    val cmd_args = collect_command_args(raw_args)

    val config = parse_args(cmd_args)

    val target_path = if cmd_args.len() > 0 and not cmd_args[0].starts_with("-"):
        cmd_args[0]
    else:
        "src/"

    # Semantic analysis mode
    if config.use_semantic:
        val report = run_semantic_analysis(target_path, config)
        if config.output_format == "json":
            print_semantic_json_report(report)
        else:
            print_semantic_text_report(report, config)
        val exit_code = if report.matches.len() > config.max_allowed: 1 else: 0
        cli_exit(exit_code)

    val files = collect_files(target_path, config)

    if files.len() == 0:
        print "No files found to scan"
        cli_exit(1)

    val cache_manager = new_token_cache_manager()

    val scan_result = scan_files(files, config, cache_manager)
    val groups = build_groups_from_blocks(scan_result.0, config, cache_manager)

    if config.verbose and not config.quiet:
        print ""
        if scan_result.1.len() > 0:
            print scan_result.1
        print get_cache_stats(cache_manager)
        print ""
    elif not config.quiet:
        print ""

    if config.output_format == "json":
        print_json_report(groups)
    elif config.output_format == "sdn":
        write_sdn_database(groups, config.report_path)
        print_text_report(groups)
    else:
        print_text_report(groups)

    val exit_code = if groups.len() > config.max_allowed: 1 else: 0
    cli_exit(exit_code)
