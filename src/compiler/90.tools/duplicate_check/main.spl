#!/usr/bin/env simple
# Duplication detection CLI

use compiler.tools.duplicate_check.config (load_config, DuplicationConfig)
use compiler.tools.duplicate_check.debug (init_debug)
use compiler.tools.duplicate_check.semantic.{run_semantic_analysis}
use compiler.tools.duplicate_check.semantic_formatter.{print_semantic_text_report, print_semantic_json_report}
use std.ffi.cli.{cli_get_args, cli_exit}

fn normalize_argv(all_args: [text]) -> [text]:
    var args: [text] = []
    var entry_idx = -1
    var command_idx = -1

    var i = 0
    while i < all_args.len():
        val arg = all_args[i]
        if command_idx < 0 and arg == "duplicate-check":
            command_idx = i
        if entry_idx < 0 and arg.ends_with("duplicate_check/main.spl"):
            entry_idx = i
        elif entry_idx < 0 and arg.ends_with("main.spl"):
            entry_idx = i
        i = i + 1

    var start_idx = 0
    if command_idx >= 0:
        start_idx = command_idx
    elif entry_idx >= 0:
        start_idx = entry_idx + 1
        args.push("duplicate-check")
    elif all_args.len() > 0:
        start_idx = 1
        args.push("duplicate-check")

    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn collect_command_args(all_args: [text]) -> [text]:
    val argv = normalize_argv(all_args)
    if argv.len() <= 1:
        return []

    var cmd_args = []
    var i = 1
    while i < argv.len():
        cmd_args.push(argv[i])
        i = i + 1
    cmd_args

fn print_usage():
    print "Usage: simple duplicate-check [path] [options]"
    print ""
    print "Default behavior:"
    print "  Run semantic documentation similarity analysis on the target path."
    print ""
    print "Options:"
    print "  --format FORMAT     Output format: text or json (default: text)"
    print "  --exclude PATTERN   Exclude files matching pattern"
    print "  --verbose, -v       Show detailed progress information"
    print "  --quiet, -q         Suppress all output except results"
    print "  --semantic          Optional compatibility flag; semantic analysis is already the default"
    print "  --semantic-threshold N  Similarity threshold (default: 0.90)"
    print "  --semantic-model NAME   Ollama model (default: nomic-embed-text)"
    print "  --ollama-url URL    Ollama base URL (default: http://localhost:11434)"
    print "  --rebuild-embeddings  Force rebuild embedding cache"
    print ""
    print "Deprecated compatibility flags:"
    print "  --min-tokens N      Accepted with warning; lexical duplication checking was removed"
    print "  --min-lines N       Accepted with warning; lexical duplication checking was removed"
    print "  --min-impact N      Accepted with warning; lexical duplication checking was removed"
    print "  --cosine            Accepted with warning; semantic-only analysis now runs instead"
    print "  --parallel          Accepted with warning; lexical duplication checking was removed"
    print "  --jobs N            Accepted with warning; lexical duplication checking was removed"
    print "  --no-cache          Accepted with warning; lexical duplication checking was removed"
    print "  --cache-path PATH   Accepted with warning; lexical duplication checking was removed"
    print "  --help, -h          Show this help"

fn append_unique_flag(flags: [text], seen: {text: bool}, flag: text):
    if seen[flag] ?? false:
        return
    seen[flag] = true
    flags.push(flag)

fn collect_deprecated_lexical_flags(args: [text]) -> [text]:
    var flags: [text] = []
    var seen = {}
    var i = 0
    while i < args.len():
        val arg = args[i]

        if arg == "--min-tokens" or arg.starts_with("--min-tokens="):
            append_unique_flag(flags, seen, "--min-tokens")
            i = if arg == "--min-tokens" and i + 1 < args.len(): i + 2 else: i + 1
        elif arg == "--min-lines" or arg.starts_with("--min-lines="):
            append_unique_flag(flags, seen, "--min-lines")
            i = if arg == "--min-lines" and i + 1 < args.len(): i + 2 else: i + 1
        elif arg == "--min-impact" or arg.starts_with("--min-impact="):
            append_unique_flag(flags, seen, "--min-impact")
            i = if arg == "--min-impact" and i + 1 < args.len(): i + 2 else: i + 1
        elif arg == "--cosine":
            append_unique_flag(flags, seen, "--cosine")
            i = i + 1
        elif arg == "--parallel":
            append_unique_flag(flags, seen, "--parallel")
            i = i + 1
        elif arg == "--jobs" or arg.starts_with("--jobs="):
            append_unique_flag(flags, seen, "--jobs")
            i = if arg == "--jobs" and i + 1 < args.len(): i + 2 else: i + 1
        elif arg == "--no-cache":
            append_unique_flag(flags, seen, "--no-cache")
            i = i + 1
        elif arg == "--cache-path" or arg.starts_with("--cache-path="):
            append_unique_flag(flags, seen, "--cache-path")
            i = if arg == "--cache-path" and i + 1 < args.len(): i + 2 else: i + 1
        else:
            i = i + 1
    flags

fn print_deprecation_warning(flags: [text]):
    if flags.len() == 0:
        return
    print "WARNING: lexical duplicate-check options are deprecated and no longer change analysis."
    print "  Requested: {flags.join(', ')}"
    print "  `simple duplicate-check` now runs semantic-only analysis."
    print ""

fn parse_args(args: [text]) -> DuplicationConfig:
    var config = load_config()
    config.use_semantic = true

    var i = 0
    while i < args.len():
        val arg = args[i]

        if arg == "--min-tokens" and i + 1 < args.len():
            config.min_tokens = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-tokens="):
            config.min_tokens = int(arg.slice("--min-tokens=".len(), arg.len()))
            i = i + 1
        elif arg == "--min-lines" and i + 1 < args.len():
            config.min_lines = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-lines="):
            config.min_lines = int(arg.slice("--min-lines=".len(), arg.len()))
            i = i + 1
        elif arg == "--min-impact" and i + 1 < args.len():
            config.min_impact = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-impact="):
            config.min_impact = int(arg.slice("--min-impact=".len(), arg.len()))
            i = i + 1
        elif arg == "--format" and i + 1 < args.len():
            config.output_format = args[i + 1]
            i = i + 2
        elif arg.starts_with("--format="):
            config.output_format = arg.slice("--format=".len(), arg.len())
            i = i + 1
        elif arg == "--exclude" and i + 1 < args.len():
            config.exclude_patterns.push(args[i + 1])
            i = i + 2
        elif arg.starts_with("--exclude="):
            config.exclude_patterns.push(arg.slice("--exclude=".len(), arg.len()))
            i = i + 1
        elif arg == "--verbose" or arg == "-v":
            config.verbose = true
            i = i + 1
        elif arg == "--quiet" or arg == "-q":
            config.quiet = true
            i = i + 1
        elif arg == "--parallel":
            config.use_parallel = true
            i = i + 1
        elif arg == "--jobs" and i + 1 < args.len():
            config.use_parallel = true
            config.num_workers = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--jobs="):
            config.use_parallel = true
            config.num_workers = int(arg.slice("--jobs=".len(), arg.len()))
            i = i + 1
        elif arg == "--cosine":
            config.use_cosine_similarity = true
            config.ignore_identifiers = false
            config.ignore_literals = false
            i = i + 1
        elif arg == "--semantic":
            config.use_semantic = true
            i = i + 1
        elif arg == "--semantic-threshold" and i + 1 < args.len():
            config.semantic_threshold = float(args[i + 1])
            i = i + 2
        elif arg.starts_with("--semantic-threshold="):
            config.semantic_threshold = float(arg.slice("--semantic-threshold=".len(), arg.len()))
            i = i + 1
        elif arg == "--semantic-model" and i + 1 < args.len():
            config.semantic_model = args[i + 1]
            i = i + 2
        elif arg.starts_with("--semantic-model="):
            config.semantic_model = arg.slice("--semantic-model=".len(), arg.len())
            i = i + 1
        elif arg == "--ollama-url" and i + 1 < args.len():
            config.ollama_url = args[i + 1]
            i = i + 2
        elif arg.starts_with("--ollama-url="):
            config.ollama_url = arg.slice("--ollama-url=".len(), arg.len())
            i = i + 1
        elif arg == "--rebuild-embeddings":
            config.rebuild_embeddings = true
            i = i + 1
        elif arg == "--no-cache":
            config.use_incremental = false
            i = i + 1
        elif arg == "--cache-path" and i + 1 < args.len():
            config.use_incremental = true
            config.incremental_cache_path = args[i + 1]
            i = i + 2
        elif arg.starts_with("--cache-path="):
            config.use_incremental = true
            config.incremental_cache_path = arg.slice("--cache-path=".len(), arg.len())
            i = i + 1
        elif arg == "--help" or arg == "-h":
            print_usage()
            cli_exit(0)
        elif not arg.starts_with("-"):
            i = i + 1
        else:
            i = i + 1

    config

fn main():
    init_debug()

    val raw_args = cli_get_args() ?? []
    val argv = normalize_argv(raw_args)
    if argv.len() <= 1:
        print_usage()
        cli_exit(0)

    val cmd_args = collect_command_args(raw_args)

    val config = parse_args(cmd_args)
    val deprecated_flags = collect_deprecated_lexical_flags(cmd_args)

    val target_path = if cmd_args.len() > 0 and not cmd_args[0].starts_with("-"):
        cmd_args[0]
    else:
        "src/"

    print_deprecation_warning(deprecated_flags)

    val report = run_semantic_analysis(target_path, config)
    if config.output_format == "json":
        print_semantic_json_report(report)
    else:
        print_semantic_text_report(report, config)

    val exit_code = if report.matches.len() > config.max_allowed: 1 else: 0
    cli_exit(exit_code)
