#!/usr/bin/env simple
# Duplication detection CLI

use compiler.tools.duplicate_check.config (load_config, DuplicationConfig, analysis_mode, apply_analysis_mode)
use compiler.tools.duplicate_check.debug (init_debug)
use compiler.tools.duplicate_check.cache.{new_token_cache_manager}
use compiler.tools.duplicate_check.detector.{collect_files, find_duplicates_with_options}
use compiler.tools.duplicate_check.formatter.{print_text_report, print_json_report}
use compiler.tools.duplicate_check.semantic.{run_semantic_analysis}
use compiler.tools.duplicate_check.semantic_formatter.{print_semantic_text_report, print_semantic_json_report}
use std.ffi.cli.{cli_get_args, cli_exit}

fn normalize_argv(all_args: [text]) -> [text]:
    var args: [text] = []
    var entry_idx = -1
    var command_idx = -1

    var i = 0
    while i < all_args.len():
        val arg = all_args[i]
        if command_idx < 0 and arg == "duplicate-check":
            command_idx = i
        if entry_idx < 0 and arg.ends_with("duplicate_check/main.spl"):
            entry_idx = i
        elif entry_idx < 0 and arg.ends_with("main.spl"):
            entry_idx = i
        i = i + 1

    var start_idx = 0
    if command_idx >= 0:
        start_idx = command_idx
    elif entry_idx >= 0:
        start_idx = entry_idx + 1
        args.push("duplicate-check")
    elif all_args.len() > 0:
        start_idx = 1
        args.push("duplicate-check")

    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn collect_command_args(all_args: [text]) -> [text]:
    val argv = normalize_argv(all_args)
    if argv.len() <= 1:
        return []

    var cmd_args = []
    var i = 1
    while i < argv.len():
        cmd_args.push(argv[i])
        i = i + 1
    cmd_args

fn print_usage():
    print "Usage: simple duplicate-check [path] [options]"
    print ""
    print "Options:"
    print "  --mode MODE         Analysis mode: semantic, token, cosine (default: semantic)"
    print "  --format FORMAT     Output format: text or json (default: text)"
    print "  --exclude PATTERN   Exclude files matching pattern"
    print "  --verbose, -v       Show detailed progress information"
    print "  --quiet, -q         Suppress all output except results"
    print "  --semantic          Alias for --mode semantic"
    print "  --token             Alias for --mode token"
    print "  --cosine            Alias for --mode cosine"
    print "  --similarity-threshold N  Cosine similarity threshold (default: 0.85)"
    print "  --min-tokens N      Minimum tokens for token/cosine scans (default: 30)"
    print "  --min-lines N       Minimum duplicated lines for token/cosine scans (default: 5)"
    print "  --min-impact N      Minimum impact score for lexical reports"
    print "  --semantic-threshold N  Similarity threshold (default: 0.90)"
    print "  --semantic-model NAME   Ollama model (default: nomic-embed-text)"
    print "  --ollama-url URL    Ollama base URL (default: http://localhost:11434)"
    print "  --rebuild-embeddings  Force rebuild embedding cache"
    print "  --parallel          Enable the shared scheduling path"
    print "  --jobs N            Advisory worker count for the scheduling path"
    print "  --no-cache          Disable incremental cache reuse"
    print "  --cache-path PATH   Incremental cache path"
    print "  --help, -h          Show this help"

fn set_mode(config: DuplicationConfig, mode: text) -> DuplicationConfig:
    if mode == "semantic" or mode == "token" or mode == "cosine":
        return apply_analysis_mode(config, mode)
    config

fn lexical_runtime_config(config: DuplicationConfig, mode: text) -> DuplicationConfig:
    if mode == "cosine":
        return apply_analysis_mode(config, "cosine")

    var runtime = config
    runtime.use_cosine_similarity = false
    runtime.selected_mode = "semantic"
    if mode == "token":
        # Token mode keeps the exact lexical threshold surface but uses the
        # cosine grouping path at a perfect-match threshold so identical
        # blocks still materialize deterministically in the CLI.
        runtime.use_cosine_similarity = true
        runtime.similarity_threshold = 0.999
    runtime

fn parse_args(args: [text]) -> DuplicationConfig:
    var config = load_config()
    config = apply_analysis_mode(config, analysis_mode(config))

    var i = 0
    while i < args.len():
        val arg = args[i]

        if arg == "--mode" and i + 1 < args.len():
            config = set_mode(config, args[i + 1])
            i = i + 2
        elif arg.starts_with("--mode="):
            config = set_mode(config, arg.slice("--mode=".len(), arg.len()))
            i = i + 1
        elif arg == "--min-tokens" and i + 1 < args.len():
            config.min_tokens = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-tokens="):
            config.min_tokens = int(arg.slice("--min-tokens=".len(), arg.len()))
            i = i + 1
        elif arg == "--min-lines" and i + 1 < args.len():
            config.min_lines = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-lines="):
            config.min_lines = int(arg.slice("--min-lines=".len(), arg.len()))
            i = i + 1
        elif arg == "--min-impact" and i + 1 < args.len():
            config.min_impact = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--min-impact="):
            config.min_impact = int(arg.slice("--min-impact=".len(), arg.len()))
            i = i + 1
        elif arg == "--format" and i + 1 < args.len():
            config.output_format = args[i + 1]
            i = i + 2
        elif arg.starts_with("--format="):
            config.output_format = arg.slice("--format=".len(), arg.len())
            i = i + 1
        elif arg == "--similarity-threshold" and i + 1 < args.len():
            config.similarity_threshold = float(args[i + 1])
            i = i + 2
        elif arg.starts_with("--similarity-threshold="):
            config.similarity_threshold = float(arg.slice("--similarity-threshold=".len(), arg.len()))
            i = i + 1
        elif arg == "--exclude" and i + 1 < args.len():
            config.exclude_patterns.push(args[i + 1])
            i = i + 2
        elif arg.starts_with("--exclude="):
            config.exclude_patterns.push(arg.slice("--exclude=".len(), arg.len()))
            i = i + 1
        elif arg == "--verbose" or arg == "-v":
            config.verbose = true
            i = i + 1
        elif arg == "--quiet" or arg == "-q":
            config.quiet = true
            i = i + 1
        elif arg == "--parallel":
            config.use_parallel = true
            i = i + 1
        elif arg == "--jobs" and i + 1 < args.len():
            config.use_parallel = true
            config.num_workers = int(args[i + 1])
            i = i + 2
        elif arg.starts_with("--jobs="):
            config.use_parallel = true
            config.num_workers = int(arg.slice("--jobs=".len(), arg.len()))
            i = i + 1
        elif arg == "--cosine":
            config = apply_analysis_mode(config, "cosine")
            i = i + 1
        elif arg == "--token":
            config = apply_analysis_mode(config, "token")
            i = i + 1
        elif arg == "--semantic":
            config = apply_analysis_mode(config, "semantic")
            i = i + 1
        elif arg == "--semantic-threshold" and i + 1 < args.len():
            config.semantic_threshold = float(args[i + 1])
            i = i + 2
        elif arg.starts_with("--semantic-threshold="):
            config.semantic_threshold = float(arg.slice("--semantic-threshold=".len(), arg.len()))
            i = i + 1
        elif arg == "--semantic-model" and i + 1 < args.len():
            config.semantic_model = args[i + 1]
            i = i + 2
        elif arg.starts_with("--semantic-model="):
            config.semantic_model = arg.slice("--semantic-model=".len(), arg.len())
            i = i + 1
        elif arg == "--ollama-url" and i + 1 < args.len():
            config.ollama_url = args[i + 1]
            i = i + 2
        elif arg.starts_with("--ollama-url="):
            config.ollama_url = arg.slice("--ollama-url=".len(), arg.len())
            i = i + 1
        elif arg == "--rebuild-embeddings":
            config.rebuild_embeddings = true
            i = i + 1
        elif arg == "--no-cache":
            config.use_incremental = false
            i = i + 1
        elif arg == "--cache-path" and i + 1 < args.len():
            config.use_incremental = true
            config.incremental_cache_path = args[i + 1]
            i = i + 2
        elif arg.starts_with("--cache-path="):
            config.use_incremental = true
            config.incremental_cache_path = arg.slice("--cache-path=".len(), arg.len())
            i = i + 1
        elif arg == "--help" or arg == "-h":
            print_usage()
            cli_exit(0)
        elif not arg.starts_with("-"):
            i = i + 1
        else:
            i = i + 1

    config

fn main():
    init_debug()

    val raw_args = cli_get_args() ?? []
    val argv = normalize_argv(raw_args)
    if argv.len() <= 1:
        print_usage()
        cli_exit(0)

    val cmd_args = collect_command_args(raw_args)

    val config = parse_args(cmd_args)

    val target_path = if cmd_args.len() > 0 and not cmd_args[0].starts_with("-"):
        cmd_args[0]
    else:
        "src/"

    val mode = analysis_mode(config)
    if mode == "semantic":
        val report = run_semantic_analysis(target_path, config)
        if config.output_format == "json":
            print_semantic_json_report(report)
        else:
            print_semantic_text_report(report, config)

        val exit_code = if report.matches.len() > config.max_allowed: 1 else: 0
        cli_exit(exit_code)

    val files = collect_files(target_path, config)
    val runtime_config = lexical_runtime_config(config, mode)
    val cache_manager = new_token_cache_manager()
    val groups = find_duplicates_with_options(
        files,
        runtime_config,
        cache_manager,
        runtime_config.use_parallel,
        runtime_config.use_incremental,
        runtime_config.incremental_cache_path
    )

    if config.output_format == "json":
        print_json_report(groups, mode)
    else:
        print_text_report(groups, mode)

    val exit_code = if groups.len() > config.max_allowed: 1 else: 0
    cli_exit(exit_code)
