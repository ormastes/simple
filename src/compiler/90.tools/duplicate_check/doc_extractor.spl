# Doc comment and signature extraction from .spl files

use compiler.tools.duplicate_check.config.{DuplicationConfig, default_config}
use compiler.tools.duplicate_check.detector.{collect_files}
use compiler.tools.duplicate_check.math_utils.{find_substr}
use std.nogc_sync_mut.io.file_ops.{file_read}
use std.nogc_sync_mut.io.process_ops.{shell_output}
struct DocEntry:
    file_path: text
    line_number: i64
    item_name: text
    item_kind: text
    signature: text
    doc_comment: text
    has_doc: bool

fn make_doc_entry(file_path: text, line_number: i64, item_name: text, item_kind: text, signature: text, pending_doc: text) -> DocEntry:
    val has = pending_doc.len() > 0
    DocEntry(
        file_path: file_path,
        line_number: line_number,
        item_name: item_name,
        item_kind: item_kind,
        signature: signature,
        doc_comment: pending_doc,
        has_doc: has
    )

fn extract_docs_from_file(file_path: text) -> [DocEntry]:
    var content = file_read(file_path) ?? ""
    if content.len() == 0:
        content = shell_output("cat '{file_path}' 2>/dev/null || true", "")
    if content.len() == 0:
        return []

    val lines = content.split("\n")
    var entries: [DocEntry] = []
    var pending_doc = ""
    var i = 0

    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()

        if trimmed.starts_with("#") and not trimmed.starts_with("#!"):
            val comment_text = process_doc_line(trimmed)
            if pending_doc.len() > 0:
                pending_doc = pending_doc + " " + comment_text
            else:
                pending_doc = comment_text
            i = i + 1
            continue

        if trimmed.starts_with("\"\"\""):
            val doc_text = collect_docstring(lines, i)
            if doc_text.len() > 0:
                if pending_doc.len() > 0:
                    pending_doc = pending_doc + " " + doc_text
                else:
                    pending_doc = doc_text
            i = i + 1
            while i < lines.len() and not lines[i].trim().ends_with("\"\"\""):
                i = i + 1
            if i < lines.len():
                i = i + 1
            continue

        val is_fn = trimmed.starts_with("fn ")
        val is_static_fn = trimmed.starts_with("static fn ")
        if is_fn or is_static_fn:
            val sig = extract_signature(trimmed)
            val name = extract_fn_name(trimmed)
            var doc = pending_doc
            if doc.len() == 0 and i + 1 < lines.len():
                val next_trimmed = lines[i + 1].trim()
                if next_trimmed.starts_with("\"\"\""):
                    doc = collect_docstring(lines, i + 1)
            entries.push(make_doc_entry(file_path, i + 1, name, "fn", sig, doc))
            pending_doc = ""
            i = i + 1
            continue

        if trimmed.starts_with("struct "):
            val name = extract_type_name(trimmed, "struct ")
            entries.push(make_doc_entry(file_path, i + 1, name, "struct", trimmed, pending_doc))
            pending_doc = ""
            i = i + 1
            continue

        if trimmed.starts_with("class "):
            val name = extract_type_name(trimmed, "class ")
            entries.push(make_doc_entry(file_path, i + 1, name, "class", trimmed, pending_doc))
            pending_doc = ""
            i = i + 1
            continue

        if trimmed.starts_with("enum "):
            val name = extract_type_name(trimmed, "enum ")
            entries.push(make_doc_entry(file_path, i + 1, name, "enum", trimmed, pending_doc))
            pending_doc = ""
            i = i + 1
            continue

        if trimmed.len() > 0:
            pending_doc = ""

        i = i + 1

    entries

fn build_exclude_args(exclude: [text]) -> text:
    var args = ""
    for pattern in exclude:
        if args.len() > 0:
            args = args + " "
        args = args + "-not -path \"*/" + pattern + "*\""
    args

fn extract_docs_batch(path: text, exclude: [text]) -> [DocEntry]:
    val exclude_args = build_exclude_args(exclude)
    val sa = "BEGIN { pending=\"\"; in_doc=0; prev_file=\"\" } "
    val sb = "FILENAME != prev_file { pending=\"\"; in_doc=0; prev_file=FILENAME } "
    val sc = "in_doc==1 { line=$0; sub(/^[ \\t]+/, \"\", line); if (line ~ /\"\"\"$/) { sub(/\"\"\"$/, \"\", line); sub(/^[ \\t]+/, \"\", line); sub(/[ \\t]+$/, \"\", line); if (length(line)>0) { if (length(pending)>0) pending=pending \" \" line; else pending=line }; in_doc=0; next } else { if (length(line)>0) { if (length(pending)>0) pending=pending \" \" line; else pending=line }; next } } "
    val sd = "{ line=$0; sub(/^[ \\t]+/, \"\", line); sub(/[ \\t]+$/, \"\", line) } "
    val se = "line ~ /^#[^!]/ || line == \"#\" { cmt=line; sub(/^#+[ \\t]*/, \"\", cmt); if (length(pending)>0) pending=pending \" \" cmt; else pending=cmt; next } "
    val sf = "line ~ /^\"\"\"/ { if (line ~ /^\"\"\".*\"\"\"$/ && length(line)>6) { inner=substr(line,4,length(line)-6); sub(/^[ \\t]+/, \"\", inner); sub(/[ \\t]+$/, \"\", inner); if (length(pending)>0) pending=pending \" \" inner; else pending=inner; next } else { rest=substr(line,4); sub(/^[ \\t]+/, \"\", rest); sub(/[ \\t]+$/, \"\", rest); if (length(rest)>0) { if (length(pending)>0) pending=pending \" \" rest; else pending=rest }; in_doc=1; next } } "
    val sg = "line ~ /^(static )?fn / { name=line; sub(/^static fn /, \"\", name); sub(/^fn /, \"\", name); sub(/[^a-zA-Z0-9_].*/, \"\", name); sig=line; pd=0; for(k=1;k<=length(line);k++) { c=substr(line,k,1); if(c==\"(\") pd++; if(c==\")\") pd--; if(c==\":\" && pd==0) { sig=substr(line,1,k-1); sub(/^[ \\t]+/, \"\", sig); sub(/[ \\t]+$/, \"\", sig); break } }; gsub(/\\t/, \" \", pending); printf \"%s\\t%d\\t%s\\t%s\\t%s\\t%s\\n\", FILENAME, FNR, name, \"fn\", sig, pending; pending=\"\"; next } "
    val sh_struct = "line ~ /^struct / { name=substr(line, 8); sub(/[^a-zA-Z0-9_].*/, \"\", name); gsub(/\\t/, \" \", pending); printf \"%s\\t%d\\t%s\\t%s\\t%s\\t%s\\n\", FILENAME, FNR, name, \"struct\", line, pending; pending=\"\"; next } "
    val si = "line ~ /^class / { name=substr(line, 7); sub(/[^a-zA-Z0-9_].*/, \"\", name); gsub(/\\t/, \" \", pending); printf \"%s\\t%d\\t%s\\t%s\\t%s\\t%s\\n\", FILENAME, FNR, name, \"class\", line, pending; pending=\"\"; next } "
    val sj = "line ~ /^enum / { name=substr(line, 6); sub(/[^a-zA-Z0-9_].*/, \"\", name); gsub(/\\t/, \" \", pending); printf \"%s\\t%d\\t%s\\t%s\\t%s\\t%s\\n\", FILENAME, FNR, name, \"enum\", line, pending; pending=\"\"; next } "
    val sk = "length(line) > 0 { pending=\"\" }"
    val full_script = sa + sb + sc + sd + se + sf + sg + sh_struct + si + sj + sk
    val cmd = "find {path} -name \"*.spl\" {exclude_args} 2>/dev/null | xargs -r awk \"{full_script}\" 2>/dev/null"
    val output = shell_output(cmd, "")
    if output.len() == 0:
        return []
    parse_batch_output(output)

fn parse_batch_output(output: text) -> [DocEntry]:
    val lines = output.split("\n")
    var entries: [DocEntry] = []
    for line in lines:
        if line.len() == 0:
            continue
        val parts = line.split("\t")
        if parts.len() < 6:
            continue
        val file_path = parts[0]
        val line_str = parts[1]
        var line_num = 0
        val line_bytes = line_str.bytes()
        var li = 0
        while li < line_bytes.len():
            val digit = line_bytes[li] - 48
            if digit >= 0 and digit <= 9:
                line_num = line_num * 10 + digit
            li = li + 1
        val item_name = parts[2]
        val item_kind = parts[3]
        val signature = parts[4]
        val doc_comment = parts[5]
        val entry = make_doc_entry(file_path, line_num, item_name, item_kind, signature, doc_comment)
        entries.push(entry)
    entries

fn extract_docs_from_directory(path: text, exclude: [text]) -> [DocEntry]:
    val batch_result = extract_docs_batch(path, exclude)
    if batch_result.len() > 0:
        return batch_result
    var config = default_config()
    config.exclude_patterns = exclude
    config.quiet = true
    val files = collect_files(path, config)
    var all_entries: [DocEntry] = []
    for file in files:
        val file_entries = extract_docs_from_file(file)
        for entry in file_entries:
            all_entries.push(entry)
    all_entries

fn collect_docstring(lines: [text], start: i64) -> text:
    val first = lines[start].trim()
    if first.starts_with("\"\"\"") and first.ends_with("\"\"\"") and first.len() > 6:
        return first[3:first.len() - 3].trim()
    var parts: [text] = []
    val first_content = first[3:].trim()
    if first_content.len() > 0:
        parts.push(first_content)
    var j = start + 1
    while j < lines.len():
        val lt = lines[j].trim()
        if lt.ends_with("\"\"\""):
            val before = lt[0:lt.len() - 3].trim()
            if before.len() > 0:
                parts.push(before)
            break
        if lt.len() > 0:
            parts.push(lt)
        j = j + 1
    parts.join(" ")

fn process_doc_line(raw: text) -> text:
    var s = raw
    while s.starts_with("#"):
        s = s[1:]
    s.trim()

fn process_doc_text(raw: text) -> text:
    val lines = raw.split("\n")
    var parts: [text] = []
    for line in lines:
        val processed = process_doc_line(line)
        if processed.len() > 0:
            parts.push(processed)
    parts.join(" ")

fn extract_signature(line: text) -> text:
    # Extract up to the colon that ends the signature
    val colon_idx = find_signature_end(line)
    if colon_idx >= 0:
        return line[0:colon_idx].trim()
    line.trim()

fn find_signature_end(line: text) -> i64:
    var paren_depth = 0
    val bytes = line.bytes()
    var i = 0
    while i < bytes.len():
        val b = bytes[i]
        if b == 40:
            paren_depth = paren_depth + 1
        elif b == 41:
            paren_depth = paren_depth - 1
        elif b == 58 and paren_depth == 0:
            return i
        i = i + 1
    -1

fn is_ident_byte(b: i64) -> bool:
    (b >= 97 and b <= 122) or (b >= 65 and b <= 90) or (b >= 48 and b <= 57) or b == 95

fn extract_fn_name(line: text) -> text:
    var start = 0
    if line.contains("fn "):
        val idx = find_substr(line, "fn ")
        if idx >= 0:
            start = idx + 3
    val bytes = line.bytes()
    var end = start
    while end < bytes.len() and is_ident_byte(bytes[end]):
        end = end + 1
    if end > start:
        return line[start:end]
    ""

fn extract_type_name(line: text, prefix: text) -> text:
    val start = prefix.len()
    val bytes = line.bytes()
    var end = start
    while end < bytes.len() and is_ident_byte(bytes[end]):
        end = end + 1
    if end > start:
        return line[start:end]
    ""

fn build_embedding_key(entry: DocEntry) -> text:
    val sig_part = entry.signature
    val doc_part = entry.doc_comment
    if doc_part.len() > 0:
        sig_part + " | " + doc_part
    else:
        sig_part

fn content_hash(s: text) -> text:
    val bytes = s.bytes()
    var acc = bytes.len() + 17
    var i = 0
    while i < bytes.len():
        acc = acc + bytes[i] + (i * 131)
        i = i + 1
    "{acc}"
