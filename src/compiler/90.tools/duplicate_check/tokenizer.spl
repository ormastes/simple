# Tokenizer for duplication detection
# Uses pure Simple lexer for performance

use app.duplicate_check.config (DuplicationConfig)

enum SimpleTokenKind:
    Identifier
    Keyword
    Operator
    Literal
    Punctuation
    Comment
    Whitespace

struct SimpleToken:
    kind: SimpleTokenKind
    value: text
    line: i64
    column: i64

fn token_to_string(token: SimpleToken) -> text:
    "{token.kind}:{token.value}"

fn tokenize(source: text, config: DuplicationConfig) -> [SimpleToken]:
    """Tokenize source code for duplication detection."""
    var result: [SimpleToken] = []
    var i = 0
    var line = 1
    var column = 1

    while i < source.len():
        val ch = source[i:i+1]
        var handled = false

        if ch == "\n":
            if not config.ignore_whitespace:
                result.push(SimpleToken(kind: SimpleTokenKind.Whitespace, value: "\n", line: line, column: column))
            line = line + 1
            column = 1
            i = i + 1
            handled = true

        if not handled:
            if ch == " " or ch == "\t":
                if not config.ignore_whitespace:
                    result.push(SimpleToken(kind: SimpleTokenKind.Whitespace, value: ch, line: line, column: column))
                i = i + 1
                column = column + 1
                handled = true

        if not handled:
            if ch == "#":
                while i < source.len() and source[i:i+1] != "\n":
                    i = i + 1
                handled = true

        if not handled:
            val is_letter = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
            if is_letter:
                var ident_parts: [text] = []
                var start_col = column
                while i < source.len():
                    val c = source[i:i+1]
                    val is_alnum = (c >= "a" and c <= "z") or (c >= "A" and c <= "Z") or (c >= "0" and c <= "9") or c == "_"
                    if not is_alnum:
                        break
                    ident_parts.push(c)
                    i = i + 1
                    column = column + 1
                val ident = ident_parts.join("")

                val keywords = ["fn", "val", "var", "if", "else", "while", "for", "match", "case", "return", "break", "continue", "class", "struct", "enum", "use", "export"]
                val is_keyword = keywords.contains(ident)

                val kind = if is_keyword: SimpleTokenKind.Keyword else: SimpleTokenKind.Identifier
                val value = if kind == SimpleTokenKind.Identifier and config.ignore_identifiers then "IDENTIFIER" else ident

                result.push(SimpleToken(kind: kind, value: value, line: line, column: start_col))
                handled = true

        if not handled:
            val is_digit = ch >= "0" and ch <= "9"
            if is_digit:
                var num_parts: [text] = []
                var start_col = column
                while i < source.len():
                    val c = source[i:i+1]
                    val is_numchar = (c >= "0" and c <= "9") or c == "."
                    if not is_numchar:
                        break
                    num_parts.push(c)
                    i = i + 1
                    column = column + 1
                val num = num_parts.join("")

                val value = if config.ignore_literals then "LITERAL" else num

                result.push(SimpleToken(kind: SimpleTokenKind.Literal, value: value, line: line, column: start_col))
                handled = true

        if not handled:
            if ch == "\"":
                var str_parts: [text] = ["\""]
                var start_col = column
                i = i + 1
                column = column + 1
                while i < source.len() and source[i:i+1] != "\"":
                    str_parts.push(source[i:i+1])
                    i = i + 1
                    column = column + 1
                if i < source.len():
                    str_parts.push("\"")
                    i = i + 1
                    column = column + 1
                val str_val = str_parts.join("")

                val value = if config.ignore_literals then "LITERAL" else str_val

                result.push(SimpleToken(kind: SimpleTokenKind.Literal, value: value, line: line, column: start_col))
                handled = true

        if not handled:
            # Direct comparisons instead of loop over 21-element array
            var matched = false
            if i + 1 < source.len():
                val two = source[i:i+2]
                if two == "==" or two == "!=" or two == "<=" or two == ">=" or two == "->":
                    result.push(SimpleToken(kind: SimpleTokenKind.Operator, value: two, line: line, column: column))
                    i = i + 2
                    column = column + 2
                    matched = true

            if not matched:
                if ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "=" or ch == "<" or ch == ">" or ch == ":" or ch == "." or ch == "," or ch == "(" or ch == ")" or ch == "[" or ch == "]" or ch == "{" or ch == "}":
                    result.push(SimpleToken(kind: SimpleTokenKind.Operator, value: ch, line: line, column: column))
                    i = i + 1
                    column = column + 1
                    matched = true

            if matched:
                handled = true

        if not handled:
            i = i + 1
            column = column + 1

    result

