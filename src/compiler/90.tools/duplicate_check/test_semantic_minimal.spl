#!/usr/bin/env simple
use compiler.tools.duplicate_check.semantic.{run_semantic_analysis_local}
use compiler.tools.duplicate_check.config.{default_config}

fn main():
    print "Running local semantic analysis on a small directory..."
    val config = default_config()
    val report = run_semantic_analysis_local("src/compiler/90.tools/duplicate_check/", config)
    print "Total items: {report.total_items}"
    print "Items with docs: {report.items_with_docs}"
    print "Matches: {report.matches.len()}"
    print "Missing docs: {report.missing_docs.len()}"
    print "Done!"
