# File selection helpers for duplicate detector

use compiler.tools.duplicate_check.config.{DuplicationConfig}
use std.nogc_sync_mut.io.dir_ops.{dir_walk_native}
use std.nogc_sync_mut.io.sffi_common.{is_absolute_path}

extern fn rt_path_absolute(path: text) -> text

fn collect_detector_files(path: text, config: DuplicationConfig) -> [text]:
    if path.ends_with(".spl"):
        if should_exclude_detector_path(path, config):
            return []
        return [path]

    val scan_path = rt_path_absolute(path).replace("\\", "/")
    val relative_root = detector_relative_root(path)
    var files = []
    for physical_path in dir_walk_native(scan_path):
        val file_path = detector_restore_relative_path(physical_path, scan_path, relative_root)
        if not file_path.ends_with(".spl"):
            continue
        if should_exclude_detector_path(file_path, config):
            continue
        files.push(file_path)

    files

fn detector_relative_root(path: text) -> text:
    if is_absolute_path(path):
        return ""
    var root = path.replace("\\", "/")
    while root.len() > 1 and root.ends_with("/"):
        root = root.substring(0, root.len() - 1)
    root

fn detector_restore_relative_path(physical_path: text, scan_path: text, relative_root: text) -> text:
    if relative_root == "":
        return physical_path
    val normalized = physical_path.replace("\\", "/")
    val prefix = scan_path + "/"
    if not normalized.starts_with(prefix):
        return physical_path
    val suffix = normalized.substring(prefix.len(), normalized.len())
    relative_root + "/" + suffix

fn should_exclude_detector_path(path: text, config: DuplicationConfig) -> bool:
    for pattern in config.exclude_patterns:
        if matches_detector_exclude(path, pattern):
            return true
    false

fn matches_detector_exclude(path: text, pattern: text) -> bool:
    val trimmed_pattern = pattern.trim()
    if trimmed_pattern.len() == 0:
        return false

    if trimmed_pattern.contains("*"):
        if wildcard_match(path, trimmed_pattern):
            return true

        val base_name = basename_text(path)
        if wildcard_match(base_name, trimmed_pattern):
            return true

        if trimmed_pattern.starts_with("**/"):
            val suffix_pattern = trimmed_pattern.substring(3, trimmed_pattern.len())
            if wildcard_match(path, suffix_pattern):
                return true
            return wildcard_match(base_name, suffix_pattern)

        return false

    if trimmed_pattern.ends_with("/"):
        val segment = trimmed_pattern.substring(0, trimmed_pattern.len() - 1)
        if segment.len() == 0:
            return false
        return path.contains("/{segment}/") or path.starts_with("{segment}/") or path.contains("{segment}/")

    path.contains(trimmed_pattern)

fn basename_text(path: text) -> text:
    var i = path.len() - 1
    while i >= 0:
        if path.substring(i, i + 1) == "/":
            return path.substring(i + 1, path.len())
        i = i - 1
    path

fn wildcard_match(value: text, pattern: text) -> bool:
    var value_idx = 0
    var pattern_idx = 0
    var star_idx = -1
    var match_idx = 0

    while value_idx < value.len():
        val pattern_matches = (
            pattern_idx < pattern.len() and
            pattern.substring(pattern_idx, pattern_idx + 1) == value.substring(value_idx, value_idx + 1)
        )

        if pattern_matches:
            value_idx = value_idx + 1
            pattern_idx = pattern_idx + 1
            continue

        val is_star = pattern_idx < pattern.len() and pattern.substring(pattern_idx, pattern_idx + 1) == "*"
        if is_star:
            star_idx = pattern_idx
            match_idx = value_idx
            pattern_idx = pattern_idx + 1
            continue

        if star_idx >= 0:
            pattern_idx = star_idx + 1
            match_idx = match_idx + 1
            value_idx = match_idx
            continue

        return false

    while pattern_idx < pattern.len() and pattern.substring(pattern_idx, pattern_idx + 1) == "*":
        pattern_idx = pattern_idx + 1

    pattern_idx == pattern.len()
