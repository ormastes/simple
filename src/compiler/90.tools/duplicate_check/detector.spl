#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Core duplication detection engine using Karp-Rabin rolling hash

use compiler.tools.duplicate_check.config.{DuplicationConfig}
use compiler.tools.duplicate_check.tokenizer.{SimpleToken, tokenize, token_to_string}
use compiler.tools.duplicate_check.features.{FeatureVec, extract_token_frequencies, build_feature_vector, cosine_similarity}
use compiler.tools.duplicate_check.debug.{debug_log, debug_log_progress}
use compiler.tools.duplicate_check.cache.{TokenCacheManager, get_cached_tokens, set_cached_tokens}
use compiler.tools.duplicate_check.detector_files.{collect_detector_files}
use std.nogc_sync_mut.io.file_ops.{file_read}

struct TokenInterner:
    strings: {text: i64}
    reverse: {i64: text}
    next_id: i64

fn new_token_interner() -> TokenInterner:
    TokenInterner(strings: {}, reverse: {}, next_id: 0)

fn intern_token(interner: TokenInterner, token_str: text) -> i64:
    if interner.strings.contains_key(token_str):
        interner.strings[token_str]
    else:
        val id = interner.next_id
        interner.strings[token_str] = id
        interner.reverse[id] = token_str
        interner.next_id = interner.next_id + 1
        id

fn log_progress(config: DuplicationConfig, message: text):
    """Print progress message if not quiet."""
    if not config.quiet:
        print message

fn log_verbose(config: DuplicationConfig, message: text):
    """Print verbose message if verbose mode enabled."""
    if config.verbose and not config.quiet:
        print message

struct DuplicateBlock:
    file: text
    line_start: i64
    line_end: i64
    token_count: i64
    hash_value: i64
    snippet_start_offset: i64
    snippet_end_offset: i64
    code: text

struct DuplicateGroup:
    blocks: [DuplicateBlock]
    occurrences: i64
    total_lines: i64
    impact_score: i64

struct HashScanSummary:
    repeated_hashes: {text: bool}
    candidate_files: {text: bool}

struct TokenWindowCandidate:
    index: i64
    end_index: i64
    line_start: i64
    line_end: i64
    hash_value: i64

struct SimilarityPrep:
    blocks: [DuplicateBlock]
    features: [FeatureVec]
    low_signal_flags: [bool]
    file_count: i64

fn rolling_hash(tokens: [SimpleToken], start: i64, window: i64) -> i64:
    """Compute rolling hash for token window with inlined character hashing."""
    var hash = 0
    val base = 31
    val mod_val = 1000000007

    var i = 0
    while i < window and start + i < tokens.len():
        val token = tokens[start + i]
        val token_str = token_to_string(token)

        val bytes = token_str.bytes()
        var char_code = 0
        var j = 0
        while j < bytes.len():
            char_code = char_code + bytes[j]
            j = j + 1

        hash = (hash * base + char_code) % mod_val
        i = i + 1

    hash

fn extract_code_snippet(source: text, tokens: [SimpleToken], start: i64, end_pos: i64) -> text:
    if start < 0 or start >= tokens.len():
        return ""
    val last_idx = end_pos - 1
    if last_idx < start or last_idx >= tokens.len():
        return ""
    val start_offset = tokens[start].start_offset
    val end_offset = tokens[last_idx].end_offset
    if start_offset < 0 or end_offset < start_offset or end_offset > source.len():
        return ""
    source[start_offset:end_offset]

fn block_line_count(block: DuplicateBlock) -> i64:
    block.line_end - block.line_start + 1

fn total_lines_for_blocks(blocks: [DuplicateBlock]) -> i64:
    var total_lines = 0
    for block in blocks:
        total_lines = total_lines + block_line_count(block)
    total_lines

fn sort_blocks_by_file_and_line(blocks: [DuplicateBlock]) -> [DuplicateBlock]:
    var sorted = blocks
    var i = 0
    while i < sorted.len() - 1:
        var j = 0
        while j < sorted.len() - i - 1:
            val left = sorted[j]
            val right = sorted[j + 1]
            val should_swap = if left.file > right.file:
                true
            elif left.file == right.file and left.line_start > right.line_start:
                true
            else:
                false
            if should_swap:
                sorted[j] = right
                sorted[j + 1] = left
            j = j + 1
        i = i + 1
    sorted

fn collapse_overlapping_blocks(blocks: [DuplicateBlock]) -> [DuplicateBlock]:
    if blocks.len() <= 1:
        return blocks

    val sorted = sort_blocks_by_file_and_line(blocks)
    var collapsed = [sorted[0]]
    var i = 1
    while i < sorted.len():
        val current = sorted[i]
        val last_idx = collapsed.len() - 1
        val previous = collapsed[last_idx]
        val overlaps_same_file = previous.file == current.file and current.line_start <= previous.line_end
        if overlaps_same_file:
            val merged_start = if previous.line_start < current.line_start: previous.line_start else: current.line_start
            val merged_end = if previous.line_end > current.line_end: previous.line_end else: current.line_end
            val merged_snippet_start = if previous.snippet_start_offset < current.snippet_start_offset: previous.snippet_start_offset else: current.snippet_start_offset
            val merged_snippet_end = if previous.snippet_end_offset > current.snippet_end_offset: previous.snippet_end_offset else: current.snippet_end_offset
            val merged_code = if previous.code.len() >= current.code.len(): previous.code else: current.code
            collapsed[last_idx] = DuplicateBlock(
                file: previous.file,
                line_start: merged_start,
                line_end: merged_end,
                token_count: if previous.token_count > current.token_count: previous.token_count else: current.token_count,
                hash_value: previous.hash_value,
                snippet_start_offset: merged_snippet_start,
                snippet_end_offset: merged_snippet_end,
                code: merged_code
            )
        else:
            collapsed.push(current)
        i = i + 1
    collapsed

fn build_duplicate_group(blocks: [DuplicateBlock]) -> DuplicateGroup:
    val deduped_blocks = collapse_overlapping_blocks(blocks)
    val total_lines = total_lines_for_blocks(deduped_blocks)
    DuplicateGroup(
        blocks: deduped_blocks,
        occurrences: deduped_blocks.len(),
        total_lines: total_lines,
        impact_score: deduped_blocks.len() * total_lines
    )

fn duplicate_block_signature(block: DuplicateBlock) -> text:
    "{block.token_count}|{block.code}"

fn materialize_block_code(block: DuplicateBlock, source_cache: {text: text}) -> DuplicateBlock:
    if block.code.len() > 0:
        return block

    var source = source_cache[block.file] ?? ""
    if source.len() == 0:
        source = file_read(block.file)
        source_cache[block.file] = source

    var code = ""
    if block.snippet_start_offset >= 0 and block.snippet_end_offset >= block.snippet_start_offset and block.snippet_end_offset <= source.len():
        code = source[block.snippet_start_offset:block.snippet_end_offset]

    DuplicateBlock(
        file: block.file,
        line_start: block.line_start,
        line_end: block.line_end,
        token_count: block.token_count,
        hash_value: block.hash_value,
        snippet_start_offset: block.snippet_start_offset,
        snippet_end_offset: block.snippet_end_offset,
        code: code
    )

fn has_signal_word(code: text, word: text) -> bool:
    code.contains("{word} ") or code.contains("{word}(") or code.contains("{word}:")

fn count_executable_lines(code: text) -> i64:
    var count = 0
    val lines = code.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("val ") or trimmed.starts_with("var ") or trimmed.starts_with("return") or trimmed.starts_with("if ") or trimmed.starts_with("while ") or trimmed.starts_with("for ") or trimmed.starts_with("match") or trimmed.starts_with("case ") or trimmed.starts_with("break") or trimmed.starts_with("continue"):
            count = count + 1
    count

fn count_nonempty_lines(code: text) -> i64:
    var count = 0
    val lines = code.split("\n")
    for line in lines:
        if line.trim().len() > 0:
            count = count + 1
    count

fn is_low_signal_block(block: DuplicateBlock) -> bool:
    val code = block.code
    val executable_lines = count_executable_lines(code)
    val nonempty_lines = count_nonempty_lines(code)
    if executable_lines < 2:
        return true
    executable_lines * 3 < nonempty_lines

fn compute_token_code(token: SimpleToken) -> i64:
    """Compute stable numeric code without allocating token strings."""
    val bytes = token.value.bytes()
    var char_code = 17
    var j = 0
    while j < bytes.len():
        char_code = (char_code * 31 + bytes[j]) % 1000000007
        j = j + 1
    val kind_code = token_kind_code(token.kind)
    (char_code * 37 + kind_code) % 1000000007

fn token_kind_code(kind: SimpleTokenKind) -> i64:
    if kind == SimpleTokenKind.Identifier:
        return 1
    if kind == SimpleTokenKind.Keyword:
        return 2
    if kind == SimpleTokenKind.Operator:
        return 3
    if kind == SimpleTokenKind.Literal:
        return 4
    if kind == SimpleTokenKind.Punctuation:
        return 5
    if kind == SimpleTokenKind.Comment:
        return 6
    7

fn power_mod(base: i64, exp: i64, mod_val: i64) -> i64:
    """Compute base^exp % mod_val efficiently."""
    var result = 1
    var b = base % mod_val
    var e = exp

    while e > 0:
        if e % 2 == 1:
            result = (result * b) % mod_val
        b = (b * b) % mod_val
        e = e / 2

    result

fn is_line_start_window(tokens: [SimpleToken], index: i64) -> bool:
    if index <= 0:
        return true
    tokens[index].line != tokens[index - 1].line

fn load_tokens_for_file(file_path: text, config: DuplicationConfig, cache_manager: TokenCacheManager) -> [SimpleToken]:
    val cached = get_cached_tokens(cache_manager, file_path)
    if cached != nil:
        return cached

    val content = file_read(file_path)
    val tokens = tokenize(content, config)
    set_cached_tokens(cache_manager, file_path, tokens)
    tokens

fn build_token_codes(tokens: [SimpleToken], interner: TokenInterner) -> [i64]:
    var token_codes = []
    var idx = 0
    while idx < tokens.len():
        token_codes.push(compute_token_code(tokens[idx]))
        idx = idx + 1
    token_codes

fn collect_token_window_candidates(tokens: [SimpleToken], config: DuplicationConfig, interner: TokenInterner) -> [TokenWindowCandidate]:
    if tokens.len() < config.min_tokens:
        return []

    val token_codes = build_token_codes(tokens, interner)
    val base = 31
    val mod_val = 1000000007
    val window_size = config.min_tokens
    val base_power = power_mod(base, window_size - 1, mod_val)

    var hash = 0
    var j = 0
    while j < window_size:
        hash = (hash * base + token_codes[j]) % mod_val
        j = j + 1

    var candidates = []
    var i = 0
    while i + config.min_tokens <= tokens.len():
        if i > 0:
            val old_code = token_codes[i - 1]
            val new_code = token_codes[i + window_size - 1]
            hash = (hash - (old_code * base_power) % mod_val + mod_val) % mod_val
            hash = (hash * base + new_code) % mod_val

        if not is_line_start_window(tokens, i):
            i = i + 1
            continue

        val start_line = tokens[i].line
        val end_idx = (i + config.min_tokens).min(tokens.len())
        val end_line = tokens[end_idx - 1].line
        if end_line - start_line + 1 >= config.min_lines:
            candidates.push(TokenWindowCandidate(
                index: i,
                end_index: end_idx,
                line_start: start_line,
                line_end: end_line,
                hash_value: hash
            ))

        i = i + 1
    candidates

fn collect_hash_counts_in_file(file_path: text, config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner, hash_counts: {text: i64}) -> {text: bool}:
    val tokens = load_tokens_for_file(file_path, config, cache_manager)
    var file_hashes = {}

    val candidates = collect_token_window_candidates(tokens, config, interner)
    for candidate in candidates:
        val hash_key = "{candidate.hash_value}"
        val existing = hash_counts[hash_key] ?? 0
        hash_counts[hash_key] = existing + 1
        file_hashes[hash_key] = true

    file_hashes

fn collect_repeated_hashes(files: [text], config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner) -> HashScanSummary:
    var hash_counts = {}
    var file_hashes = {}
    for file in files:
        file_hashes[file] = collect_hash_counts_in_file(file, config, cache_manager, interner, hash_counts)

    var repeated_hashes = {}
    for hash_key in hash_counts.keys():
        if (hash_counts[hash_key] ?? 0) > 1:
            repeated_hashes[hash_key] = true

    var candidate_files = {}
    for file in file_hashes.keys():
        val hashes = file_hashes[file] ?? {}
        for hash_key in hashes.keys():
            if repeated_hashes.contains_key(hash_key):
                candidate_files[file] = true
                break

    HashScanSummary(repeated_hashes: repeated_hashes, candidate_files: candidate_files)

fn find_duplicates_in_file(file_path: text, config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner) -> [DuplicateBlock]:
    find_duplicates_in_file_with_hash_filter(file_path, config, cache_manager, interner, {})

fn find_duplicates_in_file_with_hash_filter(file_path: text, config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner, repeated_hashes: {text: bool}) -> [DuplicateBlock]:
    val tokens = load_tokens_for_file(file_path, config, cache_manager)
    val filter_enabled = repeated_hashes.keys().len() > 0
    val content = if filter_enabled: "" else: file_read(file_path)

    var batches = []
    var current_batch = []
    val batch_size = 100

    val candidates = collect_token_window_candidates(tokens, config, interner)
    for candidate in candidates:
        val hash_key = "{candidate.hash_value}"
        if filter_enabled and not repeated_hashes.contains_key(hash_key):
            continue
        val code = if filter_enabled:
            ""
        else:
            extract_code_snippet(content, tokens, candidate.index, candidate.end_index)
        val new_block = DuplicateBlock(
            file: file_path,
            line_start: candidate.line_start,
            line_end: candidate.line_end,
            token_count: config.min_tokens,
            hash_value: candidate.hash_value,
            snippet_start_offset: tokens[candidate.index].start_offset,
            snippet_end_offset: tokens[candidate.end_index - 1].end_offset,
            code: code
        )

        current_batch.push(new_block)

        if current_batch.len() >= batch_size:
            batches.push(current_batch)
            current_batch = []

    if current_batch.len() > 0:
        batches.push(current_batch)

    var blocks = []
    for batch in batches:
        for item in batch:
            blocks.push(item)

    blocks

fn bucket_blocks_by_hash(all_blocks: [DuplicateBlock]) -> {text: [DuplicateBlock]}:
    var hash_map = {}
    for block in all_blocks:
        val hash_key = "{block.hash_value}"

        if hash_map.contains_key(hash_key):
            var existing = hash_map[hash_key]
            existing.push(block)
            hash_map[hash_key] = existing
        else:
            hash_map[hash_key] = [block]
    hash_map

fn bucket_exact_blocks(blocks: [DuplicateBlock], source_cache: {text: text}) -> {text: [DuplicateBlock]}:
    var exact_map = {}
    for block in blocks:
        val materialized = materialize_block_code(block, source_cache)
        val exact_key = duplicate_block_signature(materialized)
        if exact_map.contains_key(exact_key):
            var existing = exact_map[exact_key]
            existing.push(materialized)
            exact_map[exact_key] = existing
        else:
            exact_map[exact_key] = [materialized]
    exact_map

fn contains_high_signal_block(blocks: [DuplicateBlock]) -> bool:
    for block in blocks:
        if not is_low_signal_block(block):
            return true
    false

fn add_exact_groups(exact_map: {text: [DuplicateBlock]}, config: DuplicationConfig, groups: [DuplicateGroup]):
    for exact_key in exact_map.keys():
        val exact_blocks = exact_map[exact_key]
        if exact_blocks.len() < 2:
            continue

        if not contains_high_signal_block(exact_blocks):
            continue

        val group = build_duplicate_group(exact_blocks)
        if group.impact_score >= config.min_impact:
            groups.push(group)

fn group_by_hash(all_blocks: [DuplicateBlock], config: DuplicationConfig) -> [DuplicateGroup]:
    val hash_map = bucket_blocks_by_hash(all_blocks)
    var source_cache = {}

    val groups = []

    for hash_key in hash_map.keys():
        val blocks = hash_map[hash_key]

        if blocks.len() >= 2:
            val exact_map = bucket_exact_blocks(blocks, source_cache)
            add_exact_groups(exact_map, config, groups)

    groups

fn sort_by_impact(groups: [DuplicateGroup]) -> [DuplicateGroup]:
    var sorted = groups
    var n = sorted.len()

    var i = 0
    while i < n - 1:
        var j = 0
        while j < n - i - 1:
            val left = sorted[j]
            val right = sorted[j + 1]
            if left.impact_score < right.impact_score:
                sorted[j] = right
                sorted[j + 1] = left
            j = j + 1
        i = i + 1

    sorted

fn collect_files(path: text, config: DuplicationConfig) -> [text]:
    collect_detector_files(path, config)

fn sample_blocks_for_similarity(all_blocks: [DuplicateBlock], config: DuplicationConfig) -> [DuplicateBlock]:
    val max_blocks_to_analyze = 320
    var blocks_to_analyze = all_blocks
    if all_blocks.len() > max_blocks_to_analyze:
        log_progress(config, "WARNING: Too many blocks ({all_blocks.len()}), sampling {max_blocks_to_analyze} across files")
        # Sample blocks distributed across files instead of taking first N
        # Group blocks by file, then round-robin pick from each file
        var file_blocks = {}
        for block in all_blocks:
            if file_blocks.contains_key(block.file):
                var grouped = file_blocks[block.file]
                grouped.push(block)
                file_blocks[block.file] = grouped
            else:
                file_blocks[block.file] = [block]

        val file_keys = file_blocks.keys()
        var limited = []
        var round = 0
        var done = false
        while not done:
            var added_any = false
            for fk in file_keys:
                val fblocks = file_blocks[fk]
                if round < fblocks.len():
                    limited.push(fblocks[round])
                    added_any = true
                    if limited.len() >= max_blocks_to_analyze:
                        done = true
                        break
            if not added_any:
                done = true
            round = round + 1
        blocks_to_analyze = limited
        log_verbose(config, "  Sampled from {file_keys.len()} files")
    blocks_to_analyze

fn load_tokens_with_line_indexes(blocks_to_analyze: [DuplicateBlock], config: DuplicationConfig, cache_manager: TokenCacheManager) -> SimilarityPrep:
    log_progress(config, "Pre-computing features for {blocks_to_analyze.len()} blocks...")
    var file_token_cache = {}
    var file_line_index_cache = {}
    var feature_vectors = []
    var low_signal_flags = []
    var block_idx = 0
    while block_idx < blocks_to_analyze.len():
        val block = blocks_to_analyze[block_idx]
        low_signal_flags.push(is_low_signal_block(block))

        var tokens = []
        if file_token_cache.contains_key(block.file):
            tokens = file_token_cache[block.file]
        else:
            val cached_tok = get_cached_tokens(cache_manager, block.file)
            if cached_tok != nil:
                tokens = cached_tok
            else:
                val content = file_read(block.file)
                tokens = tokenize(content, config)
                set_cached_tokens(cache_manager, block.file, tokens)
            file_token_cache[block.file] = tokens

            # Build line-to-token-index map once per file for O(1) lookups
            var line_index = {}
            var li = 0
            var last_line = -1
            while li < tokens.len():
                val tline = tokens[li].line
                if tline != last_line:
                    val line_key = "{tline}"
                    line_index[line_key] = li
                    last_line = tline
                li = li + 1
            file_line_index_cache[block.file] = line_index

        # O(1) lookup via line index
        var token_start = 0
        var found_start = false
        val cached_line_index = file_line_index_cache[block.file]
        if cached_line_index != nil:
            val line_key = "{block.line_start}"
            if cached_line_index.contains_key(line_key):
                token_start = cached_line_index[line_key]
                found_start = true

        if not found_start:
            # Fallback to linear scan
            var ti = 0
            while ti < tokens.len():
                if tokens[ti].line == block.line_start:
                    token_start = ti
                    found_start = true
                    break
                ti = ti + 1

        var feature_vec = FeatureVec(block_id: block_idx, features: {}, magnitude: 0.0)
        if found_start:
            val token_end = (token_start + block.token_count).min(tokens.len())
            val freq_map = extract_token_frequencies(tokens, token_start, token_end)
            feature_vec = build_feature_vector(block_idx, freq_map)

        feature_vectors.push(feature_vec)
        block_idx = block_idx + 1

    log_progress(config, "Extracted {feature_vectors.len()} feature vectors from {file_token_cache.keys().len()} files")
    SimilarityPrep(
        blocks: blocks_to_analyze,
        features: feature_vectors,
        low_signal_flags: low_signal_flags,
        file_count: file_token_cache.keys().len()
    )

fn build_similarity_adjacency(prep: SimilarityPrep, config: DuplicationConfig) -> {text: [i64]}:
    log_progress(config, "Starting pairwise comparison of {prep.blocks.len()} blocks...")
    val total_possible = (prep.blocks.len() * (prep.blocks.len() - 1)) / 2
    log_verbose(config, "  Max comparisons: {total_possible} (optimizations will reduce this)")

    var comparison_count = 0
    var skipped_same_file = 0
    var match_count = 0
    val max_comparisons_per_block = 36
    val max_total_comparisons = 7000
    var adjacency = {}

    var i = 0
    while i < prep.blocks.len() and comparison_count < max_total_comparisons:
        if i % 50 == 0:
            log_verbose(config, "  Block {i}/{prep.blocks.len()}: {comparison_count} comparisons, {match_count} matches")

        if comparison_count >= max_total_comparisons:
            log_progress(config, "  Reached comparison limit ({max_total_comparisons}), stopping early")
            break

        val block1 = prep.blocks[i]
        var comparisons_this_block = 0
        var j = i + 1

        while j < prep.blocks.len() and comparisons_this_block < max_comparisons_per_block:
            val block2 = prep.blocks[j]

            val same_file = block1.file == block2.file
            if same_file:
                skipped_same_file = skipped_same_file + 1
                j = j + 1
                continue

            if prep.low_signal_flags[i] and prep.low_signal_flags[j]:
                j = j + 1
                continue

            comparison_count = comparison_count + 1
            comparisons_this_block = comparisons_this_block + 1

            val feature_vec1 = prep.features[i]
            val feature_vec2 = prep.features[j]
            val similarity = cosine_similarity(feature_vec1, feature_vec2)

            val above_threshold = similarity >= config.similarity_threshold
            if above_threshold:
                match_count = match_count + 1
                val key1 = "{i}"
                val key2 = "{j}"
                if adjacency.contains_key(key1):
                    var neighbors1 = adjacency[key1]
                    neighbors1.push(j)
                    adjacency[key1] = neighbors1
                else:
                    adjacency[key1] = [j]

                if adjacency.contains_key(key2):
                    var neighbors2 = adjacency[key2]
                    neighbors2.push(i)
                    adjacency[key2] = neighbors2
                else:
                    adjacency[key2] = [i]

            j = j + 1
        i = i + 1

    log_progress(config, "Completed {comparison_count} comparisons, found {match_count} similar pairs")
    adjacency

fn build_similarity_groups(adjacency: {text: [i64]}, blocks_to_analyze: [DuplicateBlock], config: DuplicationConfig) -> [DuplicateGroup]:
    var groups = []
    var visited = {}
    for node_key in adjacency.keys():
        if visited.contains_key(node_key):
            continue

        var component = []
        var stack = [node_key]
        visited[node_key] = true

        while stack.len() > 0:
            val current = stack[stack.len() - 1]
            stack = stack[0:stack.len() - 1]
            component.push(current)

            val neighbors = adjacency[current] ?? []
            for neighbor in neighbors:
                val neighbor_key = "{neighbor}"
                if not visited.contains_key(neighbor_key):
                    visited[neighbor_key] = true
                    stack.push(neighbor_key)

        if component.len() < 2:
            continue

        var component_blocks = []
        for block_key in component:
            val block_idx = parse_idx(block_key)
            if block_idx >= 0 and block_idx < blocks_to_analyze.len():
                component_blocks.push(blocks_to_analyze[block_idx])

        if component_blocks.len() < 2:
            continue

        val new_group = build_duplicate_group(component_blocks)
        if new_group.impact_score >= config.min_impact:
            groups.push(new_group)

    groups

fn refine_groups_with_similarity(exact_groups: [DuplicateGroup], all_blocks: [DuplicateBlock], config: DuplicationConfig, cache_manager: TokenCacheManager) -> [DuplicateGroup]:
    """Refine hash-based groups using cosine similarity to catch fuzzy duplicates."""
    val blocks_to_analyze = sample_blocks_for_similarity(all_blocks, config)
    val prep = load_tokens_with_line_indexes(blocks_to_analyze, config, cache_manager)
    val adjacency = build_similarity_adjacency(prep, config)
    val similarity_groups = build_similarity_groups(adjacency, blocks_to_analyze, config)

    var refined_groups = []
    for group in exact_groups:
        refined_groups.push(group)
    for group in similarity_groups:
        refined_groups.push(group)
    refined_groups

fn parse_idx(value: text) -> i64:
    var result = 0
    var i = 0
    while i < value.len():
        val byte = value.bytes()[i]
        if byte < 48 or byte > 57:
            return -1
        result = result * 10 + (byte - 48)
        i = i + 1
    result

fn find_duplicates(files: [text], config: DuplicationConfig, cache_manager: TokenCacheManager) -> [DuplicateGroup]:
    var all_blocks = []

    val interner = new_token_interner()

    log_progress(config, "Scanning {files.len()} files...")

    val hash_scan = if config.use_cosine_similarity:
        HashScanSummary(repeated_hashes: {}, candidate_files: {})
    else:
        collect_repeated_hashes(files, config, cache_manager, interner)

    for file in files:
        if not config.use_cosine_similarity and not hash_scan.candidate_files.contains_key(file):
            log_verbose(config, "  {file}: skipped (no repeated hashes)")
            continue
        val blocks = if config.use_cosine_similarity:
            find_duplicates_in_file(file, config, cache_manager, interner)
        else:
            find_duplicates_in_file_with_hash_filter(file, config, cache_manager, interner, hash_scan.repeated_hashes)
        all_blocks.merge(blocks)
        log_verbose(config, "  {file}: {blocks.len()} blocks")

    log_progress(config, "Found {all_blocks.len()} potential duplicate blocks")

    val exact_groups = group_by_hash(all_blocks, config)

    val refined_groups = if config.use_cosine_similarity:
        log_progress(config, "Refining with cosine similarity...")
        val result = refine_groups_with_similarity(exact_groups, all_blocks, config, cache_manager)
        result
    else:
        exact_groups

    val sorted = sort_by_impact(refined_groups)

    log_progress(config, "Grouped into {sorted.len()} duplicate groups")

    sorted

fn find_duplicates_with_options(
    files: [text],
    config: DuplicationConfig,
    cache_manager: TokenCacheManager,
    use_parallel: bool,
    use_incremental: bool,
    incremental_cache_path: text
) -> [DuplicateGroup]:
    # Parallel and incremental modes require cross-module imports (parallel.spl, incremental.spl).
    # Falling back to sequential processing until module imports are fully supported.
    if use_parallel:
        eprint("[WARNING] Parallel duplicate detection not available; falling back to sequential processing")
    if use_incremental:
        eprint("[WARNING] Incremental duplicate detection not available; falling back to full scan")
    find_duplicates(files, config, cache_manager)
