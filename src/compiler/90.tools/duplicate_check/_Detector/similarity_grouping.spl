# Duplicate-check — file collection + similarity grouping/refinement

use compiler.tools.duplicate_check.config.{DuplicationConfig}
use compiler.tools.duplicate_check.features.{FeatureVec, extract_token_frequencies, build_feature_vector, cosine_similarity, feature_signature}
use compiler.tools.duplicate_check.cache.{TokenCacheManager, get_cached_tokens, set_cached_tokens_with_content}
use compiler.tools.duplicate_check.detector_files.{collect_detector_files}
use compiler.tools.duplicate_check._Detector.interner_and_logging.*
use std.nogc_sync_mut.io.time_ops.{current_time_ms}

fn collect_files(path: text, config: DuplicationConfig) -> [text]:
    collect_detector_files(path, config)

fn sample_blocks_for_similarity(all_blocks: [DuplicateBlock], _config: DuplicationConfig) -> [DuplicateBlock]:
    all_blocks

fn load_tokens_with_line_indexes(blocks_to_analyze: [DuplicateBlock], config: DuplicationConfig, cache_manager: TokenCacheManager) -> SimilarityPrep:
    log_progress(config, "Pre-computing features for {blocks_to_analyze.len()} blocks...")
    var file_token_cache = {}
    var file_line_index_cache = {}
    var feature_vectors = []
    var low_signal_flags = []
    var block_idx = 0
    val start_ms = current_time_ms()
    var last_ms = start_ms
    while block_idx < blocks_to_analyze.len():
        val block = blocks_to_analyze[block_idx]
        low_signal_flags.push(is_low_signal_block(block))

        var tokens = []
        if file_token_cache.has(block.file):
            tokens = file_token_cache[block.file]
        else:
            val cached_tok = get_cached_tokens(cache_manager, block.file)
            if cached_tok != nil:
                tokens = cached_tok
            else:
                val content = read_detector_source(block.file)
                tokens = tokenize(content, config)
                set_cached_tokens_with_content(cache_manager, block.file, tokens, content)
            file_token_cache[block.file] = tokens

            # Build line-to-token-index map once per file for O(1) lookups
            var line_index = {}
            var li = 0
            var last_line = -1
            while li < tokens.len():
                val tline = tokens[li].line
                if tline != last_line:
                    val line_key = "{tline}"
                    line_index[line_key] = li
                    last_line = tline
                li = li + 1
            file_line_index_cache[block.file] = line_index

        # O(1) lookup via line index
        var token_start = 0
        var found_start = false
        val cached_line_index = file_line_index_cache[block.file]
        if cached_line_index != nil:
            val line_key = "{block.line_start}"
            if cached_line_index.has(line_key):
                token_start = cached_line_index[line_key]
                found_start = true

        if not found_start:
            # Fallback to linear scan
            var ti = 0
            while ti < tokens.len():
                if tokens[ti].line == block.line_start:
                    token_start = ti
                    found_start = true
                    break
                ti = ti + 1

        var feature_vec = FeatureVec(block_id: block_idx, features: {}, magnitude: 0.0)
        if found_start:
            val token_end = (token_start + block.token_count).min(tokens.len())
            val freq_map = extract_token_frequencies(tokens, token_start, token_end)
            feature_vec = build_feature_vector(block_idx, freq_map)

        feature_vectors.push(feature_vec)
        block_idx = block_idx + 1
        last_ms = progress_tick(config, "feature pass", block_idx, blocks_to_analyze.len(), start_ms, last_ms)

    log_progress(config, "Extracted {feature_vectors.len()} feature vectors from {file_token_cache.keys().len()} files")
    SimilarityPrep(
        blocks: blocks_to_analyze,
        features: feature_vectors,
        low_signal_flags: low_signal_flags,
        file_count: file_token_cache.keys().len()
    )

fn build_similarity_adjacency(prep: SimilarityPrep, config: DuplicationConfig) -> {text: [i64]}:
    # Root-cause fix (was: nested O(n^2) loop capped at max_total_comparisons=7000
    # with a token-count approximation standing in for real cosine_similarity —
    # a silent-truncation workaround that also never scored genuine cosine
    # similarity). Instead, build a signature-token inverted index (same
    # technique already used by semantic.spl's local doc-similarity path):
    # bucket blocks by their top-N highest-weighted tokens, and only run real
    # cosine_similarity within a bucket. Two blocks that share no significant
    # vocabulary never get compared, so the candidate-pair count stays near
    # the number of buckets * bucket-size^2 instead of blocks^2.
    log_progress(config, "Bucketing {prep.blocks.len()} blocks by shared token signature (inverted index)...")

    var sigs: [text] = []
    var si = 0
    while si < prep.features.len():
        sigs.push(feature_signature(prep.features[si], 5))
        si = si + 1

    var token_to_indices: {text: text} = {}
    var gi = 0
    while gi < prep.blocks.len():
        if prep.features[gi].magnitude != 0.0 and not prep.low_signal_flags[gi]:
            for tok in sigs[gi].split(","):
                if tok.len() > 0:
                    if token_to_indices.has(tok):
                        token_to_indices[tok] = token_to_indices[tok] + "," + "{gi}"
                    else:
                        token_to_indices[tok] = "{gi}"
        gi = gi + 1

    var adjacency = {}
    var comparison_count = 0
    var match_count = 0
    var dropped_bucket_blocks = 0
    # Cap giant buckets (a token so common it isn't discriminative, e.g. "value").
    # A genuine clone pair shares several signature tokens, so it also lands in
    # smaller, non-capped buckets — this only drops the low-value comparisons
    # that a common single token would otherwise force.
    val max_bucket_size = 400
    var seen_pairs: {text: bool} = {}
    val start_ms = current_time_ms()
    var last_ms = start_ms

    for tok in token_to_indices.keys():
        val idx_strs = token_to_indices[tok].split(",")
        if idx_strs.len() > max_bucket_size:
            log_progress(config, "  Skipping oversized bucket '{tok}' ({idx_strs.len()} blocks, cap {max_bucket_size}) to bound work")
            dropped_bucket_blocks = dropped_bucket_blocks + idx_strs.len()
            continue

        var indices: [i64] = []
        for s in idx_strs:
            indices.push(int(s))

        var pi = 0
        while pi < indices.len():
            val i = indices[pi]
            var pj = pi + 1
            while pj < indices.len():
                val j = indices[pj]
                val block1 = prep.blocks[i]
                val block2 = prep.blocks[j]

                if block1.file == block2.file:
                    pj = pj + 1
                    continue

                val lo = if i < j: i else: j
                val hi = if i < j: j else: i
                val pair_key = "{lo}-{hi}"
                if seen_pairs.has(pair_key):
                    pj = pj + 1
                    continue
                seen_pairs[pair_key] = true

                comparison_count = comparison_count + 1
                last_ms = progress_tick(config, "compare pass", comparison_count, comparison_count, start_ms, last_ms)

                val sim = cosine_similarity(prep.features[i], prep.features[j])
                if sim >= config.similarity_threshold:
                    match_count = match_count + 1
                    val key1 = "{i}"
                    val key2 = "{j}"
                    if adjacency.has(key1):
                        var neighbors1 = adjacency[key1]
                        neighbors1.push(j)
                        adjacency[key1] = neighbors1
                    else:
                        adjacency[key1] = [j]

                    if adjacency.has(key2):
                        var neighbors2 = adjacency[key2]
                        neighbors2.push(i)
                        adjacency[key2] = neighbors2
                    else:
                        adjacency[key2] = [i]

                pj = pj + 1
            pi = pi + 1

    if dropped_bucket_blocks > 0:
        log_progress(config, "  Dropped {dropped_bucket_blocks} block-slots from oversized buckets (raise max_bucket_size if this misses a real clone)")
    log_progress(config, "Completed {comparison_count} real cosine comparisons via inverted index, found {match_count} similar pairs")
    adjacency

fn build_similarity_groups(adjacency: {text: [i64]}, blocks_to_analyze: [DuplicateBlock], config: DuplicationConfig) -> [DuplicateGroup]:
    var groups = []
    var visited = {}
    for node_key in adjacency.keys():
        if visited.has(node_key):
            continue

        var component = []
        var stack = [node_key]
        visited[node_key] = true

        while stack.len() > 0:
            val current = stack[stack.len() - 1]
            stack = stack[0:stack.len() - 1]
            component.push(current)

            val neighbors = adjacency[current] ?? []
            for neighbor in neighbors:
                val neighbor_key = "{neighbor}"
                if not visited.has(neighbor_key):
                    visited[neighbor_key] = true
                    stack.push(neighbor_key)

        if component.len() < 2:
            continue

        var component_blocks = []
        for block_key in component:
            val block_idx = parse_idx(block_key)
            if block_idx >= 0 and block_idx < blocks_to_analyze.len():
                component_blocks.push(blocks_to_analyze[block_idx])

        if component_blocks.len() < 2:
            continue

        val new_group = build_duplicate_group(component_blocks)
        if new_group.impact_score >= config.min_impact:
            groups.push(new_group)

    groups

fn refine_groups_with_similarity(exact_groups: [DuplicateGroup], all_blocks: [DuplicateBlock], config: DuplicationConfig, cache_manager: TokenCacheManager) -> [DuplicateGroup]:
    """Refine hash-based groups using cosine similarity to catch fuzzy duplicates."""
    val blocks_to_analyze = sample_blocks_for_similarity(all_blocks, config)
    val prep = load_tokens_with_line_indexes(blocks_to_analyze, config, cache_manager)
    val adjacency = build_similarity_adjacency(prep, config)
    val similarity_groups = build_similarity_groups(adjacency, blocks_to_analyze, config)

    var refined_groups = []
    for group in exact_groups:
        refined_groups.push(group)
    for group in similarity_groups:
        refined_groups.push(group)
    refined_groups

fn parse_idx(value: text) -> i64:
    var result = 0
    var i = 0
    while i < value.len():
        val byte = value.bytes()[i]
        if byte < 48 or byte > 57:
            return -1
        result = result * 10 + (byte - 48)
        i = i + 1
    result

fn normalize_identifiers_for_cheap_key(text_val: text) -> text:
    # Blanket-replace identifier/keyword runs with "#" and digit runs with
    # "0", keeping punctuation/operators/newlines as-is. Cosine mode's whole
    # purpose is catching renamed-identifier near-duplicates (config keeps
    # ignore_identifiers=false so the *real* feature vectors still see the
    # actual names) -- an exact-text or exact-token-hash pre-filter can never
    # anchor those pairs, since every identifier differs. This coarser key
    # anchors on structure instead of names, which both sides of a rename
    # still share, and is cheap (byte scan, no token structs).
    val bytes = text_val.bytes()
    val len = bytes.len()
    var result = ""
    var i = 0
    while i < len:
        val b = bytes[i]
        val is_letter = (b >= 97 and b <= 122) or (b >= 65 and b <= 90) or b == 95
        val is_digit = b >= 48 and b <= 57
        if is_letter:
            while i < len:
                val c = bytes[i]
                val is_alnum = (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or (c >= 48 and c <= 57) or c == 95
                if not is_alnum:
                    break
                i = i + 1
            result = result + "#"
        elif is_digit:
            while i < len:
                val c = bytes[i]
                val is_numchar = (c >= 48 and c <= 57) or c == 46
                if not is_numchar:
                    break
                i = i + 1
            result = result + "0"
        else:
            result = result + text_val[i:i+1]
            i = i + 1
    result

fn collect_cheap_line_window_candidates(files: [text], config: DuplicationConfig) -> {text: bool}:
    # Cheap pre-filter (Pass 0): built on the same string-based line-window
    # keying that fast_line_window_duplicate_groups already uses for token
    # mode -- raw split("\n") text, no per-token SimpleToken struct
    # allocation, so it is far cheaper than tokenize(), which profiling
    # showed costs ~2ms/token in this interpreter and dominates wall time
    # regardless of how well the comparison stage is pruned. Keys are
    # identifier-normalized (see normalize_identifiers_for_cheap_key) so
    # renamed-but-structurally-identical blocks -- cosine's actual target --
    # still register as a candidate pair here. Signal lines come from the
    # shared tokenizer, so comment/string text cannot admit a file by itself.
    val window = if config.min_lines > 0: config.min_lines else: 5
    var key_counts: {text: i64} = {}
    var file_keys: {text: [text]} = {}

    for file in files:
        val source = read_detector_source(file)
        val lines = source.split("\n")
        val signal_prefix = signal_line_prefix(source, config)
        if lines.len() < window:
            continue

        var seen_in_file: {text: bool} = {}
        var start = 0
        while start + window <= lines.len():
            val raw_key = line_window_key(lines, start, window)
            if window_has_signal(signal_prefix, start, window):
                val key = normalize_identifiers_for_cheap_key(raw_key)
                # Count EVERY occurrence (not deduped per file): a window
                # repeated twice inside one file is a within-file duplicate
                # and must make that file a candidate on its own.
                val existing = key_counts[key] ?? 0
                key_counts[key] = existing + 1
                if not seen_in_file.has(key):
                    seen_in_file[key] = true
            start = start + 1

        var keys_list: [text] = []
        for k in seen_in_file.keys():
            keys_list.push(k)
        file_keys[file] = keys_list

    var candidate_files: {text: bool} = {}
    for file in file_keys.keys():
        val keys_list = file_keys[file]
        var ki = 0
        while ki < keys_list.len():
            val k = keys_list[ki]
            if (key_counts[k] ?? 0) > 1:
                candidate_files[file] = true
                ki = keys_list.len()
            else:
                ki = ki + 1
    candidate_files

fn extract_blocks_from_files(candidate_files: [text], config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner, repeated_hashes: {text: bool}) -> [DuplicateBlock]:
    var all_blocks = []
    val start_ms = current_time_ms()
    var last_ms = start_ms
    var done = 0
    for file in candidate_files:
        val blocks = find_duplicates_in_file_with_hash_filter(file, config, cache_manager, interner, repeated_hashes)
        all_blocks.merge(blocks)
        log_verbose(config, "  {file}: {blocks.len()} blocks")
        done = done + 1
        last_ms = progress_tick(config, "extract pass", done, candidate_files.len(), start_ms, last_ms)
    all_blocks

fn scan_duplicate_blocks(files: [text], config: DuplicationConfig, cache_manager: TokenCacheManager, interner: TokenInterner) -> [DuplicateBlock]:
    if config.use_cosine_similarity:
        # Root-cause fix (task #89): the old code zeroed repeated_hashes and
        # ran this unfiltered over *every* file in the tree -- that unbounded
        # extraction, not the pairwise comparison, is what SIGTERMed on a
        # medium directory (see
        # doc/08_tracking/bug/duplicate_check_cosine_quadratic_timeout_2026-07-01.md).
        # An exact-hash pre-filter (the bug report's suggested direction)
        # would fix the volume but silently break correctness: cosine's
        # whole purpose is scoring blocks that do NOT hash-match (renamed
        # identifiers), so gating extraction on an exact match would prune
        # away every real fuzzy pair -- confirmed by
        # test/01_unit/app/duplicate_check/detector_grouping_spec.spl's
        # "keeps cosine groups across similar files" case. Instead: Pass 0
        # prunes *files* cheaply using an identifier-normalized structural
        # key (still an inverted index, just coarser), then Pass 2 extracts
        # every block from that already-small candidate set -- extraction
        # volume is bounded by which files can possibly matter, not by an
        # exact-match requirement that would defeat cosine's purpose.
        log_progress(config, "Pass 0: cheap line-window pre-filter across {files.len()} files (skips tokenize() for files with no structurally-repeated line-window)...")
        val cheap_candidates = collect_cheap_line_window_candidates(files, config)
        var scan_files: [text] = []
        for f in files:
            if cheap_candidates.has(f):
                scan_files.push(f)
        if scan_files.len() < files.len():
            val pruned0 = files.len() - scan_files.len()
            log_progress(config, "  Pass 0 pruned {pruned0} file(s) before tokenizing (no structurally-repeated line-window anywhere)")

        log_progress(config, "Pass 2: extracting all blocks from {scan_files.len()} Pass-0 candidate file(s)...")
        return extract_blocks_from_files(scan_files, config, cache_manager, interner, {})

    log_progress(config, "Pass 1: collecting hash counts across {files.len()} files...")
    val summary = collect_repeated_hashes(files, config, cache_manager, interner)
    val candidate_files = summary.candidate_files.keys()
    val repeated_hashes = summary.repeated_hashes
    val repeated_count = repeated_hashes.keys().len()
    log_progress(config, "  {repeated_count} repeated hashes in {candidate_files.len()} candidate files")

    log_progress(config, "Pass 2: extracting blocks from candidate files...")
    extract_blocks_from_files(candidate_files, config, cache_manager, interner, repeated_hashes)

fn find_duplicates(files: [text], config: DuplicationConfig, cache_manager: TokenCacheManager) -> [DuplicateGroup]:
    if config.selected_mode == "token":
        log_progress(config, "Scanning {files.len()} files with fast line-window token gate...")
        val line_groups = fast_line_window_duplicate_groups(files, config)
        log_progress(config, "Grouped into {line_groups.len()} duplicate groups")
        return line_groups

    val interner = new_token_interner()

    log_progress(config, "Scanning {files.len()} files...")

    val all_blocks = scan_duplicate_blocks(files, config, cache_manager, interner)

    log_progress(config, "Found {all_blocks.len()} potential duplicate blocks")

    val exact_groups = group_exact_blocks(all_blocks, config, cache_manager)

    val refined_groups = if config.use_cosine_similarity:
        log_progress(config, "Refining with cosine similarity (inverted-index pruned candidate pairs)...")
        refine_groups_with_similarity(exact_groups, all_blocks, config, cache_manager)
    else:
        exact_groups

    val sorted = sort_by_impact(refined_groups)

    log_progress(config, "Grouped into {sorted.len()} duplicate groups")

    sorted

fn find_duplicates_with_options(
    files: [text],
    config: DuplicationConfig,
    cache_manager: TokenCacheManager,
    use_parallel: bool,
    use_incremental: bool,
    incremental_cache_path: text
) -> [DuplicateGroup]:
    # Parallel and incremental modes require cross-module imports (parallel.spl, incremental.spl).
    # Falling back to sequential processing until module imports are fully supported.
    if use_parallel:
        eprint("[WARNING] Parallel duplicate detection not available; falling back to sequential processing")
    if use_incremental:
        eprint("[WARNING] Incremental duplicate detection not available; falling back to full scan")
    find_duplicates(files, config, cache_manager)
