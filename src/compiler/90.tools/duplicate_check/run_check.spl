#!/usr/bin/env simple
# Standalone duplicate checker — NO app.io imports (avoids loading entire compiler)
# Perf: O(n log n) via sort+group instead of O(n²) pairwise comparison
# Phase 1: Token-based windowing + Karp-Rabin rolling hash + identifier normalization

extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_walk(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_cli_get_args() -> [text]
extern fn rt_text_to_bytes(s: text) -> [i64]

fn file_read(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn dir_walk(path: text) -> [text]:
    rt_dir_walk(path)

fn collect_spl_files(dir_path: text) -> [text]:
    val all_files = dir_walk(dir_path)
    var spl_files = []
    for f in all_files:
        if f.ends_with(".spl") and not f.ends_with("_spec.spl") and not f.ends_with("_test.spl") and not f.contains("/test/"):
            spl_files.push(f)
    spl_files

# ── Token types ──────────────────────────────────────────────────────────────
# 0 = keyword, 1 = identifier, 2 = operator, 3 = literal, 4 = punctuation
# 5 = whitespace (skipped), 6 = comment (skipped)

# Simple keywords in the language
fn is_keyword(word: text) -> bool:
    if word == "fn" or word == "var" or word == "val" or word == "if" or word == "else":
        return true
    if word == "while" or word == "for" or word == "in" or word == "return" or word == "class":
        return true
    if word == "trait" or word == "impl" or word == "enum" or word == "struct" or word == "type":
        return true
    if word == "alias" or word == "use" or word == "extern" or word == "static" or word == "self":
        return true
    if word == "true" or word == "false" or word == "nil" or word == "not" or word == "and" or word == "or":
        return true
    if word == "me" or word == "mut" or word == "pub" or word == "super" or word == "import":
        return true
    if word == "break" or word == "continue" or word == "yield" or word == "async" or word == "await":
        return true
    if word == "pass_todo" or word == "pass_do_nothing" or word == "pass_dn" or word == "pass":
        return true
    false

fn is_alpha(ch: i64) -> bool:
    if ch >= 65 and ch <= 90:
        return true
    if ch >= 97 and ch <= 122:
        return true
    if ch == 95:
        return true
    false

fn is_digit(ch: i64) -> bool:
    ch >= 48 and ch <= 57

fn is_alnum(ch: i64) -> bool:
    is_alpha(ch) or is_digit(ch)

fn is_whitespace(ch: i64) -> bool:
    ch == 32 or ch == 9 or ch == 10 or ch == 13

# ── Token representation ─────────────────────────────────────────────────────
# Parallel arrays for token data:
#   tok_types:  [i64]   — 0=keyword, 1=identifier, 2=operator, 3=literal, 4=punctuation
#   tok_values: [text]  — the text of the token
#   tok_lines:  [i64]   — 1-based line number where the token appears

# ── Inline tokenizer ─────────────────────────────────────────────────────────
# Returns number of tokens produced; populates the parallel arrays passed in.
fn tokenize(source: text, out_types: [i64], out_values: [text], out_lines: [i64]) -> i64:
    val bytes = rt_text_to_bytes(source)
    var pos = 0
    var line_num = 1
    var count = 0
    val src_len = bytes.len()

    while pos < src_len:
        val ch = bytes[pos]

        # ── Newline ──────────────────────────────────────────────────────
        if ch == 10:
            line_num = line_num + 1
            pos = pos + 1
            continue

        # ── Whitespace (skip) ────────────────────────────────────────────
        if is_whitespace(ch):
            pos = pos + 1
            continue

        # ── Comment (# to end of line — skip) ───────────────────────────
        if ch == 35:
            while pos < src_len and bytes[pos] != 10:
                pos = pos + 1
            continue

        # ── String literal (double-quoted) ───────────────────────────────
        if ch == 34:
            var str_end = pos + 1
            while str_end < src_len and bytes[str_end] != 34:
                if bytes[str_end] == 92:
                    str_end = str_end + 2
                else:
                    if bytes[str_end] == 10:
                        line_num = line_num + 1
                    str_end = str_end + 1
            if str_end < src_len:
                str_end = str_end + 1
            var lit_text = ""
            var li = pos
            while li < str_end and li < src_len:
                val lc = bytes[li]
                # Build string char by char from bytes
                li = li + 1
            out_types.push(3)
            out_values.push("_STR_")
            out_lines.push(line_num)
            count = count + 1
            pos = str_end
            continue

        # ── Numeric literal ──────────────────────────────────────────────
        if is_digit(ch):
            var num_end = pos + 1
            while num_end < src_len and (is_digit(bytes[num_end]) or bytes[num_end] == 46):
                num_end = num_end + 1
            # Collect the numeric text
            var num_text = ""
            var ni = pos
            while ni < num_end:
                ni = ni + 1
            out_types.push(3)
            out_values.push("_NUM_")
            out_lines.push(line_num)
            count = count + 1
            pos = num_end
            continue

        # ── Identifier or keyword ────────────────────────────────────────
        if is_alpha(ch):
            var id_end = pos + 1
            while id_end < src_len and is_alnum(bytes[id_end]):
                id_end = id_end + 1
            # Extract identifier text via source substring
            val id_text = source.substring(pos, id_end)
            if is_keyword(id_text):
                out_types.push(0)
                out_values.push(id_text)
            else:
                out_types.push(1)
                out_values.push(id_text)
            out_lines.push(line_num)
            count = count + 1
            pos = id_end
            continue

        # ── Multi-char operators ─────────────────────────────────────────
        var next_ch = 0
        if pos + 1 < src_len:
            next_ch = bytes[pos + 1]

        # Two-character operators
        var is_two_char_op = false
        if ch == 61 and next_ch == 61:
            is_two_char_op = true
        if ch == 33 and next_ch == 61:
            is_two_char_op = true
        if ch == 60 and next_ch == 61:
            is_two_char_op = true
        if ch == 62 and next_ch == 61:
            is_two_char_op = true
        if ch == 45 and next_ch == 62:
            is_two_char_op = true
        if ch == 124 and next_ch == 62:
            is_two_char_op = true
        if ch == 62 and next_ch == 62:
            is_two_char_op = true
        if ch == 126 and next_ch == 62:
            is_two_char_op = true
        if ch == 42 and next_ch == 42:
            is_two_char_op = true
        if ch == 58 and next_ch == 61:
            is_two_char_op = true
        if ch == 46 and next_ch == 63:
            is_two_char_op = true
        if ch == 63 and next_ch == 63:
            is_two_char_op = true
        if ch == 38 and next_ch == 58:
            is_two_char_op = true

        if is_two_char_op:
            val op_text = source.substring(pos, pos + 2)
            out_types.push(2)
            out_values.push(op_text)
            out_lines.push(line_num)
            count = count + 1
            pos = pos + 2
            continue

        # ── Single-char operators ────────────────────────────────────────
        var is_op = false
        if ch == 43 or ch == 45 or ch == 42 or ch == 47 or ch == 37:
            is_op = true
        if ch == 61 or ch == 60 or ch == 62 or ch == 33:
            is_op = true
        if ch == 124 or ch == 38 or ch == 126 or ch == 94:
            is_op = true

        if is_op:
            val sop_text = source.substring(pos, pos + 1)
            out_types.push(2)
            out_values.push(sop_text)
            out_lines.push(line_num)
            count = count + 1
            pos = pos + 1
            continue

        # ── Punctuation (parens, brackets, braces, comma, colon, dot, etc.) ─
        var is_punct = false
        if ch == 40 or ch == 41 or ch == 91 or ch == 93 or ch == 123 or ch == 125:
            is_punct = true
        if ch == 44 or ch == 58 or ch == 46 or ch == 59 or ch == 64:
            is_punct = true

        if is_punct:
            val punc_text = source.substring(pos, pos + 1)
            out_types.push(4)
            out_values.push(punc_text)
            out_lines.push(line_num)
            count = count + 1
            pos = pos + 1
            continue

        # ── Unknown character — skip ─────────────────────────────────────
        pos = pos + 1

    count

# ── Karp-Rabin token hash ────────────────────────────────────────────────────
# Hash a single token value to a number for use in rolling hash
fn hash_token_value(token_val: text) -> i64:
    val codes = rt_text_to_bytes(token_val)
    var h = 0
    var ci = 0
    while ci < codes.len():
        h = (h * 31 + codes[ci]) % 1000000007
        ci = ci + 1
    if h < 0:
        h = h + 1000000007
    h

# Compute base^exp mod m using repeated squaring
fn pow_mod(base_val: i64, exp_val: i64, mod_val: i64) -> i64:
    var result = 1
    var b = base_val % mod_val
    var e = exp_val
    while e > 0:
        if e % 2 == 1:
            result = (result * b) % mod_val
        e = e / 2
        b = (b * b) % mod_val
    result

# ── Normalize tokens for identifier-insensitive matching ─────────────────────
# Returns new values array with identifiers replaced by _ID_
fn normalize_tokens(types: [i64], values: [text]) -> [text]:
    var normalized = []
    var ti = 0
    while ti < types.len():
        if types[ti] == 1:
            normalized.push("_ID_")
        else:
            normalized.push(values[ti])
        ti = ti + 1
    normalized

# ── Main duplicate finder (token-based) ──────────────────────────────────────
fn find_duplicates(files: [text], min_tokens: i64, do_normalize: bool):
    print "Scanning {files.len()} files for {min_tokens}+ token duplicates..."
    if do_normalize:
        print "  (identifier normalization ON — detects renamed-variable clones)"

    # Phase 1: Tokenize all files and collect windows
    var w_hashes = []
    var w_file_idx = []
    var w_starts = []       # start line of the window (1-based)
    var w_tok_starts = []   # start token index within file's token list

    # Cache file contents and tokens
    var file_contents = []
    var all_tok_types = []   # file_index -> [i64]
    var all_tok_values = []  # file_index -> [text] (possibly normalized)
    var all_tok_lines = []   # file_index -> [i64]
    var all_tok_raw_values = []  # file_index -> [text] (original, for content verification)

    var file_idx = 0
    var total_tokens = 0
    for file_path in files:
        val content = file_read(file_path)
        file_contents.push(content)

        var cur_types = []
        var cur_values = []
        var cur_lines = []
        val tok_count = tokenize(content, cur_types, cur_values, cur_lines)
        total_tokens = total_tokens + tok_count

        # Store raw values for content verification
        all_tok_raw_values.push(cur_values)

        # Normalize if requested
        var effective_values = cur_values
        if do_normalize:
            effective_values = normalize_tokens(cur_types, cur_values)

        all_tok_types.push(cur_types)
        all_tok_values.push(effective_values)
        all_tok_lines.push(cur_lines)

        # Build token windows with Karp-Rabin rolling hash
        if tok_count >= min_tokens:
            # Pre-hash all token values for this file
            var token_hashes = []
            var thi = 0
            while thi < tok_count:
                token_hashes.push(hash_token_value(effective_values[thi]))
                thi = thi + 1

            # Compute base^(min_tokens-1) mod M for rolling removal
            val base_power = pow_mod(31, min_tokens - 1, 1000000007)

            # Compute hash of first window
            var rolling = 0
            var wi = 0
            while wi < min_tokens:
                rolling = (rolling * 31 + token_hashes[wi]) % 1000000007
                wi = wi + 1
            if rolling < 0:
                rolling = rolling + 1000000007

            w_hashes.push(rolling)
            w_file_idx.push(file_idx)
            w_starts.push(cur_lines[0])
            w_tok_starts.push(0)

            # Slide the window using Karp-Rabin rolling update
            var slide_pos = 1
            while slide_pos <= tok_count - min_tokens:
                val old_tok = token_hashes[slide_pos - 1]
                val new_tok = token_hashes[slide_pos + min_tokens - 1]

                rolling = ((rolling - old_tok * base_power % 1000000007 + 1000000007) * 31 + new_tok) % 1000000007
                if rolling < 0:
                    rolling = rolling + 1000000007

                w_hashes.push(rolling)
                w_file_idx.push(file_idx)
                w_starts.push(cur_lines[slide_pos])
                w_tok_starts.push(slide_pos)

                slide_pos = slide_pos + 1

        file_idx = file_idx + 1

    val n = w_hashes.len()
    print "Tokenized {total_tokens} tokens, computed {n} windows from {files.len()} files"

    # Phase 2: Sort indices by hash for O(n log n) grouping
    var indices = []
    var sort_idx = 0
    while sort_idx < n:
        indices.push(sort_idx)
        sort_idx = sort_idx + 1

    indices = merge_sort(indices, w_hashes)

    # Phase 3: Walk sorted indices, group consecutive equal hashes
    var total_groups = 0
    var total_dup_tokens = 0
    var i = 0

    while i < n:
        val current_hash = w_hashes[indices[i]]

        # Find end of group with same hash
        var group_end = i + 1
        while group_end < n and w_hashes[indices[group_end]] == current_hash:
            group_end = group_end + 1

        val group_size = group_end - i

        # Only process groups with 2+ entries (potential duplicates)
        if group_size >= 2 and group_size <= 100:
            # Check pairs within group
            var gi = i
            while gi < group_end:
                var gj = gi + 1
                while gj < group_end:
                    val idx_a = indices[gi]
                    val idx_b = indices[gj]
                    val file_a = w_file_idx[idx_a]
                    val file_b = w_file_idx[idx_b]
                    val tok_start_a = w_tok_starts[idx_a]
                    val tok_start_b = w_tok_starts[idx_b]

                    # Skip same-file overlapping windows
                    var should_skip = false
                    if file_a == file_b:
                        val diff = tok_start_b - tok_start_a
                        if diff < min_tokens and diff > (0 - min_tokens):
                            should_skip = true

                    if not should_skip:
                        # Verify actual content match (not just hash collision)
                        # Use the effective (possibly normalized) values
                        val vals_a = all_tok_values[file_a]
                        val vals_b = all_tok_values[file_b]
                        var is_match = true
                        var mk = 0
                        while mk < min_tokens:
                            val ta = tok_start_a + mk
                            val tb = tok_start_b + mk
                            if ta < vals_a.len() and tb < vals_b.len():
                                if vals_a[ta] != vals_b[tb]:
                                    is_match = false
                                    break
                            else:
                                is_match = false
                                break
                            mk = mk + 1

                        if is_match:
                            total_groups = total_groups + 1
                            total_dup_tokens = total_dup_tokens + min_tokens

                            val line_a = w_starts[idx_a]
                            val line_b = w_starts[idx_b]
                            val end_line_a = all_tok_lines[file_a][tok_start_a + min_tokens - 1]
                            val end_line_b = all_tok_lines[file_b][tok_start_b + min_tokens - 1]

                            print ""
                            print "Duplicate #{total_groups} ({min_tokens} tokens, lines {line_a}-{end_line_a} / {line_b}-{end_line_b}):"
                            print "  A: {files[file_a]}:{line_a}-{end_line_a}"
                            print "  B: {files[file_b]}:{line_b}-{end_line_b}"

                            # Preview first 5 tokens from each (raw, not normalized)
                            val raw_a = all_tok_raw_values[file_a]
                            var preview_a = ""
                            var pk = 0
                            while pk < min_tokens and pk < 8:
                                val pidx = tok_start_a + pk
                                if pidx < raw_a.len():
                                    if pk > 0:
                                        preview_a = preview_a + " "
                                    preview_a = preview_a + raw_a[pidx]
                                pk = pk + 1
                            if min_tokens > 8:
                                preview_a = preview_a + " ..."
                            print "    {preview_a}"

                    gj = gj + 1
                gi = gi + 1

        i = group_end

    print ""
    print "=== Summary ==="
    print "Files scanned: {files.len()}"
    print "Total tokens: {total_tokens}"
    print "Duplicate groups: {total_groups}"
    print "Total duplicated tokens: {total_dup_tokens}"
    if do_normalize:
        print "(identifiers normalized — renamed-variable clones detected)"

# Merge sort: returns sorted index array by values[index]
fn merge_sort(arr: [i64], values: [i64]) -> [i64]:
    if arr.len() <= 1:
        return arr

    val mid = arr.len() / 2
    var left = []
    var right = []

    var i = 0
    while i < mid:
        left.push(arr[i])
        i = i + 1
    while i < arr.len():
        right.push(arr[i])
        i = i + 1

    left = merge_sort(left, values)
    right = merge_sort(right, values)
    merge_lists(left, right, values)

fn merge_lists(left: [i64], right: [i64], values: [i64]) -> [i64]:
    var result = []
    var li = 0
    var ri = 0

    while li < left.len() and ri < right.len():
        if values[left[li]] <= values[right[ri]]:
            result.push(left[li])
            li = li + 1
        else:
            result.push(right[ri])
            ri = ri + 1

    while li < left.len():
        result.push(left[li])
        li = li + 1
    while ri < right.len():
        result.push(right[ri])
        ri = ri + 1

    result

fn main():
    val args = rt_cli_get_args()
    var target = "src/compiler/00.common/"
    var min_tokens = 30
    var do_normalize = true

    # args[0]=binary, args[1]=script, args[2+]=user args
    if args.len() > 2:
        target = args[2]
    if args.len() > 3:
        min_tokens = int(args[3])

    # Check for --no-normalize flag in any position
    var arg_idx = 2
    while arg_idx < args.len():
        if args[arg_idx] == "--no-normalize":
            do_normalize = false
        arg_idx = arg_idx + 1

    val files = collect_spl_files(target)
    find_duplicates(files, min_tokens, do_normalize)
