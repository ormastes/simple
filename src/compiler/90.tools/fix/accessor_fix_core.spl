# Dummy-Accessor Auto-Fix — Core Logic
#
# Detects "dummy" get_*/set_*/is_* accessors (single-statement forwarders to a
# backing field, the ACC001 / dummy_accessor lint) and rewrites call sites to
# direct field access:
#
#     obj.get_x()    -> obj.x          # getter / is_ predicate  -> varname access
#     obj.set_x(v)   -> obj.x = v      # setter                  -> assignment
#
# Safety tiers (chosen so a textual rewrite can never miscompile a *real*
# accessor that happens to share a name on a different class):
#
#   tier-1 (cross-file): only for accessor names that are GLOBALLY UNAMBIGUOUS
#     — every method with that name in the whole source set is itself a dummy
#     forwarder (no class implements a real method of that name). For those the
#     receiver type is irrelevant, so every call site is rewritten and the
#     wrapper definitions are deleted.
#   tier-2 (same-file): for ambiguous names (some class has a real method of the
#     same name) only `self.`/`me.` calls inside the *defining class* are
#     rewritten and the wrapper is kept. Marked review-only; never deletes defs.
#
# Pure functions only (no I/O) so the CLI entry and the SPipe spec share them.

# ============================================================================
# Data structures
# ============================================================================

struct AccMethod:
    name: text
    kind: text          # "get" | "set" | "is" | "" (non-accessor)
    field: text         # backing field (suffix after the prefix)
    is_dummy: bool
    value_param: text   # setter value parameter name
    def_start: i64      # 0-based line index of the (decorator-extended) header
    def_end: i64        # exclusive 0-based line index after the body

struct AccClass:
    name: text
    indent: i64
    start_line: i64
    end_line: i64       # exclusive
    field_count: i64    # direct field members (non-method body lines)
    methods: [AccMethod]

struct AccRecord:
    file: text
    class_name: text
    name: text
    kind: text
    field: text
    def_start: i64
    def_end: i64
    class_start: i64
    class_end: i64

# ============================================================================
# Lexical helpers
# ============================================================================

fn acc_leading_ws(line: text) -> i64:
    var n = 0
    var i = 0
    while i < line.len():
        val c = line[i:i + 1]
        if c == " " or c == "\t":
            n = n + 1
            i = i + 1
        else:
            break
    n

fn acc_suffix(name: text) -> text:
    if name.starts_with("get_") and name.len() > 4:
        return name.slice(4)
    if name.starts_with("set_") and name.len() > 4:
        return name.slice(4)
    if name.starts_with("is_") and name.len() > 3:
        return name.slice(3)
    ""

fn acc_kind(name: text) -> text:
    if name.starts_with("get_") and name.len() > 4:
        return "get"
    if name.starts_with("set_") and name.len() > 4:
        return "set"
    if name.starts_with("is_") and name.len() > 3:
        return "is"
    ""

fn acc_is_method_header(trimmed: text) -> bool:
    trimmed.starts_with("fn ") or trimmed.starts_with("me ") or trimmed.starts_with("static fn ")

fn acc_method_name(trimmed: text) -> text:
    var rest = trimmed
    if rest.starts_with("static fn "):
        rest = rest.slice(10).trim()
    elif rest.starts_with("fn "):
        rest = rest.slice(3).trim()
    elif rest.starts_with("me "):
        rest = rest.slice(3).trim()
    val paren = rest.find("(")
    if paren >= 0:
        return rest.slice(0, paren).trim()
    rest.split(" ")[0].trim()

fn acc_first_value_param(trimmed: text) -> text:
    val start = trimmed.find("(")
    val end = trimmed.find(")")
    if start < 0 or end <= start:
        return ""
    val raw = trimmed.slice(start + 1, end).trim()
    if raw == "":
        return ""
    for part in raw.split(","):
        var nm = part.trim()
        val colon = nm.find(":")
        if colon >= 0:
            nm = nm.slice(0, colon).trim()
        val eq = nm.find("=")
        if eq >= 0:
            nm = nm.slice(0, eq).trim()
        if nm != "" and nm != "self" and nm != "me":
            return nm
    ""

fn acc_normalize(s: text) -> text:
    var out = s.replace(" ", "")
    out = out.replace("\t", "")
    out

fn acc_is_dummy_body(kind: text, field: text, value_param: text, body: [text]) -> bool:
    if body.len() != 1:
        return false
    val stmt = acc_normalize(body[0])
    if kind == "get" or kind == "is":
        return (stmt == "self.{field}" or stmt == "me.{field}"
                or stmt == "returnself.{field}" or stmt == "returnme.{field}")
    if kind == "set":
        if value_param == "":
            return false
        return stmt == "self.{field}={value_param}" or stmt == "me.{field}={value_param}"
    false

fn acc_is_decorator(trimmed: text) -> bool:
    trimmed.starts_with("@")

# ============================================================================
# Parsing: source text -> [AccClass]
# ============================================================================

fn parse_accessor_classes(source: text) -> [AccClass]:
    val lines = source.split("\n")
    var classes: [AccClass] = []
    var cur = -1
    var i = 0
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            i = i + 1
            continue
        val indent = acc_leading_ws(line)
        if trimmed.starts_with("class "):
            var c = AccClass(
                name: acc_parse_class_name(trimmed),
                indent: indent,
                start_line: i,
                end_line: lines.len(),
                field_count: 0,
                methods: []
            )
            classes.push(c)
            cur = classes.len() - 1
            i = i + 1
            continue
        if cur >= 0:
            var ci = classes[cur]
            if indent <= ci.indent:
                ci.end_line = i
                classes[cur] = ci
                cur = -1
                continue   # re-examine this line (could open another class)
            if acc_is_method_header(trimmed):
                val name = acc_method_name(trimmed)
                val kind = acc_kind(name)
                val field = acc_suffix(name)
                val vparam = acc_first_value_param(trimmed)
                val method_indent = indent
                # collect body
                var body: [text] = []
                var j = i + 1
                while j < lines.len():
                    val bl = lines[j]
                    val bt = bl.trim()
                    if bt != "" and not bt.starts_with("#") and acc_leading_ws(bl) <= method_indent:
                        break
                    if bt != "" and not bt.starts_with("#"):
                        body.push(bt)
                    j = j + 1
                val dummy = if kind != "": acc_is_dummy_body(kind, field, vparam, body) else: false
                # extend def_start upward over contiguous decorator lines
                var ds = i
                var k = i - 1
                while k >= 0 and acc_is_decorator(lines[k].trim()):
                    ds = k
                    k = k - 1
                var m = AccMethod(
                    name: name, kind: kind, field: field,
                    is_dummy: dummy, value_param: vparam,
                    def_start: ds, def_end: j
                )
                ci.methods.push(m)
                classes[cur] = ci
                i = j
                continue
            else:
                # direct child that is not a method header: a field decl,
                # docstring line, or decorator — count fields conservatively.
                if (not acc_is_decorator(trimmed)) and (not trimmed.starts_with("\"")) and trimmed.contains(":"):
                    ci.field_count = ci.field_count + 1
                    classes[cur] = ci
                i = i + 1
                continue
        i = i + 1
    classes

fn acc_parse_class_name(trimmed: text) -> text:
    var rest = trimmed.slice(6).trim()
    if rest.ends_with(":"):
        rest = rest.slice(0, rest.len() - 1).trim()
    val paren = rest.find("(")
    if paren >= 0:
        return rest.slice(0, paren).trim()
    val sp = rest.find(" ")
    if sp >= 0:
        return rest.slice(0, sp).trim()
    rest

# ============================================================================
# Global indexing across many files
# ============================================================================

# Collect all dummy accessor records from a {file: source} map.
fn collect_dummy_records(sources: Dict<text, text>) -> [AccRecord]:
    var out: [AccRecord] = []
    for file in sources.keys():
        val classes = parse_accessor_classes(sources[file])
        for c in classes:
            # a suffix is "real" within this class if any same-suffix method is
            # a non-dummy accessor; then none of its dummies are flagged.
            for m in c.methods:
                if not m.is_dummy:
                    continue
                if acc_suffix_has_real(c, m.field):
                    continue
                out.push(AccRecord(
                    file: file, class_name: c.name, name: m.name,
                    kind: m.kind, field: m.field,
                    def_start: m.def_start, def_end: m.def_end,
                    class_start: c.start_line, class_end: c.end_line
                ))
    out

fn acc_suffix_has_real(c: AccClass, field: text) -> bool:
    for m in c.methods:
        if m.field == field and m.kind != "" and not m.is_dummy:
            return true
    false

# Names that must NOT be globally rewritten because some method of that exact
# name is a *real* (non-dummy) accessor somewhere in the source set.
fn collect_poisoned_names(sources: Dict<text, text>) -> Dict<text, bool>:
    var poison: Dict<text, bool> = {}
    for file in sources.keys():
        val classes = parse_accessor_classes(sources[file])
        for c in classes:
            for m in c.methods:
                if m.kind != "" and not m.is_dummy:
                    poison[m.name] = true
    poison
