# EasyFix Rules - Rule Registry and Dispatch
# Manages rule registration and execution coordination.

use std.tooling.easy_fix.*
use compiler.tools.fix.rules.impl_.lint_spec (
    check_print_in_test_spec,
    check_spipe_missing_docstrings,
    check_spipe_manual_assertions,
    check_spipe_no_print_based_tests,
    check_spipe_minimal_docstrings
)
use compiler.tools.fix.rules.impl_.lint_code (
    check_unnamed_duplicate_typed_args,
    check_resource_leak,
    check_non_exhaustive_match
)
use compiler.tools.fix.rules.impl_.error_fix (
    check_parser_contextual_keyword,
    check_typo_suggestion,
    suggest_typo_fix,
    check_type_mismatch_coercion,
    suggest_type_coercion_fix
)
use compiler.tools.fix.rules.impl_.deprecation (
    check_deprecated_if_let,
    check_struct_construction_parens
)
use compiler.tools.fix.rules.impl_.lint_stub (
    check_stub_impl_text
)
use compiler.tools.fix.rules.impl_.lint_star_import (
    check_star_import_text
)
use compiler.tools.fix.rules.impl_.lint_wide_public (
    check_wide_public_text
)
use compiler.tools.fix.rules.impl_.lint_annotation (
    check_unknown_decorator,
    check_unknown_attribute
)
use compiler.tools.fix.rules.impl_.lint_module (
    check_export_outside_init,
    check_init_boundary_violation,
    check_bypass_with_code_files
)
use compiler.tools.fix.rules.impl_.lint_bool (
    check_bare_bool
)
use compiler.tools.fix.rules.impl_.lint_primitive_api (
    check_primitive_api
)
use compiler.tools.fix.rules.impl_.lint_script_language (
    check_simple_script_required
)
use compiler.tools.fix.rules.impl_.lint_short_grammar (
    check_short_grammar_refactor
)
use compiler.tools.fix.rules.impl_.lint_simd (
    check_simd_opportunities
)
use std.tooling.easy_fix.accessor_field_access.{check_field_access_refactor}

# ============================================================================
# Master: run all text-scanning rules
# ============================================================================

fn check_all_rules(source: String, file: String) -> [EasyFix]:
    var all_fixes: [EasyFix] = []

    val fixes1 = check_print_in_test_spec(source, file)
    for f in fixes1:
        all_fixes.push(f)

    val fixes2 = check_unnamed_duplicate_typed_args(source, file)
    for f in fixes2:
        all_fixes.push(f)

    val fixes3 = check_resource_leak(source, file)
    for f in fixes3:
        all_fixes.push(f)

    val fixes4 = check_spipe_missing_docstrings(source, file)
    for f in fixes4:
        all_fixes.push(f)

    val fixes5 = check_spipe_manual_assertions(source, file)
    for f in fixes5:
        all_fixes.push(f)

    val fixes6 = check_non_exhaustive_match(source, file)
    for f in fixes6:
        all_fixes.push(f)

    val fixes7 = check_parser_contextual_keyword(source, file)
    for f in fixes7:
        all_fixes.push(f)

    val fixes8 = check_deprecated_if_let(source, file)
    for f in fixes8:
        all_fixes.push(f)

    val fixes9 = check_struct_construction_parens(source, file)
    for f in fixes9:
        all_fixes.push(f)

    val fixes10 = check_stub_impl_text(source, file)
    for f in fixes10:
        all_fixes.push(f)

    val fixes11 = check_star_import_text(source, file)
    for f in fixes11:
        all_fixes.push(f)

    val fixes12 = check_wide_public_text(source, file)
    for f in fixes12:
        all_fixes.push(f)

    val fixes13 = check_unknown_decorator(source, file)
    for f in fixes13:
        all_fixes.push(f)

    val fixes14 = check_unknown_attribute(source, file)
    for f in fixes14:
        all_fixes.push(f)

    val fixes15 = check_export_outside_init(source, file)
    for f in fixes15:
        all_fixes.push(f)

    val fixes16 = check_init_boundary_violation(source, file)
    for f in fixes16:
        all_fixes.push(f)

    val fixes17 = check_bypass_with_code_files(source, file)
    for f in fixes17:
        all_fixes.push(f)

    val fixes18 = check_bare_bool(source, file)
    for f in fixes18:
        all_fixes.push(f)

    val fixes19 = check_spipe_no_print_based_tests(source, file)
    for f in fixes19:
        all_fixes.push(f)

    val fixes20 = check_spipe_minimal_docstrings(source, file)
    for f in fixes20:
        all_fixes.push(f)

    val fixes21 = check_primitive_api(source, file)
    for f in fixes21:
        all_fixes.push(f)

    val fixes22 = check_short_grammar_refactor(source, file)
    for f in fixes22:
        all_fixes.push(f)

    val fixes23 = check_simple_script_required(source, file)
    for f in fixes23:
        all_fixes.push(f)

    val fixes24 = check_field_access_refactor(source, file)
    for f in fixes24:
        all_fixes.push(f)

    # Rules 7 (typo) and 9 (type coercion) are no-ops in text-scanning mode.
    # They require compiler integration (Rust side).

    all_fixes
