# EasyFix Rules - Rule Implementations
#
# FACADE: This module has been refactored into focused submodules:
#   - impl/lint_spec.spl   — Spec file lint rules (Rules 1, 4, 5)
#   - impl/lint_code.spl   — Code quality lint rules (Rules 2, 3, 6)
#   - impl/error_fix.spl   — Compiler error fix rules (Rules 7, 8, 9)
#   - impl/deprecation.spl — Deprecated syntax rules (Rules 10, 11)
#
# Rule IDs:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:sspec_missing_docstrings   — Add template docstring to describe/context
#   L:sspec_manual_assertions    — Replace manual if/fail with expect()
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:typo_suggestion            — Fix misspelled identifiers (Levenshtein)
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   E:type_mismatch_coercion     — Insert type coercion (.to_string() etc.)
#   L:deprecated_if_let          — Replace `if let` with `if val`
#   L:struct_construction_parens — Replace ClassName(field: val) with ClassName { field: val }
#   L:stub_impl                 — Function with params returns trivial literal (possible stub)

# Import from spec lint rules (Rules 1, 4, 5, 7, 8)
use compiler.tools.fix.rules.impl.lint_spec.{
    check_print_in_test_spec,
    check_sspec_missing_docstrings,
    check_sspec_manual_assertions,
    check_sspec_no_print_based_tests,
    check_sspec_minimal_docstrings
}

# Import from code quality lint rules (Rules 2, 3, 6)
use compiler.tools.fix.rules.impl.lint_code.{
    check_unnamed_duplicate_typed_args,
    check_resource_leak,
    check_non_exhaustive_match
}

# Import from error fix rules (Rules 7, 8, 9)
use compiler.tools.fix.rules.impl.error_fix.{
    check_typo_suggestion,
    suggest_typo_fix,
    check_parser_contextual_keyword,
    check_type_mismatch_coercion,
    suggest_type_coercion_fix
}

# Import from deprecation rules (Rules 10, 11)
use compiler.tools.fix.rules.impl.deprecation.{
    check_deprecated_if_let,
    check_struct_construction_parens
}

# Import from stub impl lint rule (Rule 12)
use compiler.tools.fix.rules.impl.lint_stub.{
    check_stub_impl_text
}

# Import from star import lint rule (W0406)
use compiler.tools.fix.rules.impl.lint_star_import.{
    check_star_import_text
}

# Import from wide public lint rule (W0404)
use compiler.tools.fix.rules.impl.lint_wide_public.{
    check_wide_public_text
}

# Import from annotation lint rules
use compiler.tools.fix.rules.impl.lint_annotation.{
    check_unknown_decorator,
    check_unknown_attribute
}

# Import from module boundary lint rules
use compiler.tools.fix.rules.impl.lint_module.{
    check_export_outside_init,
    check_init_boundary_violation,
    check_bypass_with_code_files
}

# Import from bare bool lint rule
use compiler.tools.fix.rules.impl.lint_bool.{
    check_bare_bool
}

# Import from primitive API lint rule
use compiler.tools.fix.rules.impl.lint_primitive_api.{
    check_primitive_api
}

# Re-export all rules
