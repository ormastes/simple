# EasyFix Rules - Bare Bool Detection (Text-Scanning)
#
# Text-based detection for bare bool parameters in public functions:
#   L:bare_bool — Function parameter uses bare bool type, suggest enum

use std.tooling.easy_fix.*
use super.super.helpers.*

# ============================================================================
# Rule: bare_bool
# Detects function parameters typed as `bool` or `Bool` in public fn/me
# signatures. Does NOT flag return types (-> bool is OK).
# Does NOT flag parameters in private functions (heuristic: lines with
# deeper indentation, suggesting they are inside a class/struct body).
#
# Confidence: Uncertain (heuristic — may not always warrant an enum)
# ============================================================================

fn check_bare_bool(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var in_class_body = false
    var class_indent = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        # Track class/struct body context for private function detection
        if trimmed.starts_with("class ") or trimmed.starts_with("struct "):
            in_class_body = true
            class_indent = indent

        # If we dedent back to or past the class level, we left the body
        if in_class_body and indent <= class_indent and trimmed.len() > 0:
            if not trimmed.starts_with("class ") and not trimmed.starts_with("struct "):
                in_class_body = false

        # Only check function signatures
        val is_fn = trimmed.starts_with("fn ") or trimmed.starts_with("me ") or trimmed.starts_with("static fn ")
        if is_fn:
            # Skip private functions (inside class body = likely private)
            if in_class_body and indent > class_indent:
                byte_offset = byte_offset + line.len() + 1
                continue

            # Extract the parameter list
            val paren_start = trimmed.find("(")
            val paren_end = trimmed.find(")")
            if paren_start >= 0 and paren_end > paren_start:
                val params_str = trimmed.slice(paren_start + 1, paren_end)
                val params = params_str.split(",")

                for param in params:
                    val p = param.trim()
                    # Check for `: bool` or `: Bool` type annotation
                    if _has_bare_bool_type(p):
                        val param_name = _extract_param_name(p)
                        var fix = EasyFix.create(
                            id: "L:bare_bool:{line_num}",
                            description: "parameter '{param_name}' uses bare bool — consider replacing with a descriptive enum",
                            confidence: FixConfidence.Uncertain
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: byte_offset + indent,
                            end: byte_offset + line.len(),
                            line: line_num,
                            column: indent + 1,
                            new_text: line
                        ))
                        fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

fn _has_bare_bool_type(param: text) -> bool:
    """Check if a parameter has bare bool or Bool type."""
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return false
    val type_part = param.slice(colon_pos + 1).trim()
    # Match exactly "bool" or "Bool" (not Option<bool>, [bool], etc.)
    if type_part == "bool" or type_part == "Bool":
        return true
    false

fn _extract_param_name(param: text) -> text:
    """Extract the parameter name from 'name: type' pattern."""
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return param.trim()
    param.slice(0, colon_pos).trim()
