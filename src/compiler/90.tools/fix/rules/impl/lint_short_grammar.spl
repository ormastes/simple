# EasyFix Rules - Short Grammar Refactors (Text-Scanning)
#
# Conservative rewrites from explicit long grammar to proven short grammar:
#   L:short_grammar_method_ref — `\x: x.method()` -> `&:method`
#   L:short_grammar_placeholder — `\x: x * 2` -> `_1 * 2`
#                               — `\x: x.method() > 0` -> `_1.method() > 0`
# Interpolation rewrites are intentionally not emitted until the parser
# transforms placeholders inside interpolation expressions.

use std.tooling.easy_fix.*
use compiler.tools.fix.rules.helpers.*

fn check_short_grammar_refactor(source: text, file: text) -> [EasyFix]:
    for_each_line(source, \ctx:
        _check_short_grammar_line(ctx, file)
    )

fn _check_short_grammar_line(ctx: LineContext, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var search_from = 0
    while search_from < ctx.line.len():
        val lambda_start = _find_next_lambda_start(ctx.line, search_from)
        if lambda_start < 0:
            return fixes
        if _line_has_functional_update_before(ctx.line, lambda_start):
            search_from = lambda_start + 1
            continue
        val parsed = _parse_method_ref_candidate(ctx.line, lambda_start)
        match parsed:
            case Some(candidate):
                var fix = EasyFix.create(
                    id: "L:short_grammar_method_ref:{ctx.line_num}:{lambda_start + 1}",
                    description: "replace explicit lambda with method reference short grammar `&:{candidate.method}`",
                    confidence: FixConfidence.Safe
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: ctx.byte_offset + lambda_start,
                    end: ctx.byte_offset + candidate.end_offset,
                    line: ctx.line_num,
                    column: lambda_start + 1,
                    new_text: "&:{candidate.method}"
                ))
                fixes.push(fix)
                search_from = candidate.end_offset
            case nil:
                val placeholder = _parse_placeholder_candidate(ctx.line, lambda_start)
                match placeholder:
                    case Some(candidate):
                        var fix = EasyFix.create(
                            id: "L:short_grammar_placeholder:{ctx.line_num}:{lambda_start + 1}",
                            description: "replace explicit lambda with placeholder short grammar `{candidate.new_text}`",
                            confidence: FixConfidence.Safe
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: ctx.byte_offset + lambda_start,
                            end: ctx.byte_offset + candidate.end_offset,
                            line: ctx.line_num,
                            column: lambda_start + 1,
                            new_text: candidate.new_text
                        ))
                        fixes.push(fix)
                        search_from = candidate.end_offset
                    case nil:
                        search_from = lambda_start + 1

    fixes

fn _find_next_lambda_start(line: text, search_from: i64) -> i64:
    val candidate = _find_text_from(line, "\\", search_from)
    if candidate < 0:
        return -1
    if _line_has_comment_before(line, candidate) or _position_is_inside_string(line, candidate):
        return _find_next_lambda_start(line, candidate + 1)
    if candidate + 1 >= line.len():
        return -1
    val next = line[candidate + 1:candidate + 2]
    if _is_identifier_start(next) or next == "(":
        return candidate
    _find_next_lambda_start(line, candidate + 1)

fn _line_has_comment_before(line: text, pos: i64) -> bool:
    var i = 0
    while i < pos:
        if line[i:i + 1] == "#":
            return true
        i = i + 1
    false

fn _line_has_functional_update_before(line: text, pos: i64) -> bool:
    _find_text_from(line[0:pos], "->", 0) >= 0

fn _position_is_inside_string(line: text, pos: i64) -> bool:
    var i = 0
    var in_string = false
    while i < pos:
        val ch = line[i:i + 1]
        if ch == "\"":
            in_string = not in_string
        i = i + 1
    in_string

struct ShortGrammarMethodRefCandidate:
    method: text
    end_offset: i64

struct ShortGrammarPlaceholderCandidate:
    new_text: text
    end_offset: i64

fn _parse_method_ref_candidate(line: text, lambda_start: i64) -> Option<ShortGrammarMethodRefCandidate>:
    val colon_abs = _find_text_from(line, ":", lambda_start)
    if colon_abs < 0:
        return nil
    val colon_rel = colon_abs - lambda_start

    val raw_param = line[lambda_start:colon_abs].trim()
    if raw_param.len() < 2:
        return nil
    val introducer = raw_param[0:1]
    if _is_identifier_char(introducer):
        return nil
    val param = raw_param[1:raw_param.len()].trim()
    if not _is_plain_identifier(param):
        return nil

    var body_start = lambda_start + colon_rel + 1
    while body_start < line.len() and line[body_start:body_start + 1] == " ":
        body_start = body_start + 1

    val receiver_prefix = param + "."
    val body_tail = line[body_start:line.len()]
    if not body_tail.starts_with(receiver_prefix):
        return nil

    val method_start = body_start + receiver_prefix.len()
    val method_end = _scan_identifier_end(line, method_start)
    if method_end <= method_start:
        return nil

    val method = line[method_start:method_end]
    if method.starts_with("_"):
        return nil

    val call_end = method_end + 2
    if call_end > line.len() or line[method_end:call_end] != "()":
        return nil

    val suffix = line[call_end:line.len()].trim()
    if suffix != "" and not suffix.starts_with(")") and not suffix.starts_with(","):
        return nil

    Some(ShortGrammarMethodRefCandidate(method: method, end_offset: call_end))

fn _parse_placeholder_candidate(line: text, lambda_start: i64) -> Option<ShortGrammarPlaceholderCandidate>:
    val colon_abs = _find_text_from(line, ":", lambda_start)
    if colon_abs < 0:
        return nil
    val colon_rel = colon_abs - lambda_start

    val raw_param = line[lambda_start:colon_abs].trim()
    if raw_param.len() < 2:
        return nil
    val tuple_candidate = _parse_tuple_placeholder_candidate(line, lambda_start, colon_abs)
    match tuple_candidate:
        case Some(candidate):
            return Some(candidate)
        case nil:
            pass
    val introducer = raw_param[0:1]
    if _is_identifier_char(introducer):
        return nil
    val param = raw_param[1:raw_param.len()].trim()
    if not _is_plain_identifier(param):
        return nil

    var body_start = lambda_start + colon_rel + 1
    while body_start < line.len() and line[body_start:body_start + 1] == " ":
        body_start = body_start + 1

    val expr_end = _scan_simple_lambda_expr_end(line, body_start)
    if expr_end <= body_start:
        return nil
    val expr = line[body_start:expr_end].trim()
    val value_prefix = param + " "
    val member_prefix = param + "."
    if not expr.starts_with(value_prefix) and not expr.starts_with(member_prefix) and not _expr_contains_plain_identifier(expr, param):
        return nil
    if not _placeholder_brackets_are_param_free(expr, param):
        return nil
    if not _placeholder_quotes_are_safe(expr, param):
        return nil
    if expr.contains("(") and not _placeholder_calls_are_safe(expr, param):
        return nil
    val replacement = "_1"
    if _placeholder_expr_is_unary_not_safe(expr, param):
        val unary_new_text = _replace_plain_identifier(expr, param, replacement)
        if unary_new_text == expr:
            return nil
        return Some(ShortGrammarPlaceholderCandidate(new_text: unary_new_text, end_offset: expr_end))
    if _placeholder_expr_has_unsafe_direct_field_predicate(expr, param):
        return nil
    if not _placeholder_expr_is_safe(expr) and not _placeholder_expr_is_single_param_call(expr, param) and not _placeholder_expr_is_call_with_safe_args(expr, param) and not _placeholder_expr_is_field_access(expr, param) and not _placeholder_expr_is_unary_not_safe(expr, param):
        return nil

    val new_text = _replace_plain_identifier(expr, param, replacement)
    if new_text == expr:
        return nil
    Some(ShortGrammarPlaceholderCandidate(new_text: new_text, end_offset: expr_end))

fn _parse_tuple_placeholder_candidate(line: text, lambda_start: i64, colon_abs: i64) -> Option<ShortGrammarPlaceholderCandidate>:
    val raw_param = line[lambda_start:colon_abs].trim()
    if not raw_param.starts_with("\\(") or not raw_param.ends_with(")"):
        return nil
    val inner = raw_param[2:raw_param.len() - 1].trim()
    if inner == "":
        return nil

    val params = inner.split(",")
    if params.len() < 2:
        return nil
    var clean_params: [text] = []
    for param in params:
        val clean = param.trim()
        if not _is_plain_identifier(clean):
            return nil
        clean_params.push(clean)

    var body_start = colon_abs + 1
    while body_start < line.len() and line[body_start:body_start + 1] == " ":
        body_start = body_start + 1

    val expr_end = _scan_simple_lambda_expr_end(line, body_start)
    if expr_end <= body_start:
        return nil
    val expr = line[body_start:expr_end].trim()
    if expr == "":
        return nil
    if expr.contains("\""):
        return nil

    var new_text = expr
    var replaced = false
    var idx = 0
    while idx < clean_params.len():
        val replacement = "_.{idx}"
        val updated = _replace_plain_identifier(new_text, clean_params[idx], replacement)
        if updated != new_text:
            replaced = true
        new_text = updated
        idx = idx + 1

    if not replaced or new_text == expr:
        return nil
    if new_text.contains("\\(") or new_text.contains("\\)"):
        return nil
    Some(ShortGrammarPlaceholderCandidate(new_text: new_text, end_offset: expr_end))

fn _scan_simple_lambda_expr_end(line: text, start: i64) -> i64:
    var i = start
    var paren_depth = 0
    while i < line.len():
        val ch = line[i:i + 1]
        if ch == "(":
            paren_depth = paren_depth + 1
        elif ch == ")":
            if paren_depth == 0:
                return i
            paren_depth = paren_depth - 1
        elif ch == "," and paren_depth == 0:
            return i
        i = i + 1
    i

fn _find_text_from(line: text, needle: text, search_from: i64) -> i64:
    if needle == "":
        return search_from
    var i = search_from
    while i + needle.len() <= line.len():
        if line[i:i + needle.len()] == needle:
            return i
        i = i + 1
    -1

fn _placeholder_expr_is_safe(expr: text) -> bool:
    expr.contains(" + ") or expr.contains(" - ") or expr.contains(" * ") or expr.contains(" / ") or expr.contains(" % ") or expr.contains(" > ") or expr.contains(" < ") or expr.contains(" == ") or expr.contains(" != ") or expr.contains(" >= ") or expr.contains(" <= ")

fn _placeholder_calls_are_safe(expr: text, param: text) -> bool:
    var i = 0
    while i < expr.len():
        if expr[i:i + 1] == "(":
            val close = _find_text_from(expr, ")", i + 1)
            if close < 0:
                return false
            val inner = expr[i + 1:close].trim()
            if inner != "" and not _placeholder_call_args_are_safe(inner, param):
                return false
            i = close + 1
        else:
            i = i + 1
    true

fn _placeholder_call_args_are_safe(inner: text, param: text) -> bool:
    var start = 0
    while start <= inner.len():
        val comma = _find_text_from(inner, ",", start)
        val end = if comma < 0: inner.len() else: comma
        val arg = inner[start:end].trim()
        if not _placeholder_call_arg_is_safe(arg, param):
            return false
        if comma < 0:
            return true
        start = comma + 1
    true

fn _placeholder_call_arg_is_safe(arg: text, param: text) -> bool:
    if not _expr_contains_plain_identifier(arg, param):
        return true
    if arg == param:
        return true
    _placeholder_expr_is_safe(arg) or _placeholder_expr_is_single_param_call(arg, param) or _placeholder_expr_is_call_with_safe_args(arg, param) or _placeholder_expr_is_field_access(arg, param) or _placeholder_expr_is_unary_not_safe(arg, param)

fn _placeholder_brackets_are_param_free(expr: text, param: text) -> bool:
    var i = 0
    while i < expr.len():
        if expr[i:i + 1] == "[":
            val close = _find_text_from(expr, "]", i + 1)
            if close < 0:
                return false
            val inner = expr[i + 1:close]
            if _expr_contains_plain_identifier(inner, param):
                return false
            i = close + 1
        else:
            i = i + 1
    true

fn _placeholder_quotes_are_safe(expr: text, param: text) -> bool:
    if not expr.contains("\""):
        return true
    if expr == "\"{" + param + "}\"":
        return true
    if not expr.contains(param):
        return true
    if not expr.contains("\"" + param + "\"") and not expr.contains("{" + param + "}"):
        return true
    var i = 0
    while i < expr.len():
        if expr[i:i + 1] == "\"" and not _placeholder_position_is_inside_brackets(expr, i):
            return false
        i = i + 1
    true

fn _placeholder_expr_is_field_access(expr: text, param: text) -> bool:
    val prefix = param + "."
    if not expr.starts_with(prefix):
        return false
    val field = expr[prefix.len():expr.len()]
    _is_plain_identifier(field)

fn _placeholder_expr_has_unsafe_direct_field_predicate(expr: text, param: text) -> bool:
    val prefix = param + "."
    if not expr.starts_with(prefix):
        return false
    val field_start = prefix.len()
    val field_end = _scan_identifier_end(expr, field_start)
    if field_end <= field_start:
        return false
    if field_end < expr.len() and expr[field_end:field_end + 1] == "(":
        return false
    expr[field_end:expr.len()].trim() != ""

fn _placeholder_expr_is_unary_not_safe(expr: text, param: text) -> bool:
    val prefix = "not "
    if not expr.starts_with(prefix):
        return false
    val inner = expr[prefix.len():expr.len()].trim()
    if inner == "":
        return false
    val field_prefix = param + "."
    if inner.starts_with(field_prefix):
        return _is_plain_identifier(inner[field_prefix.len():inner.len()])
    _placeholder_expr_is_safe(inner) or _placeholder_expr_is_single_param_call(inner, param) or _placeholder_expr_is_call_with_safe_args(inner, param) or _placeholder_expr_is_field_access(inner, param)

fn _placeholder_position_is_inside_brackets(expr: text, pos: i64) -> bool:
    var depth = 0
    var i = 0
    while i < pos:
        val ch = expr[i:i + 1]
        if ch == "[":
            depth = depth + 1
        elif ch == "]" and depth > 0:
            depth = depth - 1
        i = i + 1
    depth > 0

fn _placeholder_expr_is_single_param_call(expr: text, param: text) -> bool:
    val open = _find_text_from(expr, "(", 0)
    if open <= 0:
        return false
    val fn_name = expr[0:open].trim()
    if not _is_plain_identifier(fn_name):
        return false
    val close = _find_text_from(expr, ")", open + 1)
    if close != expr.len() - 1:
        return false
    expr[open + 1:close].trim() == param

fn _placeholder_expr_is_call_with_safe_args(expr: text, param: text) -> bool:
    val open = _find_text_from(expr, "(", 0)
    if open <= 0:
        return false
    val close = _find_text_from(expr, ")", open + 1)
    if close != expr.len() - 1:
        return false
    _placeholder_call_args_are_safe(expr[open + 1:close].trim(), param)

fn _expr_contains_plain_identifier(expr: text, param: text) -> bool:
    _replace_plain_identifier(expr, param, "_") != expr

fn _replace_plain_identifier(expr: text, param: text, replacement: text) -> text:
    var result = ""
    var i = 0
    while i < expr.len():
        if i + param.len() <= expr.len() and expr[i:i + param.len()] == param:
            val before = if i == 0: "" else: expr[i - 1:i]
            val after = if i + param.len() >= expr.len(): "" else: expr[i + param.len():i + param.len() + 1]
            if (before == "" or not _is_identifier_char(before)) and (after == "" or not _is_identifier_char(after)):
                result = result + replacement
                i = i + param.len()
            else:
                result = result + expr[i:i + 1]
                i = i + 1
        else:
            result = result + expr[i:i + 1]
            i = i + 1
    result

fn _scan_identifier_end(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line[i:i + 1]
        if not _is_identifier_char(ch):
            return i
        i = i + 1
    i

fn _is_plain_identifier(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value[i:i + 1]
        if i == 0:
            if not _is_identifier_start(ch):
                return false
        elif not _is_identifier_char(ch):
            return false
        i = i + 1
    true

fn _is_identifier_start(ch: text) -> bool:
    "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_".contains(ch)

fn _is_identifier_char(ch: text) -> bool:
    _is_identifier_start(ch) or "0123456789".contains(ch)
