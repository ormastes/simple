# EasyFix Rules - Bare Primitive Public API Detection (Text-Scanning)
#
# Text-based detection for bare primitive types in public function signatures:
#   L:primitive_api — Public API uses bare integer/float primitive types
#
# This intentionally does not cover `bool` because that has its own `bare_bool`
# lint, and it does not try to prove full AST-level correctness.

use std.tooling.easy_fix.*

struct PrimitiveApiAuditEntry:
    file: text
    line: i64
    item_name: text
    position: text
    primitive_type: text
    reason_code: text
    suggested_wrapper: text

fn primitive_api_types() -> [text]:
    ["i64", "i32", "i16", "i8",
     "u64", "u32", "u16", "u8",
     "f64", "f32"]

fn primitive_api_audit_types() -> [text]:
    ["i64", "i32", "i16", "i8",
     "u64", "u32", "u16", "u8",
     "f64", "f32", "bool", "text", "str", "String"]

fn primitive_api_audit_source(source: text, file: text) -> [PrimitiveApiAuditEntry]:
    var entries: [PrimitiveApiAuditEntry] = []
    val lines = source.split("\n")
    var line_num = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()

        val is_extern_fn = trimmed.starts_with("extern fn ")
        val is_pub_fn = trimmed.starts_with("pub fn ") or trimmed.starts_with("pub me ") or trimmed.starts_with("pub static fn ")
        if not is_extern_fn and is_pub_fn:
            val item_name = _extract_public_function_name(trimmed)
            val params = _extract_params(trimmed)
            val return_type = _extract_return_type(trimmed)

            var all_types: [text] = []
            for param in params:
                val pt = _extract_param_type(param)
                if pt != "":
                    all_types.push(pt)
            if return_type != "":
                all_types.push(return_type)

            val is_pure_math = all_types.len() > 0 and _all_same_primitive(all_types)

            if not is_pure_math:
                for param in params:
                    val param_type = _extract_param_type(param)
                    if _is_audited_primitive_type(param_type):
                        val param_name = _extract_param_name(param)
                        entries.push(PrimitiveApiAuditEntry(
                            file: file,
                            line: line_num,
                            item_name: item_name,
                            position: "param '{param_name}'",
                            primitive_type: param_type,
                            reason_code: _primitive_reason_code(param_type),
                            suggested_wrapper: _suggest_wrapper_name(param_name, param_type)
                        ))

                if _is_audited_primitive_type(return_type):
                    entries.push(PrimitiveApiAuditEntry(
                        file: file,
                        line: line_num,
                        item_name: item_name,
                        position: "return type",
                        primitive_type: return_type,
                        reason_code: _primitive_reason_code(return_type),
                        suggested_wrapper: _suggest_wrapper_name(item_name, return_type)
                    ))

    entries

fn primitive_api_audit_report(source: text, file: text) -> text:
    val entries = primitive_api_audit_source(source, file)
    var out = "primitive_api_audit file={file} count={entries.len()}\n"
    for entry in entries:
        out = out + "{entry.file}:{entry.line}: {entry.item_name} {entry.position} uses {entry.primitive_type} reason={entry.reason_code} suggest={entry.suggested_wrapper}\n"
    out

fn check_primitive_api(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()

        val is_extern_fn = trimmed.starts_with("extern fn ")
        val is_pub_fn = trimmed.starts_with("pub fn ") or trimmed.starts_with("pub me ") or trimmed.starts_with("pub static fn ")
        if not is_extern_fn and is_pub_fn:
            val params = _extract_params(trimmed)
            val return_type = _extract_return_type(trimmed)

            var all_types: [text] = []
            for param in params:
                val pt = _extract_param_type(param)
                if pt != "":
                    all_types.push(pt)
            if return_type != "":
                all_types.push(return_type)

            val is_pure_math = all_types.len() > 0 and _all_same_primitive(all_types)

            if not is_pure_math:
                for param in params:
                    val param_type = _extract_param_type(param)
                    if _is_bare_primitive_type(param_type):
                        val param_name = _extract_param_name(param)
                        var fix = EasyFix.create(
                            id: "L:primitive_api:{line_num}",
                            description: "public API parameter '{param_name}' uses bare primitive type '{param_type}'",
                            confidence: FixConfidence.Uncertain
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: byte_offset,
                            end: byte_offset + line.len(),
                            line: line_num,
                            column: 1,
                            new_text: line
                        ))
                        fixes.push(fix)

                if _is_bare_primitive_type(return_type):
                    var fix = EasyFix.create(
                        id: "L:primitive_api:{line_num}",
                        description: "public API return type uses bare primitive type '{return_type}'",
                        confidence: FixConfidence.Uncertain
                    )
                    fix.add_replacement(Replacement.create(
                        file: file,
                        start: byte_offset,
                        end: byte_offset + line.len(),
                        line: line_num,
                        column: 1,
                        new_text: line
                    ))
                    fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

fn _all_same_primitive(types: [text]) -> bool:
    if types.len() == 0:
        return false
    val first = types[0]
    if not _is_bare_primitive_type(first):
        return false
    for ty in types:
        if ty != first:
            return false
    true

fn _extract_params(line: text) -> [text]:
    val paren_start = line.find("(")
    val paren_end = line.find(")")
    if paren_start < 0 or paren_end <= paren_start:
        return []
    val params_str = line.slice(paren_start + 1, paren_end).trim()
    if params_str == "":
        return []
    params_str.split(",")

fn _extract_param_type(param: text) -> text:
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return ""
    param.slice(colon_pos + 1).trim()

fn _extract_param_name(param: text) -> text:
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return param.trim()
    param.slice(0, colon_pos).trim()

fn _extract_return_type(line: text) -> text:
    val arrow_pos = line.find("->")
    if arrow_pos < 0:
        return ""
    val after_arrow = line.slice(arrow_pos + 2).trim()
    val colon_pos = after_arrow.find(":")
    if colon_pos < 0:
        return after_arrow.trim()
    after_arrow.slice(0, colon_pos).trim()

fn _is_bare_primitive_type(ty: text) -> bool:
    for primitive in primitive_api_types():
        if ty == primitive:
            return true
    false

fn _is_audited_primitive_type(ty: text) -> bool:
    for primitive in primitive_api_audit_types():
        if ty == primitive:
            return true
    false

fn _primitive_reason_code(ty: text) -> text:
    match ty:
        case "bool": "needs_bool_wrapper_or_enum"
        case "text" | "str" | "String": "needs_domain_text_type"
        case _: "needs_newunit"

fn _suggest_wrapper_name(name: text, ty: text) -> text:
    if ty == "bool":
        return "{_title_token(name)}Flag"
    if ty == "text" or ty == "str" or ty == "String":
        return "{_title_token(name)}Text"
    "{_title_token(name)}Value"

fn _extract_public_function_name(line: text) -> text:
    var rest = line
    if rest.starts_with("pub static fn "):
        rest = rest.slice(14)
    elif rest.starts_with("pub fn "):
        rest = rest.slice(7)
    elif rest.starts_with("pub me "):
        rest = rest.slice(7)
    val paren_pos = rest.find("(")
    if paren_pos < 0:
        return rest.trim()
    rest.slice(0, paren_pos).trim()

fn _title_token(name: text) -> text:
    val cleaned = name.replace("'", "").replace("_", " ").trim()
    if cleaned == "":
        return "Semantic"
    val parts = cleaned.split(" ")
    var result = ""
    for part in parts:
        if part == "":
            continue
        val first = part.slice(0, 1).upper()
        val rest = if part.len() > 1: part.slice(1) else: ""
        result = result + first + rest
    result

# ============================================================================
# L:raw_unit_postfix — auto-fix for AC-4 raw-primitive → unit-typed parameter.
#
# Text-level heuristic rewrite: for call sites whose callee is a known
# unit-taking function and the arg is an integer/float literal without a
# suffix, suggest `<N>_<unit>` or `<N.M>_<unit>`. Confidence is Uncertain —
# the real call-site resolution happens in the AST lint; this rule surfaces
# the rewrite for `simple fix` tooling.
#
# Input to the rule: a line that matches `<callee>(<lit>, ...)` where
# `<callee>` appears in KNOWN_UNIT_CALLEES → unit pairs. The allowlist is
# populated from the unit registry at compile time when available; this file
# carries a minimal bootstrap set (length + time + mass SI bases) that covers
# stdlib bootstrap calls. AST-driven suggestions (see primitive_api.spl
# `check_call_site`) supply the full set at runtime.
# ============================================================================

fn _raw_unit_bootstrap_pairs() -> [[text]]:
    # Each inner = [callee_prefix, unit_short_symbol].
    # Prefix match keeps this deliberately narrow — tune once the registry-
    # backed path is wired through.
    [["travel_km", "km"],
     ["sleep_ms", "ms"],
     ["sleep_s", "s"],
     ["weigh_kg", "kg"]]

fn _is_suffixed_literal(lit: text) -> bool:
    """Treat `10_km`, `1.5_kg`, etc. as already-typed — do NOT rewrite them."""
    val trimmed = lit.trim()
    if trimmed.len() == 0:
        return false
    val underscore = trimmed.find("_")
    if underscore < 0:
        return false
    # Everything before underscore must be digits (with optional '.', '-').
    var i: i64 = 0
    var saw_digit = false
    while i < underscore:
        val c = trimmed[i:i+1]
        val is_digit = c >= "0" and c <= "9"
        val is_dot = c == "."
        val is_sign = c == "-" and i == 0
        if is_digit:
            saw_digit = true
        else:
            if not (is_dot or is_sign):
                return false
        i = i + 1
    saw_digit

fn _is_bare_numeric_literal(lit: text) -> bool:
    """Match `10`, `-3`, `1.5`, `1_000` (digit separators stripped)."""
    val trimmed = lit.trim()
    if trimmed.len() == 0:
        return false
    var i: i64 = 0
    var saw_digit = false
    var dot_seen = false
    while i < trimmed.len():
        val c = trimmed[i:i+1]
        val is_digit = c >= "0" and c <= "9"
        val is_sep = c == "_"
        val is_sign = c == "-" and i == 0
        val is_dot = c == "."
        if is_digit:
            saw_digit = true
        elif is_dot:
            if dot_seen:
                return false
            dot_seen = true
        elif not (is_sep or is_sign):
            return false
        i = i + 1
    saw_digit

fn _apply_unit_postfix(literal: text, unit_short: text) -> text:
    """Rewrite `10` → `10_km`. Leaves suffixed literals unchanged."""
    if _is_suffixed_literal(literal):
        return literal
    if not _is_bare_numeric_literal(literal):
        return literal
    literal.trim() + "_" + unit_short

fn check_raw_unit_postfix(source: text, file: text) -> [EasyFix]:
    """Scan text for call sites of known unit-taking functions with a leading
    bare literal. Emits an Uncertain EasyFix proposing `<N>_<unit>` rewrite.

    This is a bootstrap-only heuristic; AST-driven detection lives in
    `src/compiler/35.semantics/lint/primitive_api.spl::check_call_site`."""
    var fixes: [EasyFix] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    val pairs = _raw_unit_bootstrap_pairs()

    for line in lines:
        line_num = line_num + 1
        for pair in pairs:
            val callee = pair[0]
            val unit_short = pair[1]
            val marker = callee + "("
            val idx = line.find(marker)
            if idx < 0:
                continue
            val after = line.slice(idx + marker.len())
            val comma = after.find(",")
            val rparen = after.find(")")
            var cut = rparen
            if comma >= 0 and (rparen < 0 or comma < rparen):
                cut = comma
            if cut < 0:
                continue
            val first_arg = after.slice(0, cut).trim()
            if not _is_bare_numeric_literal(first_arg):
                continue
            if _is_suffixed_literal(first_arg):
                continue
            val rewritten = _apply_unit_postfix(first_arg, unit_short)
            val new_line = line.replace(callee + "(" + first_arg, callee + "(" + rewritten)
            var fix = EasyFix.create(
                id: "L:raw_unit_postfix:{line_num}",
                description: "raw primitive passed to unit-typed parameter of '{callee}'; use '{rewritten}' postfix",
                confidence: FixConfidence.Uncertain
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: byte_offset,
                end: byte_offset + line.len(),
                line: line_num,
                column: 1,
                new_text: new_line
            ))
            fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes
