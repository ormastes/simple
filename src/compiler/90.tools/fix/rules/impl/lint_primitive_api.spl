# EasyFix Rules - Bare Primitive Public API Detection (Text-Scanning)
#
# Text-based detection for bare primitive types in public function signatures:
#   L:primitive_api — Public API uses bare integer/float primitive types
#
# This intentionally does not cover `bool` because that has its own `bare_bool`
# lint, and it does not try to prove full AST-level correctness.

use std.tooling.easy_fix.*

val PRIMITIVE_API_TYPES = [
    "i64", "i32", "i16", "i8",
    "u64", "u32", "u16", "u8",
    "f64", "f32"
]

fn check_primitive_api(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()

        if trimmed.starts_with("pub fn ") or trimmed.starts_with("pub me ") or trimmed.starts_with("pub static fn "):
            val params = _extract_params(trimmed)
            for param in params:
                val param_type = _extract_param_type(param)
                if _is_bare_primitive_type(param_type):
                    val param_name = _extract_param_name(param)
                    var fix = EasyFix.create(
                        id: "L:primitive_api:{line_num}",
                        description: "public API parameter '{param_name}' uses bare primitive type '{param_type}'",
                        confidence: FixConfidence.Uncertain
                    )
                    fix.add_replacement(Replacement.create(
                        file: file,
                        start: byte_offset,
                        end: byte_offset + line.len(),
                        line: line_num,
                        column: 1,
                        new_text: line
                    ))
                    fixes.push(fix)

            val return_type = _extract_return_type(trimmed)
            if _is_bare_primitive_type(return_type):
                var fix = EasyFix.create(
                    id: "L:primitive_api:{line_num}",
                    description: "public API return type uses bare primitive type '{return_type}'",
                    confidence: FixConfidence.Uncertain
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: byte_offset,
                    end: byte_offset + line.len(),
                    line: line_num,
                    column: 1,
                    new_text: line
                ))
                fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

fn _extract_params(line: text) -> [text]:
    val paren_start = line.find("(")
    val paren_end = line.find(")")
    if paren_start < 0 or paren_end <= paren_start:
        return []
    val params_str = line.slice(paren_start + 1, paren_end).trim()
    if params_str == "":
        return []
    params_str.split(",")

fn _extract_param_type(param: text) -> text:
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return ""
    param.slice(colon_pos + 1).trim()

fn _extract_param_name(param: text) -> text:
    val colon_pos = param.find(":")
    if colon_pos < 0:
        return param.trim()
    param.slice(0, colon_pos).trim()

fn _extract_return_type(line: text) -> text:
    val arrow_pos = line.find("->")
    if arrow_pos < 0:
        return ""
    val after_arrow = line.slice(arrow_pos + 2).trim()
    val colon_pos = after_arrow.find(":")
    if colon_pos < 0:
        return after_arrow.trim()
    after_arrow.slice(0, colon_pos).trim()

fn _is_bare_primitive_type(ty: text) -> bool:
    for primitive in PRIMITIVE_API_TYPES:
        if ty == primitive:
            return true
    false
