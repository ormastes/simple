# EasyFix Rules - Annotation Lint Rules (Text-Scanning)
#
# Text-based detection for unknown decorators and attributes:
#   L:unknown_decorator  — Decorator name not in known whitelist
#   L:unknown_attribute  — Attribute name not in known whitelist

use std.tooling.easy_fix.*
use super.super.helpers.*

# Known decorator names (lines starting with @name)
val KNOWN_DECORATORS = [
    "async", "pure", "io", "net", "fs", "unsafe", "verify", "trusted",
    "ghost", "auto_lean", "bounds", "extern", "simd", "inline", "test",
    "property_test", "snapshot_test", "deprecated", "generated_by",
    "Lib", "inject", "sys_inject", "naked", "noreturn", "interrupt",
    "entry", "align", "gpu_intrinsic"
]

# Known attribute names (lines starting with #[name)
val KNOWN_ATTRIBUTES = [
    "allow", "warn", "deny", "default", "concurrency_mode", "layout",
    "pure", "snapshot", "deprecated", "bypass", "skip_todo", "generated",
    "inline", "ignore"
]

# ============================================================================
# Rule: unknown_decorator
# Detects @name lines where name is not in the known whitelist.
# Confidence: Likely
# ============================================================================

fn check_unknown_decorator(source: text, file: text) -> [EasyFix]:
    for_each_line(source, \ctx:
        var line_fixes: [EasyFix] = []

        if ctx.trimmed.starts_with("@"):
            # Extract the decorator name (first word after @)
            val after_at = ctx.trimmed.slice(1)
            if after_at.len() > 0:
                # Get the name part (up to first paren, space, or end)
                var name = after_at
                val paren_pos = after_at.find("(")
                val space_pos = after_at.find(" ")
                if paren_pos >= 0 and (space_pos < 0 or paren_pos < space_pos):
                    name = after_at.slice(0, paren_pos)
                else if space_pos >= 0:
                    name = after_at.slice(0, space_pos)

                # Skip empty names or comment lines like @# or @@
                if name.len() > 0 and not name.starts_with("#") and not name.starts_with("@"):
                    if not _is_known_decorator(name):
                        var fix = EasyFix.create(
                            id: "L:unknown_decorator:{ctx.line_num}",
                            description: "unknown decorator '@{name}' — not in known whitelist",
                            confidence: FixConfidence.Likely
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: ctx.byte_offset + ctx.indent,
                            end: ctx.byte_offset + ctx.line.len(),
                            line: ctx.line_num,
                            column: ctx.indent + 1,
                            new_text: ctx.line
                        ))
                        line_fixes.push(fix)

        line_fixes
    )

fn _is_known_decorator(name: text) -> bool:
    for known in KNOWN_DECORATORS:
        if name == known:
            return true
    false

# ============================================================================
# Rule: unknown_attribute
# Detects #[name ...] lines where name is not in the known whitelist.
# Skips #[allow ...], #[warn ...], #[deny ...] (already known).
# Skips inner attributes #![...].
# Confidence: Likely
# ============================================================================

fn check_unknown_attribute(source: text, file: text) -> [EasyFix]:
    for_each_line(source, \ctx:
        var line_fixes: [EasyFix] = []

        # Match #[name but not #![name (inner attribute)
        if ctx.trimmed.starts_with("#[") and not ctx.trimmed.starts_with("#!["):
            val after_bracket = ctx.trimmed.slice(2)
            if after_bracket.len() > 0:
                # Extract the attribute name (up to first paren, bracket, space, or end)
                var name = after_bracket
                val paren_pos = after_bracket.find("(")
                val bracket_pos = after_bracket.find("]")
                val space_pos = after_bracket.find(" ")

                # Find the earliest delimiter
                var end_pos = name.len()
                if paren_pos >= 0 and paren_pos < end_pos:
                    end_pos = paren_pos
                if bracket_pos >= 0 and bracket_pos < end_pos:
                    end_pos = bracket_pos
                if space_pos >= 0 and space_pos < end_pos:
                    end_pos = space_pos

                name = after_bracket.slice(0, end_pos)

                if name.len() > 0:
                    if not _is_known_attribute(name):
                        var fix = EasyFix.create(
                            id: "L:unknown_attribute:{ctx.line_num}",
                            description: "unknown attribute '#[{name}]' — not in known whitelist",
                            confidence: FixConfidence.Likely
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: ctx.byte_offset + ctx.indent,
                            end: ctx.byte_offset + ctx.line.len(),
                            line: ctx.line_num,
                            column: ctx.indent + 1,
                            new_text: ctx.line
                        ))
                        line_fixes.push(fix)

        line_fixes
    )

fn _is_known_attribute(name: text) -> bool:
    for known in KNOWN_ATTRIBUTES:
        if name == known:
            return true
    false
