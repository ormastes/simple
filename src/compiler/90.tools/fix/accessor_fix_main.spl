#!/usr/bin/env simple
# Dummy-Accessor Auto-Fix — CLI entry
#
# Finds dummy get_*/set_*/is_* accessors (the ACC001 / dummy_accessor lint) and
# rewrites call sites to direct field access, deleting the wrapper definitions
# where it is provably safe (see accessor_fix_core.spl for the safety tiers):
#
#     obj.get_x()   -> obj.x        # getter / predicate -> varname access
#     obj.set_x(v)  -> obj.x = v    # setter             -> assignment
#
# The accessor index is built GLOBALLY across every caller-bearing root: a name
# is only deleted/cross-file-rewritten when no class anywhere implements a real
# method of that name (so the rewrite cannot miscompile a same-named accessor).
# Files are streamed one at a time so the whole tree never sits in memory.
#
# Usage (interpreter mode required — the global index relies on Dict ops the JIT
# miscompiles):
#   SIMPLE_EXECUTION_MODE=interpret \
#     bin/simple run src/compiler/90.tools/fix/accessor_fix_main.spl [options]
#
# Options:
#   --apply         Write changes to disk (default is dry-run)
#   --root <dir>    Replace the scan roots (repeatable). WARNING: narrowing the
#                   roots narrows the global index and can hide external callers;
#                   only do this when the subtree is self-contained.
#   --no-tier2      Skip same-file self/me rewrites of ambiguous accessors
#   --quiet         Only print the summary line

use compiler.tools.fix.accessor_fix_core.*
use compiler.tools.fix.accessor_fix_rewrite.*
use std.nogc_sync_mut.io.file_ops.{file_read, file_write}
use std.nogc_sync_mut.io.dir_ops.{dir_walk}
use std.sffi.cli.{cli_get_args}

fn acc_should_scan(path: text) -> bool:
    if not path.ends_with(".spl"):
        return false
    if path.contains("/vendor/"):
        return false
    if path.contains("/target/"):
        return false
    if path.starts_with("build/") or path.contains("/build/"):
        return false
    if path.contains("/.git/") or path.contains("/.jj/"):
        return false
    true

# Pass-1 precheck: only files that *define* an accessor add index entries.
fn acc_defines_accessor(source: text) -> bool:
    (source.contains("fn get_") or source.contains("fn set_") or source.contains("fn is_")
     or source.contains("me get_") or source.contains("me set_") or source.contains("me is_"))

# Pass-2 precheck: a file needs rewriting only if it defines or calls an accessor.
fn acc_file_relevant(source: text) -> bool:
    acc_defines_accessor(source) or source.contains(".get_") or source.contains(".set_") or source.contains(".is_")

fn main():
    val args = cli_get_args()
    var apply = false
    var include_tier2 = true
    var quiet = false
    var roots: [text] = []
    var i = 0
    while i < args.len():
        val a = args[i]
        if a == "--apply":
            apply = true
        elif a == "--no-tier2":
            include_tier2 = false
        elif a == "--quiet":
            quiet = true
        elif a == "--root" and i + 1 < args.len():
            i = i + 1
            roots.push(args[i])
        i = i + 1
    if roots.len() == 0:
        roots = ["src", "test", "examples", "doc", "scripts", "tools", "bin"]

    # Collect the file list once.
    var files: [text] = []
    for root in roots:
        for path in dir_walk(root):
            if acc_should_scan(path):
                files.push(path)

    # ---- Pass 1: build the global accessor index (names only, source discarded)
    var field_of: Dict<text, text> = {}
    var kind_of: Dict<text, text> = {}
    var dummy_names: Dict<text, bool> = {}
    var poison: Dict<text, bool> = {}
    var setter_unsafe: Dict<text, bool> = {}
    for path in files:
        val content = file_read(path)
        if content == "":
            continue
        if acc_defines_accessor(content):
            val classes = parse_accessor_classes(content)
            for c in classes:
                for m in c.methods:
                    if m.kind == "":
                        continue
                    if m.is_dummy and not acc_suffix_has_real(c, m.field):
                        dummy_names[m.name] = true
                        field_of[m.name] = m.field
                        kind_of[m.name] = m.kind
                    else:
                        poison[m.name] = true
        # caller-side scan: setter calls used as expressions can't be rewritten,
        # so their wrappers must not be deleted.
        for name in acc_unsafe_setter_names(content):
            setter_unsafe[name] = true

    var unambiguous: Dict<text, bool> = {}
    var deletable: Dict<text, bool> = {}
    for name in dummy_names.keys():
        if poison.has(name):
            continue
        unambiguous[name] = true
        if kind_of[name] == "set" and setter_unsafe.has(name):
            continue
        deletable[name] = true

    if not quiet:
        print "[accessor-fix] indexed {files.len()} files: {dummy_names.len()} dummy name(s), {unambiguous.len()} unambiguous, {deletable.len()} deletable"

    # ---- Pass 2: rewrite file by file
    var files_changed = 0
    var defs_removed = 0
    var calls_rewritten = 0
    var tier2_calls = 0
    var written = 0
    for path in files:
        val content = file_read(path)
        if content == "" or not acc_file_relevant(content):
            continue
        val fr = acc_process_file(content, field_of, kind_of, unambiguous, deletable, include_tier2)
        if not fr.changed:
            continue
        files_changed = files_changed + 1
        defs_removed = defs_removed + fr.removed
        calls_rewritten = calls_rewritten + fr.rewritten
        tier2_calls = tier2_calls + fr.tier2
        if apply:
            val ok = file_write(path, fr.source)
            if ok:
                written = written + 1
            else:
                print "[accessor-fix] ERROR: failed to write {path}"
        if not quiet:
            print "  {path}  (-{fr.removed} def, ~{fr.rewritten} call, ~{fr.tier2} self)"

    val mode = if apply: "applied" else: "dry-run"
    print "[accessor-fix] {mode}: {files_changed} file(s), {defs_removed} wrapper(s) removed, {calls_rewritten} cross-file call(s) rewritten, {tier2_calls} same-file call(s) simplified"
    if not apply:
        print "[accessor-fix] re-run with --apply to write changes"
