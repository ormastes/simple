# Dummy-Accessor Auto-Fix — Rewrite Engine
#
# Consumes the index from accessor_fix_core and produces rewritten sources.
# See accessor_fix_core.spl for the safety-tier rationale.

use compiler.tools.fix.accessor_fix_core.*

struct AccFixStats:
    files_changed: i64
    defs_removed: i64
    calls_rewritten: i64    # tier-1 (cross-file, any receiver)
    tier2_calls: i64        # tier-2 (same-file self/me only)

struct AccFileResult:
    source: text
    removed: i64
    rewritten: i64
    tier2: i64
    changed: bool

struct AccTier2:
    name: text
    field: text
    kind: text
    class_start: i64
    class_end: i64

# ============================================================================
# Identifier-boundary helpers
# ============================================================================

val ACC_IDENT_CHARS = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"

fn acc_is_ident_char(c: text) -> bool:
    ACC_IDENT_CHARS.contains(c)

fn acc_boundary_before(line: text, idx: i64) -> bool:
    if idx == 0:
        return true
    not acc_is_ident_char(line[idx - 1:idx])

fn acc_receiver_is_self_or_me(line: text, dot: i64) -> bool:
    if dot >= 4 and line.slice(dot - 4, dot) == "self":
        return acc_boundary_before(line, dot - 4)
    if dot >= 2 and line.slice(dot - 2, dot) == "me":
        return acc_boundary_before(line, dot - 2)
    false

fn acc_is_receiver_char(c: text) -> bool:
    acc_is_ident_char(c) or c == "." or c == "[" or c == "]" or c == "(" or c == ")"

# True if s contains a comma outside of any bracket/quote nesting — i.e. the
# argument list has more than one argument. A dummy setter takes exactly one
# value, so a multi-arg call targets a different method and must be left alone.
fn acc_has_top_level_comma(s: text) -> bool:
    var depth = 0
    var in_str = false
    var i = 0
    while i < s.len():
        val c = s[i:i + 1]
        if in_str:
            if c == "\"":
                in_str = false
        elif c == "\"":
            in_str = true
        elif c == "(" or c == "[" or c == "{":
            depth = depth + 1
        elif c == ")" or c == "]" or c == "}":
            depth = depth - 1
        elif c == "," and depth == 0:
            return true
        i = i + 1
    false

# A setter call `recv.set_x(EXPR)` is only safe to turn into `recv.x = EXPR`
# when it is a standalone statement. In expression position (e.g. the RHS of an
# assignment, `node = node.set_x(v)`, or a nested argument) the assignment form
# is invalid, so such calls must be left untouched.
fn acc_is_statement_setter(line: text, dot: i64, close: i64) -> bool:
    val after = line.slice(close + 1)
    val after_t = after.trim()
    if after_t != "" and not after_t.starts_with("#"):
        return false
    var rs = dot
    while rs > 0 and acc_is_receiver_char(line[rs - 1:rs]):
        rs = rs - 1
    val leading = line.slice(0, rs)
    leading.trim() == ""

# Collect setter names whose calls appear in expression position anywhere in the
# source — their wrapper defs must NOT be deleted (the call cannot be rewritten).
fn acc_unsafe_setter_names(source: text) -> [text]:
    var unsafe: [text] = []
    if not source.contains(".set_"):
        return unsafe
    for line in source.split("\n"):
        var i = 0
        while i < line.len():
            val tail = line.slice(i)
            val rel = tail.find(".set_")
            if rel < 0:
                break
            val dot = i + rel
            val dtail = line.slice(dot)
            val open = dtail.find("(")
            if open < 0:
                break
            val open_abs = dot + open
            val name = line.slice(dot + 1, open_abs)
            # find matching close paren
            var depth = 0
            var p = open_abs
            var close = -1
            while p < line.len():
                val ch = line[p:p + 1]
                if ch == "(":
                    depth = depth + 1
                elif ch == ")":
                    depth = depth - 1
                    if depth == 0:
                        close = p
                        break
                p = p + 1
            if close < 0:
                # multi-line / unbalanced call — treat as unsafe
                if not unsafe.contains(name):
                    unsafe.push(name)
                break
            if not acc_is_statement_setter(line, dot, close):
                if not unsafe.contains(name):
                    unsafe.push(name)
            i = close + 1
    unsafe

# ============================================================================
# Line-level rewriting
# ============================================================================

# Replace every ".name()" (getter/predicate, zero args) with ".field".
# When restrict_self, only "self."/"me." receivers are rewritten.
fn rewrite_get_in_line(line: text, name: text, field: text, restrict_self: bool) -> (text, i64):
    if restrict_self:
        var (l1, c1) = acc_replace_all(line, "self.{name}()", "self.{field}")
        var (l2, c2) = acc_replace_all(l1, "me.{name}()", "me.{field}")
        return (l2, c1 + c2)
    acc_replace_all(line, ".{name}()", ".{field}")

# Replace ".name(EXPR)" (setter, one arg) with ".field = EXPR" using a balanced
# paren scan so nested calls in EXPR are preserved. Multi-line calls (no closing
# paren on the line) are left untouched.
fn rewrite_set_in_line(line: text, name: text, field: text, restrict_self: bool) -> (text, i64):
    val call = ".{name}("
    var result = ""
    var i = 0
    var count = 0
    while i < line.len():
        val tail = line.slice(i)
        val rel = tail.find(call)
        if rel < 0:
            result = result + tail
            break
        val dot = i + rel
        val open = dot + call.len() - 1
        if restrict_self and not acc_receiver_is_self_or_me(line, dot):
            result = result + line.slice(i, open + 1)
            i = open + 1
            continue
        var depth = 0
        var p = open
        var close = -1
        while p < line.len():
            val ch = line[p:p + 1]
            if ch == "(":
                depth = depth + 1
            elif ch == ")":
                depth = depth - 1
                if depth == 0:
                    close = p
                    break
            p = p + 1
        if close < 0:
            result = result + line.slice(i, open + 1)
            i = open + 1
            continue
        if not acc_is_statement_setter(line, dot, close):
            # expression-context setter call — leave it untouched
            result = result + line.slice(i, open + 1)
            i = open + 1
            continue
        val expr = line.slice(open + 1, close).trim()
        if acc_has_top_level_comma(expr):
            # multi-arg call — not this single-value dummy setter
            result = result + line.slice(i, open + 1)
            i = open + 1
            continue
        result = result + line.slice(i, dot) + ".{field} = {expr}"
        i = close + 1
        count = count + 1
    (result, count)

fn acc_replace_all(hay: text, needle: text, repl: text) -> (text, i64):
    if needle == "":
        return (hay, 0)
    var result = ""
    var i = 0
    var count = 0
    while i < hay.len():
        val tail = hay.slice(i)
        val rel = tail.find(needle)
        if rel < 0:
            result = result + tail
            break
        result = result + hay.slice(i, i + rel) + repl
        i = i + rel + needle.len()
        count = count + 1
    (result, count)

# ============================================================================
# Whole-file processing
# ============================================================================

fn acc_process_file(
    source: text,
    field_of: Dict<text, text>,
    kind_of: Dict<text, text>,
    unambiguous: Dict<text, bool>,
    deletable: Dict<text, bool>,
    include_tier2: bool
) -> AccFileResult:
    val classes = parse_accessor_classes(source)
    val lines = source.split("\n")

    # mark wrapper definition lines for deletion (tier-1 only)
    var delete_line: [bool] = []
    var di = 0
    while di < lines.len():
        delete_line.push(false)
        di = di + 1

    var removed = 0
    for c in classes:
        var cand: [AccMethod] = []
        for m in c.methods:
            if m.is_dummy and m.kind != "" and deletable.has(m.name) and not acc_suffix_has_real(c, m.field):
                cand.push(m)
        if cand.len() == 0:
            continue
        val surviving = c.methods.len() - cand.len()
        if c.field_count == 0 and surviving == 0:
            continue   # deleting all members would leave an empty class body
        for m in cand:
            var t = m.def_start
            while t < m.def_end:
                if t >= 0 and t < delete_line.len():
                    delete_line[t] = true
                t = t + 1
            removed = removed + 1

    # tier-2 ambiguous targets (kept defs, self/me rewrite within class range)
    var amb: [AccTier2] = []
    for c in classes:
        for m in c.methods:
            if m.is_dummy and m.kind != "" and (not unambiguous.has(m.name)) and not acc_suffix_has_real(c, m.field):
                amb.push(AccTier2(name: m.name, field: m.field, kind: m.kind, class_start: c.start_line, class_end: c.end_line))

    var unamb_names: [text] = []
    for n in unambiguous.keys():
        unamb_names.push(n)

    var out_lines: [text] = []
    var rew = 0
    var t2 = 0
    var idx = 0
    while idx < lines.len():
        if delete_line[idx]:
            idx = idx + 1
            continue
        var line = lines[idx]
        if line.contains("("):
            # tier-1: any receiver, only names that appear on the line
            for name in unamb_names:
                if line.contains(name):
                    val kind = kind_of[name]
                    val field = field_of[name]
                    if kind == "set":
                        var (nl, n) = rewrite_set_in_line(line, name, field, false)
                        line = nl
                        rew = rew + n
                    else:
                        var (nl2, n2) = rewrite_get_in_line(line, name, field, false)
                        line = nl2
                        rew = rew + n2
            # tier-2: self/me only, within the defining class
            if include_tier2:
                for a in amb:
                    if idx >= a.class_start and idx < a.class_end and line.contains(a.name):
                        if a.kind == "set":
                            var (sl, sn) = rewrite_set_in_line(line, a.name, a.field, true)
                            line = sl
                            t2 = t2 + sn
                        else:
                            var (sl2, sn2) = rewrite_get_in_line(line, a.name, a.field, true)
                            line = sl2
                            t2 = t2 + sn2
        out_lines.push(line)
        idx = idx + 1

    val newsrc = out_lines.join("\n")
    val changed = removed > 0 or rew > 0 or t2 > 0
    AccFileResult(source: newsrc, removed: removed, rewritten: rew, tier2: t2, changed: changed)

# ============================================================================
# Top-level: apply fixes across a {file: source} map
# ============================================================================

fn apply_accessor_fixes(sources: Dict<text, text>, include_tier2: bool) -> (Dict<text, text>, AccFixStats):
    val records = collect_dummy_records(sources)
    val poison = collect_poisoned_names(sources)

    # Count every accessor-named method header (class / impl / struct / standalone)
    # so a real method hidden in an impl block blocks the rewrite.
    var total_headers: Dict<text, i64> = {}
    for file in sources.keys():
        for line in sources[file].split("\n"):
            val hn = acc_header_accessor_name(line.trim())
            if hn != "":
                val prev = if total_headers.has(hn): total_headers[hn] else: 0
                total_headers[hn] = prev + 1

    var field_of: Dict<text, text> = {}
    var kind_of: Dict<text, text> = {}
    var dummy_count: Dict<text, i64> = {}
    for r in records:
        field_of[r.name] = r.field
        kind_of[r.name] = r.kind
        val prev = if dummy_count.has(r.name): dummy_count[r.name] else: 0
        dummy_count[r.name] = prev + 1

    var unambiguous: Dict<text, bool> = {}
    for r in records:
        if poison.has(r.name):
            continue
        val total = if total_headers.has(r.name): total_headers[r.name] else: 0
        if total == dummy_count[r.name]:
            unambiguous[r.name] = true

    # Setter names with an expression-context call anywhere are kept (not deleted).
    var setter_unsafe: Dict<text, bool> = {}
    for file in sources.keys():
        for name in acc_unsafe_setter_names(sources[file]):
            setter_unsafe[name] = true

    var deletable: Dict<text, bool> = {}
    for name in unambiguous.keys():
        if kind_of[name] == "set" and setter_unsafe.has(name):
            continue
        deletable[name] = true

    var result: Dict<text, text> = {}
    var stats = AccFixStats(files_changed: 0, defs_removed: 0, calls_rewritten: 0, tier2_calls: 0)
    for file in sources.keys():
        val fr = acc_process_file(sources[file], field_of, kind_of, unambiguous, deletable, include_tier2)
        result[file] = fr.source
        if fr.changed:
            stats.files_changed = stats.files_changed + 1
            stats.defs_removed = stats.defs_removed + fr.removed
            stats.calls_rewritten = stats.calls_rewritten + fr.rewritten
            stats.tier2_calls = stats.tier2_calls + fr.tier2
    (result, stats)
