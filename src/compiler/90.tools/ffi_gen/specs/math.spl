# Math Module - Intern FFI Spec
#
# Declares all math extern functions for auto-generation of
# interpreter_extern/math.rs boilerplate.
#
# Integer math functions use inline_expr (native Rust operations on Value types).
# Float math functions delegate to runtime FFI (simple_runtime::value::ffi::math).
#
# Usage: simple ffi-gen --gen-intern src/compiler/90.tools/ffi_gen/specs/math.spl

use compiler.tools.ffi_gen.intern_codegen (InternFnSpec, InternParamSpec)

# ============================================================================
# Math Function Specifications
# ============================================================================

fn math_specs() -> [InternFnSpec]:
    var specs: [InternFnSpec] = []

    # --- Integer math (built-in names, inline Rust expressions) ---

    specs.push(InternFnSpec(
        name: "abs", category: "math",
        params: [InternParamSpec(name: "n", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Absolute value of an integer",
        inline_expr: "n.abs()"
    ))

    specs.push(InternFnSpec(
        name: "min", category: "math",
        params: [InternParamSpec(name: "a", value_type: "i64"), InternParamSpec(name: "b", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Minimum of two integers",
        inline_expr: "a.min(b)"
    ))

    specs.push(InternFnSpec(
        name: "max", category: "math",
        params: [InternParamSpec(name: "a", value_type: "i64"), InternParamSpec(name: "b", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Maximum of two integers",
        inline_expr: "a.max(b)"
    ))

    specs.push(InternFnSpec(
        name: "pow", category: "math",
        params: [InternParamSpec(name: "base", value_type: "i64"), InternParamSpec(name: "exp", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Power function (base^exponent) for integers",
        inline_expr: "base.pow(exp as u32)"
    ))

    specs.push(InternFnSpec(
        name: "sqrt", category: "math",
        params: [InternParamSpec(name: "n", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Integer square root",
        inline_expr: "(n as f64).sqrt() as i64"
    ))

    specs.push(InternFnSpec(
        name: "floor", category: "math",
        params: [InternParamSpec(name: "n", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Floor (identity for integers)",
        inline_expr: "n"
    ))

    specs.push(InternFnSpec(
        name: "ceil", category: "math",
        params: [InternParamSpec(name: "n", value_type: "i64")],
        return_type: "i64", runtime_fn: "",
        doc: "Ceiling (identity for integers)",
        inline_expr: "n"
    ))

    # --- Float math (rt_math_* prefix, delegate to runtime FFI) ---

    # 1-arg f64 -> f64 functions (unrolled for text-parser compatibility)
    specs.push(InternFnSpec(
        name: "rt_math_log", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_log",
        doc: "Natural logarithm",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_log10", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_log10",
        doc: "Base-10 logarithm",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_log2", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_log2",
        doc: "Base-2 logarithm",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_exp", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_exp",
        doc: "Exponential function",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_sqrt", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_sqrt",
        doc: "Square root for floats",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_cbrt", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_cbrt",
        doc: "Cube root for floats",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_sin", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_sin",
        doc: "Sine (radians)",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_cos", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_cos",
        doc: "Cosine (radians)",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_tan", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_tan",
        doc: "Tangent (radians)",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_asin", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_asin",
        doc: "Arc sine",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_acos", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_acos",
        doc: "Arc cosine",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_atan", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_atan",
        doc: "Arc tangent",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_sinh", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_sinh",
        doc: "Hyperbolic sine",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_cosh", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_cosh",
        doc: "Hyperbolic cosine",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_tanh", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_tanh",
        doc: "Hyperbolic tangent",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_floor", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_floor",
        doc: "Floor for floats",
        inline_expr: ""
    ))
    specs.push(InternFnSpec(
        name: "rt_math_ceil", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_ceil",
        doc: "Ceiling for floats",
        inline_expr: ""
    ))

    # 2-arg f64 -> f64 functions
    specs.push(InternFnSpec(
        name: "rt_math_pow", category: "math",
        params: [InternParamSpec(name: "base", value_type: "f64"), InternParamSpec(name: "exp", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_pow",
        doc: "Power function for floats",
        inline_expr: ""
    ))

    specs.push(InternFnSpec(
        name: "rt_math_atan2", category: "math",
        params: [InternParamSpec(name: "y", value_type: "f64"), InternParamSpec(name: "x", value_type: "f64")],
        return_type: "f64", runtime_fn: "rt_math_atan2",
        doc: "Two-argument arc tangent",
        inline_expr: ""
    ))

    # 0-arg special value functions
    specs.push(InternFnSpec(
        name: "rt_math_nan", category: "math",
        params: [],
        return_type: "f64", runtime_fn: "rt_math_nan",
        doc: "Returns IEEE 754 NaN",
        inline_expr: ""
    ))

    specs.push(InternFnSpec(
        name: "rt_math_inf", category: "math",
        params: [],
        return_type: "f64", runtime_fn: "rt_math_inf",
        doc: "Returns IEEE 754 positive infinity",
        inline_expr: ""
    ))

    # 1-arg f64 -> bool functions
    specs.push(InternFnSpec(
        name: "rt_math_is_nan", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "bool", runtime_fn: "rt_math_is_nan",
        doc: "Check if value is NaN",
        inline_expr: ""
    ))

    specs.push(InternFnSpec(
        name: "rt_math_is_inf", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "bool", runtime_fn: "rt_math_is_inf",
        doc: "Check if value is infinite",
        inline_expr: ""
    ))

    specs.push(InternFnSpec(
        name: "rt_math_is_finite", category: "math",
        params: [InternParamSpec(name: "x", value_type: "f64")],
        return_type: "bool", runtime_fn: "rt_math_is_finite",
        doc: "Check if value is finite",
        inline_expr: ""
    ))

    specs
