# FFI Generator Module
#
# Generate Simple FFI wrappers from C/C++ headers and Rust source code.
# Supports runtime (C → Simple) and external library (C++ → Rust → Simple) patterns.
#
# Public API:
#   - use compiler.tools.ffi_gen.main.{generate_ffi, ffi_gen_main}
#   - use compiler.tools.ffi_gen.parse_header.{parse_c_header}
#   - use compiler.tools.ffi_gen.parse_rust.{parse_rust_functions}
#   - use compiler.tools.ffi_gen.codegen.{generate_wrapper}
#   - use compiler.tools.ffi_gen.types.{FfiFunction, FfiType, FfiBinding}
#
# Internal Components:
#   - Header parsing and analysis
#   - Type mapping (C/C++/Rust → Simple)
#   - Code generation (SFFI wrappers)
#   - Template system
#   - Naming conventions

# All submodules are automatically available through the module system.
# FFI generation follows the SFFI pattern (Simple FFI) documented in
# doc/07_guide/sffi_patterns.md.

# Re-exported from ffi_gen_workspace.spl
export generate_workspace, generate_workspace_root_toml, generate_single_crate
export generate_crate_cargo_toml, generate_crate_lib_stub, verify_workspace

# Re-exported from main.spl
export CliOptions, RustEnvConfig, log_info, log_step, print_error
