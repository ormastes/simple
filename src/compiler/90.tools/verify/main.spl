# Simple Verification Tool
#
# Lean verification workflow:
# - `simple verify regenerate` writes and validates the generated Lean artifacts
# - `simple verify check` hard-fails on any `sorry`
# - `simple verify status` reports Lean availability and artifact presence
# - `simple verify list` prints the authoritative artifact inventory

import io.args as args
import io.fs as fs
import verification.regenerate as regen
import verification.proofs.checker as checker

fn print_help():
    print("Usage: simple verify [command]")
    print("")
    print("Commands:")
    print("  regenerate    Regenerate Lean artifacts and validate them")
    print("  check         Check the authoritative Lean artifacts (fails on any sorry)")
    print("  status        Show Lean availability and artifact presence")
    print("  list          List the authoritative Lean artifact inventory")
    print("  help          Show this help message")
    print("")
    print("Examples:")
    print("  simple verify status")
    print("  simple verify regenerate")
    print("  simple verify check")

fn artifact_inventory() -> [text]:
    checker.known_verification_files()

fn print_inventory(title: text):
    val files = artifact_inventory()
    var present = 0
    print(title)
    print("===================")
    print("")
    for path in files:
        val exists = fs.exist(path)
        val status = if exists: "OK" else: "MISSING"
        if exists:
            present = present + 1
        print("  [{status}] {path}")
    print("")
    print("Artifacts present: {present}/{files.len()}")

fn print_validation(validation: Dict<text, bool>) -> bool:
    var all_valid = true
    for path in validation.keys():
        val valid = validation[path]
        val status = if valid: "OK" else: "MISMATCH"
        print("  {path}: {status}")
        if not valid:
            all_valid = false
    all_valid

fn cmd_regenerate() -> Int:
    print("Regenerating Lean verification files...")
    print("")

    val files = regen.regenerate_all()
    val pre_validation = regen.validate_regeneration(files, ".")

    print("Current file state:")
    val pre_ok = print_validation(pre_validation)
    if pre_ok:
        print("All tracked files were already up to date.")
    else:
        print("Some tracked files were out of date and will be rewritten.")
    print("")

    print("Writing regenerated files...")
    val written = regen.write_regenerated_files(files, ".")
    print("Wrote {written.len()} files.")
    print("")

    print("Re-validating written files...")
    val post_validation = regen.validate_regeneration(files, ".")
    val post_ok = print_validation(post_validation)

    if post_ok:
        print("")
        print("All files validated successfully.")
        0
    else:
        print("")
        print("WARNING: One or more artifacts did not match the generated output.")
        1

fn cmd_check() -> Int:
    print("Checking Lean verification artifacts...")
    print("")

    val config = checker.CheckerConfig.create()
        .with_project_dir(".")
    val proof_checker = checker.ProofChecker.create(config)
    val result = proof_checker.check_verification_dir()

    print(result.summary())

    if result.failure_count() > 0:
        print("")
        print("Failed checks:")
        for file_result in result.file_results:
            if not file_result.status.is_success():
                print("  {file_result.summary_line()}")
        1
    else:
        0

fn cmd_status() -> Int:
    print("Verification Status")
    print("===================")
    print("")

    val lean_available = checker.is_lean_available()
    if lean_available:
        print("Lean 4: Available")
    else:
        print("Lean 4: Not found (install with: elan install leanprover/lean4:stable)")

    print("")
    print_inventory("Verification Artifacts")
    0

fn cmd_list() -> Int:
    print_inventory("Verification Artifact Inventory")
    0

fn main() -> Int:
    val argv = args.get_args()

    if argv.len() < 2:
        print_help()
        return 0

    val command = argv[1]
    match command:
        case "regenerate":
            cmd_regenerate()
        case "check":
            cmd_check()
        case "status":
            cmd_status()
        case "list":
            cmd_list()
        case "help":
            print_help()
            0
        case "--help":
            print_help()
            0
        case "-h":
            print_help()
            0
        case _:
            print("Unknown command: {command}")
            print("Run 'simple verify help' for usage information.")
            1
