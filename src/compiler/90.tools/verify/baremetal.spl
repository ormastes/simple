# Simple (.spl) replacement for scripts/verify-baremetal-setup.sh
# Verify Bare-Metal Build System Setup
#
# Checks that all infrastructure is in place for bare-metal builds.

use app.io.mod.{shell_bool, shell_output, file_exists, exit}
use compiler.tools.verify.noalloc_reachable.{verify_noalloc_reachable_imports}

val COLOR_GREEN = "\x1b[0;32m"
val COLOR_RED = "\x1b[0;31m"
val COLOR_YELLOW = "\x1b[1;33m"
val COLOR_RESET = "\x1b[0m"

fn check_file(path: text) -> bool:
    if file_exists(path):
        print "{COLOR_GREEN}OK{COLOR_RESET} {path}"
        return true
    else:
        print "{COLOR_RED}FAIL{COLOR_RESET} {path} (missing)"
        return false

fn check_executable(name: text, purpose: text) -> bool:
    if shell_bool("command -v {name}"):
        val version = shell_output("{name} --version 2>&1 | head -1", "").trim()
        print "{COLOR_GREEN}OK{COLOR_RESET} {name} ({version})"
        return true
    else:
        print "{COLOR_YELLOW}WARN{COLOR_RESET} {name} (not installed - required for {purpose})"
        return false

fn check_no_matches(label: text, cmd: text) -> bool:
    val matches = shell_output(cmd + " || true", "").trim()
    if matches.len() == 0:
        print "{COLOR_GREEN}OK{COLOR_RESET} {label}"
        return true

    print "{COLOR_RED}FAIL{COLOR_RESET} {label}"
    print matches
    return false

fn check_noalloc_reachable_imports() -> bool:
    val errors = verify_noalloc_reachable_imports()
    if errors.len() == 0:
        print "{COLOR_GREEN}OK{COLOR_RESET} no unsafe reachable imports from nogc_async_mut_noalloc"
        return true

    print "{COLOR_RED}FAIL{COLOR_RESET} no unsafe reachable imports from nogc_async_mut_noalloc"
    for error in errors:
        print error
    false

fn main():
    print "=== Bare-Metal Build System Verification ==="
    print ""

    var errors = 0

    # Check linker scripts
    print "Linker Scripts:"
    if not check_file("src/compiler/70.backend/baremetal/arm/linker.ld"):
        errors = errors + 1
    if not check_file("src/compiler/70.backend/baremetal/x86_64/linker.ld"):
        errors = errors + 1
    if not check_file("src/compiler/70.backend/baremetal/riscv/linker.ld"):
        errors = errors + 1
    print ""

    # Check startup code
    print "Startup Code (crt0.s):"
    if not check_file("src/compiler/70.backend/baremetal/arm/crt0.s"):
        errors = errors + 1
    if not check_file("src/compiler/70.backend/baremetal/x86_64/crt0.s"):
        errors = errors + 1
    if not check_file("src/compiler/70.backend/baremetal/riscv/crt0.s"):
        errors = errors + 1
    print ""

    # Check build system files
    print "Build System:"
    if not check_file("src/app/build/baremetal.smf"):
        errors = errors + 1
    if not check_file("src/app/build/__init__.smf"):
        errors = errors + 1
    if not check_file("src/app/build/types.smf"):
        errors = errors + 1
    print ""

    # Check tests
    print "Tests:"
    if not check_file("test/integration/baremetal_build_spec.spl"):
        errors = errors + 1
    print ""

    # Check documentation
    print "Documentation:"
    if not check_file("doc/07_guide/backend/baremetal.md"):
        errors = errors + 1
    if not check_file("doc/09_report/2026/02/baremetal_build_system_integration_2026-02-14.md"):
        errors = errors + 1
    print ""

    # Check source constraints required by noalloc bare-metal presets.
    print "Noalloc Source Constraints:"
    if not check_no_matches(
        "no allocating-family imports from nogc_async_mut_noalloc",
        "rg -n '^(use|from|import)( lazy)? std\\.(nogc_sync_mut|nogc_async_mut|nogc_async_immut|gc_async_mut)\\.' src/lib/nogc_async_mut_noalloc -g '*.spl'"
    ):
        errors = errors + 1
    if not check_no_matches(
        "no app imports from nogc_async_mut_noalloc",
        "rg -n '^(use|from|import)( lazy)? app\\.' src/lib/nogc_async_mut_noalloc -g '*.spl'"
    ):
        errors = errors + 1
    if not check_no_matches(
        "no allocation annotations in nogc_async_mut_noalloc",
        "rg -n '^(# *)?@alloc\\b' src/lib/nogc_async_mut_noalloc -g '*.spl'"
    ):
        errors = errors + 1
    if not check_no_matches(
        "no host allocation APIs in nogc_async_mut_noalloc",
        "rg -n '\\b(malloc|calloc|free)\\s*\\(|\\brt_alloc\\b|extern fn .*realloc' src/lib/nogc_async_mut_noalloc -g '*.spl'"
    ):
        errors = errors + 1
    if not check_noalloc_reachable_imports():
        errors = errors + 1
    print ""

    # Check toolchains (optional)
    print "Toolchains (optional - required for actual builds):"
    check_executable("clang", "ARM builds")
    check_executable("ld.lld", "ARM builds")
    check_executable("qemu-system-arm", "ARM testing")
    print ""
    check_executable("as", "x86_64 builds")
    check_executable("ld", "x86_64 builds")
    check_executable("qemu-system-x86_64", "x86_64 testing")
    print ""
    check_executable("clang", "RISC-V builds")
    check_executable("ld.lld", "RISC-V builds")
    check_executable("qemu-system-riscv64", "RISC-V testing")
    print ""

    # Summary
    print "=== Summary ==="
    if errors == 0:
        print "{COLOR_GREEN}All infrastructure files present!{COLOR_RESET}"
        print ""
        print "Next steps:"
        print "  1. Implement compiler backend for bare-metal targets"
        print "  2. Run: simple build baremetal --list-targets"
        print "  3. Build: simple build baremetal --target=x86_64 hello.spl"
        print ""
        exit(0)
    else:
        print "{COLOR_RED}{errors} file(s) missing!{COLOR_RESET}"
        print ""
        print "Please ensure all infrastructure files are in place."
        exit(1)

main()
