        dir_create_all("test/01_unit/app/sffi_gen")
        src_count = src_count + copy_files_to_dir(sffi_files, "test/01_unit/app/sffi_gen")

    if file_exists("src/app/fix/rules/impl/lint_spec.spl"):
        if copy_if_not_exists("src/app/fix/rules/impl/lint_spec.spl", "test/01_unit/app/fix/lint_spec.spl"):
