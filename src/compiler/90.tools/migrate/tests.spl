    for d in dirs:
        dir_create_all(d)

    print "  Created directory structure."

    # Step 2: Move feature specs
    print "Step 2: Moving feature specs..."
    var feat_count = 0

    # Feature subdirs
    val feat_subdirs = glob_files("test/03_system/features/*/")
    for sub_dir in feat_subdirs:
