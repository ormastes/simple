    # Diagnostics
    val diag_files = glob_files("test/diagnostics/*_spec.spl")
    remaining = remaining + copy_files_to_dir(diag_files, "test/01_unit/app/diagnostics")

    # Debug
    dir_create_all("test/01_unit/app/debug")
    val debug_files = glob_files("test/debug/*_spec.spl")
    remaining = remaining + copy_files_to_dir(debug_files, "test/01_unit/app/debug")

