    sysrem_count = sysrem_count + copy_files_to_dir(sys_coll_files, "test/feature")

    val sys_interp_top = glob_files("test/03_system/interpreter/*_spec.spl")
    sysrem_count = sysrem_count + sys_interp_top.len()

