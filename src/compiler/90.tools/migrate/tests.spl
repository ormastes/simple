        "shell:test/01_unit/std",
        "config:test/01_unit/std",
        "console:test/01_unit/std",
        "sffi:test/01_unit/std",
        "fs:test/01_unit/std",
        "host:test/01_unit/std",
        "dap:test/01_unit/app/dap",
        "diagram:test/01_unit/app/diagram",
        "exp:test/01_unit/std/exp",
        "failsafe:test/01_unit/std/failsafe",

