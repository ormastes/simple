    librem_count = librem_count + copy_files_to_dir(spec_lib_files, "test/01_unit/lib/std/spec")

    dir_create_all("test/01_unit/lib/std/type_checker")
    val tc_files = find_files("test/01_unit/lib/std/type_checker -name '*_spec.spl'")
    librem_count = librem_count + copy_files_to_dir(tc_files, "test/01_unit/lib/std/type_checker")

    # Top-level test/lib/*_spec.spl
