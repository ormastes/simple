    remaining = remaining + copy_files_to_dir(bench_files, "test/benchmark")

    # Baremetal
    dir_create_all("test/03_system/baremetal")
    val bare_files = glob_files("test/baremetal/*_spec.spl")
    remaining = remaining + copy_files_to_dir(bare_files, "test/03_system/baremetal")

    # Specs
