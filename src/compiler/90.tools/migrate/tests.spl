    print "  Processed {int_count} integration tests"

    # Step 8: Move system tests
    print "Step 8: Moving system tests..."
    var sys_count = 0

    val sys_comp = glob_files("test/03_system/compiler/*_spec.spl")
    sys_count = sys_count + sys_comp.len()

    val sys_interp = glob_files("test/03_system/interpreter/sample/python_inspired_sample/*_spec.spl")
    sys_count = sys_count + sys_interp.len()

    val sys_dap = glob_files("test/03_system/dap/*_spec.spl")
    sys_count = sys_count + sys_dap.len()

    val sys_watch = glob_files("test/03_system/watcher/*_spec.spl")
    sys_count = sys_count + sys_watch.len()

    val sys_sffi = glob_files("test/03_system/sffi/*_spec.spl") + glob_files("test/03_system/sffi/*_test.spl")
