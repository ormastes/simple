struct MethodFieldAccess:
    method_name: text
    fields_accessed: [text]
    methods_called: [text]

struct LCOMResult:
    lcom4: i64
    method_count: i64
    field_count: i64
    component_sizes: [i64]

fn fields_share_access(a: [text], b: [text]) -> bool:
    for x in a:
        for y in b:
            if x == y:
                return true
    false

fn find_method_index(methods: [MethodFieldAccess], name: text) -> i64:
    for i in range(0, methods.len()):
        if methods[i].method_name == name:
            return i
    -1

fn sort_descending(values: [i64]) -> [i64]:
    var result = values
    for i in range(0, result.len()):
        for j in range(i + 1, result.len()):
            if result[j] > result[i]:
                val tmp = result[i]
                result[i] = result[j]
                result[j] = tmp
    result

fn _count_fields(methods: [MethodFieldAccess]) -> i64:
    var fields: [text] = []
    for method in methods:
        for field in method.fields_accessed:
            if not fields.contains(field):
                fields.push(field)
    fields.len()

fn _connected(methods: [MethodFieldAccess], a: i64, b: i64) -> bool:
    if fields_share_access(methods[a].fields_accessed, methods[b].fields_accessed):
        return true
    methods[a].methods_called.contains(methods[b].method_name) or methods[b].methods_called.contains(methods[a].method_name)

fn compute_lcom4(class_name: text, methods: [MethodFieldAccess]) -> LCOMResult:
    val n = methods.len()
    if n == 0:
        return LCOMResult(lcom4: 0, method_count: 0, field_count: 0, component_sizes: [])
    var seen: [bool] = []
    for _i in range(0, n):
        seen.push(false)
    var components: [i64] = []
    for i in range(0, n):
        if not seen[i]:
            var stack: [i64] = [i]
            seen[i] = true
            var size = 0
            while stack.len() > 0:
                val current = stack[stack.len() - 1]
                stack = stack[0:stack.len() - 1]
                size = size + 1
                for j in range(0, n):
                    if not seen[j] and _connected(methods, current, j):
                        seen[j] = true
                        stack.push(j)
            components.push(size)
    LCOMResult(lcom4: components.len(), method_count: n, field_count: _count_fields(methods), component_sizes: sort_descending(components))
