struct TypeVector:
    types: [text]
    hash: i64

struct ATSSWarning:
    fn1_name: text
    fn2_name: text
    edit_distance: i64

fn type_set_edit_distance(a: [text], b: [text]) -> i64:
    var removed = 0
    for item in a:
        if not b.contains(item):
            removed = removed + 1
    var added = 0
    for item in b:
        if not a.contains(item):
            added = added + 1
    removed + added

fn generate_deletion_variants(types: [text]) -> [[text]]:
    var result: [[text]] = []
    for skip in range(0, types.len()):
        var variant: [text] = []
        for i in range(0, types.len()):
            if i != skip:
                variant.push(types[i])
        result.push(variant)
    result

fn compute_type_hash(types: [text]) -> i64:
    var hash: i64 = 0
    for ty in types:
        for b in ty.bytes():
            hash = (hash * 31 + b) % 2147483647
    hash

fn check_atss(names: [text], signatures: [[text]], threshold: i64) -> [ATSSWarning]:
    var warnings: [ATSSWarning] = []
    var i = 0
    while i < signatures.len():
        var j = i + 1
        while j < signatures.len():
            val distance = type_set_edit_distance(signatures[i], signatures[j])
            if distance <= threshold:
                warnings.push(ATSSWarning(fn1_name: names[i], fn2_name: names[j], edit_distance: distance))
            j = j + 1
        i = i + 1
    warnings

export ATSSWarning
export check_atss
