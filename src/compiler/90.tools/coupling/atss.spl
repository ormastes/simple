struct TypeVector:
    types: [text]
    hash: i64

fn type_set_edit_distance(a: [text], b: [text]) -> i64:
    var removed = 0
    for item in a:
        if not b.contains(item):
            removed = removed + 1
    var added = 0
    for item in b:
        if not a.contains(item):
            added = added + 1
    removed + added

fn generate_deletion_variants(types: [text]) -> [[text]]:
    var result: [[text]] = []
    for skip in range(0, types.len()):
        var variant: [text] = []
        for i in range(0, types.len()):
            if i != skip:
                variant.push(types[i])
        result.push(variant)
    result

fn compute_type_hash(types: [text]) -> i64:
    var hash: i64 = 0
    for ty in types:
        for b in ty.bytes():
            hash = (hash * 31 + b) % 2147483647
    hash
