use compiler.tools.duplicate_check.tokenizer.{SimpleToken, SimpleTokenKind}

struct RelaxedToken:
    kind_ordinal: i64
    line: i64
    column: i64

fn token_kind_ordinal(kind: SimpleTokenKind) -> i64:
    match kind:
        case Identifier: 0
        case Keyword: 1
        case Operator: 2
        case Literal: 3
        case Punctuation: 4
        case Comment: 5
        case Whitespace: 6

fn to_relaxed_tokens(tokens: [SimpleToken]) -> [RelaxedToken]:
    var result: [RelaxedToken] = []
    for token in tokens:
        if token.kind != SimpleTokenKind.Whitespace and token.kind != SimpleTokenKind.Comment:
            result.push(RelaxedToken(kind_ordinal: token_kind_ordinal(token.kind), line: token.line, column: token.column))
    result
