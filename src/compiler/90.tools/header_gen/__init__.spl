# Header Generator Module
#
# Generates C (.h) and C++ (.hpp) headers for @export("C") Simple classes
# and functions. Also provides shared library build flag helpers.
#
# Public API:
#   - use compiler.tools.header_gen.{HeaderGenerator}
#   - use compiler.tools.header_gen.{emit_c_header, emit_cpp_header}
#   - use compiler.tools.header_gen.{SharedLibFlags, get_shared_lib_flags}

mod header_gen

# Child modules
pub mod mod_
pub mod c_header
pub mod cpp_header
pub mod shared_lib_flags

# Re-exports for public API — entry point
export use mod_.HeaderGenerator

# Re-exports — C header generation
export use c_header.emit_c_header

# Re-exports — C++ header generation
export use cpp_header.emit_cpp_header

# Re-exports — shared library flags
export use shared_lib_flags.SharedLibFlags
export use shared_lib_flags.get_shared_lib_flags
export use shared_lib_flags.shared_lib_output_path
export use shared_lib_flags.import_lib_output_path
export use shared_lib_flags.apply_shared_compile_flags
export use shared_lib_flags.apply_shared_link_flags
