# Header Generation Utilities
#
# Shared helper functions used by both C and C++ header generators.

fn to_guard_name(lib_name: text) -> text:
    var result = lib_name.upper()
    result = result.replace("-", "_")
    result = result.replace(".", "_")
    result = result.replace(" ", "_")
    result

fn sanitize_c_name(name: text) -> text:
    var s = name.replace("<", "_")
    s = s.replace(">", "")
    s = s.replace(",", "_")
    s = s.replace(" ", "")
    s = s.replace("::", "_")
    s
