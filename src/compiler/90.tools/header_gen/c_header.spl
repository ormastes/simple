# C Header Generator
#
# Generates C header (.h) files for @export("C") classes and functions.
# Produces include guards, opaque handle typedefs, function declarations,
# lifecycle functions, and _Static_assert layout verification blocks.
#
# Uses CTypeMapper for type conversions and type_layout for struct layout
# verification. Output is valid C11 with C++ extern "C" compatibility.

use compiler.mir.mir_data.*
use compiler.backend.c_type_mapper.{CTypeMapper}
use compiler.backend.error_conversion.{is_result_type, is_result_type_name, map_result_type, emit_error_type_header_declarations, emit_result_function_declaration}
use compiler.backend.callback_trampoline.{is_callback_type, build_callback_typedef, emit_callback_typedef, CallbackTypedef}
use compiler.types.type_layout.{LayoutVerification, LayoutAttr, layoutattr_c_repr, verify_c_layout, generate_c_static_asserts, generate_c_struct_def}
use hir_definitions.{HirField}
use hir_types.{HirType}

# ============================================================================
# C Header Emission
# ============================================================================

fn emit_c_header(lib_name: text, exported_fns: [MirFunction], exported_types: [MirTypeDef], module: MirModule) -> text:
    """Generate a complete C header (.h) file for exported Simple types and functions.

    The generated header includes:
    1. Include guard (#ifndef / #define / #endif)
    2. Standard includes (stdint.h, stddef.h, stdbool.h)
    3. extern "C" block for C++ compatibility
    4. Library lifecycle declarations (spl_library_init/shutdown)
    5. Opaque handle typedefs for each exported class
    6. Constructor/destructor/method declarations for each class
    7. Standalone function declarations
    8. _Static_assert layout verification blocks for repr(C) types
    9. Closing guards
    """
    val guard_name = _to_guard_name(lib_name)
    var lines: [text] = []

    # Include guard
    lines.push(r"#ifndef " + guard_name + r"_H")
    lines.push(r"#define " + guard_name + r"_H")
    lines.push(r"")

    # Standard includes
    lines.push(r"#include <stdint.h>")
    lines.push(r"#include <stddef.h>")
    lines.push(r"#include <stdbool.h>")
    lines.push(r"")

    # C++ compatibility
    lines.push(r"#ifdef __cplusplus")
    lines.push(r"extern " + "\"C\"" + r" {")
    lines.push(r"#endif")
    lines.push(r"")

    # Library lifecycle
    lines.push(r"/* Library lifecycle */")
    lines.push(r"void spl_library_init(void);")
    lines.push(r"void spl_library_shutdown(void);")
    lines.push(r"")

    # Error type declarations — emitted when any export returns Result<T,E>
    # Check standalone exported functions
    var has_result_fns = false
    var rfi = 0
    while rfi < exported_fns.len():
        if is_result_type(exported_fns[rfi].signature.return_type):
            has_result_fns = true
        rfi = rfi + 1
    # Also check methods on exported types
    if not has_result_fns:
        var rti = 0
        while rti < exported_types.len():
            val rt_type = exported_types[rti]
            val rt_c_name = _sanitize_c_name(rt_type.name)
            val rt_method_prefix = r"__simple_" + rt_c_name + r"_"
            for _sym, func in module.functions:
                if func.name.starts_with(rt_method_prefix):
                    if is_result_type(func.signature.return_type):
                        has_result_fns = true
            rti = rti + 1
    if has_result_fns:
        val err_decls = emit_error_type_header_declarations()
        var edi = 0
        while edi < err_decls.len():
            lines.push(err_decls[edi])
            edi = edi + 1

    # Runtime layout verification — declared when repr(C) types are present
    var has_repr_c_structs = false
    var rc_idx = 0
    while rc_idx < exported_types.len():
        val rc_type = exported_types[rc_idx]
        match rc_type.kind:
            case Struct(fields):
                if fields.len() > 0:
                    has_repr_c_structs = true
            case _:
                pass_dn
        rc_idx = rc_idx + 1

    if has_repr_c_structs:
        lines.push(r"/* Runtime layout verification — call to assert ABI compatibility */")
        lines.push(r"void spl_verify_layouts(void);")
        lines.push(r"")

    # Callback typedefs — emitted before function declarations so they can
    # be used as parameter types. Collected from all exported function signatures.
    # Ownership: callbacks are "borrowed" — caller owns the function pointer,
    # callee does not store it beyond the call.
    val callback_typedefs = _collect_callback_typedefs(exported_fns, exported_types, module)
    if callback_typedefs.len() > 0:
        lines.push(r"/* Callback typedefs (borrowed — caller retains ownership) */")
        var cb_idx = 0
        while cb_idx < callback_typedefs.len():
            lines.push(emit_callback_typedef(callback_typedefs[cb_idx]))
            cb_idx = cb_idx + 1
        lines.push(r"")

    # Exported types — opaque handles and function declarations
    var type_idx = 0
    while type_idx < exported_types.len():
        val type_def = exported_types[type_idx]
        val type_lines = _emit_type_declarations(type_def, module)
        var tl_idx = 0
        while tl_idx < type_lines.len():
            lines.push(type_lines[tl_idx])
            tl_idx = tl_idx + 1
        type_idx = type_idx + 1

    # Exported standalone functions
    if exported_fns.len() > 0:
        lines.push(r"/* Exported functions */")
        var fn_idx = 0
        while fn_idx < exported_fns.len():
            val func = exported_fns[fn_idx]
            val decl = _emit_function_declaration(func)
            lines.push(decl)
            fn_idx = fn_idx + 1
        lines.push(r"")

    # Layout verification (_Static_assert blocks)
    var lv_idx = 0
    while lv_idx < exported_types.len():
        val type_def = exported_types[lv_idx]
        val assert_block = _emit_layout_asserts(type_def)
        if assert_block != "":
            lines.push(assert_block)
            lines.push(r"")
        lv_idx = lv_idx + 1

    # Close extern "C" and include guard
    lines.push(r"#ifdef __cplusplus")
    lines.push(r"}")
    lines.push(r"#endif")
    lines.push(r"")
    lines.push(r"#endif /* " + guard_name + r"_H */")

    lines.join("\n")


# ============================================================================
# Internal Helpers
# ============================================================================

fn _to_guard_name(lib_name: text) -> text:
    """Convert library name to uppercase include guard name."""
    var result = lib_name.to_upper()
    result = result.replace("-", "_")
    result = result.replace(".", "_")
    result = result.replace(" ", "_")
    result

fn _sanitize_c_name(name: text) -> text:
    """Sanitize a Simple type/function name for use as a C identifier."""
    var s = name.replace("<", "_")
    s = s.replace(">", "")
    s = s.replace(",", "_")
    s = s.replace(" ", "")
    s = s.replace("::", "_")
    s

fn _mir_type_to_c_param(ty: MirType) -> text:
    """Map a MIR type to C parameter type string."""
    val mapper = CTypeMapper.create()
    match ty.kind:
        case Unit: "void"
        case Opaque(name):
            if name == "str" or name == "text":
                "const char*"
            else:
                mapper.map_type(ty)
        case _: mapper.map_type(ty)

fn _mir_type_to_c_return(ty: MirType) -> text:
    """Map a MIR type to C return type string."""
    val mapper = CTypeMapper.create()
    match ty.kind:
        case Unit: "void"
        case Opaque(name):
            if name == "str" or name == "text":
                "const char*"
            else:
                mapper.map_type(ty)
        case _: mapper.map_type(ty)

fn _emit_type_declarations(type_def: MirTypeDef, module: MirModule) -> [text]:
    """Emit opaque handle typedef and function declarations for an exported type."""
    var lines: [text] = []
    val c_name = _sanitize_c_name(type_def.name)
    val prefix = if type_def.export_name != "": type_def.export_name else: "spl_" + c_name

    lines.push(r"/* --- " + c_name + r" --- */")

    # Opaque handle typedef
    lines.push(r"typedef struct " + prefix + r"* " + prefix + r"_t;")
    lines.push(r"")

    # Constructor and destructor
    match type_def.kind:
        case Struct(fields):
            # Create declaration
            val create_params = _fields_to_c_params(fields)
            lines.push(prefix + r"_t " + prefix + r"_create(" + create_params + r");")

            # Destroy declaration
            lines.push(r"void " + prefix + r"_destroy(" + prefix + r"_t self);")
            lines.push(r"")

        case _:
            pass_dn

    # Method declarations — find functions matching this class
    val method_prefix_str = r"__simple_" + c_name + r"_"
    for _sym, func in module.functions:
        if func.name.starts_with(method_prefix_str):
            val method_name = func.name.replace(method_prefix_str, "")
            if method_name != "" and method_name != "new" and method_name != "drop":
                val method_decl = _emit_method_declaration(prefix, method_name, func)
                lines.push(method_decl)

    lines.push(r"")
    lines

fn _fields_to_c_params(fields: [MirFieldDef]) -> text:
    """Convert struct fields to C function parameter list."""
    if fields.len() == 0:
        return "void"

    var params: [text] = []
    var fi = 0
    while fi < fields.len():
        val field = fields[fi]
        val c_ty = _mir_type_to_c_param(field.type_)
        params.push(c_ty + " " + field.name)
        fi = fi + 1

    params.join(", ")

fn _emit_method_declaration(prefix: text, method_name: text, func: MirFunction) -> text:
    """Emit a C function declaration for a class method.

    If the method returns Result<T,E>, declares with error out-parameter:
        T prefix_method(self, args..., spl_error_t** err_out);
    """
    # First param is self handle, rest are method params
    var params: [text] = []
    params.push(prefix + r"_t self")

    # Skip first param (self) in signature
    var pi = 1
    while pi < func.signature.params.len():
        val param_ty = _mir_type_to_c_param(func.signature.params[pi])
        params.push(param_ty + " arg" + "{pi}")
        pi = pi + 1

    # Check for Result<T,E> return type
    if is_result_type(func.signature.return_type):
        val type_name = match func.signature.return_type.kind:
            case Opaque(name): name
            case _: "Result"
        val mapping = map_result_type(type_name)
        val full_name = prefix + "_" + method_name
        return emit_result_function_declaration(full_name, mapping.ok_c_type, params, mapping.is_void_ok)

    val ret_type = _mir_type_to_c_return(func.signature.return_type)
    val params_str = params.join(", ")
    ret_type + " " + prefix + "_" + method_name + "(" + params_str + ");"

fn _emit_function_declaration(func: MirFunction) -> text:
    """Emit a C function declaration for a standalone exported function.

    If the function returns Result<T,E>, declares with error out-parameter:
        T fn_name(args..., spl_error_t** err_out);
    """
    val internal_name = func.name
    val export_name = if func.export_name != "":
        func.export_name
    else:
        # Strip __simple_ prefix if present
        if internal_name.starts_with(r"__simple_"):
            "spl_" + internal_name.replace(r"__simple_", "")
        else:
            "spl_" + _sanitize_c_name(internal_name)

    # Check for Result<T,E> return type
    if is_result_type(func.signature.return_type):
        val type_name = match func.signature.return_type.kind:
            case Opaque(name): name
            case _: "Result"
        val mapping = map_result_type(type_name)

        var params: [text] = []
        var pi = 0
        while pi < func.signature.params.len():
            val param_ty = _mir_type_to_c_param(func.signature.params[pi])
            params.push(param_ty + " arg" + "{pi}")
            pi = pi + 1

        return emit_result_function_declaration(export_name, mapping.ok_c_type, params, mapping.is_void_ok)

    val ret_type = _mir_type_to_c_return(func.signature.return_type)

    var params: [text] = []
    var pi = 0
    while pi < func.signature.params.len():
        val param_ty = _mir_type_to_c_param(func.signature.params[pi])
        params.push(param_ty + " arg" + "{pi}")
        pi = pi + 1

    val params_str = if params.len() == 0: "void" else: params.join(", ")
    ret_type + " " + export_name + "(" + params_str + ");"

fn _emit_layout_asserts(type_def: MirTypeDef) -> text:
    """Emit _Static_assert layout verification block for a struct type.

    Converts MirFieldDef to HirField to use the type_layout verification
    functions, then generates _Static_assert statements.
    """
    match type_def.kind:
        case Struct(fields):
            if fields.len() == 0:
                return ""

            val c_name = _sanitize_c_name(type_def.name)

            # Build HirField list from MirFieldDef for layout computation
            var hir_fields: [HirField] = []
            var fi = 0
            while fi < fields.len():
                val field = fields[fi]
                val hir_type = _mir_type_to_hir_type(field.type_)
                hir_fields.push(HirField(
                    name: field.name,
                    type_: hir_type,
                    has_bits_attr: field.has_bits_attr,
                    bits_width: field.bits_width
                ))
                fi = fi + 1

            # Compute and verify layout using C repr
            val verification = verify_c_layout(c_name, hir_fields, layoutattr_c_repr())

            # Generate struct definition and static asserts
            var result_lines: [text] = []
            result_lines.push(r"/* Layout verification for " + c_name + r" */")
            result_lines.push(generate_c_struct_def(verification))
            result_lines.push(r"")
            result_lines.push(generate_c_static_asserts(verification))
            result_lines.join("\n")

        case _:
            ""

fn _mir_type_to_hir_type(ty: MirType) -> HirType:
    """Convert a MIR type to an approximate HirType for layout computation.

    Maps MIR type kinds to their HirType names for use with the
    type_layout module's size/alignment computation.
    """
    match ty.kind:
        case I64: HirType.named("i64")
        case I32: HirType.named("i32")
        case I16: HirType.named("i16")
        case I8: HirType.named("i8")
        case U64: HirType.named("u64")
        case U32: HirType.named("u32")
        case U16: HirType.named("u16")
        case U8: HirType.named("u8")
        case F64: HirType.named("f64")
        case F32: HirType.named("f32")
        case Bool: HirType.named("bool")
        case Unit: HirType.named("unit")
        case Ptr(_, _): HirType.named("usize")
        case _: HirType.named("i64")

# ============================================================================
# Callback Typedef Collection
# ============================================================================

fn _collect_callback_typedefs(exported_fns: [MirFunction], exported_types: [MirTypeDef], module: MirModule) -> [CallbackTypedef]:
    """Collect all unique callback typedefs from exported function signatures.

    Scans parameter types of all exported standalone functions and class methods.
    For each Fn<(A) -> B> type (without captures), builds a CallbackTypedef.
    Deduplicates by typedef name to avoid redundant declarations.
    """
    var typedefs: [CallbackTypedef] = []
    var seen_names: [text] = []

    # Check standalone exported functions
    var fi = 0
    while fi < exported_fns.len():
        val func = exported_fns[fi]
        var pi = 0
        while pi < func.signature.params.len():
            val param_ty = func.signature.params[pi]
            val type_name = _mir_type_name(param_ty)
            if is_callback_type(type_name):
                val cb = build_callback_typedef(type_name)
                if not seen_names.contains(cb.name):
                    seen_names.push(cb.name)
                    typedefs.push(cb)
            pi = pi + 1
        fi = fi + 1

    # Check methods on exported types
    var ti = 0
    while ti < exported_types.len():
        val type_def = exported_types[ti]
        val c_name = _sanitize_c_name(type_def.name)
        val method_prefix = r"__simple_" + c_name + r"_"
        for _sym, func in module.functions:
            if func.name.starts_with(method_prefix):
                var mpi = 1  # Skip self
                while mpi < func.signature.params.len():
                    val param_ty = func.signature.params[mpi]
                    val type_name = _mir_type_name(param_ty)
                    if is_callback_type(type_name):
                        val cb = build_callback_typedef(type_name)
                        if not seen_names.contains(cb.name):
                            seen_names.push(cb.name)
                            typedefs.push(cb)
                    mpi = mpi + 1
        ti = ti + 1

    typedefs

fn _mir_type_name(ty: MirType) -> text:
    """Extract the type name string from a MIR type for callback detection."""
    match ty.kind:
        case Opaque(name): name
        case _: ""

# ============================================================================
# Export
# ============================================================================
