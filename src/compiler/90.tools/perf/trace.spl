# Chrome Trace Event Format span API — Lane L observability Phase 1.
#
# Emits events in the Chrome Trace Event JSON format
# (https://chromium.googlesource.com/catapult tracing docs), consumable by
# chrome://tracing and Perfetto. Fed by:
#   - Manual trace_begin/trace_end spans ("B"/"E" phase events).
#   - profiler.spl's Profiler counters, via trace_from_profiler() (one "X"
#     complete-event per region, using its accumulated total_time_ns).
#   - trace_ingest_span(): a generic complete-span ingestion hook so a
#     kernel scheduler-trace-ring reader can feed this module once VFS/boot
#     wiring lands (Phase 2, gated) — no kernel dependency lives here.
#
# JSON is hand-serialized here rather than via `std.json`: that library's
# json_stringify()/json_object() require values pre-wrapped as tagged
# ("object"|"array"|..., payload) tuples (see
# src/lib/common/json/serializer.spl _json_serialize_object), and calling it
# with plain dict/array literals (the natural Simple idiom, and what
# profiler.spl/benchmark.spl in this same directory already did) throws
# "invalid operation: tuple index access on non-tuple type dict" — a
# pre-existing std.json bug independent of this lane's scope. Filed as a
# finding; TraceEvent's fixed, simple shape makes local serialization cheap
# and keeps this module correct without depending on that bug.

import io
import perf.profiler

extern fn rt_time_monotonic_ns() -> i64

fn _trace_json_escape(s: text) -> text:
    var out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out

class TraceEvent:
    name:   text
    cat:    text
    ph:     text   # "B" begin, "E" end, "X" complete
    ts_us:  i64    # microseconds — Chrome trace convention
    dur_us: i64    # only meaningful for "X"
    pid:    i64
    tid:    i64

    fn to_json() -> text:
        val ts_str = self.ts_us.to_string()
        val pid_str = self.pid.to_string()
        val tid_str = self.tid.to_string()
        var out = "{\"name\":\"" + _trace_json_escape(self.name) + "\""
        out = out + ",\"cat\":\"" + _trace_json_escape(self.cat) + "\""
        out = out + ",\"ph\":\"" + self.ph + "\""
        out = out + ",\"ts\":" + ts_str
        out = out + ",\"pid\":" + pid_str
        out = out + ",\"tid\":" + tid_str
        if self.ph == "X":
            out = out + ",\"dur\":" + self.dur_us.to_string()
        out + "}"

var _g_trace_events: [TraceEvent] = []
val _g_trace_pid: i64 = 1

fn trace_clear():
    _g_trace_events = []

fn trace_events_count() -> i64:
    _g_trace_events.len()

fn trace_begin(name: text, category: text, tid: i64):
    _g_trace_events.push(TraceEvent(
        name: name, cat: category, ph: "B",
        ts_us: rt_time_monotonic_ns() / 1000, dur_us: 0,
        pid: _g_trace_pid, tid: tid
    ))

fn trace_end(name: text, category: text, tid: i64):
    _g_trace_events.push(TraceEvent(
        name: name, cat: category, ph: "E",
        ts_us: rt_time_monotonic_ns() / 1000, dur_us: 0,
        pid: _g_trace_pid, tid: tid
    ))

fn trace_ingest_span(name: text, category: text, start_ns: i64, end_ns: i64, tid: i64):
    """Generic complete-span (X) ingestion. Feeds either trace_from_profiler
    below or (Phase 2, kernel-gated) a sched-trace-ring reader."""
    _g_trace_events.push(TraceEvent(
        name: name, cat: category, ph: "X",
        ts_us: start_ns / 1000, dur_us: (end_ns - start_ns) / 1000,
        pid: _g_trace_pid, tid: tid
    ))

fn trace_from_profiler(prof: profiler.Profiler):
    """Feed the Chrome-trace buffer from a profiler.spl Profiler's PerfCounter
    stats. Each region becomes one complete (X) event ending now, spanning
    back by its accumulated total_time_ns.

    Takes the Profiler explicitly (caller: profiler.get_profiler()) instead
    of resolving the module-global itself: under the interpreter, different
    import-path spellings of the same module (perf.profiler vs
    compiler.tools.perf.profiler) bind separate module instances with
    separate globals, so a hidden get_profiler() here would silently read a
    DIFFERENT profiler than the one the caller populated."""
    val now_ns = rt_time_monotonic_ns()
    for counter in prof.get_stats():
        trace_ingest_span(counter.name, "profiler", now_ns - counter.total_time_ns, now_ns, 0)

fn trace_to_json() -> text:
    var parts: [text] = []
    for ev in _g_trace_events:
        parts.push(ev.to_json())
    var joined = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            joined = joined + ","
        joined = joined + parts[i]
        i = i + 1
    "{\"traceEvents\":[" + joined + "],\"displayTimeUnit\":\"ns\"}"

fn trace_save(path: text):
    io.write_file(path, trace_to_json())
    print "Trace saved to {path}"
