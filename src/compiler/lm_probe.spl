use compiler.frontend.frontend.{parse_full_frontend}
use compiler.hir.hir_lowering.types.{hirlowering_for_module}
use compiler.hir.hir_lowering.items.*
use compiler.common.config.{Logger}
use compiler.frontend.parser_types.{Module}

extern fn rt_file_read_text(path: text) -> text

fn lower_path(path: text):
    val log = Logger(level: 0)
    val modules: Dict<text, Module> = {}
    val src = rt_file_read_text(path) ?? ""
    if src == "":
        print "SKIP {path}"
        return
    print "PARSE:start {path}"
    val m = parse_full_frontend(src, path, "probe", log)
    print "LOWER:start {path}"
    var lowering = hirlowering_for_module(path, modules)
    val hir = lowering.lower_module(m)
    print "LOWER:done {path} fns={hir.functions.len()}"

fn main():
    lower_path("/home/ormastes/dev/pub/simple/src/lib/common/crypto/hkdf.spl")
    lower_path("/home/ormastes/dev/pub/simple/src/app/cli/query_tokens.spl")
    lower_path("/home/ormastes/dev/pub/simple/src/app/interpreter/call/dispatch.spl")
    lower_path("/home/ormastes/dev/pub/simple/src/lib/common/search/roaring.spl")
    lower_path("/home/ormastes/dev/pub/simple/src/lib/common/js/engine/parser_statements.spl")
    lower_path("/home/ormastes/dev/pub/simple/src/app/cli/main.spl")
