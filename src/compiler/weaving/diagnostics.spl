# Weaving Diagnostics
#
# Defines WeavingDiagnostic and DiagnosticLevel for the MDSOC weaving layer.
# Consumed by compiler/85.mdsoc/weaving/weaving_result.spl.

# ============================================================================
# DiagnosticLevel
# ============================================================================

enum DiagnosticLevel:
    Error
    Warning
    Info

# ============================================================================
# WeavingDiagnostic
# ============================================================================

struct WeavingDiagnostic:
    """A diagnostic message produced during aspect weaving."""
    level: DiagnosticLevel
    message: text
    predicate: text
    location: text

impl WeavingDiagnostic:
    static fn error(msg: text) -> WeavingDiagnostic:
        WeavingDiagnostic(level: DiagnosticLevel.Error, message: msg,
                          predicate: "", location: "")

    static fn warning(msg: text) -> WeavingDiagnostic:
        WeavingDiagnostic(level: DiagnosticLevel.Warning, message: msg,
                          predicate: "", location: "")

    static fn info(msg: text) -> WeavingDiagnostic:
        WeavingDiagnostic(level: DiagnosticLevel.Info, message: msg,
                          predicate: "", location: "")

    fn with_predicate(pred: text) -> WeavingDiagnostic:
        WeavingDiagnostic(level: self.level, message: self.message,
                          predicate: pred, location: self.location)

    fn with_location(loc: text) -> WeavingDiagnostic:
        WeavingDiagnostic(level: self.level, message: self.message,
                          predicate: self.predicate, location: loc)

    fn is_error() -> bool:
        match self.level:
            case DiagnosticLevel.Error: true
            case _: false

    fn is_warning() -> bool:
        match self.level:
            case DiagnosticLevel.Warning: true
            case _: false

    fn is_info() -> bool:
        match self.level:
            case DiagnosticLevel.Info: true
            case _: false

    fn level_name() -> text:
        match self.level:
            case DiagnosticLevel.Error: "error"
            case DiagnosticLevel.Warning: "warning"
            case DiagnosticLevel.Info: "info"
