# MIR Lowering - Expression Lowering
#
# Expression lowering from HIR to MIR:
# - Literal lowering (int, float, bool, string, nil, unit)
# - Variable references
# - Binary/unary operators (including special pipeline/compose/parallel)
# - Function calls (direct and indirect)
# - Method calls (instance, trait, static, free function / UFCS)
# - Array, tuple, set, and constant expression lowering
# - Field access

use compiler.mir.mir_data.*
use compiler.hir.hir.*
use compiler.common.diagnostics.span.{Span}
use compiler.blocks.value.BlockValue
use compiler.mir.mir_lowering_types.{MirLowering, MirError}
use compiler.backend.gpu_intrinsics.{is_gpu_intrinsic}

# ============================================================================
# Expression Lowering
# ============================================================================

impl MirLowering:
    me bitfield_field_mask(bit_width: i64) -> i64:
        """Return a signed i64 mask for a bitfield slice, including full-width fields."""
        if bit_width <= 0:
            return 0
        if bit_width >= 64:
            return -1
        (1 << bit_width) - 1

    me bitfield_field_result_type(field: HirBitfieldField) -> MirType:
        """Choose the MIR result type for a lowered bitfield field read."""
        if field.has_type_:
            match field.type_.kind:
                case Bool:
                    return MirType.bool()
                case _:
                    return MirType.bits(field.bit_width)
        MirType.bits(field.bit_width)

    me bitfield_total_width(fields: [HirBitfieldField]) -> i64:
        """Return the packed storage width for a bitfield definition."""
        var total = 0
        for field in fields:
            total = total + field.bit_width
        total

    me lower_expr(expr: HirExpr) -> LocalId:
        """Lower HIR expression to MIR, return result local."""

        match expr.kind:
            case IntLit(value, _):

                var b = self.builder
                val result = b.emit_const_int(value)
                self.builder = b
                result

            case FloatLit(value, _):

                var b = self.builder
                val result = b.emit_const_float(value)
                self.builder = b
                result

            case BoolLit(value):

                var b = self.builder
                val result = b.emit_const_bool(value)
                self.builder = b
                result

            case StringLit(value, _):

                # Store string as constant; runtime resolves pointer
                var b = self.builder
                val dest = b.new_temp(MirType(kind: MirTypeKind.Opaque("str")))
                b.emit_const(dest, MirConstValue.Str(value), MirType(kind: MirTypeKind.Opaque("str")))
                self.builder = b
                dest

            case NilLit | UnitLit:

                var b = self.builder
                val result = b.new_temp(MirType.unit())
                self.builder = b
                result

            case Var(symbol):

                # Look up variable in local_map using contains_key first
                if self.local_map.has(symbol):
                    self.local_map[symbol]
                else:
                    self.error("undefined variable", Some(expr.span))
                    var b_err = self.builder
                    val err_tmp = b_err.new_temp(MirType.i64())
                    self.builder = b_err
                    err_tmp

            case Binary(op, left, right):

                # Check if this is a special pipeline operator first
                val special_result = self.lower_binop_special(op, left, right)
                if special_result.?:
                    special_result.unwrap()
                else:
                    # Normal binary operation
                    val left_local = self.lower_expr(left)
                    val right_local = self.lower_expr(right)
                    val mir_op = self.lower_binop(op)
                    val result_type = self.infer_binop_type(op)
                    var b = self.builder
                    val binop_result = b.emit_binop(mir_op, mir_operand_copy(left_local), mir_operand_copy(right_local), result_type)
                    self.builder = b
                    binop_result

            case Unary(op, operand):

                val operand_local = self.lower_expr(operand)
                val mir_op = self.lower_unaryop(op)
                var b = self.builder
                val unary_result = b.emit_unary(mir_op, mir_operand_copy(operand_local), MirType.i64())
                self.builder = b
                unary_result

            case If(cond, then_, else_):

                self.lower_if(cond, then_, else_)

            case Call(callee, args, _):

                self.lower_call(callee, args)

            case MethodCall(receiver, method, args, resolution):
                self.lower_method_call(receiver, method, args, resolution)

            case ArrayLit(elements, _):
                self.lower_array_lit(elements)

            case Index(base, index):
                # Array indexing: arr[i] -> GEP + Load
                val base_local = self.lower_expr(base)
                val index_local = self.lower_expr(index)
                var b = self.builder
                val ptr = b.emit_gep(
                    mir_operand_copy(base_local),
                    [mir_operand_copy(index_local)],
                    MirType.ptr(MirType.i64(), false)
                )
                val loaded = b.emit_load(mir_operand_copy(ptr), MirType.i64())
                self.builder = b
                loaded

            case SetLit(elements, _):
                self.lower_set_lit(elements)

            case TupleLit(elements):
                self.lower_tuple_lit(elements)

            case Block(block):
                val result = self.lower_block(block)
                if result.?:
                    result.unwrap()
                else:
                    var b = self.builder
                    val temp = b.new_temp(MirType.unit())
                    self.builder = b
                    temp

            case Loop(body, _):
                self.lower_loop(body)

            case While(cond, body, _):
                self.lower_while(cond, body)

            case For(var_, iter, body, _):
                self.lower_for(var_, iter, body)

            case Return(value):

                var br = self.builder
                if value.?:
                    val result = self.lower_expr(value.unwrap())
                    br = self.builder
                    br.terminate_return(Some(mir_operand_copy(result)))
                else:
                    br.terminate_return(nil)
                self.builder = br
                var br2 = self.builder
                val ret_temp = br2.new_temp(MirType.unit())
                self.builder = br2
                ret_temp

            case Break(break_label, break_value):
                if self.loop_stack.len() > 0:
                    val (loop_continue_block, break_block) = self.loop_stack[self.loop_stack.len() - 1]
                    var b = self.builder
                    b.terminate_goto(break_block)
                    self.builder = b
                var b = self.builder
                val break_temp = b.new_temp(MirType.unit())
                self.builder = b
                break_temp

            case Continue(cont_label):
                if self.loop_stack.len() > 0:
                    val (continue_block, loop_break_block) = self.loop_stack[self.loop_stack.len() - 1]
                    var b = self.builder
                    b.terminate_goto(continue_block)
                    self.builder = b
                var b = self.builder
                val cont_temp = b.new_temp(MirType.unit())
                self.builder = b
                cont_temp

            # Custom blocks (user-defined: sh{}, sql{}, re{}, etc.)
            case CustomBlock(kind, value):
                self.lower_custom_block(kind, value, expr.span)

            # Math/DL blocks with special semantics
            case LossBlock(body):
                self.lower_loss_block(body)

            case NogradBlock(body):
                self.lower_nograd_block(body)

            case Range(start, end, inclusive, step):
                self.lower_range(start, end, inclusive, step)

            # Async/Await expressions
            case Await(future_expr):
                self.lower_await(future_expr)

            case Yield(value):
                self.lower_yield(value)

            # Unsafe block - lower the body, no special handling
            case UnsafeBlock(body):
                self.lower_block(body) ?? self.builder.new_temp(MirType.unit())

            # Inline assembly
            case InlineAsm(asm):
                self.lower_inline_asm(asm)

            # Target-qualified inline assembly
            case InlineAsmMatch(arms):
                self.lower_inline_asm_match(arms)

            # Field access: obj.field_name
            case Field(base, field_name, resolved):
                val base_local = self.lower_expr(base)
                val bitfield_result = self.try_lower_bitfield_get(base, base_local, field_name)
                if bitfield_result.?:
                    return bitfield_result.unwrap()
                val field_idx = self.resolve_field_index(base, field_name, resolved)
                var b = self.builder
                val result = b.emit_get_field(mir_operand_copy(base_local), field_idx, MirType.i64())
                self.builder = b
                result

            # B5b Phase 1: lower MatchCase on integer-literal patterns to
            # MirTerminator.Switch (dense >=4 arms, span <= 1024) or to a
            # nested If chain (sparse / smaller). Other pattern kinds and
            # guards are explicitly rejected as Phase 2.
            case MatchCase(scrutinee, arms):
                self.lower_match_case(scrutinee, arms)

            case _:

                self.error("unsupported MIR expression: {expr.kind}", nil)
                nil

    # ========================================================================
    # B5b Phase 1 — MatchCase lowering (integer-literal patterns only)
    # ========================================================================

    me lower_match_case(scrutinee: HirExpr, arms: [HirMatchArm]) -> LocalId:
        """Lower a `match` expression on integer-literal patterns.

        Phase 1 supports:
          - HirPatternKind.Wildcard            (default arm)
          - HirPatternKind.Literal(IntLit n)   (constant int arm)

        Phase 2a (this revision) additionally supports:
          - HirPatternKind.Binding(symbol, _)  (irrefutable default arm
            that also binds the scrutinee to a local symbol; mutability
            flag is irrelevant at MIR-lowering time and is ignored here)
          - HirPatternKind.Or(patterns) when every alternative is
            Literal(IntLit n) (each alternative becomes its own
            int_cases entry pointing at the shared arm body)

        Anything else (Tuple, Array, Struct, Enum, Range, non-IntLit
        Literal, Or with non-IntLit alternatives, or any guard) yields a
        clear diagnostic so users get a real error instead of
        `unsupported MIR expression`.

        Dense int matches (>=4 cases, key-span <= 1024) emit
        MirTerminator.Switch so the backend can produce a jump table; sparse
        / smaller matches fall back to a chained If terminator. The
        scrutinee is evaluated once into a temp to avoid duplicating side
        effects.
        """
        # Phase 1+2a gate: every arm must be (Wildcard | Binding |
        # Literal(IntLit) | Or(of IntLit)) with no guard. If anything else
        # is present, emit a Phase 2 diagnostic naming the offending kind
        # and bail out with a unit temp.
        var int_cases: [(i64, HirBlock)] = []
        var default_body: HirBlock? = nil
        var default_binding: SymbolId? = nil
        var idx = 0
        while idx < arms.len():
            val arm = arms[idx]
            if arm.has_guard:
                self.error(
                    "B5b Phase 2 not yet implemented: match arm guard",
                    Some(arm.span)
                )
                var b_err = self.builder
                val err_temp = b_err.new_temp(MirType.unit())
                self.builder = b_err
                return err_temp
            match arm.pattern.kind:
                case Wildcard:
                    if default_body.?:
                        self.error(
                            "B5b: match has multiple wildcard arms",
                            Some(arm.span)
                        )
                        var b_err2 = self.builder
                        val err_temp2 = b_err2.new_temp(MirType.unit())
                        self.builder = b_err2
                        return err_temp2
                    default_body = Some(arm.body)
                case Literal(lit_expr):
                    match lit_expr.kind:
                        case IntLit(n, _):
                            int_cases = int_cases.push((n, arm.body))
                        case _:
                            self.error(
                                "B5b Phase 2 not yet implemented: pattern kind Literal(non-IntLit)",
                                Some(arm.pattern.span)
                            )
                            var b_err3 = self.builder
                            val err_temp3 = b_err3.new_temp(MirType.unit())
                            self.builder = b_err3
                            return err_temp3
                case Binding(symbol, _):
                    # Phase 2a: irrefutable binding pattern acts like a
                    # wildcard default but also binds the scrutinee to a
                    # local symbol. Mutability flag is ignored at MIR
                    # level (it only matters for borrow-check).
                    if default_body.?:
                        self.error(
                            "B5b: match has multiple wildcard/binding default arms",
                            Some(arm.span)
                        )
                        var b_dup = self.builder
                        val t_dup = b_dup.new_temp(MirType.unit())
                        self.builder = b_dup
                        return t_dup
                    default_body = Some(arm.body)
                    default_binding = Some(symbol)
                case Or(sub_patterns):
                    # Phase 2a: Or-of-IntLit alternatives expand into one
                    # int_cases entry per alternative, all pointing at the
                    # same shared arm body. Any non-IntLit sub-pattern
                    # falls through to the Phase 2 diagnostic below.
                    var or_ok = true
                    var oi = 0
                    while oi < sub_patterns.len() and or_ok:
                        val sp = sub_patterns[oi]
                        match sp.kind:
                            case Literal(sp_lit):
                                match sp_lit.kind:
                                    case IntLit(sn, _):
                                        int_cases = int_cases.push((sn, arm.body))
                                    case _:
                                        or_ok = false
                            case _:
                                or_ok = false
                        oi = oi + 1
                    if not or_ok:
                        self.error(
                            "B5b Phase 2 not yet implemented: pattern kind Or with non-IntLit alternatives",
                            Some(arm.pattern.span)
                        )
                        var b_o2 = self.builder
                        val t_o2 = b_o2.new_temp(MirType.unit())
                        self.builder = b_o2
                        return t_o2
                case Tuple(_):
                    self.error(
                        "B5b Phase 2 not yet implemented: pattern kind Tuple",
                        Some(arm.pattern.span)
                    )
                    var b_t = self.builder
                    val t_t = b_t.new_temp(MirType.unit())
                    self.builder = b_t
                    return t_t
                case Array(_, _):
                    self.error(
                        "B5b Phase 2 not yet implemented: pattern kind Array",
                        Some(arm.pattern.span)
                    )
                    var b_a = self.builder
                    val t_a = b_a.new_temp(MirType.unit())
                    self.builder = b_a
                    return t_a
                case Struct(_, _):
                    self.error(
                        "B5b Phase 2 not yet implemented: pattern kind Struct",
                        Some(arm.pattern.span)
                    )
                    var b_s = self.builder
                    val t_s = b_s.new_temp(MirType.unit())
                    self.builder = b_s
                    return t_s
                case Enum(_, _, _):
                    self.error(
                        "B5b Phase 2 not yet implemented: pattern kind Enum",
                        Some(arm.pattern.span)
                    )
                    var b_e = self.builder
                    val t_e = b_e.new_temp(MirType.unit())
                    self.builder = b_e
                    return t_e
                case Range(_, _, _):
                    self.error(
                        "B5b Phase 2 not yet implemented: pattern kind Range",
                        Some(arm.pattern.span)
                    )
                    var b_r = self.builder
                    val t_r = b_r.new_temp(MirType.unit())
                    self.builder = b_r
                    return t_r
                case Error:
                    self.error(
                        "B5b: match arm has Error pattern (parser/HIR error)",
                        Some(arm.pattern.span)
                    )
                    var b_x = self.builder
                    val t_x = b_x.new_temp(MirType.unit())
                    self.builder = b_x
                    return t_x
            idx = idx + 1

        # Phase 1 also requires a wildcard default arm; without one we'd
        # need exhaustiveness analysis (Phase 2). Reject cleanly.
        if not default_body.?:
            self.error(
                "B5b Phase 2 not yet implemented: match without wildcard default arm",
                nil
            )
            var b_nd = self.builder
            val t_nd = b_nd.new_temp(MirType.unit())
            self.builder = b_nd
            return t_nd

        # Evaluate scrutinee once into a temp.
        val scrut_local = self.lower_expr(scrutinee)

        # Decide dense vs sparse. Same heuristic as Rust seed:
        #   arms >= 4 and (max - min) <= 1024  =>  Switch
        #   otherwise                          =>  If chain
        val use_switch = self.should_emit_switch(int_cases)

        if use_switch:
            self.emit_switch_dispatch(scrut_local, int_cases, default_body.unwrap(), default_binding)
        else:
            self.emit_if_chain_dispatch(scrut_local, int_cases, default_body.unwrap(), default_binding)

    me should_emit_switch(int_cases: [(i64, HirBlock)]) -> bool:
        """Heuristic: dense int matches go to Switch (jump table), sparse
        / small matches stay as If chains. Mirrors the Rust-seed B5
        constants SWITCH_MIN_ARMS=4 and SWITCH_MAX_SPAN=1024."""
        if int_cases.len() < 4:
            return false
        var lo = int_cases[0].0
        var hi = int_cases[0].0
        var i = 1
        while i < int_cases.len():
            val k = int_cases[i].0
            if k < lo:
                lo = k
            if k > hi:
                hi = k
            i = i + 1
        val span = hi - lo
        span >= 0 and span <= 1024

    me emit_switch_dispatch(scrut_local: LocalId, int_cases: [(i64, HirBlock)], default_body: HirBlock, default_binding: SymbolId?) -> LocalId:
        """Emit a MirTerminator.Switch for a dense int match. Each arm
        lowers into its own block, stores its result into a shared temp,
        and jumps to a merge block. Mirrors lower_if's
        temp-then-merge pattern."""
        var b = self.builder
        val result = b.new_temp(MirType.i64())
        val merge_block = b.new_block(Some("match_merge"))
        val default_block = b.new_block(Some("match_default"))

        # Allocate one block per arm and build SwitchCase entries.
        var case_blocks: [(BlockId, HirBlock)] = []
        var sw_cases: [SwitchCase] = []
        var i = 0
        while i < int_cases.len():
            val key = int_cases[i].0
            val body = int_cases[i].1
            val arm_block = b.new_block(Some("match_arm"))
            case_blocks = case_blocks.push((arm_block, body))
            sw_cases = sw_cases.push(SwitchCase(value: key, target: arm_block))
            i = i + 1

        # Seal the current block with the Switch terminator.
        b.terminate_switch(mir_operand_copy(scrut_local), sw_cases, default_block)
        self.builder = b

        # Lower each arm body into its block.
        var ci = 0
        while ci < case_blocks.len():
            val arm_block = case_blocks[ci].0
            val arm_body = case_blocks[ci].1
            var b_arm = self.builder
            b_arm.switch_to_block(arm_block)
            self.builder = b_arm
            val arm_result = self.lower_block(arm_body)
            var b_arm2 = self.builder
            if arm_result.?:
                b_arm2.emit_copy(result, arm_result.unwrap())
            b_arm2.terminate_goto(merge_block)
            self.builder = b_arm2
            ci = ci + 1

        # Default arm. If the default arm came from a Binding pattern,
        # map the binding's symbol to the scrutinee local before lowering
        # the body so references inside the arm body resolve.
        var b_d = self.builder
        b_d.switch_to_block(default_block)
        self.builder = b_d
        if default_binding.?:
            self.local_map[default_binding.unwrap()] = scrut_local
        val def_result = self.lower_block(default_body)
        var b_d2 = self.builder
        if def_result.?:
            b_d2.emit_copy(result, def_result.unwrap())
        b_d2.terminate_goto(merge_block)
        self.builder = b_d2

        # Merge block.
        var b_m = self.builder
        b_m.switch_to_block(merge_block)
        self.builder = b_m

        result

    me emit_if_chain_dispatch(scrut_local: LocalId, int_cases: [(i64, HirBlock)], default_body: HirBlock, default_binding: SymbolId?) -> LocalId:
        """Emit a nested If chain for sparse / small int matches.
        Cheaper than a jump table when arms < 4 or key span > 1024."""
        var b = self.builder
        val result = b.new_temp(MirType.i64())
        val merge_block = b.new_block(Some("match_merge"))
        self.builder = b

        var i = 0
        while i < int_cases.len():
            val key = int_cases[i].0
            val body = int_cases[i].1

            # Build `scrut == key` into a bool local.
            var b_cmp = self.builder
            val key_local = b_cmp.emit_const_int(key)
            val cmp_local = b_cmp.emit_binop(
                MirBinOp.Eq,
                mir_operand_copy(scrut_local),
                mir_operand_copy(key_local),
                MirType.bool()
            )
            val arm_block = b_cmp.new_block(Some("match_arm"))
            val next_block = b_cmp.new_block(Some("match_next"))
            b_cmp.terminate_if(mir_operand_copy(cmp_local), arm_block, next_block)
            self.builder = b_cmp

            # Arm body block.
            var b_arm = self.builder
            b_arm.switch_to_block(arm_block)
            self.builder = b_arm
            val arm_result = self.lower_block(body)
            var b_arm2 = self.builder
            if arm_result.?:
                b_arm2.emit_copy(result, arm_result.unwrap())
            b_arm2.terminate_goto(merge_block)
            self.builder = b_arm2

            # Continue cascading into next_block.
            var b_n = self.builder
            b_n.switch_to_block(next_block)
            self.builder = b_n

            i = i + 1

        # After all cases, current block is the cascade tail = default.
        # If the default arm came from a Binding pattern, map the
        # binding's symbol to the scrutinee local before lowering.
        if default_binding.?:
            self.local_map[default_binding.unwrap()] = scrut_local
        val def_result = self.lower_block(default_body)
        var b_def = self.builder
        if def_result.?:
            b_def.emit_copy(result, def_result.unwrap())
        b_def.terminate_goto(merge_block)
        self.builder = b_def

        # Merge block.
        var b_m = self.builder
        b_m.switch_to_block(merge_block)
        self.builder = b_m

        result

    me try_lower_bitfield_get(base: HirExpr, base_local: LocalId, field_name: text) -> LocalId?:
        """Lower bitfield field reads before generic struct field access."""
        val type_sym = self.expr_type_symbol(base)
        if not type_sym.?:
            return nil

        val sym_id = type_sym.unwrap().id
        if not self.bitfield_map.has(sym_id):
            return nil

        val fields = self.bitfield_map[sym_id]
        var idx = 0
        while idx < fields.len():
            val field = fields[idx]
            if field.name == field_name and not field.is_reserved:
                var b = self.builder
                val result = if self.current_has_vhdl_metadata:
                    val slice_dest = b.new_temp(self.bitfield_field_result_type(field))
                    val hi = field.bit_offset + field.bit_width - 1
                    b.emit(MirInst(
                        kind: MirInstKind.VhdlSlice(
                            slice_dest,
                            mir_operand_copy(base_local),
                            hi,
                            field.bit_offset
                        ),
                        span: nil
                    ))
                    slice_dest
                else:
                    val mask = self.bitfield_field_mask(field.bit_width)
                    val shifted = if field.bit_offset == 0:
                        base_local
                    else:
                        val offset_const = b.emit_const_int(field.bit_offset)
                        b.emit_binop(
                            MirBinOp.Shr,
                            mir_operand_copy(base_local),
                            mir_operand_copy(offset_const),
                            MirType.i64()
                        )
                    val mask_const = b.emit_const_int(mask)
                    b.emit_binop(
                        MirBinOp.BitAnd,
                        mir_operand_copy(shifted),
                        mir_operand_copy(mask_const),
                        MirType.i64()
                    )
                self.builder = b
                return Some(result)
            idx = idx + 1

        nil

    me lower_binop_special(op: HirBinOp, left: HirExpr, right: HirExpr) -> LocalId?:
        """Check if this is a special binary op needing non-BinOp lowering."""
        match op:
            case PipeForward:
                # x |> f  ->  PipeForward(x, f)
                val value_local = self.lower_expr(left)
                val func_local = self.lower_expr(right)
                val dest = self.builder.new_temp(MirType.i64())
                self.builder.emit(MirInst(kind: MirInstKind.PipeForward(dest, mir_operand_copy(value_local), mir_operand_copy(func_local)), span: nil))
                Some(dest)

            case Compose:
                # f >> g  ->  Compose(f, g, true)
                val f_local = self.lower_expr(left)
                val g_local = self.lower_expr(right)
                val dest = self.builder.new_temp(MirType.i64())
                self.builder.emit(MirInst(kind: MirInstKind.Compose(dest, mir_operand_copy(f_local), mir_operand_copy(g_local), true), span: nil))
                Some(dest)

            case ComposeBack:
                # f << g  ->  Compose(f, g, false)
                val f_local = self.lower_expr(left)
                val g_local = self.lower_expr(right)
                val dest = self.builder.new_temp(MirType.i64())
                self.builder.emit(MirInst(kind: MirInstKind.Compose(dest, mir_operand_copy(f_local), mir_operand_copy(g_local), false), span: nil))
                Some(dest)

            case Parallel:
                # f // g  ->  Parallel([f, g])
                val f_local = self.lower_expr(left)
                val g_local = self.lower_expr(right)
                val dest = self.builder.new_temp(MirType.i64())
                self.builder.emit(MirInst(kind: MirInstKind.Parallel(dest, [mir_operand_copy(f_local), mir_operand_copy(g_local)]), span: nil))
                Some(dest)

            case LayerConnect:
                # layer1 ~> layer2  ->  LayerConnect(layer1, layer2)
                val l1_local = self.lower_expr(left)
                val l2_local = self.lower_expr(right)
                val dest = self.builder.new_temp(MirType.i64())
                self.builder.emit(MirInst(kind: MirInstKind.LayerConnect(dest, mir_operand_copy(l1_local), mir_operand_copy(l2_local)), span: nil))
                Some(dest)

            case _:
                nil  # Not a special op, use normal BinOp

    me lower_binop(op: HirBinOp) -> MirBinOp:
        """Convert HIR binary op to MIR binary op."""
        match op:
            case Add: MirBinOp.Add
            case Sub: MirBinOp.Sub
            case Mul: MirBinOp.Mul
            case Div: MirBinOp.Div
            case Mod: MirBinOp.Rem
            case Pow: MirBinOp.Pow
            case MatMul: MirBinOp.MatMul
            case BitAnd: MirBinOp.BitAnd
            case BitOr: MirBinOp.BitOr
            case BitXor: MirBinOp.BitXor
            case Shl: MirBinOp.Shl
            case Shr: MirBinOp.Shr
            case Eq: MirBinOp.Eq
            case NotEq: MirBinOp.Ne
            case Lt: MirBinOp.Lt
            case LtEq: MirBinOp.Le
            case Gt: MirBinOp.Gt
            case GtEq: MirBinOp.Ge
            case BroadcastAdd: MirBinOp.BroadcastAdd
            case BroadcastSub: MirBinOp.BroadcastSub
            case BroadcastMul: MirBinOp.BroadcastMul
            case BroadcastDiv: MirBinOp.BroadcastDiv
            case BroadcastPow: MirBinOp.BroadcastPow
            case _: MirBinOp.Add

    me lower_unaryop(op: HirUnaryOp) -> MirUnaryOp:
        """Convert HIR unary op to MIR unary op."""
        match op:
            case Neg: MirUnaryOp.Neg
            case Not: MirUnaryOp.Not
            case BitNot: MirUnaryOp.BitNot
            case Transpose: MirUnaryOp.Transpose
            case _: MirUnaryOp.Neg

    me infer_binop_type(op: HirBinOp) -> MirType:
        """Infer result type of binary operation."""
        match op:
            case Eq | NotEq | Lt | LtEq | Gt | GtEq:
                MirType.bool()
            case _:
                MirType.i64()  # Default to i64

    me lower_call(callee: HirExpr, args: [HirCallArg]) -> LocalId:
        """Lower function call.

        Handles both direct calls (Var) and indirect calls (closures, function pointers).
        Intercepts GPU intrinsic calls (gpu_global_id, etc.) and emits MIR GPU instructions.
        """
        # Check for GPU intrinsic calls before lowering arguments
        match callee.kind:
            case Var(symbol):
                val sym = self.symbols.get(symbol)
                val callee_name = if sym.?: sym.name else: ""
                if is_gpu_intrinsic(callee_name):
                    return self.lower_gpu_intrinsic_call(callee_name, args)
            case _: ()

        var arg_operands: [MirOperand] = []
        for arg in args:
            val arg_local = self.lower_expr(arg.value)
            arg_operands = arg_operands.push(mir_operand_copy(arg_local))

        # Check if this is a direct call (Var) or indirect call
        match callee.kind:
            case Var(symbol):
                # Direct call - use Call instruction
                val func_operand = self.symbol_to_operand(symbol)
                var b = self.builder
                val result = b.emit_call(func_operand, arg_operands, MirType.i64())
                if result.?:
                    self.builder = b
                    result.unwrap()
                else:
                    val temp = b.new_temp(MirType.unit())
                    self.builder = b
                    temp

            case _:
                # Indirect call - lower callee expression and use CallIndirect
                val callee_local = self.lower_expr(callee)
                # Infer parameter types from arguments
                var param_types: [MirType] = []
                for arg_op in arg_operands:
                    param_types.push(MirType.i64())
                # Infer return type from callee's type annotation if available
                val ret_type = if callee.type_.?:
                    self.lower_type(callee.type_.unwrap())
                else:
                    MirType.i64()
                val sig = MirSignature(
                    params: param_types,
                    return_type: ret_type,
                    is_variadic: false
                )
                var b = self.builder
                val result = b.emit_call_indirect(mir_operand_copy(callee_local), arg_operands, sig, MirType.i64())
                if result.?:
                    self.builder = b
                    result.unwrap()
                else:
                    val temp = b.new_temp(MirType.unit())
                    self.builder = b
                    temp

    me is_mutating_method(name: text) -> bool:
        """Allow-list of methods that mutate `self`.

        Used by `lower_method_call` to trigger a post-call write-back when the
        receiver is an indexed slot (`stack[i]`) or a field (`obj.child`). For
        reference-semantics receivers the write-back is an idempotent re-store
        of the same pointer; for value-semantics receivers it is the fix for
        the lost mutation. See Rust seed bug #28.
        """
        match name:
            case "push": true
            case "pop": true
            case "insert": true
            case "remove": true
            case "clear": true
            case "extend": true
            case "sort": true
            case "reverse": true
            case "set": true
            case "delete": true
            case "append": true
            case "prepend": true
            case "splice": true
            case "drain": true
            case "truncate": true
            case "resize": true
            case "fill": true
            case "swap": true
            case "update": true
            case "replace": true
            case "init": true
            case "reset": true
            case "inc": true
            case "dec": true
            case _: false

    me lower_method_call(receiver: HirExpr, method: text, args: [HirCallArg], resolution: MethodResolution) -> LocalId:
        """Lower method call based on resolution.

        UFCS: For FreeFunction resolution, receiver becomes first argument.
        Handles this.index()/thread_index()/group_index() for @simd kernels.

        Indexed/field receiver write-back: when the receiver is `arr[i]` or
        `obj.field` and the method is in `is_mutating_method`, we pre-lower
        the base/index/field locals, dispatch the call with the loaded
        receiver, then emit a store-back so mutations reach the original
        slot. Without this, `stack[i].push(x)` silently discards the
        mutation because the receiver is loaded as a value copy into a
        temporary (pure-Simple equivalent of Rust seed bug #28).
        """
        # Handle this.index() / this.thread_index() / this.group_index() for @simd
        match receiver.kind:
            case Var(sym):
                val recv_name = if self.symbols.get(sym).?: self.symbols.get(sym).name else: ""
                if recv_name == "this":
                    match method:
                        case "index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuGlobalId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case "thread_index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuLocalId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case "group_index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuBlockId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case _: ()
            case _: ()

        # Pre-lower writeback origin for mutating methods on indexed/field receivers.
        # wb_kind: 0 = none, 1 = indexed (rt_array_set), 2 = field (emit_set_field)
        var wb_kind: i64 = 0
        var wb_base: LocalId = 0
        var wb_index: LocalId = 0
        var wb_field_idx: i64 = 0
        var wb_receiver: LocalId = 0

        if self.is_mutating_method(method):
            match receiver.kind:
                case Index(base, index):
                    wb_base = self.lower_expr(base)
                    wb_index = self.lower_expr(index)
                    var wb_b = self.builder
                    val wb_ptr = wb_b.emit_gep(
                        mir_operand_copy(wb_base),
                        [mir_operand_copy(wb_index)],
                        MirType.ptr(MirType.i64(), false)
                    )
                    wb_receiver = wb_b.emit_load(mir_operand_copy(wb_ptr), MirType.i64())
                    self.builder = wb_b
                    wb_kind = 1
                case Field(base, field_name, resolved):
                    wb_base = self.lower_expr(base)
                    wb_field_idx = self.resolve_field_index(base, field_name, resolved)
                    var wb_b = self.builder
                    wb_receiver = wb_b.emit_get_field(mir_operand_copy(wb_base), wb_field_idx, MirType.i64())
                    self.builder = wb_b
                    wb_kind = 2
                case _: ()

        match resolution:
            case InstanceMethod(type_id, method_id):
                # Direct method call on type
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val method_operand = self.symbol_to_operand(method_id)
                var b = self.builder
                val result = b.emit_call(method_operand, arg_operands, MirType.i64())
                self.builder = b
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_receiver)
                if result.?:
                    result.unwrap()
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.unit())
                    self.builder = b2
                    temp

            case TraitMethod(trait_id, method_id):
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val method_operand = self.symbol_to_operand(method_id)
                var b = self.builder
                val result = b.emit_call(method_operand, arg_operands, MirType.i64())
                self.builder = b
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_receiver)
                if result.?:
                    result.unwrap()
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.unit())
                    self.builder = b2
                    temp

            case FreeFunction(func_id):
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val func_operand = self.symbol_to_operand(func_id)
                var b = self.builder
                val result = b.emit_call(func_operand, arg_operands, MirType.i64())
                self.builder = b
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_receiver)
                if result.?:
                    result.unwrap()
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.unit())
                    self.builder = b2
                    temp

            case StaticMethod(type_id, method_id):
                var arg_operands: [MirOperand] = []
                for arg in args:
                    val arg_local = self.lower_expr(arg.value)
                    arg_operands = arg_operands.push(mir_operand_copy(arg_local))

                val method_operand = self.symbol_to_operand(method_id)
                var b = self.builder
                val result = b.emit_call(method_operand, arg_operands, MirType.i64())
                if result.?:
                    self.builder = b
                    result.unwrap()
                else:
                    val temp = b.new_temp(MirType.unit())
                    self.builder = b
                    temp

            case Unresolved:
                self.error("unresolved method call: {method}", nil)
                var b = self.builder
                val temp = b.new_temp(MirType.unit())
                self.builder = b
                temp

    me build_args_from_receiver(receiver_local: LocalId, args: [HirCallArg]) -> [MirOperand]:
        """Build arg operands starting from a pre-lowered receiver local.

        Used by the indexed/field writeback path in `lower_method_call` to
        avoid re-lowering the receiver HIR (which would duplicate side
        effects and re-run emit_gep/emit_load for the indexed slot).
        """
        var arg_operands: [MirOperand] = [mir_operand_copy(receiver_local)]
        for arg in args:
            val arg_local = self.lower_expr(arg.value)
            arg_operands = arg_operands.push(mir_operand_copy(arg_local))
        arg_operands

    me emit_method_writeback(wb_kind: i64, wb_base: LocalId, wb_index: LocalId, wb_field_idx: i64, wb_receiver: LocalId):
        """Emit the post-call store-back for a mutating method on an
        indexed or field receiver. No-op when `wb_kind == 0`.

        wb_kind 1: `rt_array_set(base, index, receiver)` (indexed slot)
        wb_kind 2: `emit_set_field(base, field_idx, receiver)` (struct field)
        """
        if wb_kind == 1:
            val func_operand = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Int(0),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.unit(), is_variadic: false)))
            ))
            self.builder.emit_call(func_operand, [
                mir_operand_copy(wb_base),
                mir_operand_copy(wb_index),
                mir_operand_copy(wb_receiver)
            ], MirType.unit())
        else if wb_kind == 2:
            var b = self.builder
            b.emit_set_field(mir_operand_copy(wb_base), wb_field_idx, mir_operand_copy(wb_receiver))
            self.builder = b

    me lower_gpu_intrinsic_call(name: text, args: [HirCallArg]) -> LocalId:
        """Lower GPU intrinsic function call to MIR GPU instruction."""
        # Resolve dimension argument (default 0)
        val dim = if args.len() > 0:
            # Try to extract constant integer from the dimension argument
            val dim_expr = args[0].value
            match dim_expr.kind:
                case IntLit(value, _):
                    value
                case _:
                    # Non-constant dim: lower to MIR but use 0 as fallback
                    val dim_local = self.lower_expr(dim_expr)
                    0
        else:
            0

        var b = self.builder
        val dest = b.new_temp(MirType.i64())

        match name:
            case "gpu_global_id":
                b.emit(MirInst(kind: MirInstKind.GpuGlobalId(dest, dim), span: nil))
            case "gpu_local_id":
                b.emit(MirInst(kind: MirInstKind.GpuLocalId(dest, dim), span: nil))
            case "gpu_block_id":
                b.emit(MirInst(kind: MirInstKind.GpuBlockId(dest, dim), span: nil))
            case "gpu_block_dim":
                b.emit(MirInst(kind: MirInstKind.GpuBlockDim(dest, dim), span: nil))
            case "gpu_grid_dim":
                b.emit(MirInst(kind: MirInstKind.GpuGridDim(dest, dim), span: nil))
            case "gpu_sync" | "gpu_barrier":
                b.emit(MirInst(kind: MirInstKind.GpuBarrier(GpuBarrierScope.Workgroup), span: nil))
            case "gpu_mem_fence":
                b.emit(MirInst(kind: MirInstKind.GpuMemFence(GpuMemoryScope.Workgroup), span: nil))
            case "gpu_atomic_cas":
                # Compare-and-swap: gpu_atomic_cas(ptr, expected, desired)
                self.builder = b
                if args.len() >= 3:
                    val ptr_local = self.lower_expr(args[0].value)
                    val expected_local = self.lower_expr(args[1].value)
                    val desired_local = self.lower_expr(args[2].value)
                    var b_cas = self.builder
                    val cas_dest = b_cas.new_temp(MirType.i64())
                    b_cas.emit(MirInst(kind: MirInstKind.GpuAtomicCas(cas_dest, mir_operand_copy(ptr_local), mir_operand_copy(expected_local), mir_operand_copy(desired_local)), span: nil))
                    self.builder = b_cas
                    return cas_dest
                else:
                    var b_cas2 = self.builder
                    b_cas2.emit_comment("gpu_atomic_cas requires 3 args (ptr, expected, desired)")
                    self.builder = b_cas2
                    return dest
            case _:
                # Atomic ops and others — fall through to regular call
                self.builder = b
                var arg_operands: [MirOperand] = []
                for arg in args:
                    val arg_local = self.lower_expr(arg.value)
                    arg_operands = arg_operands.push(mir_operand_copy(arg_local))
                val func_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str(name),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b2 = self.builder
                val call_result = b2.emit_call(func_op, arg_operands, MirType.i64())
                self.builder = b2
                if call_result.?:
                    return call_result.unwrap()
                else:
                    return dest

        self.builder = b
        dest

    me symbol_to_operand(symbol: SymbolId) -> MirOperand:
        """Convert a symbol to a function pointer operand."""
        # Look up function name from symbol table for direct calls
        val sym = self.symbols.get(symbol)
        val name = if sym.?: sym.name else: "unknown_{symbol.id}"
        MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str(name),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))

    me lower_array_lit(elements: [HirExpr]) -> LocalId:
        """Lower array literal."""
        var operands: [MirOperand] = []
        for elem in elements:
            val local = self.lower_expr(elem)
            operands = operands.push(mir_operand_copy(local))

        val elem_type = if elements.len() > 0 and elements[0].type_.?:
            self.lower_type(elements[0].type_.unwrap())
        else:
            MirType.i64()
        val array_type = MirType(kind: MirTypeKind.Array(elem_type, elements.len()))

        self.builder.emit_aggregate(
            AggregateKind.Array(elem_type),
            operands,
            array_type
        )

    me lower_tuple_lit(elements: [HirExpr]) -> LocalId:
        """Lower tuple literal."""
        var operands: [MirOperand] = []
        var types: [MirType] = []
        for elem in elements:
            val local = self.lower_expr(elem)
            operands = operands.push(mir_operand_copy(local))
            val elem_ty = if elem.type_.?:
                self.lower_type(elem.type_.unwrap())
            else:
                MirType.i64()
            types = types.push(elem_ty)

        val tuple_type = MirType(kind: MirTypeKind.Tuple(types))
        self.builder.emit_aggregate(AggregateKind.Tuple, operands, tuple_type)

    me lower_set_lit(elements: [HirExpr]) -> LocalId:
        """Lower set literal to Set.from() call.

        Transforms: s{1, 2, 3}
        Into: Set.from([1, 2, 3])

        This is simpler than Set.new() + insert() and works with current runtime.
        Future optimization: emit direct Set.new() + insert() calls.
        """
        # Infer element type from first element, or default to i64
        val elem_type = if elements.len() > 0 and elements[0].type_.?:
            self.lower_type(elements[0].type_.unwrap())
        else:
            MirType.i64()

        # Lower elements to array literal
        var elem_operands: [MirOperand] = []
        for elem in elements:
            val elem_local = self.lower_expr(elem)
            elem_operands = elem_operands.push(mir_operand_copy(elem_local))

        # Create array from elements
        val array_type = MirType(kind: MirTypeKind.Array(elem_type, elements.len()))
        val array_local = self.builder.emit_aggregate(
            AggregateKind.Array(elem_type),
            elem_operands,
            array_type
        )

        # Call Set.from(array) - using runtime function placeholder
        # In a real implementation, this would resolve Set.from symbol from symbol table
        # For now, create a function operand that will be resolved by codegen
        val set_from_operand = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Int(0),  # Placeholder - codegen will resolve "Set.from"
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [array_type],
                return_type: MirType(kind: MirTypeKind.Named("Set", [elem_type])),
                is_variadic: false
            )))
        ))

        val set_type = MirType(kind: MirTypeKind.Named("Set", [elem_type]))
        val result = self.builder.emit_call(
            set_from_operand,
            [mir_operand_copy(array_local)],
            set_type
        )

        result ?? self.builder.new_temp(set_type)

    me lower_const_expr(expr: HirExpr) -> MirConstValue?:
        """Lower constant expression."""
        match expr.kind:
            case IntLit(value, _):
                Some(MirConstValue.Int(value))
            case FloatLit(value, _):
                Some(MirConstValue.Float(value))
            case BoolLit(value):
                Some(MirConstValue.Bool(value))
            case StringLit(value, _):
                Some(MirConstValue.Str(value))
            case _:
                nil

# ============================================================================
# Exports
# ============================================================================

# Methods are attached to MirLowering via impl block above.
# No separate exports needed -- they are accessed through MirLowering instances.
