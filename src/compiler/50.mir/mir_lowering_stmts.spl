# MIR Lowering - Statement and Control Flow Lowering
#
# Statement and control flow lowering from HIR to MIR:
# - Statement lowering (let, assign, expr, block, asm assert)
# - Assignment lowering (variable, field, index)
# - If/else lowering to basic blocks
# - Loop, while, for lowering with break/continue
# - Range-based and iterator-based for loop lowering

use compiler.mir.mir_data.*
use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.common.diagnostics.span.{Span}
use compiler.mir.mir_lowering_types.{MirLowering, MirError}

extern fn rt_enum_discriminant(value: HirStmtKind) -> i64

fn mir_stmt_symbol_id_value(symbol: SymbolId) -> i64:
    symbol.id

fn mir_stmt_local_id_value(local: LocalId) -> i64:
    local.id

fn mir_hir_stmt_kind_disc(k: HirStmtKind) -> i64:
    rt_enum_discriminant(k)

# ============================================================================
# Statement Lowering
# ============================================================================

impl MirLowering:
    me local_mir_type_of(local: LocalId) -> MirType?:
        """Look up a local's registered MIR type (mirrors the scan in
        local_is_runtime_array). Used to thread a runtime-array initializer's
        real Array/Slice type onto an un-annotated `var xs = [...]` binding,
        instead of the i64 default that would send later `xs[i]` reads down the
        wrong raw-GEP path (they must take rt_array_get)."""
        var local_i = 0
        while local_i < self.builder.locals.len():
            val item = self.builder.locals[local_i]
            if item.id.id == local.id:
                return Some(item.type_)
            local_i = local_i + 1
        nil

    fn local_is_float(local: LocalId) -> bool:
        """True when a lowered local holds a native float value (F32/F64).

        Keyed off the MIR local type (mirrors local_is_str/local_mir_type_of)
        because the inferred HIR `let_type` for `val y = x * 4.0` is
        unreliably a non-nil i64 on this path. Without threading the real
        F64/F32 type onto the binding, its spill slot is alloca'd i64 and the
        float round-trips through an i64 store (10.0 -> 10)."""
        var local_i = 0
        while local_i < self.builder.locals.len():
            val item = self.builder.locals[local_i]
            if item.id.id == local.id:
                match item.type_.kind:
                    case MirTypeKind.F32: return true
                    case MirTypeKind.F64: return true
                    case _: return false
            local_i = local_i + 1
        false

    fn local_is_unit(local: LocalId) -> bool:
        """True when a lowered local's registered MIR type is Unit -- e.g. the
        placeholder result of a void statement like `print "x"` used as a
        block's trailing "value" (bootstrap print lowering always returns a
        LocalId even though the call itself has no result). Unit maps to LLVM
        `void` (llvm_type_mapper map_type), and `void` is not a legal alloca /
        load / store operand type -- only a legal function return type. Used
        by lower_if to skip copying such a placeholder into the (always-i64)
        merge-result slot, which otherwise forces the backend to materialize
        an `alloca void` for the arm's placeholder (see bug doc
        native_if_print_only_arms_alloca_void_2026-07-11.md)."""
        match self.local_mir_type_of(local):
            case Some(t):
                match t.kind:
                    case MirTypeKind.Unit: true
                    case _: false
            case nil: false

    me lower_stmt(stmt: HirStmt):
        """Lower HIR statement to MIR."""
        # NOTE: previously declared `val stmt_kind: HirStmtKind` / `val
        # stmt_span: Span` without an initializer and assigned them inside
        # the `case HirStmt(kind, span):` arm below, then matched on
        # stmt_kind in a SECOND, separate match statement. That pattern was
        # found to be broken in the interpreter: stmt_kind ends up bound to
        # an unresolved placeholder that matches no real HirStmtKind
        # pattern, so every statement silently fell through to the
        # catch-all no-op arm (confirmed by isolated repro -- see
        # doc/08_tracking/bug/vhdl_backend_spec_remaining_failures_2026-07-02.md).
        # Fixed by nesting the stmt_kind match directly inside the
        # HirStmt(kind, span) arm instead of round-tripping through
        # pre-declared, later-assigned `val`s.
        match stmt:
            case _:
                val span: Span = stmt.span
                val stmt_kind_value: HirStmtKind = stmt.kind
                val fallback_type = HirType(kind: HirTypeKind.Unit, span: Span.empty())
                val fallback_expr = HirExpr(kind: HirExprKind.NilLit, has_type_: true, type_: fallback_type, span: span)
                val let_disc = mir_hir_stmt_kind_disc(HirStmtKind.Let(SymbolId(id: -1), fallback_type, fallback_expr))
                if mir_hir_stmt_kind_disc(stmt_kind_value) == let_disc:
                    val let_symbol = match stmt_kind_value:
                        case HirStmtKind.Let(symbol, _, _):
                            if symbol != nil:
                                Some(symbol)
                            else:
                                nil
                        case _:
                            nil
                    val let_type = match stmt_kind_value:
                        case HirStmtKind.Let(_, type_, _):
                            type_
                        case _:
                            nil
                    val let_init = match stmt_kind_value:
                        case HirStmtKind.Let(_, _, init):
                            init
                        case _:
                            fallback_expr

                    if let_symbol.?:
                        val symbol_value = let_symbol ?? SymbolId(id: -1)
                        val symbol_value_id = mir_stmt_symbol_id_value(symbol_value)
                        if symbol_value_id < 0:
                            self.error("let binding has no resolved symbol", Some(span))
                            return
                        # `val f = \x: ...` -- keep the existing bind-time
                        # capture snapshot, and materialize non-capturing lambdas
                        # through the same lifted FuncPtr used for lambda args.
                        val is_lambda_bind = match let_init.kind:
                            case Lambda(_, _, _):
                                true
                            case _:
                                false
                        if is_lambda_bind:
                            self.lambda_bindings[symbol_value_id] = let_init
                            # By-value capture (match oracle semantics): freeze
                            # each free variable's CURRENT value into a new temp
                            # local NOW, at bind time (see
                            # snapshot_lambda_capture in switch_operators_calls.spl),
                            # so a later mutation of a captured outer `var` (which
                            # this pipeline's MIR mutates in place, not via SSA
                            # renaming) does not leak into calls of this lambda.
                            self.lambda_capture_snapshot[symbol_value_id] = self.snapshot_lambda_capture(let_init)
                            val lambda_operand = self.lower_lambda_value(let_init)
                            if lambda_operand != nil:
                                val lifted_lambda = lambda_operand.unwrap()
                                match lifted_lambda.kind:
                                    case Const(_, lambda_type):
                                        var lambda_builder = self.builder
                                        val lambda_local = lambda_builder.emit_cast(lifted_lambda, lambda_type)
                                        self.builder = lambda_builder
                                        self.local_map[symbol_value_id] = lambda_local
                                    case Copy(lambda_local) | Move(lambda_local):
                                        self.local_map[symbol_value_id] = lambda_local
                                    case _:
                                        pass
                            return
                        val mir_type = match let_type:
                            case Some(type_value):
                                self.lower_type(type_value)
                            case nil:
                                MirType.i64()

                        var init_local = self.lower_expr(let_init)
                        val annotated_narrow_int = match mir_type.kind:
                            case MirTypeKind.I8 | MirTypeKind.U8 | MirTypeKind.I16 | MirTypeKind.U16 | MirTypeKind.I32 | MirTypeKind.U32: true
                            case _: false
                        val annotated_float = match mir_type.kind:
                            case MirTypeKind.F32 | MirTypeKind.F64: true
                            case _: false
                        if let_type != nil and (annotated_narrow_int or annotated_float):
                            var cast_builder = self.builder
                            init_local = cast_builder.emit_cast(mir_operand_copy(init_local), mir_type)
                            self.builder = cast_builder
                        val init_local_id = mir_stmt_local_id_value(init_local)
                        if init_local_id < 0:
                            self.error("let initializer produced no local", Some(span))
                            return
                        # Without an explicit annotation (`var xs = [...]`),
                        # mir_type defaulted to i64, so `xs` lost the array type
                        # and later `xs[i]` reads took the wrong raw-GEP path
                        # (local_is_runtime_array checks THIS binding's MIR kind).
                        # Thread the initializer's real Array/Slice type onto the
                        # binding instead. Copy is unchanged (a runtime array is a
                        # pointer; translate_copy_move keys off the source local),
                        # so value semantics are preserved -- only the read-path
                        # decision is corrected.
                        # Same preservation for a string binding (`val c = a + b`):
                        # a `+` concat produces a string temp (Opaque str) but the
                        # binding's HIR type is nil / a non-string arithmetic type,
                        # so mir_type defaulted to i64 and `c` lost its string type
                        # -- a later `c.len` then took the struct get_field path
                        # (reading the first byte / nil-deref -> SIGSEGV) instead
                        # of rt_strlen. When the initializer is a real string
                        # value, thread its string MIR type onto the binding
                        # regardless of the (unreliable) inferred let_type.
                        # Same preservation for a float binding (`val y = x * 4.0`):
                        # the inferred let_type is unreliably non-nil (i64) on this
                        # path, so mir_type defaulted to i64, the binding's SSA
                        # spill slot was alloca'd i64, and the f64 value
                        # round-tripped through fptosi/store i64 (10.0 -> 10),
                        # degrading later comparisons to icmp on truncated ints.
                        # When the initializer is a real float value, thread its
                        # F64/F32 MIR type onto the binding (same rationale as the
                        # string case above).
                        #
                        # Bug #138: the array case above was gated on
                        # `let_type == nil`, unlike its str/float siblings just
                        # below (which thread unconditionally) -- but
                        # `val all_args = get_cli_args()` (a call returning
                        # `[text]`) gets a non-nil-but-wrong synthesized
                        # `let_type` (the HirTypeKind.Infer -> i64 default noted
                        # throughout this file), same as the str/float cases'
                        # "unreliably non-nil" HIR type. That left `all_args`
                        # bound as plain i64, so `all_args[i]` took the raw-GEP
                        # path instead of rt_array_get -- reading raw bytes off
                        # the SplArray header as if they were an element, then
                        # feeding that garbage i64 to rt_len/rt_string_starts_with
                        # as a tagged handle (SIGSEGV). Thread unconditionally,
                        # matching str/float.
                        val effective_type = if self.local_is_runtime_array(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else if self.local_is_runtime_dict(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else if self.local_is_str(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else if self.local_is_float(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else:
                            mir_type
                        val bf_sym = self.bitfield_value_syms.get(init_local_id)
                        # Struct values are pointer-represented; alias the binding
                        # straight to the constructed local (like the bitfield
                        # pass-through) so struct_value_syms (keyed by that local's
                        # .id) stays valid for a later `p.x` field read.
                        val struct_sym = self.struct_value_syms.get(init_local.id)
                        if bf_sym != nil or struct_sym != nil:
                            self.bind_local(symbol_value_id, init_local)
                        else:
                            var b = self.builder
                            val local = b.new_local(nil, effective_type, LocalKind.Var)
                            self.builder = b
                            self.bind_local(symbol_value_id, local)
                            if self.runtime_array_locals.has(init_local.id):
                                self.runtime_array_locals[local.id] = true
                            if self.runtime_dict_locals.has(init_local.id):
                                self.runtime_dict_locals[local.id] = true
                            if self.runtime_value_locals.has(init_local.id):
                                self.runtime_value_locals[local.id] = true
                            if self.nil_locals.has(init_local.id):
                                self.nil_locals[local.id] = true
                            # Bug (array-of-structs field misread), CONFLICT-FLAG
                            # (mir_lowering_stmts.spl is fenced, touched per the
                            # fence rule's "CONFLICT-FLAG if must touch"
                            # allowance): array_element_struct_syms (see
                            # lower_array_lit / expr_dispatch.spl's Index case)
                            # must propagate the SAME way runtime_array_locals
                            # does above -- otherwise `val pts = [Point(...),
                            # ...]` rebinds the array literal's result to a NEW
                            # local id that has no entry in
                            # array_element_struct_syms, silently losing the
                            # element struct name and reverting `pts[i].y` to
                            # the field-index-0 misread this fix exists to stop.
                            val ael_sym = self.array_element_struct_syms.get(init_local.id)
                            if ael_sym != nil:
                                val ael_name = ael_sym ?? ""
                                if ael_name != "":
                                    self.array_element_struct_syms[local.id] = ael_name
                            var b2 = self.builder
                            b2.emit_copy(local, init_local)
                            self.builder = b2
                    else:
                        self.error("let binding has no resolved symbol", Some(span))
                    return

                match stmt_kind_value:
                    case HirStmtKind.Expr(extracted_expr):
                        val expr: HirExpr = extracted_expr
                        self.lower_expr(expr)

                    case Let(symbol, type_, init):
                        val symbol_id = mir_stmt_symbol_id_value(symbol)
                        if symbol_id < 0:
                            self.error("let binding has no resolved symbol", Some(span))
                            return
                        # NOTE: avoid Option.map()/.unwrap() and `if val ...`
                        # here -- the seed interpreter mishandles both on a
                        # "present" struct optional. `type_` is nil for any
                        # `val x = ...` without an explicit type annotation;
                        # the direct match keeps that nil from reaching
                        # lower_type and tripping a `.kind` read on nil.
                        val mir_type = match type_:
                            case Some(type_value):
                                self.lower_type(type_value)
                            case nil:
                                MirType.i64()

                        # Lower the initializer first so a bitfield-construct
                        # pass-through can be aliased directly, without first
                        # materializing an intermediate I64 local.
                        var has_init = false
                        var init_local = LocalId(id: 0)
                        if val init_expr = init:
                            init_local = self.lower_expr(init_expr)
                            has_init = true

                        # Bitfield construction (`val inst = BitfieldType(raw)`)
                        # is a bit-identical identity pass-through: alias the
                        # binding straight to the source local instead of
                        # emitting a fresh I64 temp + Copy, so downstream slices
                        # read the source signal directly (imem_rdata(6 downto 0),
                        # not sig_N(6 downto 0)). bitfield_value_syms is only
                        # populated for real bitfield types, so non-bitfield
                        # code always takes the ordinary new_local + Copy path.
                        # `i64?`/`text?` are shared (Option/heap) types, so the
                        # W1003 mut-capability checker forbids reassigning a `var`
                        # of these types. Compute the initializer's local id once
                        # into a plain-i64 var (not a shared type, so a var-i64
                        # reassignment is allowed) and then bind bf_sym/struct_sym
                        # exactly once as `val`.
                        var init_local_id: i64 = -1
                        if has_init:
                            init_local_id = mir_stmt_local_id_value(init_local)
                            if init_local_id < 0:
                                self.error("let initializer produced no local", Some(span))
                                return
                        val bf_sym: i64? = if has_init: self.bitfield_value_syms.get(init_local_id) else: nil
                        # Struct values are pointer-represented; aliasing the
                        # binding straight to the constructed local (like the
                        # bitfield pass-through) keeps struct_value_syms (keyed
                        # by the constructed local's .id) valid so a later
                        # `p.x` field read can recover the field ordering.
                        # Key on init_local.id directly to match how
                        # lower_struct_construct writes the map.
                        val struct_sym: text? = if has_init: self.struct_value_syms.get(init_local.id) else: nil
                        # See the disc==1 early-Let path: a `val`/`var xs = ...`
                        # must inherit the initializer's real Array/Slice type
                        # (unconditionally -- a non-nil-but-Infer-defaulted
                        # `type_` is as unreliable as a nil one, see Bug #138)
                        # so later `xs[i]` reads take rt_array_get instead of a
                        # raw GEP. (This arm is dead for Let today -- disc==1
                        # handles it above -- but kept in sync so the two paths
                        # cannot silently diverge.)
                        val effective_type = if has_init and self.local_is_runtime_array(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else if has_init and self.local_is_runtime_dict(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else if has_init and self.local_is_float(init_local):
                            self.local_mir_type_of(init_local) ?? mir_type
                        else:
                            mir_type
                        if bf_sym != nil or struct_sym != nil:
                            self.bind_local(symbol_id, init_local)
                        else:
                            var b = self.builder
                            val local = b.new_local(nil, effective_type, LocalKind.Var)
                            self.builder = b
                            self.bind_local(symbol_id, local)
                            if has_init and self.runtime_array_locals.has(init_local.id):
                                self.runtime_array_locals[local.id] = true
                            if has_init and self.runtime_dict_locals.has(init_local.id):
                                self.runtime_dict_locals[local.id] = true
                            if has_init and self.runtime_value_locals.has(init_local.id):
                                self.runtime_value_locals[local.id] = true
                            if has_init and self.nil_locals.has(init_local.id):
                                self.nil_locals[local.id] = true
                            # Bug (array-of-structs field misread), CONFLICT-FLAG
                            # (mir_lowering_stmts.spl is fenced): mirror the same
                            # array_element_struct_syms propagation as the other
                            # Let-lowering arm above, so `val pts = [Point(...),
                            # ...]` (this Let path) doesn't lose the element
                            # struct name when it rebinds to a fresh local id.
                            if has_init:
                                val ael_sym2 = self.array_element_struct_syms.get(init_local.id)
                                if ael_sym2 != nil:
                                    val ael_name2 = ael_sym2 ?? ""
                                    if ael_name2 != "":
                                        self.array_element_struct_syms[local.id] = ael_name2
                            if has_init:
                                var b2 = self.builder
                                b2.emit_copy(local, init_local)
                                self.builder = b2

                    case Assign(target, op, value):
                        val value_local = self.lower_expr(value)
                        self.lower_assign(target, op, value_local)

                    case Block(block):
                        self.lower_block(block)

                    case AsmAssert(spec):
                        self.lower_asm_assert(spec, span)

                    case _:
                        ()

    me lower_assign_var(symbol_id: i64, op: HirAssignOp?, value_local: LocalId, span: Span):
        """Emit the write-back for an assignment to a local variable target
        (shared by the `Var` and `NamedVar` lvalue cases)."""
        if symbol_id < 0:
            self.error("assignment target has no resolved symbol", Some(span))
        elif self.global_symbol_ids.has(symbol_id) and self.find_global_static(symbol_id).?:
            # mutglobal2 lane (module-level `var` mutation end-to-end, see
            # scratchpad/mutglobal_plan.md + scratchpad/mutglobal2 report):
            # `g = ...` / `g += ...` where `g` is a module-level `var`
            # (registered by function_lowering.spl's `lower_const`, BEFORE
            # any function body is lowered) has no per-function SSA local at
            # all -- write through the backend's real `@g_name` global
            # storage via `StoreGlobal` instead of the local_map's
            # emit_copy/alloca path below. Checked BEFORE `local_map` on
            # purpose: a module-level `var` is deliberately never also
            # inserted into `local_map` (see the read hook in
            # expr_dispatch.spl), so the two branches are mutually exclusive
            # for any given symbol_id; order here is not load-bearing today,
            # only documents that a global write must never fall through to
            # the per-function-local path.
            #
            # `elif val x = opt:` is NOT used here on purpose: this exact
            # pattern regressed the smoke matrix's `while_sum`/`for_in_array`
            # cases (2 failures, "undefined field 'symbol': cannot access
            # field on value of type 'nil'") -- an ordinary LOCAL loop
            # counter's `symbol_id` makes `find_global_static` return a bare
            # `nil` (not a real module global), but the seed interpreter's
            # `if val <pat> = <optional>`/`elif val` presence check can still
            # enter the "true" branch with the bound value nil (the same
            # documented quirk as the `op.?`/`if val assign_op = op` note
            # just below, and Bug native_i64opt_some0_collapses_to_nil's
            # class of issue) -- `global_static.symbol` on that nil then
            # crashed. The explicit `.has(...)`/`.? ` + `.unwrap()` sequence
            # below never touches that unsafe pattern.
            val global_static = self.find_global_static(symbol_id).unwrap()
            val global_symbol = global_static.symbol
            val g_type = global_static.type_
            if op.?:
                # Compound assignment (g += y etc.): load current value,
                # combine, store back -- mirrors the local_map compound-
                # assign arm below, but through Load/StoreGlobal.
                val assign_op = op.unwrap()
                var b_cur = self.builder
                val cur_local = b_cur.new_temp(g_type)
                b_cur.emit(MirInst(kind: MirInstKind.LoadGlobal(cur_local, global_symbol), span: Some(span)))
                self.builder = b_cur
                val current = mir_operand_copy(cur_local)
                val new_val = mir_operand_copy(value_local)
                val mir_op = self.lower_assign_op(assign_op)
                var b_op = self.builder
                val result = b_op.emit_binop(mir_op, current, new_val, g_type)
                b_op.emit(MirInst(kind: MirInstKind.StoreGlobal(global_symbol, mir_operand_copy(result)), span: Some(span)))
                self.builder = b_op
            else:
                var b_store = self.builder
                b_store.emit(MirInst(kind: MirInstKind.StoreGlobal(global_symbol, mir_operand_copy(value_local)), span: Some(span)))
                self.builder = b_store
        else:
            val local = self.find_local(symbol_id)
            if local.id < 0:
                self.error("assignment target is not a local", Some(span))
                return
            # Use the positive `op.?` presence test, NOT `if val assign_op = op`:
            # the seed interpreter's `if val <pat> = <optional>` presence check
            # can wrongly enter the true branch when the optional is nil (the
            # documented `if val`/`if not x.?` quirk), which turned a plain
            # `x = x + 1` (op == nil) into a spurious compound `x + (x + 1)`.
            if op.?:
                # Compound assignment (x += y etc.)
                val assign_op = op.unwrap()
                val current = mir_operand_copy(local)
                val new_val = mir_operand_copy(value_local)
                val mir_op = self.lower_assign_op(assign_op)
                var b = self.builder
                val result = b.emit_binop(mir_op, current, new_val, MirType.i64())
                b.emit_copy(local, result)
                self.builder = b
                self.runtime_value_locals = self.runtime_value_locals.remove(local.id)
                self.nil_locals = self.nil_locals.remove(local.id)
                self.runtime_array_locals = self.runtime_array_locals.remove(local.id)
                self.runtime_dict_locals = self.runtime_dict_locals.remove(local.id)
            else:
                var b = self.builder
                b.emit_copy(local, value_local)
                self.builder = b
                if self.runtime_value_locals.has(value_local.id):
                    self.runtime_value_locals[local.id] = true
                else:
                    self.runtime_value_locals = self.runtime_value_locals.remove(local.id)
                if self.runtime_array_locals.has(value_local.id):
                    self.runtime_array_locals[local.id] = true
                else:
                    self.runtime_array_locals = self.runtime_array_locals.remove(local.id)
                if self.runtime_dict_locals.has(value_local.id):
                    self.runtime_dict_locals[local.id] = true
                else:
                    self.runtime_dict_locals = self.runtime_dict_locals.remove(local.id)
                if self.nil_locals.has(value_local.id):
                    self.nil_locals[local.id] = true
                else:
                    self.nil_locals = self.nil_locals.remove(local.id)
                # Bug (array-of-structs field misread), CONFLICT-FLAG
                # (mir_lowering_stmts.spl is fenced): a `var`-reassignment
                # (`pts = pts.push(...)`, etc.) must carry
                # array_element_struct_syms forward the same way
                # runtime_array_locals does above, or a reassigned
                # array-of-structs variable loses its element struct name.
                if self.array_element_struct_syms.has(value_local.id):
                    self.array_element_struct_syms[local.id] = self.array_element_struct_syms[value_local.id]
                else:
                    self.array_element_struct_syms = self.array_element_struct_syms.remove(local.id)

    me lower_assign(target: HirExpr, op: HirAssignOp?, value_local: LocalId):
        """Lower assignment."""
        match target.kind:
            case Var(symbol):
                self.lower_assign_var(mir_stmt_symbol_id_value(symbol), op, value_local, target.span)

            case NamedVar(symbol, name):
                # HIR lowering emits NamedVar(symbol, name) for every resolved
                # identifier (see expr_dispatch `case NamedVar`). The assignment
                # lvalue path only handled the name-less Var(symbol) variant, so
                # `x = ...` where the target is a NamedVar fell through to the
                # catch-all and the write-back Copy was silently dropped --
                # loop-carried updates (`i = i + 1`) were lost, producing
                # non-terminating loops on the native path. Mirror the Var arm.
                self.lower_assign_var(mir_stmt_symbol_id_value(symbol), op, value_local, target.span)

            case Field(base, field, resolved):
                # Field assignment: obj.field = value
                val receiver = self.lower_expr(base)
                val bitfield_value = self.try_lower_bitfield_set(base, receiver, field, value_local)
                if val bitfield_local = bitfield_value:
                    var bitfield_b = self.builder
                    bitfield_b.emit_copy(receiver, bitfield_local)
                    self.builder = bitfield_b
                    return
                val field_index = self.resolve_field_index(base, receiver, field, resolved)
                var b = self.builder
                b.emit_set_field(mir_operand_copy(receiver), field_index, mir_operand_copy(value_local))
                self.builder = b

            case Index(base, index):
                # Index assignment: arr[i] = value
                # Lower to runtime call: rt_array_set(arr, index, value)
                val receiver = self.lower_expr(base)
                # Dict handles insert via rt_dict_set with a tagged key, NOT the
                # raw rt_array_set/GEP path below (which treats the string key as
                # an element offset). Mirrors the dict getter in expr_dispatch.
                if self.local_is_runtime_dict(receiver):
                    val dict_key = self.lower_dict_key(index)
                    val boxed_value = self.box_runtime_value(value_local)
                    val dict_set_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_dict_set"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
                    ))
                    var b_dset = self.builder
                    b_dset.emit_call(dict_set_op, [mir_operand_copy(receiver), mir_operand_copy(dict_key), mir_operand_copy(boxed_value)], MirType.i64())
                    self.builder = b_dset
                    return
                val index_local = self.lower_expr(index)
                self.emit_bounds_check_for_index(base.type_, receiver, index_local)
                val boxed_value = self.box_runtime_value(value_local)

                # Create function operand for rt_array_set(ptr, i64, i64) -> void.
                # Mirror the rt_array_get callee shape (see expr_dispatch.spl
                # `case Index` getter): the callee MUST name the runtime symbol
                # via MirConstValue.Str, not the integer 0, or the store no-ops.
                val func_operand = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("rt_array_set"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.ptr(MirType.i64(), false), MirType.i64(), MirType.i64()], return_type: MirType.unit(), is_variadic: false)))
                ))

                # Emit call with no return value
                self.builder.emit_call(func_operand, [mir_operand_copy(receiver), mir_operand_copy(index_local), mir_operand_copy(boxed_value)], MirType.unit())

            case _:
                self.error("unsupported MIR assignment target: {target.kind}", nil)

    me lower_receiver_and_args(receiver: HirExpr, args: [HirCallArg]) -> [MirOperand]:
        """Lower receiver and arguments for method calls."""
        val receiver_local = self.lower_expr(receiver)
        var arg_operands: [MirOperand] = [mir_operand_copy(receiver_local)]
        for arg in args:
            val arg_local = self.lower_expr(arg.value)
            arg_operands = arg_operands.push(mir_operand_copy(arg_local))
        arg_operands

    me lower_assign_op(op: HirAssignOp) -> MirBinOp:
        """Convert assignment op to binary op."""
        match op:
            case Add: MirBinOp.Add
            case Sub: MirBinOp.Sub
            case Mul: MirBinOp.Mul
            case Div: MirBinOp.Div
            case Mod: MirBinOp.Rem
            case _: MirBinOp.Add

    me try_lower_bitfield_set(base: HirExpr, base_local: LocalId, field_name: text, value_local: LocalId) -> LocalId?:
        """Lower bitfield field writes before generic struct field assignment."""
        val sym_id = self.bitfield_type_sym_for(base, base_local)
        if sym_id < 0:
            return nil
        if not self.bitfield_map.has(sym_id):
            return nil

        val fields = self.bitfield_map[sym_id]
        var idx = 0
        while idx < fields.len():
            match fields[idx]:
                case HirBitfieldField(_, name, _, _, bit_width, bit_offset, is_reserved, _):
                    if name != field_name or is_reserved:
                        idx = idx + 1
                        continue
                    val total_width = self.bitfield_total_width(fields)
                    if self.current_has_vhdl_metadata and bit_offset == 0 and bit_width > 0 and total_width > bit_width:
                        var b = self.builder
                        val preserved_high = b.new_temp(MirType.bits(total_width - bit_width))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlSlice(
                                preserved_high,
                                mir_operand_copy(base_local),
                                total_width - 1,
                                bit_width
                            ),
                            span: nil
                        ))
                        val casted_new = b.emit_cast(mir_operand_copy(value_local), MirType.bits(bit_width))
                        val result = b.new_temp(MirType.bits(total_width))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlConcat(
                                result,
                                [mir_operand_copy(preserved_high), mir_operand_copy(casted_new)]
                            ),
                            span: nil
                        ))
                        self.builder = b
                        return Some(result)
                    elif self.current_has_vhdl_metadata and bit_offset + bit_width == total_width and bit_width > 0 and bit_offset > 0:
                        var b = self.builder
                        val casted_new = b.emit_cast(mir_operand_copy(value_local), MirType.bits(bit_width))
                        val preserved_low = b.new_temp(MirType.bits(bit_offset))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlSlice(
                                preserved_low,
                                mir_operand_copy(base_local),
                                bit_offset - 1,
                                0
                            ),
                            span: nil
                        ))
                        val result = b.new_temp(MirType.bits(total_width))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlConcat(
                                result,
                                [mir_operand_copy(casted_new), mir_operand_copy(preserved_low)]
                            ),
                            span: nil
                        ))
                        self.builder = b
                        return Some(result)
                    elif self.current_has_vhdl_metadata and bit_offset > 0 and bit_width > 0 and bit_offset + bit_width < total_width:
                        var b = self.builder
                        val high_width = total_width - (bit_offset + bit_width)
                        val preserved_high = b.new_temp(MirType.bits(high_width))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlSlice(
                                preserved_high,
                                mir_operand_copy(base_local),
                                total_width - 1,
                                bit_offset + bit_width
                            ),
                            span: nil
                        ))
                        val casted_new = b.emit_cast(mir_operand_copy(value_local), MirType.bits(bit_width))
                        val preserved_low = b.new_temp(MirType.bits(bit_offset))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlSlice(
                                preserved_low,
                                mir_operand_copy(base_local),
                                bit_offset - 1,
                                0
                            ),
                            span: nil
                        ))
                        val result = b.new_temp(MirType.bits(total_width))
                        b.emit(MirInst(
                            kind: MirInstKind.VhdlConcat(
                                result,
                                [mir_operand_copy(preserved_high), mir_operand_copy(casted_new), mir_operand_copy(preserved_low)]
                            ),
                            span: nil
                        ))
                        self.builder = b
                        return Some(result)

                    val mask = self.bitfield_field_mask(bit_width)
                    val shifted_mask = mask << bit_offset
                    var b = self.builder
                    val clear_mask_const = b.emit_const_int(~shifted_mask)
                    val cleared = b.emit_binop(
                        MirBinOp.BitAnd,
                        mir_operand_copy(base_local),
                        mir_operand_copy(clear_mask_const),
                        MirType.i64()
                    )
                    val mask_const = b.emit_const_int(mask)
                    val masked_new = b.emit_binop(
                        MirBinOp.BitAnd,
                        mir_operand_copy(value_local),
                        mir_operand_copy(mask_const),
                        MirType.i64()
                    )
                    val shifted_new = if bit_offset == 0:
                        masked_new
                    else:
                        val offset_const = b.emit_const_int(bit_offset)
                        b.emit_binop(
                            MirBinOp.Shl,
                            mir_operand_copy(masked_new),
                            mir_operand_copy(offset_const),
                            MirType.i64()
                        )
                    val result = b.emit_binop(
                        MirBinOp.BitOr,
                        mir_operand_copy(cleared),
                        mir_operand_copy(shifted_new),
                        MirType.i64()
                    )
                    self.builder = b
                    return Some(result)
            idx = idx + 1

        nil

# ============================================================================
# Control Flow Lowering
# ============================================================================

    me lower_if(cond: HirExpr, then_: HirBlock, else_: HirBlock?) -> LocalId:
        """Lower if expression."""
        val cond_local = self.lower_expr(cond)

        var b = self.builder
        val then_block = b.new_block(Some("then"))
        val else_block = b.new_block(Some("else"))
        val merge_block = b.new_block(Some("merge"))
        val result = b.new_temp(MirType.i64())
        b.terminate_if(mir_operand_copy(cond_local), then_block, else_block)
        self.builder = b

        # Then block
        var b2 = self.builder
        b2.switch_to_block(then_block)
        self.builder = b2
        val then_result = self.lower_block(then_)
        var b3 = self.builder
        var result_defined = false
        if not b3.current_block_has_explicit_terminator():
            if val then_local = then_result:
                # A Unit-typed arm result (statement-form print, etc.) has no
                # real value to merge -- copying it into the i64 result slot
                # would force an `alloca void` in the backend. Leave
                # result_defined false; the merge block below falls back to
                # a const-0 def in that case.
                if not self.local_is_unit(then_local):
                    b3.emit_copy(result, then_local)
                    result_defined = true
            b3.terminate_goto(merge_block)
        self.builder = b3

        # Else block
        var b4 = self.builder
        b4.switch_to_block(else_block)
        self.builder = b4
        if val else_block_value = else_:
            val else_result = self.lower_block(else_block_value)
            var b5 = self.builder
            if not b5.current_block_has_explicit_terminator():
                if val else_local = else_result:
                    if not self.local_is_unit(else_local):
                        b5.emit_copy(result, else_local)
                        result_defined = true
                b5.terminate_goto(merge_block)
            self.builder = b5
        else:
            var b5 = self.builder
            b5.terminate_goto(merge_block)
            self.builder = b5

        # Merge block
        var b6 = self.builder
        b6.switch_to_block(merge_block)
        # The terminator guard skips emit_copy in arms that already returned;
        # if no arm defined result, the returned LocalId would be read while
        # undefined downstream (NULL llvm::Value* -> ICmp SIGSEGV in llvm-lib).
        # Define it in the merge block so every returned id has a def.
        if not result_defined:
            b6.emit_const(result, MirConstValue.Int(0), MirType.i64())
        self.builder = b6

        result

    me lower_loop(body: HirBlock) -> LocalId:
        """Lower loop expression."""
        var b = self.builder
        val loop_block = b.new_block(Some("loop"))
        val exit_block = b.new_block(Some("loop_exit"))
        self.builder = b

        self.loop_stack = self.loop_stack.push((loop_block, exit_block))

        var b2 = self.builder
        b2.terminate_goto(loop_block)
        b2.switch_to_block(loop_block)
        self.builder = b2

        self.lower_block(body)

        # If the body's last statement already terminated the current block
        # (an explicit break/continue/return with no trailing code), don't
        # add a second terminator -- doing so would silently overwrite it
        # (e.g. turning a trailing `break` into a backedge, making the loop
        # infinite). Mirrors the guard in lower_for.
        var b3 = self.builder
        if not b3.current_block_has_explicit_terminator():
            b3.terminate_goto(loop_block)
        self.builder = b3

        self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]

        var b4 = self.builder
        b4.switch_to_block(exit_block)
        val loop_result = b4.new_temp(MirType.unit())
        self.builder = b4
        loop_result

    me lower_while(cond: HirExpr, body: HirBlock) -> LocalId:
        """Lower while expression."""
        var b = self.builder
        val cond_block = b.new_block(Some("while_cond"))
        val body_block = b.new_block(Some("while_body"))
        val exit_block = b.new_block(Some("while_exit"))
        self.builder = b

        self.loop_stack = self.loop_stack.push((cond_block, exit_block))

        var b2 = self.builder
        b2.terminate_goto(cond_block)
        b2.switch_to_block(cond_block)
        self.builder = b2

        val cond_local = self.lower_expr(cond)
        var b3 = self.builder
        b3.terminate_if(mir_operand_copy(cond_local), body_block, exit_block)
        b3.switch_to_block(body_block)
        self.builder = b3

        self.lower_block(body)

        # If the body's last statement already terminated the current block
        # (an explicit break/continue/return with no trailing code), don't
        # add a second terminator -- doing so would silently overwrite it
        # (e.g. turning a trailing `break` into a backedge, making the loop
        # infinite -- #163: `while true:`/`loop:` + continue). Mirrors the
        # guard in lower_for.
        var b4 = self.builder
        if not b4.current_block_has_explicit_terminator():
            b4.terminate_goto(cond_block)
        self.builder = b4

        self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]

        var b5 = self.builder
        b5.switch_to_block(exit_block)
        val while_result = b5.new_temp(MirType.unit())
        self.builder = b5
        while_result

    me lower_for(var_: SymbolId, iter: HirExpr, body: HirBlock) -> LocalId:
        """Lower for expression.

        For range-based iteration (for x in start..end), lowers directly to
        a counted while-loop with an integer counter. This avoids the overhead
        of the full iterator protocol and produces simpler MIR that is easier
        to optimize (LICM, unrolling, strength reduction).

        For non-range iterables, falls back to the iterator protocol:
            val _iter = collection.iter()
            while _iter.has_next():
                val x = _iter.next()
                body
        """
        # Check if the iterable is a Range expression for direct lowering
        # NOTE: this arm was previously dead in practice for every native
        # `for i in start..end:` loop -- NOT because this match is broken,
        # but because the flat-AST bridge that feeds this pipeline
        # (_FlatAstBridge/convert_nodes.spl's convert_flat_expr) had no
        # EXPR_RANGE case, so `iter.kind` arrived here as ExprKind.NilLit
        # instead of a real Range and always fell to `case _`. That always
        # sent range-based for-loops into the generic iterator-protocol
        # fallback (lower_for_iterator), which panics with "for-in over
        # non-array iterables is not supported" for anything that isn't a
        # runtime array -- i.e. every native-build `for i in 0..N:` crashed
        # at runtime. Fixed at the source (convert_nodes.spl now builds
        # ExprKind.Range for EXPR_RANGE); this match itself needed no change
        # once the bridge fed it a real Range.
        match iter.kind:
            case Range(start, end, inclusive, step):
                return self.lower_for_range(var_, start, end, inclusive, step, body)
            case _:
                pass  # Fall through to iterator protocol

        # General case: iterator protocol lowering
        self.lower_for_iterator(var_, iter, body)

    me lower_for_range(
        var_: SymbolId,
        start: HirExpr?,
        end: HirExpr?,
        inclusive: bool,
        step: HirExpr?,
        body: HirBlock
    ) -> LocalId:
        """Lower range-based for loop directly to a counted while-loop.

        Lowers:
            for i in start..end:
                body

        Into:
            var i = start
            while i < end:   (or i <= end for inclusive)
                body
                i = i + step
        """
        # Derive loop counter type from bound HirExpr types before emitting any code.
        # This preserves u64 (and other non-i64 integer) counter types end-to-end.
        var loop_ty = MirType.i64()
        if val end_expr = end:
            match end_expr.type_:
                case Some(end_type):
                    loop_ty = self.lower_type(end_type)
                case nil:
                    ()
        elif val start_expr = start:
            match start_expr.type_:
                case Some(start_type):
                    loop_ty = self.lower_type(start_type)
                case nil:
                    ()

        # Lower start value (default to typed 0)
        var start_local: LocalId = 0
        if val start_expr = start:
            start_local = self.lower_expr(start_expr)
        else:
            var b = self.builder
            val temp = b.new_temp(loop_ty)
            b.emit_const(temp, MirConstValue.Int(0), loop_ty)
            self.builder = b
            start_local = temp

        # Lower end value (default to typed 0; open-ended ranges need the iterator path)
        var end_local: LocalId = 0
        if val end_expr = end:
            end_local = self.lower_expr(end_expr)
        else:
            var b = self.builder
            val temp = b.new_temp(loop_ty)
            b.emit_const(temp, MirConstValue.Int(0), loop_ty)
            self.builder = b
            end_local = temp

        # Lower step value (default to typed 1)
        var step_local: LocalId = 0
        if val step_expr = step:
            step_local = self.lower_expr(step_expr)
        else:
            var b = self.builder
            val temp = b.new_temp(loop_ty)
            b.emit_const(temp, MirConstValue.Int(1), loop_ty)
            self.builder = b
            step_local = temp

        # Create the loop counter variable (mutable)
        var b_init = self.builder
        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
        b_init.emit_copy(counter, start_local)
        self.builder = b_init

        # Bind loop variable to the counter
        val range_var_id = mir_stmt_symbol_id_value(var_)
        if range_var_id < 0:
            self.error("for range loop variable has no resolved symbol", Some(body.span))
        else:
            self.bind_local(range_var_id, counter)

        # Create loop blocks
        var b_blocks = self.builder
        val cond_block = b_blocks.new_block(Some("for_range_cond"))
        val body_block = b_blocks.new_block(Some("for_range_body"))
        val inc_block = b_blocks.new_block(Some("for_range_inc"))
        val exit_block = b_blocks.new_block(Some("for_range_exit"))
        self.builder = b_blocks

        # `continue` must target inc_block, not cond_block directly: the
        # counter increment (counter = counter + step) is compiler-
        # synthesized and must run on every iteration, including ones ended
        # early by `continue` -- otherwise the counter never advances and
        # the loop spins forever once a `continue` fires. Mirrors the fix
        # already applied to lower_for_array_indexed (see its loop_stack
        # push below for the same rationale).
        self.loop_stack = self.loop_stack.push((inc_block, exit_block))

        # Jump to condition check
        var b_goto = self.builder
        b_goto.terminate_goto(cond_block)
        b_goto.switch_to_block(cond_block)
        self.builder = b_goto

        # Condition: counter < end (or counter <= end for inclusive)
        val cmp_op = if inclusive: MirBinOp.Le else: MirBinOp.Lt
        var b_cond = self.builder
        val cond_result = b_cond.emit_binop(
            cmp_op,
            mir_operand_copy(counter),
            mir_operand_copy(end_local),
            MirType.bool()
        )
        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
        b_cond.switch_to_block(body_block)
        self.builder = b_cond

        # Lower the loop body
        self.lower_block(body)

        # If the body's last statement already terminated the current block
        # (an explicit break/continue/return with no trailing code), don't
        # add a second terminator here -- doing so would silently overwrite
        # it: e.g. a trailing `break`'s Goto(exit_block) or a `return`'s Ret
        # would be clobbered by this loop's own fall-through jump, turning
        # `break`/`return` into a plain backedge. Mirrors the guard already
        # used by lower_loop/lower_while/lower_for_array_indexed -- this
        # range-based for-loop was the one lowering missing it.
        var b_body_end = self.builder
        if not b_body_end.current_block_has_explicit_terminator():
            b_body_end.terminate_goto(inc_block)
        self.builder = b_body_end

        # Increment: counter = counter + step (also the `continue` target)
        var b_inc = self.builder
        b_inc.switch_to_block(inc_block)
        val incremented = b_inc.emit_binop(
            MirBinOp.Add,
            mir_operand_copy(counter),
            mir_operand_copy(step_local),
            loop_ty
        )
        b_inc.emit_copy(counter, incremented)
        self.builder = b_inc

        # Jump back to condition
        var b_back = self.builder
        b_back.terminate_goto(cond_block)
        self.builder = b_back

        # Exit block
        self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]
        var b_exit = self.builder
        b_exit.switch_to_block(exit_block)
        val for_result = b_exit.new_temp(MirType.unit())
        self.builder = b_exit
        for_result

    me lower_for_iterator(var_: SymbolId, iter: HirExpr, body: HirBlock) -> LocalId:
        """Lower `for x in collection` for non-range iterables.

        Runtime arrays lower to a real counted index loop (see
        lower_for_array_indexed). Any other iterable (dicts, custom
        iterators, ...) has no native iterator-protocol lowering yet (#143):
        the old stub emitted iter()/has_next()/next() calls through null
        function-pointer constants (Const Int(0) FuncPtr), which resolve to
        `call 0` and SIGSEGV natively. Instead of that, fail loudly: record a
        compile error AND emit an rt_panic call carrying the same message, so
        pipelines that drop MirLowering.errors (e.g. the native-build
        worker's lower_to_mir) still abort with a clear diagnostic at runtime
        rather than crashing on a null call.
        """
        # Step 1: Lower the iterable expression
        val collection_local = self.lower_expr(iter)
        var element_type = MirType.i64()
        if val loop_symbol = self.symbols.get_symbol(var_):
            match loop_symbol.type_:
                case Some(loop_symbol_type):
                    element_type = self.lower_type(loop_symbol_type)
                case nil:
                    ()

        # The loop-variable symbol's HIR type is frequently nil on this
        # pipeline (native-build's lower_to_mir runs without a full
        # type-inference pass), so `element_type` silently defaulted to i64
        # above for EVERY for-in loop whose loop var has no resolved type --
        # correct by accident for `for n in [1,2,3]` (ints really are i64),
        # but WRONG for `for s in ["ab","cd"]`: a string array element is a
        # TAGGED heap-string handle (see box_runtime_value/lower_array_lit),
        # and decoding it as i64 shifts/truncates the handle into garbage,
        # which downstream string method calls then dereference as if it
        # were a raw char* -> SIGSEGV or garbage output.
        #
        # The array/slice's OWN lowered MIR type is authoritative and always
        # populated at construction time (lower_array_lit sets
        # `Array(first_element's_mir_type, size)`), exactly like the direct
        # index-read path `arr[i]` already reads element type off
        # `base_mir_type.kind` (see expr_dispatch.spl `case Index`). Mirror
        # that here so `for x in arr` and `arr[i]` agree on the element type.
        if val coll_mir_type = self.local_mir_type_of(collection_local):
            match coll_mir_type.kind:
                case MirTypeKind.Array(elem_t, _):
                    element_type = elem_t
                case MirTypeKind.Slice(elem_t):
                    element_type = elem_t
                case _:
                    ()

        # Runtime-array fast path: lower `for x in arr` to an index-based
        # counted loop over rt_array_len / rt_array_get (mirrors the array
        # index-read call shape in _MirLoweringExpr/expr_dispatch.spl).
        if self.local_is_runtime_array(collection_local):
            return self.lower_for_array_indexed(var_, collection_local, element_type, body)

        # Non-array iterable: no supported lowering (#143). Fail loudly.
        val iter_unsupported_msg = "for-in over non-array iterables is not supported by native codegen yet (#143); iterate an array or use while"
        self.error(iter_unsupported_msg, Some(body.span))

        # Belt-and-braces for pipelines that never read MirLowering.errors:
        # emit `rt_panic(msg)` where the loop would have been. A MIR Str
        # const lowers to a NUL-terminated C-string pointer, matching
        # rt_panic(const char*). The loop body is intentionally not lowered.
        var b_panic = self.builder
        val panic_msg_local = b_panic.emit_const_str(iter_unsupported_msg)
        val panic_func_operand = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_panic"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.unit(), is_variadic: false)))
        ))
        b_panic.emit_call(panic_func_operand, [mir_operand_copy(panic_msg_local)], MirType.unit())
        val for_result = b_panic.new_temp(MirType.unit())
        self.builder = b_panic
        for_result

    me lower_for_array_indexed(
        var_: SymbolId,
        collection_local: LocalId,
        element_type: MirType,
        body: HirBlock
    ) -> LocalId:
        """Lower `for x in arr` over a runtime array as a counted index loop.

        Emits the equivalent of:
            var i = 0
            val n = rt_array_len(arr)
            while i < n:
                val x = rt_array_get(arr, i)
                body
                i = i + 1

        Uses the same rt_array_len / rt_array_get call shape as the array
        index-read lowering in _MirLoweringExpr/expr_dispatch.spl, avoiding the
        generic iterator protocol whose null-funcptr callees SIGSEGV natively.
        """
        val loop_ty = MirType.i64()

        # Length: n = rt_array_len(arr)
        val len_func = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_len"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_len = self.builder
        val len_call = b_len.emit_call(len_func, [mir_operand_copy(collection_local)], MirType.i64())
        var len_local: LocalId = 0
        if val len_value = len_call:
            len_local = len_value
        else:
            len_local = b_len.new_temp(MirType.i64())
        self.builder = b_len

        # Counter: var i = 0
        var b_init = self.builder
        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
        val zero = b_init.new_temp(loop_ty)
        b_init.emit_const(zero, MirConstValue.Int(0), loop_ty)
        b_init.emit_copy(counter, zero)
        # Step constant 1 (defined once, used in the increment block)
        val one = b_init.new_temp(loop_ty)
        b_init.emit_const(one, MirConstValue.Int(1), loop_ty)
        self.builder = b_init

        # Loop blocks
        var b_blocks = self.builder
        val cond_block = b_blocks.new_block(Some("for_arr_cond"))
        val body_block = b_blocks.new_block(Some("for_arr_body"))
        val inc_block = b_blocks.new_block(Some("for_arr_inc"))
        val exit_block = b_blocks.new_block(Some("for_arr_exit"))
        self.builder = b_blocks

        # `continue` must target the increment block, not cond_block directly:
        # this is a counted-index desugaring of `for x in arr`, so the counter
        # increment is compiler-synthesized and must run on every iteration
        # (including ones ended early by `continue`). Pointing continue at
        # cond_block skips the increment, so the counter never advances and the
        # loop spins forever once a `continue` fires.
        self.loop_stack = self.loop_stack.push((inc_block, exit_block))

        # Jump to condition check
        var b_goto = self.builder
        b_goto.terminate_goto(cond_block)
        b_goto.switch_to_block(cond_block)
        self.builder = b_goto

        # Condition: i < n
        var b_cond = self.builder
        val cond_result = b_cond.emit_binop(
            MirBinOp.Lt,
            mir_operand_copy(counter),
            mir_operand_copy(len_local),
            MirType.bool()
        )
        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
        b_cond.switch_to_block(body_block)
        self.builder = b_cond

        # Element: x = rt_array_get(arr, i)
        val get_func = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_get"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_get = self.builder
        val get_call = b_get.emit_call(
            get_func,
            [mir_operand_copy(collection_local), mir_operand_copy(counter)],
            MirType.i64()
        )
        var elem_local: LocalId = 0
        if val get_value = get_call:
            elem_local = get_value
        else:
            elem_local = b_get.new_temp(MirType.i64())
        self.builder = b_get

        # rt_array_get returns a TAGGED runtime value (value << 3 for small
        # ints, boxed handle otherwise). Decode it to the element's primitive
        # type before binding, exactly as the direct index-read path does
        # (decode_runtime_value in _MirLoweringExpr/expr_dispatch.spl). Without
        # this the loop variable stays tagged, so arithmetic and comparisons
        # against untagged literals are wrong (e.g. `x == 3` never matches a
        # tagged element, and `total + x` accumulates value<<3). Regression
        # introduced when array elements began carrying tagged runtime values.
        val decoded_elem = self.decode_runtime_value(elem_local, element_type)

        # Bind loop variable to the (decoded) element
        var b_bind = self.builder
        val loop_var = b_bind.new_local(nil, element_type, LocalKind.Var)
        b_bind.emit_copy(loop_var, decoded_elem)
        self.builder = b_bind
        val loop_var_id = mir_stmt_symbol_id_value(var_)
        if loop_var_id < 0:
            self.error("for loop variable has no resolved symbol", Some(body.span))
        else:
            self.bind_local(loop_var_id, loop_var)
            # Bug (array-of-structs field misread), CONFLICT-FLAG
            # (mir_lowering_stmts.spl is fenced): `for p in pts` over an
            # array of structs desugars to this counted-index loop, whose
            # decoded per-iteration element is a SEPARATE decode_runtime_value
            # call site from expr_dispatch.spl's Index case (which already
            # got the array_element_struct_syms -> struct_value_syms
            # propagation). Without the SAME propagation here, `p.y` inside
            # the loop body silently defaulted to field index 0 (reading
            # `.x`'s slot) exactly like the standalone `pts[i].y` bug this
            # lane fixed, just reached via the for-loop desugaring instead.
            val for_elem_struct_name = self.array_element_struct_syms.get(collection_local.id)
            if for_elem_struct_name != nil:
                val fesn = for_elem_struct_name ?? ""
                if fesn != "":
                    self.struct_value_syms[loop_var.id] = fesn

        # Lower the loop body
        self.lower_block(body)

        # Fall through into the increment block. If the body's last statement
        # already terminated the current block (an explicit break/continue/
        # return with no trailing code), don't add a second terminator -- let
        # that jump stand.
        var b_body_end = self.builder
        if not b_body_end.current_block_has_explicit_terminator():
            b_body_end.terminate_goto(inc_block)
        self.builder = b_body_end

        # Increment: i = i + 1 (also the `continue` target -- see loop_stack push)
        var b_inc = self.builder
        b_inc.switch_to_block(inc_block)
        val incremented = b_inc.emit_binop(
            MirBinOp.Add,
            mir_operand_copy(counter),
            mir_operand_copy(one),
            loop_ty
        )
        b_inc.emit_copy(counter, incremented)
        self.builder = b_inc

        # Jump back to condition
        var b_back = self.builder
        b_back.terminate_goto(cond_block)
        self.builder = b_back

        # Exit block
        self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]
        var b_exit = self.builder
        b_exit.switch_to_block(exit_block)
        val for_result = b_exit.new_temp(MirType.unit())
        self.builder = b_exit
        for_result

# ============================================================================
# Exports
# ============================================================================

# Methods are attached to MirLowering via impl block above.
# No separate exports needed -- they are accessed through MirLowering instances.
