# MIR Canonical Intrinsic Name Constants
#
# Canonical text identifiers for cipher and SIMD intrinsic operations
# used in MirInstKind.Intrinsic.  Shared by the pattern-idiom recogniser
# (60.mir_opt) and the backend lowering layer (70.backend/lowering/).
#
# Adding a new intrinsic:
#   1. Add a let constant here.
#   2. Add a TargetIdiom variant in 70.backend/feature_caps.spl.
#   3. Add a rule in 60.mir_opt/mir_opt/pattern/rules_crypto.spl.
#   4. Add a lowering case in 70.backend/lowering/intrinsic_lowering_*.spl.

# ============================================================================
# AES-NI / AES
# ============================================================================

"""Canonical name for AES forward mix-columns + ShiftRows round (AESENC)."""
val CRYPTO_AES_ROUND:          text = "crypto_aes_round"

"""Canonical name for AES final round without MixColumns (AESENCLAST)."""
val CRYPTO_AES_ROUND_LAST:     text = "crypto_aes_round_last"

"""Canonical name for AES inverse round (AESDEC)."""
val CRYPTO_AES_INV_ROUND:      text = "crypto_aes_inv_round"

"""Canonical name for AES inverse final round (AESDECLAST)."""
val CRYPTO_AES_INV_ROUND_LAST: text = "crypto_aes_inv_round_last"

"""Canonical name for AES inverse mix-columns (AESIMC)."""
val CRYPTO_AES_IMC:            text = "crypto_aes_imc"

"""Canonical name for AES key schedule assist (AESKEYGENASSIST)."""
val CRYPTO_AES_KEYGEN_ASSIST:  text = "crypto_aes_keygen_assist"

# ============================================================================
# SHA-256
# ============================================================================

"""Canonical name for SHA-256 two-round computation (SHA256RNDS2)."""
val CRYPTO_SHA256_RNDS2:       text = "crypto_sha256_rounds2"

"""Canonical name for SHA-256 message schedule word expand 1 (SHA256MSG1)."""
val CRYPTO_SHA256_MSG1:        text = "crypto_sha256_msg1"

"""Canonical name for SHA-256 message schedule word expand 2 (SHA256MSG2)."""
val CRYPTO_SHA256_MSG2:        text = "crypto_sha256_msg2"

# ============================================================================
# SHA-512
# ============================================================================

"""Canonical name for SHA-512 two-round computation (SHA512RNDS2)."""
val CRYPTO_SHA512_RNDS2:       text = "crypto_sha512_rnds2"

"""Canonical name for SHA-512 message schedule word expand 1 (SHA512MSG1)."""
val CRYPTO_SHA512_MSG1:        text = "crypto_sha512_msg1"

"""Canonical name for SHA-512 message schedule word expand 2 (SHA512MSG2)."""
val CRYPTO_SHA512_MSG2:        text = "crypto_sha512_msg2"

# ============================================================================
# CRC32 (SSE4.2 / AArch64 CRC extension)
# ============================================================================

"""Canonical name for CRC32 update with one byte (CRC32 r32, r/m8)."""
val CRC32_U8:                  text = "crc32_u8"

"""Canonical name for CRC32 update with a 32-bit word (CRC32 r32, r/m32)."""
val CRC32_U32:                 text = "crc32_u32"

"""Canonical name for CRC32 update with a 64-bit word (CRC32 r64, r/m64)."""
val CRC32_U64:                 text = "crc32_u64"

# ============================================================================
# Carry-less multiply (PCLMULQDQ / PMULL)
# ============================================================================

"""Canonical name for carry-less multiply low 64 bits (PCLMULQDQ imm8=0x00)."""
val CLMUL_LO:                  text = "clmul_lo"

"""Canonical name for carry-less multiply high 64 bits (PCLMULQDQ imm8=0x11)."""
val CLMUL_HI:                  text = "clmul_hi"

# ============================================================================
# Portable bit-manipulation intrinsics
# ============================================================================

"""Canonical name for rotate-left bit idiom (native rol/ror fallback family)."""
val BIT_ROTATE_LEFT:           text = "bit_rotate_left"

"""Canonical name for rotate-right bit idiom (native rol/ror fallback family)."""
val BIT_ROTATE_RIGHT:          text = "bit_rotate_right"

"""Canonical name for population count idiom."""
val BIT_POPCOUNT:              text = "bit_popcount"

"""Canonical name for count-leading-zeros idiom."""
val BIT_CLZ:                   text = "bit_clz"

"""Canonical name for count-trailing-zeros idiom."""
val BIT_CTZ:                   text = "bit_ctz"

"""Canonical name for byte-swap idiom."""
val BIT_BSWAP:                 text = "bit_bswap"

"""Canonical name for bit-reverse idiom."""
val BIT_BITREVERSE:            text = "bit_bitreverse"

"""Canonical name for bit-parity idiom (XOR-reduce / popcount & 1)."""
val BIT_PARITY:                text = "bit_parity"

"""Canonical name for carry-less multiply idiom used by GHASH/Poly1305 helpers."""
val CRYPTO_CLMUL:              text = "crypto_clmul"

# ============================================================================
# Matrix-kernel intrinsics
# ============================================================================

"""Canonical name for vectorizable dot-product micro-kernel."""
val MATRIX_DOT:                text = "matrix_dot"

"""Canonical name for vectorizable outer-product update micro-kernel."""
val MATRIX_OUTER_PRODUCT:      text = "matrix_outer_product"

"""Canonical name for blocked GEMM / FMA micro-kernel."""
val MATRIX_FMA_KERNEL:         text = "matrix_fma_kernel"

# ============================================================================
# Cipher intrinsic queries
# ============================================================================

fn cipher_intrinsic_arg_count(name: text) -> i64?:
    if name == CRYPTO_AES_ROUND or name == CRYPTO_AES_ROUND_LAST or name == CRYPTO_AES_INV_ROUND or name == CRYPTO_AES_INV_ROUND_LAST:
        return Some(2)
    if name == CRYPTO_AES_IMC:
        return Some(1)
    if name == CRYPTO_AES_KEYGEN_ASSIST:
        return Some(2)
    if name == CRYPTO_SHA256_RNDS2:
        return Some(3)
    if (name == CRYPTO_SHA256_MSG1 or name == CRYPTO_SHA256_MSG2):
        return Some(2)
    if (name == CRC32_U8 or name == CRC32_U32 or name == CRC32_U64):
        return Some(2)
    if (name == CLMUL_LO or name == CLMUL_HI):
        return Some(2)
    nil

fn is_cipher_intrinsic(name: text) -> bool:
    cipher_intrinsic_arg_count(name).? == true

export CRYPTO_AES_ROUND, CRYPTO_AES_ROUND_LAST, CRYPTO_AES_INV_ROUND, CRYPTO_AES_INV_ROUND_LAST
export CRYPTO_AES_IMC, CRYPTO_AES_KEYGEN_ASSIST
export CRYPTO_SHA256_RNDS2, CRYPTO_SHA256_MSG1, CRYPTO_SHA256_MSG2
export CRYPTO_SHA512_RNDS2, CRYPTO_SHA512_MSG1, CRYPTO_SHA512_MSG2
export CRC32_U8, CRC32_U32, CRC32_U64
export CLMUL_LO, CLMUL_HI
export BIT_ROTATE_LEFT, BIT_ROTATE_RIGHT, BIT_POPCOUNT, BIT_CLZ, BIT_CTZ
export BIT_BSWAP, BIT_BITREVERSE, BIT_PARITY
export CRYPTO_CLMUL, MATRIX_DOT, MATRIX_OUTER_PRODUCT, MATRIX_FMA_KERNEL
export cipher_intrinsic_arg_count, is_cipher_intrinsic
