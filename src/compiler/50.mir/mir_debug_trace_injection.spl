# MIR Debug Trace Injection — Semantic Trace Call Insertion
#
# Stub/skeleton for the MIR rewrite pass that instruments compiled code
# with semantic trace calls. Follows the mir_aop_injection.spl pattern.
#
# The actual MIR rewriting is complex and will be done iteratively.
# This file defines the injection API and level-gating predicates.

# ============================================================================
# Trace Injection Config
# ============================================================================

struct TraceInjectionConfig:
    level: i32     # TraceLevel as int (0=None, 1=Functions, 2=Objects, 3=Full)
    enabled: bool

impl TraceInjectionConfig:
    static fn create(level: i32) -> TraceInjectionConfig:
        TraceInjectionConfig(
            level: level,
            enabled: level > 0
        )

    static fn disabled() -> TraceInjectionConfig:
        TraceInjectionConfig(level: 0, enabled: false)

# ============================================================================
# Level-Gating Predicates
# ============================================================================

fn should_inject_function_enter(config: TraceInjectionConfig) -> bool:
    """FunctionEnter: injected at level >= Functions (1)."""
    config.enabled and config.level >= 1

fn should_inject_function_exit(config: TraceInjectionConfig) -> bool:
    """FunctionExit: injected at level >= Functions (1)."""
    config.enabled and config.level >= 1

fn should_inject_variable_write(config: TraceInjectionConfig) -> bool:
    """VariableWrite: injected at level >= Full (3)."""
    config.enabled and config.level >= 3

fn should_inject_object_alloc(config: TraceInjectionConfig) -> bool:
    """ObjectAlloc/Drop/OwnershipTransfer: injected at level >= Objects (2)."""
    config.enabled and config.level >= 2

fn should_inject_borrow_events(config: TraceInjectionConfig) -> bool:
    """BorrowStart/BorrowEnd: injected at level >= Full (3)."""
    config.enabled and config.level >= 3

fn should_inject_async_events(config: TraceInjectionConfig) -> bool:
    """AsyncSpawn/Yield/Resume/Complete: injected at level >= Full (3)."""
    config.enabled and config.level >= 3
