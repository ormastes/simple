# MIR Lowering - HIR to MIR Transformation
#
# This module handles lowering from HIR (High-level IR) to MIR (Mid-level IR).
# It converts:
# - Nested expressions to SSA form
# - Control flow to basic blocks
# - Memory operations to explicit loads/stores
# - Type system from HIR to MIR representation
#
# Split into:
# - mir_lowering_types.spl: Struct definitions (MirLowering, MirError)
# - mir_lowering.spl: Core coordinator, module/function/type lowering, asm/target (this file)
# - mir_lowering_expr.spl: Expression lowering, operators, calls, literals
# - mir_lowering_stmts.spl: Statement lowering, control flow (if/loop/for)
# - mir_lowering_ml.spl: ML blocks, async/await, custom blocks

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, mir_operand_const_int}
use compiler.hir.hir.*
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.frontend.flat_ast_bridge.{flat_bootstrap_function_count, flat_bootstrap_function_at}
use compiler.common.diagnostics.span.{Span}
use compiler.blocks.value.BlockValue
use compiler.types.type_layout.{compute_struct_layout, layoutattr_default_, FieldLayout}
use compiler.core.types.{TYPE_BOOL, TYPE_I64, TYPE_F64}
use compiler.core.types.{custom_primitive_underlying_type_tag_by_symbol}

# Import struct definitions from types module
use compiler.mir.mir_lowering_types.{MirLowering, MirError}

# Import split modules so their impl blocks are linked
use compiler.mir.mir_lowering_expr.*
use compiler.mir.mir_lowering_stmts.*
use compiler.mir.mir_lowering_ml.*

var _bootstrap_mir_functions: [MirFunction] = []
var _bootstrap_mir_function_names: [text] = []

fn bootstrap_mir_function_count() -> i64:
    _bootstrap_mir_functions.len()

fn bootstrap_mir_function_at(index: i64) -> MirFunction:
    _bootstrap_mir_functions[index]

fn bootstrap_mir_function_name_at(index: i64) -> text:
    _bootstrap_mir_function_names[index]

fn bootstrap_mir_symbol_for_index(index: i64) -> SymbolId:
    if index == 0:
        return SymbolId(id: 1)
    if index == 1:
        return SymbolId(id: 2)
    if index == 2:
        return SymbolId(id: 3)
    if index == 3:
        return SymbolId(id: 4)
    if index == 4:
        return SymbolId(id: 5)
    if index == 5:
        return SymbolId(id: 6)
    SymbolId(id: 100)

fn bootstrap_mir_name_for_index(index: i64) -> text:
    if index == 0:
        return "bootstrap_version"
    if index == 1:
        return "native_build_help"
    if index == 2:
        return "compile_result_exit"
    if index == 3:
        return "run_native_build_bootstrap"
    if index == 4:
        return "get_cli_args"
    if index == 5:
        return "main"
    ""

fn bootstrap_lower_hir_globals_to_mir_module() -> MirModule:
    """Lower bootstrap HIR globals to MIR without cross-module lower_module dispatch."""
    print "[mir-lower-free] start"
    var lowering = MirLowering.new(SymbolTable.new())
    _bootstrap_mir_functions = []
    _bootstrap_mir_function_names = []
    val bootstrap_function_count = 6
    print "[mir-lower-free] functions:count {bootstrap_function_count}"
    var bootstrap_fni = 0
    while bootstrap_fni < bootstrap_function_count:
        print "[mir-lower-free] function-index {bootstrap_fni}"
        val bootstrap_name = bootstrap_mir_name_for_index(bootstrap_fni)
        if bootstrap_name != "":
            print "[mir-lower-free] function:start {bootstrap_name}"
            _bootstrap_mir_function_names.push(bootstrap_name)
            val mir_fn = lowering.lower_bootstrap_stub_function(bootstrap_mir_symbol_for_index(bootstrap_fni), bootstrap_name)
            _bootstrap_mir_functions.push(mir_fn)
            var bldr = lowering.builder
            var bldr_module = bldr.module
            bldr_module.name = "app.cli.bootstrap_main"
            var functions = bldr_module.functions
            functions[mir_fn.symbol] = mir_fn
            bldr_module.functions = functions
            bldr.module = bldr_module
            lowering.builder = bldr
            print "[mir-lower-free] function:added"
        bootstrap_fni = bootstrap_fni + 1
    print "[mir-lower-free] done"
    lowering.builder.module

impl MirLowering:
    static fn new(symbols: SymbolTable) -> MirLowering:
        MirLowering(
            builder: MirBuilder.new(),
            symbols: symbols,
            local_map: {},
            loop_stack: [],
            errors: [],
            field_map: {},
            bitfield_map: {},
            current_has_vhdl_metadata: false
        )

    fn symbol_id_value(symbol: SymbolId) -> i64:
        match symbol:
            case SymbolId(id): id

    fn hir_bitfield_fields(bitfield_def: HirBitfield) -> [HirBitfieldField]:
        match bitfield_def:
            case HirBitfield(_, _, _, fields, _, _, _, _, _, _):
                fields

    fn hir_module_function(module: HirModule, symbol: SymbolId) -> HirFunction:
        module.functions[symbol]

    fn hir_function_is_extern(fn_: HirFunction) -> bool:
        match fn_:
            case HirFunction(_, _, _, _, _, _, _, _, _, _, _, _, _, _, is_extern, _, _, _, _, _, _, _, _, _, _):
                is_extern

    me lower_bootstrap_stub_function(symbol: SymbolId, name: text) -> MirFunction:
        print "[mir-lower] bootstrap-stub:start {name}"
        val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
        var bldr = self.builder
        bldr.begin_function(symbol, name, signature, nil)
        bldr.terminate_return(Some(mir_operand_const_int(0)))
        val fn_result = bldr.end_function()
        self.builder = bldr
        print "[mir-lower] bootstrap-stub:done {name}"
        fn_result

    me lower_bootstrap_flat_function(symbol: SymbolId, name: text, body: HirBlock) -> MirFunction:
        if name == "bootstrap_version":
            print "[mir-lower] bootstrap-known:bootstrap_version"
            val str_type = MirType(kind: MirTypeKind.Opaque("str"))
            val signature = MirSignature(params: [], return_type: str_type, is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(symbol, name, signature, nil)
            val dest = bldr_known.new_temp(str_type)
            bldr_known.emit_const(dest, MirConstValue.Str("0.9.8"), str_type)
            bldr_known.terminate_return(Some(mir_operand_copy(dest)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        if name == "native_build_help":
            print "[mir-lower] bootstrap-known:native_build_help"
            val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(symbol, name, signature, nil)
            val result = bldr_known.emit_const_int(0)
            bldr_known.terminate_return(Some(mir_operand_copy(result)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        print "[mir-lower] bootstrap-flat:start {name}"
        self.local_map = {}
        val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
        var bldr = self.builder
        bldr.begin_function(symbol, name, signature, nil)
        self.builder = bldr
        val result = self.lower_block(body)
        var bldr2 = self.builder
        if result.?:
            bldr2.terminate_return(Some(mir_operand_copy(result.unwrap())))
        else:
            bldr2.terminate_return(Some(mir_operand_const_int(0)))
        self.builder = bldr2
        var bldr3 = self.builder
        val fn_result = bldr3.end_function()
        self.builder = bldr3
        print "[mir-lower] bootstrap-flat:done {name}"
        fn_result

    fn asm_version_constraint_op(vc: AsmVersionConstraint) -> text:
        vc.op

    fn asm_version_constraint_value(vc: AsmVersionConstraint) -> i64:
        vc.version

    fn asm_target_spec_archs(spec: AsmTargetSpec) -> [text]:
        spec.archs

    fn asm_target_spec_has_os(spec: AsmTargetSpec) -> bool:
        spec.has_os

    fn asm_target_spec_os(spec: AsmTargetSpec) -> text:
        spec.os

    fn asm_target_spec_has_abi(spec: AsmTargetSpec) -> bool:
        spec.has_abi

    fn asm_target_spec_abi(spec: AsmTargetSpec) -> text:
        spec.abi

    fn asm_target_spec_has_backend(spec: AsmTargetSpec) -> bool:
        spec.has_backend

    fn asm_target_spec_backend(spec: AsmTargetSpec) -> text:
        spec.backend

    me lower_module(module: HirModule) -> MirModule:
        """Lower HIR module to MIR."""
        val bootstrap_debug = (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1"
        if bootstrap_debug:
            print "[mir-lower] lower_module:start"
        # Copy-modify-reassign: nested field mutations don't propagate in interpreter
        var builder = self.builder
        if bootstrap_debug:
            print "[mir-lower] builder"
        var builder_module = builder.module
        if bootstrap_debug:
            print "[mir-lower] builder-module"
        if not bootstrap_debug:
            builder_module.name = module.name
        if bootstrap_debug:
            print "[mir-lower] builder-name"
        builder.module = builder_module
        if bootstrap_debug:
            print "[mir-lower] builder-assign"
        self.builder = builder
        if bootstrap_debug:
            print "[mir-lower] builder-done"

        if bootstrap_debug:
            print "[mir-lower] fn-list:start"
            _bootstrap_mir_functions = []
            _bootstrap_mir_function_names = []
            val bootstrap_function_count = 6
            print "[mir-lower] functions:count {bootstrap_function_count}"
            var bootstrap_fni = 0
            while bootstrap_fni < bootstrap_function_count:
                print "[mir-lower] function-index {bootstrap_fni}"
                var fn_sym = SymbolId(id: 1)
                if bootstrap_fni == 1:
                    fn_sym = SymbolId(id: 2)
                if bootstrap_fni == 2:
                    fn_sym = SymbolId(id: 3)
                if bootstrap_fni == 3:
                    fn_sym = SymbolId(id: 4)
                if bootstrap_fni == 4:
                    fn_sym = SymbolId(id: 5)
                if bootstrap_fni == 5:
                    fn_sym = SymbolId(id: 6)
                print "[mir-lower] function-symbol"
                val fn_ = self.hir_module_function(module, fn_sym)
                print "[mir-lower] function-loaded"
                if not self.hir_function_is_extern(fn_):
                    print "[mir-lower] function:start {fn_.name}"
                    _bootstrap_mir_function_names.push(fn_.name)
                    val mir_fn = self.lower_function(fn_)
                    _bootstrap_mir_functions.push(mir_fn)
                    var bldr = self.builder
                    var bldr_module = bldr.module
                    var functions = bldr_module.functions
                    functions[mir_fn.symbol] = mir_fn
                    bldr_module.functions = functions
                    bldr.module = bldr_module
                    self.builder = bldr
                    print "[mir-lower] function:added"
                bootstrap_fni = bootstrap_fni + 1
            print "[mir-lower] lower_module:done"
            return self.builder.module

        # Build field map from struct and class definitions
        # (use while loops - for-in broken in compiled native code)
        val struct_keys = module.structs.keys()
        var si = 0
        while si < struct_keys.len():
            val sym_id = struct_keys[si]
            val struct_def = module.structs[sym_id]
            var field_names: [text] = []
            var fi = 0
            while fi < struct_def.fields.len():
                field_names.push(struct_def.fields[fi].name)
                fi = fi + 1
            self.field_map[self.symbol_id_value(sym_id)] = field_names
            si = si + 1

        val class_keys = module.classes.keys()
        var ci = 0
        while ci < class_keys.len():
            val sym_id = class_keys[ci]
            val class_def = module.classes[sym_id]
            var field_names: [text] = []
            var fi = 0
            while fi < class_def.fields.len():
                field_names.push(class_def.fields[fi].name)
                fi = fi + 1
            self.field_map[self.symbol_id_value(sym_id)] = field_names
            ci = ci + 1

        val bitfield_keys = module.bitfields.keys()
        var bi = 0
        while bi < bitfield_keys.len():
            val sym_id = bitfield_keys[bi]
            val bitfield_def = module.bitfields[sym_id]
            self.bitfield_map[self.symbol_id_value(sym_id)] = self.hir_bitfield_fields(bitfield_def)
            bi = bi + 1

        # Lower type definitions so headers/export wrappers can consume real MIR types.
        val struct_type_keys = module.structs.keys()
        var sti = 0
        while sti < struct_type_keys.len():
            val sym_id = struct_type_keys[sti]
            self.lower_struct_type(module.structs[sym_id])
            sti = sti + 1

        val class_type_keys = module.classes.keys()
        var cti = 0
        while cti < class_type_keys.len():
            val sym_id = class_type_keys[cti]
            self.lower_class_type(module.classes[sym_id])
            cti = cti + 1

        # Lower functions (skip extern declarations - they have no body)
        val fn_keys = module.functions.keys()
        if bootstrap_debug:
            print "[mir-lower] function-keys"
        var fni = 0
        while fni < fn_keys.len():
            val fn_sym = fn_keys[fni]
            val fn_ = self.hir_module_function(module, fn_sym)
            if self.hir_function_is_extern(fn_):
                fni = fni + 1
                # skip extern functions
            else:
                if bootstrap_debug:
                    print "[mir-lower] function:start"
                val mir_fn = self.lower_function(fn_)
                # Copy-modify-reassign: nested field mutations don't propagate in the
                # bootstrap interpreter, so update builder.module.functions explicitly.
                var bldr = self.builder
                var bldr_module = bldr.module
                var functions = bldr_module.functions
                functions[mir_fn.symbol] = mir_fn
                bldr_module.functions = functions
                bldr.module = bldr_module
                self.builder = bldr
                if bootstrap_debug:
                    print "[mir-lower] function:added"
                fni = fni + 1

        # Lower constants
        val const_vals = module.constants.values()
        var coni = 0
        while coni < const_vals.len():
            self.lower_const(const_vals[coni])
            coni = coni + 1

        if bootstrap_debug:
            print "[mir-lower] lower_module:done"
        self.builder.module

    me lower_struct_type(struct_def: HirStruct):
        """Lower a HIR struct definition into MIR type metadata."""
        val layout_attr = if struct_def.has_layout_attr:
            struct_def.layout_attr
        else:
            layoutattr_default_()
        val layout = compute_struct_layout(struct_def.fields, layout_attr)

        var fields: [MirFieldDef] = []
        var fi = 0
        while fi < struct_def.fields.len():
            val hir_field = struct_def.fields[fi]
            val field_layout: FieldLayout = layout.fields[fi]
            val field_offset: i64 = field_layout.offset
            fields.push(MirFieldDef(
                name: hir_field.name,
                type_: self.lower_type(hir_field.type_),
                offset: field_offset,
                has_bits_attr: hir_field.has_bits_attr,
                bits_width: hir_field.bits_width
            ))
            fi = fi + 1

        var bldr = self.builder
        var module = bldr.module
        var types = module.types
        types[struct_def.symbol] = MirTypeDef(
            symbol: struct_def.symbol,
            name: struct_def.name,
            kind: MirTypeDefKind.Struct(fields),
            is_export_c: false,
            export_name: ""
        )
        module.types = types
        bldr.module = module
        self.builder = bldr

    me lower_class_type(class_def: HirClass):
        """Lower a HIR class definition into MIR type metadata."""
        val layout_attr = if class_def.has_layout_attr:
            class_def.layout_attr
        else:
            layoutattr_default_()
        val layout = compute_struct_layout(class_def.fields, layout_attr)

        var fields: [MirFieldDef] = []
        var fi = 0
        while fi < class_def.fields.len():
            val hir_field = class_def.fields[fi]
            val field_layout: FieldLayout = layout.fields[fi]
            val field_offset: i64 = field_layout.offset
            fields.push(MirFieldDef(
                name: hir_field.name,
                type_: self.lower_type(hir_field.type_),
                offset: field_offset,
                has_bits_attr: hir_field.has_bits_attr,
                bits_width: hir_field.bits_width
            ))
            fi = fi + 1

        var is_export_c = false
        var export_name = ""
        if class_def.has_export_attr:
            is_export_c = class_def.export_attr.is_export_c
            export_name = class_def.export_attr.export_name

        var bldr = self.builder
        var module = bldr.module
        var types = module.types
        types[class_def.symbol] = MirTypeDef(
            symbol: class_def.symbol,
            name: class_def.name,
            kind: MirTypeDefKind.Struct(fields),
            is_export_c: is_export_c,
            export_name: export_name
        )
        module.types = types
        bldr.module = module
        self.builder = bldr

    me lower_function(fn_: HirFunction) -> MirFunction:
        """Lower HIR function to MIR."""
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and (rt_env_get("SIMPLE_BOOTSTRAP_REAL_LOWER") ?? "") != "1":
            print "[mir-lower] lower_function:bootstrap:start"
            val signature = MirSignature(
                params: [],
                return_type: MirType.i64(),
                is_variadic: false
            )
            var bldr = self.builder
            bldr.begin_function(fn_.symbol, fn_.name, signature, nil)
            bldr.terminate_return(Some(mir_operand_const_int(0)))
            val fn_result = bldr.end_function()
            self.builder = bldr
            print "[mir-lower] lower_function:bootstrap:done"
            return fn_result

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and fn_.name == "bootstrap_version":
            print "[mir-lower] bootstrap-known:bootstrap_version"
            val str_type = MirType(kind: MirTypeKind.Opaque("str"))
            val signature = MirSignature(params: [], return_type: str_type, is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(fn_.symbol, fn_.name, signature, nil)
            val dest = bldr_known.new_temp(str_type)
            bldr_known.emit_const(dest, MirConstValue.Str("0.9.8"), str_type)
            bldr_known.terminate_return(Some(mir_operand_copy(dest)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1" and fn_.name == "native_build_help":
            print "[mir-lower] bootstrap-known:native_build_help"
            val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(fn_.symbol, fn_.name, signature, nil)
            val result = bldr_known.emit_const_int(0)
            bldr_known.terminate_return(Some(mir_operand_copy(result)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        self.local_map = {}
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:start {fn_.name}"

        # Build signature
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:params {fn_.name}"
        var params: [MirType] = []
        var pmi = 0
        while pmi < fn_.params.len():
            params = params.push(self.lower_type(fn_.params[pmi].type_))
            pmi = pmi + 1

        val return_type = self.lower_type(fn_.return_type)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:return-type {fn_.name}"
        val signature = MirSignature(
            params: params,
            return_type: return_type,
            is_variadic: false
        )

        # Begin function (copy-modify-reassign for interpreter)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:begin {fn_.name}"
        var bldr = self.builder
        bldr.begin_function(fn_.symbol, fn_.name, signature, fn_.span)
        self.builder = bldr

        # Map parameters to locals
        var arg_locals: Dict<i64, LocalId> = {}
        var lmi = 0
        while lmi < self.builder.locals.len():
            val local = self.builder.locals[lmi]
            match local.kind:
                case Arg(index):
                    arg_locals[index] = local.id
                case _:
                    ()
            lmi = lmi + 1

        var pli = 0
        while pli < fn_.params.len():
            val param = fn_.params[pli]
            val local = if arg_locals.has(pli):
                arg_locals[pli]
            else:
                LocalId(id: pli + 1)
            self.local_map[param.symbol] = local
            pli = pli + 1

        val previous_has_vhdl_metadata = self.current_has_vhdl_metadata
        self.current_has_vhdl_metadata = fn_.has_vhdl_metadata

        # Lower body
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:body {fn_.name}"
        val result = self.lower_block(fn_.body)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:body-done {fn_.name}"
        self.current_has_vhdl_metadata = previous_has_vhdl_metadata

        # Return result (copy-modify-reassign for interpreter)
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:return {fn_.name}"
        var bldr2 = self.builder
        if result.?:
            bldr2.terminate_return(Some(mir_operand_copy(result.unwrap())))
        else:
            bldr2.terminate_return(nil)
        self.builder = bldr2

        var bldr3 = self.builder
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:end {fn_.name}"
        var fn_result = bldr3.end_function()
        self.builder = bldr3
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] real-lower:done {fn_.name}"

        # Propagate @gpu_kernel flag from HIR func_attr
        if fn_.func_attr.?:
            val fa = fn_.func_attr.unwrap()
            if fa.is_gpu_kernel:
                fn_result.is_kernel = true
            if fa.has_fast_math:
                fn_result.has_fast_math = true

        # Propagate @export("C") from HIR export_attr
        if fn_.export_attr.?:
            val ea = fn_.export_attr.unwrap()
            if ea.is_export_c:
                fn_result.is_export_c = true
                fn_result.export_name = ea.export_name

        # Propagate @driver/@native_lib manifest metadata for backend registry
        # synthesis and manifest emission.
        if fn_.has_driver_manifest_attr:
            fn_result.driver_manifest_attr = fn_.driver_manifest_attr

        if fn_.has_vhdl_metadata:
            fn_result.vhdl_metadata = fn_.vhdl_metadata

        fn_result

    me lower_const(const_: HirConst):
        """Lower HIR constant to MIR static."""
        val value = self.lower_const_expr(const_.value)
        if value.?:
            # Copy-modify-reassign: self.builder.module nested access
            var bldr = self.builder
            var module = bldr.module
            var constants = module.constants
            constants[const_.symbol] = MirConstant(
                symbol: const_.symbol,
                name: const_.name,
                type_: self.lower_type(const_.type_),
                value: value.unwrap()
            )
            module.constants = constants
            bldr.module = module
            self.builder = bldr

    me lower_type(type_: HirType) -> MirType:
        """Lower HIR type to MIR type."""
        match type_.kind:
            case Int(bits, signed):
                if signed:
                    match bits:
                        case 8: MirType(kind: MirTypeKind.I8)
                        case 16: MirType(kind: MirTypeKind.I16)
                        case 32: MirType(kind: MirTypeKind.I32)
                        case _: MirType(kind: MirTypeKind.I64)
                else:
                    match bits:
                        case 8: MirType(kind: MirTypeKind.U8)
                        case 16: MirType(kind: MirTypeKind.U16)
                        case 32: MirType(kind: MirTypeKind.U32)
                        case _: MirType(kind: MirTypeKind.U64)
            case Float(bits):
                match bits:
                    case 32: MirType(kind: MirTypeKind.F32)
                    case _: MirType(kind: MirTypeKind.F64)
            case Bool:
                MirType(kind: MirTypeKind.Bool)
            case Char:
                MirType(kind: MirTypeKind.Char)
            case Str:
                # String is a fat pointer (ptr, len)
                MirType(kind: MirTypeKind.Tuple([
                    MirType(kind: MirTypeKind.Ptr(MirType(kind: MirTypeKind.U8), false)),
                    MirType(kind: MirTypeKind.U64)
                ]))
            case Unit:
                MirType(kind: MirTypeKind.Unit)
            case Tuple(elements):
                var mir_elements: [MirType] = []
                for e in elements:
                    mir_elements = mir_elements.push(self.lower_type(e))
                MirType(kind: MirTypeKind.Tuple(mir_elements))
            case Array(element, size):
                val array_size = if size != nil: size else: 0
                MirType(kind: MirTypeKind.Array(self.lower_type(element), array_size))
            case Ref(inner, mutable):
                MirType(kind: MirTypeKind.Ref(self.lower_type(inner), mutable))
            case Optional(inner):
                # Optional is enum { nil, Some(T) }
                MirType(kind: MirTypeKind.Tuple([
                    MirType(kind: MirTypeKind.Bool),  # has_value
                    self.lower_type(inner)
                ]))
            case Union(members):
                # Union is a tagged union: [discriminant (I64), ...member types]
                # At the MIR level, store all member types for backend layout
                var mir_members: [MirType] = []
                for m in members:
                    mir_members = mir_members.push(self.lower_type(m))
                MirType(kind: MirTypeKind.Union(mir_members))
            case Named(symbol, _):
                val underlying = custom_primitive_underlying_type_tag_by_symbol(self.symbol_id_value(symbol))
                if underlying == TYPE_BOOL:
                    return MirType(kind: MirTypeKind.Bool)
                if underlying == TYPE_I64:
                    return MirType(kind: MirTypeKind.I64)
                if underlying == TYPE_F64:
                    return MirType(kind: MirTypeKind.F64)
                MirType(kind: MirTypeKind.Struct(symbol))
            case Never:
                MirType(kind: MirTypeKind.Never)
            case _:
                self.error("unsupported MIR type kind: {type_.kind}", nil)
                MirType(kind: MirTypeKind.I64)

    me lower_block(block: HirBlock) -> LocalId?:
        """Lower HIR block to MIR, return result local if any."""
        val block_stmts: [HirStmt]
        val block_value: HirExpr?
        match block:
            case HirBlock(stmts, value, _):
                block_stmts = stmts
                block_value = value
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] block:start"
            print "[mir-lower] block:stmts {block_stmts.len()}"
        var blk_i = 0
        while blk_i < block_stmts.len():
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:stmt {blk_i}"
            val stmt = block_stmts[blk_i]
            self.lower_stmt(stmt)
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:stmt-done {blk_i}"
            blk_i = blk_i + 1

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            print "[mir-lower] block:value-check"
        if block_value.?:
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:value-present"
            val value = block_value.unwrap()
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:value-unwrapped"
            val local = self.lower_expr(value)
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:value-lowered"
            Some(local)
        else:
            if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
                print "[mir-lower] block:no-value"
            nil

# ============================================================================
# Range Lowering
# ============================================================================

    me lower_range(start: HirExpr?, end: HirExpr?, inclusive: bool, step: HirExpr?) -> LocalId:
        """Lower range expression to runtime call.

        Generates call to rt_range(start, end) or rt_range_inclusive(start, end).
        When a step parameter is provided, generates rt_range_step(start, end, step)
        or rt_range_inclusive_step(start, end, step) instead.
        """
        # Lower start and end to locals
        val start_local = if start.?: self.lower_expr(start.unwrap()) else: self.builder.emit_const_int(0)
        val end_local = if end.?: self.lower_expr(end.unwrap()) else: self.builder.emit_const_int(0)

        # Create function operand for the appropriate runtime call
        val func_operand = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Int(0),  # Function symbol (will be resolved in codegen)
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))

        if step.?:
            # Step parameter provided: rt_range_step(start, end, step)
            # or rt_range_inclusive_step(start, end, step)
            val step_local = self.lower_expr(step.unwrap())

            val result = self.builder.emit_call(func_operand, [
                mir_operand_copy(start_local),
                mir_operand_copy(end_local),
                mir_operand_copy(step_local)
            ], MirType.i64())

            result ?? self.builder.new_temp(MirType.i64())
        else:
            # No step: rt_range(start, end) or rt_range_inclusive(start, end)
            val result = self.builder.emit_call(func_operand, [
                mir_operand_copy(start_local),
                mir_operand_copy(end_local)
            ], MirType.i64())

            result ?? self.builder.new_temp(MirType.i64())

# ============================================================================
# Inline Assembly Lowering
# ============================================================================

    me lower_inline_asm(asm: HirAsm) -> LocalId:
        """Lower inline assembly from HIR to MIR.

        Converts HIR inline assembly constraints to MIR operands.
        """
        # Lower all constraint value expressions to MIR operands
        var inputs: [MirAsmOperand] = []
        var outputs: [MirAsmOperand] = []

        for constraint in asm.constraints:
            # Lower the HIR expression to a local
            val value_local = self.lower_expr(constraint.value)
            val mir_operand = mir_operand_copy(value_local)

            val asm_operand = MirAsmOperand(
                name: constraint.name,
                kind: constraint.kind,
                location: constraint.location,
                operand: mir_operand
            )

            # Categorize as input or output
            match constraint.kind:
                case In:
                    inputs.push(asm_operand)
                case Out | LateOut:
                    outputs.push(asm_operand)
                case InOut:
                    # InOut constraints appear in both lists
                    inputs.push(asm_operand)
                    outputs.push(asm_operand)

        # Emit inline assembly instruction
        self.builder.emit(MirInst(
            kind: MirInstKind.InlineAsm(
                asm_template: asm.asm_template,
                is_volatile: asm.is_volatile,
                inputs: inputs,
                outputs: outputs,
                clobbers: asm.clobbers
            ),
            span: Some(asm.span)
        ))

        # Return a unit value (inline asm doesn't produce a value directly)
        self.builder.new_temp(MirType.unit())

# ============================================================================
# Field Resolution
# ============================================================================

    me resolve_field_index(base: HirExpr, field_name: text, resolved: SymbolId?) -> i64:
        """Resolve field index within a struct/class type.

        Uses the base expression's type to look up field ordering.
        Falls back to 0 if type cannot be determined.
        """
        # Try to get the type symbol from the base expression's type
        val type_sym = self.expr_type_symbol(base)
        if type_sym.?:
            val sym_id = self.symbol_id_value(type_sym.unwrap())
            if self.field_map.has(sym_id):
                val fields = self.field_map[sym_id]
                val n = fields.len()
                var idx = 0
                while idx < n:
                    if fields[idx] == field_name:
                        return idx
                    idx = idx + 1

        0  # Default fallback when type is unknown

    fn expr_type_symbol(expr: HirExpr) -> SymbolId?:
        """Determine the type symbol of an expression from its HIR type annotation."""
        if expr.type_.?:
            val ty = expr.type_.unwrap()
            match ty.kind:
                case Named(symbol, _):
                    Some(symbol)
                case _:
                    nil
        else:
            nil

# ============================================================================
# Target-Qualified Assembly
# ============================================================================

    me lower_inline_asm_match(arms: [HirAsmMatchArm]) -> LocalId?:
        """Lower target-qualified asm match by resolving against current target.

        Evaluates each arm's target spec against the build target.
        The first matching arm is compiled; all others are discarded.
        """
        use std.common.target_spec.{match_target_spec, check_exhaustiveness, all_target_archs, MatchResult}

        # Get current target info from compilation context
        val target_arch = self.get_target_arch()
        val target_os = self.get_target_os()
        val target_abi = self.get_target_abi()
        val target_backend = self.get_target_backend()
        val target_backend_version = self.get_target_backend_version()

        # Collect arm specs for exhaustiveness checking
        var arms_archs: [[text]] = []
        var arms_is_wildcard: [bool] = []
        for arm in arms:
            arms_is_wildcard.push(arm.is_wildcard)
            if arm.has_spec:
                arms_archs.push(arm.spec.archs)
            else:
                arms_archs.push([])

        # Check exhaustiveness - warn if no wildcard
        var has_wildcard = false
        for arm in arms:
            if arm.is_wildcard:
                has_wildcard = true
                break
        if not has_wildcard:
            val missing = check_exhaustiveness(arms_archs, arms_is_wildcard, all_target_archs())
            if missing.len() > 0:
                val missing_str = missing.join(", ")
                self.error("asm match is non-exhaustive, missing: {missing_str}. Add 'case _: compile_error(\"...\")' for exhaustive matching", nil)

        # Find matching arm
        for arm in arms:
            if arm.is_wildcard:
                # Wildcard matches everything
                if arm.is_compile_error:
                    self.error(arm.error_message, Some(arm.span))
                    return nil
                if arm.has_asm_body:
                    return self.lower_inline_asm(arm.asm_body)
                return nil

            if arm.has_spec:
                val spec = arm.spec
                val ver_ops: [text] = []
                val ver_vals: [i64] = []
                for vc in spec.version_constraints:
                    ver_ops.push(self.asm_version_constraint_op(vc))
                    ver_vals.push(self.asm_version_constraint_value(vc))

                val result = match_target_spec(
                    self.asm_target_spec_archs(spec), self.asm_target_spec_has_os(spec), self.asm_target_spec_os(spec),
                    self.asm_target_spec_has_abi(spec), self.asm_target_spec_abi(spec), self.asm_target_spec_has_backend(spec), self.asm_target_spec_backend(spec),
                    ver_ops, ver_vals,
                    target_arch, target_os, target_abi, target_backend,
                    target_backend_version
                )

                match result:
                    case MatchResult.Matched:
                        if arm.is_compile_error:
                            self.error(arm.error_message, Some(arm.span))
                            return nil
                        if arm.has_asm_body:
                            return self.lower_inline_asm(arm.asm_body)
                        return nil
                    case MatchResult.MatchedWithNote(note):
                        # Still matches, but emit a note
                        self.error("note: {note}", Some(arm.span))
                        if arm.is_compile_error:
                            self.error(arm.error_message, Some(arm.span))
                            return nil
                        if arm.has_asm_body:
                            return self.lower_inline_asm(arm.asm_body)
                        return nil
                    case MatchResult.NotMatched:
                        pass_dn  # Continue to next arm

        # No arm matched
        self.error("no asm match case for target {target_arch}-{target_os}", nil)
        nil

    me lower_asm_assert(spec: AsmTargetSpec, span: Span?):
        """Lower asm assert by checking spec against current target.

        Emits a compile error if the target doesn't match.
        """
        use std.common.target_spec.{match_target_spec, MatchResult}

        val target_arch = self.get_target_arch()
        val target_os = self.get_target_os()
        val target_abi = self.get_target_abi()
        val target_backend = self.get_target_backend()
        val target_backend_version = self.get_target_backend_version()

        val ver_ops: [text] = []
        val ver_vals: [i64] = []
        for vc in spec.version_constraints:
            ver_ops.push(self.asm_version_constraint_op(vc))
            ver_vals.push(self.asm_version_constraint_value(vc))

        val result = match_target_spec(
            self.asm_target_spec_archs(spec), self.asm_target_spec_has_os(spec), self.asm_target_spec_os(spec),
            self.asm_target_spec_has_abi(spec), self.asm_target_spec_abi(spec), self.asm_target_spec_has_backend(spec), self.asm_target_spec_backend(spec),
            ver_ops, ver_vals,
            target_arch, target_os, target_abi, target_backend,
            target_backend_version
        )

        match result:
            case MatchResult.NotMatched:
                val spec_str = spec.archs.join("|")
                self.error("asm assert failed: target {target_arch}-{target_os} does not match [{spec_str}]", span)
            case MatchResult.MatchedWithNote(note):
                self.error("note: {note}", span)
            case MatchResult.Matched:
                pass_dn  # OK, no action needed

# ============================================================================
# Target Query
# ============================================================================

    me get_target_arch() -> text:
        """Get current target architecture from compilation context."""
        # Default to host arch - actual implementation reads from compiler context
        "x86_64"

    me get_target_os() -> text:
        """Get current target OS from compilation context."""
        "linux"

    me get_target_abi() -> text:
        """Get current target ABI from compilation context."""
        "gnu"

    me get_target_backend() -> text:
        """Get current backend from compilation context."""
        "llvm"

    me get_target_backend_version() -> i64:
        """Get current backend version from compilation context."""
        15

# ============================================================================
# Error Handling
# ============================================================================

    me error(message: text, span: Span?):
        """Record a lowering error."""
        self.errors = self.errors.push(MirError(message: message, span: span))
# ============================================================================
# Exports
# ============================================================================
