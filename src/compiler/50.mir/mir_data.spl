# MIR - Mid-level Intermediate Representation (Data Structures)
#
# Lower-level IR between HIR and native code generation.
# Features:
# - Explicit control flow (basic blocks, terminators)
# - Explicit memory operations (load, store, alloc)
# - SSA form (each value defined once)
# - Type-annotated values
# - Ready for optimization and codegen
#
# Split into:
# - mir_types.spl: Type system and leaf data structures (~210 lines)
# - mir_instructions.spl: Blocks, instructions, terminators, operands (~460 lines)
# - mir_data.spl: MirBuilder API + re-exports (this file)

use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.mir.mir_types.*
use compiler.mir.mir_instructions.*

extern fn rt_env_get(key: text) -> text

# ============================================================================
# MIR Builder
# ============================================================================

struct MirBuilder:
    """Builder for constructing MIR."""
    module: MirModule
    current_function: MirFunction?
    current_block: BlockId
    next_local_id: i64
    next_block_id: i64
    locals: [MirLocal]
    blocks: [MirBlock]
    instructions: [MirInst]

impl MirBuilder:
    static fn new() -> MirBuilder:
        MirBuilder(
            module: MirModule(
                name: "",
                functions: {},
                statics: {},
                constants: {},
                types: {}
            ),
            current_function: nil,
            current_block: BlockId.entry(),
            next_local_id: 0,
            next_block_id: 1,
            locals: [],
            blocks: [],
            instructions: []
        )

    # ========================================================================
    # Function Building
    # ========================================================================

    me begin_function(symbol: SymbolId, name: text, signature: MirSignature, span: Span):
        """Begin building a new function."""
        self.current_function = Some(MirFunction(
            symbol: symbol,
            name: name,
            signature: signature,
            locals: [],
            blocks: [],
            entry_block: BlockId.entry(),
            span: span,
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            gpu_target: "",
            gpu_backend_order: "",
            is_export_c: false,
            export_name: "",
            has_driver_manifest_attr: false,
            driver_manifest_attr: nil,
            has_vhdl_metadata: false,
            vhdl_metadata: vhdl_hardware_metadata_default(),
            has_fast_math: false,
            unroll_factor: 0,
            pipeline_ii: 0,
            memory_banks: 0
        ))
        self.next_local_id = 0
        self.next_block_id = 1
        self.locals = []
        self.blocks = []
        self.instructions = []
        self.current_block = BlockId.entry()

        # Create entry block
        self.blocks = self.blocks.push(MirBlock(
            id: BlockId.entry(),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.Unreachable  # Placeholder
        ))

        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") != "1":
            # Create return local
            if signature.return_type.kind != MirTypeKind.Unit:
                self.new_local(Some("_return"), signature.return_type, LocalKind.Return)

        # NOTE(#133): parameter locals are created unconditionally, including
        # under SIMPLE_BOOTSTRAP. HIR param lowering was fixed (declaration_lowering.spl
        # lower_function) to stop dropping params under bootstrap, so `signature.params`
        # is now correctly populated -- but this loop was still gated off, so no
        # `LocalKind.Arg(i)` locals ever got created for bootstrap functions. Without
        # them, function_lowering.spl's param-to-local mapping fell back to a phantom
        # `LocalId(id: pli+1)` that was never registered as a real local (and collided
        # with body-local ids, which also start counting from 0/1), so the codegen's
        # Arg-local scan (core_codegen.spl) found nothing and emitted a zero-param
        # `define`, while body references to the param read as `undef`. Creating the
        # Arg locals here fixes both: real params on `define`, and body identifier
        # references resolve to the correct local.
        # `_return` local creation stays bootstrap-gated -- 0-param bootstrap functions
        # (e.g. `bootstrap_version`, which returns `text`) already work today without
        # it, so this is left untouched to avoid an unrelated behavior change.
        for i in 0..signature.params.len():
            self.new_local(nil, signature.params[i], LocalKind.Arg(i))

    me end_function() -> MirFunction:
        """Finish building current function and return it."""
        # Finalize current block
        self.finalize_block()

        var fn_ = match self.current_function:
            case Some(active_function):
                active_function
            case None:
                MirFunction(
                symbol: SymbolId.new(-1),
                name: "<invalid>",
                signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
                locals: [],
                blocks: [],
                entry_block: BlockId.entry(),
                span: nil,
                generic_params: [],
                is_generic_template: false,
                specialization_of: nil,
                type_bindings: {},
                layout_phase: nil,
                is_kernel: false,
                gpu_target: "",
                gpu_backend_order: "",
                is_export_c: false,
                export_name: "",
                has_driver_manifest_attr: false,
                driver_manifest_attr: nil,
                has_vhdl_metadata: false,
                vhdl_metadata: vhdl_hardware_metadata_default(),
                has_fast_math: false,
                unroll_factor: 0,
                pipeline_ii: 0,
                memory_banks: 0
                )
        fn_.locals = self.locals
        fn_.blocks = self.blocks
        self.current_function = nil
        fn_

    me add_function(fn_: MirFunction):
        """Add a completed function to the module."""
        var functions = self.module.functions
        functions[fn_.symbol] = fn_
        self.module.functions = functions

    # ========================================================================
    # Local Variables
    # ========================================================================

    me new_local(name: text?, type_: MirType, kind: LocalKind) -> LocalId:
        """Create a new local variable."""
        val id = LocalId(id: self.next_local_id)
        self.next_local_id = self.next_local_id + 1

        self.locals = self.locals.push(MirLocal(
            id: id,
            name: name,
            type_: type_,
            kind: kind,
            is_ghost: false
        ))

        id

    me new_temp(type_: MirType) -> LocalId:
        """Create a new temporary."""
        self.new_local(nil, type_, LocalKind.Temp)

    me set_local_name(id: LocalId, name: text):
        """Assign a source-level name to an existing local.

        Used to thread real HIR parameter names onto the MIR arg locals that
        begin_function creates nameless from the (types-only) MirSignature, so
        backends emit real port names (e.g. imem_rdata) instead of arg0/arg1.
        """
        var updated: [MirLocal] = []
        var i = 0
        while i < self.locals.len():
            val loc = self.locals[i]
            if loc.id.id == id.id:
                updated = updated.push(MirLocal(
                    id: loc.id,
                    name: Some(name),
                    type_: loc.type_,
                    kind: loc.kind,
                    is_ghost: loc.is_ghost
                ))
            else:
                updated = updated.push(loc)
            i = i + 1
        self.locals = updated

    # ========================================================================
    # Basic Blocks
    # ========================================================================

    me new_block(label: text?) -> BlockId:
        """Create a new basic block."""
        val id = BlockId.new(self.next_block_id)
        self.next_block_id = self.next_block_id + 1

        self.blocks = self.blocks.push(MirBlock(
            id: id,
            label: label,
            instructions: [],
            terminator: MirTerminator.Unreachable  # Placeholder
        ))

        id

    me switch_to_block(block: BlockId):
        """Switch to building a different block."""
        self.finalize_block()
        self.current_block = block
        self.instructions = []

    me finalize_block():
        """Finalize current block with accumulated instructions."""
        if self.instructions.is_empty():
            return

        # Find and update current block
        var found = false
        for i in 0..self.blocks.len():
            if self.blocks[i].id.id == self.current_block.id:
                var block = self.blocks[i]
                block.instructions = self.instructions
                self.blocks[i] = block
                found = true
                break

        self.instructions = []

    # ========================================================================
    # Instructions
    # ========================================================================

    me emit(inst: MirInst):
        """Emit an instruction to current block."""
        self.instructions.push(inst)

    me emit_const(dest: LocalId, value: MirConstValue, type_: MirType):
        """Emit a constant load."""
        self.emit(MirInst(
            kind: MirInstKind.Const(dest, value, type_),
            span: nil
        ))

    me emit_const_int(value: i64) -> LocalId:
        """Emit an integer constant and return its local."""
        val dest = self.new_temp(MirType.i64())
        self.emit_const(dest, MirConstValue.Int(value), MirType.i64())
        dest

    me emit_const_float(value: f64) -> LocalId:
        """Emit a float constant and return its local."""
        val dest = self.new_temp(MirType.f64())
        self.emit_const(dest, MirConstValue.Float(value), MirType.f64())
        dest

    me emit_const_bool(value: bool) -> LocalId:
        """Emit a boolean constant and return its local."""
        val dest = self.new_temp(MirType.bool())
        self.emit_const(dest, MirConstValue.Bool(value), MirType.bool())
        dest

    me emit_copy(dest: LocalId, src: LocalId):
        """Emit a copy instruction."""
        self.emit(MirInst(
            kind: MirInstKind.Copy(dest, src),
            span: nil
        ))

    me emit_move(dest: LocalId, src: LocalId):
        """Emit a move instruction."""
        self.emit(MirInst(
            kind: MirInstKind.Move(dest, src),
            span: nil
        ))

    me emit_binop(op: MirBinOp, left: MirOperand, right: MirOperand, type_: MirType) -> LocalId:
        """Emit a binary operation and return result local."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.BinOp(dest, op, left, right),
            span: nil
        ))
        dest

    me emit_unary(op: MirUnaryOp, operand: MirOperand, type_: MirType) -> LocalId:
        """Emit a unary operation and return result local."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.UnaryOp(dest, op, operand),
            span: nil
        ))
        dest

    me emit_load(ptr: MirOperand, type_: MirType) -> LocalId:
        """Emit a load instruction."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.Load(dest, ptr),
            span: nil
        ))
        dest

    me emit_store(ptr: MirOperand, value: MirOperand):
        """Emit a store instruction."""
        self.emit(MirInst(
            kind: MirInstKind.Store(ptr, value),
            span: nil
        ))

    me emit_alloc(type_: MirType) -> LocalId:
        """Emit an allocation."""
        val dest = self.new_temp(MirType.ptr(type_, true))
        self.emit(MirInst(
            kind: MirInstKind.Alloc(dest, type_),
            span: nil
        ))
        dest

    me emit_entry_alloc(type_: MirType) -> LocalId:
        """Emit a fixed-lifetime allocation in the function entry block."""
        val dest = self.new_temp(MirType.ptr(type_, true))
        val alloc = MirInst(kind: MirInstKind.Alloc(dest, type_), span: nil)
        if self.current_block.id == BlockId.entry().id:
            self.emit(alloc)
        else:
            var entry = self.blocks[0]
            entry.instructions = entry.instructions.push(alloc)
            self.blocks[0] = entry
        dest

    me emit_call(func: MirOperand, args: [MirOperand], return_type: MirType) -> LocalId?:
        """Emit a function call."""
        val dest: LocalId? = if return_type.kind != MirTypeKind.Unit:
            Some(self.new_temp(return_type))
        else:
            nil

        self.emit(MirInst(
            kind: MirInstKind.Call(dest, func, args),
            span: nil
        ))

        dest

    me emit_value_call(func: MirOperand, args: [MirOperand], return_type: MirType) -> LocalId:
        """Emit a call that is statically known to return a value."""
        val dest = self.new_temp(return_type)
        self.emit(MirInst(
            kind: MirInstKind.Call(Some(dest), func, args),
            span: nil
        ))
        dest

    me emit_call_indirect(ptr: MirOperand, args: [MirOperand], sig: MirSignature, return_type: MirType) -> LocalId?:
        """Emit an indirect function call (through closure or function pointer)."""
        val dest: LocalId? = if return_type.kind != MirTypeKind.Unit:
            Some(self.new_temp(return_type))
        else:
            nil

        self.emit(MirInst(
            kind: MirInstKind.CallIndirect(dest, ptr, args, sig),
            span: nil
        ))

        dest

    me emit_cast(operand: MirOperand, target: MirType) -> LocalId:
        """Emit a type cast."""
        val dest = self.new_temp(target)
        self.emit(MirInst(
            kind: MirInstKind.Cast(dest, operand, target),
            span: nil
        ))
        dest

    me emit_bitcast(operand: MirOperand, target: MirType) -> LocalId:
        val dest = self.new_temp(target)
        self.emit(MirInst(
            kind: MirInstKind.Bitcast(dest, operand, target),
            span: nil
        ))
        dest

    me emit_aggregate(kind: AggregateKind, operands: [MirOperand], type_: MirType) -> LocalId:
        """Emit aggregate construction."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.Aggregate(dest, kind, operands),
            span: nil
        ))
        dest

    me emit_get_field(base: MirOperand, field: i64, type_: MirType) -> LocalId:
        """Emit field access."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.GetField(dest, base, field),
            span: nil
        ))
        dest

    me emit_set_field(base: MirOperand, field: i64, value: MirOperand):
        """Emit field assignment."""
        self.emit(MirInst(
            kind: MirInstKind.SetField(base, field, value),
            span: nil
        ))

    me emit_gep(base: MirOperand, indices: [MirOperand], type_: MirType) -> LocalId:
        """Emit GetElementPtr instruction."""
        val dest = self.new_temp(type_)
        self.emit(MirInst(
            kind: MirInstKind.GetElementPtr(dest, base, indices),
            span: nil
        ))
        dest

    # ========================================================================
    # Terminators
    # ========================================================================

    me terminate_goto(target: BlockId):
        """Terminate current block with unconditional jump."""
        self.set_terminator(MirTerminator.Goto(target))

    me terminate_return(value: MirOperand?):
        """Terminate current block with return."""
        self.set_terminator(MirTerminator.Ret(value))

    me terminate_if(cond: MirOperand, then_: BlockId, else_: BlockId):
        """Terminate current block with conditional branch."""
        self.set_terminator(MirTerminator.If(cond, then_, else_))

    me terminate_switch(value: MirOperand, targets: [SwitchCase], default: BlockId):
        """Terminate current block with switch.

        B5b dormant-bug fix: previously declared targets as [(i64, BlockId)]
        which was incompatible with MirTerminator.Switch (which takes
        [SwitchCase]). Zero callers existed when this was discovered; the
        signature is now corrected so the MatchCase MIR lowerer can call it.
        """
        self.set_terminator(MirTerminator.Switch(value, targets, default))

    me terminate_unreachable():
        """Terminate current block as unreachable."""
        self.set_terminator(MirTerminator.Unreachable)

    me set_terminator(term: MirTerminator):
        """Set terminator for current block."""
        self.finalize_block()

        for i in 0..self.blocks.len():
            if self.blocks[i].id.id == self.current_block.id:
                var block = self.blocks[i]
                block.terminator = term
                self.blocks[i] = block
                break

    fn current_block_has_explicit_terminator() -> bool:
        for block in self.blocks:
            if block.id.id == self.current_block.id:
                match block.terminator:
                    case Unreachable:
                        return false
                    case _:
                        return true
        false

    # ========================================================================
    # Convenience Methods (for interpreter compatibility)
    # ========================================================================

    me begin_simple_function(name: text, return_type_kind: text):
        """Begin a function with simple return type.
        return_type_kind: "i64", "f64", "bool", "unit", "void"
        """
        var ret_type = MirType(kind: MirTypeKind.Unit)
        if return_type_kind == "i64":
            ret_type = MirType(kind: MirTypeKind.I64)
        elif return_type_kind == "f64":
            ret_type = MirType(kind: MirTypeKind.F64)
        elif return_type_kind == "bool":
            ret_type = MirType(kind: MirTypeKind.Bool)

        val sig = MirSignature(params: [], return_type: ret_type, is_variadic: false)
        val sym = SymbolId(id: self.module.functions.len())
        self.begin_function(sym, name, sig, nil)

    me emit_const_str(value: text) -> LocalId:
        """Emit a string constant and return its local."""
        val str_type = MirType(kind: MirTypeKind.Ptr(MirType(kind: MirTypeKind.I8), false))
        val dest = self.new_temp(str_type)
        self.emit_const(dest, MirConstValue.Str(value), str_type)
        dest

    me emit_void_call(func_name: text, args: [LocalId]):
        """Emit a void call to a named function."""
        val func_type = MirType(kind: MirTypeKind.Unit)
        var operands: [MirOperand] = []
        for a in args:
            operands.push(MirOperand(kind: MirOperandKind.Copy(a)))

        val func_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str(func_name),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [],
                return_type: func_type,
                is_variadic: false
            )))
        ))

        self.emit(MirInst(
            kind: MirInstKind.Call(nil, func_op, operands),
            span: nil
        ))

    me terminate_return_copy(local: LocalId):
        """Terminate with return copying a local."""
        self.set_terminator(MirTerminator.Ret(
            MirOperand(kind: MirOperandKind.Copy(local))
        ))

    me terminate_return_void():
        """Terminate with void return."""
        self.set_terminator(MirTerminator.Ret(nil))

