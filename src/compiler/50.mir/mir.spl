# MIR - Mid-level Intermediate Representation
#
# This module re-exports MIR components from split modules.
# The implementation has been split into:
# - mir_types.spl: Type system and leaf data structures (~210 lines)
# - mir_instructions.spl: Blocks, instructions, terminators, operands (~460 lines)
# - mir_data.spl: MirBuilder API + re-exports (~330 lines)
# - mir_lowering_types.spl: Struct definitions (MirLowering, MirError) (~35 lines)
# - mir_lowering.spl: Core coordinator, module/function/type/asm lowering (~500 lines)
# - mir_lowering_expr.spl: Expression lowering, operators, calls, literals (~550 lines)
# - mir_lowering_stmts.spl: Statement lowering, control flow (if/loop/for) (~470 lines)
# - mir_lowering_ml.spl: ML blocks, async/await, custom blocks (~230 lines)
# - mir_json.spl: JSON serialization for JIT/FFI (bootstrap-compatible)

use compiler.mir.mir_data.*
use compiler.mir.mir_lowering.*
use compiler.mir.mir_json.*
use compiler.mir.mir_serialization.*

