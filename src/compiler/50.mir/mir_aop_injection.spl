# MIR AOP Injection — Advice Call Insertion into MIR Functions
#
# Provides functions to inject advice calls (before/after/around) into
# MIR function blocks. Used by the driver's weave_aop() step.

use compiler.mir.mir_instructions.*
use compiler.mir.mir_types.{MirConstValue, MirType, MirTypeKind, MirSignature}
use compiler.frontend.core.aop.{MirBlockInfo, InstructionInfo, WeavingResult, AdviceCallInfo, JoinPointKind}

# ============================================================================
# AOP Weave Accounting (W2-B)
# ============================================================================
# Tracks how many advices were requested vs. actually woven into MIR so that
# generation backends (e.g. VHDL) can record `aop_weave_count` in their
# generation manifest and fail closed when requested aspects were not woven
# (a silently dropped aspect would remove woven debug/JTAG logic from RTL).

var g_aop_advices_requested: i64 = 0
var g_aop_weave_count: i64 = 0

pub fn aop_weave_accounting_reset(requested: i64):
    g_aop_advices_requested = requested
    g_aop_weave_count = 0

pub fn aop_weave_accounting_add(inserted: i64):
    g_aop_weave_count = g_aop_weave_count + inserted

pub fn aop_advices_requested() -> i64:
    g_aop_advices_requested

pub fn aop_weave_count() -> i64:
    g_aop_weave_count

# ============================================================================
# Before Advice Injection
# ============================================================================

fn inject_before_advice(func: MirFunction, advice_fn_name: text) -> MirFunction:
    """Insert a call to advice_fn at the beginning of the entry block."""
    if func.blocks.len() == 0:
        return func
    var new_blocks: [MirBlock] = []
    var bi = 0
    while bi < func.blocks.len():
        val block = func.blocks[bi]
        if bi == 0:
            # Prepend advice call to entry block
            val call_inst = make_advice_call_inst(advice_fn_name)
            var new_insts: [MirInst] = [call_inst]
            for inst in block.instructions:
                new_insts.push(inst)
            new_blocks.push(MirBlock(
                id: block.id,
                label: block.label,
                instructions: new_insts,
                terminator: block.terminator
            ))
        else:
            new_blocks.push(block)
        bi = bi + 1
    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# After Success Advice Injection
# ============================================================================

fn inject_after_success_advice(func: MirFunction, advice_fn_name: text) -> MirFunction:
    """Insert a call to advice_fn before every Return terminator."""
    var new_blocks: [MirBlock] = []
    for block in func.blocks:
        match block.terminator:
            case Ret(_):
                val call_inst = make_advice_call_inst(advice_fn_name)
                var new_insts: [MirInst] = []
                for inst in block.instructions:
                    new_insts.push(inst)
                new_insts.push(call_inst)
                new_blocks.push(MirBlock(
                    id: block.id,
                    label: block.label,
                    instructions: new_insts,
                    terminator: block.terminator
                ))
            case _:
                new_blocks.push(block)
    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# After Error Advice Injection
# ============================================================================

fn inject_after_error_advice(func: MirFunction, advice_fn_name: text) -> MirFunction:
    """Insert a call to advice_fn at blocks that handle errors (Unwind terminators)."""
    var new_blocks: [MirBlock] = []
    for block in func.blocks:
        match block.terminator:
            case Unwind:
                val call_inst = make_advice_call_inst(advice_fn_name)
                var new_insts: [MirInst] = []
                for inst in block.instructions:
                    new_insts.push(inst)
                new_insts.push(call_inst)
                new_blocks.push(MirBlock(
                    id: block.id,
                    label: block.label,
                    instructions: new_insts,
                    terminator: block.terminator
                ))
            case _:
                new_blocks.push(block)
    MirFunction(..func, blocks: new_blocks)

fn inject_advice_at_instruction(func: MirFunction, block_id: i64, instruction_index: i64, advice_fn_name: text, before: bool) -> MirFunction:
    """Insert an advice call before or after a specific MIR instruction."""
    var new_blocks: [MirBlock] = []
    for block in func.blocks:
        if block.id.id != block_id:
            new_blocks.push(block)
        else:
            val call_inst = make_advice_call_inst(advice_fn_name)
            var new_insts: [MirInst] = []
            var idx = 0
            for inst in block.instructions:
                if before and idx == instruction_index:
                    new_insts.push(call_inst)
                new_insts.push(inst)
                if not before and idx == instruction_index:
                    new_insts.push(call_inst)
                idx = idx + 1
            new_blocks.push(MirBlock(
                id: block.id,
                label: block.label,
                instructions: new_insts,
                terminator: block.terminator
            ))
    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# Around Advice Injection
# ============================================================================

fn inject_around_advice(func: MirFunction, advice_fn_name: text) -> MirFunction:
    """Wrap the function entry with a call to around advice.
       The around advice receives a proceed context that calls the original body."""
    # For around advice, prepend a call at entry that passes the function name
    # as context. The around advice framework handles proceed() internally.
    if func.blocks.len() == 0:
        return func
    var new_blocks: [MirBlock] = []
    val entry_block = func.blocks[0]
    val call_inst = make_advice_call_inst(advice_fn_name)
    var new_insts: [MirInst] = [call_inst]
    for inst in entry_block.instructions:
        new_insts.push(inst)
    new_blocks.push(MirBlock(
        id: entry_block.id,
        label: entry_block.label,
        instructions: new_insts,
        terminator: entry_block.terminator
    ))
    var bi = 1
    while bi < func.blocks.len():
        new_blocks.push(func.blocks[bi])
        bi = bi + 1
    MirFunction(..func, blocks: new_blocks)

# ============================================================================
# MIR ↔ AOP Bridge
# ============================================================================

fn extract_mir_block_info(blocks: [MirBlock]) -> [MirBlockInfo]:
    """Convert real MIR blocks to AOP-compatible MirBlockInfo structs."""
    var result: [MirBlockInfo] = []
    for block in blocks:
        var infos: [InstructionInfo] = []
        var idx = 0
        for inst in block.instructions:
            val tag = classify_mir_inst_kind(inst.kind)
            infos.push(InstructionInfo(index: idx, kind_tag: tag))
            idx = idx + 1
        result.push(MirBlockInfo(id: block.id.id, instruction_kinds: infos))
    result

fn classify_mir_inst_kind(kind: MirInstKind) -> text:
    """Classify a MIR instruction kind into an AOP-relevant tag."""
    match kind:
        case BinOp(_, op, _, _):
            match op:
                case Eq: "comparison"
                case Ne: "comparison"
                case Lt: "comparison"
                case Le: "comparison"
                case Gt: "comparison"
                case Ge: "comparison"
                case _: "arithmetic"
        case Call(_, _, _): "call"
        case CallIndirect(_, _, _, _): "call"
        case Intrinsic(_, _, _): "intrinsic"
        case Store(_, _): "assignment"
        case SetField(_, _, _): "assignment"
        case VhdlSignalAssign(_, _, _): "assignment"
        case VhdlVarAssign(_, _): "assignment"
        case MirSimdStore(_, _, _): "assignment"
        case _: "other"

fn apply_weaving_result(func: MirFunction, result: WeavingResult) -> MirFunction:
    """Apply advice insertions from a WeavingResult to a MirFunction."""
    var woven = func
    for call_info in result.advice_calls:
        match call_info.join_point_kind:
            case Execution:
                woven = inject_before_advice(woven, call_info.advice_function)
            case FunctionCall:
                woven = inject_advice_at_instruction(woven, call_info.block_id, call_info.instruction_index, call_info.advice_function, true)
            case VariableAssignment:
                woven = inject_advice_at_instruction(woven, call_info.block_id, call_info.instruction_index, call_info.advice_function, false)
            case Error:
                woven = inject_after_error_advice(woven, call_info.advice_function)
            case _:
                # Decision, Condition — inject at entry for now
                woven = inject_before_advice(woven, call_info.advice_function)
    woven

# ============================================================================
# Helpers
# ============================================================================

fn make_advice_call_inst(advice_fn_name: text) -> MirInst:
    """Create a MIR Call instruction to an advice function (void -> void)."""
    val func_operand = MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Str(advice_fn_name),
        MirType(kind: MirTypeKind.FuncPtr(MirSignature(
            params: [],
            return_type: MirType.unit(),
            is_variadic: false
        )))
    ))
    MirInst(
        kind: MirInstKind.Call(nil, func_operand, []),
        span: nil
    )
