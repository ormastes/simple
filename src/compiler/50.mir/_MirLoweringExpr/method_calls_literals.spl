# Part of src/compiler/50.mir/mir_lowering_expr.spl: method calls, writeback, gpu intrinsics, array/tuple/set/const literals
use compiler.mir.mir_lowering_expr.*
# MIR Lowering - Expression Lowering
#
# Expression lowering from HIR to MIR:
# - Literal lowering (int, float, bool, string, nil, unit)
# - Variable references
# - Binary/unary operators (including special pipeline/compose/parallel)
# - Function calls (direct and indirect)
# - Method calls (instance, trait, static, free function / UFCS)
# - Array, tuple, set, and constant expression lowering
# - Field access

use compiler.mir.mir_data.*
use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.common.diagnostics.span.{Span}
use compiler.blocks.value.BlockValue
use compiler.mir.mir_lowering_types.{MirLowering, MirError}
use compiler.backend.gpu_intrinsics.{is_gpu_intrinsic}

extern fn rt_env_get(key: text) -> text

# ============================================================================
# Expression Lowering
# ============================================================================

impl MirLowering:
    me tag_str_local_if_raw(value_local: LocalId) -> LocalId:
        """A raw char* (string literal, MirType Opaque "str") must be tagged via
        rt_strlen + rt_string_new before entering the tagged rt_string_* ABI;
        any other value is already tagged/int and passes through (same scheme
        as the push fallback's push_val_is_raw_str below)."""
        var tsr_is_raw = false
        if val tsr_ty = self.local_mir_type_of(value_local):
            match tsr_ty.kind:
                case MirTypeKind.Opaque(tsr_ty_name):
                    if tsr_ty_name == "str":
                        tsr_is_raw = true
                case _: ()
        if not tsr_is_raw:
            return value_local
        val tsr_len_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_strlen"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_tsrlen = self.builder
        val tsr_len_res = b_tsrlen.emit_call(tsr_len_op, [mir_operand_copy(value_local)], MirType.i64())
        self.builder = b_tsrlen
        if val tsr_len_local = tsr_len_res:
            val tsr_new_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_string_new"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_tsrnew = self.builder
            val tsr_new_res = b_tsrnew.emit_call(tsr_new_op, [mir_operand_copy(value_local), mir_operand_copy(tsr_len_local)], MirType.i64())
            self.builder = b_tsrnew
            if val tsr_new_local = tsr_new_res:
                return tsr_new_local
        value_local

    me ensure_tagged_str(value_local: LocalId) -> LocalId:
        """Task #178 (text3 lane): normalize a text value to a DEFINITELY
        tagged heap-string handle, regardless of whether it started tagged
        (a runtime string, e.g. a concat/replace result) or raw (a bootstrap
        string literal). Unlike tag_str_local_if_raw above -- which decides
        "is this raw" from the STATIC MIR type alone (Opaque "str" always
        assumed raw) and unconditionally re-tags, corrupting an
        ALREADY-tagged value by strlen-ing its RtCoreString header bytes as
        if they were the string content (the exact bug this task's `.len()`
        fix, in the same file, had to back out of) -- this does a RUNTIME
        tagged-or-raw check first via rt_interp_cstr (bug #136's
        autodetection: unwraps an already-tagged handle to its real data
        buffer, or passes an already-raw char* through unchanged), THEN
        (re)tags that guaranteed-raw buffer via rt_strlen + rt_string_new.
        Safe for both representations. Used to fix `.starts_with()`/
        `.ends_with()`'s RECEIVER (their existing code below only tagged the
        prefix/suffix ARGUMENT, silently assuming the receiver is always an
        already-tagged "argv element" -- a genuinely-raw literal receiver,
        e.g. `val s = "hello world"; s.starts_with("hello")`, made
        rt_string_starts_with's rt_core_as_string(receiver) check fail and
        silently return false always)."""
        val ets_cstr_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_interp_cstr"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
        ))
        var b_ets_cstr = self.builder
        val ets_cstr_res = b_ets_cstr.emit_call(ets_cstr_op, [mir_operand_copy(value_local)], MirType(kind: MirTypeKind.Opaque("str")))
        self.builder = b_ets_cstr
        var ets_raw = value_local
        if val ets_cstr_local = ets_cstr_res:
            ets_raw = ets_cstr_local
        val ets_len_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_strlen"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_ets_len = self.builder
        val ets_len_res = b_ets_len.emit_call(ets_len_op, [mir_operand_copy(ets_raw)], MirType.i64())
        self.builder = b_ets_len
        if val ets_len_local = ets_len_res:
            val ets_new_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_string_new"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_ets_new = self.builder
            val ets_new_res = b_ets_new.emit_call(ets_new_op, [mir_operand_copy(ets_raw), mir_operand_copy(ets_len_local)], MirType.i64())
            self.builder = b_ets_new
            if val ets_new_local = ets_new_res:
                return ets_new_local
        ets_raw

    me lower_text_split_lines(receiver: HirExpr) -> LocalId:
        """Lower `text.split_lines()` (bug: pure_simple_text_split_lines_missing).

        Semantics (matches Rust's str::lines(), per the bug doc): split on
        "\\n", treating "\\r\\n" as a single separator (a trailing "\\r" is
        stripped from every line), and never emit a trailing empty line when
        the text ends with a newline.

        Built ENTIRELY out of already-supported primitives -- no new extern:
          1. normalized = receiver.replace("\\r\\n", "\\n")   (existing
             rt_string_replace, same call shape as the "replace" special
             case above -- collapses CRLF to LF in one pass, so no
             per-line \\r-stripping loop is needed).
          2. ends_nl = normalized.ends_with("\\n")   (existing
             rt_string_ends_with, same call shape as the "ends_with"
             special case above).
          3. If ends_nl: strip exactly the final "\\n" via the same
             rt_string_len + rt_interp_cstr + spl_str_slice sequence the
             "substring"/"slice" special case above already uses (raw-buffer
             slice, then re-tag via ensure_tagged_str).
          4. lines = body.split("\\n")   (existing rt_string_split, same
             call shape as the "split" special case above); flagged
             runtime_array_locals exactly like plain `.split()` so
             downstream indexing/for-in/.len() route through rt_array_get.
          5. Clear the split result for empty input via existing
             rt_array_clear, preserving Rust's empty iterator semantics.

        No loop/array-copy machinery is required: collapsing CRLF up front
        and trimming at most one trailing separator before the single
        split() call reuses 100% pre-existing call shapes.
        """
        val sl_recv_raw = self.lower_expr(receiver)
        val ts_recv = self.ensure_tagged_str(sl_recv_raw)

        val str_ty = MirType(kind: MirTypeKind.Opaque("str"))

        var b_crlf = self.builder
        val crlf_raw = b_crlf.new_temp(str_ty)
        b_crlf.emit_const(crlf_raw, MirConstValue.Str("\r\n"), str_ty)
        self.builder = b_crlf
        val crlf_lit = self.ensure_tagged_str(crlf_raw)

        var b_lf = self.builder
        val lf_raw = b_lf.new_temp(str_ty)
        b_lf.emit_const(lf_raw, MirConstValue.Str("\n"), str_ty)
        self.builder = b_lf
        val lf_lit = self.ensure_tagged_str(lf_raw)

        # normalized = receiver.replace("\r\n", "\n")
        val replace_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_string_replace"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: str_ty, is_variadic: false)))
        ))
        var b_repl = self.builder
        val normalized_res = b_repl.emit_call(replace_op, [mir_operand_copy(ts_recv), mir_operand_copy(crlf_lit), mir_operand_copy(lf_lit)], str_ty)
        val normalized = normalized_res ?? b_repl.new_temp(str_ty)
        self.builder = b_repl

        val length_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_string_len"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_length = self.builder
        val length_res = b_length.emit_call(length_op, [mir_operand_copy(normalized)], MirType.i64())
        val full_len = length_res ?? b_length.new_temp(MirType.i64())
        self.builder = b_length

        # ends_nl = normalized.ends_with("\n")  (raw i64 0/1, normalized to Bool via != 0)
        val ew_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_string_ends_with"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_ew = self.builder
        val ends_res = b_ew.emit_call(ew_op, [mir_operand_copy(normalized), mir_operand_copy(lf_lit)], MirType.i64())
        val ends_nl = ends_res ?? b_ew.new_temp(MirType.i64())
        val zero_i = b_ew.emit_const_int(0)
        val cond = b_ew.emit_binop(MirBinOp.Ne, mir_operand_copy(ends_nl), mir_operand_copy(zero_i), MirType.bool())
        self.builder = b_ew

        var b_prep = self.builder
        val strip_block = b_prep.new_block(Some("split_lines_strip"))
        val keep_block = b_prep.new_block(Some("split_lines_keep"))
        val merge_block = b_prep.new_block(Some("split_lines_merge"))
        val body_local = b_prep.new_temp(str_ty)
        b_prep.terminate_if(mir_operand_copy(cond), strip_block, keep_block)
        self.builder = b_prep

        # strip_block: body = normalized[0 .. len-1)  (drop the trailing "\n")
        var b_strip = self.builder
        b_strip.switch_to_block(strip_block)
        self.builder = b_strip

        val cstr_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_interp_cstr"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: str_ty, is_variadic: false)))
        ))
        var b_cstr = self.builder
        val cstr_res = b_cstr.emit_call(cstr_op, [mir_operand_copy(normalized)], str_ty)
        val raw_buf = cstr_res ?? normalized
        self.builder = b_cstr

        var b_slen = self.builder
        val one_i = b_slen.emit_const_int(1)
        val trimmed_len = b_slen.emit_binop(MirBinOp.Sub, mir_operand_copy(full_len), mir_operand_copy(one_i), MirType.i64())
        val zero_idx = b_slen.emit_const_int(0)
        self.builder = b_slen

        val sslice_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("spl_str_slice"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: str_ty, is_variadic: false)))
        ))
        var b_slice = self.builder
        val slice_res = b_slice.emit_call(sslice_op, [mir_operand_copy(raw_buf), mir_operand_copy(zero_idx), mir_operand_copy(trimmed_len)], str_ty)
        val stripped_raw = slice_res ?? raw_buf
        self.builder = b_slice
        val stripped_tagged = self.ensure_tagged_str(stripped_raw)

        var b_strip_end = self.builder
        b_strip_end.emit_copy(body_local, stripped_tagged)
        b_strip_end.terminate_goto(merge_block)
        self.builder = b_strip_end

        # keep_block: body = normalized (no trailing newline to drop)
        var b_keep = self.builder
        b_keep.switch_to_block(keep_block)
        b_keep.emit_copy(body_local, normalized)
        b_keep.terminate_goto(merge_block)
        self.builder = b_keep

        var b_merge = self.builder
        b_merge.switch_to_block(merge_block)
        self.builder = b_merge

        # lines = body.split("\n")
        val split_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_string_split"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b_split = self.builder
        val split_res = b_split.emit_call(split_op, [mir_operand_copy(body_local), mir_operand_copy(lf_lit)], MirType.i64())
        val lines_local = split_res ?? body_local
        self.builder = b_split

        val empty_zero = b_split.emit_const_int(0)
        val empty_input = b_split.emit_binop(MirBinOp.Eq, mir_operand_copy(full_len), mir_operand_copy(empty_zero), MirType.bool())
        val clear_block = b_split.new_block(Some("split_lines_clear_empty"))
        val keep_lines_block = b_split.new_block(Some("split_lines_keep_lines"))
        val lines_done_block = b_split.new_block(Some("split_lines_done"))
        b_split.terminate_if(mir_operand_copy(empty_input), clear_block, keep_lines_block)
        self.builder = b_split

        var b_clear = self.builder
        b_clear.switch_to_block(clear_block)
        val clear_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_clear"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.I8), is_variadic: false)))
        ))
        b_clear.emit_call(clear_op, [mir_operand_copy(lines_local)], MirType(kind: MirTypeKind.I8))
        b_clear.terminate_goto(lines_done_block)
        self.builder = b_clear

        var b_keep_lines = self.builder
        b_keep_lines.switch_to_block(keep_lines_block)
        b_keep_lines.terminate_goto(lines_done_block)
        self.builder = b_keep_lines

        var b_lines_done = self.builder
        b_lines_done.switch_to_block(lines_done_block)
        self.builder = b_lines_done
        self.runtime_array_locals[lines_local.id] = true
        val line_hir_type = HirType(kind: HirTypeKind.Str, span: receiver.span)
        self.local_hir_types[lines_local.id] = HirType(kind: HirTypeKind.Array(line_hir_type, nil), span: receiver.span)
        lines_local

    me result_ok_hir_type(receiver: HirExpr) -> HirType?:
        val receiver_type = self.enum_match_expr_type(receiver)
        if receiver_type != nil:
            val found_type = receiver_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
            match found_type.kind:
                case HirTypeKind.Result(ok_type, _): return Some(ok_type)
                case _: ()
        nil

    me result_err_hir_type(receiver: HirExpr) -> HirType?:
        val receiver_type = self.enum_match_expr_type(receiver)
        if receiver_type != nil:
            val found_type = receiver_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
            match found_type.kind:
                case HirTypeKind.Result(_, err_type): return Some(err_type)
                case _: ()
        nil

    me option_inner_hir_type(receiver: HirExpr) -> HirType?:
        val receiver_type = self.enum_match_expr_type(receiver)
        if receiver_type != nil:
            val found_type = receiver_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
            match found_type.kind:
                case HirTypeKind.Optional(inner_type): return Some(inner_type)
                case _: ()
        nil

    me option_inner_hir_type_for_local(receiver: HirExpr, local: LocalId) -> HirType?:
        val declared = self.option_inner_hir_type(receiver)
        if declared != nil:
            return declared
        if self.local_hir_types.has(local.id):
            val local_type = self.local_hir_types[local.id]
            match local_type.kind:
                case HirTypeKind.Optional(inner_type): return Some(inner_type)
                case _: ()
        nil

    me method_receiver_is_option(receiver: HirExpr, local: LocalId) -> bool:
        if self.option_inner_hir_type_for_local(receiver, local) != nil:
            return true
        self.nil_locals.has(local.id)

    me option_map_value_hir_type(local: LocalId, span: Span) -> HirType?:
        """Recover the primitive type needed to decode an Option.map result."""
        if self.local_hir_types.has(local.id):
            val known = self.local_hir_types[local.id]
            match known.kind:
                case HirTypeKind.Int(_, _) | HirTypeKind.Float(_) | HirTypeKind.Bool | HirTypeKind.Char | HirTypeKind.Str:
                    return Some(known)
                case _: ()
        if self.struct_value_syms.has(local.id) or self.runtime_array_locals.has(local.id) or self.runtime_dict_locals.has(local.id) or self.runtime_value_locals.has(local.id):
            return nil
        if val type_ = self.local_mir_type_of(local):
            # NOTE: each arm returns directly (rather than yielding a value
            # assigned via `val kind = match ...` and wrapped afterwards) --
            # a match-arm that mixes a plain-value arm (bare no-payload enum
            # variant like `HirTypeKind.Str`) with a sibling arm that does an
            # early `return` from within a nested `if/else` corrupts the
            # bare-variant tag under the seed interpreter (root cause of the
            # option_is_none_map_llvm ptr->i1 cast bug: this exact pattern
            # made `HirTypeKind.Str` fail to match `case HirTypeKind.Str` at
            # the call site, so `.unwrap_or()` never took the text path).
            match type_.kind:
                case MirTypeKind.I8: return Some(HirType(kind: HirTypeKind.Int(8, true), span: span))
                case MirTypeKind.U8: return Some(HirType(kind: HirTypeKind.Int(8, false), span: span))
                case MirTypeKind.I16: return Some(HirType(kind: HirTypeKind.Int(16, true), span: span))
                case MirTypeKind.U16: return Some(HirType(kind: HirTypeKind.Int(16, false), span: span))
                case MirTypeKind.I32: return Some(HirType(kind: HirTypeKind.Int(32, true), span: span))
                case MirTypeKind.U32: return Some(HirType(kind: HirTypeKind.Int(32, false), span: span))
                case MirTypeKind.I64: return Some(HirType(kind: HirTypeKind.Int(64, true), span: span))
                case MirTypeKind.U64: return Some(HirType(kind: HirTypeKind.Int(64, false), span: span))
                case MirTypeKind.F32: return Some(HirType(kind: HirTypeKind.Float(32), span: span))
                case MirTypeKind.F64: return Some(HirType(kind: HirTypeKind.Float(64), span: span))
                case MirTypeKind.Bool: return Some(HirType(kind: HirTypeKind.Bool, span: span))
                case MirTypeKind.Char: return Some(HirType(kind: HirTypeKind.Char, span: span))
                case MirTypeKind.Opaque(name):
                    if name == "str":
                        return Some(HirType(kind: HirTypeKind.Str, span: span))
                    else:
                        return nil
                case _: return nil
        nil

    me option_text_value(value_local: LocalId, result_type: MirType) -> LocalId:
        val text_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_interp_cstr"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: result_type, is_variadic: false)))
        ))
        var b_text = self.builder
        val text_res = b_text.emit_call(text_op, [mir_operand_copy(value_local)], result_type)
        self.builder = b_text
        text_res ?? value_local

    me option_payload_or_self(value_local: LocalId) -> LocalId:
        val unwrap_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_unwrap_or_self"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
        ))
        var b = self.builder
        val result = b.emit_call(unwrap_op, [mir_operand_copy(value_local)], MirType.i64())
        self.builder = b
        result ?? value_local

    me option_bool_value(value_local: LocalId) -> LocalId:
        """Decode an `Option<bool>` receiver back to a genuine i1.

        `Option<T>` locals are lowered (function_lowering.spl's `lower_type`,
        `Optional(inner) -> Tuple([Bool, inner])`) to the flat-nullable-ABI
        pointer representation everywhere the backend primes an aggregate
        MIR type as `ptr` (matches how `is_some`/`is_none` reinterpret the
        receiver as a pointer for the null check). For `Option<i64>` this is
        representationally free -- an i64 payload is pointer-width, so the
        raw ptr bit pattern IS already usable wherever an i64 is expected
        (arithmetic like `x * 2` round-trips through the backend's implicit
        ptrtoint coercions) -- but `Option<bool>`'s 1-bit payload is NOT
        pointer-width: binding the raw ptr-typed receiver directly as a
        lambda parameter or unwrap_or result (declared type Bool) leaves a
        `not x`/comparison operating on a genuine `ptr` value instead of a
        real `i1`, which the backend's unary/binop lowering then
        misinterprets as an implicit is-null/truthiness check on the pointer
        itself (parity case option_is_none_map_llmv's `some_bool.map(fn(x:
        bool) -> bool: not x)` and plain `some_bool.unwrap_or(false)`).
        Bridge explicitly: ptrtoint to a real integer width, then trunc down
        to i1 -- the same two-step reversal of value_as_type's i1->ptr
        "handle unbox" bridge in core_codegen.spl."""
        var b_wide = self.builder
        val widened = b_wide.emit_cast(mir_operand_copy(value_local), MirType.i64())
        self.builder = b_wide
        var b_narrow = self.builder
        val narrowed = b_narrow.emit_cast(mir_operand_copy(widened), MirType.bool())
        self.builder = b_narrow
        narrowed

    me lower_result_unwrap(receiver: HirExpr, payload_type: HirType, default_expr: HirExpr?, unwrap_err: bool) -> LocalId:
        var result_type = MirType.i64()
        var is_text = false
        var supported = false
        var result_struct_name = ""
        match payload_type.kind:
            case HirTypeKind.Int(bits, signed):
                if bits == 64 and signed:
                    supported = true
            case HirTypeKind.Str:
                result_type = self.bootstrap_text_type()
                is_text = true
                supported = true
            case HirTypeKind.Named(symbol, _):
                if default_expr == nil:
                    val type_symbol = self.symbols.get_symbol(symbol)
                    if type_symbol != nil:
                        match type_symbol.kind:
                            case Struct:
                                result_struct_name = type_symbol.name
                                supported = true
                            case _: ()
            case _: ()
        if not supported:
            val operation = if unwrap_err: "unwrap_err" else: "unwrap"
            self.error("unsupported Result {operation} payload type", Some(receiver.span))
            var b_bad = self.builder
            val bad = b_bad.emit_const_int(0)
            self.builder = b_bad
            return bad

        val receiver_local = self.lower_expr(receiver)
        var b_disc = self.builder
        val disc_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_enum_discriminant"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
        ))
        val disc_res = b_disc.emit_call(disc_op, [mir_operand_copy(receiver_local)], MirType.i64())
        var disc_local = LocalId(id: 0)
        if val found_disc = disc_res:
            disc_local = found_disc
        val payload_key = b_disc.emit_const_int(if unwrap_err: 1 else: 0)
        val has_payload = b_disc.emit_binop(MirBinOp.Eq, mir_operand_copy(disc_local), mir_operand_copy(payload_key), MirType.bool())
        val payload_block = b_disc.new_block(Some("result_unwrap_payload"))
        val mismatch_block = b_disc.new_block(Some("result_unwrap_mismatch"))
        val merge_block = b_disc.new_block(Some("result_unwrap_merge"))
        val result_local = b_disc.new_temp(result_type)
        b_disc.terminate_if(mir_operand_copy(has_payload), payload_block, mismatch_block)
        self.builder = b_disc

        var b_ok = self.builder
        b_ok.switch_to_block(payload_block)
        val payload_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_enum_payload"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
        ))
        val payload_res = b_ok.emit_call(payload_op, [mir_operand_copy(receiver_local)], MirType.i64())
        self.builder = b_ok
        var payload_value = receiver_local
        if val payload_local = payload_res:
            payload_value = payload_local
        if is_text:
            var b_text = self.builder
            val text_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_interp_cstr"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: result_type, is_variadic: false)))
            ))
            val text_res = b_text.emit_call(text_op, [mir_operand_copy(payload_value)], result_type)
            self.builder = b_text
            if val text_local = text_res:
                payload_value = text_local
        b_ok = self.builder
        b_ok.emit_copy(result_local, payload_value)
        b_ok.terminate_goto(merge_block)
        self.builder = b_ok

        var b_err = self.builder
        b_err.switch_to_block(mismatch_block)
        self.builder = b_err
        if default_expr != nil:
            val fallback_expr = default_expr ?? HirExpr(kind: HirExprKind.NilLit, type_: nil, span: receiver.span)
            var fallback = self.lower_expr(fallback_expr)
            if is_text and self.runtime_value_locals.has(fallback.id):
                fallback = self.decode_runtime_value(fallback, result_type)
            b_err = self.builder
            b_err.emit_copy(result_local, fallback)
        else:
            val panic_text = if unwrap_err: "called `.unwrap_err()` on an Ok Result" else: "called `.unwrap()` on an Err Result"
            val panic_msg = b_err.emit_const_str(panic_text)
            val panic_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_panic"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.unit(), is_variadic: false)))
            ))
            b_err.emit_call(panic_op, [mir_operand_copy(panic_msg)], MirType.unit())
            b_err.emit_const(result_local, MirConstValue.Zero, result_type)
        b_err.terminate_goto(merge_block)
        self.builder = b_err

        var b_merge = self.builder
        b_merge.switch_to_block(merge_block)
        self.builder = b_merge
        if result_struct_name != "":
            self.struct_value_syms[result_local.id] = result_struct_name
            self.local_hir_types[result_local.id] = payload_type
        result_local

    me lower_method_call(receiver: HirExpr, method: text, args: [HirCallArg], resolution: MethodResolution) -> LocalId:
        """Lower method call based on resolution.

        UFCS: For FreeFunction resolution, receiver becomes first argument.
        Handles this.index()/thread_index()/group_index() for @simd kernels.

        Indexed/field receiver write-back: when the receiver is `arr[i]` or
        `obj.field` and the method is in `is_mutating_method`, we pre-lower
        the base/index/field locals, dispatch the call with the loaded
        receiver, then emit a store-back so mutations reach the original
        slot. Without this, `stack[i].push(x)` silently discards the
        mutation because the receiver is loaded as a value copy into a
        temporary (pure-Simple equivalent of Rust seed bug #28).
        """
        val resolution_is_unresolved = match resolution:
            case Unresolved: true
            case _: false
        var result_ok_type: HirType? = nil
        var result_err_type: HirType? = nil
        if method == "unwrap" or method == "unwrap_or":
            result_ok_type = self.result_ok_hir_type(receiver)
        if method == "unwrap_err":
            result_err_type = self.result_err_hir_type(receiver)

        # Native entry lowering commonly has no MethodResolution, so probe
        # Option-like receivers once and reuse that local in the Unresolved
        # owner fallback. This keeps builtin names type-directed and prevents
        # custom methods with the same leaf name from being stolen.
        var prelowered_method_receiver: LocalId = 0
        var has_prelowered_method_receiver = false
        var option_method_receiver = false
        val declared_option_receiver = self.option_inner_hir_type(receiver) != nil
        val option_method_shape =
            (method == "is_some" and args.len() == 0) or
            (method == "is_none" and args.len() == 0) or
            (method == "map" and args.len() == 1) or
            (method == "unwrap" and args.len() == 0 and result_ok_type == nil) or
            (method == "unwrap_or" and args.len() == 1 and result_ok_type == nil)
        val probe_option_receiver = option_method_shape and (resolution_is_unresolved or declared_option_receiver)
        if probe_option_receiver:
            prelowered_method_receiver = self.lower_expr(receiver)
            has_prelowered_method_receiver = true
            option_method_receiver = self.method_receiver_is_option(receiver, prelowered_method_receiver)

        if method == "is_some" and args.len() == 0 and option_method_receiver:
            val receiver_local = prelowered_method_receiver
            val is_some = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_is_some"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                    params: [MirType.i64()], return_type: MirType.bool(), is_variadic: false
                )))
            ))
            return self.emit_resolved_direct_call(is_some, [mir_operand_copy(receiver_local)], MirType.bool())

        # `.is_none()` -- mirror of `.is_some()` immediately above, same
        # rt_is_none runtime helper the ExistsCheck/NullCoalesce (`.?`/`??`)
        # lowering already relies on for its is-nil branch test.
        if method == "is_none" and args.len() == 0 and option_method_receiver:
            val receiver_local = prelowered_method_receiver
            val is_none = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_is_none"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                    params: [MirType.i64()], return_type: MirType.bool(), is_variadic: false
                )))
            ))
            return self.emit_resolved_direct_call(is_none, [mir_operand_copy(receiver_local)], MirType.bool())

        # `.unwrap()` accepts the canonical enum-id-1 Option handle plus the
        # raw migration form. A present value yields its payload and nil/None
        # panics. Branch on rt_is_some(receiver), never truthiness, so a
        # present numeric zero is preserved.
        if method == "unwrap" and args.len() == 0:
            if result_ok_type != nil:
                return self.lower_result_unwrap(receiver, result_ok_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span), nil, false)

        # `.unwrap_err()` is Result-owned, never a backend leaf-name alias.
        if method == "unwrap_err" and args.len() == 0 and result_err_type != nil:
            return self.lower_result_unwrap(receiver, result_err_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span), nil, true)

        # `.unwrap()` accepts the canonical enum-id-1 Option handle plus the
        # raw migration form. A present value yields its payload and nil/None
        # panics. Branch on rt_is_some(receiver), never truthiness, so a
        # present numeric zero is preserved.
        if method == "unwrap" and args.len() == 0 and option_method_receiver:
            val receiver_local = prelowered_method_receiver
            var unwrap_result_type = MirType.i64()
            var unwrap_is_text = false
            var unwrap_is_bool = false
            val inner_type_uw = self.option_inner_hir_type_for_local(receiver, receiver_local)
            if inner_type_uw != nil:
                val found_inner_uw = inner_type_uw ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
                match found_inner_uw.kind:
                    case HirTypeKind.Str:
                        unwrap_result_type = self.bootstrap_text_type()
                        unwrap_is_text = true
                    case HirTypeKind.Bool:
                        unwrap_result_type = MirType.bool()
                        unwrap_is_bool = true
                    case _: unwrap_result_type = self.lower_type(found_inner_uw)
            elif self.local_is_str(receiver_local):
                unwrap_result_type = self.bootstrap_text_type()
                unwrap_is_text = true
            elif val receiver_mir_type_uw = self.local_mir_type_of(receiver_local):
                unwrap_result_type = receiver_mir_type_uw

            var b_uw_chk = self.builder
            val is_some_uw_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_is_some"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                    params: [MirType.i64()], return_type: MirType.bool(), is_variadic: false
                )))
            ))
            val is_some_uw_res = b_uw_chk.emit_call(is_some_uw_op, [mir_operand_copy(receiver_local)], MirType.bool())
            self.builder = b_uw_chk
            var is_some_uw_local = LocalId(id: 0)
            if val isl = is_some_uw_res:
                is_some_uw_local = isl

            var b_split_uw = self.builder
            val some_block_uw = b_split_uw.new_block(Some("unwrap_some"))
            val none_block_uw = b_split_uw.new_block(Some("unwrap_none"))
            val merge_block_uw = b_split_uw.new_block(Some("unwrap_merge"))
            val result_local_uw = b_split_uw.new_temp(unwrap_result_type)
            b_split_uw.terminate_if(mir_operand_copy(is_some_uw_local), some_block_uw, none_block_uw)
            self.builder = b_split_uw

            var b_some_uw = self.builder
            b_some_uw.switch_to_block(some_block_uw)
            self.builder = b_some_uw
            var some_val_uw = self.option_payload_or_self(receiver_local)
            if unwrap_is_text:
                some_val_uw = self.option_text_value(some_val_uw, unwrap_result_type)
            elif self.runtime_value_locals.has(receiver_local.id) and not self.option_value_locals.has(receiver_local.id):
                some_val_uw = self.decode_runtime_value(receiver_local, unwrap_result_type)
            elif unwrap_is_bool:
                some_val_uw = self.option_bool_value(some_val_uw)
            b_some_uw = self.builder
            b_some_uw.emit_copy(result_local_uw, some_val_uw)
            b_some_uw.terminate_goto(merge_block_uw)
            self.builder = b_some_uw

            var b_none_uw = self.builder
            b_none_uw.switch_to_block(none_block_uw)
            self.builder = b_none_uw
            val panic_msg_uw = b_none_uw.emit_const_str("called `.unwrap()` on a nil Option")
            val panic_op_uw = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_panic"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.unit(), is_variadic: false)))
            ))
            b_none_uw.emit_call(panic_op_uw, [mir_operand_copy(panic_msg_uw)], MirType.unit())
            b_none_uw.emit_const(result_local_uw, MirConstValue.Zero, unwrap_result_type)
            b_none_uw.terminate_goto(merge_block_uw)
            self.builder = b_none_uw

            if self.runtime_value_locals.has(some_val_uw.id):
                self.runtime_value_locals[result_local_uw.id] = true

            var b_merge_uw = self.builder
            b_merge_uw.switch_to_block(merge_block_uw)
            self.builder = b_merge_uw
            return result_local_uw

        # `.unwrap_or(default)` accepts canonical and migration Option forms:
        # a present value yields its payload and nil/None yields `default`.
        # Structurally identical to the `NullCoalesce` (`x ?? default`)
        # lowering in expr_dispatch.spl: branch on rt_is_some (not
        # truthiness, so `Some(0).unwrap_or(9)` yields 0), lower the default
        # expression lazily inside the none-branch (mirrors `??`'s laziness),
        # merge via a shared result slot rather than the phi intrinsic (same
        # "PHI nodes not grouped at top of basic block" hazard documented
        # there).
        if method == "unwrap_or" and args.len() == 1:
            if result_ok_type != nil:
                return self.lower_result_unwrap(receiver, result_ok_type ?? HirType(kind: HirTypeKind.Error, span: receiver.span), Some(args[0].value), false)

        if method == "unwrap_or" and args.len() == 1 and option_method_receiver:
            val receiver_local = prelowered_method_receiver
            var uo_result_type = MirType.i64()
            var uo_is_text = false
            val inner_type_uo = self.option_inner_hir_type_for_local(receiver, receiver_local)
            if inner_type_uo != nil:
                val found_inner_uo = inner_type_uo ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
                match found_inner_uo.kind:
                    case HirTypeKind.Str:
                        uo_result_type = self.bootstrap_text_type()
                        uo_is_text = true
                    case _: uo_result_type = self.lower_type(found_inner_uo)
            elif self.local_is_str(receiver_local):
                uo_result_type = self.bootstrap_text_type()
                uo_is_text = true
            elif val receiver_mir_type_uo = self.local_mir_type_of(receiver_local):
                uo_result_type = receiver_mir_type_uo

            var b_uo_chk = self.builder
            val is_some_uo_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_is_some"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                    params: [MirType.i64()], return_type: MirType.bool(), is_variadic: false
                )))
            ))
            val is_some_uo_res = b_uo_chk.emit_call(is_some_uo_op, [mir_operand_copy(receiver_local)], MirType.bool())
            self.builder = b_uo_chk
            var is_some_uo_local = LocalId(id: 0)
            if val isl = is_some_uo_res:
                is_some_uo_local = isl

            var b_split_uo = self.builder
            val some_block_uo = b_split_uo.new_block(Some("unwrap_or_some"))
            val none_block_uo = b_split_uo.new_block(Some("unwrap_or_none"))
            val merge_block_uo = b_split_uo.new_block(Some("unwrap_or_merge"))
            val result_local_uo = b_split_uo.new_temp(uo_result_type)
            b_split_uo.terminate_if(mir_operand_copy(is_some_uo_local), some_block_uo, none_block_uo)
            self.builder = b_split_uo

            var b_some_uo = self.builder
            b_some_uo.switch_to_block(some_block_uo)
            self.builder = b_some_uo
            var uo_is_bool = false
            match uo_result_type.kind:
                case MirTypeKind.Bool: uo_is_bool = true
                case _: ()
            var some_val_uo = self.option_payload_or_self(receiver_local)
            if uo_is_text:
                some_val_uo = self.option_text_value(some_val_uo, uo_result_type)
            elif self.runtime_value_locals.has(receiver_local.id) and not self.option_value_locals.has(receiver_local.id):
                some_val_uo = self.decode_runtime_value(receiver_local, uo_result_type)
            elif uo_is_bool:
                # Bare `some_bool.unwrap_or(default)` (no `.map()` in
                # between): the receiver is the `Option<bool>` variable
                # itself, ptr-shaped per option_bool_value's doc comment, not
                # yet routed through box_runtime_value/decode_runtime_value's
                # tagged-Bool scheme (that only applies to a `.map()` result).
                # Decode the same way.
                some_val_uo = self.option_bool_value(some_val_uo)
            b_some_uo = self.builder
            b_some_uo.emit_copy(result_local_uo, some_val_uo)
            b_some_uo.terminate_goto(merge_block_uo)
            self.builder = b_some_uo

            var b_none_uo = self.builder
            b_none_uo.switch_to_block(none_block_uo)
            self.builder = b_none_uo
            val default_local_uo = self.lower_expr(args[0].value)
            var default_val_uo = default_local_uo
            if uo_is_text:
                default_val_uo = self.option_text_value(default_local_uo, uo_result_type)
            elif self.runtime_value_locals.has(default_local_uo.id):
                default_val_uo = self.decode_runtime_value(default_local_uo, uo_result_type)
            b_none_uo = self.builder
            b_none_uo.emit_copy(result_local_uo, default_val_uo)
            b_none_uo.terminate_goto(merge_block_uo)
            self.builder = b_none_uo

            if self.runtime_value_locals.has(some_val_uo.id) or self.runtime_value_locals.has(default_val_uo.id):
                self.runtime_value_locals[result_local_uo.id] = true

            var b_merge_uo = self.builder
            b_merge_uo.switch_to_block(merge_block_uo)
            self.builder = b_merge_uo
            return result_local_uo

        # `.map(fn)` on a proven Option -- Some(v) yields Some(transform(v)),
        # nil stays nil. Arrays and custom owners may expose the same name, so
        # unknown receivers fall through to normal owner dispatch. Reuse the
        # probe above so a side-effecting receiver expression runs once.
        if method == "map" and args.len() == 1 and option_method_receiver:
            val recv_probe_local_map = prelowered_method_receiver
            if option_method_receiver:
                match args[0].value.kind:
                    case Lambda(map_params, map_body, _):
                        val receiver_local = recv_probe_local_map
                        var map_inner_type = MirType.i64()
                        val map_inner_hir = self.option_inner_hir_type_for_local(receiver, receiver_local)
                        if map_inner_hir != nil:
                            val found_inner_map = map_inner_hir ?? HirType(kind: HirTypeKind.Error, span: receiver.span)
                            match found_inner_map.kind:
                                case HirTypeKind.Str: map_inner_type = self.bootstrap_text_type()
                                case _: map_inner_type = self.lower_type(found_inner_map)
                        elif val map_inner_ty_local = self.local_mir_type_of(receiver_local):
                            map_inner_type = map_inner_ty_local

                        var b_map_chk = self.builder
                        val is_some_map_op = MirOperand(kind: MirOperandKind.Const(
                            MirConstValue.Str("rt_is_some"),
                            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                                params: [MirType.i64()], return_type: MirType.bool(), is_variadic: false
                            )))
                        ))
                        val is_some_map_res = b_map_chk.emit_call(is_some_map_op, [mir_operand_copy(receiver_local)], MirType.bool())
                        self.builder = b_map_chk
                        var is_some_map_local = LocalId(id: 0)
                        if val isl = is_some_map_res:
                            is_some_map_local = isl

                        var b_split_map = self.builder
                        val some_block_map = b_split_map.new_block(Some("option_map_some"))
                        val none_block_map = b_split_map.new_block(Some("option_map_none"))
                        val merge_block_map = b_split_map.new_block(Some("option_map_merge"))
                        val result_local_map = b_split_map.new_temp(MirType.i64())
                        b_split_map.terminate_if(mir_operand_copy(is_some_map_local), some_block_map, none_block_map)
                        self.builder = b_split_map

                        var b_some_map = self.builder
                        b_some_map.switch_to_block(some_block_map)
                        self.builder = b_some_map
                        var some_val_map = self.option_payload_or_self(receiver_local)
                        var map_inner_is_bool = false
                        match map_inner_type.kind:
                            case MirTypeKind.Bool: map_inner_is_bool = true
                            case _: ()
                        if self.runtime_value_locals.has(receiver_local.id) and not self.option_value_locals.has(receiver_local.id):
                            some_val_map = self.decode_runtime_value(receiver_local, map_inner_type)
                        elif map_inner_is_bool:
                            # `Option<bool>` receiver: see option_bool_value's
                            # doc comment -- the receiver is ptr-shaped (the
                            # flat-nullable-ABI encoding an `Optional(Bool)`
                            # local is primed with), not a raw i1, so binding
                            # it straight to the lambda's `x: bool` parameter
                            # would feed a `ptr` value into `not x` / any bool
                            # op. Decode explicitly.
                            some_val_map = self.option_bool_value(some_val_map)
                        val map_call_local = self.lower_inline_lambda_with_locals(map_params, map_body, [some_val_map])
                        val map_value_type = self.option_map_value_hir_type(map_call_local, map_body.span)
                        var map_call_tagged = map_call_local
                        var mapped_option_type = HirType(kind: HirTypeKind.Optional(
                            HirType(kind: HirTypeKind.Error, span: map_body.span)
                        ), span: map_body.span)
                        if map_value_type == nil:
                            self.error("unsupported Option.map result type", Some(map_body.span))
                            var b_bad_map = self.builder
                            map_call_tagged = b_bad_map.emit_const_int(3)
                            self.builder = b_bad_map
                        else:
                            val mapped_inner = map_value_type ?? HirType(kind: HirTypeKind.Error, span: map_body.span)
                            mapped_option_type = HirType(kind: HirTypeKind.Optional(mapped_inner), span: map_body.span)
                            map_call_tagged = self.ensure_option_handle(map_call_local, mapped_option_type)
                        var b_some_map2 = self.builder
                        b_some_map2.emit_copy(result_local_map, map_call_tagged)
                        b_some_map2.terminate_goto(merge_block_map)
                        self.builder = b_some_map2

                        var b_none_map = self.builder
                        b_none_map.switch_to_block(none_block_map)
                        self.builder = b_none_map
                        val map_none = b_none_map.emit_const_int(3)
                        self.builder = b_none_map
                        self.nil_locals[map_none.id] = true
                        val map_none_tagged = self.ensure_option_handle(map_none, mapped_option_type)
                        b_none_map = self.builder
                        b_none_map.emit_copy(result_local_map, map_none_tagged)
                        b_none_map.terminate_goto(merge_block_map)
                        self.builder = b_none_map

                        var b_merge_map = self.builder
                        b_merge_map.switch_to_block(merge_block_map)
                        self.builder = b_merge_map
                        self.runtime_value_locals[result_local_map.id] = true
                        self.option_value_locals[result_local_map.id] = true
                        self.local_hir_types[result_local_map.id] = mapped_option_type
                        return result_local_map
                    case _: ()

        # Reclassify `Shape.Circle(7)` — parsed as a MethodCall — into enum
        # construction when the receiver names a registered enum and `method` is
        # one of its variants. Real static methods (method NOT a variant) fall
        # through. Name-keyed to dodge the interpreter symbol_id_value(-1) quirk.
        var recv_enum_name = ""
        match receiver.kind:
            case Var(rsym):
                val rs = self.symbols.get_symbol(rsym)
                if rs.?: recv_enum_name = rs.name
            case NamedVar(_, rname):
                recv_enum_name = rname
            case _: ()
        if recv_enum_name != "" and self.enum_variant_index.has(recv_enum_name):
            var is_variant = false
            for vn in self.enum_variant_index[recv_enum_name]:
                if vn == method:
                    is_variant = true
            if is_variant:
                return self.lower_enum_construct_named(recv_enum_name, method, args)

        # Handle this.index() / this.thread_index() / this.group_index() for @simd
        match receiver.kind:
            case Var(sym):
                val recv_name = if self.symbols.get_symbol(sym).?: self.symbols.get_symbol(sym).name else: ""
                if recv_name == "this":
                    match method:
                        case "index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuGlobalId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case "thread_index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuLocalId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case "group_index":
                            var b = self.builder
                            val dest = b.new_temp(MirType.i64())
                            b.emit(MirInst(kind: MirInstKind.GpuBlockId(dest, 0), span: nil))
                            self.builder = b
                            return dest
                        case _: ()
            case _: ()

        # Pre-lower writeback origin for mutating methods on indexed/field receivers.
        # wb_kind: 0 = none, 1 = indexed (rt_array_set), 2 = field (emit_set_field)
        var wb_kind: i64 = 0
        var wb_base: LocalId = 0
        var wb_index: LocalId = 0
        var wb_field_idx: i64 = 0
        var wb_receiver: LocalId = 0
        var receiver_type = MirType.i64()
        val maybe_receiver_type_for_call = receiver.type_
        if maybe_receiver_type_for_call != nil:
            val found_receiver_type = maybe_receiver_type_for_call
            if found_receiver_type != nil:
                receiver_type = self.lower_type(found_receiver_type)

        # Bug #138: `resolution == Unresolved` (no method-resolution info for
        # this receiver -- HIR type inference never populated receiver.type_)
        # is the actual condition the untyped string-method fallbacks below
        # need, on EITHER the bootstrap flat-HIR path or the normal
        # native-build path -- both produce Unresolved here for the same
        # reason. Representation is identical on both paths too: argv
        # elements always come from `rt_get_args` -> `rt_cli_get_args`, which
        # tags them via `rt_string_new` regardless of SIMPLE_BOOTSTRAP.
        # Raw-pointer `.offset(index)` is element-based, while MirBinOp.Offset
        # is the backend-neutral byte-offset operation. Scale once here from
        # the receiver's pointee type so every backend and the interpreter see
        # the same byte displacement.
        if method == "offset" and args.len() == 1 and resolution_is_unresolved:
            val offset_receiver = self.lower_expr(receiver)
            var offset_receiver_type = receiver_type
            if val known_offset_type = self.local_mir_type_of(offset_receiver):
                offset_receiver_type = known_offset_type
            match offset_receiver_type.kind:
                case MirTypeKind.Ptr(pointee, _):
                    val offset_index = self.lower_expr(args[0].value)
                    var byte_offset = offset_index
                    val pointee_size = pointee.size_bytes()
                    if pointee_size != 1:
                        var offset_builder = self.builder
                        val size_local = offset_builder.emit_const_int(pointee_size)
                        byte_offset = offset_builder.emit_binop(
                            MirBinOp.Mul,
                            mir_operand_copy(offset_index),
                            mir_operand_copy(size_local),
                            MirType.i64()
                        )
                        self.builder = offset_builder
                    var offset_builder = self.builder
                    val offset_result = offset_builder.emit_binop(
                        MirBinOp.Offset,
                        mir_operand_copy(offset_receiver),
                        mir_operand_copy(byte_offset),
                        offset_receiver_type
                    )
                    self.builder = offset_builder
                    return offset_result
                case _: ()

        var receiver_is_dict = false
        if maybe_receiver_type_for_call != nil:
            val found_receiver_type = maybe_receiver_type_for_call
            if found_receiver_type != nil:
                match found_receiver_type.kind:
                    case Dict(_, _): receiver_is_dict = true
                    case _: ()

        # Dict method fallback detection (dictops sweep, same root gap as the
        # `.len()` fix below): HIR type inference frequently never populates
        # `receiver.type_` for a Dict-typed local, so `resolution` comes back
        # Unresolved and the static-type check above misses every dict method
        # call on such a receiver -- `.keys()`, `.values()`, `.has()`,
        # `.contains()`/`.contains_key()`, `.get()`, `.remove()`/`.delete()`
        # all fell through to the generic `case Unresolved:` handler (a loud,
        # correct-but-avoidable MIR error). Mirror the `.len()` fix: lower the
        # receiver once up front for this closed set of dict method names and
        # consult `runtime_dict_locals` (populated at every dict-literal/
        # assignment site independent of HIR static typing) to recover
        # dict-ness.
        var dict_recv_local: LocalId = 0
        var dict_recv_lowered = false
        val is_dict_method_name = method == "keys" or method == "values" or method == "has" or method == "contains" or method == "contains_key" or method == "get" or method == "remove" or method == "delete"
        if not receiver_is_dict and resolution_is_unresolved and is_dict_method_name:
            dict_recv_local = self.lower_expr(receiver)
            dict_recv_lowered = true
            # Bug (native_dict_param_no_dictness): mirrors the `.len()` fix
            # right below -- `local_is_runtime_dict` also falls back to the
            # receiver's registered MIR type (correct for a dict-typed
            # FUNCTION PARAMETER, whose local id never reaches
            # `runtime_dict_locals` since that map is only seeded at
            # dict-literal/assignment sites), not just the id-keyed map.
            # Without this, `d.keys()`/`.has()`/etc. on a `Dict<text,i64>`
            # param fell through to the generic Unresolved handler, which is
            # a LOUD "unresolved method call" native-build failure.
            if self.local_is_runtime_dict(dict_recv_local):
                receiver_is_dict = true
                self.runtime_dict_locals[dict_recv_local.id] = true

        if receiver_is_dict and (method == "values" or method == "keys") and args.len() == 0:
            val receiver_local = if dict_recv_lowered: dict_recv_local else: self.lower_expr(receiver)
            val runtime_name = if method == "values": "rt_dict_values" else: "rt_dict_keys"
            val func_operand = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str(runtime_name),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
            ))
            # Bug (native_dict_keys_iter_index): rt_dict_keys/rt_dict_values
            # return a real element type (the dict's key/value type, e.g.
            # tagged heap strings for `Dict<text,i64>.keys()`), but this call
            # was typed as a bare i64 return with no per-element MIR type
            # recorded on the result local (unlike `lower_dict_lit`, which
            # builds a typed `Dict(key_type, value_type)` temp). Without an
            # Array(elem_type,_) type on the result, `for k in d.keys()`
            # (lower_for_iterator, mir_lowering_stmts.spl) can't find an
            # element type from the collection's own MIR type and falls back
            # to i64 -- so decode_runtime_value decoded a TAGGED heap-string
            # key handle as an INTEGER (right-shift-by-3), corrupting it. The
            # corrupted `k` then hashed/matched nothing in `d[k]`'s
            # rt_dict_get, so every native `for k in d.keys(): s += d[k]`
            # summed to 0. Mirror lower_dict_lit's typed-temp pattern: recover
            # the dict's key_type/value_type via local_mir_type_of and stamp
            # an Array(elem_type, 0) type onto a fresh temp copy of the call
            # result, so the for-loop (and any other Array-typed consumer)
            # decodes each element correctly.
            var dict_keys_elem_type = MirType.i64()
            val dict_keys_recv_type = self.local_mir_type_of(receiver_local)
            if dict_keys_recv_type != nil:
                match dict_keys_recv_type.kind:
                    case Dict(k_type, v_type):
                        val picked_type = if method == "values": v_type else: k_type
                        # Bug (native_dict_call_result_keys_elem_type):
                        # a dict-typed local's key/value MIR type is not always
                        # the SAME string representation. A dict LITERAL's key
                        # type comes from `local_mir_type_of` on the raw
                        # (pre-box) key local, which for a string literal is
                        # `Opaque("str")` -- the representation
                        # `decode_runtime_value` (expr_dispatch.spl) explicitly
                        # recognizes and un-tags via rt_interp_cstr. A dict
                        # returned FROM A FUNCTION instead gets its key/value
                        # types from `lower_type(HirType)`, whose `Str` case
                        # always produces the fat-pointer `Tuple([Ptr(U8),
                        # U64])` representation, NOT `Opaque("str")`.
                        # `decode_runtime_value` has no case for that Tuple
                        # shape, so it fell through to the untyped default arm
                        # and returned the raw TAGGED heap-string handle
                        # un-decoded. The loop variable was then bound with
                        # that Tuple type instead of Opaque("str"), so
                        # `d[k]`'s `box_runtime_value(k)` also skipped its
                        # str-specific re-tagging step (the local was already
                        # marked `runtime_value_locals`) -- but `k` was never
                        # unwrapped to match the key representation
                        # `rt_dict_get`'s `rt_native_eq` compares against,
                        # so every lookup silently missed and returned 0.
                        # Normalize any string-shaped key/value type to
                        # `Opaque("str")` here (mirroring the representation a
                        # dict literal's raw string key already carries) so
                        # decode_runtime_value's existing Opaque("str") branch
                        # runs for a call-result dict's `.keys()`/`.values()`
                        # exactly like it already does for a literal dict's.
                        dict_keys_elem_type = if self.mir_type_is_str(picked_type):
                            MirType(kind: MirTypeKind.Opaque("str"))
                        else:
                            picked_type
                    case _: ()
            var b_dict = self.builder
            val result = b_dict.emit_call(func_operand, [mir_operand_copy(receiver_local)], MirType.i64())
            self.builder = b_dict
            if val result_local = result:
                val dict_keys_array_type = MirType(kind: MirTypeKind.Array(dict_keys_elem_type, 0))
                var b_dict_typed = self.builder
                val dict_keys_typed = b_dict_typed.new_temp(dict_keys_array_type)
                b_dict_typed.emit_copy(dict_keys_typed, result_local)
                self.builder = b_dict_typed
                self.runtime_array_locals[dict_keys_typed.id] = true
                self.runtime_value_locals[dict_keys_typed.id] = true
                return dict_keys_typed
            return receiver_local

        # `.has(key)` / `.contains(key)` / `.contains_key(key)` -> rt_dict_contains.
        # The runtime symbol (int8_t rt_dict_contains(int64_t, int64_t)) is
        # already linked and already backend-declared (asm_constraints_helpers.spl);
        # this method call just never routed to it. Result is a raw i64 0/1,
        # normalized to Bool via `!= 0` (mirrors the lambda-predicate pattern
        # elsewhere in this file, since `declare i64 @rt_dict_contains` cannot
        # return an LLVM i1 directly).
        if receiver_is_dict and (method == "has" or method == "contains" or method == "contains_key") and args.len() == 1:
            val receiver_local = if dict_recv_lowered: dict_recv_local else: self.lower_expr(receiver)
            val key_local = self.lower_dict_key(args[0].value)
            val contains_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_dict_contains"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_has = self.builder
            val has_call = b_has.emit_call(contains_op, [mir_operand_copy(receiver_local), mir_operand_copy(key_local)], MirType.i64())
            val has_raw = has_call ?? b_has.new_temp(MirType.i64())
            val zero_has = b_has.emit_const_int(0)
            val has_bool = b_has.emit_binop(MirBinOp.Ne, mir_operand_copy(has_raw), mir_operand_copy(zero_has), MirType.bool())
            self.builder = b_has
            return has_bool

        # `.get(key)` -> rt_dict_get, decoded exactly like the `d[k]` Index
        # case in expr_dispatch.spl (same runtime call, same decode_runtime_value
        # unboxing). Missing-key behavior intentionally mirrors the existing
        # `d[k]` raw-read path (pre-existing garbage-on-miss behavior documented
        # in scratchpad/dict_native_report.md item 15 -- not introduced here,
        # not fixed here, out of scope for this sweep).
        if receiver_is_dict and method == "get" and args.len() == 1:
            val receiver_local = if dict_recv_lowered: dict_recv_local else: self.lower_expr(receiver)
            val key_local = self.lower_dict_key(args[0].value)
            var get_value_type = MirType.i64()
            val dict_mir_type_get = self.local_mir_type_of(receiver_local)
            if dict_mir_type_get != nil:
                match dict_mir_type_get.kind:
                    case Dict(_, value_type): get_value_type = value_type
                    case _: ()
            val get_op2 = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_dict_get"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_get2 = self.builder
            val get_res2 = b_get2.emit_call(get_op2, [mir_operand_copy(receiver_local), mir_operand_copy(key_local)], MirType.i64())
            self.builder = b_get2
            if val get_local2 = get_res2:
                return self.decode_runtime_value(get_local2, get_value_type)
            return receiver_local

        # `.remove(key)` / `.delete(key)` -> rt_dict_remove (mutates in place,
        # returns whether the key was present -- discarded here). The oracle
        # (bootstrap-seed interpreter) implements dict methods with a
        # functional clone-then-mutate style internally, but re-binds the
        # result back onto the receiver identifier as an interpreter-level
        # side effect, so `d.remove(key)` is observably a mutation from the
        # caller's perspective either way (confirmed: `d.remove("a")` as a
        # bare statement, with no reassignment, still leaves `d.has("a")` ==
        # false on the oracle). Returning the same dict handle here matches
        # that observable behavior, including the common `d = d.remove(key)`
        # idiom (a no-op self-reassignment of the now-mutated handle).
        if receiver_is_dict and (method == "remove" or method == "delete") and args.len() == 1:
            val receiver_local = if dict_recv_lowered: dict_recv_local else: self.lower_expr(receiver)
            val key_local = self.lower_dict_key(args[0].value)
            val remove_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_dict_remove"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_rm = self.builder
            b_rm.emit_call(remove_op, [mir_operand_copy(receiver_local), mir_operand_copy(key_local)], MirType.i64())
            self.builder = b_rm
            return receiver_local

        if (method == "len" or method == "length") and args.len() == 0:
            var len_symbol = ""
            if maybe_receiver_type_for_call != nil:
                val found_receiver_type = maybe_receiver_type_for_call
                if found_receiver_type != nil:
                    len_symbol = self.len_runtime_symbol_for_hir_type(found_receiver_type)
            var receiver_local: LocalId = 0
            var receiver_lowered = false
            if len_symbol == "":
                match resolution:
                    case Unresolved:
                        # Bug #137/#138 (follow-up): an untyped receiver (no HIR
                        # type inference ran -- receiver.type_ is nil) leaves
                        # `resolution` Unresolved both under the bootstrap flat
                        # HIR path AND on the normal native-build path (the same
                        # gap: bootstrap_main.spl's `all_args[i]`/`first` locals
                        # never get a synthesized type). Forcing `rt_array_len`
                        # was correct only for arrays: on a tagged string it
                        # calls rt_core_array_ptr on a string handle and
                        # silently returns 0, so every `first.len() == N` guard
                        # in bootstrap_main (--version/--help/compile/
                        # native-build) was dead and never dispatched. rt_len is
                        # the unified accessor -- it routes a tagged string to
                        # its length and a (raw or tagged) array ptr to its
                        # element count -- so one symbol serves both call sites
                        # correctly, on either path. Previously this was gated
                        # behind SIMPLE_BOOTSTRAP=1; that env check was only ever
                        # a proxy for "no type info" and excluded the identical
                        # normal-path gap, so it now keys directly off
                        # `resolution == Unresolved` instead.
                        #
                        # Dict follow-up: rt_len's runtime fallback (rt_len in
                        # runtime_native.c) only special-cases tagged strings
                        # and array pointers -- a dict handle matches neither
                        # `rt_core_as_string` nor `rt_core_as_array`, so it
                        # falls through to a hardcoded 0 (`Dict.len()` silently
                        # returning 0 natively, never loud). There is no HIR
                        # static type available here to route straight to
                        # `rt_dict_len` (same root gap as above), but the
                        # MIR-lowering layer independently tracks dict-ness per
                        # local in `runtime_dict_locals` (populated at every
                        # dict-literal/assignment site -- see
                        # `lower_dict_literal` and mir_lowering_stmts.spl's var
                        # decl/reassign propagation), keyed off the lowered
                        # local id rather than the HIR type. Lower the receiver
                        # now (instead of after this match) so that map can be
                        # consulted, and prefer the already-linked, already
                        # backend-declared `rt_dict_len` runtime symbol over
                        # the generic accessor when it says so.
                        receiver_local = self.lower_expr(receiver)
                        receiver_lowered = true
                        # Bug (native_dict_param_no_dictness): `runtime_dict_locals`
                        # is only populated at dict-literal/assignment sites
                        # (lower_dict_lit / mir_lowering_stmts.spl var-decl
                        # propagation), so a dict-typed FUNCTION PARAMETER's
                        # local id never lands in this map even though it holds
                        # a real dict handle -- `fn f(d: Dict<text,i64>):
                        # d.len()` silently returned 0 natively (rt_len's
                        # fallback treats an unrecognized handle as neither a
                        # string nor an array and hardcodes 0). `local_is_runtime_dict`
                        # (expr_dispatch.spl) already recovers this correctly
                        # for the `d[k]` Index path by ALSO consulting the
                        # local's registered MIR type (begin_function/mir_data.spl
                        # threads the real `Dict(key,value)` type from
                        # `signature.params` onto every Arg local, so
                        # `local_mir_type_of` is authoritative for params even
                        # though runtime_dict_locals isn't) -- reuse the same
                        # helper here instead of only checking the id-keyed map.
                        if self.local_is_runtime_dict(receiver_local):
                            self.runtime_dict_locals[receiver_local.id] = true
                            len_symbol = "rt_dict_len"
                        else:
                            len_symbol = "rt_len"
                    case _: ()
            if len_symbol != "":
                if not receiver_lowered:
                    receiver_local = self.lower_expr(receiver)
                # rt_len (unlike rt_dict_len) expects a tagged heap-string
                # handle for the string case (it probes via
                # rt_core_as_string, which only recognizes RT_VALUE_TAG_HEAP
                # values). A raw char* (Opaque "str": a bare string literal,
                # an interpolation/rt_interp_cstr result, or any other
                # untagged text producer) is not tagged and silently returns
                # 0 -- e.g. `val s = "hello"; s.len()` or
                # `"hi {name}".len()` printed 0 instead of the real length,
                # while `("a"+"b").len()` worked because rt_string_concat's
                # result is already tagged.
                #
                # Fix attempt #1 (REVERTED): unconditionally re-tag the
                # receiver via tag_str_local_if_raw before calling rt_len.
                # tag_str_local_if_raw decides "is this raw" purely from the
                # STATIC MIR type (Opaque "str"), which cannot distinguish an
                # already-tagged runtime string (e.g. a concat/replace
                # result) from a genuinely-raw literal -- both share the same
                # MIR type. Re-running rt_strlen+rt_string_new on an
                # ALREADY-tagged value reads the RtCoreString header bytes as
                # if they were string content (same failure mode documented
                # in expr_dispatch.spl's `.len` field-access fix: "strlen
                # stops 3 bytes in at the header's reserved-field NUL"),
                # which regressed `("foo"+"bar"+"baz").len()` from 9 to 3.
                #
                # Correct fix: mirror the `.len` (no-parens, HirExprKind.Field)
                # routing in expr_dispatch.spl, which already solves this
                # exact tagged-or-raw ambiguity by coercing through
                # rt_interp_cstr (a RUNTIME check: unwraps an already-tagged
                # string to its data buffer, or passes an already-raw char*
                # straight through) and then rt_strlen on the normalized
                # buffer -- safe regardless of the receiver's actual runtime
                # tag state. Only do this when the receiver is not a known
                # array local (runtime_array_locals): arrays must keep going
                # through plain rt_len, since rt_interp_cstr/rt_strlen would
                # misinterpret raw array memory as a C string.
                if len_symbol == "rt_len" and not self.runtime_array_locals.has(receiver_local.id):
                    val lc_cstr_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_interp_cstr"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
                    ))
                    var b_lc_cstr = self.builder
                    val lc_cstr_res = b_lc_cstr.emit_call(lc_cstr_op, [mir_operand_copy(receiver_local)], MirType(kind: MirTypeKind.Opaque("str")))
                    self.builder = b_lc_cstr
                    var lc_buf = receiver_local
                    if val lc_cstr_local = lc_cstr_res:
                        lc_buf = lc_cstr_local
                    val lc_strlen_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_strlen"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                    ))
                    var b_lc_strlen = self.builder
                    val lc_strlen_res = b_lc_strlen.emit_call(lc_strlen_op, [mir_operand_copy(lc_buf)], MirType.i64())
                    self.builder = b_lc_strlen
                    if val lc_strlen_local = lc_strlen_res:
                        return lc_strlen_local
                    return lc_buf
                val func_operand = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str(len_symbol),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b_len = self.builder
                val result = b_len.emit_call(func_operand, [mir_operand_copy(receiver_local)], MirType.i64())
                self.builder = b_len
                if val result_local = result:
                    return result_local
                return receiver_local

        # `.to_text()` on a numeric receiver (task #178 text3 probe #5: int -> string
        # conversion). Had NO native MIR lowering at all (fell to the Task
        # #145 loud-fail like char_at did before its fix above). A text
        # receiver's `.to_text()` is a no-op passthrough (matches the
        # language convention that to_text() on text returns itself
        # unchanged); anything else falls through to rt_raw_i64_to_string,
        # which formats a RAW (untagged) native i64 value directly via
        # snprintf -- this is deliberately NOT rt_to_string/rt_value_to_string,
        # which expect a TAGGED/boxed Any value (tag bits set on the int
        # itself) and would misrender a plain typed i64 local as a bogus
        # "<value:0x2a>" pointer-style dump. Scoped to i64 (this task's
        # tested construct); bool/float receivers are not covered here and
        # still loud-fail via the Unresolved fallthrough below.
        if method == "to_text" and args.len() == 0 and resolution_is_unresolved:
            val tt_receiver = self.lower_expr(receiver)
            var tt_is_str = false
            if val tt_ty = self.local_mir_type_of(tt_receiver):
                match tt_ty.kind:
                    case MirTypeKind.Opaque(tt_ty_name):
                        if tt_ty_name == "str":
                            tt_is_str = true
                    case _: ()
            if tt_is_str:
                return tt_receiver
            # rt_raw_i64_to_string returns a TAGGED string handle (a real
            # string constructor), not an integer -- the dest type MUST be
            # registered as Opaque("str"), not i64. Registering i64 here (a
            # bug caught during verification) made lower_bootstrap_print_call's
            # numeric-coercion check (switch_operators_calls.spl, which keys
            # off local_mir_type_of) see an i64-typed local for `print(s)` and
            # re-run rt_raw_i64_to_string A SECOND TIME on the already-tagged
            # handle, formatting its pointer bits as a bogus decimal number
            # instead of printing the text.
            val tt_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_raw_i64_to_string"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
            ))
            var b_tt = self.builder
            val tt_res = b_tt.emit_call(tt_op, [mir_operand_copy(tt_receiver)], MirType(kind: MirTypeKind.Opaque("str")))
            self.builder = b_tt
            if val tt_local = tt_res:
                return tt_local
            return tt_receiver

        if method == "bytes" and args.len() == 0:
            var is_text_receiver = false
            if maybe_receiver_type_for_call != nil:
                val found_receiver_type = maybe_receiver_type_for_call
                if found_receiver_type != nil:
                    match found_receiver_type.kind:
                        case Str: is_text_receiver = true
                        case _: ()
            if is_text_receiver:
                val receiver_local = self.lower_expr(receiver)
                val func_operand = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("rt_string_bytes"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                        params: [MirType.i64()],
                        return_type: MirType.i64(),
                        is_variadic: false
                    )))
                ))
                var b_bytes = self.builder
                val result = b_bytes.emit_call(func_operand, [mir_operand_copy(receiver_local)], MirType.i64())
                self.builder = b_bytes
                if val result_local = result:
                    return result_local
                return receiver_local

        # Task #144: `n.to_string()` on the bootstrap flat-HIR path resolves to
        # MethodResolution.Unresolved (no method-resolution info), so it fell
        # through to `case Unresolved:` below, which emits an error and returns
        # a placeholder const-0 i64 WITHOUT lowering the receiver or calling any
        # runtime conversion. `print(n.to_string())` then received the raw i64
        # 0 in place of a string pointer -> rt_print silently printed nothing.
        #
        # Lower the receiver, then render it exactly like Bug #136's numeric
        # string-interpolation coercion: rt_raw_i64_to_string(i64) -> a TAGGED
        # heap string, then rt_interp_cstr unwraps that tag to the raw char*
        # (Opaque "str") that rt_print/rt_println expect. A receiver that is
        # already a string (`s.to_string()`) is an identity — detected from its
        # lowered MIR type and returned as-is instead of being fed to the
        # integer conversion.
        if method == "to_string" and args.len() == 0 and (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            val ts_receiver = self.lower_expr(receiver)
            var ts_is_str = false
            if val ts_recv_ty = self.local_mir_type_of(ts_receiver):
                match ts_recv_ty.kind:
                    case MirTypeKind.Opaque(ts_recv_ty_name):
                        if ts_recv_ty_name == "str":
                            ts_is_str = true
                    case _: ()
            if ts_is_str:
                return ts_receiver
            val i64s_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_raw_i64_to_string"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_i64s = self.builder
            val i64s_res = b_i64s.emit_call(i64s_op, [mir_operand_copy(ts_receiver)], MirType.i64())
            self.builder = b_i64s
            var ts_tagged = ts_receiver
            if val i64s_local = i64s_res:
                ts_tagged = i64s_local
            val ts_cstr_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_interp_cstr"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
            ))
            var b_ts_cstr = self.builder
            val ts_cstr_res = b_ts_cstr.emit_call(ts_cstr_op, [mir_operand_copy(ts_tagged)], MirType(kind: MirTypeKind.Opaque("str")))
            self.builder = b_ts_cstr
            if val ts_cstr_local = ts_cstr_res:
                return ts_cstr_local
            return ts_tagged

        # Task #145 (join-family silent-null): `[...].join(sep)` on the
        # bootstrap flat-HIR path resolves to MethodResolution.Unresolved (no
        # method-resolution info at this stage), so it fell through to
        # `case Unresolved:` below, which emits an error and returns a
        # placeholder const-0 i64 WITHOUT lowering the receiver, the array
        # elements, or the call. `print([...].join(sep))` then received a raw
        # 0 in place of a string pointer -> rt_print silently printed nothing
        # (see scratchpad/dynamic_text_probe_result.md probes p4/p5/p6).
        #
        # Handle the case where the receiver is a literal array `[...]`
        # (HIR ArrayLit) directly -- the elements are statically known here,
        # before any runtime array boxing. Lower each element and the
        # separator, coerce every operand to a raw char* via
        # bootstrap_coerce_to_raw_str (Bug #136's string-interpolation
        # coercion scheme: Opaque("str") passes through, anything else is
        # rendered via rt_raw_i64_to_string then unwrapped by rt_interp_cstr),
        # then splice with rt_strcat (emit_raw_strcat) -- exactly how `+`
        # concatenation already lowers correctly (p2/p7 PASS in the probe
        # matrix).
        #
        # `[...].map(...).join(...)` (receiver NOT a literal ArrayLit) is NOT
        # handled here: the runtime array built by rt_array_new/rt_array_push
        # stores each pushed element as a RAW i64 word with no tag applied
        # (see aggregate_intrinsics.spl translate_aggregate `case Array`), so
        # routing through rt_array_join/rt_string_join (which expect TAGGED
        # RuntimeValue elements) would misinterpret raw string-literal words
        # as corrupt tagged handles. Fixing that generically requires tagging
        # every array element at construction time -- broader change, out of
        # scope here (documented in join_lowering_fix_report.md).
        if method == "join" and args.len() == 1 and (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            match receiver.kind:
                case ArrayLit(jn_elements, _):
                    if jn_elements.len() == 0:
                        return self.emit_bootstrap_str_const("")
                    # Every self-call below is un-nested through an
                    # intermediate val on purpose: the seed interpreter
                    # drops/misevaluates a self-method call nested as an
                    # argument to another self-method call (same quirk the
                    # Bug #136 interpolation code documents as "Intermediate
                    # var for the index access"). The nested form
                    # `self.coerce(self.lower_expr(x))` emitted
                    # self-referential IR (`%l0 = call ...(i64 %l0)`) with
                    # the element lowering silently skipped.
                    val jn_sep_arg = args[0]
                    val jn_sep_expr = jn_sep_arg.value
                    val jn_sep_raw = self.lower_expr(jn_sep_expr)
                    val jn_sep_local = self.bootstrap_coerce_to_raw_str(jn_sep_raw)
                    val jn_first_expr = jn_elements[0]
                    val jn_first_raw = self.lower_expr(jn_first_expr)
                    var jn_result = self.bootstrap_coerce_to_raw_str(jn_first_raw)
                    var jn_i = 1
                    while jn_i < jn_elements.len():
                        jn_result = self.emit_raw_strcat(jn_result, jn_sep_local)
                        val jn_elem_expr = jn_elements[jn_i]
                        val jn_elem_raw = self.lower_expr(jn_elem_expr)
                        val jn_elem_local = self.bootstrap_coerce_to_raw_str(jn_elem_raw)
                        jn_result = self.emit_raw_strcat(jn_result, jn_elem_local)
                        jn_i = jn_i + 1
                    return jn_result
                case _: ()

        # Bug #137 (follow-up): `x.starts_with(literal)` on the bootstrap
        # argv-element path resolves to MethodResolution.Unresolved (the flat
        # bootstrap HIR has no method resolution), so it fell through to the
        # `case Unresolved:` arm below which emits an ERROR and returns a
        # fresh unit temp WITHOUT lowering the call or its arguments -- the
        # call result local was referenced (`and i64 %2, %lN`) but never
        # defined (llc: "use of undefined value"). The no-arg `len` above is
        # the only string method that had a pre-resolution special case, which
        # is why `first.len()` lowered but `first.starts_with(...)` did not.
        #
        # Emit a real runtime call. Representation: argv elements are TAGGED
        # heap strings (rt_cli_get_args builds them via rt_string_new), while a
        # bootstrap string literal lowers to a RAW char* pointer (a
        # getelementptr into a [N x i8] global). rt_string_starts_with(i64
        # value, i64 prefix) needs BOTH operands tagged, so tag the raw literal
        # first: rt_string_new(ptr, rt_strlen(ptr)). rt_string_starts_with is
        # bounds-checked (returns 0 when prefix longer than receiver), which
        # matters now that `and` is eager -- `starts_with` runs even when the
        # preceding `len == N` guard is false.
        #
        # Bug fix (task #178 text3 lane): the ABOVE comment's "argv elements
        # are always tagged" assumption does not hold for a receiver that is
        # itself a genuinely-raw literal (e.g. `val s = "hello world";
        # s.starts_with("hello")`) -- only the prefix argument was tagged
        # below; the receiver was passed straight through, so
        # rt_string_starts_with's rt_core_as_string(receiver) check silently
        # failed and every such call returned false. ensure_tagged_str fixes
        # this without the double-tag corruption risk an unconditional
        # strlen+rt_string_new (like the prefix's own tagging just below)
        # would have on an ALREADY-tagged receiver (e.g. a concat result).
        if method == "starts_with" and args.len() == 1 and resolution_is_unresolved:
            # Bug (native_string_method_var_arg lane, 2026-07-14): un-nest through
            # an intermediate val, exactly like the `join` fix above documents --
            # the seed interpreter drops/misevaluates a self-method call nested
            # directly as an argument to another self-method call
            # (`self.ensure_tagged_str(self.lower_expr(receiver))`). When the
            # method's OTHER argument (the prefix) is a plain literal, this
            # nesting bug was invisible; once a VARIABLE argument is present the
            # inner `self.lower_expr(receiver)` call gets silently skipped, so
            # `ensure_tagged_str` receives a garbage/default LocalId(id: 0)
            # operand -- and its OWN first new_temp also happens to allocate id
            # 0, producing a self-referencing SSA value (`%l0 = call ptr
            # @rt_interp_cstr(ptr %l0)`), an LLVM verifier fault ("Only PHI nodes
            # may reference their own value!").
            val sw_receiver_raw = self.lower_expr(receiver)
            val sw_receiver = self.ensure_tagged_str(sw_receiver_raw)
            val sw_prefix_ptr = self.lower_expr(args[0].value)
            val strlen_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_strlen"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_swlen = self.builder
            val sw_len_res = b_swlen.emit_call(strlen_op, [mir_operand_copy(sw_prefix_ptr)], MirType.i64())
            self.builder = b_swlen
            if val sw_prefix_len = sw_len_res:
                val newstr_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("rt_string_new"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b_swnew = self.builder
                val sw_tagged_res = b_swnew.emit_call(newstr_op, [mir_operand_copy(sw_prefix_ptr), mir_operand_copy(sw_prefix_len)], MirType.i64())
                self.builder = b_swnew
                if val sw_tagged_prefix = sw_tagged_res:
                    val starts_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_string_starts_with"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                    ))
                    var b_sw = self.builder
                    val sw_res = b_sw.emit_call(starts_op, [mir_operand_copy(sw_receiver), mir_operand_copy(sw_tagged_prefix)], MirType.i64())
                    self.builder = b_sw
                    if val sw_local = sw_res:
                        return sw_local
            return sw_receiver

        # Bug #138 (follow-up): same untyped-receiver gap as starts_with above,
        # `.chr()` / `.to_char()` on an integer receiver: the native lane had NO
        # lowering for this builtin (the LLVM lane routes it to char_from_code),
        # so compiled code silently produced an empty/NIL result — SimpleOS font
        # name-table decode yielded "" for every entry (validator reason=names),
        # and _vfs_bytes_to_text produced empty manifests. Route to the runtime
        # rt_char_from_code(code) -> tagged single-char string (strong impl in
        # rt_extras.c on baremetal, runtime_native.c hosted).
        if (method == "chr" or method == "to_char") and args.len() == 0 and resolution_is_unresolved:
            val chr_receiver = self.lower_expr(receiver)
            val chr_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_char_from_code"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_chr = self.builder
            val chr_res = b_chr.emit_call(chr_op, [mir_operand_copy(chr_receiver)], MirType.i64())
            self.builder = b_chr
            if val chr_local = chr_res:
                return chr_local
            return chr_receiver

        # for `x.ends_with(suffix)`. Mirrors the starts_with fix exactly:
        # rt_string_ends_with(i64 value, i64 suffix) needs both operands
        # tagged, so tag a raw string-literal suffix via rt_string_new first.
        # Also mirrors task #178's receiver-tagging fix above (same silent
        # always-false bug for a raw-literal receiver).
        if method == "ends_with" and args.len() == 1 and resolution_is_unresolved:
            # Same un-nesting fix as starts_with above (native_string_method_var_arg
            # lane, 2026-07-14) -- avoid `self.X(self.lower_expr(receiver))`.
            val ew_receiver_raw = self.lower_expr(receiver)
            val ew_receiver = self.ensure_tagged_str(ew_receiver_raw)
            val ew_suffix_ptr = self.lower_expr(args[0].value)
            val ew_strlen_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_strlen"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_ewlen = self.builder
            val ew_len_res = b_ewlen.emit_call(ew_strlen_op, [mir_operand_copy(ew_suffix_ptr)], MirType.i64())
            self.builder = b_ewlen
            if val ew_suffix_len = ew_len_res:
                val ew_newstr_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("rt_string_new"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b_ewnew = self.builder
                val ew_tagged_res = b_ewnew.emit_call(ew_newstr_op, [mir_operand_copy(ew_suffix_ptr), mir_operand_copy(ew_suffix_len)], MirType.i64())
                self.builder = b_ewnew
                if val ew_tagged_suffix = ew_tagged_res:
                    val ends_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_string_ends_with"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                    ))
                    var b_ew = self.builder
                    val ew_res = b_ew.emit_call(ends_op, [mir_operand_copy(ew_receiver), mir_operand_copy(ew_tagged_suffix)], MirType.i64())
                    self.builder = b_ew
                    if val ew_local = ew_res:
                        return ew_local
            return ew_receiver

        # Bug #137/#138 (follow-up): the typed substring/slice special case
        # below is gated on receiver.type_ == Some(Str), but an untyped
        # receiver (no HIR type inference ran -- both under the bootstrap flat
        # HIR path and on the normal native-build path) sets expr type_ to
        # nil, so `args[i].substring(2)` / `args[i].substring(9)` (the -oFILE
        # / --output=FILE path parsing in bootstrap_main lines 17,21) never
        # reached it and fell through to `case Unresolved:` -> const 0 ->
        # wrong/garbage filename. Handle it type-independently whenever
        # resolution is Unresolved, mirroring the starts_with fix.
        #
        # Representation: the receiver may be a tagged argv element
        # (rt_string_new-built) OR a genuinely-raw char* (a plain string
        # literal, e.g. `val s = "hello world"; s.substring(6)` -- text/text3
        # probe #4), but spl_str_slice/spl_str_len operate on RAW char*.
        #
        # BUG (fixed here): this previously coerced via rt_string_data
        # (tagged -> raw ptr), which requires the receiver to ALREADY be a
        # tagged handle -- rt_string_data returns NULL for anything else. A
        # raw literal receiver made this NULL, so spl_str_len(NULL) -> 0 and
        # spl_str_slice(NULL, start, 0) -> "" (empty string) SILENTLY (no
        # error, no crash, just a blank result) whenever `start >= end`
        # (which `start=6, end=0` always is), instead of the correct
        # substring. Use rt_interp_cstr instead: it does the tagged-or-raw
        # check at RUNTIME (bug #136's autodetection) -- a tagged handle
        # unwraps to its buffer, an already-raw char* passes through
        # unchanged -- so it is correct for both representations. The
        # raw-char* result matches the non-bootstrap Str-path representation
        # the downstream -o/--output filename handling expects. Supports both
        # `.substring(start)` (1 arg; end = spl_str_len) and
        # `.substring(start, end)` (2 args).
        # Bug (array.slice/.substring misrouted to string.slice): this erased-
        # receiver fallback (like the "contains" one further below) assumed
        # an untyped/unresolved "slice"/"substring" receiver is always a
        # STRING. `a[1:3]` on a runtime array desugars to
        # `MethodCall(a, "slice", [1, 3])` (see the _FlatAstBridge EXPR_SLICE
        # conversion) and ALSO resolves as Unresolved (arrays have no
        # registered stdlib `slice` symbol), so without a receiver-type guard
        # it fell into this SAME branch: the array's raw handle got
        # `rt_interp_cstr`'d and passed to `spl_str_slice` as if it were a
        # string pointer, treating live array element words as if they were
        # string byte data -- silently wrong output (or worse, an
        # out-of-bounds/garbage read) instead of a clean error. There is no
        # dedicated array-slice runtime helper implemented, so exclude a
        # positively-known array/slice receiver here and let it fall through
        # to the ordinary `case Unresolved:` path's loud "unresolved method
        # call: slice" build failure (matching .pop()/.first()/.last()/
        # array.contains()) instead of a silent wrong answer.
        var slice_recv_is_array = false
        if method == "substring" or method == "slice":
            if val slice_recv_ty = receiver.type_:
                match slice_recv_ty.kind:
                    case HirTypeKind.Array(_, _) | HirTypeKind.Slice(_):
                        slice_recv_is_array = true
                    case _: ()
            if not slice_recv_is_array:
                match receiver.kind:
                    case Var(_) | NamedVar(_, _):
                        val slice_recv_probe = self.lower_expr(receiver)
                        if self.local_is_runtime_array(slice_recv_probe):
                            slice_recv_is_array = true
                    case _: ()
        if (method == "substring" or method == "slice") and (args.len() == 1 or args.len() == 2) and resolution_is_unresolved and not slice_recv_is_array:
            val sub_recv_tagged = self.lower_expr(receiver)
            val strdata_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_interp_cstr"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
            ))
            var b_subsd = self.builder
            val sub_recv_res = b_subsd.emit_call(strdata_op, [mir_operand_copy(sub_recv_tagged)], MirType(kind: MirTypeKind.Opaque("str")))
            self.builder = b_subsd
            if val sub_recv_raw = sub_recv_res:
                var sub_args: [MirOperand] = [mir_operand_copy(sub_recv_raw)]
                for arg in args:
                    val sub_arg_local = self.lower_expr(arg.value)
                    sub_args = sub_args.push(mir_operand_copy(sub_arg_local))
                if args.len() == 1:
                    val sublen_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("spl_str_len"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                    ))
                    var b_sublen = self.builder
                    val sublen_res = b_sublen.emit_call(sublen_op, [mir_operand_copy(sub_recv_raw)], MirType.i64())
                    self.builder = b_sublen
                    if val sublen_local = sublen_res:
                        sub_args = sub_args.push(mir_operand_copy(sublen_local))
                val subslice_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("spl_str_slice"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
                ))
                var b_subslice = self.builder
                val subslice_res = b_subslice.emit_call(subslice_op, sub_args, MirType(kind: MirTypeKind.Opaque("str")))
                self.builder = b_subslice
                if val subslice_local = subslice_res:
                    return subslice_local
                return sub_recv_raw
            return sub_recv_tagged

        # `.char_at(index)` (task #178 text3 probe #4): had NO native MIR
        # lowering at all -- unlike substring/slice above, this fell all the
        # way to `case Unresolved:` -> const-0 placeholder -> the existing
        # Task #145 loud-fail (`unresolved method call: char_at`), a correct
        # but avoidable gap since the underlying runtime already exists
        # (rt_string_char_at, declared in llvm_lib_translate.spl). Not routed
        # through rt_string_char_at directly here: that function requires an
        # ALREADY-tagged receiver (rt_core_as_string-checked) and returns nil
        # for a raw literal, the same trap substring/slice above just got
        # fixed for. Instead reuse the just-fixed, verified-safe substring
        # machinery: normalize the receiver via rt_interp_cstr (tagged-or-raw
        # autodetect) and take a 1-char slice [index, index+1) via
        # spl_str_slice, returning a fresh raw 1-char string -- consistent
        # with substring's return representation and with the oracle
        # (`"h"`, a 1-char text, not a char code).
        if method == "char_at" and args.len() == 1 and resolution_is_unresolved:
            val ca_recv_tagged = self.lower_expr(receiver)
            val ca_cstr_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_interp_cstr"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
            ))
            var b_ca_cstr = self.builder
            val ca_recv_res = b_ca_cstr.emit_call(ca_cstr_op, [mir_operand_copy(ca_recv_tagged)], MirType(kind: MirTypeKind.Opaque("str")))
            self.builder = b_ca_cstr
            if val ca_recv_raw = ca_recv_res:
                val ca_idx_local = self.lower_expr(args[0].value)
                val ca_one_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(1), MirType.i64()))
                var b_ca_end = self.builder
                val ca_end_local = b_ca_end.emit_binop(MirBinOp.Add, mir_operand_copy(ca_idx_local), ca_one_op, MirType.i64())
                self.builder = b_ca_end
                val ca_slice_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("spl_str_slice"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
                ))
                var b_ca_slice = self.builder
                val ca_slice_res = b_ca_slice.emit_call(ca_slice_op, [mir_operand_copy(ca_recv_raw), mir_operand_copy(ca_idx_local), mir_operand_copy(ca_end_local)], MirType(kind: MirTypeKind.Opaque("str")))
                self.builder = b_ca_slice
                if val ca_slice_local = ca_slice_res:
                    return ca_slice_local
                return ca_recv_raw
            return ca_recv_tagged

        # Erased-receiver fallbacks for builtin text methods (2026-07-13,
        # whole-compiler redeploy closure): trim/lower/to_lower/split/replace
        # on an untyped receiver never resolve (no HIR type inference under
        # bootstrap, and the builtin Str type has no symbol for try_ufcs), so
        # they fell through to `case Unresolved:` -> const-0 placeholder =
        # silent data loss (Task #145). Mirror the starts_with/substring
        # fallbacks above, calling the tagged rt_string_* runtime directly.
        # Receivers/args on this path are tagged handles (argv elements,
        # rt_array_get results, rt_string_* results); raw char* literals
        # (Opaque "str") are tagged first (tag_str_local_if_raw, same scheme
        # as the push fallback below). Arity-gated so a user method with the
        # same name but different arity still reaches `case Unresolved:`.
        # rfind: rt_string_rfind returns -1 for not-found while the language
        # contract is `i64?` (nil for not-found). Under the bootstrap
        # bare-payload Optional repr the difference is only observable through
        # a `?? default` / nil-test; the known closure site
        # (io_runtime.spl file_write: `rfind("/") ?? 0` then `<= 0` guard)
        # behaves identically for -1 and nil. Revisit if a closure site ever
        # distinguishes them.
        # find (native_env_closure_unsupported_methods lane, 2026-07-16):
        # same family as rfind, mapped to rt_string_find (already exported by
        # the deployed seed and used by rfind above -- verified via `nm` on
        # the deployed binary and a direct extern-call probe). Confirmed the
        # seed interpreter (interpreter_method/string.rs "find") returns a
        # plain i64, -1 for not-found, identical to rt_string_find -- so
        # find/rfind share both the runtime symbol pattern AND the -1-vs-nil
        # equivalence noted above. std.env.variables.expand_var_expr's
        # `expr.find(":-")` / `.find(":=")` (the native_env_closure_
        # unsupported_methods_2026-07-16 blocker) matches this exact
        # zero-arg-string-arg / i64-result shape.
        # Bug (array.contains misrouted to string.contains): this whole arm
        # assumes an untyped/unresolved "contains" receiver is always a
        # STRING (mirroring trim/lower/split/replace/rfind, which really are
        # string-only). But `[10,20,30].contains(30)` also resolves as
        # Unresolved (arrays have no registered stdlib `contains` symbol
        # either), so without a receiver-type check it fell into this SAME
        # branch: the array's raw handle got passed as if it were a string
        # pointer into rt_string_contains, silently returning false/false
        # for every case instead of a clean error (no build failure, no
        # crash -- just wrong 0/0 output; the exact "NEVER silent-wrong"
        # case this lane must catch). An array `.contains` has no dedicated
        # runtime helper (rt_array_contains is declared in
        # llvm_lib_translate.spl but never implemented in
        # runtime_native.c -- linking against it would fail at link time,
        # not build time), so the correct fix here is to exclude a
        # positively-known array/slice receiver from this string-only arm
        # and let it fall through to the ordinary `case Unresolved:` path,
        # which already produces the required LOUD "unresolved method call:
        # contains" build failure (matching the existing loud-fail
        # convention for .pop()/.first()/.last()) instead of a silent wrong
        # answer.
        var contains_recv_is_array = false
        if method == "contains":
            if val contains_recv_ty = receiver.type_:
                match contains_recv_ty.kind:
                    case HirTypeKind.Array(_, _) | HirTypeKind.Slice(_):
                        contains_recv_is_array = true
                    case _: ()
            if not contains_recv_is_array:
                # HIR type inference is erased/nil for a plain Var receiver
                # under this lowering mode, so the type-based check above
                # misses `val a = [1,2,3]; a.contains(x)`. A bare Var/NamedVar
                # receiver's lowering is a pure lookup of its already-bound
                # SSA local (no new instructions emitted -- the binding was
                # created once when the array literal/argument was first
                # lowered), so probing it here to check runtime_array_locals
                # membership is safe to repeat at line ~765 without
                # duplicating side effects (unlike an arbitrary call-expr
                # receiver, which this probe deliberately does NOT touch).
                match receiver.kind:
                    case Var(_) | NamedVar(_, _):
                        val contains_recv_probe = self.lower_expr(receiver)
                        if self.local_is_runtime_array(contains_recv_probe):
                            contains_recv_is_array = true
                    case _: ()
        if (method == "trim" or method == "lower" or method == "to_lower" or method == "split" or method == "replace" or method == "rfind" or method == "find" or method == "contains") and resolution_is_unresolved and not contains_recv_is_array:
            val ts_arity_ok = match method:
                case "split": args.len() == 1
                case "rfind": args.len() == 1
                case "find": args.len() == 1
                case "replace": args.len() == 2
                case "contains": args.len() == 1
                case _: args.len() == 0
            if ts_arity_ok:
                # Bug (native_string_method_var_arg lane, 2026-07-14), part 1:
                # un-nest `self.tag_str_local_if_raw(self.lower_expr(receiver))`
                # through an intermediate val -- same seed-interpreter
                # nested-self-call landmine as starts_with/ends_with above
                # (`self.X(self.lower_expr(...))` gets silently dropped/
                # misevaluated when a VARIABLE arg is also present).
                #
                # Part 2: use `ensure_tagged_str` (a RUNTIME tagged-or-raw
                # check via rt_interp_cstr), not `tag_str_local_if_raw` (a
                # STATIC MIR-type check), for both receiver and args. A
                # variable bound to a string literal (`val sub = "ell"`) is
                # genuinely raw at runtime, but the local produced by lowering
                # a `Var` reference to it does not reliably carry the
                # Opaque("str") MIR type that `tag_str_local_if_raw` keys off
                # (confirmed empirically: a literal arg like
                # `"hello".contains("ell")` got tagged correctly, but the
                # equivalent `val sub = "ell"; "hello".contains(sub)` did not
                # -- `rt_string_contains` received the untagged raw arg
                # alongside the tagged receiver and always returned false).
                # `ensure_tagged_str` sidesteps the unreliable static check
                # entirely and is safe for an already-tagged input too (no
                # double-tag risk), so it is correct for both the literal and
                # variable cases this arm has to serve.
                val ts_recv_raw = self.lower_expr(receiver)
                val ts_recv = self.ensure_tagged_str(ts_recv_raw)
                var ts_ops: [MirOperand] = [mir_operand_copy(ts_recv)]
                for ts_arg in args:
                    val ts_arg_local = self.lower_expr(ts_arg.value)
                    val ts_arg_tagged = self.ensure_tagged_str(ts_arg_local)
                    ts_ops = ts_ops.push(mir_operand_copy(ts_arg_tagged))
                val ts_sym = match method:
                    case "split": "rt_string_split"
                    case "replace": "rt_string_replace"
                    case "trim": "rt_string_trim"
                    case "rfind": "rt_string_rfind"
                    case "find": "rt_string_find"
                    case "contains": "rt_string_contains"
                    case _: "rt_string_to_lower"
                # Bug fix (task #178 text3 lane): trim/lower/to_lower/replace
                # return TAGGED STRING HANDLES, not integers (rfind returns an
                # index; contains returns a bool, both correctly i64; split
                # returns an array handle, flagged separately below via
                # runtime_array_locals). Registering the dest as MirType.i64()
                # made downstream local_is_str()/local_mir_type_of() checks
                # (print/interpolation coercion, `==`, concat, `.len()`) treat
                # the result as a raw integer -- print() then rendered the
                # string HANDLE's bit pattern as decimal digits via
                # rt_raw_i64_to_string instead of the actual text, e.g.
                # `"a,b".replace(",", "-")` printed a garbage number instead
                # of "a-b" (silent wrong, no error at all; verified via
                # SIMPLE_KEEP_LLVM_IR).
                val ts_dest_ty = match method:
                    case "replace" | "trim" | "lower" | "to_lower":
                        MirType(kind: MirTypeKind.Opaque("str"))
                    case _: MirType.i64()
                val ts_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str(ts_sym),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: ts_dest_ty, is_variadic: false)))
                ))
                var b_ts = self.builder
                val ts_res = b_ts.emit_call(ts_op, ts_ops, ts_dest_ty)
                self.builder = b_ts
                if val ts_local = ts_res:
                    # rt_string_split returns a tagged rt_array handle; flag it
                    # so downstream indexing/for-in routes through rt_array_get.
                    if method == "split":
                        self.runtime_array_locals[ts_local.id] = true
                        val split_hir_type = HirType(kind: HirTypeKind.Str, span: receiver.span)
                        self.local_hir_types[ts_local.id] = HirType(kind: HirTypeKind.Array(split_hir_type, nil), span: receiver.span)
                    return ts_local
                return ts_recv

        # Bug (pure_simple_text_split_lines_missing, 2026-07-16): `text.split_lines()` / `.lines()`
        # had no MIR lowering at all (fell to the generic Unresolved loud-fail:
        # "unresolved method call: split_lines"). Guard against a positively-known
        # array/slice receiver first -- same rationale as the `contains`/
        # `substring` guards above: an array also resolves Unresolved for this
        # (unregistered) method name, and without the guard its raw handle would
        # get silently treated as a string pointer instead of loud-failing.
        var split_lines_recv_is_array = false
        val is_lines_method = method == "split_lines" or method == "lines"
        if is_lines_method:
            if val slr_ty = receiver.type_:
                match slr_ty.kind:
                    case HirTypeKind.Array(_, _) | HirTypeKind.Slice(_):
                        split_lines_recv_is_array = true
                    case _: ()
            if not split_lines_recv_is_array:
                match receiver.kind:
                    case Var(_) | NamedVar(_, _):
                        val slr_probe = self.lower_expr(receiver)
                        if self.local_is_runtime_array(slr_probe):
                            split_lines_recv_is_array = true
                    case _: ()
        if is_lines_method and args.len() == 0 and resolution_is_unresolved and not split_lines_recv_is_array:
            return self.lower_text_split_lines(receiver)

        if (method == "substring" or method == "slice"):
            val maybe_receiver_type = receiver.type_
            match maybe_receiver_type:
                case nil:
                    ()
                case Some(found_receiver_type):
                    if found_receiver_type != nil:
                        match found_receiver_type.kind:
                            case Str:
                                if args.len() == 1 or args.len() == 2:
                                    val receiver_local = self.lower_expr(receiver)
                                    var arg_operands: [MirOperand] = [mir_operand_copy(receiver_local)]
                                    for arg in args:
                                        val arg_local = self.lower_expr(arg.value)
                                        arg_operands = arg_operands.push(mir_operand_copy(arg_local))
                                    if args.len() == 1:
                                        val len_operand = MirOperand(kind: MirOperandKind.Const(
                                            MirConstValue.Str("spl_str_len"),
                                            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                                        ))
                                        var b_len = self.builder
                                        val len_result = b_len.emit_call(len_operand, [mir_operand_copy(receiver_local)], MirType.i64())
                                        self.builder = b_len
                                        if val len_local = len_result:
                                            arg_operands = arg_operands.push(mir_operand_copy(len_local))
                                    val slice_operand = MirOperand(kind: MirOperandKind.Const(
                                        MirConstValue.Str("spl_str_slice"),
                                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
                                    ))
                                    var b_slice = self.builder
                                    val slice_result = b_slice.emit_call(slice_operand, arg_operands, MirType(kind: MirTypeKind.Opaque("str")))
                                    self.builder = b_slice
                                    if val slice_local = slice_result:
                                        return slice_local
                                    return receiver_local
                            case _:
                                ()

        if self.is_mutating_method(method):
            match receiver.kind:
                case Index(base, index):
                    wb_base = self.lower_expr(base)
                    wb_index = self.lower_expr(index)
                    if self.local_is_runtime_array(wb_base):
                        val getter = MirOperand(kind: MirOperandKind.Const(
                            MirConstValue.Str("rt_array_get"),
                            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
                        ))
                        var wb_b = self.builder
                        val loaded = wb_b.emit_call(getter, [mir_operand_copy(wb_base), mir_operand_copy(wb_index)], receiver_type)
                        self.builder = wb_b
                        if val value = loaded:
                            wb_receiver = value
                            self.runtime_value_locals[value.id] = true
                    else:
                        var wb_b = self.builder
                        val wb_ptr = wb_b.emit_gep(
                            mir_operand_copy(wb_base),
                            [mir_operand_copy(wb_index)],
                            MirType.ptr(receiver_type, false)
                        )
                        wb_receiver = wb_b.emit_load(mir_operand_copy(wb_ptr), receiver_type)
                        self.builder = wb_b
                    wb_kind = 1
                case Field(base, field_name, resolved):
                    wb_base = self.lower_expr(base)
                    wb_field_idx = self.resolve_field_index(base, wb_base, field_name, resolved)
                    var wb_b = self.builder
                    wb_receiver = wb_b.emit_get_field(mir_operand_copy(wb_base), wb_field_idx, receiver_type)
                    self.builder = wb_b
                    self.remember_field_projection_provenance(base, wb_base, wb_field_idx, wb_receiver)
                    wb_kind = 2
                case _: ()

        match resolution:
            case InstanceMethod(type_id, method_id):
                # Direct method call on type
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val method_operand = self.symbol_to_operand(method_id)
                val return_type = self.resolved_call_return_type(method_id)
                var b = self.builder
                val result = b.emit_call(method_operand, arg_operands, return_type)
                self.builder = b
                var wb_value = wb_receiver
                if val result_local = result:
                    wb_value = result_local
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_value)
                if val result_local = result:
                    self.remember_call_hir_return(result_local, method_id)
                    result_local
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.i64())
                    # void call: define the placeholder so a consumer never
                    # reads an undefined local (use-before-def -> llvm-lib NULL)
                    b2.emit_const(temp, MirConstValue.Int(0), MirType.i64())
                    self.builder = b2
                    temp

            case TraitMethod(trait_id, method_id):
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val method_operand = self.symbol_to_operand(method_id)
                val return_type = self.resolved_call_return_type(method_id)
                var b = self.builder
                val result = b.emit_call(method_operand, arg_operands, return_type)
                self.builder = b
                var wb_value = wb_receiver
                if val result_local = result:
                    wb_value = result_local
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_value)
                if val result_local = result:
                    self.remember_call_hir_return(result_local, method_id)
                    result_local
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.i64())
                    # void call: define the placeholder so a consumer never
                    # reads an undefined local (use-before-def -> llvm-lib NULL)
                    b2.emit_const(temp, MirConstValue.Int(0), MirType.i64())
                    self.builder = b2
                    temp

            case FreeFunction(func_id):
                val arg_operands = if wb_kind != 0:
                    self.build_args_from_receiver(wb_receiver, args)
                else:
                    self.lower_receiver_and_args(receiver, args)
                val func_operand = self.symbol_to_operand(func_id)
                val return_type = self.resolved_call_return_type(func_id)
                var b = self.builder
                val result = b.emit_call(func_operand, arg_operands, return_type)
                self.builder = b
                var wb_value = wb_receiver
                if val result_local = result:
                    wb_value = result_local
                self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, wb_value)
                if val result_local = result:
                    self.remember_call_hir_return(result_local, func_id)
                    result_local
                else:
                    var b2 = self.builder
                    val temp = b2.new_temp(MirType.i64())
                    # void call: define the placeholder so a consumer never
                    # reads an undefined local (use-before-def -> llvm-lib NULL)
                    b2.emit_const(temp, MirConstValue.Int(0), MirType.i64())
                    self.builder = b2
                    temp

            case StaticMethod(type_id, method_id):
                var arg_operands: [MirOperand] = []
                for arg in args:
                    val arg_local = self.lower_expr(arg.value)
                    arg_operands = arg_operands.push(mir_operand_copy(arg_local))

                val method_operand = self.symbol_to_operand(method_id)
                val return_type = self.resolved_call_return_type(method_id)
                val result = self.emit_resolved_direct_call(method_operand, arg_operands, return_type)
                self.remember_call_hir_return(result, method_id)
                result

            case Unresolved:
                # Bug #138/#156 keystone: minimal-viable native resolution of
                # struct INSTANCE methods when HIR type inference left
                # `resolution` Unresolved (receiver.type_ nil -- see the
                # resolution_is_unresolved doc comment above). MethodResolver
                # (resolve_strategies.spl try_instance_method) requires a
                # typed receiver to resolve `c.get()`, which native-build
                # never provides for a plain struct local/param, so every
                # user struct method previously fell all the way through to
                # the `self.error(...)` placeholder below. struct_value_syms
                # (populated for locals/params/constructions -- see
                # function_lowering.spl's self-param copy and
                # switch_operators_calls.spl's struct-construction
                # registration) recovers the receiver's struct NAME from the
                # lowered local; struct_method_syms (module.impls-derived --
                # see module_lowering.spl) maps "{struct}::{method}" to the
                # method's real SymbolId. Dispatch mirrors the resolved
                # InstanceMethod case above exactly (symbol_to_operand +
                # resolved_call_return_type), just reached via a name-keyed
                # lookup instead of `resolution`. The receiver is lowered
                # ONCE here (reused below by the `push` special-case, which
                # previously re-lowered it) to avoid double-evaluating a
                # side-effecting receiver expression.
                var static_receiver_name = ""
                match receiver.kind:
                    case NamedVar(static_symbol, static_name):
                        val static_def = self.symbols.get_symbol(static_symbol)
                        if static_def != nil:
                            match static_def.kind:
                                case Class | Struct | Enum: static_receiver_name = static_name
                                case _: ()
                    case Var(static_symbol):
                        val static_def = self.symbols.get_symbol(static_symbol)
                        if static_def != nil:
                            match static_def.kind:
                                case Class | Struct | Enum: static_receiver_name = static_def.name
                                case _: ()
                    case _: ()
                val static_method_key = "static::{static_receiver_name}::{method}"
                if static_receiver_name != "" and self.struct_method_syms.has(static_method_key):
                    val static_method_id = self.struct_method_syms[static_method_key]
                    var static_args: [MirOperand] = []
                    for arg in args:
                        val static_arg = self.lower_expr(arg.value)
                        static_args.push(mir_operand_copy(static_arg))
                    var static_return_type = self.resolved_call_return_type(static_method_id)
                    val static_result_name = self.struct_method_return_names.get("{static_receiver_name}::{method}")
                    if static_result_name != nil and static_result_name != "":
                        for static_result_symbol in self.symbols.symbols.values():
                            if static_result_symbol.name == static_result_name:
                                match static_result_symbol.kind:
                                    case Class | Struct | Enum:
                                        static_return_type = MirType(kind: MirTypeKind.Struct(static_result_symbol.id))
                                    case _: ()
                    val static_result = self.emit_resolved_direct_call(self.symbol_to_operand(static_method_id), static_args, static_return_type)
                    self.remember_call_hir_return(static_result, static_method_id)
                    return static_result

                val unresolved_receiver_local = if wb_kind != 0:
                    wb_receiver
                elif has_prelowered_method_receiver:
                    prelowered_method_receiver
                else:
                    self.lower_expr(receiver)
                val unresolved_struct_name = self.struct_value_syms.get(unresolved_receiver_local.id)
                if unresolved_struct_name != nil and unresolved_struct_name != "":
                    val unresolved_method_key = "{unresolved_struct_name}::{method}"
                    # Method symbols are owner-qualified during HIR lowering,
                    # so unrelated types may safely expose the same method name.
                    if self.struct_method_syms.has(unresolved_method_key):
                        val resolved_method_id = self.struct_method_syms[unresolved_method_key]
                        var im_arg_operands: [MirOperand] = [mir_operand_copy(unresolved_receiver_local)]
                        for arg in args:
                            val im_arg_local = self.lower_expr(arg.value)
                            im_arg_operands = im_arg_operands.push(mir_operand_copy(im_arg_local))
                        val im_method_operand = self.symbol_to_operand(resolved_method_id)
                        val im_return_type = self.resolved_call_return_type(resolved_method_id)
                        var im_b = self.builder
                        val im_result = im_b.emit_call(im_method_operand, im_arg_operands, im_return_type)
                        self.builder = im_b
                        var im_wb_value = wb_receiver
                        if val im_result_local = im_result:
                            im_wb_value = im_result_local
                        self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, im_wb_value)
                        if val im_result_local = im_result:
                            self.remember_call_hir_return(im_result_local, resolved_method_id)
                            # Thread the callee's declared return struct name
                            # onto the result local (methchain lane fix) so a
                            # chained `.m2()` on THIS call's result resolves
                            # via the same struct_value_syms lookup the
                            # receiver used above. Looked up text-keyed (NOT
                            # via the method SymbolId's HIR .type_, which is
                            # nil here -- native-build's --entry path never
                            # runs the HIR type-inference pass that would
                            # populate it) from struct_method_return_names,
                            # built at HIR-lowering time in
                            # trait_impl_lowering.spl where the method's
                            # `-> Pt` annotation IS resolved regardless of
                            # path -- see HirImpl.method_return_struct_names.
                            val im_ret_struct_name = self.struct_method_return_names.get(unresolved_method_key)
                            if im_ret_struct_name != nil and im_ret_struct_name != "":
                                self.struct_value_syms[im_result_local.id] = im_ret_struct_name
                            # Methchain lane construct #5 (`obj.items()[0]`):
                            # register the result into runtime_array_locals
                            # when the method's declared return type is
                            # Array/Slice, so a chained `[idx]` on this call's
                            # result indexes through the runtime array path
                            # (see struct_method_return_is_array doc comment)
                            # instead of silently misreading the raw boxed
                            # handle as an offset.
                            if self.struct_method_return_is_array.has(unresolved_method_key):
                                self.runtime_array_locals[im_result_local.id] = true
                            return im_result_local
                        var im_b2 = self.builder
                        val im_temp = im_b2.new_temp(MirType.i64())
                        im_b2.emit_const(im_temp, MirConstValue.Int(0), MirType.i64())
                        self.builder = im_b2
                        return im_temp

                # Task #155: native lowering for array `map`/`filter`/`fold` with
                # lambda arguments, on top of #165's lambda-lift/fnptr machinery
                # (lower_lambda_value in switch_operators_calls.spl). Like `push`
                # above, these builtin-Array methods have no MethodResolver entry
                # (the resolver requires a symbol-bearing HIR type) so they always
                # reach this Unresolved arm, typed or not.
                #
                # Only a non-capturing INLINE lambda literal argument is handled:
                # lower_lambda_value returns Some(fnptr operand) for a liftable
                # `Lambda` node and nil for anything else (a capturing lambda, a
                # lambda stored in a variable and passed by name, or a non-lambda
                # arg) -- nil falls straight through to the existing loud
                # "unresolved method call" failure below, never silently
                # mis-lowering. Guarded on `local_is_runtime_array` so a
                # same-named method on some other Unresolved-typed receiver
                # (which this codebase does not currently have, but might grow)
                # can't be misdispatched as an array op.
                if self.local_is_runtime_array(unresolved_receiver_local):
                    if method == "map" and args.len() == 1:
                        val map_lambda_operand = self.lower_lambda_value(args[0].value)
                        if val map_lam_op = map_lambda_operand:
                            return self.lower_array_map(unresolved_receiver_local, map_lam_op)
                    if method == "filter" and args.len() == 1:
                        val filter_lambda_operand = self.lower_lambda_value(args[0].value)
                        if val filter_lam_op = filter_lambda_operand:
                            return self.lower_array_filter(unresolved_receiver_local, filter_lam_op)
                    if method == "fold" and args.len() == 2:
                        val fold_lambda_operand = self.lower_lambda_value(args[1].value)
                        if val fold_lam_op = fold_lambda_operand:
                            val fold_init_raw = self.lower_expr(args[0].value)
                            return self.lower_array_fold(unresolved_receiver_local, fold_init_raw, fold_lam_op)

                # Bug #149: `x.push(item)` never resolves via MethodResolver
                # (try_instance_method/try_trait_method/try_ufcs in
                # resolve_strategies.spl all require a symbol-bearing HIR
                # type; the builtin Array type has none), so every `.push()`
                # call reaches this arm -- not only on the untyped/bootstrap
                # argv-driven path. Confirmed empirically: a type-annotated
                # `var arr: [i64] = [1, 2]; arr.push(3)` hits the identical
                # fatal "unresolved method call: push" native-build error
                # (driver_pipeline.spl turns collected MirLowering errors
                # into a hard failure on the normal, non-bootstrap path) as
                # an untyped argv-driven push.
                #
                # Reuse the SAME writeback bookkeeping the (currently
                # unreachable for Array) InstanceMethod/TraitMethod/
                # FreeFunction cases above rely on for mutating methods on
                # Index/Field receivers: wb_kind/wb_base/wb_index/
                # wb_field_idx/wb_receiver were already pre-lowered above
                # this `match resolution:`, regardless of resolution value.
                # Reusing wb_receiver (instead of re-lowering `receiver`)
                # avoids double-evaluating a side-effecting index expression
                # (`stack[compute_index()].push(x)`), and feeding it back
                # through emit_method_writeback guarantees exact behavioral
                # parity with however a resolved push would behave.
                #
                # Runtime representation (see runtime_native.c): arrays are
                # heap-boxed -- `rt_core_array_reserve` grows a push by
                # `realloc`-ing the internal `data` buffer only; the outer
                # RtCoreArray header (== the tagged i64 handle value itself)
                # never moves. So `rt_array_push(handle, value)` mutates
                # through a STABLE handle -- the writeback below is an
                # idempotent re-store for Index/Field receivers (same as
                # the existing wb doc comment already states for resolved
                # mutating methods) and a true no-op for a plain Var
                # receiver (wb_kind == 0) -- never a silently-dropped append.
                if method == "push" and args.len() == 1:
                    # Bug (array-push-tag): rt_array_push's `val` slot is the
                    # tagged i64 runtime ABI -- EVERY other producer of array
                    # element storage (lower_array_lit's per-element loop,
                    # lower_dict_lit's value slot, lower_dict_key) tags its
                    # value via self.box_runtime_value before handing it to
                    # the runtime. This arm used to hand-rolled ONLY the
                    # string case (rt_strlen/rt_string_new, duplicating
                    # box_runtime_value's own str branch) and left every other
                    # type (i64/i32/bool/f32/f64 literals AND already-tagged
                    # runtime values) to pass through RAW. box_runtime_value
                    # is itself idempotent for already-tagged runtime/array/
                    # dict/nil locals (see its `runtime_value_locals.has`
                    # early-return), so it's a safe drop-in replacement here:
                    # a raw int literal now gets `<<3` tag-boxed exactly like
                    # an array-literal element does, so a later `a[i]` read
                    # (which always un-boxes via `>>3`) recovers the true
                    # value instead of corrupting a small untagged int (e.g.
                    # push(7) stored raw 7, then read-side `7 >> 3 == 0`).
                    val push_recv = unresolved_receiver_local
                    val push_val_raw = self.lower_expr(args[0].value)
                    val push_val_tagged = self.box_runtime_value(push_val_raw)
                    val push_op = MirOperand(kind: MirOperandKind.Const(
                        MirConstValue.Str("rt_array_push"),
                        MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                            params: [MirType.ptr(MirType.i64(), false), MirType.i64()],
                            return_type: MirType(kind: MirTypeKind.I8),
                            is_variadic: false
                        )))
                    ))
                    var b_push = self.builder
                    b_push.emit_call(push_op, [mir_operand_copy(push_recv), mir_operand_copy(push_val_tagged)], MirType(kind: MirTypeKind.I8))
                    self.builder = b_push
                    self.emit_method_writeback(wb_kind, wb_base, wb_index, wb_field_idx, push_recv)
                    return push_recv
                self.error("unresolved method call: {method}", nil)
                # Task #145: self.error only COLLECTS -- both the bootstrap
                # lane (driver_bootstrap.spl reads ctx.errors, never
                # MirLowering.errors) and the native-build worker drop the
                # list (see mir_lowering_stmts.spl lower_for_iterator's
                # belt-and-braces note). The const-0 placeholder below then
                # ships as SILENT data loss (exit 0, no stderr) -- exactly
                # how the `.join()` no-op survived undetected. Surface it
                # loudly at lowering time, naming the method.
                print "[mir-lower] WARNING: unresolved method call '{method}' lowered to const-0 placeholder (silent-null risk, Task #145)"
                var b = self.builder
                val temp = b.new_temp(MirType.i64())
                # self.error only collects; returning an undefined temp here
                # produces a use-before-def local (NULL llvm::Value* -> ICmp
                # SIGSEGV in llvm-lib). Give the placeholder a def.
                b.emit_const(temp, MirConstValue.Int(0), MirType.i64())
                self.builder = b
                temp

    me bootstrap_coerce_to_raw_str(local: LocalId) -> LocalId:
        """Bootstrap-only: coerce a lowered value to a raw char* (Opaque
        "str"), reusing Bug #136's string-interpolation coercion scheme (see
        `lower_string_interpolation` in expr_dispatch.spl). A string operand
        (Opaque "str") passes straight through rt_interp_cstr unchanged. A
        non-string operand (e.g. an i64) is first rendered to a decimal
        string via rt_raw_i64_to_string (a tagged heap string), which
        rt_interp_cstr then unwraps to its char* buffer. Used by the
        bootstrap `.join()` fix (Task #145) to normalize array-literal
        elements and the separator to the raw char* representation
        `emit_raw_strcat`/rt_strcat expects.
        """
        var is_str = false
        if val ty = self.local_mir_type_of(local):
            match ty.kind:
                case MirTypeKind.Opaque(ty_name):
                    if ty_name == "str":
                        is_str = true
                case _: ()
        var cstr_src = mir_operand_copy(local)
        if not is_str:
            val num_op = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_raw_i64_to_string"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
            ))
            var b_num = self.builder
            val num_res = b_num.emit_call(num_op, [mir_operand_copy(local)], MirType.i64())
            self.builder = b_num
            if val num_local = num_res:
                cstr_src = mir_operand_copy(num_local)
        val cstr_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_interp_cstr"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType(kind: MirTypeKind.Opaque("str")), is_variadic: false)))
        ))
        var b_cstr = self.builder
        val cstr_res = b_cstr.emit_call(cstr_op, [cstr_src], MirType(kind: MirTypeKind.Opaque("str")))
        self.builder = b_cstr
        if val cstr_local = cstr_res:
            cstr_local
        else:
            local

    me len_runtime_symbol_for_hir_type(type_: HirType?) -> text:
        """Return a concrete len helper for built-in collection types.

        This avoids routing hot typed `.len()` calls through generic `rt_len`
        while preserving custom/user-defined `len` resolution.
        """
        if type_ == nil:
            return ""
        match type_.kind:
            case Str:
                "rt_string_len"
            case Array(_, _):
                "rt_array_len"
            case Slice(_):
                "rt_array_len"
            case Dict(_, _):
                "rt_dict_len"
            case _:
                ""

    me build_args_from_receiver(receiver_local: LocalId, args: [HirCallArg]) -> [MirOperand]:
        """Build arg operands starting from a pre-lowered receiver local.

        Used by the indexed/field writeback path in `lower_method_call` to
        avoid re-lowering the receiver HIR (which would duplicate side
        effects and re-run emit_gep/emit_load for the indexed slot).
        """
        var arg_operands: [MirOperand] = [mir_operand_copy(receiver_local)]
        for arg in args:
            val arg_local = self.lower_expr(arg.value)
            arg_operands = arg_operands.push(mir_operand_copy(arg_local))
        arg_operands

    me emit_method_writeback(wb_kind: i64, wb_base: LocalId, wb_index: LocalId, wb_field_idx: i64, receiver_value: LocalId):
        """Emit the post-call store-back for a mutating method on an
        indexed or field receiver. No-op when `wb_kind == 0`.

        wb_kind 1: `rt_array_set(base, index, receiver)` (indexed slot)
        wb_kind 2: `emit_set_field(base, field_idx, receiver)` (struct field)
        """
        if wb_kind == 1:
            val boxed_receiver = self.box_runtime_value(receiver_value)
            val func_operand = MirOperand(kind: MirOperandKind.Const(
                MirConstValue.Str("rt_array_set"),
                MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.ptr(MirType.i64(), false), MirType.i64(), MirType.i64()], return_type: MirType.unit(), is_variadic: false)))
            ))
            self.builder.emit_call(func_operand, [
                mir_operand_copy(wb_base),
                mir_operand_copy(wb_index),
                mir_operand_copy(boxed_receiver)
            ], MirType.unit())
        else if wb_kind == 2:
            var b = self.builder
            b.emit_set_field(mir_operand_copy(wb_base), wb_field_idx, mir_operand_copy(receiver_value))
            self.builder = b

    me lower_gpu_intrinsic_call(name: text, args: [HirCallArg]) -> LocalId:
        """Lower GPU intrinsic function call to MIR GPU instruction."""
        # Resolve dimension argument (default 0)
        val dim = if args.len() > 0:
            # Try to extract constant integer from the dimension argument
            val dim_expr = args[0].value
            match dim_expr.kind:
                case IntLit(value, _):
                    value
                case _:
                    # Non-constant dim: lower to MIR but use 0 as fallback
                    val dim_local = self.lower_expr(dim_expr)
                    0
        else:
            0

        var b = self.builder
        val dest = b.new_temp(MirType.i64())

        match name:
            case "gpu_global_id":
                b.emit(MirInst(kind: MirInstKind.GpuGlobalId(dest, dim), span: nil))
            case "gpu_local_id":
                b.emit(MirInst(kind: MirInstKind.GpuLocalId(dest, dim), span: nil))
            case "gpu_block_id":
                b.emit(MirInst(kind: MirInstKind.GpuBlockId(dest, dim), span: nil))
            case "gpu_block_dim":
                b.emit(MirInst(kind: MirInstKind.GpuBlockDim(dest, dim), span: nil))
            case "gpu_grid_dim":
                b.emit(MirInst(kind: MirInstKind.GpuGridDim(dest, dim), span: nil))
            case "gpu_sync" | "gpu_barrier":
                b.emit(MirInst(kind: MirInstKind.GpuBarrier(GpuBarrierScope.Workgroup), span: nil))
            case "gpu_mem_fence":
                b.emit(MirInst(kind: MirInstKind.GpuMemFence(GpuMemoryScope.Workgroup), span: nil))
            case "gpu_atomic_cas":
                # Compare-and-swap: gpu_atomic_cas(ptr, expected, desired)
                self.builder = b
                if args.len() >= 3:
                    val ptr_local = self.lower_expr(args[0].value)
                    val expected_local = self.lower_expr(args[1].value)
                    val desired_local = self.lower_expr(args[2].value)
                    var b_cas = self.builder
                    val cas_dest = b_cas.new_temp(MirType.i64())
                    b_cas.emit(MirInst(kind: MirInstKind.GpuAtomicCas(cas_dest, mir_operand_copy(ptr_local), mir_operand_copy(expected_local), mir_operand_copy(desired_local)), span: nil))
                    self.builder = b_cas
                    return cas_dest
                else:
                    var b_cas2 = self.builder
                    b_cas2.emit_comment("gpu_atomic_cas requires 3 args (ptr, expected, desired)")
                    self.builder = b_cas2
                    return dest
            case _:
                # Atomic ops and others — fall through to regular call
                self.builder = b
                var arg_operands: [MirOperand] = []
                for arg in args:
                    val arg_local = self.lower_expr(arg.value)
                    arg_operands = arg_operands.push(mir_operand_copy(arg_local))
                val func_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str(name),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b2 = self.builder
                val call_result = b2.emit_call(func_op, arg_operands, MirType.i64())
                self.builder = b2
                if val call_local = call_result:
                    return call_local
                else:
                    return dest

        self.builder = b
        dest

    me bootstrap_symbol_name(symbol: SymbolId) -> text:
        if not symbol.?:
            return ""
        val id = self.symbol_id_value(symbol)
        if id == 1:
            return "bootstrap_version"
        if id == 2:
            return "native_build_help"
        if id == 3:
            return "compile_result_exit"
        if id == 4:
            return "run_native_build_bootstrap"
        if id == 5:
            return "get_cli_args"
        if id == 6:
            return "main"
        if id == 7:
            return "bootstrap_output_from_args"
        if id == 8:
            return "rt_native_build"
        ""

    me symbol_to_operand(symbol: SymbolId) -> MirOperand:
        """Convert a symbol to a function pointer operand."""
        # Look up function name from symbol table for direct calls
        val sym = self.symbols.get_symbol(symbol)
        var name = if sym.?: sym.name else: self.bootstrap_symbol_name(symbol)
        name = name.replace("::", ".")
        if name == "":
            name = "unknown_{self.symbol_id_value(symbol)}"
        var signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
        if sym != nil and sym.type_ != nil:
            match sym.type_.kind:
                case HirTypeKind.Function(params, ret, _):
                    var mir_params: [MirType] = []
                    for param in params:
                        mir_params = mir_params.push(self.lower_type(param))
                    signature = MirSignature(params: mir_params, return_type: self.lower_type(ret), is_variadic: false)
                case _: ()
        MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str(name),
            MirType(kind: MirTypeKind.FuncPtr(signature))
        ))

    me named_function_operand(fallback_name: text) -> MirOperand?:
        var known_function = false
        for name in self.current_function_names:
            if name == fallback_name:
                known_function = true
        if not known_function:
            return nil
        Some(MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str(fallback_name),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [], return_type: MirType.i64(), is_variadic: false
            )))
        )))

    me lower_array_lit(elements: [HirExpr]) -> LocalId:
        """Lower array literal."""
        var operands: [MirOperand] = []
        var lowered_elem_type = MirType.i64()
        # Bug (array-of-structs field misread): `pts[i].y` on
        # `[Point(x:1,y:2), Point(x:3,y:4)]` always read field 0 (x) no
        # matter which field name was requested, because reading an array
        # element back out (expr_dispatch.spl's Index case) has no way to
        # learn the element's struct NAME -- resolve_field_index's fallback
        # chain (HIR type annotation, then struct_value_syms) finds nothing
        # for a freshly-decoded array-element local and silently defaults to
        # index 0. Each element's own local IS registered in
        # struct_value_syms at construction time (StructLit lowering), so
        # capture the FIRST element's struct name here (elements of a single
        # array literal are expected to share one struct type) and stash it
        # keyed by the ARRAY's own local id in array_element_struct_syms; the
        # Index case then re-attaches it to each decoded per-element result.
        var elem_struct_name = ""
        for elem in elements:
            # A Lambda literal element (`[\x: x+1, \x: x*2]`) is a first-class
            # function VALUE -- `self.lower_expr` has no generic Lambda case and
            # returns nil, which then crashed on `local.id` below (an internal
            # "undefined field 'id' on nil" instead of a clean diagnostic).
            # NOTE: lifting it to a fnptr via #165's `lower_lambda_value` (as
            # the struct-field-initializer fix above does) was tried here too
            # and made the BUILD succeed, but the resulting binary then
            # SIGSEGV'd at runtime the first time an element was called back
            # out of the array -- box_runtime_value/array-element tagging does
            # not round-trip a raw fnptr constant correctly. A silent-successful
            # build that crashes at runtime is strictly worse than today's
            # build-time failure, so that path is NOT taken here; this is a
            # guard-only fix (still a clean loud build failure, never a crash).
            val local = self.lower_expr(elem)
            if local == nil:
                self.error("unsupported array element (cannot lower to a value)", nil)
                operands = operands.push(MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(0), MirType.i64())))
            else:
                if operands.len() == 0:
                    val local_type = self.local_mir_type_of(local)
                    if local_type != nil:
                        lowered_elem_type = local_type
                    val elem_vname = self.struct_value_syms.get(local.id)
                    if elem_vname != nil:
                        elem_struct_name = elem_vname ?? ""
                val boxed = self.box_runtime_value(local)
                operands = operands.push(mir_operand_copy(boxed))

        # The lowered local is authoritative. Flat HIR expression metadata may
        # still carry the parser's default i64 for typed variables.
        val elem_type = lowered_elem_type
        val array_type = MirType(kind: MirTypeKind.Array(elem_type, elements.len()))

        val arr_local = self.builder.emit_aggregate(
            AggregateKind.Array(elem_type),
            operands,
            array_type
        )
        self.runtime_array_locals[arr_local.id] = true
        self.runtime_value_locals[arr_local.id] = true
        if elem_struct_name != "":
            self.array_element_struct_syms[arr_local.id] = elem_struct_name
        arr_local

    me lower_dict_key(key_expr: HirExpr) -> LocalId:
        """Lower a dict key to the runtime ABI (i64).

        A plain string literal lowers to a RAW char* pointer (getelementptr into
        a [N x i8] global), but the runtime dict compares keys as tagged heap
        strings via rt_native_eq. Tag plain string-literal keys with
        rt_string_new(ptr, rt_strlen(ptr)); pass everything else (already-tagged
        string variables, int keys) through unchanged.
        """
        val key_local = self.lower_expr(key_expr)
        self.box_runtime_value(key_local)

    me lower_dict_lit(entries: [(HirExpr, HirExpr)]) -> LocalId:
        """Lower a dict literal `{k: v, ...}` to rt_dict_new + rt_dict_set calls.

        The result is a tagged i64 dict handle; the local is registered in
        runtime_dict_locals so a later `d[k]` read routes to rt_dict_get (see
        expr_dispatch `case Index`). All keys/values use the flat i64 runtime
        ABI; string-literal keys are tagged via lower_dict_key.
        """
        val new_op = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_dict_new"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
        ))
        val cap_hint = MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(0), MirType.i64()))
        var key_type = MirType.i64()
        var value_type = MirType.i64()
        var first_entry = true
        var b_new = self.builder
        val new_res = b_new.emit_call(new_op, [cap_hint], MirType.i64())
        self.builder = b_new
        if val dict_local = new_res:
            for entry in entries:
                val (key_expr, value_expr) = entry
                # Bug (native_dict_keys_iter_index): capture the key's type
                # from the RAW (pre-box) lowered local, mirroring how
                # `value_type` below already reads `value_local` BEFORE
                # `box_runtime_value(value_local)` runs. `lower_dict_key`
                # lowers AND boxes in one step (`self.box_runtime_value(self.
                # lower_expr(key_expr))`), so reading its type straight off
                # its return value picked up the BOXED representation's MIR
                # type instead -- for a string-literal key that box step is
                # `rt_string_new`, an `emit_call` typed i64 (the runtime
                # symbol's declared return type), so `key_type` silently
                # became `I64` for every string-keyed dict literal (a
                # `Dict<text,i64>` recorded its OWN type as `Dict(I64,I64)`).
                # That corrupted every consumer of the dict's recorded key
                # type -- specifically `.keys()`'s result-array element type
                # fix just above, which decoded each TAGGED heap-string key
                # as an INTEGER (right-shift-by-3) instead of a string,
                # producing a garbage `d[k]` lookup key and a silently-wrong
                # sum. Lower the key raw first (capturing its true type), box
                # it after, exactly like the value already does.
                val key_local_raw = self.lower_expr(key_expr)
                if first_entry:
                    key_type = self.local_mir_type_of(key_local_raw) ?? key_type
                val key_local = self.box_runtime_value(key_local_raw)
                val value_local = self.lower_expr(value_expr)
                if first_entry:
                    value_type = self.local_mir_type_of(value_local) ?? value_type
                    first_entry = false
                val boxed_value = self.box_runtime_value(value_local)
                val set_op = MirOperand(kind: MirOperandKind.Const(
                    MirConstValue.Str("rt_dict_set"),
                    MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64(), MirType.i64(), MirType.i64()], return_type: MirType.i64(), is_variadic: false)))
                ))
                var b_set = self.builder
                b_set.emit_call(set_op, [mir_operand_copy(dict_local), mir_operand_copy(key_local), mir_operand_copy(boxed_value)], MirType.i64())
                self.builder = b_set
            val dict_type = MirType(kind: MirTypeKind.Dict(key_type, value_type))
            var b_typed = self.builder
            val typed = b_typed.new_temp(dict_type)
            b_typed.emit_copy(typed, dict_local)
            self.builder = b_typed
            self.runtime_dict_locals[typed.id] = true
            self.runtime_value_locals[typed.id] = true
            return typed
        # rt_dict_new always returns a local; fall back to a const 0 handle only
        # if the call somehow produced no result, to keep this total.
        var b_fb = self.builder
        val fb = b_fb.new_temp(MirType.i64())
        b_fb.emit_const(fb, MirConstValue.Int(0), MirType.i64())
        self.builder = b_fb
        fb

    me lower_array_repeat(value: HirExpr, count: HirExpr) -> LocalId:
        """Lower array-repeat `[value; count]` to `rt_array_repeat(value, count)`.

        The runtime stores `count` raw i64 copies of `value` and returns a tagged
        heap-array handle. Both operands are coerced to the i64 runtime ABI. The
        result local is typed as an Array so later `[i]` reads route through
        `rt_array_get` (see expr_dispatch `local_is_runtime_array`/Array-type
        branch) rather than an inline aggregate GEP.
        """
        # Element type from the repeated value (default i64). Redundant nil
        # re-check guards against lower_type(nil) -- same pattern as lower_array_lit.
        var elem_type = MirType.i64()
        val value_type = value.type_
        if val vt = value_type:
            if vt != nil:
                elem_type = self.lower_type(vt)

        # Lower and coerce operands to the RuntimeValue array ABI.
        val value_local = self.lower_expr(value)
        val count_local = self.lower_expr(count)
        val value_i64 = self.box_runtime_value(value_local)
        var cb = self.builder
        val count_i64 = cb.emit_cast(mir_operand_copy(count_local), MirType.i64())
        self.builder = cb

        # Static size when the count is a literal, else 0. The heap array carries
        # its own runtime length; this only annotates the MIR type for routing.
        var static_size: i64 = 0
        match count.kind:
            case IntLit(cv, _): static_size = cv
            case _: static_size = 0
        val array_type = MirType(kind: MirTypeKind.Array(elem_type, static_size))

        # Bug #149: the FuncPtr's declared `return_type` here is what
        # `translate_operand`/`remember_function_return_type` registers as
        # `rt_array_repeat`'s KNOWN return type at codegen time -- it must
        # match `array_type` (Array kind -> "ptr"), the type this call's
        # DESTINATION local is actually declared with below. Declaring it
        # `i64` here (as before) registered a return type that disagreed
        # with the destination local's MIR-declared (and therefore
        # `ptr_locals`-primed) type, leaving the call itself emitted as
        # `i64` while later consumers (a copy, or a `.len()`/index call
        # argument) still saw the stale `ptr_locals` flag and treated the
        # i64-defined value as a pointer -- invalid IR. `rt_array_repeat`
        # genuinely returns `SplArray*` in C (same as rt_array_new), so
        # `array_type` (-> ptr) is correct here, matching the static
        # `declare ptr @rt_array_repeat(i64, i64)` in
        # asm_constraints_helpers.spl's emit_runtime_declarations.
        val repeat_fn = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_repeat"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [MirType.i64(), MirType.i64()],
                return_type: array_type,
                is_variadic: false
            )))
        ))
        var b = self.builder
        val result = b.emit_call(
            repeat_fn,
            [mir_operand_copy(value_i64), mir_operand_copy(count_i64)],
            array_type
        )
        self.builder = b
        val result_local = result ?? self.builder.new_temp(array_type)
        self.runtime_array_locals[result_local.id] = true
        self.runtime_value_locals[result_local.id] = true
        result_local

    me rt_array_len_operand() -> MirOperand:
        MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_len"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))

    me rt_array_get_operand() -> MirOperand:
        MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_get"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)))
        ))

    me rt_array_push_operand() -> MirOperand:
        MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_push"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [MirType.ptr(MirType.i64(), false), MirType.i64()],
                return_type: MirType(kind: MirTypeKind.I8),
                is_variadic: false
            )))
        ))

    me lower_array_map(arr: LocalId, lam_op: MirOperand) -> LocalId:
        """Lower `arr.map(\\x: expr)` for a runtime `[i64]` array.

        Emits a counted index loop (same shape as
        mir_lowering_stmts.lower_for_array_indexed): builds a fresh result
        array via rt_array_new/rt_array_push, calling the #165-lifted lambda
        fnptr once per element. `rt_array_get` returns a TAGGED runtime value
        (decode_runtime_value untags it to raw i64 -- the lambda's forced ABI,
        see lower_lambda_value); the lambda's raw i64 result is re-tagged
        (box_runtime_value) before rt_array_push, matching how the existing
        `push` intercept above tags its argument.
        """
        val loop_ty = MirType.i64()

        var b_len = self.builder
        val len_call = b_len.emit_call(self.rt_array_len_operand(), [mir_operand_copy(arr)], MirType.i64())
        val len_local = len_call ?? b_len.new_temp(MirType.i64())
        self.builder = b_len

        val array_type = MirType(kind: MirTypeKind.Array(MirType.i64(), 0))
        var b_new = self.builder
        val zero_cap = b_new.emit_const_int(0)
        val new_call = b_new.emit_call(MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_new"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: array_type, is_variadic: false)))
        )), [mir_operand_copy(zero_cap)], array_type)
        val result_arr = new_call ?? b_new.new_temp(array_type)
        self.builder = b_new
        self.runtime_array_locals[result_arr.id] = true
        self.runtime_value_locals[result_arr.id] = true

        var b_init = self.builder
        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
        val zero = b_init.new_temp(loop_ty)
        b_init.emit_const(zero, MirConstValue.Int(0), loop_ty)
        b_init.emit_copy(counter, zero)
        val one = b_init.new_temp(loop_ty)
        b_init.emit_const(one, MirConstValue.Int(1), loop_ty)
        self.builder = b_init

        var b_blocks = self.builder
        val cond_block = b_blocks.new_block(Some("map_cond"))
        val body_block = b_blocks.new_block(Some("map_body"))
        val inc_block = b_blocks.new_block(Some("map_inc"))
        val exit_block = b_blocks.new_block(Some("map_exit"))
        self.builder = b_blocks

        var b_goto = self.builder
        b_goto.terminate_goto(cond_block)
        b_goto.switch_to_block(cond_block)
        self.builder = b_goto

        var b_cond = self.builder
        val cond_result = b_cond.emit_binop(MirBinOp.Lt, mir_operand_copy(counter), mir_operand_copy(len_local), MirType.bool())
        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
        b_cond.switch_to_block(body_block)
        self.builder = b_cond

        var b_get = self.builder
        val get_call = b_get.emit_call(self.rt_array_get_operand(), [mir_operand_copy(arr), mir_operand_copy(counter)], MirType.i64())
        val elem_tagged = get_call ?? b_get.new_temp(MirType.i64())
        self.builder = b_get
        val elem_raw = self.decode_runtime_value(elem_tagged, MirType.i64())

        var b_call = self.builder
        val call_result = b_call.emit_call(lam_op, [mir_operand_copy(elem_raw)], MirType.i64())
        val mapped_raw = call_result ?? b_call.new_temp(MirType.i64())
        self.builder = b_call
        val mapped_tagged = self.box_runtime_value(mapped_raw)

        var b_push = self.builder
        b_push.emit_call(self.rt_array_push_operand(), [mir_operand_copy(result_arr), mir_operand_copy(mapped_tagged)], MirType(kind: MirTypeKind.I8))
        self.builder = b_push

        var b_body_end = self.builder
        if not b_body_end.current_block_has_explicit_terminator():
            b_body_end.terminate_goto(inc_block)
        self.builder = b_body_end

        var b_inc = self.builder
        b_inc.switch_to_block(inc_block)
        val incremented = b_inc.emit_binop(MirBinOp.Add, mir_operand_copy(counter), mir_operand_copy(one), loop_ty)
        b_inc.emit_copy(counter, incremented)
        self.builder = b_inc
        var b_back = self.builder
        b_back.terminate_goto(cond_block)
        self.builder = b_back

        var b_exit = self.builder
        b_exit.switch_to_block(exit_block)
        self.builder = b_exit
        result_arr

    me lower_array_filter(arr: LocalId, lam_op: MirOperand) -> LocalId:
        """Lower `arr.filter(\\x: predicate)` for a runtime `[i64]` array.

        Same counted-loop shape as `lower_array_map`, but the lambda's raw i64
        result is treated as a boolean predicate (!= 0 -- the backend's `Ret`
        terminator already zero-extends a bool-typed lambda body to the
        lifted function's forced i64 return, see core_codegen.spl's
        `value_as_type` coercion on `Ret`) and, when true, the ORIGINAL tagged
        element (not the decoded raw value) is pushed into the result array
        unchanged, since filter must preserve element values, only select a
        subset.
        """
        val loop_ty = MirType.i64()

        var b_len = self.builder
        val len_call = b_len.emit_call(self.rt_array_len_operand(), [mir_operand_copy(arr)], MirType.i64())
        val len_local = len_call ?? b_len.new_temp(MirType.i64())
        self.builder = b_len

        val array_type = MirType(kind: MirTypeKind.Array(MirType.i64(), 0))
        var b_new = self.builder
        val zero_cap = b_new.emit_const_int(0)
        val new_call = b_new.emit_call(MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Str("rt_array_new"),
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [MirType.i64()], return_type: array_type, is_variadic: false)))
        )), [mir_operand_copy(zero_cap)], array_type)
        val result_arr = new_call ?? b_new.new_temp(array_type)
        self.builder = b_new
        self.runtime_array_locals[result_arr.id] = true
        self.runtime_value_locals[result_arr.id] = true

        var b_init = self.builder
        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
        val zero = b_init.new_temp(loop_ty)
        b_init.emit_const(zero, MirConstValue.Int(0), loop_ty)
        b_init.emit_copy(counter, zero)
        val one = b_init.new_temp(loop_ty)
        b_init.emit_const(one, MirConstValue.Int(1), loop_ty)
        self.builder = b_init

        var b_blocks = self.builder
        val cond_block = b_blocks.new_block(Some("filter_cond"))
        val body_block = b_blocks.new_block(Some("filter_body"))
        val push_block = b_blocks.new_block(Some("filter_push"))
        val inc_block = b_blocks.new_block(Some("filter_inc"))
        val exit_block = b_blocks.new_block(Some("filter_exit"))
        self.builder = b_blocks

        var b_goto = self.builder
        b_goto.terminate_goto(cond_block)
        b_goto.switch_to_block(cond_block)
        self.builder = b_goto

        var b_cond = self.builder
        val cond_result = b_cond.emit_binop(MirBinOp.Lt, mir_operand_copy(counter), mir_operand_copy(len_local), MirType.bool())
        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
        b_cond.switch_to_block(body_block)
        self.builder = b_cond

        var b_get = self.builder
        val get_call = b_get.emit_call(self.rt_array_get_operand(), [mir_operand_copy(arr), mir_operand_copy(counter)], MirType.i64())
        val elem_tagged = get_call ?? b_get.new_temp(MirType.i64())
        self.builder = b_get
        val elem_raw = self.decode_runtime_value(elem_tagged, MirType.i64())

        var b_call = self.builder
        val call_result = b_call.emit_call(lam_op, [mir_operand_copy(elem_raw)], MirType.i64())
        val pred_raw = call_result ?? b_call.new_temp(MirType.i64())
        val zero_pred = b_call.emit_const_int(0)
        val keep = b_call.emit_binop(MirBinOp.Ne, mir_operand_copy(pred_raw), mir_operand_copy(zero_pred), MirType.bool())
        b_call.terminate_if(mir_operand_copy(keep), push_block, inc_block)
        b_call.switch_to_block(push_block)
        self.builder = b_call

        var b_push = self.builder
        b_push.emit_call(self.rt_array_push_operand(), [mir_operand_copy(result_arr), mir_operand_copy(elem_tagged)], MirType(kind: MirTypeKind.I8))
        b_push.terminate_goto(inc_block)
        self.builder = b_push

        var b_inc = self.builder
        b_inc.switch_to_block(inc_block)
        val incremented = b_inc.emit_binop(MirBinOp.Add, mir_operand_copy(counter), mir_operand_copy(one), loop_ty)
        b_inc.emit_copy(counter, incremented)
        self.builder = b_inc
        var b_back = self.builder
        b_back.terminate_goto(cond_block)
        self.builder = b_back

        var b_exit = self.builder
        b_exit.switch_to_block(exit_block)
        self.builder = b_exit
        result_arr

    me lower_array_fold(arr: LocalId, init: LocalId, lam_op: MirOperand) -> LocalId:
        """Lower `arr.fold(init, \\acc, x: expr)` for a runtime `[i64]` array.

        Same counted-loop shape as `lower_array_map`/`lower_array_filter`, but
        accumulates into a mutable `acc` Var local (initialized from `init`,
        already the raw i64 ABI value since it comes from a plain expression,
        not an array element) instead of building a result array. Each
        iteration calls the 2-arg lifted lambda as `lam(acc, elem_raw)` and
        stores the raw i64 result back into `acc`; the final `acc` is
        returned once the loop exits.
        """
        val loop_ty = MirType.i64()

        var b_len = self.builder
        val len_call = b_len.emit_call(self.rt_array_len_operand(), [mir_operand_copy(arr)], MirType.i64())
        val len_local = len_call ?? b_len.new_temp(MirType.i64())
        self.builder = b_len

        var b_init = self.builder
        val acc = b_init.new_local(nil, loop_ty, LocalKind.Var)
        val init_i64 = b_init.emit_cast(mir_operand_copy(init), loop_ty)
        b_init.emit_copy(acc, init_i64)
        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
        val zero = b_init.new_temp(loop_ty)
        b_init.emit_const(zero, MirConstValue.Int(0), loop_ty)
        b_init.emit_copy(counter, zero)
        val one = b_init.new_temp(loop_ty)
        b_init.emit_const(one, MirConstValue.Int(1), loop_ty)
        self.builder = b_init

        var b_blocks = self.builder
        val cond_block = b_blocks.new_block(Some("fold_cond"))
        val body_block = b_blocks.new_block(Some("fold_body"))
        val inc_block = b_blocks.new_block(Some("fold_inc"))
        val exit_block = b_blocks.new_block(Some("fold_exit"))
        self.builder = b_blocks

        var b_goto = self.builder
        b_goto.terminate_goto(cond_block)
        b_goto.switch_to_block(cond_block)
        self.builder = b_goto

        var b_cond = self.builder
        val cond_result = b_cond.emit_binop(MirBinOp.Lt, mir_operand_copy(counter), mir_operand_copy(len_local), MirType.bool())
        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
        b_cond.switch_to_block(body_block)
        self.builder = b_cond

        var b_get = self.builder
        val get_call = b_get.emit_call(self.rt_array_get_operand(), [mir_operand_copy(arr), mir_operand_copy(counter)], MirType.i64())
        val elem_tagged = get_call ?? b_get.new_temp(MirType.i64())
        self.builder = b_get
        val elem_raw = self.decode_runtime_value(elem_tagged, MirType.i64())

        var b_call = self.builder
        val call_result = b_call.emit_call(lam_op, [mir_operand_copy(acc), mir_operand_copy(elem_raw)], MirType.i64())
        val new_acc = call_result ?? b_call.new_temp(MirType.i64())
        b_call.emit_copy(acc, new_acc)
        self.builder = b_call

        var b_body_end = self.builder
        if not b_body_end.current_block_has_explicit_terminator():
            b_body_end.terminate_goto(inc_block)
        self.builder = b_body_end

        var b_inc = self.builder
        b_inc.switch_to_block(inc_block)
        val incremented = b_inc.emit_binop(MirBinOp.Add, mir_operand_copy(counter), mir_operand_copy(one), loop_ty)
        b_inc.emit_copy(counter, incremented)
        self.builder = b_inc
        var b_back = self.builder
        b_back.terminate_goto(cond_block)
        self.builder = b_back

        var b_exit = self.builder
        b_exit.switch_to_block(exit_block)
        self.builder = b_exit
        acc

    me lower_tuple_lit(elements: [HirExpr]) -> LocalId:
        """Lower tuple literal."""
        var operands: [MirOperand] = []
        var types: [MirType] = []
        for elem in elements:
            val local = self.lower_expr(elem)
            operands = operands.push(mir_operand_copy(local))
            var elem_ty = MirType.i64()
            val maybe_elem_type = elem.type_
            if val elem_type = maybe_elem_type:
                if elem_type != nil:
                    elem_ty = self.lower_type(elem_type)
            types = types.push(elem_ty)

        val tuple_type = MirType(kind: MirTypeKind.Tuple(types))
        self.builder.emit_aggregate(AggregateKind.Tuple, operands, tuple_type)

    me lower_set_lit(elements: [HirExpr]) -> LocalId:
        """Lower set literal to Set.from() call.

        Transforms: s{1, 2, 3}
        Into: Set.from([1, 2, 3])

        This is simpler than Set.new() + insert() and works with current runtime.
        Future optimization: emit direct Set.new() + insert() calls.
        """
        # Infer element type from first element, or default to i64
        # NOTE: `if val first_type = elements[0].type_:` is not sufficient
        # here -- confirmed by isolated repro that the seed interpreter's
        # `if val` presence check can still enter the true branch with
        # `first_type` bound to nil for this indexed+field-chained Option
        # (elements[0] here is often un-type-inferred the first time this
        # array/set literal is reached via a fresh, non-entry-closure code
        # path). A redundant explicit nil re-check on the bound value guards
        # against calling lower_type(nil), which crashes with "undefined
        # field 'kind': cannot access field on value of type 'nil'".
        val elem_type = if elements.len() > 0:
            val first_elem = elements[0]
            val first_elem_type = first_elem.type_
            if val first_type = first_elem_type:
                if first_type == nil:
                    MirType.i64()
                else:
                    self.lower_type(first_type)
            else:
                MirType.i64()
        else:
            MirType.i64()

        # Lower elements to array literal
        var elem_operands: [MirOperand] = []
        for elem in elements:
            val elem_local = self.lower_expr(elem)
            val boxed = self.box_runtime_value(elem_local)
            elem_operands = elem_operands.push(mir_operand_copy(boxed))

        # Create array from elements
        val array_type = MirType(kind: MirTypeKind.Array(elem_type, elements.len()))
        val array_local = self.builder.emit_aggregate(
            AggregateKind.Array(elem_type),
            elem_operands,
            array_type
        )

        # Call Set.from(array) - using runtime function placeholder
        # In a real implementation, this would resolve Set.from symbol from symbol table
        # For now, create a function operand that will be resolved by codegen
        val set_from_operand = MirOperand(kind: MirOperandKind.Const(
            MirConstValue.Int(0),  # Placeholder - codegen will resolve "Set.from"
            MirType(kind: MirTypeKind.FuncPtr(MirSignature(
                params: [array_type],
                return_type: MirType(kind: MirTypeKind.Named("Set", [elem_type])),
                is_variadic: false
            )))
        ))

        val set_type = MirType(kind: MirTypeKind.Named("Set", [elem_type]))
        val result = self.builder.emit_call(
            set_from_operand,
            [mir_operand_copy(array_local)],
            set_type
        )

        result ?? self.builder.new_temp(set_type)

    me lower_const_expr(expr: HirExpr) -> MirConstValue?:
        """Lower constant expression."""
        match expr.kind:
            case IntLit(value, _):
                Some(MirConstValue.Int(value))
            case FloatLit(value, _):
                Some(MirConstValue.Float(value))
            case BoolLit(value):
                Some(MirConstValue.Bool(value))
            case StringLit(value, _):
                Some(MirConstValue.Str(value))
            case _:
                nil

# ============================================================================
# Exports
# ============================================================================

# Methods are attached to MirLowering via impl block above.
# No separate exports needed -- they are accessed through MirLowering instances.
