# Part of src/compiler/50.mir/mir_lowering.spl: module/struct/class type lowering, asm target-spec accessors
use compiler.mir.mir_lowering.*
# MIR Lowering - HIR to MIR Transformation
#
# This module handles lowering from HIR (High-level IR) to MIR (Mid-level IR).
# It converts:
# - Nested expressions to SSA form
# - Control flow to basic blocks
# - Memory operations to explicit loads/stores
# - Type system from HIR to MIR representation
#
# Split into:
# - mir_lowering_types.spl: Struct definitions (MirLowering, MirError)
# - mir_lowering.spl: Core coordinator, module/function/type lowering, asm/target (this file)
# - mir_lowering_expr.spl: Expression lowering, operators, calls, literals
# - mir_lowering_stmts.spl: Statement lowering, control flow (if/loop/for)
# - mir_lowering_ml.spl: ML blocks, async/await, custom blocks

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, mir_operand_const_int}
use compiler.hir.hir_types.*
use compiler.hir.hir_definitions.*
use compiler.frontend.flat_ast_bridge.{flat_bootstrap_function_count, flat_bootstrap_function_at}
use compiler.common.diagnostics.span.{Span}
use compiler.blocks.value.BlockValue
use compiler.types.type_layout.{compute_struct_layout, layoutattr_default_, FieldLayout}
use std.array.{array_sort_by}

extern fn rt_env_get(key: text) -> text

fn mir_lower_env_get(key: text) -> text:
    rt_env_get(key)

fn mir_lower_trace_enabled() -> bool:
    val trace = mir_lower_env_get("SIMPLE_COMPILER_TRACE") ?? ""
    val phase = mir_lower_env_get("SIMPLE_COMPILER_PHASE_PROFILE") ?? ""
    val diag = mir_lower_env_get("SIMPLE_BOOTSTRAP_DIAG") ?? ""
    if trace == "1":
        return true
    if phase == "1":
        return true
    diag == "1"
use compiler.core.types.{TYPE_BOOL, TYPE_I64, TYPE_F64}
use compiler.mir.synthetic_driver_codegen.{apply_synthetic_driver_codegen}
use compiler.frontend.core.types.{custom_primitive_underlying_type_tag_by_symbol}
use compiler.core.interpreter.hashmap.{hm_hash_text}

# Import struct definitions from types module
use compiler.mir.mir_lowering_types.{MirLowering, MirError}
use compiler.common.mir_target_context.{MirTargetContext, mir_target_context_from}

# Import split modules so their impl blocks are linked
use compiler.mir.mir_lowering_expr.*
use compiler.mir.mir_lowering_stmts.*
use compiler.mir.mir_lowering_ml.*

fn string_literal_has_runtime_interpolations(interps: [HirInterpolation]?) -> bool:
    if val parts = interps:
        return parts.len() > 0
    false

fn runtime_module_initializer_supported(const_: HirConst) -> bool:
    match const_.value.kind:
        case IntLit(_, _) | FloatLit(_, _) | BoolLit(_): false
        case StringLit(_, interps): string_literal_has_runtime_interpolations(interps)
        # Preserve the pre-existing call path; additionally admit wrapped
        # expressions only when every native backend can declare the scalar.
        case Call(_, _, _): true
        case _:
            match const_.type_.kind:
                case Int(_, _) | Float(_) | Bool: true
                case _: false

fn runtime_module_initializers_in_declaration_order(consts: [HirConst]) -> [HirConst]:
    var dynamic: [HirConst] = []
    for const_ in consts:
        if runtime_module_initializer_supported(const_):
            dynamic.push(const_)
    array_sort_by(dynamic, \a, b:
        if a.span.start < b.span.start: -1
        elif a.span.start > b.span.start: 1
        elif a.symbol.id < b.symbol.id: -1
        elif a.symbol.id > b.symbol.id: 1
        else: 0
    )

impl MirLowering:
    static fn new(symbols: SymbolTable) -> MirLowering:
        val target_context = mir_target_context_from("", "unknown", "unknown", "llvm", -1)
        MirLowering.new_for_target(symbols, target_context)

    static fn new_for_target(symbols: SymbolTable, target_context: MirTargetContext) -> MirLowering:
        val empty_loop_stack: [(BlockId, BlockId)] = []
        val empty_errors: [MirError] = []
        MirLowering(
            builder: MirBuilder.new(),
            symbols: symbols,
            local_map: {},
            local_hir_types: {},
            current_function_symbols: [],
            current_function_names: [],
            loop_stack: empty_loop_stack,
            errors: empty_errors,
            field_map: {},
            bitfield_map: {},
            bitfield_value_syms: {},
            struct_field_order: {},
            struct_field_has_default: {},
            struct_field_default_expr: {},
            class_type_names: {},
            struct_field_type_name: {},
            struct_field_repr_name: {},
            struct_field_hir_type: {},
            struct_field_array_element_type_name: {},
            struct_field_array_elem_type: {},
            struct_value_syms: {},
            struct_method_syms: {},
            struct_method_ambiguous: {},
            struct_method_return_names: {},
            struct_method_return_is_array: {},
            enum_payload_struct_names: {},
            enum_tuple_text_slots: {},
            runtime_array_locals: {},
            runtime_dict_locals: {},
            runtime_elem_value_type: {},
            array_element_struct_syms: {},
            runtime_value_locals: {},
            option_value_locals: {},
            nil_locals: {},
            enum_variant_index: {},
            enum_runtime_id_index: {},
            enum_runtime_id_names: {},
            lambda_bindings: {},
            lambda_capture_snapshot: {},
            current_has_vhdl_metadata: false,
            global_symbol_ids: {},
            target_context: target_context
        )

    fn symbol_id_value(symbol: SymbolId) -> i64:
        match symbol:
            case SymbolId(id): id
            case _: -1

    me register_enum_runtime_name(runtime_name: text, enum_name: text, span: Span?):
        val runtime_id = (hm_hash_text(runtime_name) % 2147483646) + 2
        val id_key = "{runtime_id}"
        val existing = self.enum_runtime_id_names.get(id_key)
        if existing != nil and existing != runtime_name:
            val prior_name = existing ?? "<unknown>"
            self.error("enum runtime ID collision: '{prior_name}' and '{runtime_name}'", span)
            return
        self.enum_runtime_id_names[id_key] = runtime_name
        self.enum_runtime_id_index[enum_name] = runtime_id

    me register_enum_runtime_id(enum_def: HirEnum):
        self.register_enum_runtime_name(enum_def.runtime_name, enum_def.name, Some(enum_def.span))

    fn hir_bitfield_fields(bitfield_def: HirBitfield) -> [HirBitfieldField]:
        match bitfield_def:
            case HirBitfield(_, _, _, fields, _, _, _, _, _, _):
                fields

    fn hir_module_function(module: HirModule, symbol: SymbolId) -> HirFunction:
        val target_id = self.symbol_id_value(symbol)
        if target_id < 0:
            return HirFunction(
                symbol: symbol,
                name: "",
                type_params: [],
                params: [],
                return_type: HirType(kind: HirTypeKind.Int(64, true), span: Span.empty()),
                body: HirBlock(stmts: [], has: false, value: nil, span: Span.empty()),
                effects: [],
                visibility: Visibility.Private,
                is_async: false,
                is_static: false,
                is_public: false,
                is_method: false,
                is_mutable: false,
                is_const: false,
                is_extern: true,
                func_attr: nil,
                has_export_attr: false,
                export_attr: nil,
                has_driver_manifest_attr: false,
                driver_manifest_attr: DriverManifestAttr(kind: DriverManifestAttrKind.Driver, driver_class: 0, vendor: 0, device_ids: [], version: "", abi: ""),
                has_suspension: false,
                has_vhdl_metadata: false,
                vhdl_metadata: vhdl_hardware_metadata_default(),
                has_doc_comment: false,
                doc_comment: "",
                span: Span.empty()
            )
        for fn_ in module.functions.values():
            val fn_id = self.symbol_id_value(fn_.symbol)
            if fn_id == target_id:
                return fn_
        HirFunction(
            symbol: symbol,
            name: "",
            type_params: [],
            params: [],
            return_type: HirType(kind: HirTypeKind.Int(64, true), span: Span.empty()),
            body: HirBlock(stmts: [], has: false, value: nil, span: Span.empty()),
            effects: [],
            visibility: Visibility.Private,
            is_async: false,
            is_static: false,
            is_public: false,
            is_method: false,
            is_mutable: false,
            is_const: false,
            is_extern: true,
            func_attr: nil,
            has_export_attr: false,
            export_attr: nil,
            has_driver_manifest_attr: false,
            driver_manifest_attr: DriverManifestAttr(kind: DriverManifestAttrKind.Driver, driver_class: 0, vendor: 0, device_ids: [], version: "", abi: ""),
            has_suspension: false,
            has_vhdl_metadata: false,
            vhdl_metadata: vhdl_hardware_metadata_default(),
            has_doc_comment: false,
            doc_comment: "",
            span: Span.empty()
        )

    fn hir_function_is_extern(fn_: HirFunction) -> bool:
        match fn_:
            case HirFunction(_, _, _, _, _, _, _, _, _, _, _, _, _, _, is_extern, _, _, _, _, _, _, _, _, _, _, _):
                is_extern

    me bootstrap_function_signature(name: text) -> MirSignature:
        MirSignature(params: [], return_type: self.bootstrap_call_return_type(name), is_variadic: false)

    fn bootstrap_default_return_operand(return_type: MirType) -> MirOperand?:
        if return_type.kind == MirTypeKind.Unit:
            return nil
        Some(MirOperand(kind: MirOperandKind.Const(MirConstValue.Zero, return_type)))

    me lower_bootstrap_stub_function(symbol: SymbolId, name: text) -> MirFunction:
        if mir_lower_trace_enabled():
            print "[mir-lower] bootstrap-stub:start {name}"
        val signature = self.bootstrap_function_signature(name)
        var bldr = self.builder
        bldr.begin_function(symbol, name, signature, nil)
        bldr.terminate_return(self.bootstrap_default_return_operand(signature.return_type))
        val fn_result = bldr.end_function()
        self.builder = bldr
        if mir_lower_trace_enabled():
            print "[mir-lower] bootstrap-stub:done {name}"
        fn_result

    me lower_bootstrap_flat_function(symbol: SymbolId, name: text, body: HirBlock) -> MirFunction:
        if name == "bootstrap_version":
            if mir_lower_trace_enabled():
                print "[mir-lower] bootstrap-known:bootstrap_version"
            val str_type = MirType(kind: MirTypeKind.Opaque("str"))
            val signature = MirSignature(params: [], return_type: str_type, is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(symbol, name, signature, nil)
            val dest = bldr_known.new_temp(str_type)
            bldr_known.emit_const(dest, MirConstValue.Str("0.9.8"), str_type)
            bldr_known.terminate_return(Some(mir_operand_copy(dest)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        if name == "native_build_help":
            if mir_lower_trace_enabled():
                print "[mir-lower] bootstrap-known:native_build_help"
            val signature = MirSignature(params: [], return_type: MirType.i64(), is_variadic: false)
            var bldr_known = self.builder
            bldr_known.begin_function(symbol, name, signature, nil)
            val result = bldr_known.emit_const_int(0)
            bldr_known.terminate_return(Some(mir_operand_copy(result)))
            val fn_result = bldr_known.end_function()
            self.builder = bldr_known
            return fn_result

        if mir_lower_trace_enabled():
            print "[mir-lower] bootstrap-flat:start {name}"
        self.local_map = {}
        self.local_hir_types = {}
        self.runtime_array_locals = {}
        self.runtime_dict_locals = {}
        self.runtime_elem_value_type = {}
        self.runtime_value_locals = {}
        self.option_value_locals = {}
        self.nil_locals = {}
        val signature = self.bootstrap_function_signature(name)
        var bldr = self.builder
        bldr.begin_function(symbol, name, signature, nil)
        self.builder = bldr
        val result = self.lower_block(body)
        var bldr2 = self.builder
        if not bldr2.current_block_has_explicit_terminator():
            if result.?:
                bldr2.terminate_return(Some(mir_operand_copy(result ?? LocalId(id: 0))))
            else:
                bldr2.terminate_return(self.bootstrap_default_return_operand(signature.return_type))
        self.builder = bldr2
        var bldr3 = self.builder
        val fn_result = bldr3.end_function()
        self.builder = bldr3
        if mir_lower_trace_enabled():
            print "[mir-lower] bootstrap-flat:done {name}"
        fn_result

    fn asm_version_constraint_op(vc: AsmVersionConstraint) -> text:
        vc.op

    fn asm_version_constraint_value(vc: AsmVersionConstraint) -> i64:
        vc.version

    fn asm_target_spec_archs(spec: AsmTargetSpec) -> [text]:
        spec.archs

    fn asm_target_spec_has_os(spec: AsmTargetSpec) -> bool:
        spec.has_os

    fn asm_target_spec_os(spec: AsmTargetSpec) -> text:
        spec.os

    fn asm_target_spec_has_abi(spec: AsmTargetSpec) -> bool:
        spec.has_abi

    fn asm_target_spec_abi(spec: AsmTargetSpec) -> text:
        spec.abi

    fn asm_target_spec_has_backend(spec: AsmTargetSpec) -> bool:
        spec.has_backend

    fn asm_target_spec_backend(spec: AsmTargetSpec) -> text:
        spec.backend

    me register_composite_field_metadata(name: text, fields: [HirField], symbols: SymbolTable, overwrite: bool):
        """Register name-keyed struct/class field metadata."""
        var field_names: [text] = []
        var field_type_names: [text] = []
        var field_repr_names: [text] = []
        var field_hir_types: [HirType] = []
        var field_array_element_type_names: [text] = []
        var field_elem_types: [HirType] = []
        var fi = 0
        while fi < fields.len():
            val field = fields[fi]
            field_names.push(field.name)
            var field_type_name = ""
            var field_repr_name = ""
            var field_array_element_type_name = ""
            var field_elem_type = HirType(kind: HirTypeKind.Error, span: field.span)
            var field_hir_type = HirType(kind: HirTypeKind.Error, span: field.span)
            if field.type_ != nil:
                field_hir_type = field.type_
                match field.type_.kind:
                    case Str:
                        field_repr_name = "str"
                    case Named(field_type_sym, _):
                        val field_type_symbol = symbols.get_symbol_raw(field_type_sym.id)
                        if field_type_symbol.?:
                            field_type_name = field_type_symbol.name
                    case Array(field_element_type, _):
                        field_array_element_type_name = "__runtime_array__"
                        # Bug (native_class_array_field_mutation_segfault /
                        # native_bool_array_element_interpolation_special_garbage,
                        # 2026-07-17): field_array_element_type_name above
                        # only preserves a NAME (this sentinel, or a
                        # struct/class symbol name) -- not enough to tell a
                        # primitive bool/text/i64/f64 element apart from any
                        # other, so a primitive-element array field's reads
                        # still decoded as raw i64 downstream (bool printed
                        # as its tag int; text printed as its raw heap-handle
                        # number). Keep the full declared element HirType too
                        # so the Field-access lowering can build the correct
                        # primitive MIR type for the field-read result,
                        # matching the class of bug commit 4539b364955 fixed
                        # for split()-produced arrays.
                        field_elem_type = field_element_type
                        match field_element_type.kind:
                            case Named(field_element_sym, _):
                                val field_element_symbol = symbols.get_symbol_raw(field_element_sym.id)
                                if field_element_symbol.?:
                                    field_array_element_type_name = field_element_symbol.name
                            case _: ()
                    case Slice(field_slice_element_type):
                        field_array_element_type_name = "__runtime_array__"
                        field_elem_type = field_slice_element_type
                        match field_slice_element_type.kind:
                            case Named(field_slice_element_sym, _):
                                val field_slice_element_symbol = symbols.get_symbol_raw(field_slice_element_sym.id)
                                if field_slice_element_symbol.?:
                                    field_array_element_type_name = field_slice_element_symbol.name
                            case _: ()
                    case _: ()
            field_type_names.push(field_type_name)
            field_repr_names.push(field_repr_name)
            field_hir_types.push(field_hir_type)
            field_array_element_type_names.push(field_array_element_type_name)
            field_elem_types.push(field_elem_type)
            fi = fi + 1
        if overwrite or not self.struct_field_order.has(name):
            self.struct_field_order[name] = field_names
        if overwrite or not self.struct_field_type_name.has(name):
            self.struct_field_type_name[name] = field_type_names
        if overwrite or not self.struct_field_repr_name.has(name):
            self.struct_field_repr_name[name] = field_repr_names
        if overwrite or not self.struct_field_hir_type.has(name):
            self.struct_field_hir_type[name] = field_hir_types
        if overwrite or not self.struct_field_array_element_type_name.has(name):
            self.struct_field_array_element_type_name[name] = field_array_element_type_names
        if overwrite or not self.struct_field_array_elem_type.has(name):
            self.struct_field_array_elem_type[name] = field_elem_types

    me prescan_module_struct_names(module: HirModule):
        """Cross-module struct/class-name prepass (field-index SEGV).

        Entry-closure lowering iterates modules on ONE shared MirLowering,
        and the ENTRY module is lowered BEFORE the dependency modules it
        imports. A field read on an imported struct value (`state.driver`
        where DisplayState lives in another module) therefore found nothing
        in struct_field_order — the provider module's structs had not been
        registered yet — and resolve_field_index silently fell back to
        field index 0, reading `frame_id` as the `driver` pointer (SIGSEGV
        at address 7). Callers that loop several HIR modules over one
        MirLowering must call this for EVERY module before lowering ANY of
        them, so imported struct layouts resolve regardless of lowering
        order.

        NAME-keyed maps only: field_map is keyed by per-module numeric
        SymbolIds which collide across modules (each module has its own
        SymbolTable), so it must never be filled cross-module. Existing
        entries are kept (first module wins on a name collision); the
        module's own registration in lower_module still overwrites
        unconditionally at lowering time, so a module's local definition
        always shadows an imported same-name struct while that module is
        being lowered.

        Also derives struct_field_type_name from the DECLARED field types
        (`driver: FramebufferDriver`), so chained access off an imported
        nested struct (`state.driver.width`, bug #166 mechanism) resolves
        too — the construct-site prescan that normally fills that map runs
        per-module and hits the same ordering gap."""
        val prescan_struct_values = module.structs.values()
        var psi = 0
        while psi < prescan_struct_values.len():
            val struct_def = prescan_struct_values[psi]
            # register_composite_field_metadata (above) now also captures
            # each field's declared array ELEMENT HirType into
            # struct_field_array_elem_type, so this call alone covers both
            # the struct-name/repr bookkeeping and the primitive-element
            # bool/text decode fix (native_class_array_field_mutation_segfault
            # / native_bool_array_element_interpolation_special_garbage,
            # 2026-07-17) -- no separate inline loop needed here.
            self.register_composite_field_metadata(struct_def.name, struct_def.fields, module.symbols, false)
            psi = psi + 1
        val prescan_class_values = module.classes.values()
        psi = 0
        while psi < prescan_class_values.len():
            val class_def = prescan_class_values[psi]
            self.register_composite_field_metadata(class_def.name, class_def.fields, module.symbols, false)
            psi = psi + 1

    me lower_module(module: HirModule) -> MirModule:
        """Lower HIR module to MIR."""
        var function_names: [text] = []
        for func in module.functions.values():
            function_names.push(func.name)
        self.current_function_names = function_names
        # Cross-module prescans keep the first definition. The module being
        # lowered is authoritative for its own same-name struct/class.
        val local_struct_values = module.structs.values()
        var local_meta_i = 0
        while local_meta_i < local_struct_values.len():
            val struct_def = local_struct_values[local_meta_i]
            self.register_composite_field_metadata(struct_def.name, struct_def.fields, module.symbols, true)
            local_meta_i = local_meta_i + 1
        val local_class_values = module.classes.values()
        local_meta_i = 0
        while local_meta_i < local_class_values.len():
            val class_def = local_class_values[local_meta_i]
            self.register_composite_field_metadata(class_def.name, class_def.fields, module.symbols, true)
            local_meta_i = local_meta_i + 1
        # Entry-closure lowering reuses one MirLowering while replacing its
        # active SymbolTable for every module. Method SymbolIds are therefore
        # module-local state and must not survive that boundary.
        self.struct_method_syms = {}
        self.struct_method_ambiguous = {}
        self.struct_method_return_names = {}
        self.struct_method_return_is_array = {}
        val bootstrap_mode = (mir_lower_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1"
        val bootstrap_trace = bootstrap_mode and mir_lower_trace_enabled()
        if bootstrap_trace:
            print "[mir-lower] lower_module:start module={module.name} functions={module.functions.len()}"
        # Copy-modify-reassign: nested field mutations don't propagate in interpreter
        var builder = self.builder
        if bootstrap_trace:
            print "[mir-lower] builder"
        var builder_module = builder.module
        if bootstrap_trace:
            print "[mir-lower] builder-module"
        if not bootstrap_mode:
            builder_module.name = module.name
        # Bug (entry-MIR duplication for __init__ re-export shims,
        # native_build_entry_mir_duplication_2026-07-13): callers that lower
        # several HIR modules in a loop on ONE shared MirLowering instance
        # (driver_pipeline.spl's --entry-closure `direct_lowering` loop, and
        # the whole-hir_modules fallback loop) reuse `self.builder` — and
        # this method used to mutate `builder_module.functions/statics/
        # constants/types` IN PLACE without ever clearing them first. A
        # module with no functions/types of its own (a pure `export use`
        # re-export shim, e.g. compiler.driver's __init__.spl) would then
        # silently inherit whatever the PREVIOUS module in the loop had
        # accumulated in the shared builder, since nothing in that call
        # added anything new to overwrite it. Observed as
        # object.compiler.driver.mod.o containing app.cli.bootstrap_main's
        # entire function set (duplicate symbol definitions at link time).
        # Reset the OUTPUT module body per call so `lower_module` always
        # returns a module scoped to the HIR module just passed in,
        # regardless of what a shared builder carried over from a prior
        # call. Single-shot callers (a fresh MirLowering per call) are
        # unaffected since these dicts already start empty for them.
        builder_module.functions = {}
        builder_module.statics = {}
        builder_module.constants = {}
        builder_module.types = {}
        if bootstrap_trace:
            print "[mir-lower] builder-name"
        builder.module = builder_module
        if bootstrap_trace:
            print "[mir-lower] builder-assign"
        self.builder = builder
        if not bootstrap_mode:
            self.enum_runtime_id_index = {}
        if bootstrap_trace:
            print "[mir-lower] builder-done"

        if bootstrap_mode:
            if bootstrap_trace:
                print "[mir-lower] fn-list:start"
            bootstrap_mir_functions_reset()
            val bootstrap_function_keys = module.functions.keys()
            val bootstrap_function_count = bootstrap_function_keys.len()
            if bootstrap_trace:
                print "[mir-lower] functions:count {bootstrap_function_count}"
            var bootstrap_fni = 0
            while bootstrap_fni < bootstrap_function_count:
                if bootstrap_trace:
                    print "[mir-lower] function-index {bootstrap_fni}"
                val fn_sym = bootstrap_function_keys[bootstrap_fni]
                if bootstrap_trace:
                    print "[mir-lower] function-symbol"
                val fn_ = self.hir_module_function(module, fn_sym)
                if bootstrap_trace:
                    print "[mir-lower] function-loaded"
                if not self.hir_function_is_extern(fn_):
                    if bootstrap_trace:
                        print "[mir-lower] function:start {fn_.name}"
                    val mir_fn = self.lower_function(fn_)
                    bootstrap_mir_functions_add(fn_.name, mir_fn)
                    var bldr = self.builder
                    var bldr_module = bldr.module
                    var functions = bldr_module.functions
                    functions[mir_fn.symbol] = mir_fn
                    bldr_module.functions = functions
                    bldr.module = bldr_module
                    self.builder = bldr
                    if bootstrap_trace:
                        print "[mir-lower] function:added"
                bootstrap_fni = bootstrap_fni + 1
            if bootstrap_trace:
                print "[mir-lower] lower_module:done"
            return self.builder.module

        # Build field map from struct and class definitions
        # (use while loops - for-in broken in compiled native code)
        val struct_values = module.structs.values()
        var si = 0
        while si < struct_values.len():
            val struct_def = struct_values[si]
            val sym_id = struct_def.symbol
            var field_names: [text] = []
            var field_has_default: [bool] = []
            var field_default_expr: [HirExpr] = []
            var fi = 0
            while fi < struct_def.fields.len():
                field_names.push(struct_def.fields[fi].name)
                field_has_default.push(struct_def.fields[fi].has_default)
                field_default_expr.push(struct_def.fields[fi].default)
                fi = fi + 1
            self.field_map[self.symbol_id_value(sym_id)] = field_names
            self.struct_field_has_default[struct_def.name] = field_has_default
            self.struct_field_default_expr[struct_def.name] = field_default_expr
            # Name-keyed struct field order: lower_call reclassifies a
            # `Point(x:3,y:4)` paren-constructor Call into aggregate construction
            # by looking up the callee name here (structs only, not classes).
            self.struct_field_order[struct_def.name] = field_names
            si = si + 1

        # Build enum variant-index registry (enum NAME -> ordered variant names).
        # A variant's index is its runtime discriminant. Name-keyed like structs.
        val enum_values = module.enums.values()
        var ei = 0
        while ei < enum_values.len():
            val enum_def = enum_values[ei]
            var variant_names: [text] = []
            var vi = 0
            while vi < enum_def.variants.len():
                variant_names.push(enum_def.variants[vi].name)
                vi = vi + 1
            self.enum_variant_index[enum_def.name] = variant_names
            self.register_enum_runtime_id(enum_def)
            ei = ei + 1

        # Register the built-in Result enum so bare-variant construction
        # (`Ok(v)` / `Err(e)`) and `match r: case Ok(v)/Err(e)` resolve the same
        # discriminants (Ok=0, Err=1) as user enums. Result is not carried in
        # module.enums, so without this the variants lowered as indirect calls
        # to an undefined callee. Skip if user code shadows the name.
        if not self.enum_variant_index.has("Result"):
            self.enum_variant_index["Result"] = ["Ok", "Err"]
        if not self.enum_runtime_id_index.has("Result"):
            self.enum_runtime_id_index["Result"] = 0

        # Register the built-in Option enum so bare-variant construction
        # (`Some(v)` / `None`) and `match o: case Some(v)/None` resolve the same
        # discriminants (Some=0, None=1, matching the stdlib `enum Option`
        # declaration order). Option is not carried in module.enums. Skip if
        # user code shadows the name.
        if not self.enum_variant_index.has("Option"):
            self.enum_variant_index["Option"] = ["Some", "None"]
        if not self.enum_runtime_id_index.has("Option"):
            self.enum_runtime_id_index["Option"] = 1

        # Build (struct NAME, method name) -> method SymbolId lookup from
        # module.impls. Bug #138/#156: a receiver with no HIR type inference
        # (receiver.type_ nil) leaves MethodResolution.Unresolved for every
        # user struct instance method on the native-build path (try_
        # instance_method requires a typed receiver). The Unresolved fallback
        # in method_calls_literals.spl recovers the receiver's struct NAME
        # from struct_value_syms and looks it up here to dispatch the real
        # method instead of failing.
        var static_method_symbol_ids: Dict<i64, bool> = {}
        val module_fn_values = module.functions.values()
        var mfi = 0
        while mfi < module_fn_values.len():
            # module.functions also contains impl methods; retain their static
            # marker for the separate static receiver lookup below.
            val module_fn = module_fn_values[mfi]
            if module_fn.is_static:
                static_method_symbol_ids[self.symbol_id_value(module_fn.symbol)] = true
            mfi = mfi + 1

        var impl_mi = 0
        while impl_mi < module.impls.len():
            val impl_def = module.impls[impl_mi]
            var impl_type_name = ""
            match impl_def.type_.kind:
                case Named(impl_type_sym, _):
                    val impl_type_symbol = self.symbols.get_symbol_raw(impl_type_sym.id)
                    if impl_type_symbol.?:
                        impl_type_name = impl_type_symbol.name
                case _: ()
            if impl_type_name != "":
                val impl_method_names = impl_def.methods.keys()
                var mni = 0
                while mni < impl_method_names.len():
                    val impl_method_name = impl_method_names[mni]
                    val impl_method_id = impl_def.methods[impl_method_name]
                    val impl_method_key = "{impl_type_name}::{impl_method_name}"
                    self.struct_method_syms[impl_method_key] = impl_method_id
                    val impl_method_is_static = static_method_symbol_ids.has(self.symbol_id_value(impl_method_id))
                    if impl_method_is_static:
                        self.struct_method_syms["static::{impl_method_key}"] = impl_method_id
                    # Methchain lane: thread the method's declared return-type
                    # struct name (resolved during HIR lowering -- see
                    # HirImpl.method_return_struct_names doc comment) so a
                    # chained `.m2()` on this call's RESULT can resolve too
                    # (consumed in method_calls_literals.spl's Unresolved arm).
                    val impl_ret_struct_name = impl_def.method_return_struct_names.get(impl_method_name)
                    if impl_ret_struct_name != nil and impl_ret_struct_name != "":
                        self.struct_method_return_names["{impl_type_name}::{impl_method_name}"] = impl_ret_struct_name
                    # Methchain lane construct #5 (`obj.items()[0]`): thread
                    # whether the method returns an Array/Slice so the call
                    # result registers into runtime_array_locals (see
                    # HirImpl.method_return_is_array doc comment).
                    val impl_ret_is_array = impl_def.method_return_is_array.get(impl_method_name)
                    if impl_ret_is_array != nil and impl_ret_is_array:
                        self.struct_method_return_is_array["{impl_type_name}::{impl_method_name}"] = true
                    mni = mni + 1
            impl_mi = impl_mi + 1

        val class_values = module.classes.values()
        var ci = 0
        while ci < class_values.len():
            val class_def = class_values[ci]
            val sym_id = class_def.symbol
            var field_names: [text] = []
            var field_has_default: [bool] = []
            var field_default_expr: [HirExpr] = []
            var fi = 0
            while fi < class_def.fields.len():
                field_names.push(class_def.fields[fi].name)
                field_has_default.push(class_def.fields[fi].has_default)
                field_default_expr.push(class_def.fields[fi].default)
                fi = fi + 1
            self.field_map[self.symbol_id_value(sym_id)] = field_names
            self.struct_field_has_default[class_def.name] = field_has_default
            self.struct_field_default_expr[class_def.name] = field_default_expr
            # Name-keyed, same as the struct loop above: `lower_call`'s
            # paren-constructor reclassification and struct_value_syms'
            # field/method-dispatch bookkeeping both key off
            # struct_field_order by NAME regardless of struct/class, so a
            # class instance needs an entry here too (module_assembly.spl
            # now routes `class` decls into `module.classes` instead of
            # `module.structs` -- see bug
            # s19_class_free_fn_mutation_dropped_native_2026-07-17). The
            # separate `class_type_names` set below is what lets
            # function_lowering.spl's param binding tell a class apart from a
            # real struct once both satisfy struct_field_order.
            self.struct_field_order[class_def.name] = field_names
            self.class_type_names[class_def.name] = true
            ci = ci + 1

        val bitfield_values = module.bitfields.values()
        var bi = 0
        while bi < bitfield_values.len():
            val bitfield_def = bitfield_values[bi]
            val sym_id = bitfield_def.symbol
            # Key by direct .id access: symbol_id_value's match-destructure
            # of SymbolId returns nil in the interpreter, silently keying
            # the whole map by nil.
            self.bitfield_map[sym_id.id] = self.hir_bitfield_fields(bitfield_def)
            bi = bi + 1

        # Lower type definitions so headers/export wrappers can consume real MIR types.
        val struct_type_values = module.structs.values()
        var sti = 0
        while sti < struct_type_values.len():
            self.lower_struct_type(struct_type_values[sti])
            sti = sti + 1

        val class_type_values = module.classes.values()
        var cti = 0
        while cti < class_type_values.len():
            self.lower_class_type(class_type_values[cti])
            cti = cti + 1

        # Lower module-level constants/statics BEFORE any function body is
        # lowered (mutglobal2 lane, see scratchpad/mutglobal_plan.md +
        # scratchpad/mutglobal2 report). This loop used to run AFTER the
        # function-lowering loop below, which meant `self.global_static_ids`/
        # `self.global_const_ids` (populated by `lower_const`,
        # function_lowering.spl -- consulted by expr_dispatch.spl's
        # NamedVar/Var read hook and mir_lowering_stmts.spl's
        # lower_assign_var write hook to recognize a module-level `var`/`val`
        # reference) were still empty while every function body was being
        # lowered, so a real reference to a module global inside ANY function
        # would still hit the "undefined variable" fallback. Moving this
        # loop earlier makes the module-global registry available to every
        # function body lowered below, module-wide (order-independent, same
        # rationale as the struct/class/enum prep above and the prescan
        # pass right after this).
        val const_vals = module.constants.values()
        var coni = 0
        while coni < const_vals.len():
            self.lower_const(const_vals[coni])
            self.lower_static(const_vals[coni])
            coni = coni + 1

        self.lower_runtime_module_initializers(module, const_vals)

        # Order-independent pre-pass: walk every function body (read-only,
        # no MIR emitted) to seed struct_field_type_name from its real
        # construction sites BEFORE any function is actually lowered. See
        # prescan_expr_for_struct_types's own comment for the nondeterministic
        # bug this closes: a nested struct field's chained access
        # (`q.inner.y` where `q = outer()` and `outer`'s OWN body constructs
        # `Q(inner: make(3), ...)`) previously depended on whether
        # module.functions happened to lower `outer` before `main` --
        # `module.functions.values()` iteration order is not guaranteed
        # stable, so `q.inner.y` nondeterministically read field 0 (`x`)
        # instead of field 1 (`y`) on runs where the populating function
        # (`outer`) had not yet been visited by the real lowering loop below.
        val prescan_fn_values = module.functions.values()
        var psi = 0
        while psi < prescan_fn_values.len():
            if not prescan_fn_values[psi].is_extern:
                self.prescan_block_for_struct_types(prescan_fn_values[psi].body)
            psi = psi + 1

        # Lower functions (skip extern declarations - they have no body)
        val fn_values = module.functions.values()
        if bootstrap_trace:
            print "[mir-lower] function-keys"
        var fni = 0
        while fni < fn_values.len():
            val fn_ = fn_values[fni]
            if self.hir_function_is_extern(fn_):
                fni = fni + 1
                # skip extern functions
            else:
                if bootstrap_trace:
                    print "[mir-lower] function:start"
                val mir_fn = self.lower_function(fn_)
                # Copy-modify-reassign: nested field mutations don't propagate in the
                # bootstrap interpreter, so update builder.module.functions explicitly.
                var bldr = self.builder
                var bldr_module = bldr.module
                var functions = bldr_module.functions
                functions[mir_fn.symbol] = mir_fn
                bldr_module.functions = functions
                bldr.module = bldr_module
                self.builder = bldr
                if bootstrap_trace:
                    print "[mir-lower] function:added"
                fni = fni + 1

        if bootstrap_trace:
            print "[mir-lower] lower_module:done"
        self.builder.module

    # mutglobal lane (module-level `var` mutation, see
    # scratchpad/mutglobal_plan.md): `lower_const` (function_lowering.spl,
    # owned by another lane) already lowers EVERY module-level HIR binding
    # (`val` and `var`) into `MirModule.constants` unconditionally -- that
    # path is untouched here. `MirModule.statics`/`MirStatic` previously had
    # no producer anywhere in the compiler (pure dead scaffolding: the field
    # existed on `MirModule`/`MirStatic` but nothing ever wrote to it and no
    # backend ever read it). This gives module-level `var` bindings (the
    # MUTABLE subset, `const_.is_mutable`) a real MIR-level representation
    # distinct from the constant-folded `.constants` entry, so a backend can
    # emit genuine `@name = global ...` storage for them instead of only
    # ever seeing an inlinable compile-time value. Does not remove or alter
    # anything already in `.constants` -- purely additive, so any existing
    # consumer of `.constants` (e.g. the VHDL backend) is unaffected.
    #
    # NOTE (gap, see scratchpad/mutglobal_plan.md): nothing downstream of
    # this MIR-level population yet READS a global's address for an
    # identifier reference (MIR expr lowering's `NamedVar` case only
    # consults the per-function `local_map`) or WRITES to one for a plain
    # `name = expr` assignment target (statement lowering only knows about
    # per-function SSA locals) -- both of those hooks live in files owned by
    # other lanes (`_MirLoweringExpr/expr_dispatch.spl`,
    # `mir_lowering_stmts.spl`/`var_reassign_ssa.spl`). This method makes
    # `MirModule.statics` real and populated; wiring an actual read/write
    # through it is the documented follow-up.
    me lower_static(const_: HirConst):
        """Lower a module-level HIR binding that needs storage into a MIR
        static. Literal immutable bindings remain compile-time constants;
        non-folded bindings receive runtime initialization."""
        val folded = self.lower_const_expr(const_.value)
        if folded.?:
            if not const_.is_mutable:
                return
        elif not runtime_module_initializer_supported(const_):
            return
        val static_type = match const_.value.kind:
            case StringLit(_, interps):
                if string_literal_has_runtime_interpolations(interps):
                    MirType(kind: MirTypeKind.Opaque("str"))
                else:
                    self.lower_type(const_.type_)
            case _:
                match const_.type_.kind:
                    case Infer(_, _): MirType.i64()
                    case _: self.lower_type(const_.type_)
        var init_const: MirConstant? = nil
        if val const_value = folded:
            init_const = Some(MirConstant(
                symbol: const_.symbol,
                name: const_.name,
                type_: static_type,
                value: const_value
            ))
        var bldr = self.builder
        var module_ = bldr.module
        var statics = module_.statics
        statics[const_.symbol] = MirStatic(
            symbol: const_.symbol,
            name: const_.name,
            type_: static_type,
            init: init_const,
            is_mutable: const_.is_mutable
        )
        module_.statics = statics
        bldr.module = module_
        self.builder = bldr

    me lower_runtime_module_initializers(module: HirModule, consts: [HirConst]):
        val dynamic = runtime_module_initializers_in_declaration_order(consts)
        if dynamic.len() == 0:
            return

        val module_name = module.name.replace(".", "_").replace("/", "_").replace("-", "_")
        val init_name = "__module_init_{module_name}_dynamic"
        var symbols = self.symbols
        val init_symbol = symbols.define(init_name, SymbolKind.Function, nil, Span.empty(), Visibility.Private, false, nil)
        self.symbols = symbols

        self.local_map = {}
        self.local_hir_types = {}
        self.runtime_array_locals = {}
        self.runtime_dict_locals = {}
        self.runtime_elem_value_type = {}
        self.runtime_value_locals = {}
        self.option_value_locals = {}
        self.nil_locals = {}

        val signature = MirSignature(params: [], return_type: MirType.unit(), is_variadic: false)
        var bldr = self.builder
        bldr.begin_function(init_symbol, init_name, signature, Span.empty())
        self.builder = bldr

        for const_ in dynamic:
            val value = self.lower_expr(const_.value)
            val value_type = self.lookup_local_type(value)
            var value_builder = self.builder
            var value_module = value_builder.module
            var statics = value_module.statics
            statics[const_.symbol] = MirStatic(
                symbol: const_.symbol,
                name: const_.name,
                type_: value_type,
                init: nil,
                is_mutable: const_.is_mutable
            )
            value_module.statics = statics
            value_builder.module = value_module
            value_builder.emit(MirInst(kind: MirInstKind.StoreGlobal(const_.symbol, mir_operand_copy(value)), span: Some(const_.span)))
            self.builder = value_builder

        var finish = self.builder
        finish.terminate_return(nil)
        val init_function = finish.end_function()
        var result_module = finish.module
        var functions = result_module.functions
        functions[init_function.symbol] = init_function
        result_module.functions = functions
        finish.module = result_module
        self.builder = finish

    me lower_struct_type(struct_def: HirStruct):
        """Lower a HIR struct definition into MIR type metadata."""
        val layout_attr = if struct_def.has_layout_attr:
            struct_def.layout_attr
        else:
            layoutattr_default_()
        val layout = compute_struct_layout(struct_def.fields, layout_attr)

        var fields: [MirFieldDef] = []
        var fi = 0
        while fi < struct_def.fields.len():
            val hir_field = struct_def.fields[fi]
            val field_layout: FieldLayout = layout.fields[fi]
            val field_offset: i64 = field_layout.offset
            fields.push(MirFieldDef(
                name: hir_field.name,
                type_: self.lower_type(hir_field.type_),
                offset: field_offset,
                has_bits_attr: hir_field.has_bits_attr,
                bits_width: hir_field.bits_width
            ))
            fi = fi + 1

        var bldr = self.builder
        var module = bldr.module
        var types = module.types
        types[struct_def.symbol] = MirTypeDef(
            symbol: struct_def.symbol,
            name: struct_def.name,
            kind: MirTypeDefKind.Struct(fields),
            is_export_c: false,
            export_name: ""
        )
        module.types = types
        bldr.module = module
        self.builder = bldr

    me lower_class_type(class_def: HirClass):
        """Lower a HIR class definition into MIR type metadata."""
        val layout_attr = if class_def.has_layout_attr:
            class_def.layout_attr
        else:
            layoutattr_default_()
        val layout = compute_struct_layout(class_def.fields, layout_attr)

        var fields: [MirFieldDef] = []
        var fi = 0
        while fi < class_def.fields.len():
            val hir_field = class_def.fields[fi]
            val field_layout: FieldLayout = layout.fields[fi]
            val field_offset: i64 = field_layout.offset
            fields.push(MirFieldDef(
                name: hir_field.name,
                type_: self.lower_type(hir_field.type_),
                offset: field_offset,
                has_bits_attr: hir_field.has_bits_attr,
                bits_width: hir_field.bits_width
            ))
            fi = fi + 1

        var is_export_c = false
        var export_name = ""
        if class_def.has_export_attr:
            is_export_c = class_def.export_attr.is_export_c
            export_name = class_def.export_attr.export_name

        var bldr = self.builder
        var module = bldr.module
        var types = module.types
        types[class_def.symbol] = MirTypeDef(
            symbol: class_def.symbol,
            name: class_def.name,
            kind: MirTypeDefKind.Struct(fields),
            is_export_c: is_export_c,
            export_name: export_name
        )
        module.types = types
        bldr.module = module
        self.builder = bldr

    # ========================================================================
    # Order-independent struct_field_type_name pre-pass (see call site above)
    # ========================================================================

    me prescan_enum_owner_for_variant(name: text) -> text:
        """Which enum owns variant `name`, mirroring lower_call's own Ok/Err/
        Some/None interception plus its bare-variant enum_variant_index scan.
        "" when `name` is not a known enum variant at all (an ordinary struct
        or free-function call)."""
        if name == "Ok" or name == "Err":
            return "Result"
        if name == "Some" or name == "None":
            return "Option"
        for ename in self.enum_variant_index.keys():
            if enum_variant_disc(self.enum_variant_index[ename], name) >= 0:
                return ename
        ""

    me prescan_block_for_struct_types(block: HirBlock):
        """Read-only HIR walk over a function body (no MIR emitted): finds
        every struct-construct call reachable from `block` and records its
        nested field struct names into struct_field_type_name, regardless of
        which function this block belongs to or in what order module.functions
        happens to be visited by the real per-function lowering loop."""
        var si = 0
        while si < block.stmts.len():
            self.prescan_stmt_for_struct_types(block.stmts[si])
            si = si + 1
        if block.has:
            self.prescan_expr_for_struct_types(block.value)

    me prescan_stmt_for_struct_types(stmt: HirStmt):
        match stmt.kind:
            case Expr(expr):
                self.prescan_expr_for_struct_types(expr)
            case Let(_, _, init):
                self.prescan_expr_for_struct_types(init)
            case Assign(_, _, value):
                self.prescan_expr_for_struct_types(value)
            case Block(inner_block):
                self.prescan_block_for_struct_types(inner_block)
            case _:
                ()

    me prescan_expr_for_struct_types(expr: HirExpr) -> text:
        """Returns the struct NAME `expr` statically denotes (a direct struct
        construct, or a call to a function whose declared return type is a
        Named struct), or "" when unknown. Recurses into Call args, Return,
        Block, and If so a `return Q(inner: make(3), tag: 99)`-shaped function
        body (the exact case this pre-pass exists for) is fully covered."""
        match expr.kind:
            case Call(callee, args, _):
                var name = ""
                match callee.kind:
                    case Var(sym):
                        val s = self.symbols.get_symbol_raw(sym.id)
                        if s.?: name = s.name
                    case NamedVar(_, n):
                        name = n
                    case _:
                        ()
                if name != "":
                    val owner_enum = self.prescan_enum_owner_for_variant(name)
                    if owner_enum != "" and args.len() == 1:
                        # Enum/Result payload chain fix: `Ok(make(3))` /
                        # `Circle(make_point())` constructs a payload that may
                        # itself be a struct VALUE. Record
                        # "{owner_enum}::{name}" -> that struct's NAME here too
                        # (same map lower_enum_construct_named/lower_enum_lit
                        # populate at real-lowering time), order-independently,
                        # so `case Ok(p): print(p.y)` resolves correctly no
                        # matter which function constructs the payload relative
                        # to which function matches on it.
                        val nested_payload = self.prescan_expr_for_struct_types(args[0].value)
                        if nested_payload != "":
                            self.enum_payload_struct_names["{owner_enum}::{name}"] = nested_payload
                        return ""
                if name != "" and self.struct_field_order.has(name):
                    val field_names = self.struct_field_order[name]
                    var field_type_names: [text] = []
                    var fi = 0
                    while fi < field_names.len():
                        val want = field_names[fi]
                        var chosen_idx = if fi < args.len(): fi else: -1
                        var ai = 0
                        while ai < args.len():
                            if args[ai].has_name and args[ai].name == want:
                                chosen_idx = ai
                            ai = ai + 1
                        var nested = ""
                        if chosen_idx >= 0 and chosen_idx < args.len():
                            nested = self.prescan_expr_for_struct_types(args[chosen_idx].value)
                        field_type_names.push(nested)
                        fi = fi + 1
                    if not self.struct_field_type_name.has(name):
                        self.struct_field_type_name[name] = field_type_names
                    else:
                        val prev = self.struct_field_type_name[name]
                        var merged: [text] = []
                        var mi = 0
                        while mi < field_type_names.len():
                            var name_i = field_type_names[mi]
                            if name_i == "" and mi < prev.len():
                                name_i = prev[mi]
                            merged.push(name_i)
                            mi = mi + 1
                        self.struct_field_type_name[name] = merged
                    return name
                # Not a direct struct construct: maybe a call to a known
                # function whose declared return type is a Named struct
                # (mirrors resolved_call_return_type's own symbol lookup).
                var callee_symbol: SymbolId? = nil
                match callee.kind:
                    case Var(sym2):
                        callee_symbol = Some(sym2)
                    case NamedVar(sym2, _):
                        callee_symbol = Some(sym2)
                    case _:
                        ()
                if val cs = callee_symbol:
                    val fn_sym = self.symbols.get_symbol_raw(cs.id)
                    if fn_sym.?:
                        if val fn_type = fn_sym.type_:
                            match fn_type.kind:
                                case HirTypeKind.Function(_, ret, _):
                                    match ret.kind:
                                        case Named(ret_sym, _):
                                            val ret_symbol = self.symbols.get_symbol_raw(ret_sym.id)
                                            if ret_symbol.?:
                                                return ret_symbol.name
                                        case _:
                                            ()
                                case _:
                                    ()
                ""
            case Return(value):
                if val rv = value:
                    self.prescan_expr_for_struct_types(rv)
                else:
                    ""
            case Block(inner_block):
                self.prescan_block_for_struct_types(inner_block)
                ""
            case If(cond, then_, else_):
                self.prescan_expr_for_struct_types(cond)
                self.prescan_block_for_struct_types(then_)
                if val eb = else_:
                    self.prescan_block_for_struct_types(eb)
                ""
            case MethodCall(mc_receiver, mc_method, mc_args, _):
                # Dot-qualified enum construction (`Shape.Circle(make(9))`)
                # actually arrives as a MethodCall (receiver=Shape,
                # method=Circle), reclassified into enum construction only at
                # REAL-lowering time by method_calls_literals.spl's own
                # "receiver names a registered enum and method is one of its
                # variants" check (mirrored here) -- NOT as a distinct EnumLit
                # node. Recurse into args either way so a struct-returning
                # call passed as a plain method argument is still discovered.
                var mc_recv_enum_name = ""
                match mc_receiver.kind:
                    case Var(mc_rsym):
                        val mc_rs = self.symbols.get_symbol_raw(mc_rsym.id)
                        if mc_rs.?: mc_recv_enum_name = mc_rs.name
                    case NamedVar(_, mc_rname):
                        mc_recv_enum_name = mc_rname
                    case _:
                        ()
                var mc_is_variant = false
                if mc_recv_enum_name != "" and self.enum_variant_index.has(mc_recv_enum_name):
                    for mc_vn in self.enum_variant_index[mc_recv_enum_name]:
                        if mc_vn == mc_method:
                            mc_is_variant = true
                if mc_is_variant and mc_args.len() == 1:
                    val mc_nested = self.prescan_expr_for_struct_types(mc_args[0].value)
                    if mc_nested != "":
                        self.enum_payload_struct_names["{mc_recv_enum_name}::{mc_method}"] = mc_nested
                else:
                    var mc_ai = 0
                    while mc_ai < mc_args.len():
                        self.prescan_expr_for_struct_types(mc_args[mc_ai].value)
                        mc_ai = mc_ai + 1
                ""
            case EnumLit(type_, variant, payload):
                # Dot-qualified enum construction (`Shape.Circle(make(9))`)
                # arrives as a distinct HirExprKind.EnumLit node, NOT a Call --
                # the Call-shaped enum-owner check above never sees this shape
                # at all. Same struct-value chain fix, mirrors lower_enum_lit's
                # own single-value Tuple payload handling.
                var elit_enum_name = ""
                match type_.kind:
                    case Named(elit_sym, _):
                        val elit_s = self.symbols.get_symbol_raw(elit_sym.id)
                        if elit_s.?: elit_enum_name = elit_s.name
                    case _:
                        ()
                if val elit_payload = payload:
                    match elit_payload:
                        case Tuple(elit_values):
                            if elit_values.len() == 1 and elit_enum_name != "":
                                val elit_nested = self.prescan_expr_for_struct_types(elit_values[0])
                                if elit_nested != "":
                                    self.enum_payload_struct_names["{elit_enum_name}::{variant}"] = elit_nested
                        case _:
                            ()
                ""
            case _:
                ""
