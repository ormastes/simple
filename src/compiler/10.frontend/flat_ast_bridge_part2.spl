# Part 2 of src/compiler/10.frontend/flat_ast_bridge.spl
use compiler.frontend.flat_ast_bridge.*
# Flat AST Bridge
#
# Converts the core parser's flat, index-based AST into the richer frontend
# Module shape expected by HIR lowering. This is used as the bootstrap-safe
# frontend path when the newer parser surface is unavailable.

use compiler.core.parser.{parser_has_errors, parser_get_errors, parser_init_with_path}
use compiler.core.parser_decls.{parse_module_body}
use compiler.core.ast.*
use compiler.core.ast.{decl_get_body, decl_get_field_bits, decl_get_field_defaults, decl_get_field_types, decl_get_fields}
use compiler.core.ast.{decl_get_imports, decl_get_is_comptime, decl_get_is_lazy, decl_get_name, decl_get_param_names}
use compiler.core.ast.{decl_get_param_types, decl_get_ret_type, decl_get_visibility_text, module_decl_at, module_decl_count_get}
use compiler.core.ast.{decl_is_packed}
use compiler.core.ast_expr.*
use compiler.core.ast_stmt.*
use compiler.core.ast_stmt.{STMT_GPU_LAUNCH, stmt_get_gpu_grid, stmt_get_gpu_block}
use compiler.core.types.{TYPE_VOID, TYPE_BOOL, TYPE_I64, TYPE_F64, TYPE_TEXT, TYPE_ARRAY_I64, TYPE_ARRAY_TEXT, TYPE_ARRAY_BOOL, TYPE_ARRAY_ANY, TYPE_ANY, TYPE_NIL}
use compiler.core.types.{TYPE_DICT, TYPE_FN, TYPE_OPTION, TYPE_OPTION_I64, TYPE_OPTION_F64, TYPE_OPTION_TEXT, TYPE_OPTION_BOOL}
use compiler.core.types.{TYPE_RESULT, TYPE_FUTURE, TYPE_POLL, TYPE_TASK, TYPE_GENERIC_ERASED}
use compiler.core.types.{TYPE_UNION, TYPE_INTERSECTION, TYPE_REFINEMENT, TYPE_NAMED_BASE, TYPE_UNION_BASE, type_tag_name, int_to_str}
use compiler.frontend.parser_types.{Module as FrontendModule, Function as ParserFunction}
use compiler.frontend.parser_types.*
use compiler.frontend.parser_types_expr.*
use compiler.frontend.parser_types_expr.{ComprehensionClause, ComprehensionKind, GpuLaunchConfig}
use compiler.frontend.lexer_types.Span
use compiler.common.dependency.visibility.{Visibility}
use std.nogc_sync_mut.io.process_ops.{eprint}
extern fn rt_env_get(key: text) -> text

fn flat_decl_tag_text(idx: i64) -> text:
    rt_env_get("SIMPLE_BOOTSTRAP_DECL_TAG_" + int_to_str(idx))

fn flat_decl_field_text(idx: i64, field: text) -> text:
    rt_env_get("SIMPLE_BOOTSTRAP_DECL_" + int_to_str(idx) + "_" + field)

fn flat_bootstrap_enabled() -> bool:
    rt_env_get("SIMPLE_BOOTSTRAP") == "1"

fn flat_text_list_count(raw: text) -> i64:
    if raw == "":
        return 0
    var count: i64 = 1
    var i: i64 = 0
    while i < raw.len():
        if raw[i:i + 1] == "\n":
            count = count + 1
        i = i + 1
    count

fn flat_text_list_at(raw: text, target: i64) -> text:
    var start: i64 = 0
    var index: i64 = 0
    var i: i64 = 0
    while i <= raw.len():
        if i == raw.len() or raw[i:i + 1] == "\n":
            if index == target:
                return raw[start:i]
            index = index + 1
            start = i + 1
        i = i + 1
    ""

fn flat_i64_list_count(raw: text) -> i64:
    if raw == "":
        return 0
    var count: i64 = 1
    var i: i64 = 0
    while i < raw.len():
        if raw[i:i + 1] == ",":
            count = count + 1
        i = i + 1
    count

fn flat_i64_list_at(raw: text, target: i64) -> i64:
    var start: i64 = 0
    var index: i64 = 0
    var i: i64 = 0
    while i <= raw.len():
        if i == raw.len() or raw[i:i + 1] == ",":
            if index == target:
                return text_parse_int_simple(raw[start:i])
            index = index + 1
            start = i + 1
        i = i + 1
    0

fn flat_ast_to_module(path: text) -> FrontendModule:
    print "[flat-bridge] path={path}"
    if flat_bootstrap_enabled() and not flat_is_bootstrap_entry_path(path):
        return flat_empty_module(path)
    if flat_bootstrap_enabled():
        eprint("[flat-bridge] bootstrap real entry:start")
    val raw_decl_count = module_decl_count_get()
    var decl_count = raw_decl_count
    if flat_bootstrap_enabled() and raw_decl_count > 64:
        decl_count = 64
    if flat_bootstrap_enabled():
        eprint("[flat-bridge] decl_count {decl_count}")
    var functions: Dict<text, ParserFunction> = {}
    var structs: Dict<text, Struct> = {}
    var enums: Dict<text, Enum> = {}
    var constants: Dict<text, Const> = {}
    var imports: [Import] = []
    var exports: [Export] = []
    var domain_blocks: [DomainBlock] = []
    var impls: [Impl] = []
    var aop_advices: [AopAdvice] = []
    var di_bindings: [DiBinding] = []
    var arch_rules: [ArchRule] = []
    var bitfields: Dict<text, Bitfield> = {}
    val span = make_span()

    var di = 0
    while di < decl_count:
        val idx = module_decl_at(di)
        val tag_text = flat_decl_tag_text(idx)
        if flat_bootstrap_enabled():
            eprint("[flat-bridge] decl:start {di} tag {tag_text}")
            if tag_text != "1":
                di = di + 1
                eprint("[flat-bridge] decl:skip {di}")
                continue
        if tag_text == "1":
            val fn_ = convert_decl_fn(idx)
            functions[fn_.name] = fn_
        elif tag_text == "2":
            val fn_ = convert_decl_extern_fn(idx)
            functions[fn_.name] = fn_
        elif tag_text == "3":
            val s_name = decl_get_name(idx)
            val f_names = decl_get_fields(idx)
            val f_types = decl_get_field_types(idx)
            val f_bits = decl_get_field_bits(idx)
            val s_visibility = convert_decl_visibility(idx)
            var is_packed = false
            if idx < decl_is_packed.len():
                if decl_is_packed[idx] == 1:
                    is_packed = true
            if is_packed:
                var bf_fields: [BitfieldField] = []
                var fi = 0
                while fi < f_names.len():
                    var fb: i64 = -1
                    if fi < f_bits.len():
                        fb = f_bits[fi]
                    var bf_bits: i64 = 0
                    if fb > 0:
                        bf_bits = fb
                    bf_fields.push(BitfieldField(
                        name: f_names[fi],
                        has_type_: true,
                        type_: Type(kind: TypeKind.Infer, span: span),
                        has_bits: fb > 0,
                        bits: bf_bits,
                        is_reserved: false,
                        span: span
                    ))
                    fi = fi + 1
                bitfields[s_name] = Bitfield(
                    name: s_name,
                    backing_type: Type(kind: TypeKind.Infer, span: span),
                    fields: bf_fields,
                    visibility: s_visibility,
                    is_public: s_visibility.is_public(),
                    has_doc_comment: false,
                    doc_comment: "",
                    attributes: [],
                    span: span
                )
            else:
                var fields: [Field] = []
                var fi = 0
                while fi < f_names.len():
                    val ft = Type(kind: TypeKind.Infer, span: span)
                    val fd = nil
                    var fb: i64 = -1
                    if fi < f_bits.len():
                        fb = f_bits[fi]
                    var field_default = Expr(kind: ExprKind.NilLit, span: span)
                    if fd != nil:
                        field_default = fd
                    var field_bits: i64 = 0
                    if fb > 0:
                        field_bits = fb
                    fields.push(Field(
                        f_names[fi],
                        ft,
                        fd != nil,
                        field_default,
                        Visibility.Private,
                        false,
                        false,
                        fb > 0,
                        field_bits,
                        false,
                        0,
                        span
                    ))
                    fi = fi + 1
                structs[s_name] = Struct(
                    name: s_name,
                    type_params: [],
                    fields: fields,
                    visibility: s_visibility,
                    is_public: s_visibility.is_public(),
                    attributes: [],
                    has_doc_comment: false,
                    doc_comment: "",
                    span: span
                )
        elif tag_text == "8":
            val e_name = decl_get_name(idx)
            enums[e_name] = Enum(
                name: e_name,
                type_params: [],
                variants: [],
                visibility: convert_decl_visibility(idx),
                is_public: convert_decl_visibility(idx).is_public(),
                has_doc_comment: false,
                doc_comment: "",
                span: span
            )
        elif tag_text == "9":
            val target_name = decl_get_name(idx)
            val method_ids = decl_get_body(idx)
            var methods: Dict<text, ParserFunction> = {}
            var mi = 0
            while mi < method_ids.len():
                val method_id = method_ids[mi]
                val fn_ = convert_decl_method_fn(method_id, target_name)
                methods[fn_.name] = fn_
                mi = mi + 1
            impls.push(Impl(
                type_: Type(kind: TypeKind.Named(target_name, []), span: span),
                has_trait_: false,
                trait_: Type(kind: TypeKind.Infer, span: span),
                type_params: [],
                where_clause: [],
                methods: methods,
                assoc_types: [],
                span: span
            ))
        elif tag_text == "4" or tag_text == "5":
            val c_name = decl_get_name(idx)
            val body = decl_get_body(idx)
            var init = Expr(kind: ExprKind.NilLit, span: span)
            if body.len() > 0:
                init = convert_flat_expr(body[0])
            if c_name.starts_with("_expr_"):
                match init.kind:
                    case ExprKind.Call(callee, args):
                        match callee.kind:
                            case ExprKind.Ident(helper_name):
                                if helper_name == "__domain_block" and args.len() >= 2:
                                    match args[0].value.kind:
                                        case ExprKind.StringLit(kind, _):
                                            match args[1].value.kind:
                                                case ExprKind.StringLit(payload, _):
                                                    domain_blocks.push(DomainBlock(kind, payload, "module", span))
                                                    di = di + 1
                                                    continue
                                                case _:
                                                    pass
                                        case _:
                                            pass
                            case _:
                                pass
                    case _:
                        pass
            constants[c_name] = Const(
                name: c_name,
                has_type_: false,
                type_: Type(kind: TypeKind.Infer, span: span),
                value: init,
                is_mutable: tag_text == "5",
                visibility: convert_decl_visibility(idx),
                is_public: convert_decl_visibility(idx).is_public(),
                is_volatile: false,
                has_fixed_address: false,
                fixed_address: 0,
                span: span
            )
        elif tag_text == "6":
            val module_path = decl_get_name(idx)
            val items_list = decl_get_imports(idx)
            var import_items: [ImportItem] = []
            var ii = 0
            while ii < items_list.len():
                import_items.push(ImportItem(
                    name: items_list[ii],
                    has_alias: false,
                    alias: ""
                ))
                ii = ii + 1
            imports.push(Import(
                module: module_path,
                items: import_items,
                is_lazy: decl_get_is_lazy(idx) != 0,
                span: span
            ))
        elif tag_text == "7":
            val export_items = decl_get_imports(idx)
            exports.push(Export(items: export_items, span: span))
        elif tag_text == "14":
            val aop_data = decl_get_imports(idx)
            var aop_pointcut = ""
            if aop_data.len() > 0:
                aop_pointcut = aop_data[0]
            var aop_form = "before"
            if aop_data.len() > 1:
                aop_form = aop_data[1]
            var aop_priority_text = "0"
            if aop_data.len() > 2:
                aop_priority_text = aop_data[2]
            aop_advices.push(AopAdvice(
                pointcut: aop_pointcut,
                form: aop_form,
                handler: decl_get_name(idx),
                priority: text_parse_int_simple(aop_priority_text),
                span: span
            ))
        elif tag_text == "15":
            val di_data = decl_get_imports(idx)
            var di_pointcut = ""
            if di_data.len() > 0:
                di_pointcut = di_data[0]
            di_bindings.push(DiBinding(
                pointcut: di_pointcut,
                implementation: decl_get_name(idx),
                span: span
            ))
        elif tag_text == "16":
            val ar_data = decl_get_imports(idx)
            var ar_pointcut = ""
            if ar_data.len() > 0:
                ar_pointcut = ar_data[0]
            var ar_message = ""
            if ar_data.len() > 1:
                ar_message = ar_data[1]
            arch_rules.push(ArchRule(
                kind: decl_get_name(idx),
                pointcut: ar_pointcut,
                message: ar_message,
                span: span
            ))
        di = di + 1
        if flat_bootstrap_enabled():
            eprint("[flat-bridge] decl:done {di}")

    print "[flat-bridge] building frontend module path={path}"
    val built_module = parser_module_new(
        name: path,
        imports: imports,
        exports: exports,
        domain_blocks: domain_blocks,
        functions: functions,
        classes: {},
        actors: {},
        structs: structs,
        enums: enums,
        bitfields: bitfields,
        traits: {},
        impls: impls,
        type_aliases: {},
        constants: constants,
        static_asserts: [],
        aop_advices: aop_advices,
        di_bindings: di_bindings,
        arch_rules: arch_rules,
        mock_decls: []
    )
    print "[flat-bridge] built frontend module path={path}"
    built_module

fn parse_and_build_module(source: text, path: text) -> FrontendModule:
    parser_init_with_path(source, path)
    parse_module_body()
    if parser_has_errors():
        val errors = parser_get_errors()
        var ei = 0
        while ei < errors.len():
            print "  {errors[ei]}"
            ei = ei + 1
    flat_ast_to_module(path)
