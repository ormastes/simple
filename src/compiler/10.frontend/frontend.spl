# Compiler Frontend Runner
#
# Shared frontend entrypoint for full Simple compiler modes:
# outline (TreeSitter) -> block resolution -> full parse -> desugar.
#
# This keeps frontend orchestration centralized so compiler modes
# (check/interpret/jit/aot) all consume exactly one parse pipeline.

use compiler.frontend.parser_types.{Module, DomainBlock}
use compiler.frontend.flat_ast_bridge.{parse_and_build_module, parse_and_build_surface_module}
use compiler.frontend.desugar.desugar_async.{desugar_module}
use compiler.frontend.desugar.collection_desugar.{desugar_collections}
use compiler.common.diagnostics.span.{Span}
use std.nogc_sync_mut.io.process_ops.{eprint}
# @cfg/@when conditional-compilation preprocessor. Delegate to the real
# implementation under a UNIQUE name: a local `preprocess_conditionals` that
# collided with a same-name `use` import previously shadowed the real one,
# leaving @cfg stripping inert (all arch variants survived → wrong-arch
# dispatch, e.g. arm64 byte_len on x86_64). The unique `_pp_*` name cannot
# collide, so the real stripping always runs.
use compiler.core.parser_preprocessor.{_pp_preprocess_conditionals}
fn preprocess_conditionals(source: text) -> text:
    _pp_preprocess_conditionals(source)
use compiler.common.config.{Logger}

fn frontend_log_trace(log: Logger, message: text):
    if log.level >= 20:
        pass_dn

fn frontend_phase_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

extern fn rt_env_get(key: text) -> text

fn frontend_domain_kind_for_line(line: text) -> text:
    val kinds = ["schema", "style", "ui", "music", "bim", "cad", "city", "rtl"]
    for kind in kinds:
        if line.starts_with(kind + "{") and line.ends_with("}"):
            return kind
    ""

fn frontend_line_is_domain_block(line: text) -> bool:
    frontend_domain_kind_for_line(line) != ""

fn frontend_may_have_domain_block(source: text) -> bool:
    (source.contains("schema{") or source.contains("style{") or
        source.contains("ui{") or source.contains("music{") or
        source.contains("bim{") or source.contains("cad{") or
        source.contains("city{") or source.contains("rtl{"))

fn frontend_collect_domain_blocks(source: text) -> [DomainBlock]:
    var blocks: [DomainBlock] = []
    for raw_line in source.split("\n"):
        val line = raw_line.trim()
        val kind = frontend_domain_kind_for_line(line)
        if kind != "":
            val payload = line.substring(kind.len() + 1, line.len() - 1).trim()
            blocks.push(DomainBlock(kind, payload, "module", Span.empty()))
    blocks

fn frontend_strip_domain_block_lines(source: text) -> text:
    var lines: [text] = []
    for raw_line in source.split("\n"):
        if frontend_line_is_domain_block(raw_line.trim()):
            lines.push("")
        else:
            lines.push(raw_line)
    lines.join("\n")

fn parse_full_frontend(source: text, file_path: text, module_name: text, log: Logger) -> Module:
    val preprocessed = preprocess_conditionals(source)
    var domain_blocks: [DomainBlock] = []
    var parse_source = preprocessed
    if frontend_may_have_domain_block(preprocessed):
        domain_blocks = frontend_collect_domain_blocks(preprocessed)
        parse_source = frontend_strip_domain_block_lines(preprocessed)

    frontend_log_trace(log, "2: core parser bridge...")
    if frontend_phase_trace_enabled():
        eprint("[frontend] parse_and_build:start path={file_path}")
    var module = parse_and_build_module(parse_source, file_path)
    if domain_blocks.len() > 0:
        module.domain_blocks = domain_blocks
    if frontend_phase_trace_enabled():
        eprint("[frontend] parse_and_build:done path={file_path}")
    if (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1":
        print "[frontend] parsed module path={file_path}"

    # Phase 2d: Desugar async/await/spawn/actor syntax
    frontend_log_trace(log, "2d: desugaring...")
    module = desugar_module(module)

    # Phase 2e: Rewrite collection patterns + for-in-chars elimination
    # parse_and_build_module resets the flat AST arenas for this module.
    desugar_collections(0, 0)

    # Return the parsed-and-desugared module (declared return type is Module).
    module

fn parse_surface_frontend(source: text, file_path: text, module_name: text, log: Logger) -> Module:
    val preprocessed = preprocess_conditionals(source)
    var domain_blocks: [DomainBlock] = []
    var parse_source = preprocessed
    if frontend_may_have_domain_block(preprocessed):
        domain_blocks = frontend_collect_domain_blocks(preprocessed)
        parse_source = frontend_strip_domain_block_lines(preprocessed)
    var module = parse_and_build_surface_module(parse_source, file_path)
    if domain_blocks.len() > 0:
        module.domain_blocks = domain_blocks
    # Preserve the effective public headers produced by the full frontend
    # (notably async fn -> fn returning Future<T>). Bodyless async functions
    # have no suspension points, so module-private state helpers are deferred
    # to the Phase-3 full parse.
    desugar_module(module)
