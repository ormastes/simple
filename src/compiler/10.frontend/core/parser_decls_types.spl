# Parser — Type Declaration Module
#
# Extracted from parser_decls.spl: struct/class, enum, and bitfield declarations.

use compiler.core.tokens.{TOK_IDENT, TOK_STRING_LIT, TOK_INT_LIT}
use compiler.core.tokens.{TOK_KW_FN, TOK_KW_STATIC, TOK_KW_ME, TOK_KW_PUB, TOK_KW_TYPE}
use compiler.core.tokens.{TOK_LPAREN, TOK_RPAREN, TOK_UNDERSCORE}
use compiler.core.tokens.{TOK_COLON, TOK_COMMA, TOK_QUESTION}
use compiler.core.tokens.{TOK_ASSIGN, TOK_LBRACKET, TOK_RBRACKET}
use compiler.core.tokens.{TOK_INDENT, TOK_DEDENT, TOK_EOF}
use compiler.core.ast.{decl_struct_def, decl_enum_def, decl_impl_block, module_add_decl}
use compiler.core.types.{type_tag_name, int_to_str}
use compiler.core.types.{named_type_register}
use compiler.core.parser.{par_kind_get, par_text_get, par_struct_names}
use compiler.core.parser.{parser_advance, parser_expect, parser_error}
use compiler.core.parser.{parser_skip_newlines, parser_skip_newlines_and_semicolons}
use compiler.core.parser.{parser_parse_type, parser_parse_type_with_union}
use compiler.core.parser_expr.{parse_expr, parse_int_text}
use compiler.core.parser_decls_use.{parse_impl_decl, parse_class_body_method}
use compiler.core.parser_decls_fn.{parse_type_params}

# ===== Helper Functions =====

fn bitfield_backing_bits_from_name(type_name: text) -> i64:
    if type_name == "u8":
        return 8
    if type_name == "u16":
        return 16
    if type_name == "u32":
        return 32
    if type_name == "u64":
        return 64
    0

fn bitfield_field_bits_from_name(type_name: text) -> i64:
    if type_name == "bool":
        return 1
    val has_u_prefix: bool = type_name.starts_with("u")
    val has_i_prefix: bool = type_name.starts_with("i")
    if not (has_u_prefix or has_i_prefix):
        return 0
    if type_name.len() <= 1:
        return 0
    for bi in 1..type_name.len():
        val ch = type_name[bi]
        if ch < "0" or ch > "9":
            return 0
    val bits = parse_int_text(type_name[1:type_name.len()])
    if bits <= 0 or bits > 64:
        return 0
    bits

fn has_seen_name(names: [text], target: text) -> bool:
    for nm in names:
        if nm == target:
            return true
    false


# ===== Enum Declarations =====

fn parse_enum_decl() -> i64:
    parser_advance()
    val enum_name = par_text_get()
    parser_expect(TOK_IDENT)

    # Parse optional type parameters: enum Result<T, E>:
    val type_params = parse_type_params()

    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    var variant_names: [text] = []
    var enum_method_ids: [i64] = []

    for i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip docstrings in enum body
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Handle methods inside enum body: fn, static fn, me, pub fn, pub static fn
        if par_kind_get() == TOK_KW_PUB:
            parser_advance()
            if par_kind_get() == TOK_KW_STATIC:
                val sm_id = parse_class_body_method(enum_name, true, false)
                if sm_id >= 0:
                    enum_method_ids.push(sm_id)
            elif par_kind_get() == TOK_KW_FN:
                val fm_id = parse_class_body_method(enum_name, false, false)
                if fm_id >= 0:
                    enum_method_ids.push(fm_id)
            elif par_kind_get() == TOK_KW_ME:
                val mm_id = parse_class_body_method(enum_name, false, true)
                if mm_id >= 0:
                    enum_method_ids.push(mm_id)
            continue
        if par_kind_get() == TOK_KW_STATIC:
            val sm_id = parse_class_body_method(enum_name, true, false)
            if sm_id >= 0:
                enum_method_ids.push(sm_id)
            continue
        if par_kind_get() == TOK_KW_FN:
            val fm_id = parse_class_body_method(enum_name, false, false)
            if fm_id >= 0:
                enum_method_ids.push(fm_id)
            continue
        if par_kind_get() == TOK_KW_ME:
            val mm_id = parse_class_body_method(enum_name, false, true)
            if mm_id >= 0:
                enum_method_ids.push(mm_id)
            continue

        # Skip comments that may appear as idents
        val vname = par_text_get()
        parser_expect(TOK_IDENT)
        # Handle enum variant data: Variant(field: type, ...)
        if par_kind_get() == TOK_LPAREN:
            parser_advance()
            for j in 0..100:
                if par_kind_get() == TOK_RPAREN:
                    break
                if par_kind_get() == TOK_EOF:
                    break
                # Skip field_name: type pairs
                if par_kind_get() == TOK_IDENT:
                    parser_advance()
                    if par_kind_get() == TOK_COLON:
                        parser_advance()
                        parser_parse_type()
                        # Handle optional ? after type
                        if par_kind_get() == TOK_QUESTION:
                            parser_advance()
                elif par_kind_get() == TOK_LBRACKET:
                    parser_parse_type()
                else:
                    parser_advance()
                if par_kind_get() == TOK_COMMA:
                    parser_advance()
            parser_expect(TOK_RPAREN)
        variant_names.push(vname)
        parser_skip_newlines_and_semicolons()

    val enum_did = decl_enum_def(enum_name, variant_names, 0)

    # If enum had methods, create an impl block for them
    if enum_method_ids.len() > 0:
        val impl_d = decl_impl_block(enum_name, enum_method_ids, 0)
        module_add_decl(impl_d)

    enum_did

# ===== Bitfield Declaration =====

fn parse_bitfield_decl() -> i64:
    # Consume 'bitfield' keyword
    parser_advance()
    val bf_name = par_text_get()
    parser_expect(TOK_IDENT)
    par_struct_names.push(bf_name)

    # Pre-register type name
    named_type_register(bf_name, [], [])

    # Parse backing type: bitfield Name(u32):
    parser_expect(TOK_LPAREN)
    val backing_type = parser_parse_type()
    parser_expect(TOK_RPAREN)
    val backing_name = type_tag_name(backing_type)
    val backing_bits = bitfield_backing_bits_from_name(backing_name)
    if backing_bits == 0:
        parser_error("bitfield backing type must be u8, u16, u32, or u64")

    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    # Parse fields as struct fields with bit-width types
    # The struct gets a single __raw field of the backing type.
    # Additional named fields are also recorded for semantic analysis.
    var field_names: [text] = ["__raw"]
    var field_types: [i64] = [backing_type]
    var field_defaults: [i64] = [-1]
    var seen_names: [text] = []
    var used_bits: i64 = 0

    for bf_i in 0..200:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip comments/docstrings
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Field: name: type  OR  _: uN (reserved)
        val field_name = par_text_get()
        val is_underscore: bool = par_kind_get() == TOK_UNDERSCORE
        if is_underscore:
            parser_advance()
        else:
            parser_expect(TOK_IDENT)
        parser_expect(TOK_COLON)
        val field_type = parser_parse_type()
        val field_type_name = type_tag_name(field_type)
        val field_bits = bitfield_field_bits_from_name(field_type_name)
        if field_bits == 0:
            parser_error("bitfield field type must be bool, uN, or iN")
        used_bits = used_bits + field_bits

        # Skip reserved fields (don't add to struct)
        if not is_underscore:
            if has_seen_name(seen_names, field_name):
                parser_error("duplicate bitfield field name: " + field_name)
            seen_names.push(field_name)
            field_names.push(field_name)
            field_types.push(field_type)
            field_defaults.push(-1)

        parser_skip_newlines_and_semicolons()

    if backing_bits > 0 and used_bits > backing_bits:
        parser_error("bitfield '" + bf_name + "' uses " + int_to_str(used_bits) + " bits but backing type allows only " + int_to_str(backing_bits))

    decl_struct_def(bf_name, field_names, field_types, field_defaults, 0)
