# Interpreter Resource Tracker — per-module name tracking for selective unload.
#
# Tracks which functions, structs, enums, and globals belong to each loaded
# module.  When a module is unloaded, all its names are removed from the
# interpreter's function table, struct table, enum registry, and global env.
#
# Uses parallel arrays (arena pattern) to stay seed-compilable.

# ============================================================================
# Tracking Arrays
# ============================================================================

# Each index corresponds to one loaded module.
var irt_paths: [text] = []         # module paths (key)
var irt_funcs: [[text]] = []       # per-module function names
var irt_func_decls: [[i64]] = []   # declaration owner for each function name
var irt_func_rets: [[i64]] = []    # return metadata for restoration
var irt_func_bound: [[i64]] = []   # 1 when present in the function table
var irt_structs: [[text]] = []     # per-module struct names
var irt_struct_decls: [[i64]] = [] # declaration owner for each struct name
var irt_struct_modules: [[text]] = [] # struct-table owner path
var irt_enums: [[text]] = []       # per-module enum names
var irt_globals: [[text]] = []     # per-module global var names

# Binding history preserves last-write-wins behavior when an owner unloads.
var irt_func_history_slots: [i64] = []
var irt_func_history_names: [text] = []
var irt_func_history_decls: [i64] = []
var irt_func_history_rets: [i64] = []
var irt_func_history_bound: [i64] = []
var irt_struct_history_slots: [i64] = []
var irt_struct_history_names: [text] = []
var irt_struct_history_decls: [i64] = []
var irt_struct_history_modules: [text] = []

# ============================================================================
# Init / Reset
# ============================================================================

fn irt_init():
    irt_paths = []
    irt_funcs = []
    irt_func_decls = []
    irt_func_rets = []
    irt_func_bound = []
    irt_structs = []
    irt_struct_decls = []
    irt_struct_modules = []
    irt_enums = []
    irt_globals = []
    irt_func_history_slots = []
    irt_func_history_names = []
    irt_func_history_decls = []
    irt_func_history_rets = []
    irt_func_history_bound = []
    irt_struct_history_slots = []
    irt_struct_history_names = []
    irt_struct_history_decls = []
    irt_struct_history_modules = []

# ============================================================================
# Module Registration
# ============================================================================

fn irt_begin_module(module_path: text):
    """Start tracking a new module. Call before registering its names."""
    # Check if already tracked (idempotent)
    var i: i64 = 0
    for p in irt_paths:
        if p == module_path:
            return
        i = i + 1
    irt_paths.push(module_path)
    irt_funcs.push([])
    irt_func_decls.push([])
    irt_func_rets.push([])
    irt_func_bound.push([])
    irt_structs.push([])
    irt_struct_decls.push([])
    irt_struct_modules.push([])
    irt_enums.push([])
    irt_globals.push([])

fn irt_find_index(module_path: text) -> i64:
    """Find the index for a module path. Returns -1 if not tracked."""
    var i: i64 = 0
    for p in irt_paths:
        if p == module_path:
            return i
        i = i + 1
    -1

# ============================================================================
# Name Registration Hooks
# ============================================================================

fn irt_track_func(module_path: text, name: text, decl_id: i64, ret_type: i64, table_bound: i64):
    """Record that a function was registered for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_funcs[idx]
    var decls = irt_func_decls[idx]
    var rets = irt_func_rets[idx]
    var bounds = irt_func_bound[idx]
    var found = false
    var i: i64 = 0
    for existing_name in names:
        if existing_name == name:
            decls[i] = decl_id
            rets[i] = ret_type
            bounds[i] = table_bound
            found = true
        i = i + 1
    if not found:
        names.push(name)
        decls.push(decl_id)
        rets.push(ret_type)
        bounds.push(table_bound)
    irt_funcs[idx] = names
    irt_func_decls[idx] = decls
    irt_func_rets[idx] = rets
    irt_func_bound[idx] = bounds

    val history_len = irt_func_history_names.len()
    if history_len > 0:
        val last = history_len - 1
        val same_slot = irt_func_history_slots[last] == idx
        val same_name = irt_func_history_names[last] == name
        val same_decl = irt_func_history_decls[last] == decl_id
        val same_bound = irt_func_history_bound[last] == table_bound
        if same_slot and same_name and same_decl and same_bound:
            return
    irt_func_history_slots.push(idx)
    irt_func_history_names.push(name)
    irt_func_history_decls.push(decl_id)
    irt_func_history_rets.push(ret_type)
    irt_func_history_bound.push(table_bound)

fn irt_track_struct(module_path: text, name: text, decl_id: i64, struct_module: text):
    """Record that a struct was registered for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_structs[idx]
    var decls = irt_struct_decls[idx]
    var modules = irt_struct_modules[idx]
    var found = false
    var i: i64 = 0
    for existing_name in names:
        if existing_name == name:
            decls[i] = decl_id
            modules[i] = struct_module
            found = true
        i = i + 1
    if not found:
        names.push(name)
        decls.push(decl_id)
        modules.push(struct_module)
    irt_structs[idx] = names
    irt_struct_decls[idx] = decls
    irt_struct_modules[idx] = modules

    val history_len = irt_struct_history_names.len()
    if history_len > 0:
        val last = history_len - 1
        val same_slot = irt_struct_history_slots[last] == idx
        val same_name = irt_struct_history_names[last] == name
        val same_decl = irt_struct_history_decls[last] == decl_id
        val same_module = irt_struct_history_modules[last] == struct_module
        if same_slot and same_name and same_decl and same_module:
            return
    irt_struct_history_slots.push(idx)
    irt_struct_history_names.push(name)
    irt_struct_history_decls.push(decl_id)
    irt_struct_history_modules.push(struct_module)

fn irt_track_enum(module_path: text, name: text):
    """Record that an enum was registered for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_enums[idx]
    names.push(name)
    irt_enums[idx] = names

fn irt_track_global(module_path: text, name: text):
    """Record that a global variable was defined for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_globals[idx]
    names.push(name)
    irt_globals[idx] = names

# ============================================================================
# Unload — selective cleanup
# ============================================================================

fn irt_latest_func_metadata_slot(name: text) -> i64:
    var i = irt_func_history_names.len() - 1
    while i >= 0:
        val slot = irt_func_history_slots[i]
        if slot >= 0 and slot < irt_paths.len() and irt_paths[slot] != "" and irt_func_history_names[i] == name:
            return slot
        i = i - 1
    -1

fn irt_restore_func_table(name: text):
    var i = irt_func_history_names.len() - 1
    while i >= 0:
        val slot = irt_func_history_slots[i]
        if slot >= 0 and slot < irt_paths.len() and irt_paths[slot] != "" and irt_func_history_names[i] == name and irt_func_history_bound[i] == 1:
            func_table_register(name, irt_func_history_decls[i])
            return
        i = i - 1

fn irt_restore_func_metadata(name: text):
    var i = irt_func_history_names.len() - 1
    while i >= 0:
        val slot = irt_func_history_slots[i]
        if slot >= 0 and slot < irt_paths.len() and irt_paths[slot] != "" and irt_func_history_names[i] == name:
            func_register_return_type(name, irt_func_history_rets[i])
            return
        i = i - 1

fn irt_restore_struct(name: text):
    var i = irt_struct_history_names.len() - 1
    while i >= 0:
        val slot = irt_struct_history_slots[i]
        if slot >= 0 and slot < irt_paths.len() and irt_paths[slot] != "" and irt_struct_history_names[i] == name:
            struct_table_register_owned(name, irt_struct_history_decls[i], irt_struct_history_modules[i])
            return
        i = i - 1

fn irt_unload_module(module_path: text) -> i64:
    """Remove all names registered by a module.

    Calls func_table_remove, struct_table_remove, enum_table_remove,
    and env_remove_global for each tracked name.

    Returns the total number of names removed, or 0 if module not tracked.
    """
    val idx = irt_find_index(module_path)
    if idx < 0: return 0

    var removed: i64 = 0

    # Remove functions
    val funcs = irt_funcs[idx]
    val func_decls = irt_func_decls[idx]
    val func_rets = irt_func_rets[idx]
    val func_bounds = irt_func_bound[idx]
    var func_metadata_owned: [i64] = []
    for name in funcs:
        if irt_latest_func_metadata_slot(name) == idx:
            func_metadata_owned.push(1)
        else:
            func_metadata_owned.push(0)
    var func_index: i64 = 0

    # Tombstone before restoration so this owner's history is ignored.
    irt_paths[idx] = ""

    for name in funcs:
        val owned_decl = func_decls[func_index]
        if func_bounds[func_index] == 1 and func_table_lookup(name) == owned_decl:
            if func_table_remove(name):
                removed = removed + 1
            irt_restore_func_table(name)
        if func_metadata_owned[func_index] == 1:
            func_remove_return_type(name)
            irt_restore_func_metadata(name)
        func_index = func_index + 1

    # Remove structs
    val structs = irt_structs[idx]
    val struct_decls = irt_struct_decls[idx]
    var struct_index: i64 = 0
    for name in structs:
        if struct_table_lookup(name) == struct_decls[struct_index]:
            if struct_table_remove(name):
                removed = removed + 1
            irt_restore_struct(name)
        struct_index = struct_index + 1

    # Remove enums
    val enums = irt_enums[idx]
    for name in enums:
        if enum_table_remove(name):
            removed = removed + 1

    # Remove globals
    val globals = irt_globals[idx]
    for name in globals:
        if env_remove_global(name):
            removed = removed + 1

    # Tombstone this slot (don't shift arrays)
    irt_funcs[idx] = []
    irt_func_decls[idx] = []
    irt_func_rets[idx] = []
    irt_func_bound[idx] = []
    irt_structs[idx] = []
    irt_struct_decls[idx] = []
    irt_struct_modules[idx] = []
    irt_enums[idx] = []
    irt_globals[idx] = []

    removed

# ============================================================================
# Query
# ============================================================================

fn irt_is_tracked(module_path: text) -> bool:
    irt_find_index(module_path) >= 0

fn irt_tracked_count() -> i64:
    """Number of actively tracked modules (excludes tombstones)."""
    var count: i64 = 0
    for p in irt_paths:
        if p != "":
            count = count + 1
    count

fn irt_get_func_count(module_path: text) -> i64:
    val idx = irt_find_index(module_path)
    if idx < 0: return 0
    irt_funcs[idx].len()

fn irt_get_struct_count(module_path: text) -> i64:
    val idx = irt_find_index(module_path)
    if idx < 0: return 0
    irt_structs[idx].len()

# ============================================================================
# Exports
# ============================================================================
