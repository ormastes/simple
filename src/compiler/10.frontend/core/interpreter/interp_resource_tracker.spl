# Interpreter Resource Tracker — per-module name tracking for selective unload.
#
# Tracks which functions, structs, enums, and globals belong to each loaded
# module.  When a module is unloaded, all its names are removed from the
# interpreter's function table, struct table, enum registry, and global env.
#
# Uses parallel arrays (arena pattern) to stay seed-compilable.

# ============================================================================
# Tracking Arrays
# ============================================================================

# Each index corresponds to one loaded module.
var irt_paths: [text] = []         # module paths (key)
var irt_funcs: [[text]] = []       # per-module function names
var irt_structs: [[text]] = []     # per-module struct names
var irt_enums: [[text]] = []       # per-module enum names
var irt_globals: [[text]] = []     # per-module global var names

# pure_interp_registry_2026-07-17: owning decl_id recorded alongside each
# tracked name (parallel to irt_funcs/irt_structs), so unload can verify the
# func_table/struct_table entry still belongs to THIS module before removing
# it. -1 marks a legacy entry (registered via the plain irt_track_func /
# irt_track_struct, no owner recorded) — unload falls back to the old
# unguarded removal for those so behavior for any un-migrated caller is
# unchanged.
var irt_func_decls: [[i64]] = []   # per-module function owner decl_ids
var irt_struct_decls: [[i64]] = [] # per-module struct owner decl_ids

# ============================================================================
# Init / Reset
# ============================================================================

fn irt_init():
    irt_paths = []
    irt_funcs = []
    irt_structs = []
    irt_enums = []
    irt_globals = []
    irt_func_decls = []
    irt_struct_decls = []

# ============================================================================
# Module Registration
# ============================================================================

fn irt_begin_module(module_path: text):
    """Start tracking a new module. Call before registering its names."""
    # Check if already tracked (idempotent)
    var i: i64 = 0
    for p in irt_paths:
        if p == module_path:
            return
        i = i + 1
    irt_paths.push(module_path)
    irt_funcs.push([])
    irt_structs.push([])
    irt_enums.push([])
    irt_globals.push([])
    irt_func_decls.push([])
    irt_struct_decls.push([])

fn irt_find_index(module_path: text) -> i64:
    """Find the index for a module path. Returns -1 if not tracked."""
    var i: i64 = 0
    for p in irt_paths:
        if p == module_path:
            return i
        i = i + 1
    -1

# ============================================================================
# Name Registration Hooks
# ============================================================================

fn irt_track_func(module_path: text, name: text):
    """Record that a function was registered for a module.

    Legacy (no owner decl_id) — pushes a -1 sentinel into irt_func_decls so
    it stays lockstepped with irt_funcs. Unload falls back to the unguarded
    removal for -1 entries. Prefer irt_track_func_owned for new call sites.
    """
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_funcs[idx]
    names.push(name)
    irt_funcs[idx] = names
    var decls = irt_func_decls[idx]
    decls.push(-1)
    irt_func_decls[idx] = decls

fn irt_track_func_owned(module_path: text, name: text, decl_id: i64):
    """pure_interp_registry_2026-07-17: like irt_track_func, but records the
    owning decl_id so unload can guard against clobbering a different
    module's registration that later overwrote this bare name (see
    func_table_remove_owned in eval_tables.spl)."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_funcs[idx]
    names.push(name)
    irt_funcs[idx] = names
    var decls = irt_func_decls[idx]
    decls.push(decl_id)
    irt_func_decls[idx] = decls

fn irt_track_struct(module_path: text, name: text):
    """Record that a struct was registered for a module. Legacy — see
    irt_track_func for the -1 sentinel / _owned rationale."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_structs[idx]
    names.push(name)
    irt_structs[idx] = names
    var decls = irt_struct_decls[idx]
    decls.push(-1)
    irt_struct_decls[idx] = decls

fn irt_track_struct_owned(module_path: text, name: text, decl_id: i64):
    """pure_interp_registry_2026-07-17: like irt_track_struct, but records
    the owning decl_id (see irt_track_func_owned)."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_structs[idx]
    names.push(name)
    irt_structs[idx] = names
    var decls = irt_struct_decls[idx]
    decls.push(decl_id)
    irt_struct_decls[idx] = decls

fn irt_track_enum(module_path: text, name: text):
    """Record that an enum was registered for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_enums[idx]
    names.push(name)
    irt_enums[idx] = names

fn irt_track_global(module_path: text, name: text):
    """Record that a global variable was defined for a module."""
    val idx = irt_find_index(module_path)
    if idx < 0: return
    var names = irt_globals[idx]
    names.push(name)
    irt_globals[idx] = names

# ============================================================================
# Unload — selective cleanup
# ============================================================================

fn irt_unload_module(module_path: text) -> i64:
    """Remove all names registered by a module.

    Calls func_table_remove, struct_table_remove, enum_table_remove,
    and env_remove_global for each tracked name.

    Returns the total number of names removed, or 0 if module not tracked.
    """
    val idx = irt_find_index(module_path)
    if idx < 0: return 0

    var removed: i64 = 0

    # Remove functions (pure_interp_registry_2026-07-17: owner-guarded when a
    # decl_id was recorded, so a bare-name collision with a module registered
    # later does not delete that OTHER module's live registration).
    val funcs = irt_funcs[idx]
    val func_decls = irt_func_decls[idx]
    var fi: i64 = 0
    for name in funcs:
        val owner = func_decls[fi]
        if owner < 0:
            if func_table_remove(name):
                removed = removed + 1
            func_remove_return_type(name)
        else:
            if func_table_remove_owned(name, owner):
                removed = removed + 1
            func_remove_return_type_owned(name, owner)
        fi = fi + 1

    # Remove structs (same owner-guard as functions above)
    val structs = irt_structs[idx]
    val struct_decls = irt_struct_decls[idx]
    var si: i64 = 0
    for name in structs:
        val owner2 = struct_decls[si]
        if owner2 < 0:
            if struct_table_remove(name):
                removed = removed + 1
        else:
            if struct_table_remove_owned(name, owner2):
                removed = removed + 1
        si = si + 1

    # Remove enums
    val enums = irt_enums[idx]
    for name in enums:
        if enum_table_remove(name):
            removed = removed + 1

    # Remove globals
    val globals = irt_globals[idx]
    for name in globals:
        if env_remove_global(name):
            removed = removed + 1

    # Tombstone this slot (don't shift arrays)
    irt_paths[idx] = ""
    irt_funcs[idx] = []
    irt_structs[idx] = []
    irt_enums[idx] = []
    irt_globals[idx] = []
    irt_func_decls[idx] = []
    irt_struct_decls[idx] = []

    removed

# ============================================================================
# Query
# ============================================================================

fn irt_is_tracked(module_path: text) -> bool:
    irt_find_index(module_path) >= 0

fn irt_tracked_count() -> i64:
    """Number of actively tracked modules (excludes tombstones)."""
    var count: i64 = 0
    for p in irt_paths:
        if p != "":
            count = count + 1
    count

fn irt_get_func_count(module_path: text) -> i64:
    val idx = irt_find_index(module_path)
    if idx < 0: return 0
    irt_funcs[idx].len()

fn irt_get_struct_count(module_path: text) -> i64:
    val idx = irt_find_index(module_path)
    if idx < 0: return 0
    irt_structs[idx].len()

# ============================================================================
# Exports
# ============================================================================

