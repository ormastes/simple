#![allow(unnamed_duplicate_typed_args)]
# Core Interpreter — Runtime Module Loader
#
# Enables runtime resolution of `use` statements without requiring symlinks.
# Mirrors compile-time module loading but operates within interpreter context.
#
# Key responsibilities:
# 1. Resolve module paths (std.string → src/lib/text.spl)
# 2. Load and parse module source files
# 3. Extract exported functions from module AST
# 4. Register functions in interpreter's function table
#
# Module Path Resolution (in order):
# 1. Local directory (relative to current file)
# 2. SIMPLE_LIB environment variable path
# 3. Fallback to src/lib/ (standard library)

use compiler.core.frontend.{core_frontend_parse_isolated, core_frontend_parse_append}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> i64
extern fn rt_path_join(base: text, rel: text) -> text
extern fn rt_path_dirname(path: text) -> text
extern fn rt_dir_create_all(path: text) -> bool

# SMF loading hooks — implemented by driver layer (80.driver/smf_hooks.spl)
extern fn smf_check_freshness(source_path: text, smf_path: text) -> i64
extern fn smf_source_to_cache_path(source_path: text) -> text
extern fn smf_resolve_library(module_name: text) -> text
extern fn smf_get_or_generate(source_path: text, smf_path: text) -> i64

# SMF loading state
var _smf_enabled: bool = false
var _smf_prefer_compiled: bool = false
var _smf_allow_library: bool = false
var _smf_allow_fallback: bool = true
var _smf_regenerate: bool = false
var _smf_freshness_cache: {text: bool} = {}

# GC-mode-aware module resolution
# When set to "gc", lib fallback chain prioritizes gc_* variants.
# When "nogc" (default), uses the original nogc-first order.
var _lib_gc_mode: text = "nogc"

fn set_lib_gc_mode(mode: text):
    """Set GC mode for library module resolution.

    Args:
        mode: "gc" or "nogc" — determines lib variant priority order.
              "gc"   → gc_async_mut > gc_sync_mut > common > nogc_async_mut > nogc_sync_mut > nogc_async_mut_noalloc
              "nogc" → nogc_async_mut > nogc_sync_mut > common > gc_async_mut > nogc_async_mut_noalloc
    """
    _lib_gc_mode = mode

fn get_lib_gc_mode() -> text:
    """Get current GC mode for library module resolution."""
    _lib_gc_mode

# AST Declaration Tags (from ast.spl)
val DECL_FN = 1
val DECL_EXTERN_FN = 2
val DECL_STRUCT = 3
val DECL_VAL = 4
val DECL_VAR = 5
val DECL_USE = 6
val DECL_EXPORT = 7
val DECL_ENUM = 8
val DECL_IMPL = 9

# Helper struct for building CoreDecl (defined in ast_types.spl)
# Since we can't use generics at runtime, we construct these manually
struct ModuleDeclInfo:
    tag: i64
    name: text
    imports: [text]
    ret_type: i64

fn make_decl_info(tag: i64, name: text, imports: [text], ret_type: i64) -> ModuleDeclInfo:
    ModuleDeclInfo(tag: tag, name: name, imports: imports, ret_type: ret_type)

fn get_decl_info(did: i64) -> ModuleDeclInfo:
    # Build ModuleDeclInfo from AST arena using accessor functions
    val tag = decl_get_tag(did)
    val name = decl_get_name(did)
    val imports = decl_get_imports(did)
    val ret_type = decl_get_ret_type(did)
    make_decl_info(tag, name, imports, ret_type)

# ===== Loaded Module Tracking =====

# Snapshot arrays retained for compatibility with existing exports/builtins.
var loaded_module_paths: [text] = []
var loaded_module_file_paths: [text] = []
var loaded_module_exports: [text] = []
var _loaded_module_order: text = ""
var _loaded_module_file_map: {text: text} = {}
var _loaded_module_exports_map: {text: text} = {}
var loaded_module_set: {text: bool} = {}

# ===== Deferred (Lazy) Module Tracking =====

var _deferred_module_order: text = ""
var _deferred_module_file_map: {text: text} = {}
var _deferred_module_imports_map: {text: text} = {}
var deferred_module_set: {text: bool} = {}

fn encode_module_names(names: [text]) -> text:
    if names.len() == 0:
        return ""
    names.join("\n")

fn decode_module_names(encoded: text) -> [text]:
    if encoded == "":
        return []
    encoded.split("\n")

fn append_module_name(encoded: text, name: text) -> text:
    if encoded == "":
        return name
    encoded + "\n" + name

fn refresh_loaded_module_snapshots():
    val paths = decode_module_names(_loaded_module_order)
    var file_paths: [text] = []
    var export_names: [text] = []
    for path in paths:
        file_paths.push(_loaded_module_file_map[path] ?? "")
        export_names.push(_loaded_module_exports_map[path] ?? "")
    loaded_module_paths = paths
    loaded_module_file_paths = file_paths
    loaded_module_exports = export_names

fn deferred_imports_include(imported_names: [text], symbol_name: text) -> i64:
    if imported_names.len() == 0:
        return 1
    for imported_name in imported_names:
        if imported_name == symbol_name:
            return 1
    0

fn deferred_module_may_define_symbol(module_name: text, current_file: text, imported_names: [text], symbol_name: text) -> i64:
    if deferred_imports_include(imported_names, symbol_name) == 0:
        return 0

    val resolved_path = resolve_module_path(module_name, current_file)
    if resolved_path == "":
        return 1

    # Phase 4: SHB-based symbol check — interface-only, no body execution.
    # Try SHB first for accurate exported-symbol lookup. Falls back to
    # source scan if SHB is unavailable (e.g. first run before any SHB
    # has been generated).
    val shb_result = _shb_check_symbol(resolved_path, symbol_name)
    if shb_result >= 0:
        return shb_result

    # Fallback: lightweight source scan when no SHB is available.
    val source = load_module_source(resolved_path)
    if source == "":
        return 0
    if source.contains(symbol_name):
        return 1
    0

fn _shb_check_symbol(source_path: text, symbol_name: text) -> i64:
    """Check SHB for symbol presence. Returns 1 (found), 0 (not found),
    or -1 (SHB unavailable — caller should fall back to source scan).
    Interface-only check: reads .shb header, never executes module body."""
    val shb_dir = _shb_cache_dir()
    if shb_dir == "":
        return -1
    val shb_path = _source_to_shb_path_for_check(source_path, shb_dir)
    if rt_file_exists(shb_path) == 0:
        return -1
    val content = rt_file_read_text(shb_path)
    if content == nil:
        return -1
    val content_str = "{content}"
    if content_str == "" or content_str == "Option::None":
        return -1
    # Check if the SHB content contains the symbol name.
    # This is a lightweight check — the SHB binary format stores symbol
    # names as plain text strings, so contains() works for a quick scan.
    if content_str.contains(symbol_name):
        return 1
    0

fn _shb_cache_dir() -> text:
    """Return the SHB cache directory path, or empty if not configured."""
    # Default SHB cache location used by shb_cache.spl
    val default_dir = ".build/headers"
    if rt_file_exists(default_dir):
        return default_dir
    ""

fn _source_to_shb_path_for_check(source_path: text, shb_dir: text) -> text:
    """Convert source path to SHB cache path for symbol checking."""
    val with_slashes = source_path.replace("/", "_")
    val base = with_slashes.replace(".spl", "")
    "{shb_dir}/{base}.shb"

fn register_deferred_module(name: text, current_file: text, imported_names: [text]):
    val ds_ref = deferred_module_set
    if ds_ref.contains_key(name):
        return
    _deferred_module_order = append_module_name(_deferred_module_order, name)
    _deferred_module_file_map[name] = current_file
    _deferred_module_imports_map[name] = encode_module_names(imported_names)
    deferred_module_set[name] = true

fn is_deferred_module(name: text) -> i64:
    val ds_ref = deferred_module_set
    if ds_ref.contains_key(name):
        return 1
    0

fn force_deferred_module(name: text) -> i64:
    # Find the deferred module entry and load it
    val deferred_names = decode_module_names(_deferred_module_order)
    for mod_name in deferred_names:
        if mod_name == name:
            val current_file = _deferred_module_file_map[name] ?? ""
            val imported_names = decode_module_names(_deferred_module_imports_map[name] ?? "")
            var load_result: i64 = 0
            if imported_names.len() == 0:
                load_result = load_module(name, current_file)
            else:
                load_result = load_module_selective(name, imported_names, current_file)
            # Remove from deferred set (mark as loaded)
            deferred_module_set[name] = false
            return load_result
    0

fn try_force_any_deferred_for(symbol_name: text) -> i64:
    # Try each deferred module until symbol is found
    val deferred_names = decode_module_names(_deferred_module_order)
    for mod_name in deferred_names:
        val still_deferred = deferred_module_set[mod_name]
        if still_deferred == true:
            val current_file = _deferred_module_file_map[mod_name] ?? ""
            val imported_names = decode_module_names(_deferred_module_imports_map[mod_name] ?? "")
            val may_define = deferred_module_may_define_symbol(mod_name, current_file, imported_names, symbol_name)
            if may_define == 0:
                continue
            val ok = force_deferred_module(mod_name)
            if ok == 1:
                # Check if this module provided the symbol
                val decl_id = func_table_lookup(symbol_name)
                if decl_id >= 0:
                    return 1
    0

fn module_loader_init():
    loaded_module_paths = []
    loaded_module_file_paths = []
    loaded_module_exports = []
    _loaded_module_order = ""
    _loaded_module_file_map = {}
    _loaded_module_exports_map = {}
    loaded_module_set = {}
    _deferred_module_order = ""
    _deferred_module_file_map = {}
    _deferred_module_imports_map = {}
    deferred_module_set = {}
    _smf_freshness_cache = {}
    _smf_enabled = false
    irt_init()

fn module_is_loaded(module_path: text) -> i64:
    val ls_ref = loaded_module_set
    if ls_ref.contains_key(module_path):
        return 1
    0

fn module_mark_loaded(module_path: text, file_path: text, exports: [text]):
    _loaded_module_order = append_module_name(_loaded_module_order, module_path)
    _loaded_module_file_map[module_path] = file_path
    _loaded_module_exports_map[module_path] = encode_module_names(exports)
    refresh_loaded_module_snapshots()
    loaded_module_set[module_path] = true

fn module_get_file_path(module_name: text) -> text:
    _loaded_module_file_map[module_name] ?? ""

# ===== Module Path Resolution =====

extern fn rt_dir_list(path: text) -> [text]
extern fn rt_dir_exists(path: text) -> i64

# Cache resolved module paths to avoid repeated filesystem probing.
# Fast cache: module_name → resolved path (for stdlib modules resolved identically regardless of caller)
# Full cache: "module_name|current_file" → resolved path (for relative imports)
var _interp_module_fast_cache: {text: text} = {}
var _interp_module_cache: {text: text} = {}

fn resolve_module_path(module_name: text, current_file: text) -> text:
    # Fast path: check module-only cache first (no string concat needed)
    val fast_lookup_key = module_name + "|" + _lib_gc_mode
    val fast = _interp_module_fast_cache[fast_lookup_key] ?? ""
    if fast != "":
        return fast
    # Full path: composite key for relative imports (includes gc mode for lib resolution)
    val cache_key = module_name + "|" + current_file + "|" + _lib_gc_mode
    val cached = _interp_module_cache[cache_key] ?? ""
    if cached != "":
        return cached
    val result = _resolve_module_path_uncached(module_name, current_file)
    _interp_module_cache[cache_key] = result
    # Cache in fast path if it's a stdlib/lib import (not relative)
    # Include gc mode in fast cache key since lib resolution depends on it
    val fast_key = module_name + "|" + _lib_gc_mode
    if module_name.starts_with("std.") or module_name.starts_with("lib.") or module_name.starts_with("compiler.") or module_name.starts_with("app."):
        _interp_module_fast_cache[fast_key] = result
    result

fn _resolve_module_path_uncached(module_name: text, current_file: text) -> text:
    # Convert dotted name to file path
    # std.string → std/text.spl
    # app.io.mod → app/io/mod.spl
    # compiler.frontend.X → compiler/10.frontend/X.spl (numbered dir support)

    # Split dotted module name into parts using array+join (avoids O(n²) concat)
    val path_parts = module_name.split(".")

    # Build relative path with / separator
    val relative_path = path_parts.join("/") + ".spl"

    # Rewrite std/ → lib/ (std is a package alias, real code is in lib/)
    if relative_path.starts_with("std/"):
        relative_path = "lib" + relative_path.substring(3)

    # Try resolution strategies:

    # 1. Local directory (relative to current file)
    val current_dir = rt_path_dirname(current_file)
    val local_path = rt_path_join(current_dir, relative_path)
    if rt_file_exists(local_path):
        return local_path

    # 2. SIMPLE_LIB environment variable
    val simple_lib = rt_env_get("SIMPLE_LIB")
    val has_simple_lib = simple_lib != ""
    val lib_not_nil = simple_lib != nil
    val should_check_lib = has_simple_lib and lib_not_nil
    if should_check_lib:
        val lib_path = rt_path_join(simple_lib, relative_path)
        if rt_file_exists(lib_path):
            return lib_path

    # 3. Fallback to src/ directory
    val src_path = rt_path_join("src", relative_path)
    if rt_file_exists(src_path):
        return src_path

    # 4. Try lib subdirectory search (lib/*/X for use std.X / use lib.X)
    #    Resolution order depends on _lib_gc_mode:
    #    nogc: nogc_async_mut > nogc_sync_mut > common > gc_async_mut > nogc_async_mut_noalloc
    #    gc:   gc_async_mut > gc_sync_mut > common > nogc_async_mut > nogc_sync_mut > nogc_async_mut_noalloc
    if relative_path.starts_with("lib/"):
        val lib_subpath = relative_path.substring(4)
        val lib_dir = rt_path_join("src", "lib")
        if _lib_gc_mode == "gc":
            # GC mode: prioritize gc_* variants
            val gam = rt_path_join(lib_dir, rt_path_join("gc_async_mut", lib_subpath))
            if rt_file_exists(gam):
                return gam
            val gsm = rt_path_join(lib_dir, rt_path_join("gc_sync_mut", lib_subpath))
            if rt_file_exists(gsm):
                return gsm
            val cm = rt_path_join(lib_dir, rt_path_join("common", lib_subpath))
            if rt_file_exists(cm):
                return cm
            val nam = rt_path_join(lib_dir, rt_path_join("nogc_async_mut", lib_subpath))
            if rt_file_exists(nam):
                return nam
            val nsm = rt_path_join(lib_dir, rt_path_join("nogc_sync_mut", lib_subpath))
            if rt_file_exists(nsm):
                return nsm
            val nanm = rt_path_join(lib_dir, rt_path_join("nogc_async_mut_noalloc", lib_subpath))
            if rt_file_exists(nanm):
                return nanm
        else:
            # NoGC mode (default): prioritize nogc_* variants
            val nam = rt_path_join(lib_dir, rt_path_join("nogc_async_mut", lib_subpath))
            if rt_file_exists(nam):
                return nam
            val nsm = rt_path_join(lib_dir, rt_path_join("nogc_sync_mut", lib_subpath))
            if rt_file_exists(nsm):
                return nsm
            val cm = rt_path_join(lib_dir, rt_path_join("common", lib_subpath))
            if rt_file_exists(cm):
                return cm
            val gam = rt_path_join(lib_dir, rt_path_join("gc_async_mut", lib_subpath))
            if rt_file_exists(gam):
                return gam
            val gsm = rt_path_join(lib_dir, rt_path_join("gc_sync_mut", lib_subpath))
            if rt_file_exists(gsm):
                return gsm
            val nanm = rt_path_join(lib_dir, rt_path_join("nogc_async_mut_noalloc", lib_subpath))
            if rt_file_exists(nanm):
                return nanm

    # 5. Try numbered directory resolution (NN.name pattern)
    val numbered_path = resolve_with_numbered_dirs("src", path_parts)
    if numbered_path != "":
        if rt_file_exists(numbered_path):
            return numbered_path

    # Return attempted path even if not found (will error later)
    relative_path

fn resolve_with_numbered_dirs(base: text, parts: [text]) -> text:
    """Walk path parts, resolving each segment with NN. prefix fallback."""
    var current_dir = base
    var pi: i64 = 0
    val last_idx = parts.len() - 1

    for part in parts:
        if pi < last_idx:
            # Intermediate segment — must be a directory
            val direct = rt_path_join(current_dir, part)
            if rt_dir_exists(direct):
                current_dir = direct
            else:
                # Try numbered directory
                val numbered = find_numbered_dir_interp(current_dir, part)
                if numbered != "":
                    current_dir = numbered
                else:
                    return ""
        else:
            # Last segment — try as .spl file
            val file_path = rt_path_join(current_dir, part + ".spl")
            return file_path
        pi = pi + 1
    ""

fn find_numbered_dir_interp(parent: text, segment: text) -> text:
    """Find NN.segment directory in parent. Returns path or empty string."""
    if not rt_dir_exists(parent):
        return ""

    val entries = rt_dir_list(parent)
    for entry in entries:
        # Look for dot in entry name
        var dot_pos: i64 = -1
        var ci: i64 = 0
        for ch in entry:
            if ch == "." and dot_pos == -1:
                dot_pos = ci
            ci = ci + 1

        if dot_pos >= 1 and dot_pos <= 3:
            # Check if prefix is all digits
            val prefix = entry.substring(0, dot_pos)
            var all_digits = true
            for ch in prefix:
                if ch < "0" or ch > "9":
                    all_digits = false

            if all_digits:
                val name = entry.substring(dot_pos + 1)
                if name == segment:
                    val full_path = rt_path_join(parent, entry)
                    if rt_dir_exists(full_path):
                        return full_path
    ""

# ===== Module Load Depth Guard =====

var _module_load_depth: i64 = 0
val _MODULE_LOAD_MAX_DEPTH = 16

# ===== Module Loading =====

fn load_module_source(file_path: text) -> text:
    # Read module source file
    # Note: rt_file_read_text returns Option::None in interpreter mode for missing files
    # (not nil), so we check both nil and string representation
    val source = rt_file_read_text(file_path)
    if source == nil:
        return ""
    val source_str = "{source}"
    if source_str == "" or source_str == "Option::None":
        return ""
    source_str

fn parse_module_ast(source: text, path: text) -> i64:
    # Parse module into AST using APPEND mode to preserve caller's AST.
    # Returns 1 on success, 0 on failure.
    if core_frontend_parse_append(source, path):
        return 1
    0

fn extract_module_exports() -> [text]:
    # Extract exported function names from parsed module
    # Scans all declarations for DECL_EXPORT statements

    var exports: [text] = []
    var export_all = 0

    val decls = module_get_decls()

    # First pass: check for export statements
    for did in decls:
        val tag = decl_get_tag(did)

        if tag == DECL_EXPORT:
            # Get exported names from decl_imports field
            val names = decl_get_imports(did)
            for name in names:
                exports.push(name)

    # If no explicit exports found, export all functions
    if exports.len() == 0:
        export_all = 1

    if export_all == 1:
        for did in decls:
            val tag = decl_get_tag(did)

            if tag == DECL_FN:
                val name = decl_get_name(did)
                exports.push(name)

    exports

fn register_module_functions():
    # Register all module functions in interpreter's function table
    # This makes them available for calls

    val decls = module_get_decls()
    val mod_path = module_get_path()

    for did in decls:
        val tag = decl_get_tag(did)

        if tag == DECL_FN:
            val name = decl_get_name(did)
            val ret_type = decl_get_ret_type(did)
            func_table_register(name, did)
            func_register_return_type(name, ret_type)
            irt_track_func(mod_path, name)

        if tag == DECL_EXTERN_FN:
            val name = decl_get_name(did)
            val ret_type = decl_get_ret_type(did)
            func_register_return_type(name, ret_type)
            irt_track_func(mod_path, name)

        if tag == DECL_STRUCT:
            val name = decl_get_name(did)
            struct_table_register(name, did)
            irt_track_struct(mod_path, name)

        if tag == DECL_ENUM:
            val name = decl_get_name(did)
            val variants = decl_get_fields(did)
            # Register enum in registry for variant resolution and exhaustiveness
            enum_table_register(name, variants)
            # Register variant constants as globals (same as eval_decl for DECL_ENUM)
            var vi: i64 = 0
            for variant_name in variants:
                env_define_global(variant_name, val_make_int(vi))
                irt_track_global(mod_path, variant_name)
                vi = vi + 1
            irt_track_enum(mod_path, name)

        if tag == DECL_IMPL:
            # Register impl methods in function table
            val impl_methods = decl_get_body(did)
            for method_did in impl_methods:
                val mtag = decl_get_tag(method_did)
                if mtag == DECL_FN:
                    val mname = decl_get_name(method_did)
                    val mret = decl_get_ret_type(method_did)
                    func_table_register(mname, method_did)
                    func_register_return_type(mname, mret)
                    irt_track_func(mod_path, mname)

fn load_module_parse_only(module_name: text, current_file: text) -> i64:
    val resolved_path = resolve_module_path(module_name, current_file)
    val source = load_module_source(resolved_path)
    if source == "":
        return 0
    parse_module_ast(source, resolved_path)

fn load_module_register_only(module_name: text, current_file: text) -> i64:
    val resolved_path = resolve_module_path(module_name, current_file)
    irt_begin_module(module_name)
    val exports = extract_module_exports()
    register_module_functions()
    module_mark_loaded(module_name, resolved_path, exports)
    1

# ===== SMF Loading Support =====

fn module_loader_enable_smf(prefer_compiled: bool, allow_library: bool, allow_fallback: bool, regenerate: bool):
    _smf_enabled = true
    _smf_prefer_compiled = prefer_compiled
    _smf_allow_library = allow_library
    _smf_allow_fallback = allow_fallback
    _smf_regenerate = regenerate

fn _resolve_smf_path(source_path: text) -> text:
    if source_path == "":
        return ""
    smf_source_to_cache_path(source_path)

fn _check_freshness(source_path: text, smf_path: text) -> bool:
    val cache_key = source_path + "|" + smf_path
    if _smf_freshness_cache.contains_key(cache_key):
        return _smf_freshness_cache[cache_key]
    val fresh = smf_check_freshness(source_path, smf_path) == 1
    _smf_freshness_cache[cache_key] = fresh
    fresh

# ===== Public API =====

fn _load_module_from_source(module_name: text, current_file: text) -> i64:
    val resolved_path = resolve_module_path(module_name, current_file)
    val source = load_module_source(resolved_path)
    if source == "":
        return 0
    val parse_ok = parse_module_ast(source, resolved_path)
    if parse_ok == 0:
        return 0
    irt_begin_module(module_name)
    val exports = extract_module_exports()
    register_module_functions()
    module_mark_loaded(module_name, resolved_path, exports)
    1

fn _load_module_smf_aware(module_name: text, current_file: text) -> i64:
    val source_path = resolve_module_path(module_name, current_file)

    # Step 1: Check for fresh compiled artifact
    if _smf_prefer_compiled:
        val smf_path = _resolve_smf_path(source_path)
        if smf_path != "" and rt_file_exists(smf_path) == 1:
            if _check_freshness(source_path, smf_path):
                # TODO: load compiled module via compiled_module_adapter
                eprint("smf_loader: fresh SMF for {module_name}, falling back to source")

    # Step 2: Check library
    if _smf_allow_library:
        val lib_path = smf_resolve_library(module_name)
        if lib_path != "":
            # TODO: load from library via compiled_module_adapter
            eprint("smf_loader: library module {module_name} at {lib_path}, falling back to source")

    # Step 3: Stale SMF with regeneration
    if _smf_regenerate:
        val smf_path = _resolve_smf_path(source_path)
        if smf_path != "":
            val regen_ok = smf_get_or_generate(source_path, smf_path)
            if regen_ok == 1:
                eprint("smf_loader: regenerated SMF for {module_name}")

    # Step 4: Source fallback
    _load_module_from_source(module_name, current_file)

fn load_module(module_name: text, current_file: text) -> i64:
    # Load a module by name and register its exports
    # Returns 1 on success, 0 on failure

    # Check if already loaded
    if module_is_loaded(module_name) == 1:
        return 1

    # Depth guard: prevent runaway transitive loading
    if _module_load_depth >= _MODULE_LOAD_MAX_DEPTH:
        return 0
    _module_load_depth = _module_load_depth + 1

    var result: i64 = 0
    if _smf_enabled:
        result = _load_module_smf_aware(module_name, current_file)
    else:
        result = _load_module_from_source(module_name, current_file)

    _module_load_depth = _module_load_depth - 1
    result

fn load_module_selective(module_name: text, imported_names: [text], current_file: text) -> i64:
    # Load module and register requested names
    # Returns 1 on success, 0 on failure

    # Check if already loaded
    if module_is_loaded(module_name) == 1:
        return 1

    # Optimization: if all requested names are already in function table,
    # skip loading the module entirely (handles built-in functions)
    var all_available = true
    for name in imported_names:
        if func_table_lookup(name) < 0:
            all_available = false
            break
    if all_available and imported_names.len() > 0:
        module_mark_loaded(module_name, "", imported_names)
        return 1

    # Full load
    val load_ok = load_module(module_name, current_file)
    if load_ok == 0:
        return 0

    1

fn interp_unload_module(module_name: text) -> i64:
    """Selectively unload a module: remove its names from tables.

    Removes all functions, structs, enums, and globals that were
    registered when this module was loaded. Also removes the module
    from the loaded-module tracking set.

    Returns the number of names removed, or 0 if module was not loaded.
    """
    if module_is_loaded(module_name) == 0:
        return 0

    # Remove all tracked names from tables
    val removed = irt_unload_module(module_name)

    # Remove from loaded-module set so it can be reloaded
    loaded_module_set[module_name] = false

    removed
