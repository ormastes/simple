# MIR Lowering — core/mir/lowering.spl
#
# Seed-compatible MIR lowering entry point.
# Used by test_mir_lower.spl (10.frontend core tests).
#
# mlr_lower_module() runs HIR → MIR lowering against the global arena state
# managed by core/mir.spl and core/types.spl.

use compiler.core.ast.{ast_reset}
use compiler.core.types.{reset_all_pools}
use compiler.mir._MirLowering.bootstrap_globals.{bootstrap_lower_hir_globals_to_mir_module_for_target}
use compiler.common.mir_target_context.{mir_target_context_from}
use compiler.frontend.core.cfg_platform.{cfg_detect_arch, cfg_detect_os}

extern fn rt_env_get(key: text) -> text

fn mlr_lower_module():
    """Lower the current in-memory AST + HIR into the MIR global arena.

    Builds the seed-core boundary target context, then delegates to the
    target-aware bootstrap lowerer that registers functions, blocks, and
    instructions in the arenas core/mir.spl interrogates.
    """
    val target_context = mir_target_context_from(
        rt_env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? "",
        cfg_detect_arch(),
        cfg_detect_os(),
        "llvm",
        -1
    )
    val _result = bootstrap_lower_hir_globals_to_mir_module_for_target(target_context)
    pass_dn
