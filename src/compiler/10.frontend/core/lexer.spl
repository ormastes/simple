# Core Simple — Lexer (Tokenizer)
#
# Shared core library: converts source text into a stream of tokens.
# Handles indentation tracking, literals, identifiers, keywords,
# operators, delimiters, and comments.
#
# Design: All state in module-level vars. Functions modify state.
# Works when compiled to C; NOT in the interpreter (closure bug).
#
# Split into modules:
#   lexer_scanners.spl — all scanning functions (number, string, ident,
#                        whitespace, indentation, main token scanner)

val _NL = "\n"
use compiler.core.tokens.{keyword_lookup}
use compiler.core.tokens.{TOK_INT_LIT, TOK_FLOAT_LIT, TOK_STRING_LIT}
use compiler.core.tokens.{TOK_BOOL_LIT, TOK_NIL_LIT, TOK_IDENT}
use compiler.core.tokens.{TOK_KW_FN, TOK_KW_VAL, TOK_KW_VAR}
use compiler.core.tokens.{TOK_KW_TRUE, TOK_KW_FALSE, TOK_KW_NIL}
use compiler.core.tokens.{TOK_PLUS, TOK_MINUS, TOK_STAR, TOK_SLASH, TOK_PERCENT}
use compiler.core.tokens.{TOK_EQ, TOK_NEQ, TOK_LT, TOK_GT, TOK_LEQ, TOK_GEQ}
use compiler.core.tokens.{TOK_SHL, TOK_SHR}
use compiler.core.tokens.{TOK_ASSIGN, TOK_PLUS_ASSIGN, TOK_MINUS_ASSIGN, TOK_WALRUS}
use compiler.core.tokens.{TOK_STAR_ASSIGN, TOK_SLASH_ASSIGN}
use compiler.core.tokens.{TOK_AND, TOK_OR, TOK_NOT}
use compiler.core.tokens.{TOK_LPAREN, TOK_RPAREN, TOK_LBRACKET, TOK_RBRACKET}
use compiler.core.tokens.{TOK_LBRACE, TOK_RBRACE}
use compiler.core.tokens.{TOK_COLON, TOK_COMMA, TOK_DOT, TOK_DOTDOT}
use compiler.core.tokens.{TOK_ARROW, TOK_FAT_ARROW, TOK_PIPE}
use compiler.core.tokens.{TOK_QUESTION, TOK_QUESTION_DOT, TOK_DOUBLE_QUESTION, TOK_DOT_QUESTION}
use compiler.core.tokens.{TOK_NEWLINE, TOK_INDENT, TOK_DEDENT, TOK_EOF, TOK_ERROR}
use compiler.core.tokens.{TOK_HASH_LBRACKET, TOK_DOTDOTDOT, TOK_DOTDOT_EQ}
use compiler.core.tokens.{TOK_SEMICOLON, TOK_AT, TOK_UNDERSCORE}
use compiler.core.tokens.{TOK_PIPE_FORWARD, TOK_DOUBLE_STAR}
use compiler.core.tokens.{TOK_SUFFIXED_INT, TOK_SUFFIXED_FLOAT}
use compiler.core.tokens.{TOK_LABEL, TOK_BACKTICK_IDENT}
use compiler.core.tokens.{TOK_AMPERSAND, TOK_AMP_COLON}
use compiler.core.lexer_chars.{is_digit, is_hex_digit, is_alpha, is_ident_char, is_space}
use compiler.core.lexer_types.{Token, Span, lex_span_new, lex_token_new, lex_token_eof}

# Import from split scanner module
use compiler.core.lexer_scanners.{lex_scan_number, lex_scan_string, lex_scan_ident}
use compiler.core.lexer_scanners.{lex_skip_spaces, lex_handle_indentation, lex_scan_token}

# Light wrapper struct to satisfy callers expecting a Lexer value.
struct Lexer:
    dummy: i64

# ===== Lexer State =====

var lex_state: {text: text} = {}

# ===== Public wrapper API =====

fn lexer_new(source: text) -> Lexer:
    # Initialize global lexer state for the given source and return a thin handle.
    lex_init(source)
    Lexer(dummy: 0)

fn lexer_next_token(self: Lexer) -> Token:
    # Advance the global lexer and build a Token record.
    val kind: i64 = lex_next()
    val text = lex_token_text()
    val line = lex_token_line()
    val col = lex_token_col()
    val span = lex_span_new(0, text.len(), line, col)
    Token(kind: kind, span: span, text: text)

impl Lexer:
    static fn new(source: text) -> Lexer:
        lexer_new(source)

# ===== Lexer Init/State Access =====

fn lex_init(source: text):
    print "[lex_init] 1"
    print "[lex_init] arg_len={source.len()}"
    val owned_source = [source].join("")
    print "[lex_init] owned_len={owned_source.len()}"
    lex_source_set(owned_source)
    print "[lex_init] 2"
    print "[lex_init] stored_len={lex_source_get().len()}"
    lex_pos_set(0)
    print "[lex_init] 3"
    lex_line_set(1)
    print "[lex_init] 4"
    lex_col_set(1)
    print "[lex_init] 5"
    lex_state_set("indent_stack", "0")
    lex_indent_count_set(1)
    print "[lex_init] 6"
    lex_pending_dedents_set(0)
    print "[lex_init] 7"
    lex_at_line_start_set(true)
    print "[lex_init] 8"
    lex_paren_depth_set(0)
    print "[lex_init] 9"
    lex_round_paren_depth_set(0)
    print "[lex_init] 10"
    lex_cur_kind_set(0)
    print "[lex_init] 11"
    lex_cur_text_set("")
    print "[lex_init] 12"
    lex_cur_line_set(0)
    print "[lex_init] 13"
    lex_cur_col_set(0)
    print "[lex_init] 14"
    lex_cur_suffix_set("")
    print "[lex_init] 15"

fn lex_state_get(key: text, fallback: text) -> text:
    lex_state[key] ?? fallback

fn lex_state_set(key: text, value: text):
    lex_state[key] = value

fn lex_source_get() -> text:
    lex_state_get("source", "")

fn lex_source_set(value: text):
    lex_state_set("source", value)

fn lex_pos_get() -> i64:
    lex_state_get("pos", "0").to_int()

fn lex_pos_set(value: i64):
    lex_state_set("pos", "{value}")

fn lex_line_get() -> i64:
    lex_state_get("line", "1").to_int()

fn lex_line_set(value: i64):
    lex_state_set("line", "{value}")

fn lex_col_get() -> i64:
    lex_state_get("col", "1").to_int()

fn lex_col_set(value: i64):
    lex_state_set("col", "{value}")

fn lex_indent_count_get() -> i64:
    lex_state_get("indent_count", "1").to_int()

fn lex_indent_count_set(value: i64):
    lex_state_set("indent_count", "{value}")

fn lex_pending_dedents_get() -> i64:
    lex_state_get("pending_dedents", "0").to_int()

fn lex_pending_dedents_set(value: i64):
    lex_state_set("pending_dedents", "{value}")

fn lex_at_line_start_get() -> bool:
    val raw = lex_state_get("at_line_start", "1")
    raw == "1" or raw == "true"

fn lex_at_line_start_set(value: bool):
    if value:
        lex_state_set("at_line_start", "1")
    else:
        lex_state_set("at_line_start", "0")

fn lex_paren_depth_get() -> i64:
    lex_state_get("paren_depth", "0").to_int()

fn lex_paren_depth_set(value: i64):
    lex_state_set("paren_depth", "{value}")

fn lex_round_paren_depth_get() -> i64:
    lex_state_get("round_paren_depth", "0").to_int()

fn lex_round_paren_depth_set(value: i64):
    lex_state_set("round_paren_depth", "{value}")

fn lex_cur_kind_get_slot() -> i64:
    lex_state_get("cur_kind", "0").to_int()

fn lex_cur_kind_set(value: i64):
    lex_state_set("cur_kind", "{value}")

fn lex_cur_line_get_slot() -> i64:
    lex_state_get("cur_line", "0").to_int()

fn lex_cur_line_set(value: i64):
    lex_state_set("cur_line", "{value}")

fn lex_cur_col_get_slot() -> i64:
    lex_state_get("cur_col", "0").to_int()

fn lex_cur_col_set(value: i64):
    lex_state_set("cur_col", "{value}")

fn lex_cur_text_get_slot() -> text:
    lex_state_get("cur_text", "")

fn lex_cur_text_set(value: text):
    lex_state_set("cur_text", value)

fn lex_cur_suffix_get_slot() -> text:
    lex_state_get("cur_suffix", "")

fn lex_cur_suffix_set(value: text):
    lex_state_set("cur_suffix", value)

fn lex_indent_stack_len() -> i64:
    lex_indent_count_get()

fn lex_indent_stack_top() -> i64:
    val stack_text = lex_state_get("indent_stack", "0")
    if stack_text == "" or stack_text == nil:
        return 0
    val last_comma = stack_text.rfind(",")
    if last_comma < 0:
        return stack_text.to_int()
    stack_text.substring(last_comma + 1).to_int()

fn lex_indent_stack_push(value: i64):
    lex_state_set("indent_stack", lex_state_get("indent_stack", "0") + "," + "{value}")
    lex_indent_count_set(lex_indent_count_get() + 1)

fn lex_indent_stack_pop() -> i64:
    val stack_text = lex_state_get("indent_stack", "0")
    if stack_text == "" or stack_text == nil:
        return 0
    val last_comma = stack_text.rfind(",")
    if last_comma < 0:
        val value = stack_text.to_int()
        lex_state_set("indent_stack", "")
        lex_indent_count_set(0)
        return value
    val value = stack_text.substring(last_comma + 1).to_int()
    lex_state_set("indent_stack", stack_text.substring(0, last_comma))
    lex_indent_count_set(lex_indent_count_get() - 1)
    value

fn lex_at_end() -> bool:
    lex_pos_get() >= lex_source_get().len()

fn lex_peek() -> text:
    val pos = lex_pos_get()
    val source = lex_source_get()
    if pos >= source.len():
        return ""
    source[pos:pos + 1]

fn lex_peek_next() -> text:
    val next_pos: i64 = lex_pos_get() + 1
    val source = lex_source_get()
    if next_pos >= source.len():
        return ""
    source[next_pos:next_pos + 1]

fn lex_peek_at(offset: i64) -> text:
    val target: i64 = lex_pos_get() + offset
    val source = lex_source_get()
    if target >= source.len():
        return ""
    source[target:target + 1]

fn lex_advance() -> text:
    val pos = lex_pos_get()
    val source = lex_source_get()
    if pos >= source.len():
        return ""
    val c: text = source[pos:pos + 1]
    lex_pos_set(pos + 1)
    if c == _NL:
        lex_line_set(lex_line_get() + 1)
        lex_col_set(1)
        lex_at_line_start_set(true)
    else:
        lex_col_set(lex_col_get() + 1)
    c

fn lex_match_char(expected: text) -> bool:
    val pos = lex_pos_get()
    val source = lex_source_get()
    if pos >= source.len():
        return false
    if source[pos:pos + 1] != expected:
        return false
    lex_pos_set(pos + 1)
    lex_col_set(lex_col_get() + 1)
    true

# ===== Token Construction =====

fn lex_make_token(kind: i64, token_text: text, start_line: i64, start_col: i64):
    lex_cur_kind_set(kind)
    lex_cur_text_set(token_text)
    lex_cur_line_set(start_line)
    lex_cur_col_set(start_col)

fn lex_make_simple(kind: i64, token_text: text):
    lex_make_token(kind, token_text, lex_line_get(), lex_col_get())

# ===== Public API =====

fn lex_next() -> i64:
    print "[lex_next] source_len={lex_source_get().len()}"
    if lex_pos_get() == 0 and lex_source_get() != "":
        if lex_line_get() <= 0:
            lex_line_set(1)
        if lex_col_get() <= 0:
            lex_col_set(1)
        if not lex_at_line_start_get():
            lex_at_line_start_set(true)
    print "[lex_next] enter pending={lex_pending_dedents_get()} at_line_start={lex_at_line_start_get()} pos={lex_pos_get()}"
    # Check for pending dedents
    if lex_pending_dedents_get() > 0:
        lex_pending_dedents_set(lex_pending_dedents_get() - 1)
        lex_cur_kind_set(TOK_DEDENT)
        lex_cur_text_set("")
        print "[lex_next] pending-dedent"
        return TOK_DEDENT

    lex_scan_token()
    print "[lex_next] kind={lex_cur_kind_get_slot()} text={lex_cur_text_get_slot()}"
    return lex_cur_kind_get_slot()

fn lex_token_kind() -> i64:
    lex_cur_kind_get_slot()

fn lex_token_text() -> text:
    lex_cur_text_get_slot()

fn lex_token_line() -> i64:
    lex_cur_line_get_slot()

fn lex_token_col() -> i64:
    lex_cur_col_get_slot()

fn lex_cur_kind_get() -> i64:
    lex_cur_kind_get_slot()

fn lex_cur_text_get() -> text:
    lex_cur_text_get_slot()

fn lex_cur_line_get() -> i64:
    lex_cur_line_get_slot()

fn lex_cur_col_get() -> i64:
    lex_cur_col_get_slot()

fn lex_cur_suffix_get() -> text:
    lex_cur_suffix_get_slot()

# ===== Convenience: Tokenize All =====
# Tokenizes entire source and returns arrays of token data.
# Useful for testing and debugging.

var lex_all_kinds: [i64] = []
var lex_all_texts: [text] = []
var lex_all_lines: [i64] = []
var lex_all_cols: [i64] = []

fn lex_tokenize_all(source: text) -> i64:
    lex_init(source)
    lex_all_kinds.clear()
    lex_all_texts.clear()
    lex_all_lines.clear()
    lex_all_cols.clear()

    for i in 0..1000000:
        val kind: i64 = lex_next()
        lex_all_kinds.push(kind)
        lex_all_texts.push(lex_cur_text_get_slot())
        lex_all_lines.push(lex_cur_line_get_slot())
        lex_all_cols.push(lex_cur_col_get_slot())
        if kind == TOK_EOF:
            break

    lex_all_kinds.len()

export Lexer, lexer_new, lexer_next_token
export lex_init, lex_next, lex_token_kind, lex_token_text, lex_token_line, lex_token_col
export lex_cur_kind_get, lex_cur_text_get, lex_cur_line_get, lex_cur_col_get, lex_cur_suffix_get
export lex_indent_stack_len, lex_indent_stack_top, lex_indent_stack_push, lex_indent_stack_pop
