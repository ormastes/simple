# Core Simple — Lexer (Tokenizer)
#
# Shared core library: converts source text into a stream of tokens.
# Handles indentation tracking, literals, identifiers, keywords,
# operators, delimiters, and comments.
#
# Design: All state in module-level vars. Functions modify state.
# Works when compiled to C; NOT in the interpreter (closure bug).
#
# Split into modules:
#   lexer_scanners.spl — all scanning functions (number, string, ident,
#                        whitespace, indentation, main token scanner)

val _NL = "\n"
use compiler.core.tokens.{keyword_lookup}
use compiler.core.tokens.{TOK_INT_LIT, TOK_FLOAT_LIT, TOK_STRING_LIT}
use compiler.core.tokens.{TOK_BOOL_LIT, TOK_NIL_LIT, TOK_IDENT}
use compiler.core.tokens.{TOK_KW_FN, TOK_KW_VAL, TOK_KW_VAR}
use compiler.core.tokens.{TOK_KW_TRUE, TOK_KW_FALSE, TOK_KW_NIL}
use compiler.core.tokens.{TOK_PLUS, TOK_MINUS, TOK_STAR, TOK_SLASH, TOK_PERCENT}
use compiler.core.tokens.{TOK_EQ, TOK_NEQ, TOK_LT, TOK_GT, TOK_LEQ, TOK_GEQ}
use compiler.core.tokens.{TOK_SHL, TOK_SHR}
use compiler.core.tokens.{TOK_ASSIGN, TOK_PLUS_ASSIGN, TOK_MINUS_ASSIGN, TOK_WALRUS}
use compiler.core.tokens.{TOK_STAR_ASSIGN, TOK_SLASH_ASSIGN}
use compiler.core.tokens.{TOK_AND, TOK_OR, TOK_NOT}
use compiler.core.tokens.{TOK_LPAREN, TOK_RPAREN, TOK_LBRACKET, TOK_RBRACKET}
use compiler.core.tokens.{TOK_LBRACE, TOK_RBRACE}
use compiler.core.tokens.{TOK_COLON, TOK_COMMA, TOK_DOT, TOK_DOTDOT}
use compiler.core.tokens.{TOK_ARROW, TOK_FAT_ARROW, TOK_PIPE}
use compiler.core.tokens.{TOK_QUESTION, TOK_QUESTION_DOT, TOK_DOUBLE_QUESTION, TOK_DOT_QUESTION}
use compiler.core.tokens.{TOK_NEWLINE, TOK_INDENT, TOK_DEDENT, TOK_EOF, TOK_ERROR}
use compiler.core.tokens.{TOK_HASH_LBRACKET, TOK_DOTDOTDOT, TOK_DOTDOT_EQ}
use compiler.core.tokens.{TOK_SEMICOLON, TOK_AT, TOK_UNDERSCORE}
use compiler.core.tokens.{TOK_PIPE_FORWARD, TOK_DOUBLE_STAR}
use compiler.core.tokens.{TOK_SUFFIXED_INT, TOK_SUFFIXED_FLOAT}
use compiler.core.tokens.{TOK_LABEL, TOK_BACKTICK_IDENT}
use compiler.core.tokens.{TOK_AMPERSAND, TOK_AMP_COLON}
use compiler.core.lexer_chars.{is_digit, is_hex_digit, is_alpha, is_ident_char, is_space}
use compiler.core.lexer_types.{Token, Span, lex_span_new, lex_token_new, lex_token_eof}
use std.string_core.{char_code, char_from_code}
use compiler.core.lexer_struct.{CoreLexer, make_core_lexer, core_lexer_next_token, core_lexer_token_text, core_lexer_token_line, core_lexer_token_col}
use compiler.core.ast.{module_get_path}
use compiler.core.ast.{lexer_core_pos_get, lexer_core_pos_set, lexer_core_line_get, lexer_core_line_set}
use compiler.core.ast.{lexer_core_col_get, lexer_core_col_set, lexer_core_pending_dedents_get, lexer_core_pending_dedents_set}
use compiler.core.ast.{lexer_core_at_line_start_get, lexer_core_at_line_start_set, lexer_core_paren_depth_get, lexer_core_paren_depth_set}
use compiler.core.ast.{lexer_core_cur_kind_get, lexer_core_cur_kind_set, lexer_core_cur_text_get, lexer_core_cur_text_set}
use compiler.core.ast.{lexer_core_cur_line_get, lexer_core_cur_line_set, lexer_core_cur_col_get, lexer_core_cur_col_set}
use compiler.core.ast.{lexer_core_indent_stack_get, lexer_core_indent_stack_set}
use compiler.core.ast.{lexer_cur_kind2_get, lexer_cur_kind2_set, lexer_cur_text2_get, lexer_cur_text2_set}
use compiler.core.ast.{lexer_cur_line2_get, lexer_cur_line2_set, lexer_cur_col2_get, lexer_cur_col2_set}
use compiler.core.ast.{lexer_cur_suffix2_get, lexer_cur_suffix2_set}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool

# Import from split scanner module
use compiler.core.lexer_scanners.{lex_scan_number, lex_scan_string, lex_scan_ident}
use compiler.core.lexer_scanners.{lex_skip_spaces, lex_handle_indentation, lex_scan_token}

# Light wrapper struct to satisfy callers expecting a Lexer value.
struct Lexer:
    dummy: i64

struct LexSourceBuffer:
    content: text

# ===== Lexer State =====

var lex_state: {text: text} = {}
var lex_source_char_count_slot: [i64] = [0]
var lex_source_code_base_slot: [i64] = [0]
var lex_source_codes: [i64] = []

# ===== Public wrapper API =====

fn lexer_new(source: text) -> Lexer:
    # Initialize global lexer state for the given source and return a thin handle.
    lex_init(source)
    Lexer(dummy: 0)

fn lexer_next_token(self: Lexer) -> Token:
    # Advance the global lexer and build a Token record.
    val kind: i64 = lex_next()
    val text = lex_token_text()
    val line = lex_token_line()
    val col = lex_token_col()
    val span = lex_span_new(0, text.len(), line, col)
    Token(kind: kind, span: span, text: text)

impl Lexer:
    static fn new(source: text) -> Lexer:
        lexer_new(source)

# ===== Lexer Init/State Access =====

fn lex_init(source: text):
    lex_init_with_path(source, "")

fn lex_init_with_path(source: text, source_path: text):
    print "[lex_init_with_path] 1 source_len={source.len()} path={source_path}"
    print "[lex_init_with_path] consts ident={TOK_IDENT} error={TOK_ERROR} newline={TOK_NEWLINE} plus={TOK_PLUS}"
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_PATH", source_path)
    val has_path = source_path != ""
    print "[lex_init_with_path] 1a has_path={has_path}"
    if has_path:
        print "[lex_init_with_path] 1b using-module-path"
    else:
        print "[lex_init_with_path] 1e inline-source-ignored"
    print "[lex_init_with_path] 2"
    print "[lex_init_with_path] 2a before-pos"
    lex_state_set("pos", "0")
    lex_state_set("core_pos", "0")
    print "[lex_init_with_path] 2b before-line"
    lex_state_set("line", "1")
    lex_state_set("core_line", "1")
    print "[lex_init_with_path] 2c before-col"
    lex_state_set("col", "1")
    lex_state_set("core_col", "1")
    print "[lex_init_with_path] 2d before-pending"
    lex_state_set("pending_dedents", "0")
    lex_state_set("core_pending_dedents", "0")
    print "[lex_init_with_path] 2e before-line-start"
    lex_state_set("at_line_start", "1")
    lex_state_set("core_at_line_start", "1")
    print "[lex_init_with_path] 2f before-paren"
    lex_state_set("paren_depth", "0")
    lex_state_set("round_paren_depth", "0")
    lex_state_set("core_paren_depth", "0")
    print "[lex_init_with_path] 3"
    lex_state_set("core_cur_kind", "0")
    lex_state_set("core_cur_text", "")
    lex_state_set("core_cur_line", "0")
    lex_state_set("core_cur_col", "0")
    lex_state_set("core_indent_stack", "0")
    lex_state_set("indent_stack", "0")
    lex_state_set("indent_count", "1")
    print "[lex_init_with_path] 4"
    print "[lex_init_with_path] 4a before-cur-kind"
    lex_cur_kind_set(0)
    print "[lex_init_with_path] 4b before-cur-text"
    lex_cur_text_set("")
    print "[lex_init_with_path] 4c before-cur-line"
    lex_cur_line_set(0)
    print "[lex_init_with_path] 4d before-cur-col"
    lex_cur_col_set(0)
    print "[lex_init_with_path] 4e before-cur-suffix"
    lex_cur_suffix_set("")
    print "[lex_init_with_path] 5"
    current_core_lexer_reset_file()
    print "[lex_init_with_path] 6 state-reset"

fn lex_state_get(key: text, fallback: text) -> text:
    rt_env_get("SIMPLE_BOOTSTRAP_STATE_{key}") ?? fallback

fn lex_state_set(key: text, value: text):
    rt_env_set("SIMPLE_BOOTSTRAP_STATE_{key}", value)

fn lex_source_len() -> i64:
    current_core_source_get().len()

fn lex_source_char_at(pos: i64) -> text:
    val source = current_core_source_get()
    val source_len = source.len()
    if pos < 0 or pos >= source_len:
        return ""
    source[pos:pos + 1]

fn lex_source_slice(start: i64, end: i64) -> text:
    val source = current_core_source_get()
    if start < 0:
        start = 0
    val source_len = source.len()
    if end > source_len:
        end = source_len
    if end <= start:
        return ""
    source[start:end]

fn lex_source_set(value: text):
    val source_len = value.len()
    print "[lex_source_set] source_len={source_len}"
    lex_source_code_base_slot[0] = lex_source_codes.len()
    print "[lex_source_set] base={lex_source_code_base_slot[0]}"
    var pos = 0
    while pos < source_len:
        if pos < 4:
            print "[lex_source_set] push pos={pos}"
        lex_source_codes = lex_source_codes.push(char_code(value[pos:pos + 1]))
        pos = pos + 1
    lex_source_char_count_slot[0] = source_len
    val base = lex_source_code_base_slot[0]
    if source_len > 0:
        print "[lex_source_set] first0={char_from_code(lex_source_codes[base])}"
    if source_len > 1:
        print "[lex_source_set] first1={char_from_code(lex_source_codes[base + 1])}"
    print "[lex_source_set] stored_len={lex_source_len()}"

fn lex_pos_get() -> i64:
    lex_state_get("pos", "0").to_int()

fn lex_pos_set(value: i64):
    lex_state_set("pos", "{value}")

fn lex_line_get() -> i64:
    lex_state_get("line", "1").to_int()

fn lex_line_set(value: i64):
    lex_state_set("line", "{value}")

fn lex_col_get() -> i64:
    lex_state_get("col", "1").to_int()

fn lex_col_set(value: i64):
    lex_state_set("col", "{value}")

fn lex_indent_count_get() -> i64:
    lex_state_get("indent_count", "1").to_int()

fn lex_indent_count_set(value: i64):
    lex_state_set("indent_count", "{value}")

fn lex_pending_dedents_get() -> i64:
    lex_state_get("pending_dedents", "0").to_int()

fn lex_pending_dedents_set(value: i64):
    lex_state_set("pending_dedents", "{value}")

fn lex_at_line_start_get() -> bool:
    val raw = lex_state_get("at_line_start", "1")
    raw == "1" or raw == "true"

fn lex_at_line_start_set(value: bool):
    if value:
        lex_state_set("at_line_start", "1")
    else:
        lex_state_set("at_line_start", "0")

fn lex_paren_depth_get() -> i64:
    lex_state_get("paren_depth", "0").to_int()

fn lex_paren_depth_set(value: i64):
    lex_state_set("paren_depth", "{value}")

fn lex_round_paren_depth_get() -> i64:
    lex_state_get("round_paren_depth", "0").to_int()

fn lex_round_paren_depth_set(value: i64):
    lex_state_set("round_paren_depth", "{value}")

fn lex_cur_kind_get_slot() -> i64:
    val raw = rt_env_get("SIMPLE_BOOTSTRAP_LEX_CUR_KIND") ?? ""
    if raw == "" or raw == nil:
        return 0
    raw.to_int()

fn lex_cur_kind_set(value: i64):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_CUR_KIND", "{value}")

fn lex_cur_line_get_slot() -> i64:
    val raw = rt_env_get("SIMPLE_BOOTSTRAP_LEX_CUR_LINE") ?? ""
    if raw == "" or raw == nil:
        return 0
    raw.to_int()

fn lex_cur_line_set(value: i64):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_CUR_LINE", "{value}")

fn lex_cur_col_get_slot() -> i64:
    val raw = rt_env_get("SIMPLE_BOOTSTRAP_LEX_CUR_COL") ?? ""
    if raw == "" or raw == nil:
        return 0
    raw.to_int()

fn lex_cur_col_set(value: i64):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_CUR_COL", "{value}")

fn lex_cur_text_get_slot() -> text:
    rt_env_get("SIMPLE_BOOTSTRAP_LEX_CUR_TEXT") ?? ""

fn lex_cur_text_set(value: text):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_CUR_TEXT", value)

fn lex_cur_suffix_get_slot() -> text:
    rt_env_get("SIMPLE_BOOTSTRAP_LEX_CUR_SUFFIX") ?? ""

fn lex_cur_suffix_set(value: text):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_CUR_SUFFIX", value)

fn current_core_indent_stack_get() -> [i64]:
    val raw = lex_state_get("core_indent_stack", "0")
    if raw == "" or raw == nil:
        return [0]
    var result: [i64] = []
    for part in raw.split(","):
        if part == "":
            continue
        result = result.push(part.to_int())
    if result.len() == 0:
        return [0]
    result

fn current_core_indent_stack_set(values: [i64]):
    var parts: [text] = []
    for value in values:
        parts = parts.push("{value}")
    if parts.len() == 0:
        lex_state_set("core_indent_stack", "0")
        return
    lex_state_set("core_indent_stack", parts.join(","))

fn current_core_source_get() -> text:
    val source_path = rt_env_get("SIMPLE_BOOTSTRAP_LEX_PATH") ?? module_get_path()
    print "[current_core_source_get] path={source_path}"
    if source_path != "":
        val content = rt_file_read_text(source_path) ?? ""
        print "[current_core_source_get] len={content.len()}"
        return content
    ""

fn current_core_indent_stack_parse(raw: text) -> [i64]:
    if raw == "" or raw == nil:
        return [0]
    var result: [i64] = []
    for part in raw.split(","):
        if part == "":
            continue
        result = result.push(part.to_int())
    if result.len() == 0:
        return [0]
    result

fn current_core_indent_stack_format(values: [i64]) -> text:
    var parts: [text] = []
    for value in values:
        parts = parts.push("{value}")
    if parts.len() == 0:
        return "0"
    parts.join(",")

fn current_core_lexer_load() -> CoreLexer:
    var pos = 0
    var line = 1
    var col = 1
    var pending_dedents = 0
    var at_line_start = true
    var paren_depth = 0
    var indent_stack_raw = "0"
    val raw_pos = rt_env_get("SIMPLE_BOOTSTRAP_LEX_POS") ?? ""
    val raw_line = rt_env_get("SIMPLE_BOOTSTRAP_LEX_LINE") ?? ""
    val raw_col = rt_env_get("SIMPLE_BOOTSTRAP_LEX_COL") ?? ""
    val raw_pending = rt_env_get("SIMPLE_BOOTSTRAP_LEX_PENDING") ?? ""
    val raw_line_start = rt_env_get("SIMPLE_BOOTSTRAP_LEX_LINE_START") ?? ""
    val raw_paren = rt_env_get("SIMPLE_BOOTSTRAP_LEX_PAREN") ?? ""
    val raw_indent = rt_env_get("SIMPLE_BOOTSTRAP_LEX_INDENT") ?? ""
    if raw_pos != "":
        pos = raw_pos.to_int()
    if raw_line != "":
        line = raw_line.to_int()
    if raw_col != "":
        col = raw_col.to_int()
    if raw_pending != "":
        pending_dedents = raw_pending.to_int()
    if raw_line_start != "":
        at_line_start = raw_line_start == "1"
    if raw_paren != "":
        paren_depth = raw_paren.to_int()
    if raw_indent != "":
        indent_stack_raw = raw_indent
    val source = current_core_source_get()
    var lexer = make_core_lexer(source)
    print "[current_core_lexer_load] after-make source_len={lexer.source.len()} text_len={lexer.cur_text.len()} line={lexer.line} col={lexer.col}"
    lexer.pos = pos
    lexer.line = line
    lexer.col = col
    lexer.indent_stack = current_core_indent_stack_parse(indent_stack_raw)
    lexer.pending_dedents = pending_dedents
    lexer.at_line_start = at_line_start
    lexer.paren_depth = paren_depth
    lexer.cur_kind = 0
    lexer.cur_text = ""
    lexer.cur_line = 0
    lexer.cur_col = 0
    print "[current_core_lexer_load] after-set source_len={lexer.source.len()} text_len={lexer.cur_text.len()} line={lexer.line} col={lexer.col} pos={lexer.pos}"
    lexer

fn current_core_lexer_save(lexer: CoreLexer):
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_POS", "{lexer.pos}")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_LINE", "{lexer.line}")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_COL", "{lexer.col}")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_PENDING", "{lexer.pending_dedents}")
    if lexer.at_line_start:
        rt_env_set("SIMPLE_BOOTSTRAP_LEX_LINE_START", "1")
    else:
        rt_env_set("SIMPLE_BOOTSTRAP_LEX_LINE_START", "0")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_PAREN", "{lexer.paren_depth}")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_INDENT", current_core_indent_stack_format(lexer.indent_stack))

fn current_core_lexer_reset_file():
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_POS", "0")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_LINE", "1")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_COL", "1")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_PENDING", "0")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_LINE_START", "1")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_PAREN", "0")
    rt_env_set("SIMPLE_BOOTSTRAP_LEX_INDENT", "0")

fn lex_next_token_record() -> Token:
    val kind = lex_next()
    val text = lex_cur_text_get_slot()
    val line = lex_cur_line_get_slot()
    val col = lex_cur_col_get_slot()
    val span = lex_span_new(0, text.len(), line, col)
    Token(kind: kind, span: span, text: text)

fn lex_indent_stack_len() -> i64:
    lex_indent_count_get()

fn lex_indent_stack_top() -> i64:
    val stack_text = lex_state_get("indent_stack", "0")
    if stack_text == "" or stack_text == nil:
        return 0
    val last_comma = stack_text.rfind(",")
    if last_comma < 0:
        return stack_text.to_int()
    stack_text.substring(last_comma + 1).to_int()

fn lex_indent_stack_push(value: i64):
    lex_state_set("indent_stack", lex_state_get("indent_stack", "0") + "," + "{value}")
    lex_indent_count_set(lex_indent_count_get() + 1)

fn lex_indent_stack_pop() -> i64:
    val stack_text = lex_state_get("indent_stack", "0")
    if stack_text == "" or stack_text == nil:
        return 0
    val last_comma = stack_text.rfind(",")
    if last_comma < 0:
        val value = stack_text.to_int()
        lex_state_set("indent_stack", "")
        lex_indent_count_set(0)
        return value
    val value = stack_text.substring(last_comma + 1).to_int()
    lex_state_set("indent_stack", stack_text.substring(0, last_comma))
    lex_indent_count_set(lex_indent_count_get() - 1)
    value

fn lex_at_end() -> bool:
    lex_pos_get() >= lex_source_len()

fn lex_peek() -> text:
    val pos = lex_pos_get()
    lex_source_char_at(pos)

fn lex_peek_next() -> text:
    val next_pos: i64 = lex_pos_get() + 1
    lex_source_char_at(next_pos)

fn lex_peek_at(offset: i64) -> text:
    val target: i64 = lex_pos_get() + offset
    lex_source_char_at(target)

fn lex_advance() -> text:
    val pos = lex_pos_get()
    if pos >= lex_source_len():
        return ""
    val c: text = lex_source_char_at(pos)
    lex_pos_set(pos + 1)
    if c == _NL:
        lex_line_set(lex_line_get() + 1)
        lex_col_set(1)
        lex_at_line_start_set(true)
    else:
        lex_col_set(lex_col_get() + 1)
    c

fn lex_match_char(expected: text) -> bool:
    val pos = lex_pos_get()
    if pos >= lex_source_len():
        return false
    if lex_source_char_at(pos) != expected:
        return false
    lex_pos_set(pos + 1)
    lex_col_set(lex_col_get() + 1)
    true

# ===== Token Construction =====

fn lex_make_token(kind: i64, token_text: text, start_line: i64, start_col: i64):
    if start_col < 8 or kind == 0:
        print "[lex_make_token] kind={kind} text={token_text} line={start_line} col={start_col}"
    lex_cur_kind_set(kind)
    lex_cur_text_set(token_text)
    lex_cur_line_set(start_line)
    lex_cur_col_set(start_col)

fn lex_make_simple(kind: i64, token_text: text):
    lex_make_token(kind, token_text, lex_line_get(), lex_col_get())

fn lex_scan_token_local():
    print "[lex_scan_token_local] enter pos={lex_pos_get()} line={lex_line_get()} col={lex_col_get()} at_line_start={lex_at_line_start_get()}"
    if lex_at_end():
        print "[lex_scan_token_local] at_end"
        val slen: i64 = lex_indent_stack_len()
        if slen > 1:
            lex_indent_stack_pop()
            lex_pending_dedents_set(slen - 2)
            lex_make_token(TOK_DEDENT, "", lex_line_get(), lex_col_get())
            return
        lex_make_token(TOK_EOF, "", lex_line_get(), lex_col_get())
        return

    if lex_at_line_start_get():
        print "[lex_scan_token_local] line-start"
        if lex_round_paren_depth_get() > 0:
            lex_at_line_start_set(false)
            lex_skip_spaces()
            lex_scan_token_local()
            return
        lex_cur_kind_set(0)
        lex_handle_indentation()
        print "[lex_scan_token_local] after-indent kind={lex_cur_kind_get_slot()} pos={lex_pos_get()} line={lex_line_get()} col={lex_col_get()} at_line_start={lex_at_line_start_get()}"
        if lex_cur_kind_get_slot() != 0:
            return
        lex_scan_token_local()
        return

    lex_skip_spaces()

    if lex_at_end():
        val slen: i64 = lex_indent_stack_len()
        if slen > 1:
            lex_indent_stack_pop()
            lex_pending_dedents_set(slen - 2)
            lex_make_token(TOK_DEDENT, "", lex_line_get(), lex_col_get())
            return
        lex_make_token(TOK_EOF, "", lex_line_get(), lex_col_get())
        return

    val start_line: i64 = lex_line_get()
    val start_col: i64 = lex_col_get()
    val c: text = lex_peek()
    print "[lex_scan_token_local] c={c}"

    if c == _NL:
        lex_advance()
        lex_at_line_start_set(true)
        if lex_round_paren_depth_get() > 0:
            lex_scan_token_local()
            return
        lex_make_token(TOK_NEWLINE, _NL, start_line, start_col)
        return

    if c == "#":
        val next: text = lex_peek_next()
        if next == "[":
            lex_advance()
            lex_advance()
            lex_make_token(TOK_HASH_LBRACKET, "#[", start_line, start_col)
            return
        for i in 0..100000:
            val cc: text = lex_peek()
            val done: bool = cc == _NL or cc == ""
            if done:
                break
            lex_advance()
        lex_scan_token_local()
        return

    val is_dquote: bool = c == "\""
    val is_squote: bool = c == "'"
    if is_dquote:
        lex_scan_string()
        return
    if is_squote:
        val after_quote: text = lex_peek_next()
        val is_label: bool = is_alpha(after_quote) or after_quote == "_"
        if is_label:
            lex_advance()
            val label_start: i64 = lex_pos_get()
            for li in 0..1000:
                val lc: text = lex_peek()
                if is_ident_char(lc):
                    lex_advance()
                else:
                    break
            val label_name: text = lex_source_slice(label_start, lex_pos_get())
            lex_make_token(TOK_LABEL, label_name, start_line, start_col)
            return
        lex_scan_string()
        return

    if is_digit(c):
        lex_scan_number()
        return

    val starts_ident: bool = is_alpha(c) or c == "_"
    if starts_ident:
        lex_scan_ident()
        return

    lex_advance()
    if c == "=":
        if lex_match_char("="):
            lex_make_token(TOK_EQ, "==", start_line, start_col)
        elif lex_match_char(">"):
            lex_make_token(TOK_FAT_ARROW, "=>", start_line, start_col)
        else:
            lex_make_token(TOK_ASSIGN, "=", start_line, start_col)
        return

    if c == "!":
        if lex_match_char("="):
            lex_make_token(TOK_NEQ, "!=", start_line, start_col)
        else:
            lex_make_token(TOK_NOT, "!", start_line, start_col)
        return

    if c == "<":
        if lex_match_char("<"):
            lex_make_token(TOK_SHL, "<<", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(TOK_LEQ, "<=", start_line, start_col)
        else:
            lex_make_token(TOK_LT, "<", start_line, start_col)
        return

    if c == ">":
        if lex_match_char(">"):
            lex_make_token(TOK_SHR, ">>", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(TOK_GEQ, ">=", start_line, start_col)
        else:
            lex_make_token(TOK_GT, ">", start_line, start_col)
        return

    lex_make_token(TOK_ERROR, c, start_line, start_col)

# ===== Public API =====

fn lex_next() -> i64:
    print "[lex_next wrapper] before"
    print "[lex_next wrapper] state pending={lex_pending_dedents_get()} pos={lex_pos_get()} line={lex_line_get()} col={lex_col_get()}"
    print "[lex_next wrapper] state source_len={lex_source_len()} text_len={lex_cur_text_get_slot().len()}"
    if lex_pending_dedents_get() > 0:
        lex_pending_dedents_set(lex_pending_dedents_get() - 1)
        lex_cur_kind_set(TOK_DEDENT)
        lex_cur_text_set("")
        lex_cur_line_set(lex_line_get())
        lex_cur_col_set(lex_col_get())
        print "[lex_next wrapper] local kind={TOK_DEDENT}"
        return TOK_DEDENT
    print "[lex_next wrapper] before-scan"
    lex_scan_token_local()
    print "[lex_next wrapper] after-scan"
    print "[lex_next wrapper] local kind={lex_cur_kind_get_slot()}"
    print "[lex_next wrapper] local text={lex_cur_text_get_slot()}"
    print "[lex_next wrapper] local line={lex_cur_line_get_slot()} col={lex_cur_col_get_slot()}"
    lex_cur_kind_get_slot()

fn lex_token_kind() -> i64:
    lex_cur_kind_get_slot()

fn lex_token_text() -> text:
    lex_cur_text_get_slot()

fn lex_token_line() -> i64:
    lex_cur_line_get_slot()

fn lex_token_col() -> i64:
    lex_cur_col_get_slot()

fn lex_cur_kind_get() -> i64:
    lex_cur_kind_get_slot()

fn lex_cur_text_get() -> text:
    lex_cur_text_get_slot()

fn lex_cur_line_get() -> i64:
    lex_cur_line_get_slot()

fn lex_cur_col_get() -> i64:
    lex_cur_col_get_slot()

fn lex_cur_suffix_get() -> text:
    lex_cur_suffix_get_slot()

# ===== Convenience: Tokenize All =====
# Tokenizes entire source and returns arrays of token data.
# Useful for testing and debugging.

var lex_all_kinds: [i64] = []
var lex_all_texts: [text] = []
var lex_all_lines: [i64] = []
var lex_all_cols: [i64] = []

fn lex_tokenize_all(source: text) -> i64:
    lex_init(source)
    lex_all_kinds.clear()
    lex_all_texts.clear()
    lex_all_lines.clear()
    lex_all_cols.clear()

    for i in 0..1000000:
        val kind: i64 = lex_next()
        lex_all_kinds.push(kind)
        lex_all_texts.push(lex_cur_text_get_slot())
        lex_all_lines.push(lex_cur_line_get_slot())
        lex_all_cols.push(lex_cur_col_get_slot())
        if kind == TOK_EOF:
            break

    lex_all_kinds.len()

export Lexer, lexer_new, lexer_next_token
export lex_init, lex_next, lex_token_kind, lex_token_text, lex_token_line, lex_token_col
export lex_cur_kind_get, lex_cur_text_get, lex_cur_line_get, lex_cur_col_get, lex_cur_suffix_get
export lex_indent_stack_len, lex_indent_stack_top, lex_indent_stack_push, lex_indent_stack_pop
