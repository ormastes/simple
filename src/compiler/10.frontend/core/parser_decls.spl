# Parser — Declaration Module
#
# Declaration parsing: fn, extern fn, struct/class, enum.
# Use/export/binding/impl declarations extracted to parser_decls_use.spl.

# Split from src/compiler/10.frontend/core/parser_decls.spl to keep module cohesion under the 800-line source limit.
export use compiler.frontend.core._ParserDecls.fn_struct_decls.*
export use compiler.frontend.core._ParserDecls.enum_module_body.*
export use compiler.frontend.core._ParserDecls.bitfield_aop_arch_decls.*

# Name the public facade owners explicitly so package discovery never mistakes
# the pre-extraction compatibility modules for canonical implementations.
export use compiler.frontend.core._ParserDecls.fn_struct_decls.{
    parse_type_params, parse_fn_decl, parse_extern_fn_decl, parse_struct_decl
}
export use compiler.frontend.core._ParserDecls.enum_module_body.{
    parse_enum_decl, parse_module_body
}
export use compiler.frontend.core._ParserDecls.bitfield_aop_arch_decls.{parse_bitfield_decl}
