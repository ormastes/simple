use compiler.core.parser_decls_use.*

# Import CLI parser
use compiler.core.parser_cli.{parse_cli_decl}

# ===== Helper Functions =====

fn parser_skip_tilde_if_present():
    # Skip ~ prefix for keyword-only parameter marker
    if par_kind_get() == TOK_TILDE:
        parser_advance()

fn parser_expect_param_name():
    # Accept IDENT or SELF as parameter name
    val is_ident: bool = par_kind_get() == TOK_IDENT
    val is_self: bool = par_kind_get() == TOK_KW_SELF
    val is_valid: bool = is_ident or is_self
    if is_valid:
        parser_advance()
    else:
        parser_error("expected parameter name")
        parser_advance()

# ===== Generic Type Parameter Parsing =====

# Module-level generic constraint declarations (populated by `val generic T limits [...]`)
var file_generic_constraints: {text: [text]} = {}
var file_generic_constraint_modes: {text: text} = {}

fn parse_type_param_constraint_list() -> [text]:
    # Parses [f32, i32, f64, i64] or [f32, i32, *] constraint list
    var types: [text] = []
    if par_kind_get() != TOK_LBRACKET:
        return types
    parser_advance()
    for ci in 0..100:
        if par_kind_get() == TOK_RBRACKET:
            break
        if ci > 0:
            if par_kind_get() != TOK_COMMA:
                break
            parser_advance()
        if par_kind_get() == TOK_IDENT:
            types.push(par_text_get())
            parser_advance()
        elif par_kind_get() == TOK_STAR:
            types.push("*")
            parser_advance()
        else:
            break
    parser_expect(TOK_RBRACKET)
    types

fn parse_type_params() -> [text]:
    # Parses <T>, <T, U>, <T limits [f32, i32]>, <T: [f32, i32]>, etc.
    # Returns list of type parameter names (e.g., ["T", "U"])
    # Side effect: populates last_type_param_constraints and last_type_param_modes
    var type_params: [text] = []

    # Check for < token (either TOK_LT or TOK_LT_GENERIC)
    val has_lt: bool = par_kind_get() == TOK_LT
    val has_lt_gen: bool = par_kind_get() == TOK_LT_GENERIC
    val has_generic: bool = has_lt or has_lt_gen
    if not has_generic:
        return type_params

    parser_advance()

    # Parse type parameters with optional inline constraints
    for pi in 0..100:
        if pi > 0:
            if par_kind_get() != TOK_COMMA:
                break
            parser_advance()

        if par_kind_get() != TOK_IDENT:
            if pi == 0:
                parser_error("expected type parameter name")
            break

        val param_name = par_text_get()
        type_params.push(param_name)
        parser_advance()

        # Check for inline constraint: `T limits [...]` or `T: [...]`
        val is_limits: bool = par_kind_get() == TOK_KW_LIMITS
        val is_candidates: bool = par_kind_get() == TOK_KW_CANDIDATES
        val is_colon_constraint: bool = par_kind_get() == TOK_COLON
        if is_limits or is_candidates or is_colon_constraint:
            parser_advance()
            val constraint_types = parse_type_param_constraint_list()
            if constraint_types.len() > 0:
                # Check for * (candidate mode marker)
                var has_star = false
                var filtered: [text] = []
                for ct in constraint_types:
                    if ct == "*":
                        has_star = true
                    else:
                        filtered.push(ct)
                val mode_str = if is_candidates or has_star: "candidate" else: "limit"
                file_generic_constraints[param_name] = filtered
                file_generic_constraint_modes[param_name] = mode_str

    # Expect closing >
    parser_expect(TOK_GT)

    type_params

fn bitfield_backing_bits_from_name(type_name: text) -> i64:
    val primitive_bits = primitive_backing_bits_from_name(type_name)
    if primitive_bits > 0:
        return primitive_bits
    custom_primitive_backing_bits_by_name(type_name)

fn bitfield_field_bits_from_name(type_name: text) -> i64:
    if type_name == "bool":
        return 1
    val primitive_bits = primitive_integer_bit_width_from_name(type_name)
    if primitive_bits > 0:
        return primitive_bits
    custom_primitive_integer_bit_width_by_name(type_name)

fn has_seen_name(names: [text], target: text) -> bool:
    for nm in names:
        if nm == target:
            return true
    false

# ===== Function Declarations =====

fn parse_fn_decl(is_async: i64) -> i64:
    parser_advance()
    val fn_name = par_text_get()
    parser_expect(TOK_IDENT)

    # Parse optional type parameters: fn name<T, U>(...)
    val type_params = parse_type_params()

    parser_expect(TOK_LPAREN)

    var param_names: [text] = []
    var param_types: [i64] = []

    if par_kind_get() != TOK_RPAREN:
        # First parameter (skip ~ keyword-only marker if present)
        parser_skip_tilde_if_present()
        val pname = par_text_get()
        parser_expect_param_name()
        param_names.push(pname)
        var ptype = 0
        if par_kind_get() == TOK_COLON:
            parser_advance()
            ptype = parser_parse_type_with_union()
        param_types.push(ptype)

        for i in 0..100:
            if par_kind_get() != TOK_COMMA:
                break
            parser_advance()
            if par_kind_get() == TOK_RPAREN:
                break
            parser_skip_tilde_if_present()
            val pn = par_text_get()
            parser_expect_param_name()
            param_names.push(pn)
            var pt = 0
            if par_kind_get() == TOK_COLON:
                parser_advance()
                pt = parser_parse_type_with_union()
            param_types.push(pt)

    parser_expect(TOK_RPAREN)

    # Return type
    var ret_type = TYPE_VOID
    if par_kind_get() == TOK_ARROW:
        parser_advance()
        ret_type = parser_parse_type_with_union()

    # Skip optional where clause: where T: Bound
    if par_kind_get() == TOK_KW_WHERE:
        parser_advance()
        # Skip until the body colon
        for where_i in 0..200:
            val at_colon: bool = par_kind_get() == TOK_COLON
            val at_eof: bool = par_kind_get() == TOK_EOF
            if at_colon or at_eof:
                break
            parser_advance()

    # Function body
    parser_expect(TOK_COLON)
    val body = parse_block()

    decl_fn(fn_name, param_names, param_types, ret_type, body, is_async, type_params, 0)

fn parse_extern_fn_decl() -> i64:
    # Already consumed 'extern'
    parser_expect(TOK_KW_FN)
    val fn_name = par_text_get()
    parser_expect(TOK_IDENT)

    # Parse optional type parameters: extern fn name<T>(...)
    val type_params = parse_type_params()

    parser_expect(TOK_LPAREN)

    var param_names: [text] = []
    var param_types: [i64] = []

    if par_kind_get() != TOK_RPAREN:
        val pname = par_text_get()
        parser_expect_param_name()
        param_names.push(pname)
        var ptype = 0
        if par_kind_get() == TOK_COLON:
            parser_advance()
            ptype = parser_parse_type()
        param_types.push(ptype)

        for i in 0..100:
            if par_kind_get() != TOK_COMMA:
                break
            parser_advance()
            if par_kind_get() == TOK_RPAREN:
                break
            val pn = par_text_get()
            parser_expect_param_name()
            param_names.push(pn)
            var pt = 0
            if par_kind_get() == TOK_COLON:
                parser_advance()
                pt = parser_parse_type()
            param_types.push(pt)

    parser_expect(TOK_RPAREN)

    var ret_type = TYPE_VOID
    if par_kind_get() == TOK_ARROW:
        parser_advance()
        ret_type = parser_parse_type()

    decl_extern_fn(fn_name, param_names, param_types, ret_type, type_params, 0)

# ===== @derive Implementation Generator =====

fn generate_derive_impls(struct_idx: i64, traits: [text]):
    """Generate impl blocks for @derive(Trait1, Trait2, ...) on a struct/class."""
    val sname = decl_get_name(struct_idx)
    val fnames = decl_get_fields(struct_idx)
    val nfields = fnames.len()

    # Resolve struct type tag for method signatures
    val type_id = named_type_find(sname)
    var stype_tag: i64 = 0
    if type_id >= 0:
        stype_tag = TYPE_NAMED_BASE + type_id
    else:
        stype_tag = TYPE_ANY

    var derive_method_ids: [i64] = []

    for ti in 0..traits.len():
        val trait_name = traits[ti]

        if trait_name == "Eq":
            # fn __eq__(self, other: T) -> bool:
            #     self.f0 == other.f0 and self.f1 == other.f1 and ...
            var eq_expr: i64 = -1
            for fi in 0..nfields:
                val fname = fnames[fi]
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                val other_e = expr_ident("other", 0)
                val other_f = expr_field_access(other_e, fname, 0)
                val cmp = expr_binary(TOK_EQ, self_f, other_f, 0)
                if eq_expr < 0:
                    eq_expr = cmp
                else:
                    eq_expr = expr_binary(TOK_KW_AND, eq_expr, cmp, 0)
            # Handle zero-field struct: always equal
            if eq_expr < 0:
                eq_expr = expr_bool_lit(1, 0)
            val eq_body_stmt = stmt_expr_stmt(eq_expr, 0)
            var eq_body: [i64] = []
            eq_body.push(eq_body_stmt)
            var eq_pnames: [text] = ["self", "other"]
            var eq_ptypes: [i64] = [stype_tag, stype_tag]
            var eq_tparams: [text] = []
            val eq_m = decl_fn("__eq__", eq_pnames, eq_ptypes, TYPE_BOOL, eq_body, 0, eq_tparams, 0)
            derive_method_ids.push(eq_m)

        elif trait_name == "Hash":
            # fn __hash__(self) -> i64:
            #     var h: i64 = 0
            #     h = h * 31 + self.f0.__hash__()  (or hash via XOR)
            # Simplified: XOR all field hashes with prime multiplier
            var hash_expr: i64 = expr_int_lit(0, 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                # self.field.__hash__() -- method call
                var hash_args: [i64] = []
                val field_hash = expr_method_call(self_f, "__hash__", hash_args, 0)
                # h * 31 + field_hash
                val mul_31 = expr_int_lit(31, 0)
                val h_mul = expr_binary(TOK_STAR, hash_expr, mul_31, 0)
                hash_expr = expr_binary(TOK_PLUS, h_mul, field_hash, 0)
            val hash_body_stmt = stmt_expr_stmt(hash_expr, 0)
            var hash_body: [i64] = []
            hash_body.push(hash_body_stmt)
            var hash_pnames: [text] = ["self"]
            var hash_ptypes: [i64] = [stype_tag]
            var hash_tparams: [text] = []
            val hash_m = decl_fn("__hash__", hash_pnames, hash_ptypes, TYPE_I64, hash_body, 0, hash_tparams, 0)
            derive_method_ids.push(hash_m)

        elif trait_name == "Debug":
            # fn to_string(self) -> text:
            #     "ClassName(f0: " + self.f0.to_string() + ", f1: " + self.f1.to_string() + ")"
            var dbg_expr: i64 = expr_string_lit(sname + "(", 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                if fi > 0:
                    val comma_e = expr_string_lit(", ", 0)
                    dbg_expr = expr_binary(TOK_PLUS, dbg_expr, comma_e, 0)
                val label_e = expr_string_lit(fname + ": ", 0)
                dbg_expr = expr_binary(TOK_PLUS, dbg_expr, label_e, 0)
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                var ts_args: [i64] = []
                val field_str = expr_method_call(self_f, "to_string", ts_args, 0)
                dbg_expr = expr_binary(TOK_PLUS, dbg_expr, field_str, 0)
            val close_e = expr_string_lit(")", 0)
            dbg_expr = expr_binary(TOK_PLUS, dbg_expr, close_e, 0)
            val dbg_body_stmt = stmt_expr_stmt(dbg_expr, 0)
            var dbg_body: [i64] = []
            dbg_body.push(dbg_body_stmt)
            var dbg_pnames: [text] = ["self"]
            var dbg_ptypes: [i64] = [stype_tag]
            var dbg_tparams: [text] = []
            val dbg_m = decl_fn("to_string", dbg_pnames, dbg_ptypes, TYPE_TEXT, dbg_body, 0, dbg_tparams, 0)
            derive_method_ids.push(dbg_m)

        elif trait_name == "Display":
            # Same as Debug for Display — generates to_string
            var disp_expr: i64 = expr_string_lit(sname + "(", 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                if fi > 0:
                    val comma_e = expr_string_lit(", ", 0)
                    disp_expr = expr_binary(TOK_PLUS, disp_expr, comma_e, 0)
                val label_e = expr_string_lit(fname + ": ", 0)
                disp_expr = expr_binary(TOK_PLUS, disp_expr, label_e, 0)
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                var ts_args: [i64] = []
                val field_str = expr_method_call(self_f, "to_string", ts_args, 0)
                disp_expr = expr_binary(TOK_PLUS, disp_expr, field_str, 0)
            val close_e = expr_string_lit(")", 0)
            disp_expr = expr_binary(TOK_PLUS, disp_expr, close_e, 0)
            val disp_body_stmt = stmt_expr_stmt(disp_expr, 0)
            var disp_body: [i64] = []
            disp_body.push(disp_body_stmt)
            var disp_pnames: [text] = ["self"]
            var disp_ptypes: [i64] = [stype_tag]
            var disp_tparams: [text] = []
            val disp_m = decl_fn("to_string", disp_pnames, disp_ptypes, TYPE_TEXT, disp_body, 0, disp_tparams, 0)
            derive_method_ids.push(disp_m)

    # Create impl block for all derived methods
    if derive_method_ids.len() > 0:
        val derive_impl = decl_impl_block(sname, derive_method_ids, 0)
        module_add_decl(derive_impl)

# ===== Struct/Class Declarations =====

fn parse_struct_decl() -> i64:
    parser_advance()
    val struct_name = par_text_get()
    parser_expect(TOK_IDENT)
    par_struct_names.push(struct_name)

    # Parse optional type parameters: class Box<T>:, struct Node<T>:
    val type_params = parse_type_params()

    # Pre-register struct name so type references resolve during parsing
    named_type_register(struct_name, [], [])
    # Handle struct inheritance: struct X(Parent):
    if par_kind_get() == TOK_LPAREN:
        parser_advance()
        # Skip parent type name(s)
        for i in 0..10:
            if par_kind_get() == TOK_RPAREN:
                break
            parser_advance()
        parser_expect(TOK_RPAREN)
    # Handle "with" mixin: struct X with Y:
    if par_kind_get() == TOK_IDENT:
        if par_text_get() == "with":
            parser_advance()
            parser_expect(TOK_IDENT)
    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    var field_names: [text] = []
    var field_types: [i64] = []
    var field_defaults: [i64] = []
    var field_bits: [i64] = []
    var class_method_ids: [i64] = []

    for i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip docstrings in class/struct body
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Associated types: type Item = T (skip for now, just parse and ignore)
        if par_kind_get() == TOK_KW_TYPE:
            parser_advance()
            # Skip: 'type IDENT' or 'type IDENT = Type'
            if par_kind_get() == TOK_IDENT:
                parser_advance()
            if par_kind_get() == TOK_ASSIGN:
                parser_advance()
                parser_parse_type()
            parser_skip_newlines_and_semicolons()
            continue

        # Handle methods in class/struct body
        if par_kind_get() == TOK_KW_STATIC:
            val sm_id = parse_class_body_method(struct_name, true, false)
            if sm_id >= 0:
                class_method_ids.push(sm_id)
            continue
        if par_kind_get() == TOK_KW_FN:
            val fm_id = parse_class_body_method(struct_name, false, false)
            if fm_id >= 0:
                class_method_ids.push(fm_id)
            continue
        if par_kind_get() == TOK_KW_ME:
            val mm_id = parse_class_body_method(struct_name, false, true)
            if mm_id >= 0:
                class_method_ids.push(mm_id)
            continue

        val fname = par_text_get()
        parser_expect(TOK_IDENT)
        parser_expect(TOK_COLON)
        val ftype = parser_parse_type()
        field_names.push(fname)
        field_types.push(ftype)
        var fbits: i64 = -1
        if par_kind_get() == TOK_AT:
            parser_advance()
            if par_kind_get() == TOK_IDENT and par_text_get() == "bits":
                parser_advance()
                parser_expect(TOK_LPAREN)
                if par_kind_get() == TOK_INT_LIT:
                    fbits = parse_int_text(par_text_get())
                    parser_advance()
                else:
                    parser_error("expected integer literal in @bits(N)")
                parser_expect(TOK_RPAREN)
            else:
                parser_error("expected @bits(N) after field type")
        var fdefault: i64 = -1
        if par_kind_get() == TOK_ASSIGN:
            parser_advance()
            fdefault = parse_expr()
        field_defaults.push(fdefault)
        field_bits.push(fbits)
        parser_skip_newlines_and_semicolons()

    val struct_d = decl_struct_def(struct_name, field_names, field_types, field_defaults, field_bits, 0)

    # If class had methods, create an impl block for them
    if class_method_ids.len() > 0:
        val impl_d = decl_impl_block(struct_name, class_method_ids, 0)
        module_add_decl(impl_d)

    struct_d

fn parse_enum_decl() -> i64:
    parser_advance()
    val enum_name = par_text_get()
    parser_expect(TOK_IDENT)

    # Parse optional type parameters: enum Result<T, E>:
    val type_params = parse_type_params()

    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    var variant_names: [text] = []

    for i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip docstrings in enum body
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Skip comments that may appear as idents
        val vname = par_text_get()
        parser_expect(TOK_IDENT)
        # Handle enum variant data: Variant(field: type, ...)
        if par_kind_get() == TOK_LPAREN:
            parser_advance()
            for j in 0..100:
                if par_kind_get() == TOK_RPAREN:
                    break
                if par_kind_get() == TOK_EOF:
                    break
                # Skip field_name: type pairs
                if par_kind_get() == TOK_IDENT:
                    parser_advance()
                    if par_kind_get() == TOK_COLON:
                        parser_advance()
                        parser_parse_type()
                        # Handle optional ? after type
                        if par_kind_get() == TOK_QUESTION:
                            parser_advance()
                elif par_kind_get() == TOK_LBRACKET:
                    parser_parse_type()
                else:
                    parser_advance()
                if par_kind_get() == TOK_COMMA:
                    parser_advance()
            parser_expect(TOK_RPAREN)
        variant_names.push(vname)
        parser_skip_newlines_and_semicolons()

    decl_enum_def(enum_name, variant_names, 0)

# ===== Top-Level Module Parsing =====

fn parse_top_level_visibility() -> text:
    if par_kind_get() == TOK_KW_PUB:
        parser_advance()
        if par_kind_get() == TOK_LPAREN:
            parser_advance()
            var modifier_name = ""
            if par_kind_get() == TOK_IDENT:
                modifier_name = par_text_get()
                parser_advance()
            parser_expect(TOK_RPAREN)
            if modifier_name == "peer":
                return "peer"
            if modifier_name == "up":
                return "up"
            if modifier_name == "friend":
                return "internal"
            if modifier_name == "package":
                return "package"
            if modifier_name != "" and modifier_name != "public":
                parser_warn("unknown visibility modifier `pub(" + modifier_name + ")`; using public")
            return "public"
        return "public"
    if par_kind_get() == TOK_IDENT and par_text_get() == "pri":
        parser_advance()
        return "private"
    "private"

fn finalize_decl_visibility(decl_id: i64, visibility: text) -> i64:
    decl_set_visibility_text(decl_id, visibility)
    decl_id

fn parse_module_decl_with_visibility(loop_index: i64, visibility: text) -> i64:
    if par_kind_get() == TOK_KW_ASYNC:
        parser_advance()
        if par_kind_get() == TOK_KW_FN:
            return finalize_decl_visibility(parse_fn_decl(1), visibility)
        parser_error("expected 'fn' after 'async'")
        return -1
    if par_kind_get() == TOK_KW_FN:
        return finalize_decl_visibility(parse_fn_decl(0), visibility)
    if par_kind_get() == TOK_KW_EXTERN:
        parser_advance()
        return finalize_decl_visibility(parse_extern_fn_decl(), visibility)
    if par_kind_get() == TOK_KW_STRUCT:
        return finalize_decl_visibility(parse_struct_decl(), visibility)
    if par_kind_get() == TOK_KW_ENUM:
        return finalize_decl_visibility(parse_enum_decl(), visibility)
    if par_kind_get() == TOK_KW_CLASS:
        return finalize_decl_visibility(parse_struct_decl(), visibility)
    if par_kind_get() == TOK_KW_VAL:
        return finalize_decl_visibility(parse_val_decl(), visibility)
    if par_kind_get() == TOK_KW_LAZY:
        parser_advance()
        return finalize_decl_visibility(parse_lazy_val_decl(), visibility)
    if par_kind_get() == TOK_KW_VAR:
        return finalize_decl_visibility(parse_var_decl(), visibility)
    if par_kind_get() == TOK_KW_CONST:
        parser_advance()
        if par_kind_get() == TOK_KW_FN:
            val cfd = parse_fn_decl(0)
            decl_set_comptime(cfd)
            return finalize_decl_visibility(cfd, visibility)
        val const_name = par_text_get()
        parser_expect(TOK_IDENT)
        var const_type = 0
        if par_kind_get() == TOK_COLON:
            parser_advance()
            const_type = parser_parse_type_with_union()
        parser_expect(TOK_ASSIGN)
        val const_init = parse_expr()
        return finalize_decl_visibility(decl_val_binding(const_name, const_type, const_init, 0), visibility)
    parser_error("expected declaration after visibility modifier")
    -1

fn parse_module_body():
    for i in 0..100000:
        parser_skip_newlines_and_semicolons()
        if par_kind_get() == TOK_EOF:
            break
        val parsed_visibility = parse_top_level_visibility()
        if parsed_visibility != "private":
            parser_skip_newlines_and_semicolons()
            val visible_decl = parse_module_decl_with_visibility(i, parsed_visibility)
            if visible_decl >= 0:
                module_add_decl(visible_decl)
            continue
        if par_kind_get() == TOK_DEDENT:
            # Stray dedent at module level -- skip it
            parser_advance()
        elif par_kind_get() == TOK_KW_ASYNC:
            # Async function: async fn name()
            parser_advance()
            if par_kind_get() == TOK_KW_FN:
                val d = parse_fn_decl(1)  # 1 = is_async
                module_add_decl(d)
            else:
                parser_error("expected 'fn' after 'async'")
        elif par_kind_get() == TOK_KW_FN:
            val d = parse_fn_decl(0)  # 0 = not async
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_EXTERN:
            parser_advance()
            val d = parse_extern_fn_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_STRUCT:
            val d = parse_struct_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_ENUM:
            val d = parse_enum_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_CLASS:
            # class is treated like struct (fields + methods)
            val d = parse_struct_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_IMPL:
            val d = parse_impl_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_USE:
            val d = parse_use_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_EXPORT:
            val d = parse_export_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_VAL:
            val d = parse_val_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_LAZY:
            parser_advance()
            val d = parse_lazy_val_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_VAR:
            val d = parse_var_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_CONST:
            # const fn name(): or const binding: same as val/fn at module level
            parser_advance()
            if par_kind_get() == TOK_KW_FN:
                # const fn -- parse as normal function with comptime flag
                val cfd = parse_fn_decl(0)
                decl_set_comptime(cfd)
                module_add_decl(cfd)
            else:
                val const_name = par_text_get()
                parser_expect(TOK_IDENT)
                var const_type = 0
                if par_kind_get() == TOK_COLON:
                    parser_advance()
                    const_type = parser_parse_type_with_union()
                parser_expect(TOK_ASSIGN)
                val const_init = parse_expr()
                val cd = decl_val_binding(const_name, const_type, const_init, 0)
                module_add_decl(cd)
        elif par_kind_get() == TOK_KW_IF:
            val if_expr = parse_if_expr()
            val d = decl_val_binding("_if_" + int_to_str(i), -1, if_expr, 0)
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_FOR:
            val for_expr = parse_for_expr()
            val d = decl_val_binding("_for_" + int_to_str(i), -1, for_expr, 0)
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_WHILE:
            val while_expr = parse_while_expr()
            val d = decl_val_binding("_while_" + int_to_str(i), -1, while_expr, 0)
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_IMPORT:
            # import X.{Y, Z} -- treat like use
            val d = parse_use_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_TRAIT:
            # trait is parsed like struct (skip body)
            val d = parse_struct_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_EXTEND:
            # extend TypeName: adds methods to an existing type
            val d = parse_impl_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_BITFIELD:
            val d = parse_bitfield_decl()
            module_add_decl(d)
        elif par_kind_get() == TOK_KW_CLI:
            # cli Name: declarative arg parsing block
            val cli_d = parse_cli_decl()
            module_add_decl(cli_d)
        elif par_kind_get() == TOK_KW_CE:
            # ce NAME: computation expression block at module level
            parser_advance()
            val ce_d = parse_ce_decl()
            module_add_decl(ce_d)
        elif par_kind_get() == TOK_AT:
            # Decorator: @gpu, @gpu_kernel, @simd, @bounds(...), @derive(Eq, Hash, Debug), etc.
            parser_advance()
            var decorator_name = ""
            if par_kind_get() == TOK_IDENT:
                decorator_name = par_text_get()
                parser_advance()
            # Parse parenthesized arguments, collecting ident names for @derive
            var derive_traits: [text] = []
            if par_kind_get() == TOK_LPAREN:
                parser_advance()
                for dec_j in 0..100:
                    val dec_end1: bool = par_kind_get() == TOK_RPAREN
                    val dec_end2: bool = par_kind_get() == TOK_EOF
                    if dec_end1 or dec_end2:
                        break
                    if decorator_name == "derive":
                        if par_kind_get() == TOK_IDENT:
                            derive_traits.push(par_text_get())
                            parser_advance()
                            if par_kind_get() == TOK_COMMA:
                                parser_advance()
                        else:
                            parser_advance()
                    else:
                        parser_advance()
                parser_expect(TOK_RPAREN)
            parser_skip_newlines_and_semicolons()
            if decorator_name == "gpu_kernel" or decorator_name == "gpu":
                if par_kind_get() == TOK_KW_FN or par_kind_get() == TOK_KW_ME:
                    val d = parse_fn_decl(0)
                    decl_is_gpu_kernel[d] = 1
                    module_add_decl(d)
            elif decorator_name == "simd":
                if par_kind_get() == TOK_KW_FN or par_kind_get() == TOK_KW_ME:
                    val d = parse_fn_decl(0)
                    decl_is_simd[d] = 1
                    module_add_decl(d)
            elif decorator_name == "derive":
                val is_class: bool = par_kind_get() == TOK_KW_CLASS
                val is_struct: bool = par_kind_get() == TOK_KW_STRUCT
                if is_class or is_struct:
                    val d = parse_struct_decl()
                    decl_derives[d] = derive_traits
                    module_add_decl(d)
                    # Generate derived trait method implementations
                    generate_derive_impls(d, derive_traits)
        elif par_kind_get() == TOK_KW_NEWTYPE:
            # newtype Meters = i64 -- wrapper struct with single 'value' field
            # For numeric inner types, auto-derives __add__, __sub__, __mul__, __div__, __eq__, __lt__, __gt__
            parser_advance()
            val nt_name = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_ASSIGN)
            val inner_type = parser_parse_type()
            # Pre-register newtype so type references resolve (same as parse_struct_decl)
            par_struct_names.push(nt_name)
            named_type_register(nt_name, ["value"], [inner_type])
            custom_primitive_register(nt_name, inner_type)
            val nt_field_names: [text] = ["value"]
            val nt_field_types: [i64] = [inner_type]
            val nt_field_defaults: [i64] = [-1]
            val nt_field_bits: [i64] = [-1]
            val nt_d = decl_struct_def(nt_name, nt_field_names, nt_field_types, nt_field_defaults, nt_field_bits, 0)
            module_add_decl(nt_d)

            # Check if inner type is numeric — auto-derive operator methods
            val inner_name = type_tag_name(inner_type)
            val is_i64: bool = inner_name == "i64"
            val is_i32: bool = inner_name == "i32"
            val is_i16: bool = inner_name == "i16"
            val is_i8: bool = inner_name == "i8"
            val is_u64: bool = inner_name == "u64"
            val is_u32: bool = inner_name == "u32"
            val is_u16: bool = inner_name == "u16"
            val is_u8: bool = inner_name == "u8"
            val is_f64: bool = inner_name == "f64"
            val is_f32: bool = inner_name == "f32"
            val is_int: bool = inner_name == "Int"
            val is_float: bool = inner_name == "Float"
            val is_numeric_a: bool = is_i64 or is_i32
            val is_numeric_b: bool = is_i16 or is_i8
            val is_numeric_c: bool = is_u64 or is_u32
            val is_numeric_d: bool = is_u16 or is_u8
            val is_numeric_e: bool = is_f64 or is_f32
            val is_numeric_f: bool = is_int or is_float
            val is_numeric_ab: bool = is_numeric_a or is_numeric_b
            val is_numeric_cd: bool = is_numeric_c or is_numeric_d
            val is_numeric_ef: bool = is_numeric_e or is_numeric_f
            val is_numeric_abcd: bool = is_numeric_ab or is_numeric_cd
            val is_numeric: bool = is_numeric_abcd or is_numeric_ef

            if is_numeric:
                # Resolve the newtype's type tag for return types
                val nt_type_id = named_type_find(nt_name)
                var nt_type_tag: i64 = 0
                if nt_type_id >= 0:
                    nt_type_tag = TYPE_NAMED_BASE + nt_type_id
                else:
                    nt_type_tag = inner_type

                var nt_method_ids: [i64] = []

                # Generate arithmetic dunder methods: __add__, __sub__, __mul__, __div__
                # Each: fn __op__(self, other: T) -> T: T(value: self.value OP other.value)
                var arith_ops: [text] = ["__add__", "__sub__", "__mul__", "__div__"]
                var arith_toks: [i64] = [TOK_PLUS, TOK_MINUS, TOK_STAR, TOK_SLASH]
                for ai in 0..4:
                    val op_name = arith_ops[ai]
                    val op_tok = arith_toks[ai]
                    # Build body: self.value OP other.value -> wrap in constructor
                    val self_e = expr_ident("self", 0)
                    val self_val = expr_field_access(self_e, "value", 0)
                    val other_e = expr_ident("other", 0)
                    val other_val = expr_field_access(other_e, "value", 0)
                    val bin_expr = expr_binary(op_tok, self_val, other_val, 0)
                    # Constructor call: TypeName(result) — single positional arg for single-field struct
                    val ctor = expr_ident(nt_name, 0)
                    var ctor_args: [i64] = []
                    ctor_args.push(bin_expr)
                    val ctor_call = expr_call(ctor, ctor_args, 0)
                    val body_stmt = stmt_expr_stmt(ctor_call, 0)
                    var body: [i64] = []
                    body.push(body_stmt)
                    var pnames: [text] = ["self", "other"]
                    var ptypes: [i64] = [nt_type_tag, nt_type_tag]
                    var tparams: [text] = []
                    val m = decl_fn(op_name, pnames, ptypes, nt_type_tag, body, 0, tparams, 0)
                    nt_method_ids.push(m)

                # Generate comparison dunder methods: __eq__, __lt__, __gt__
                # Each: fn __op__(self, other: T) -> bool: self.value OP other.value
                var cmp_ops: [text] = ["__eq__", "__lt__", "__gt__"]
                var cmp_toks: [i64] = [TOK_EQ, TOK_LT, TOK_GT]
                for ci in 0..3:
                    val cmp_name = cmp_ops[ci]
                    val cmp_tok = cmp_toks[ci]
                    val self_c = expr_ident("self", 0)
                    val self_cv = expr_field_access(self_c, "value", 0)
                    val other_c = expr_ident("other", 0)
                    val other_cv = expr_field_access(other_c, "value", 0)
                    val cmp_expr = expr_binary(cmp_tok, self_cv, other_cv, 0)
                    val cmp_body_stmt = stmt_expr_stmt(cmp_expr, 0)
                    var cmp_body: [i64] = []
                    cmp_body.push(cmp_body_stmt)
                    var cpnames: [text] = ["self", "other"]
                    var cptypes: [i64] = [nt_type_tag, nt_type_tag]
                    var ctparams: [text] = []
                    val cm = decl_fn(cmp_name, cpnames, cptypes, TYPE_BOOL, cmp_body, 0, ctparams, 0)
                    nt_method_ids.push(cm)

                # Create impl block for the auto-derived methods
                val nt_impl = decl_impl_block(nt_name, nt_method_ids, 0)
                module_add_decl(nt_impl)

            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_STRING_LIT:
            # Skip module-level docstrings
            parser_advance()
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_KW_TYPE:
            # Type alias: type X = Y -- skip it
            parser_advance()
            # Skip until newline
            for j in 0..1000:
                val type_is_nl: bool = par_kind_get() == TOK_NEWLINE
                val type_is_ded: bool = par_kind_get() == TOK_DEDENT
                val type_is_eof: bool = par_kind_get() == TOK_EOF
                val type_done: bool = type_is_nl or type_is_ded
                val type_done2: bool = type_done or type_is_eof
                if type_done2:
                    break
                parser_advance()
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_KW_ASM:
            val asm_expr = parse_expr()
            val d = decl_val_binding("_asm_" + int_to_str(i), -1, asm_expr, 0)
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_INDENT:
            # Stray indent at module level -- skip it
            parser_advance()
        elif par_kind_get() == TOK_KW_ON:
            # on pc{...} use handler form [priority N]
            val d = parse_aop_advice_decl()
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_KW_FORBID:
            # forbid pc{...} "message"
            val d = parse_arch_rule_decl("forbid")
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == TOK_KW_ALLOW:
            # allow pc{...} "message"
            val d = parse_arch_rule_decl("allow")
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        else:
            # Handle bare 'print' and 'from' at module level
            if par_kind_get() == TOK_IDENT:
                if par_text_get() == "from":
                    # from X import {Y, Z}
                    parser_advance()
                    var from_path: text = ""
                    if par_kind_get() == TOK_IDENT:
                        from_path = par_text_get()
                        parser_advance()
                    for j in 0..100:
                        if par_kind_get() != TOK_DOT:
                            break
                        parser_advance()
                        if par_kind_get() == TOK_IDENT:
                            from_path = from_path + "." + par_text_get()
                            parser_advance()
                        else:
                            break
                    # Expect 'import' keyword
                    if par_kind_get() == TOK_KW_IMPORT:
                        parser_advance()
                    # Parse import list {name1, name2}
                    var from_names: [text] = []
                    val from_has_brace: bool = par_kind_get() == TOK_LBRACE
                    val from_has_paren: bool = par_kind_get() == TOK_LPAREN
                    val from_has_list: bool = from_has_brace or from_has_paren
                    if from_has_list:
                        parser_advance()
                        for j in 0..100:
                            val from_at_end1: bool = par_kind_get() == TOK_RBRACE
                            val from_at_end2: bool = par_kind_get() == TOK_RPAREN
                            val from_at_end: bool = from_at_end1 or from_at_end2
                            if from_at_end:
                                break
                            if par_kind_get() == TOK_EOF:
                                break
                            if par_kind_get() == TOK_IDENT:
                                from_names.push(par_text_get())
                                parser_advance()
                            if par_kind_get() == TOK_COMMA:
                                parser_advance()
                        parser_advance()
                    val fd = decl_use_import(from_path, from_names, 0)
                    module_add_decl(fd)
                    parser_skip_newlines_and_semicolons()
                elif par_text_get() == "comptime":
                    # comptime val name = expr -- evaluated eagerly (treat like val)
                    parser_advance()
                    if par_kind_get() == TOK_KW_VAL or par_kind_get() == TOK_KW_VAR:
                        val d = parse_val_decl()
                        module_add_decl(d)
                    elif par_kind_get() == TOK_KW_FN:
                        val ctfd = parse_fn_decl(0)
                        decl_set_comptime(ctfd)
                        module_add_decl(ctfd)
                    elif par_kind_get() == TOK_COLON:
                        # comptime: block at module level -- wrap body stmts in an expr_block
                        parser_advance()
                        val ct_blk_body = parse_block()
                        val ct_blk_unit = expr_unit(0)
                        val ct_blk_expr = expr_block(ct_blk_body, ct_blk_unit, 0)
                        val ctbd = decl_val_binding("_ct_blk_" + int_to_str(i), -1, ct_blk_expr, 0)
                        module_add_decl(ctbd)
                    else:
                        val ct_expr = parse_expr()
                        val ctd = decl_val_binding("_ct_" + int_to_str(i), -1, ct_expr, 0)
                        module_add_decl(ctd)
                    parser_skip_newlines_and_semicolons()
                elif par_text_get() == "print":
                    parser_advance()
                    val is_nl = par_kind_get() == TOK_NEWLINE
                    val is_ded = par_kind_get() == TOK_DEDENT
                    val is_eof = par_kind_get() == TOK_EOF
                    val no_arg = is_nl or is_ded
                    val no_arg2 = no_arg or is_eof
                    var print_call: i64 = 0
                    if no_arg2:
                        val callee0 = expr_ident("print", 0)
                        var args0: [i64] = []
                        print_call = expr_call(callee0, args0, 0)
                    else:
                        val print_arg = parse_expr()
                        val callee1 = expr_ident("print", 0)
                        var args1: [i64] = []
                        args1.push(print_arg)
                        print_call = expr_call(callee1, args1, 0)
                    val d = decl_val_binding("_expr_" + int_to_str(i), -1, print_call, 0)
                    module_add_decl(d)
                    parser_skip_newlines_and_semicolons()
                else:
                    val expression = parse_expr()
                    val d = decl_val_binding("_expr_" + int_to_str(i), -1, expression, 0)
                    module_add_decl(d)
                    parser_skip_newlines_and_semicolons()
            else:
                # Module-level expression/statement
                val expression = parse_expr()
                val d = decl_val_binding("_expr_" + int_to_str(i), -1, expression, 0)
                module_add_decl(d)
                parser_skip_newlines_and_semicolons()

# ===== Exports =====

# ===== Bitfield Declaration =====

fn parse_bitfield_decl() -> i64:
    # Consume 'bitfield' keyword
    parser_advance()
    val bf_name = par_text_get()
    parser_expect(TOK_IDENT)
    par_struct_names.push(bf_name)

    # Pre-register type name
    named_type_register(bf_name, [], [])

    # Parse backing type: bitfield Name(u32):
    parser_expect(TOK_LPAREN)
    val backing_type = parser_parse_type()
    parser_expect(TOK_RPAREN)
    val backing_name = type_tag_name(backing_type)
    val backing_bits = bitfield_backing_bits_from_name(backing_name)
    if backing_bits == 0:
        parser_error("bitfield backing type must be u8, u16, u32, or u64")

    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    # Parse fields as struct fields with bit-width types
    # The struct gets a single __raw field of the backing type.
    # Additional named fields are also recorded for semantic analysis.
    var field_names: [text] = ["__raw"]
    var field_types: [i64] = [backing_type]
    var field_defaults: [i64] = [-1]
    var field_bits: [i64] = [-1]
    var seen_names: [text] = []
    var used_bits: i64 = 0

    for bf_i in 0..200:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip comments/docstrings
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Field: name: type  OR  _: uN (reserved)
        val field_name = par_text_get()
        val is_underscore: bool = par_kind_get() == TOK_UNDERSCORE
        if is_underscore:
            parser_advance()
        else:
            parser_expect(TOK_IDENT)
        parser_expect(TOK_COLON)
        val field_type = parser_parse_type()
        val field_type_name = type_tag_name(field_type)
        val bit_count = bitfield_field_bits_from_name(field_type_name)
        if bit_count == 0:
            parser_error("bitfield field type must be bool, uN, or iN")
        used_bits = used_bits + bit_count

        # Skip reserved fields (don't add to struct)
        if not is_underscore:
            if has_seen_name(seen_names, field_name):
                parser_error("duplicate bitfield field name: " + field_name)
            seen_names.push(field_name)
            field_names.push(field_name)
            field_types.push(field_type)
            field_defaults.push(-1)
            field_bits.push(bit_count)

        parser_skip_newlines_and_semicolons()

    if backing_bits > 0 and used_bits > backing_bits:
        parser_error("bitfield '" + bf_name + "' uses " + int_to_str(used_bits) + " bits but backing type allows only " + int_to_str(backing_bits))

    decl_struct_def(bf_name, field_names, field_types, field_defaults, field_bits, 0)

# ===== AOP Declaration Parsing =====

fn parse_pointcut_text() -> text:
    # Expects current token to be 'pc' identifier, then '{', collects text to matching '}'
    if par_kind_get() == TOK_IDENT:
        if par_text_get() == "pc":
            parser_advance()
        else:
            parser_error("expected 'pc' before pointcut expression")
            return ""
    else:
        parser_error("expected 'pc' before pointcut expression")
        return ""
    parser_expect(TOK_LBRACE)
    var depth = 1
    var result = ""
    for j in 0..10000:
        if par_kind_get() == TOK_EOF:
            parser_error("unexpected EOF in pointcut expression")
            break
        if par_kind_get() == TOK_LBRACE:
            depth = depth + 1
            result = result + "{"
            parser_advance()
        elif par_kind_get() == TOK_RBRACE:
            depth = depth - 1
            if depth == 0:
                parser_advance()
                break
            result = result + "}"
            parser_advance()
        else:
            if result.len() > 0:
                result = result + " "
            result = result + par_text_get()
            parser_advance()
    result

fn parse_aop_advice_decl() -> i64:
    # on pc{...} use handler form [priority N]
    parser_advance()  # consume 'on'
    val pointcut = parse_pointcut_text()
    parser_expect(TOK_KW_USE)
    val handler = par_text_get()
    parser_expect(TOK_IDENT)
    val form = par_text_get()
    parser_expect(TOK_IDENT)  # before|after_success|after_error|around
    var priority_text = "0"
    if par_kind_get() == TOK_IDENT:
        if par_text_get() == "priority":
            parser_advance()
            if par_kind_get() == TOK_INT_LIT:
                priority_text = par_text_get()
                parser_advance()
    decl_aop_advice(pointcut, handler, form, priority_text, 0)

fn parse_arch_rule_decl(kind: text) -> i64:
    # forbid/allow pc{...} "message"
    parser_advance()  # consume 'forbid' or 'allow'
    val pointcut = parse_pointcut_text()
    var message = ""
    if par_kind_get() == TOK_STRING_LIT:
        message = par_text_get()
        parser_advance()
    decl_arch_rule(kind, pointcut, message, 0)
