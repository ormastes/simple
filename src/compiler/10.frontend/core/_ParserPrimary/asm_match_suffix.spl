fn parse_asm_target_spec() -> i64:
    """Parse target spec: [arch | arch2, os, abi, backend >= ver]
    Returns index into asm_arm_* arena (as spec, not full arm).
    """
    parser_expect(144)
    # Parse arch(es) with pipe grouping
    var archs: [text] = []
    if par_kind_get() == 6:
        archs.push(par_text_get())
        parser_advance()
        # Check for pipe groups: arch | arch2
        for pi in 0..20:
            if par_kind_get() == 121:
                parser_advance()
                if par_kind_get() == 6:
                    archs.push(par_text_get())
                    parser_advance()
                else:
                    parser_error("expected architecture name after '|'")
            else:
                break
    else:
        parser_error("expected architecture name in target spec")

    # Parse optional os, abi, backend (comma-separated)
    var os_val = ""
    var abi_val = ""
    var backend_val = ""
    var ver_ops: [text] = []
    var ver_vals: [i64] = []
    var field_pos = 1  # 1=os, 2=abi, 3=backend

    for fi in 0..3:
        if par_kind_get() != 160:
            break
        parser_advance()
        if par_kind_get() == 169:
            # Wildcard _
            parser_advance()
            field_pos = field_pos + 1
            continue
        if par_kind_get() == 6:
            val field_text = par_text_get()
            parser_advance()
            if field_pos == 1:
                os_val = field_text
            elif field_pos == 2:
                abi_val = field_text
            elif field_pos == 3:
                backend_val = field_text
                # Check for version constraints after backend
                for vi in 0..4:
                    if par_kind_get() == 85:
                        parser_advance()
                        if par_kind_get() == 1 or par_kind_get() == 2:
                            ver_ops.push(">=")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '>='")
                    elif par_kind_get() == 80:
                        # Could be == (two tokens) or a single ==
                        parser_advance()
                        if par_kind_get() == 80:
                            parser_advance()
                        if par_kind_get() == 1 or par_kind_get() == 2:
                            ver_ops.push("==")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '=='")
                    elif par_kind_get() == 82:
                        parser_advance()
                        if par_kind_get() == 1 or par_kind_get() == 2:
                            ver_ops.push("<")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '<'")
                    elif par_kind_get() == 6 and par_text_get() == "~=":
                        parser_advance()
                        if par_kind_get() == 1 or par_kind_get() == 2:
                            ver_ops.push("~=")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '~='")
                    else:
                        break
            field_pos = field_pos + 1
        else:
            parser_error("expected identifier or '_' in target spec")
            break

    parser_expect(145)

    val arm_idx = asm_arm_new(archs, os_val, abi_val, backend_val,
                              ver_ops, ver_vals, "", false, "", false)
    arm_idx

fn parse_int_text(txt: text) -> i64:
    """Parse integer from text (simple decimal)."""
    var result = 0
    for i in 0..txt.len():
        val ch = txt[i]
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.ord() - 48)
    result

fn parse_asm_match() -> i64:
    """Parse asm match: block with case arms.

    Syntax:
        asm match:
            case [spec]: asm_body
            case _: compile_error("msg")
    """
    parser_skip_newlines()
    if par_kind_get() != 181:
        parser_error("expected indented block after 'asm match:'")
        return expr_asm("", 0)
    parser_advance()

    var arm_indices: [i64] = []
    for mi in 0..100:
        parser_skip_newlines()
        if par_kind_get() == 182:
            parser_advance()
            break
        if par_kind_get() == 190:
            break

        # Each arm starts with 'case'
        if par_kind_get() != 44:
            parser_error("expected 'case' in asm match arm")
            parser_advance()
            continue

        parser_advance()  # consume 'case'

        # Check for wildcard: case _:
        if par_kind_get() == 169:
            parser_advance()
            parser_expect(161)

            # Parse body: either compile_error("msg") or asm lines
            parser_skip_newlines()
            if par_kind_get() == 181:
                parser_advance()
                parser_skip_newlines()

            if par_kind_get() == 6 and par_text_get() == "compile_error":
                parser_advance()
                parser_expect(140)
                var err_msg = ""
                if par_kind_get() == 3:
                    err_msg = par_text_get()
                    parser_advance()
                parser_expect(141)
                val arm_idx = asm_arm_new([], "", "", "", [], [], "", true, err_msg, true)
                arm_indices.push(arm_idx)
                # Skip to end of arm
                parser_skip_newlines()
                if par_kind_get() == 182:
                    parser_advance()
            else:
                # Wildcard with asm body
                var asm_lines: [text] = []
                for ai in 0..10000:
                    parser_skip_newlines()
                    if par_kind_get() == 182 or par_kind_get() == 190:
                        break
                    if par_kind_get() == 44:
                        break
                    if par_kind_get() == 3:
                        asm_lines.push(par_text_get())
                        parser_advance()
                    else:
                        parser_advance()
                val asm_text = asm_lines.join("\n")
                val arm_idx = asm_arm_new([], "", "", "", [], [], asm_text, false, "", true)
                arm_indices.push(arm_idx)
                if par_kind_get() == 182:
                    parser_advance()
            continue

        # case [spec]:
        val spec_idx = parse_asm_target_spec()
        parser_expect(161)

        # Parse body: either compile_error("msg") or asm lines
        parser_skip_newlines()
        if par_kind_get() == 181:
            parser_advance()
            parser_skip_newlines()

        if par_kind_get() == 6 and par_text_get() == "compile_error":
            parser_advance()
            parser_expect(140)
            var err_msg = ""
            if par_kind_get() == 3:
                err_msg = par_text_get()
                parser_advance()
            parser_expect(141)
            # Update the arm to be compile_error
            asm_arm_is_compile_error[spec_idx] = true
            asm_arm_error_msg[spec_idx] = err_msg
            arm_indices.push(spec_idx)
            parser_skip_newlines()
            if par_kind_get() == 182:
                parser_advance()
        else:
            # Collect asm body lines
            var asm_lines: [text] = []
            for ai in 0..10000:
                parser_skip_newlines()
                if par_kind_get() == 182 or par_kind_get() == 190:
                    break
                if par_kind_get() == 44:
                    break
                if par_kind_get() == 3:
                    asm_lines.push(par_text_get())
                    parser_advance()
                else:
                    parser_advance()
            val asm_text = asm_lines.join("\n")
            asm_arm_asm_text[spec_idx] = asm_text
            arm_indices.push(spec_idx)
            if par_kind_get() == 182:
                parser_advance()

    return expr_asm_match(arm_indices, 0)

fn parse_asm_assert_expr() -> i64:
    """Parse asm assert [spec] -- compile-time target guard.

    Returns an expression (value is 0/unit in interpreter).
    Uses EXPR_ASM_MATCH with i_val=1 to distinguish from asm match.
    """
    val spec_idx = parse_asm_target_spec()
    return expr_asm_assert(spec_idx, 0)

# ---------------------------------------------------------------------------
# Unit-suffix validation (unit-system-consolidation)
# ---------------------------------------------------------------------------
#
# Numeric literal suffixes (`10_km`, `1.5_kg`) are first-class unit hints.
# When a `UnitRegistry` is attached to the parser environment we validate the
# suffix and emit a diagnostic with a Levenshtein-based "did you mean?" for
# miss cases. Until the registry is wired through the parser env, known-builtin
# primitive suffixes (`_i32`, `_u8`, …) are allowed silently; all other
# alphabetic suffixes pass through untouched and the HIR-lowering pass does
# the authoritative lookup.

fn _is_builtin_primitive_suffix(suf: text) -> bool:
    if suf == "": return false
    if suf == "i8": return true
    if suf == "i16": return true
    if suf == "i32": return true
    if suf == "i64": return true
    if suf == "u8": return true
    if suf == "u16": return true
    if suf == "u32": return true
    if suf == "u64": return true
    if suf == "f32": return true
    if suf == "f64": return true
    if suf == "usize": return true
    if suf == "isize": return true
    false

fn parser_validate_unit_suffix(suf_name: text) -> unit:
    """Parser-time hook for numeric-literal suffix validation.

    Contract:
      * Empty suffix (plain `10`) — no-op.
      * Built-in primitive suffix (`_i32`, `_f64`, …) — no-op.
      * Otherwise — accepted here; HIR lowering resolves against the
        `UnitRegistry` and emits an error with a Levenshtein suggestion
        (see `src/compiler/30.types/units/unit_registry.spl::suggest_unit`)
        if the suffix is unknown.
    This function exists so future parser-env integration can raise diagnostics
    earlier without having to re-plumb the literal sites."""
    if suf_name == "":
        return
    if _is_builtin_primitive_suffix(suf_name):
        return
    # Future: if par_env_has_unit_registry(): look up via unit_registry_lookup,
    # emit parser_error("unknown unit suffix '_" + suf_name + "'; did you mean '_" + nearest + "'?")
    # when miss. For now, accept and defer to HIR lowering.
    ()

export parse_asm_target_spec, parse_int_text
export parse_asm_match, parse_asm_assert_expr
