use compiler.core.parser.{parser_guarded_int_text}
use compiler.core.parser.{parser_has_errors}
use compiler.core.parser.{parser_parse_type}

# Forward declarations for mutual recursion
use compiler.frontend.core.parser_stmts.{parse_block, parse_statement, parse_match_stmt, parse_if_expr}
use compiler.frontend.core.parser_stmts.{parse_match_stmt_tail, parse_match_expr_tail, g33_kw_ident_follow}
use compiler.frontend.core.parser_expr.{parse_expr, parse_not, parse_unary}
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_env_get(key: text) -> text

fn parser_primary_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

fn parser_primary_trace_line_enabled() -> bool:
    parser_primary_trace_enabled() and par_line_get() >= 60

# Parses the tail of a `fn` lambda after the `fn` keyword itself has already
# been consumed by the caller: `(param: Type, ...) -> RetType: body`.
# Shared by the anonymous `fn(...): ...` expression form (below) and the
# named nested-fn statement desugar (`fn NAME(...): body` -> `val NAME = fn(...): body`,
# see parser_stmts.spl parse_statement's TOK_KW_FN case).
fn parse_fn_lambda_after_kw() -> i64:
    # Parse parameter list
    parser_expect(140)
    var fn_param_names: [i64] = []
    if par_kind_get() != 141:
        val fn_p0 = par_text_get()
        if par_kind_get() == 6 or par_kind_get() == 169:
            parser_advance()
            fn_param_names.push(expr_ident(fn_p0, 0))
            if par_kind_get() == 161:
                parser_advance()
                parser_parse_type()
            for fn_pi in 0..100:
                if par_kind_get() != 160:
                    break
                parser_advance()
                if par_kind_get() == 141:
                    break
                val fn_pn = par_text_get()
                if par_kind_get() == 6 or par_kind_get() == 169:
                    parser_advance()
                    fn_param_names.push(expr_ident(fn_pn, 0))
                if par_kind_get() == 161:
                    parser_advance()
                    parser_parse_type()
    parser_expect(141)
    # Optional return type: -> Type
    if par_kind_get() == 167:
        parser_advance()
        parser_parse_type()
    # Expect ':' then body
    parser_expect(161)
    # Block body or expression body (same pattern as backslash lambda)
    var fn_lam_stmts: [i64] = []
    if par_kind_get() == 180 or par_kind_get() == 181:
        parser_skip_newlines()
        var fn_blk: [i64] = []
        if par_kind_get() == 181:
            parser_advance()
        for fn_bi in 0..100000:
            parser_skip_newlines()
            val fn_bk = par_kind_get()
            if fn_bk == 182:
                parser_advance()
                break
            if fn_bk == 141 or fn_bk == 160 or fn_bk == 190:
                break
            val fn_s = parse_statement()
            fn_blk.push(fn_s)
            if parser_has_errors():
                break
            parser_skip_newlines()
        fn_lam_stmts.push(expr_block(fn_blk, -1, 0))
    else:
        val fn_body_e = parse_expr()
        fn_lam_stmts.push(fn_body_e)
    expr_lambda(fn_param_names, fn_lam_stmts, 0)

# Integer literal token text -> value, supporting _ separators and
# 0x/0b/0o prefixes. Shared by plain (kind 1) and suffixed (kind 7) ints
# (suffixed hex like 0x10000000u64 previously hit the decimal-only path).
fn parse_int_literal_text(int_text: text) -> i64:
    if int_text.len() > 2:
        val prefix = int_text[0:2]
        if prefix == "0x":
            # Hex literal: parse digit by digit. int(hc) cannot be used for
            # letters: int("a") numeric-parses and errors ("cannot parse 'a'
            # as i64"), which broke const-eval of any hex literal with an
            # a-f digit (e.g. kernel 0xc... constants).
            val hex_digits = int_text[2:]
            var hex_val = 0
            var hi = 0
            while hi < hex_digits.len():
                val hc = hex_digits[hi:hi+1]
                if hc != "_":
                    var hd = 0
                    val lower = "0123456789abcdef"
                    val upper = "0123456789ABCDEF"
                    var k = 0
                    while k < 16:
                        if lower[k:k+1] == hc or upper[k:k+1] == hc:
                            hd = k
                        k = k + 1
                    hex_val = hex_val * 16 + hd
                hi = hi + 1
            return hex_val
        if prefix == "0b":
            # Binary literal: parse digit by digit
            val bin_digits = int_text[2:]
            var bin_val = 0
            var bi = 0
            while bi < bin_digits.len():
                val bc = bin_digits[bi:bi+1]
                if bc == "1":
                    bin_val = bin_val * 2 + 1
                elif bc == "0":
                    bin_val = bin_val * 2
                bi = bi + 1
            return bin_val
        if prefix == "0o":
            # Octal literal: parse digit by digit
            val oct_digits = int_text[2:]
            var oct_val = 0
            var oi = 0
            while oi < oct_digits.len():
                val oc = oct_digits[oi:oi+1]
                if oc != "_":
                    oct_val = oct_val * 8 + int(oc)
                oi = oi + 1
            return oct_val
    # Decimal -- strip _ separators then parse
    var stripped: text = ""
    var si = 0
    while si < int_text.len():
        val sc = int_text[si:si+1]
        if sc != "_":
            stripped = stripped + sc
        si = si + 1
    var int_val = 0
    if stripped.len() > 0:
        int_val = parser_guarded_int_text(stripped)
    int_val

fn parse_primary_expr() -> i64:
    if parser_primary_trace_line_enabled():
        eprint("[parser-primary] start kind={par_kind_get()} text={par_text_get()} line={par_line_get()} col={par_col_get()}")
    # @annotation(...) -- compile-time introspection built-ins
    # @traits(query, T, ...) desugars to __traits("query", "T", ...)
    # @file, @line, @function desugar to __builtin_file etc.
    if par_kind_get() == 171:
        parser_advance()
        val ann_name = par_text_get()
        if par_kind_get() == 6:
            parser_advance()
        if par_kind_get() == 140:
            parser_advance()
            var at_args: [i64] = []
            # First argument: the annotation name as a string literal
            at_args.push(expr_string_lit(ann_name, 0))
            for at_i in 0..20:
                if par_kind_get() == 141:
                    break
                if par_kind_get() == 160:
                    parser_advance()
                    continue
                if par_kind_get() == 190:
                    break
                # Identifier args (type names) become string literals
                if par_kind_get() == 6:
                    val id_arg = par_text_get()
                    parser_advance()
                    at_args.push(expr_string_lit(id_arg, 0))
                else:
                    val expr_arg = parse_expr()
                    at_args.push(expr_arg)
            parser_expect(141)
            val at_callee = expr_ident("__traits", 0)
            return expr_call(at_callee, at_args, 0)
        # Simple @identifier (no parens): @file, @line, @function
        val at_builtin_name = "__builtin_" + ann_name
        return expr_ident(at_builtin_name, 0)

    # keyof T -- compile-time field name list (sugar for @traits("fields", "T"))
    if par_kind_get() == TOK_KW_KEYOF:
        parser_advance()
        val keyof_type = par_text_get()
        if par_kind_get() == 6:
            parser_advance()
        var keyof_args: [i64] = []
        keyof_args.push(expr_string_lit("fields", 0))
        keyof_args.push(expr_string_lit(keyof_type, 0))
        val keyof_callee = expr_ident("__traits", 0)
        return expr_call(keyof_callee, keyof_args, 0)

    # mixin(code_text) -- compile-time code generation
    # Desugars to __mixin(code_text) builtin call
    if par_kind_get() == 203:
        parser_advance()
        parser_expect(140)
        val mixin_arg = parse_expr()
        parser_expect(141)
        var mixin_args_list: [i64] = []
        mixin_args_list.push(mixin_arg)
        val mixin_callee = expr_ident("__mixin", 0)
        return expr_call(mixin_callee, mixin_args_list, 0)

    # asm "..." | asm: "..." | asm { ... } | asm volatile { ... } | asm match: | asm assert [...]
    if par_kind_get() == 36:
        parser_advance()

        # asm match: -- multi-target dispatch
        if par_kind_get() == 43:
            parser_advance()
            parser_expect(161)
            return parse_asm_match()

        # asm assert [...] -- compile-time target guard (parsed as expression, handled as stmt)
        if par_kind_get() == 6 and par_text_get() == "assert":
            parser_advance()
            return parse_asm_assert_expr()

        if par_kind_get() == 6 and par_text_get() == "volatile":
            parser_advance()

        if par_kind_get() == 140:
            return expr_asm(parse_legacy_parenthesized_asm(), 0)

        if par_kind_get() == 3:
            parser_warn("legacy inline asm syntax; use asm { ... }")
            val inline_asm = par_text_get()
            parser_advance()
            return expr_asm(inline_asm, 0)

        if par_kind_get() == 161:
            parser_warn("legacy inline asm syntax; use asm { ... }")
            parser_advance()
            parser_skip_newlines()
            if par_kind_get() != 181:
                parser_error("expected indented asm block after 'asm:'")
                return expr_asm("", 0)
            parser_advance()
            var asm_lines: [text] = []
            for ai in 0..100000:
                parser_skip_newlines()
                if par_kind_get() == 182:
                    parser_advance()
                    break
                if par_kind_get() == 190:
                    break
                if par_kind_get() == 3:
                    asm_lines.push(par_text_get())
                    parser_advance()
                    continue
                parser_error("expected string literal in asm block")
                for aj in 0..10000:
                    val is_nl = par_kind_get() == 180
                    val is_ded = par_kind_get() == 182
                    val is_eof = par_kind_get() == 190
                    if is_nl or is_ded or is_eof:
                        break
                    parser_advance()
            return expr_asm(asm_lines.join("\n"), 0)

        if par_kind_get() == 142:
            val raw_asm = parse_raw_asm_braced_payload()
            return expr_asm(raw_asm, 0)

        if par_kind_get() == 164:
            # `asm` used as a plain identifier (e.g. `asm.constraints`);
            # the postfix layer parses the field access.
            return expr_ident("asm", 0)

        parser_error("expected string literal, ':' block, or '{...}' after 'asm'")
        return expr_asm("", 0)

    if par_kind_get() == 1:
        val int_text = par_text_get()
        parser_advance()
        return expr_int_lit(parse_int_literal_text(int_text), 0)

    if par_kind_get() == 2:
        val float_text = par_text_get()
        parser_advance()
        return expr_float_lit(float_text, 0)

    if par_kind_get() == 7:
        val suf_text = par_text_get()
        val suf_name = lex_cur_suffix_get()
        parser_advance()
        parser_validate_unit_suffix(suf_name)
        return expr_suffixed_int(parse_int_literal_text(suf_text), suf_name, 0)

    if par_kind_get() == 8:
        val suf_text = par_text_get()
        val suf_name = lex_cur_suffix_get()
        parser_advance()
        parser_validate_unit_suffix(suf_name)
        return expr_suffixed_float(suf_text, suf_name, 0)

    if par_kind_get() == 3:
        val str_text = par_text_get()
        parser_advance()
        return expr_string_lit(str_text, 0)

    if par_kind_get() == 4:
        val bool_text = par_text_get()
        parser_advance()
        if bool_text == "true":
            return expr_bool_lit(1, 0)
        return expr_bool_lit(0, 0)

    if par_kind_get() == 5:
        parser_advance()
        return expr_nil_lit(0)

    if par_kind_get() == 6:
        if par_text_get() == "todo":
            parser_advance()
            val msg = parse_optional_rationale_args()
            if msg == "":
                parser_warn("REQC003: todo requires two strings: todo(\"what remains\", \"hint or issue\")")
            return expr_pass_todo(msg, 0)

    if par_kind_get() == 6:
        val id_name = par_text_get()
        if parser_primary_trace_line_enabled():
            eprint("[parser-primary] ident:start name={id_name}")
        parser_advance()
        if parser_primary_trace_line_enabled():
            eprint("[parser-primary] ident:advanced name={id_name}")
        return expr_ident(id_name, 0)

    if par_kind_get() == 38:
        parser_advance()
        return expr_ident("self", 0)

    if par_kind_get() == 54:
        parser_advance()
        val future_expr = parse_expr()
        return expr_await(future_expr, 0)

    if par_kind_get() == 37:
        parser_advance()
        val value_expr = parse_expr()
        return expr_yield(value_expr, 0)

    # new expr | new() expr | new(alloc) expr — explicit allocation
    if par_kind_get() == 211:
        parser_advance()
        # alloc_kind: 0 = default, 1 = pool, 2 = explicit allocator
        var alloc_kind = 0
        var alloc_expr_id = -1
        # Check for allocator spec: new() or new(allocator)
        if par_kind_get() == 140:
            parser_advance()
            if par_kind_get() == 141:
                # new() — type pool
                parser_advance()
                alloc_kind = 1
            else:
                # new(allocator_expr) — explicit allocator
                alloc_expr_id = parse_expr()
                parser_expect(141)
                alloc_kind = 2
        val inner = parse_expr()
        return expr_new_alloc(alloc_kind, alloc_expr_id, inner, 0)

    if par_kind_get() == 197:
        parser_advance()
        val call_expr = parse_expr()
        return expr_spawn(call_expr, 0)

    if par_kind_get() == 195:
        parser_advance()
        parser_expect(161)
        val do_body = parse_block()
        return expr_do_block(do_body, 0)

    if par_kind_get() == 205:
        # ce NAME: block as expression -- returns last value like do:
        parser_advance()
        var ce_builder_name = par_text_get()
        parser_expect(6)
        parser_expect(161)
        val ce_body = parse_block()
        return expr_do_block(ce_body, 0)

    if par_kind_get() == 193:
        val atom_name = par_text_get()
        parser_advance()
        return expr_atom(atom_name, 0)

    if par_kind_get() == 140:
        parser_advance()
        if par_kind_get() == 141:
            parser_advance()
            return expr_unit(0)
        val inner = parse_expr()
        # G29: tuple literal — (e1, e2, ...)
        if par_kind_get() == 160:
            var tup_elems: [i64] = []
            tup_elems.push(inner)
            while par_kind_get() == 160:
                parser_advance()
                if par_kind_get() == 141:
                    break
                tup_elems.push(parse_expr())
            parser_expect(141)
            return expr_tuple(tup_elems, 0)
        parser_expect(141)
        return inner

    if par_kind_get() == 144:
        # Array literal or list comprehension
        parser_advance()
        # Empty array
        if par_kind_get() == 145:
            parser_advance()
            return expr_array_lit([], 0)
        # For-first comprehension: [for x in items if cond: expr]
        if par_kind_get() == 45:
            parser_advance()
            val comp_iter_var = par_text_get()
            parser_expect(6)
            parser_expect(50)
            val comp_iterable = parse_expr()
            var comp_cond = -1
            if par_kind_get() == 40:
                parser_advance()
                comp_cond = parse_expr()
            parser_expect(161)
            val comp_body = parse_expr()
            parser_expect(145)
            return expr_list_comp(comp_iter_var, comp_iterable, comp_body, comp_cond, 0)
        # Parse first element
        val first_elem = parse_expr()
        # Array-repeat expression: [value; count] (count may be non-literal).
        if par_kind_get() == 163:
            parser_advance()
            val repeat_count = parse_expr()
            parser_expect(145)
            return expr_array_repeat(first_elem, repeat_count, 0)
        # For-last comprehension: [expr for x in items if cond]
        if par_kind_get() == 45:
            parser_advance()
            val comp_iter_var = par_text_get()
            parser_expect(6)
            parser_expect(50)
            val comp_iterable = parse_expr()
            var comp_cond = -1
            if par_kind_get() == 40:
                parser_advance()
                comp_cond = parse_expr()
            parser_expect(145)
            return expr_list_comp(comp_iter_var, comp_iterable, first_elem, comp_cond, 0)
        # Regular array literal: [first, second, ...]
        var elements: [i64] = [first_elem]
        for i in 0..10000:
            if par_kind_get() != 160:
                break
            parser_advance()
            if par_kind_get() == 145:
                break
            elements.push(parse_expr())
        parser_expect(145)
        return expr_array_lit(elements, 0)

    if par_kind_get() == 49:
        parser_advance()
        val is_nl = par_kind_get() == 180
        val is_ded = par_kind_get() == 182
        val is_eof = par_kind_get() == 190
        val no_value = is_nl or is_ded
        val no_val2 = no_value or is_eof
        if no_val2:
            return expr_return_expr(-1, 0)
        val ret_val = parse_expr()
        return expr_return_expr(ret_val, 0)

    if par_kind_get() == 47:
        parser_advance()
        return expr_break_expr(0)

    if par_kind_get() == 48:
        parser_advance()
        return expr_continue_expr(0)

    if par_kind_get() == 52:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            return expr_pass(0)
        return expr_pass_with_msg(msg, 0)

    if par_kind_get() == 183:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_todo requires a comment string: pass_todo(\"what remains\", \"hint or issue\")")
        return expr_pass_todo(msg, 0)

    if par_kind_get() == 184:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_do_nothing requires a comment string: pass_do_nothing(\"reason\")")
        return expr_pass_do_nothing(msg, 0)

    if par_kind_get() == 185:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_dn requires a comment string: pass_dn(\"reason\")")
        return expr_pass_dn(msg, 0)

    if par_kind_get() == 57:
        parser_advance()
        val operand = parse_not()
        return expr_unary(57, operand, 0)

    if par_kind_get() == 61:
        parser_advance()
        val operand = parse_unary()
        return expr_unary(61, operand, 0)

    # Method reference: &:method_name → \__p0: __p0.method_name()
    if par_kind_get() == 210:
        parser_advance()
        if par_kind_get() != 6:
            parser_error("expected method name after '&:'")
            return expr_nil_lit(0)
        val method_name = par_text_get()
        parser_advance()
        var param_names: [i64] = []
        val param = expr_ident("__p0", 0)
        param_names.push(expr_ident("__p0", 0))
        var empty_args: [i64] = []
        val call = expr_method_call(param, method_name, empty_args, 0)
        var body_stmts: [i64] = []
        body_stmts.push(call)
        return expr_lambda(param_names, body_stmts, 0)

    # Backslash lambda: \params: expr  or  \params:\n INDENT stmts DEDENT
    # Syntax: \: expr         — zero params
    #         \x: expr        — single param
    #         \x, y: expr     — multiple params (comma-separated idents before :)
    #         \: (newline+indent block) — block body
    if par_kind_get() == 220:
        parser_advance()
        # Collect parameter names (comma-separated idents) until ':'
        var lam_params: [i64] = []
        if par_kind_get() == 6 or par_kind_get() == 169:
            val p0 = par_text_get()
            parser_advance()
            lam_params.push(expr_ident(p0, 0))
            for lpi in 0..100:
                if par_kind_get() != 160:
                    break
                parser_advance()
                if par_kind_get() != 6 and par_kind_get() != 169:
                    parser_error("expected parameter name after ','")
                    break
                val pn = par_text_get()
                parser_advance()
                lam_params.push(expr_ident(pn, 0))
        # Enable forced indentation BEFORE consuming ':' so the lexer keeps
        # emitting real NEWLINE/INDENT/DEDENT for this lambda's own body even
        # though we may be inside a call's parens (paren_depth > 0), where
        # those tokens are normally suppressed entirely (the whole
        # parenthesized expression is otherwise one logical line). Must be
        # disabled again on every exit path below. See
        # CoreLexer.enable_forced_indentation (lexer_struct.spl).
        lex_enable_forced_indentation()
        # Expect ':'
        parser_expect(161)
        # Block body or expression body. EXPR_LAMBDA's stmts list holds body
        # EXPRESSIONS (eval_lambda contract), so a block body is wrapped in a
        # single EXPR_BLOCK that owns the real statement list.
        #
        # Inside call parens the lexer emits INDENT for the lambda body but no
        # matching DEDENT before ')' (dedents flush later), so parse_block —
        # which requires a DEDENT terminator — cannot be used here. This loop
        # is parse_block's shape plus ')' (141) and ',' (160) as terminators,
        # left unconsumed for the enclosing call parser.
        var lam_stmts: [i64] = []
        if par_kind_get() == 180 or par_kind_get() == 181:
            parser_skip_newlines()
            var blk_stmts: [i64] = []
            var lam_saw_indent = false
            if par_kind_get() == 181:
                parser_advance()
                lam_saw_indent = true
            for blk_i in 0..100000:
                parser_skip_newlines()
                val bk = par_kind_get()
                if bk == 182:
                    parser_advance()
                    break
                if bk == 141 or bk == 160 or bk == 190:
                    # Block ended at the call's closing bracket/comma/eof with
                    # no DEDENT seen (last statement shared its line with the
                    # terminator) — resync the lexer's indent stack manually.
                    if lam_saw_indent:
                        lex_pop_indent()
                    break
                val s = parse_statement()
                blk_stmts.push(s)
                if parser_has_errors():
                    break
                parser_skip_newlines()
            lam_stmts.push(expr_block(blk_stmts, -1, 0))
            lex_disable_forced_indentation()
        else:
            # Expression body (single expression becomes sole body expr)
            val body_e = parse_expr()
            lam_stmts.push(body_e)
            lex_disable_forced_indentation()
        return expr_lambda(lam_params, lam_stmts, 0)

    if par_kind_get() == 169:
        parser_advance()
        return expr_ident("_", 0)

    # Dict literal, dict comprehension, or empty {}
    if par_kind_get() == 142:
        parser_advance()
        var key_exprs: [i64] = []
        var value_exprs: [i64] = []

        # Check for empty dict {}
        if par_kind_get() == 143:
            parser_advance()
            return expr_dict_lit(key_exprs, value_exprs, 0)

        # Dict comprehension for-first: {for x in items if cond: (key, val)}
        if par_kind_get() == 45:
            parser_advance()
            val dc_iter_var = par_text_get()
            parser_expect(6)
            parser_expect(50)
            val dc_iterable = parse_expr()
            var dc_cond = -1
            if par_kind_get() == 40:
                parser_advance()
                dc_cond = parse_expr()
            parser_expect(161)
            # Parse (key, value) tuple
            parser_expect(140)
            val dc_key = parse_expr()
            parser_expect(160)
            val dc_val = parse_expr()
            parser_expect(141)
            parser_expect(143)
            return expr_dict_comp(dc_iter_var, dc_iterable, dc_key, dc_val, dc_cond, 0)

        # Parse first key
        val key = parse_expr()
        parser_expect(161)
        val value = parse_expr()

        # Dict comprehension for-last: {k: v for x in items if cond}
        if par_kind_get() == 45:
            parser_advance()
            val dc_iter_var = par_text_get()
            parser_expect(6)
            parser_expect(50)
            val dc_iterable = parse_expr()
            var dc_cond = -1
            if par_kind_get() == 40:
                parser_advance()
                dc_cond = parse_expr()
            parser_expect(143)
            return expr_dict_comp(dc_iter_var, dc_iterable, key, value, dc_cond, 0)

        # Regular dict literal continues
        key_exprs.push(key)
        value_exprs.push(value)

        # Parse remaining key-value pairs
        for i in 0..10000:
            # Check for comma or closing brace
            if par_kind_get() == 160:
                parser_advance()
                # Allow trailing comma before }
                if par_kind_get() == 143:
                    parser_advance()
                    break
            elif par_kind_get() == 143:
                parser_advance()
                break
            else:
                parser_error("expected , or } in dict literal")
                break

            # Parse next key-value pair
            val next_key = parse_expr()
            key_exprs.push(next_key)
            parser_expect(161)
            val next_value = parse_expr()
            value_exprs.push(next_value)

        return expr_dict_lit(key_exprs, value_exprs, 0)

    # Lambda: \x: expr or \x, y: expr
    if par_kind_get() == 191:
        if par_text_get() == "unexpected character: \\":
            parser_advance()
            # Skip lambda params
            for i in 0..100:
                if par_kind_get() == 161:
                    parser_advance()
                    break
                if par_kind_get() == 190:
                    break
                if par_kind_get() == 180:
                    break
                parser_advance()
            val lbody = parse_expr()
            return lbody

    # Handle keywords that may appear in expression position
    if par_kind_get() == 43:
        # G33: `match` as identifier in expression position (if match: ...)
        parser_advance()
        if g33_kw_ident_follow(par_kind_get()):
            return expr_ident("match", 0)
        # `match` used as a VALUE (e.g. `val r = match n: case 1: 10 case _:
        # 99`). Bug fix: this used to call parse_match_stmt_tail() and return
        # its STATEMENT id here as if it were an expr id -- stmt-arena and
        # expr-arena indices overlap, so the caller (expecting an expr id)
        # silently read whatever unrelated EXPR happened to occupy that
        # numeric slot (wrong-arena type confusion) instead of the match's
        # real value, with no branches emitted downstream at all. Build a
        # genuine expr_match_expr node instead so match-as-a-value is a real
        # expression the rest of the pipeline (HIR MatchCase lowering, the
        # flat-AST bridge) can consume like any other expr.
        return parse_match_expr_tail()
    if par_kind_get() == 40:
        return parse_if_expr()

    # Inline fn lambda: fn(param: Type, ...) -> RetType: body
    # G16: fn keyword (kind 20) in expression position
    if par_kind_get() == 20:
        parser_advance()
        return parse_fn_lambda_after_kw()

    # loop: in EXPRESSION position (e.g. `val x = loop: ... break v`) is not
    # implemented: this fallback used to wrap the body in a plain one-shot
    # `expr_block` with no actual loop control-flow (no back-edge) and no
    # break-value plumbing (the statement-form `break` never carries a
    # value at all — see parser_stmts.spl kind==47), so the whole
    # expression silently evaluated to 0/nil instead of the intended break
    # value (bug #163 remainder). Statement-form `loop:` is unaffected —
    # it is desugared to `while true:` by parse_loop_stmt() in
    # parser_stmts.spl and still works correctly. Fail loudly here instead
    # of silently returning a wrong value.
    if par_kind_get() == 51:
        parser_error("loop-as-expression with break-value is not supported (e.g. `val x = loop: ... break v`); use a `var` plus a statement-form `loop:` / `break` instead")
        parser_advance()
        parser_expect(161)
        val loop_body_stmts = parse_block()
        return expr_nil_lit(0)

    # G26: keyword used as identifier expression (e.g. `after.len()`)
    val pe_kw_name = tok_kind_name(par_kind_get())
    val pe_is_kw = keyword_lookup(pe_kw_name) == par_kind_get()
    if pe_is_kw:
        parser_advance()
        return expr_ident(pe_kw_name, 0)

    parser_error("unexpected token in expression: " + tok_kind_name(par_kind_get()) + " '" + par_text_get() + "'")
    parser_advance()
    expr_nil_lit(0)

# ===== Asm Match/Assert Parsing =====

export parse_primary_expr
