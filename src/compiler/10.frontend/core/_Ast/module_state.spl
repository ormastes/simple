fn module_add_decl(decl_idx: i64):
    val count = ast_module_decl_count_get()
    # Perf: the per-index SIMPLE_BOOTSTRAP_MODULE_DECL_<count> env mirror accumulates
    # one environ entry per top-level decl; across an import closure (parsed into one
    # AST via parse_module_file) that is thousands of entries -> O(N^2) setenv/getenv.
    # Gate it behind bootstrap and array-back module_decl_slots unconditionally
    # (grow past the old 128 cap via push). module_decl_at is env-first/array-fallback
    # and only reads index < count, so the array is always the populated truth in
    # compiled stage4. See bug ast_env_var_quadratic_parse_2026-06-13.
    if rt_env_get_i64("SIMPLE_BOOTSTRAP", 0) == 1 and rt_env_get_i64("SIMPLE_NATIVE_ARENA_DECLS", 0) != 1:
        rt_env_set("SIMPLE_BOOTSTRAP_MODULE_DECL_" + int_to_str(count), int_to_str(decl_idx))
    if count < module_decl_slots.len():
        module_decl_slots[count] = decl_idx
    else:
        module_decl_slots.push(decl_idx)
    ast_module_decl_count_set(count + 1)

fn module_get_decls() -> [i64]:
    val count = ast_module_decl_count_get()
    if count <= 0:
        return []
    var result: [i64] = [module_decl_at(0)]
    var i = 1
    while i < count:
        result.push(module_decl_at(i))
        i = i + 1
    result

fn module_decl_count_get() -> i64:
    ast_module_decl_count_get()

fn module_decl_at(index: i64) -> i64:
    if index < 0 or index >= ast_module_decl_count_get():
        return -1
    if rt_env_get_i64("SIMPLE_NATIVE_ARENA_DECLS", 0) == 1:
        if index >= module_decl_slots.len():
            return -1
        return module_decl_slots[index]
    val env_value = rt_env_get("SIMPLE_BOOTSTRAP_MODULE_DECL_" + int_to_str(index)) ?? ""
    if env_value != "":
        return ast_parse_i64(env_value)
    module_decl_slots[index]

# ===== AST Reset =====

fn ast_reset():
    # DIAGNOSTIC (2026-07-12, flat_bridge_type_index_across_ast_reset): trace
    # every reset with the pre-reset arena sizes so an interleaved reset that
    # clobbers a still-in-flight conversion can be pinpointed. Guarded by an
    # env var so it is inert unless explicitly enabled.
    if rt_env_get_i64("SIMPLE_TRACE_AST_RESET", 0) == 1:
        ast_reset_seq = ast_reset_seq + 1
        print "[ast_reset] seq={ast_reset_seq}"
    # Native binaries may zero-initialize module arrays. Allocate once when
    # needed, then clear in place so every parsed file reuses arena storage.
    if decl_tag == nil:
        decl_tag = []
    if decl_span == nil:
        decl_span = []
    if decl_name == nil:
        decl_name = []
    if decl_params == nil:
        decl_params = []
    if decl_param_names == nil:
        decl_param_names = []
    if decl_param_types == nil:
        decl_param_types = []
    if decl_ret_type == nil:
        decl_ret_type = []
    if decl_body_stmts == nil:
        decl_body_stmts = []
    if decl_body_stmts_flat == nil:
        decl_body_stmts_flat = []
    if decl_field_names == nil:
        decl_field_names = []
    if decl_field_types == nil:
        decl_field_types = []
    if decl_field_defaults == nil:
        decl_field_defaults = []
    if decl_field_bits == nil:
        decl_field_bits = []
    if decl_imports == nil:
        decl_imports = []
    if decl_visibility == nil:
        decl_visibility = []
    if decl_is_async == nil:
        decl_is_async = []
    if decl_is_comptime == nil:
        decl_is_comptime = []
    if decl_type_params == nil:
        decl_type_params = []
    if decl_type_param_constraints == nil:
        decl_type_param_constraints = []
    if decl_type_param_constraint_mode == nil:
        decl_type_param_constraint_mode = []
    if decl_is_lazy == nil:
        decl_is_lazy = []
    if decl_is_gpu_kernel == nil:
        decl_is_gpu_kernel = []
    if decl_is_simd == nil:
        decl_is_simd = []
    if decl_is_packed == nil:
        decl_is_packed = []
    if decl_derives == nil:
        decl_derives = []
    if decl_impl_trait == nil:
        decl_impl_trait = []
    if decl_is_trait == nil:
        decl_is_trait = []
    if decl_is_hardware == nil:
        decl_is_hardware = []
    if decl_clocked_args == nil:
        decl_clocked_args = []
    if decl_vhdl_generic_args == nil:
        decl_vhdl_generic_args = []
    if decl_flatten_struct_output == nil:
        decl_flatten_struct_output = []
    if decl_is_value_type == nil:
        decl_is_value_type = []
    if decl_param_mut_text == nil:
        decl_param_mut_text = []
    if arm_pattern == nil:
        arm_pattern = []
    if arm_guard == nil:
        arm_guard = []
    if arm_body == nil:
        arm_body = []
    if arm_body_flat == nil:
        arm_body_flat = []
    if arm_binding == nil:
        arm_binding = []
    if arm_rationale == nil:
        arm_rationale = []
    if elif_cond == nil:
        elif_cond = []
    if elif_body == nil:
        elif_body = []
    if elif_else == nil:
        elif_else = []
    if module_decls == nil:
        module_decls = []
    if module_decl_slots == nil:
        module_decl_slots = []
    decl_tag.clear()
    decl_span.clear()
    decl_name.clear()
    decl_params.clear()
    decl_param_names.clear()
    decl_param_types.clear()
    decl_ret_type.clear()
    decl_body_stmts.clear()
    decl_body_stmts_flat.clear()
    decl_field_names.clear()
    decl_field_types.clear()
    decl_field_defaults.clear()
    decl_field_bits.clear()
    decl_imports.clear()
    decl_visibility.clear()
    decl_is_async.clear()
    decl_is_comptime.clear()
    decl_type_params.clear()
    decl_type_param_constraints.clear()
    decl_type_param_constraint_mode.clear()
    decl_is_lazy.clear()
    decl_is_gpu_kernel.clear()
    decl_is_simd.clear()
    decl_is_packed.clear()
    decl_derives.clear()
    decl_impl_trait.clear()
    decl_is_trait.clear()
    decl_is_hardware.clear()
    decl_clocked_args.clear()
    decl_vhdl_generic_args.clear()
    decl_flatten_struct_output.clear()
    decl_is_value_type.clear()
    decl_param_mut_text.clear()
    arm_pattern.clear()
    arm_guard.clear()
    arm_body.clear()
    arm_body_flat.clear()
    arm_binding.clear()
    arm_rationale.clear()
    elif_cond.clear()
    elif_body.clear()
    elif_else.clear()
    module_decls.clear()
    module_decl_slots.clear()
    _ast_slots_ensure()
    module_path_slot[0] = ""
    lexer_state_core_pos_slot[0] = "0"
    lexer_state_core_line_slot[0] = "1"
    lexer_state_core_col_slot[0] = "1"
    lexer_state_core_pending_dedents_slot[0] = "0"
    lexer_state_core_at_line_start_slot[0] = "1"
    lexer_state_core_paren_depth_slot[0] = "0"
    lexer_state_core_cur_kind_slot[0] = "0"
    lexer_state_core_cur_text_slot[0] = ""
    lexer_state_core_cur_line_slot[0] = "0"
    lexer_state_core_cur_col_slot[0] = "0"
    lexer_state_core_indent_stack_slot[0] = "0"
    lexer_state_cur_kind_slot[0] = "0"
    lexer_state_cur_text_slot[0] = ""
    lexer_state_cur_line_slot[0] = "0"
    lexer_state_cur_col_slot[0] = "0"
    lexer_state_cur_suffix_slot[0] = ""
    expr_reset()
    stmt_reset()
    ast_decl_count_set(0)
    ast_module_decl_count_set(0)

# ===== Struct Builders for Interpreter =====
# These functions construct Core* structs from the arena arrays
# Needed by the interpreter which expects struct-based access

fn expr_get(idx: i64) -> CoreExpr:
    CoreExpr(
        tag: expr_tag[idx],
        span_id: expr_span[idx],
        span: -1,
        i_val: expr_i_val[idx],
        f_val: expr_f_val[idx],
        s_val: expr_s_val[idx],
        left: expr_left[idx],
        right: expr_right[idx],
        extra: expr_extra[idx],
        args: expr_args[idx],
        stmts: expr_stmts[idx]
    )

fn stmt_get(idx: i64) -> CoreStmt:
    CoreStmt(
        tag: stmt_tag[idx],
        span_id: stmt_span[idx],
        span: -1,
        expr_idx: stmt_expr[idx],
        name: stmt_name[idx],
        type_tag: stmt_type_tag[idx],
        body: stmt_body[idx],
        target: -1,
        value: -1,
        condition: -1,
        op: -1,
        iterator: -1,
        iterable: -1,
        else_body: [],
        elif_conds: [],
        elif_bodies: []
    )

fn decl_get(idx: i64) -> CoreDecl:
    CoreDecl(
        tag: decl_tag[idx],
        span_id: decl_span[idx],
        span: -1,
        name: decl_name[idx],
        param_names: decl_param_names[idx],
        param_types: decl_param_types[idx],
        ret_type: decl_ret_type[idx],
        body_stmts: decl_body_stmts[idx],
        field_names: decl_field_names[idx],
        field_types: decl_field_types[idx],
        field_defaults: decl_field_defaults[idx],
        field_bits: decl_field_bits[idx],
        imports: decl_imports[idx],
        visibility_text: decl_get_visibility_text(idx),
        type_params: decl_type_params[idx],
        is_async: false,
        is_value_type: decl_get_is_value_type(idx) != 0
    )

# ===== Yield Detection Utilities =====
# These access both expr and stmt pools so they stay in the unified module.

fn expr_contains_yield(eid: i64) -> bool:
    if eid < 0: return false
    val tag = expr_tag[eid]
    if tag == EXPR_YIELD: return true
    if tag == EXPR_LAMBDA: return false
    if expr_contains_yield(expr_left[eid]): return true
    if expr_contains_yield(expr_right[eid]): return true
    if expr_contains_yield(expr_extra[eid]): return true
    for arg_eid in expr_args[eid]:
        if expr_contains_yield(arg_eid): return true
    for child_sid in expr_stmts[eid]:
        if stmt_contains_yield(child_sid): return true
    false

fn stmt_contains_yield(sid: i64) -> bool:
    if sid < 0: return false
    if expr_contains_yield(stmt_expr[sid]): return true
    for child_sid in stmt_body[sid]:
        if stmt_contains_yield(child_sid): return true
    false

fn stmts_contain_yield(body_stmts: [i64]) -> bool:
    for sid in body_stmts:
        if stmt_contains_yield(sid): return true
    false

