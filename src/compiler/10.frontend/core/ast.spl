#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Core Simple — Arena-Based AST
#
# Shared core library: AST nodes stored in parallel arrays (arena pattern).
# Each node is referenced by an i64 index. No structs, no enums with
# payloads, no generics, no me methods.
#
# Node types:
#   - Expr (expressions): integer tags in EXPR_* constants  (see ast_expr.spl)
#   - Stmt (statements): integer tags in STMT_* constants   (see ast_stmt.spl)
#   - Decl (declarations): integer tags in DECL_* constants (this file)
#   - Param (function parameters)
#   - Field (struct fields)
#   - MatchArm (match case arms)

# ===== Import from split modules =====
use compiler.core.ast_expr.*
use compiler.core.ast_stmt.*
use compiler.core.ast_types.{CoreExpr, CoreStmt, CoreDecl}

# ===== Declaration Kind Tags =====
val DECL_FN = 1
val DECL_EXTERN_FN = 2
val DECL_STRUCT = 3
val DECL_VAL = 4
val DECL_VAR = 5
val DECL_USE = 6
val DECL_EXPORT = 7
val DECL_ENUM = 8
val DECL_IMPL = 9
val DECL_CLASS = 10
val DECL_CE = 11         # ce NAME: computation expression invocation
val DECL_LAZY_VAL = 12   # lazy val name = expr (module-level deferred init)
val DECL_CLI = 13        # cli Name: declarative arg parsing block
val DECL_AOP_ADVICE = 14 # on pc{...} use handler form [priority N]
val DECL_DI_BINDING = 15 # @inject pc{...} implementation
val DECL_ARCH_RULE = 16  # forbid/allow pc{...} "message"

# ===== Declaration Arena Pools =====
var decl_tag: [i64] = []
var decl_span: [i64] = []
var decl_name: [text] = []
var decl_params: [[i64]] = []
var decl_param_names: [[text]] = []
var decl_param_types: [[i64]] = []
var decl_ret_type: [i64] = []
var decl_body_stmts: [[i64]] = []
var decl_field_names: [[text]] = []
var decl_field_types: [[i64]] = []
var decl_field_defaults: [[i64]] = []
var decl_field_bits: [[i64]] = []
var decl_imports: [[text]] = []
var decl_visibility: [text] = []
var decl_is_async: [i64] = []
var decl_is_comptime: [i64] = []
var decl_type_params: [[text]] = []
var decl_type_param_constraints: [[[text]]] = []  # per-param constraint lists: [["f32","i32"], []]
var decl_type_param_constraint_mode: [[text]] = []  # per-param mode: "limit", "candidate", ""
var decl_is_lazy: [i64] = []
var decl_is_gpu_kernel: [i64] = []   # 1 if @gpu_kernel decorated, 0 otherwise
var decl_is_simd: [i64] = []         # 1 if @simd decorated, 0 otherwise
var decl_derives: [[text]] = []      # @derive(Eq, Hash, Debug) trait list

fn decl_count() -> i64:
    decl_tag.len()

fn decl_alloc(tag: i64, span_id: i64) -> i64:
    val idx = decl_tag.len()
    decl_tag.push(tag)
    decl_span.push(span_id)
    decl_name.push("")
    decl_params.push([])
    decl_param_names.push([])
    decl_param_types.push([])
    decl_ret_type.push(0)
    decl_body_stmts.push([])
    decl_field_names.push([])
    decl_field_types.push([])
    decl_field_defaults.push([])
    decl_field_bits.push([])
    decl_imports.push([])
    decl_visibility.push("private")
    decl_is_async.push(0)
    decl_is_comptime.push(0)
    decl_type_params.push([])
    decl_type_param_constraints.push([])
    decl_type_param_constraint_mode.push([])
    decl_is_lazy.push(0)
    decl_is_gpu_kernel.push(0)
    decl_is_simd.push(0)
    decl_derives.push([])
    idx

# ===== Declaration Constructors =====

fn decl_fn(name: text, param_names: [text], param_types: [i64], ret_type: i64, body: [i64], is_async: i64, type_params: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_FN, span_id)
    decl_name[idx] = name
    decl_param_names[idx] = param_names
    decl_param_types[idx] = param_types
    decl_ret_type[idx] = ret_type
    decl_body_stmts[idx] = body
    decl_is_async[idx] = is_async
    decl_type_params[idx] = type_params
    idx

fn decl_extern_fn(name: text, param_names: [text], param_types: [i64], ret_type: i64, type_params: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_EXTERN_FN, span_id)
    decl_name[idx] = name
    decl_param_names[idx] = param_names
    decl_param_types[idx] = param_types
    decl_ret_type[idx] = ret_type
    decl_type_params[idx] = type_params
    idx

fn decl_struct_def(name: text, field_names: [text], field_types: [i64], field_defaults: [i64], field_bits: [i64], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_STRUCT, span_id)
    decl_name[idx] = name
    decl_field_names[idx] = field_names
    decl_field_types[idx] = field_types
    decl_field_defaults[idx] = field_defaults
    decl_field_bits[idx] = field_bits
    idx

fn decl_val_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_VAL, span_id)
    decl_name[idx] = name
    decl_ret_type[idx] = type_tag
    var body: [i64] = []
    body.push(init_expr)
    decl_body_stmts[idx] = body
    idx

fn decl_lazy_val_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_LAZY_VAL, span_id)
    decl_name[idx] = name
    decl_ret_type[idx] = type_tag
    var body: [i64] = []
    body.push(init_expr)
    decl_body_stmts[idx] = body
    idx

fn decl_var_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_VAR, span_id)
    decl_name[idx] = name
    decl_ret_type[idx] = type_tag
    var body: [i64] = []
    body.push(init_expr)
    decl_body_stmts[idx] = body
    idx

fn decl_use_import(module_path: text, imported_names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_USE, span_id)
    decl_name[idx] = module_path
    decl_imports[idx] = imported_names
    idx

fn decl_export_names(names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_EXPORT, span_id)
    decl_imports[idx] = names
    idx

fn decl_enum_def(name: text, variant_names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_ENUM, span_id)
    decl_name[idx] = name
    decl_field_names[idx] = variant_names
    idx

fn decl_impl_block(target_name: text, method_decl_ids: [i64], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_IMPL, span_id)
    decl_name[idx] = target_name
    decl_body_stmts[idx] = method_decl_ids
    idx

fn decl_cli_def(name: text, field_names: [text], field_types: [i64], field_defaults: [i64], body_stmts: [i64], imports: [text], span_id: i64) -> i64:
    # cli Name: block — name = struct name for parsed args,
    # field_names = option metadata as "name|type_char|default|short|doc" strings,
    # field_types = type tags for each option,
    # field_defaults = default value expr indices,
    # body_stmts = subcommand decl indices,
    # imports[0] = top-level docstring text (if any),
    # imports[1..] = directives like "default:.repl", "file:.spl", "prefetch:true"
    val idx = decl_alloc(DECL_CLI, span_id)
    decl_name[idx] = name
    decl_field_names[idx] = field_names
    decl_field_types[idx] = field_types
    decl_field_defaults[idx] = field_defaults
    decl_body_stmts[idx] = body_stmts
    decl_imports[idx] = imports
    idx

fn decl_ce_block(builder_name: text, body_stmts: [i64], span_id: i64) -> i64:
    # ce NAME: block — builder_name = computation expression builder name,
    # body_stmts = list of statement indices in ce body
    val idx = decl_alloc(DECL_CE, span_id)
    decl_name[idx] = builder_name
    decl_body_stmts[idx] = body_stmts
    idx

fn decl_aop_advice(pointcut: text, handler: text, form: text, priority_text: text, span_id: i64) -> i64:
    # on pc{pointcut} use handler form [priority N]
    # name = handler, imports = [pointcut, form, priority_text]
    val idx = decl_alloc(DECL_AOP_ADVICE, span_id)
    decl_name[idx] = handler
    decl_imports[idx] = [pointcut, form, priority_text]
    idx

fn decl_di_binding(pointcut: text, implementation: text, span_id: i64) -> i64:
    # @inject pc{pointcut} implementation
    # name = implementation, imports[0] = pointcut
    val idx = decl_alloc(DECL_DI_BINDING, span_id)
    decl_name[idx] = implementation
    decl_imports[idx] = [pointcut]
    idx

fn decl_arch_rule(kind: text, pointcut: text, message: text, span_id: i64) -> i64:
    # forbid/allow pc{pointcut} "message"
    # name = kind ("forbid"|"allow"), imports[0] = pointcut, imports[1] = message
    val idx = decl_alloc(DECL_ARCH_RULE, span_id)
    decl_name[idx] = kind
    decl_imports[idx] = [pointcut, message]
    idx

# ===== Declaration Accessors =====

fn decl_get_tag(idx: i64) -> i64:
    decl_tag[idx]

fn decl_get_span(idx: i64) -> i64:
    decl_span[idx]

fn decl_get_name(idx: i64) -> text:
    decl_name[idx]

fn decl_get_param_names(idx: i64) -> [text]:
    decl_param_names[idx]

fn decl_get_param_types(idx: i64) -> [i64]:
    decl_param_types[idx]

fn decl_get_ret_type(idx: i64) -> i64:
    decl_ret_type[idx]

fn decl_get_body(idx: i64) -> [i64]:
    decl_body_stmts[idx]

fn decl_get_fields(idx: i64) -> [text]:
    decl_field_names[idx]

fn decl_get_field_types(idx: i64) -> [i64]:
    decl_field_types[idx]

fn decl_get_field_defaults(idx: i64) -> [i64]:
    decl_field_defaults[idx]

fn decl_get_field_bits(idx: i64) -> [i64]:
    decl_field_bits[idx]

fn decl_get_imports(idx: i64) -> [text]:
    decl_imports[idx]

fn decl_get_is_pub(idx: i64) -> bool:
    decl_get_visibility_text(idx) == "public"

fn decl_get_visibility_text(idx: i64) -> text:
    if idx < 0:
        return "private"
    if idx >= decl_visibility.len():
        if decl_get_is_pub(idx):
            return "public"
        return "private"
    val stored = decl_visibility[idx]
    if stored == "":
        return "private"
    stored

fn decl_set_visibility_text(idx: i64, visibility: text):
    decl_visibility[idx] = visibility

fn decl_get_is_async(idx: i64) -> i64:
    decl_is_async[idx]

fn decl_get_type_params(idx: i64) -> [text]:
    decl_type_params[idx]

fn decl_set_type_params(idx: i64, params: [text]):
    decl_type_params[idx] = params

fn decl_get_type_param_constraints(idx: i64) -> [[text]]:
    decl_type_param_constraints[idx]

fn decl_set_type_param_constraints(idx: i64, constraints: [[text]]):
    decl_type_param_constraints[idx] = constraints

fn decl_get_type_param_constraint_mode(idx: i64) -> [text]:
    decl_type_param_constraint_mode[idx]

fn decl_set_type_param_constraint_mode(idx: i64, modes: [text]):
    decl_type_param_constraint_mode[idx] = modes

fn decl_set_comptime(idx: i64):
    decl_is_comptime[idx] = 1

fn decl_get_is_comptime(idx: i64) -> bool:
    if idx < 0: return false
    if idx >= decl_is_comptime.len(): return false
    decl_is_comptime[idx] == 1

fn decl_set_lazy(idx: i64):
    decl_is_lazy[idx] = 1

fn decl_get_is_lazy(idx: i64) -> i64:
    if idx < 0: return 0
    if idx >= decl_is_lazy.len(): return 0
    decl_is_lazy[idx]

fn decl_get_derives(idx: i64) -> [text]:
    if idx < 0: return []
    if idx >= decl_derives.len(): return []
    decl_derives[idx]

fn decl_set_derives(idx: i64, derives: [text]):
    decl_derives[idx] = derives

# ===== Match Arm Arena =====
# A match arm is (pattern_expr, guard_expr, body_stmts, binding_name)

var arm_pattern: [i64] = []
var arm_guard: [i64] = []
var arm_body: [[i64]] = []
var arm_binding: [text] = []

fn arm_new(pattern: i64, guard: i64, body: [i64]) -> i64:
    val idx = arm_pattern.len()
    arm_pattern.push(pattern)
    arm_guard.push(guard)
    arm_body.push(body)
    arm_binding.push("")
    idx

fn arm_new_with_binding(pattern: i64, guard: i64, body: [i64], binding: text) -> i64:
    val idx = arm_pattern.len()
    arm_pattern.push(pattern)
    arm_guard.push(guard)
    arm_body.push(body)
    arm_binding.push(binding)
    idx

fn arm_get_pattern(idx: i64) -> i64:
    arm_pattern[idx]

fn arm_get_guard(idx: i64) -> i64:
    arm_guard[idx]

fn arm_get_body(idx: i64) -> [i64]:
    arm_body[idx]

fn arm_get_binding(idx: i64) -> text:
    arm_binding[idx]

# ===== If Branch Arena =====
# For elif chains: (cond_expr, then_stmts)
# Stored separately from main if to support multiple elif branches.

var elif_cond: [i64] = []
var elif_body: [[i64]] = []
var elif_else: [[i64]] = []

fn elif_new(cond: i64, body: [i64], else_body: [i64]) -> i64:
    val idx = elif_cond.len()
    elif_cond.push(cond)
    elif_body.push(body)
    elif_else.push(else_body)
    idx

fn elif_get_cond(idx: i64) -> i64:
    elif_cond[idx]

fn elif_get_body(idx: i64) -> [i64]:
    elif_body[idx]

fn elif_get_else(idx: i64) -> [i64]:
    elif_else[idx]

# ===== Module (Top-Level AST) =====
# A module is a list of declarations.

var module_path_slot: [text] = [""]
var module_decls: [i64] = []
var lexer_state_core_pos_slot: [text] = ["0"]
var lexer_state_core_line_slot: [text] = ["1"]
var lexer_state_core_col_slot: [text] = ["1"]
var lexer_state_core_pending_dedents_slot: [text] = ["0"]
var lexer_state_core_at_line_start_slot: [text] = ["1"]
var lexer_state_core_paren_depth_slot: [text] = ["0"]
var lexer_state_core_cur_kind_slot: [text] = ["0"]
var lexer_state_core_cur_text_slot: [text] = [""]
var lexer_state_core_cur_line_slot: [text] = ["0"]
var lexer_state_core_cur_col_slot: [text] = ["0"]
var lexer_state_core_indent_stack_slot: [text] = ["0"]
var lexer_state_cur_kind_slot: [text] = ["0"]
var lexer_state_cur_text_slot: [text] = [""]
var lexer_state_cur_line_slot: [text] = ["0"]
var lexer_state_cur_col_slot: [text] = ["0"]
var lexer_state_cur_suffix_slot: [text] = [""]

fn module_set_path(path: text):
    module_path_slot[0] = path

fn module_get_path() -> text:
    module_path_slot[0]

fn lexer_state_get(key: text) -> text:
    if key == "core_pos":
        return lexer_state_core_pos_slot[0]
    if key == "core_line":
        return lexer_state_core_line_slot[0]
    if key == "core_col":
        return lexer_state_core_col_slot[0]
    if key == "core_pending_dedents":
        return lexer_state_core_pending_dedents_slot[0]
    if key == "core_at_line_start":
        return lexer_state_core_at_line_start_slot[0]
    if key == "core_paren_depth":
        return lexer_state_core_paren_depth_slot[0]
    if key == "core_cur_kind":
        return lexer_state_core_cur_kind_slot[0]
    if key == "core_cur_text":
        return lexer_state_core_cur_text_slot[0]
    if key == "core_cur_line":
        return lexer_state_core_cur_line_slot[0]
    if key == "core_cur_col":
        return lexer_state_core_cur_col_slot[0]
    if key == "core_indent_stack":
        return lexer_state_core_indent_stack_slot[0]
    if key == "cur_kind2":
        return lexer_state_cur_kind_slot[0]
    if key == "cur_text2":
        return lexer_state_cur_text_slot[0]
    if key == "cur_line2":
        return lexer_state_cur_line_slot[0]
    if key == "cur_col2":
        return lexer_state_cur_col_slot[0]
    if key == "cur_suffix2":
        return lexer_state_cur_suffix_slot[0]
    ""

fn lexer_state_set(key: text, value: text):
    if key == "core_pos":
        lexer_state_core_pos_slot[0] = value
        return
    if key == "core_line":
        lexer_state_core_line_slot[0] = value
        return
    if key == "core_col":
        lexer_state_core_col_slot[0] = value
        return
    if key == "core_pending_dedents":
        lexer_state_core_pending_dedents_slot[0] = value
        return
    if key == "core_at_line_start":
        lexer_state_core_at_line_start_slot[0] = value
        return
    if key == "core_paren_depth":
        lexer_state_core_paren_depth_slot[0] = value
        return
    if key == "core_cur_kind":
        lexer_state_core_cur_kind_slot[0] = value
        return
    if key == "core_cur_text":
        lexer_state_core_cur_text_slot[0] = value
        return
    if key == "core_cur_line":
        lexer_state_core_cur_line_slot[0] = value
        return
    if key == "core_cur_col":
        lexer_state_core_cur_col_slot[0] = value
        return
    if key == "core_indent_stack":
        lexer_state_core_indent_stack_slot[0] = value
        return
    if key == "cur_kind2":
        lexer_state_cur_kind_slot[0] = value
        return
    if key == "cur_text2":
        lexer_state_cur_text_slot[0] = value
        return
    if key == "cur_line2":
        lexer_state_cur_line_slot[0] = value
        return
    if key == "cur_col2":
        lexer_state_cur_col_slot[0] = value
        return
    if key == "cur_suffix2":
        lexer_state_cur_suffix_slot[0] = value
        return

fn lexer_core_pos_get() -> text:
    lexer_state_core_pos_slot[0]

fn lexer_core_pos_set(value: text):
    lexer_state_core_pos_slot[0] = value

fn lexer_core_line_get() -> text:
    lexer_state_core_line_slot[0]

fn lexer_core_line_set(value: text):
    lexer_state_core_line_slot[0] = value

fn lexer_core_col_get() -> text:
    lexer_state_core_col_slot[0]

fn lexer_core_col_set(value: text):
    lexer_state_core_col_slot[0] = value

fn lexer_core_pending_dedents_get() -> text:
