# Core Simple — Arena-Based AST
#
# Shared core library: AST nodes stored in parallel arrays (arena pattern).
# Each node is referenced by an i64 index. No structs, no enums with
# payloads, no generics, no me methods.
#
# Node types:
#   - Expr (expressions): integer tags in EXPR_* constants  (see ast_expr.spl)
#   - Stmt (statements): integer tags in STMT_* constants   (see ast_stmt.spl)
#   - Decl (declarations): integer tags in DECL_* constants (this file)
#   - Param (function parameters)
#   - Field (struct fields)
#   - MatchArm (match case arms)

# ===== Import from split modules =====
use compiler.core.ast_expr.*
use compiler.core.ast_stmt.*
use compiler.core.ast_types.{CoreExpr, CoreStmt, CoreDecl}

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool

fn ast_parse_i64(raw: text) -> i64:
    if raw == "":
        return 0
    var value: i64 = 0
    var i: i64 = 0
    var neg: bool = false
    if raw.len() > 0 and raw[0:1] == "-":
        neg = true
        i = 1
    while i < raw.len():
        val ch = raw[i:i + 1]
        value = value * 10
        if ch == "1":
            value = value + 1
        elif ch == "2":
            value = value + 2
        elif ch == "3":
            value = value + 3
        elif ch == "4":
            value = value + 4
        elif ch == "5":
            value = value + 5
        elif ch == "6":
            value = value + 6
        elif ch == "7":
            value = value + 7
        elif ch == "8":
            value = value + 8
        elif ch == "9":
            value = value + 9
        elif ch == "0":
            pass_dn
        else:
            break
        i = i + 1
    if neg:
        return 0 - value
    value

fn ast_decl_count_get() -> i64:
    ast_parse_i64(rt_env_get("SIMPLE_BOOTSTRAP_DECL_COUNT") ?? "")

fn ast_decl_count_set(value: i64):
    rt_env_set("SIMPLE_BOOTSTRAP_DECL_COUNT", int_to_str(value))

fn ast_module_decl_count_get() -> i64:
    ast_parse_i64(rt_env_get("SIMPLE_BOOTSTRAP_MODULE_DECL_COUNT") ?? "")

fn ast_module_decl_count_set(value: i64):
    rt_env_set("SIMPLE_BOOTSTRAP_MODULE_DECL_COUNT", int_to_str(value))

fn ast_decl_key(idx: i64, field: text) -> text:
    "SIMPLE_BOOTSTRAP_DECL_" + int_to_str(idx) + "_" + field

fn ast_decl_tag_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_TAG_" + int_to_str(idx)

fn ast_decl_name_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_NAME_" + int_to_str(idx)

fn ast_decl_ret_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_RET_" + int_to_str(idx)

fn ast_decl_body_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_BODY_" + int_to_str(idx)

fn ast_decl_field_names_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_FIELD_NAMES_" + int_to_str(idx)

fn ast_decl_field_types_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_FIELD_TYPES_" + int_to_str(idx)

fn ast_decl_imports_key(idx: i64) -> text:
    "SIMPLE_BOOTSTRAP_DECL_IMPORTS_" + int_to_str(idx)

fn ast_decl_i64_set(idx: i64, field: text, value: i64):
    rt_env_set(ast_decl_key(idx, field), int_to_str(value))

fn ast_decl_i64_get(idx: i64, field: text) -> i64:
    ast_parse_i64(rt_env_get(ast_decl_key(idx, field)) ?? "")

fn ast_decl_text_set(idx: i64, field: text, value: text):
    rt_env_set(ast_decl_key(idx, field), value)

fn ast_decl_text_get(idx: i64, field: text) -> text:
    rt_env_get(ast_decl_key(idx, field)) ?? ""

fn ast_text_list_join(values: [text]) -> text:
    values.join("\n")

fn ast_text_list_split(raw: text) -> [text]:
    if raw == "":
        return []
    raw.split("\n")

fn ast_i64_list_join(values: [i64]) -> text:
    var parts: [text] = []
    for value in values:
        parts.push(int_to_str(value))
    parts.join(",")

fn ast_i64_list_split(raw: text) -> [i64]:
    if raw == "":
        return []
    var result: [i64] = []
    for part in raw.split(","):
        if part != "":
            result.push(ast_parse_i64(part))
    result

# ===== Declaration Kind Tags =====
const DECL_FN = 1
const DECL_EXTERN_FN = 2
const DECL_STRUCT = 3
const DECL_VAL = 4
const DECL_VAR = 5
const DECL_USE = 6
const DECL_EXPORT = 7
const DECL_ENUM = 8
const DECL_IMPL = 9
const DECL_CLASS = 10
const DECL_CE = 11         # ce NAME: computation expression invocation
const DECL_LAZY_VAL = 12   # lazy val name = expr (module-level deferred init)
const DECL_CLI = 13        # cli Name: declarative arg parsing block
const DECL_AOP_ADVICE = 14 # on pc{...} use handler form [priority N]
const DECL_DI_BINDING = 15 # @inject pc{...} implementation
const DECL_ARCH_RULE = 16  # forbid/allow pc{...} "message"

# ===== Declaration Arena Pools =====
var decl_tag: [i64] = []
var decl_span: [i64] = []
var decl_name: [text] = []
var decl_params: [[i64]] = []
var decl_param_names: [[text]] = []
var decl_param_types: [[i64]] = []
var decl_ret_type: [i64] = []
var decl_body_stmts: [[i64]] = []
var decl_field_names: [[text]] = []
var decl_field_types: [[i64]] = []
var decl_field_defaults: [[i64]] = []
var decl_field_bits: [[i64]] = []
var decl_imports: [[text]] = []
var decl_visibility: [text] = []
var decl_is_async: [i64] = []
var decl_is_comptime: [i64] = []
var decl_type_params: [[text]] = []
var decl_type_param_constraints: [[[text]]] = []  # per-param constraint lists: [["f32","i32"], []]
var decl_type_param_constraint_mode: [[text]] = []  # per-param mode: "limit", "candidate", ""
var decl_is_lazy: [i64] = []
var decl_is_gpu_kernel: [i64] = []   # 1 if @gpu_kernel decorated, 0 otherwise
var decl_is_simd: [i64] = []         # 1 if @simd decorated, 0 otherwise
var decl_derives: [[text]] = []      # @derive(Eq, Hash, Debug) trait list

fn decl_count() -> i64:
    ast_decl_count_get()

fn decl_alloc(tag: i64, span_id: i64) -> i64:
    if decl_tag == nil:
        decl_tag = []
    val idx = ast_decl_count_get()
    ast_decl_i64_set(idx, "TAG", tag)
    rt_env_set(ast_decl_tag_key(idx), int_to_str(tag))
    ast_decl_i64_set(idx, "SPAN", span_id)
    ast_decl_text_set(idx, "VIS", "private")
    ast_decl_count_set(idx + 1)
    idx

# ===== Declaration Constructors =====

fn decl_fn(name: text, param_names: [text], param_types: [i64], ret_type: i64, body: [i64], is_async: i64, type_params: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_FN, span_id)
    rt_env_set(ast_decl_tag_key(idx), "1")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_text_set(idx, "PARAM_NAMES", ast_text_list_join(param_names))
    ast_decl_text_set(idx, "PARAM_TYPES", ast_i64_list_join(param_types))
    ast_decl_i64_set(idx, "RET", ret_type)
    rt_env_set(ast_decl_ret_key(idx), int_to_str(ret_type))
    ast_decl_text_set(idx, "BODY", ast_i64_list_join(body))
    rt_env_set(ast_decl_body_key(idx), ast_i64_list_join(body))
    ast_decl_i64_set(idx, "ASYNC", is_async)
    ast_decl_text_set(idx, "TYPE_PARAMS", ast_text_list_join(type_params))
    idx

fn decl_extern_fn(name: text, param_names: [text], param_types: [i64], ret_type: i64, type_params: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_EXTERN_FN, span_id)
    rt_env_set(ast_decl_tag_key(idx), "2")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_text_set(idx, "PARAM_NAMES", ast_text_list_join(param_names))
    ast_decl_text_set(idx, "PARAM_TYPES", ast_i64_list_join(param_types))
    ast_decl_i64_set(idx, "RET", ret_type)
    rt_env_set(ast_decl_ret_key(idx), int_to_str(ret_type))
    ast_decl_text_set(idx, "TYPE_PARAMS", ast_text_list_join(type_params))
    idx

fn decl_struct_def(name: text, field_names: [text], field_types: [i64], field_defaults: [i64], field_bits: [i64], span_id: i64) -> i64:
    print "[decl_struct_def] " + name
    val idx = decl_alloc(DECL_STRUCT, span_id)
    rt_env_set(ast_decl_tag_key(idx), "3")
    print "[decl_struct_def] idx " + int_to_str(idx)
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_text_set(idx, "FIELD_NAMES", ast_text_list_join(field_names))
    rt_env_set(ast_decl_field_names_key(idx), ast_text_list_join(field_names))
    ast_decl_text_set(idx, "FIELD_TYPES", ast_i64_list_join(field_types))
    rt_env_set(ast_decl_field_types_key(idx), ast_i64_list_join(field_types))
    ast_decl_text_set(idx, "FIELD_DEFAULTS", ast_i64_list_join(field_defaults))
    ast_decl_text_set(idx, "FIELD_BITS", ast_i64_list_join(field_bits))
    idx

fn decl_val_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_VAL, span_id)
    rt_env_set(ast_decl_tag_key(idx), "4")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_i64_set(idx, "RET", type_tag)
    ast_decl_text_set(idx, "BODY", int_to_str(init_expr))
    rt_env_set(ast_decl_body_key(idx), int_to_str(init_expr))
    idx

fn decl_lazy_val_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_LAZY_VAL, span_id)
    rt_env_set(ast_decl_tag_key(idx), "12")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_i64_set(idx, "RET", type_tag)
    ast_decl_text_set(idx, "BODY", int_to_str(init_expr))
    rt_env_set(ast_decl_body_key(idx), int_to_str(init_expr))
    ast_decl_i64_set(idx, "LAZY", 1)
    idx

fn decl_var_binding(name: text, type_tag: i64, init_expr: i64, span_id: i64) -> i64:
    val idx = decl_alloc(DECL_VAR, span_id)
    rt_env_set(ast_decl_tag_key(idx), "5")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_i64_set(idx, "RET", type_tag)
    ast_decl_text_set(idx, "BODY", int_to_str(init_expr))
    rt_env_set(ast_decl_body_key(idx), int_to_str(init_expr))
    idx

fn decl_use_import(module_path: text, imported_names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_USE, span_id)
    rt_env_set(ast_decl_tag_key(idx), "6")
    ast_decl_text_set(idx, "NAME", module_path)
    rt_env_set(ast_decl_name_key(idx), module_path)
    ast_decl_text_set(idx, "IMPORTS", ast_text_list_join(imported_names))
    rt_env_set(ast_decl_imports_key(idx), ast_text_list_join(imported_names))
    idx

fn decl_export_names(names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_EXPORT, span_id)
    rt_env_set(ast_decl_tag_key(idx), "7")
    ast_decl_text_set(idx, "IMPORTS", ast_text_list_join(names))
    rt_env_set(ast_decl_imports_key(idx), ast_text_list_join(names))
    idx

fn decl_enum_def(name: text, variant_names: [text], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_ENUM, span_id)
    rt_env_set(ast_decl_tag_key(idx), "8")
    ast_decl_text_set(idx, "NAME", name)
    rt_env_set(ast_decl_name_key(idx), name)
    ast_decl_text_set(idx, "FIELD_NAMES", ast_text_list_join(variant_names))
    rt_env_set(ast_decl_field_names_key(idx), ast_text_list_join(variant_names))
    idx

fn decl_impl_block(target_name: text, method_decl_ids: [i64], span_id: i64) -> i64:
    val idx = decl_alloc(DECL_IMPL, span_id)
    rt_env_set(ast_decl_tag_key(idx), "9")
    ast_decl_text_set(idx, "NAME", target_name)
    rt_env_set(ast_decl_name_key(idx), target_name)
    ast_decl_text_set(idx, "BODY", ast_i64_list_join(method_decl_ids))
    rt_env_set(ast_decl_body_key(idx), ast_i64_list_join(method_decl_ids))
    idx

fn decl_cli_def(name: text, field_names: [text], field_types: [i64], field_defaults: [i64], body_stmts: [i64], imports: [text], span_id: i64) -> i64:
    # cli Name: block — name = struct name for parsed args,
    # field_names = option metadata as "name|type_char|default|short|doc" strings,
    # field_types = type tags for each option,
    # field_defaults = default value expr indices,
    # body_stmts = subcommand decl indices,
    # imports[0] = top-level docstring text (if any),
    # imports[1..] = directives like "default:.repl", "file:.spl", "prefetch:true"
    val idx = decl_alloc(DECL_CLI, span_id)
    rt_env_set(ast_decl_tag_key(idx), "13")
    decl_name[idx] = name
    decl_field_names[idx] = field_names
    decl_field_types[idx] = field_types
    decl_field_defaults[idx] = field_defaults
    decl_body_stmts[idx] = body_stmts
    decl_imports[idx] = imports
    idx

fn decl_ce_block(builder_name: text, body_stmts: [i64], span_id: i64) -> i64:
    # ce NAME: block — builder_name = computation expression builder name,
    # body_stmts = list of statement indices in ce body
    val idx = decl_alloc(DECL_CE, span_id)
    rt_env_set(ast_decl_tag_key(idx), "11")
    decl_name[idx] = builder_name
    decl_body_stmts[idx] = body_stmts
    idx

fn decl_aop_advice(pointcut: text, handler: text, form: text, priority_text: text, span_id: i64) -> i64:
    # on pc{pointcut} use handler form [priority N]
    # name = handler, imports = [pointcut, form, priority_text]
    val idx = decl_alloc(DECL_AOP_ADVICE, span_id)
    rt_env_set(ast_decl_tag_key(idx), "14")
    decl_name[idx] = handler
    decl_imports[idx] = [pointcut, form, priority_text]
    idx

fn decl_di_binding(pointcut: text, implementation: text, span_id: i64) -> i64:
    # @inject pc{pointcut} implementation
    # name = implementation, imports[0] = pointcut
    val idx = decl_alloc(DECL_DI_BINDING, span_id)
    rt_env_set(ast_decl_tag_key(idx), "15")
    decl_name[idx] = implementation
    decl_imports[idx] = [pointcut]
    idx

fn decl_arch_rule(kind: text, pointcut: text, message: text, span_id: i64) -> i64:
    # forbid/allow pc{pointcut} "message"
    # name = kind ("forbid"|"allow"), imports[0] = pointcut, imports[1] = message
    val idx = decl_alloc(DECL_ARCH_RULE, span_id)
    rt_env_set(ast_decl_tag_key(idx), "16")
    decl_name[idx] = kind
    decl_imports[idx] = [pointcut, message]
    idx

# ===== Declaration Accessors =====

fn decl_get_tag(idx: i64) -> i64:
    val direct = rt_env_get(ast_decl_tag_key(idx)) ?? ""
    if direct != "":
        print "[decl_get_tag] idx " + int_to_str(idx) + " raw '" + direct + "'"
        if direct == "1": return 1
        if direct == "2": return 2
        if direct == "3":
            print "[decl_get_tag] return literal 3"
            return 3
        if direct == "4": return 4
        if direct == "5": return 5
        if direct == "6": return 6
        if direct == "7": return 7
        if direct == "8": return 8
        if direct == "9": return 9
        if direct == "10": return 10
        if direct == "11": return 11
        if direct == "12": return 12
        if direct == "13": return 13
        if direct == "14": return 14
        if direct == "15": return 15
        if direct == "16": return 16
        return ast_parse_i64(direct)
    val env_value = ast_decl_i64_get(idx, "TAG")
    if env_value != 0:
        return env_value
    decl_tag[idx]

fn decl_get_span(idx: i64) -> i64:
    val env_value = ast_decl_i64_get(idx, "SPAN")
    if env_value != 0:
        return env_value
    decl_span[idx]

fn decl_get_name(idx: i64) -> text:
    val direct = rt_env_get(ast_decl_name_key(idx)) ?? ""
    if direct != "":
        return direct
    val env_value = ast_decl_text_get(idx, "NAME")
    if env_value != "":
        return env_value
    decl_name[idx]

fn decl_get_param_names(idx: i64) -> [text]:
    val env_value = ast_decl_text_get(idx, "PARAM_NAMES")
    if env_value != "":
        return ast_text_list_split(env_value)
    decl_param_names[idx]

fn decl_get_param_types(idx: i64) -> [i64]:
    val env_value = ast_decl_text_get(idx, "PARAM_TYPES")
    if env_value != "":
        return ast_i64_list_split(env_value)
    decl_param_types[idx]

fn decl_get_ret_type(idx: i64) -> i64:
    val direct = rt_env_get(ast_decl_ret_key(idx)) ?? ""
    if direct != "":
        return ast_parse_i64(direct)
    val env_value = ast_decl_i64_get(idx, "RET")
    if env_value != 0:
        return env_value
    decl_ret_type[idx]

fn decl_get_body(idx: i64) -> [i64]:
    val direct = rt_env_get(ast_decl_body_key(idx)) ?? ""
    if direct != "":
        return ast_i64_list_split(direct)
    val env_value = ast_decl_text_get(idx, "BODY")
    if env_value != "":
        return ast_i64_list_split(env_value)
    decl_body_stmts[idx]

fn decl_get_fields(idx: i64) -> [text]:
    val direct = rt_env_get(ast_decl_field_names_key(idx)) ?? ""
    if direct != "":
        return ast_text_list_split(direct)
    val env_value = ast_decl_text_get(idx, "FIELD_NAMES")
    if env_value != "":
        return ast_text_list_split(env_value)
    decl_field_names[idx]

fn decl_get_field_types(idx: i64) -> [i64]:
    val direct = rt_env_get(ast_decl_field_types_key(idx)) ?? ""
    if direct != "":
        return ast_i64_list_split(direct)
    val env_value = ast_decl_text_get(idx, "FIELD_TYPES")
    if env_value != "":
        return ast_i64_list_split(env_value)
    decl_field_types[idx]

fn decl_get_field_defaults(idx: i64) -> [i64]:
    val env_value = ast_decl_text_get(idx, "FIELD_DEFAULTS")
    if env_value != "":
        return ast_i64_list_split(env_value)
    decl_field_defaults[idx]

fn decl_get_field_bits(idx: i64) -> [i64]:
    val env_value = ast_decl_text_get(idx, "FIELD_BITS")
    if env_value != "":
        return ast_i64_list_split(env_value)
    decl_field_bits[idx]

fn decl_get_imports(idx: i64) -> [text]:
    val direct = rt_env_get(ast_decl_imports_key(idx)) ?? ""
    if direct != "":
        return ast_text_list_split(direct)
    val env_value = ast_decl_text_get(idx, "IMPORTS")
    if env_value != "":
        return ast_text_list_split(env_value)
    decl_imports[idx]

fn decl_get_is_pub(idx: i64) -> bool:
    decl_get_visibility_text(idx) == "public"

fn decl_get_visibility_text(idx: i64) -> text:
    if idx < 0:
        return "private"
    val env_value = ast_decl_text_get(idx, "VIS")
    if env_value != "":
        return env_value
    if idx >= decl_visibility.len():
        if decl_get_is_pub(idx):
            return "public"
        return "private"
    val stored = decl_visibility[idx]
    if stored == "":
        return "private"
    stored

fn decl_set_visibility_text(idx: i64, visibility: text):
    ast_decl_text_set(idx, "VIS", visibility)
    decl_visibility[idx] = visibility

fn decl_get_is_async(idx: i64) -> i64:
    val env_value = ast_decl_i64_get(idx, "ASYNC")
    if env_value != 0:
        return env_value
    decl_is_async[idx]

fn decl_get_type_params(idx: i64) -> [text]:
    val env_value = ast_decl_text_get(idx, "TYPE_PARAMS")
    if env_value != "":
        return ast_text_list_split(env_value)
    decl_type_params[idx]

fn decl_set_type_params(idx: i64, params: [text]):
    ast_decl_text_set(idx, "TYPE_PARAMS", ast_text_list_join(params))
    decl_type_params[idx] = params

fn decl_get_type_param_constraints(idx: i64) -> [[text]]:
    decl_type_param_constraints[idx]

fn decl_set_type_param_constraints(idx: i64, constraints: [[text]]):
    decl_type_param_constraints[idx] = constraints

fn decl_get_type_param_constraint_mode(idx: i64) -> [text]:
    decl_type_param_constraint_mode[idx]

fn decl_set_type_param_constraint_mode(idx: i64, modes: [text]):
    decl_type_param_constraint_mode[idx] = modes

fn decl_set_comptime(idx: i64):
    ast_decl_i64_set(idx, "COMPTIME", 1)
    decl_is_comptime[idx] = 1

fn decl_get_is_comptime(idx: i64) -> bool:
    if idx < 0: return false
    if ast_decl_i64_get(idx, "COMPTIME") != 0: return true
    if idx >= decl_is_comptime.len(): return false
    decl_is_comptime[idx] == 1

fn decl_set_lazy(idx: i64):
    ast_decl_i64_set(idx, "LAZY", 1)
    decl_is_lazy[idx] = 1

fn decl_get_is_lazy(idx: i64) -> i64:
    if idx < 0: return 0
    val env_value = ast_decl_i64_get(idx, "LAZY")
    if env_value != 0: return env_value
    if idx >= decl_is_lazy.len(): return 0
    decl_is_lazy[idx]

fn decl_get_derives(idx: i64) -> [text]:
    if idx < 0: return []
    if idx >= decl_derives.len(): return []
    decl_derives[idx]

fn decl_set_derives(idx: i64, derives: [text]):
    decl_derives[idx] = derives

# ===== Match Arm Arena =====
# A match arm is (pattern_expr, guard_expr, body_stmts, binding_name)

var arm_pattern: [i64] = []
var arm_guard: [i64] = []
var arm_body: [[i64]] = []
var arm_binding: [text] = []
var arm_rationale: [text] = []

fn arm_new(pattern: i64, guard: i64, body: [i64]) -> i64:
    val idx = arm_pattern.len()
    arm_pattern.push(pattern)
    arm_guard.push(guard)
    arm_body.push(body)
    arm_binding.push("")
    arm_rationale.push("")
    idx

fn arm_new_with_binding(pattern: i64, guard: i64, body: [i64], binding: text) -> i64:
    val idx = arm_pattern.len()
    arm_pattern.push(pattern)
    arm_guard.push(guard)
    arm_body.push(body)
    arm_binding.push(binding)
    arm_rationale.push("")
    idx

fn arm_new_with_binding_and_rationale(pattern: i64, guard: i64, body: [i64], binding: text, rationale: text) -> i64:
    val idx = arm_pattern.len()
    arm_pattern.push(pattern)
    arm_guard.push(guard)
    arm_body.push(body)
    arm_binding.push(binding)
    arm_rationale.push(rationale)
    idx

fn arm_get_pattern(idx: i64) -> i64:
    arm_pattern[idx]

fn arm_get_guard(idx: i64) -> i64:
    arm_guard[idx]

fn arm_get_body(idx: i64) -> [i64]:
    arm_body[idx]

fn arm_get_binding(idx: i64) -> text:
    arm_binding[idx]

fn arm_get_rationale(idx: i64) -> text:
    if idx < 0:
        return ""
    if idx >= arm_rationale.len():
        return ""
    arm_rationale[idx]

# ===== If Branch Arena =====
# For elif chains: (cond_expr, then_stmts)
# Stored separately from main if to support multiple elif branches.

var elif_cond: [i64] = []
var elif_body: [[i64]] = []
var elif_else: [[i64]] = []

fn elif_new(cond: i64, body: [i64], else_body: [i64]) -> i64:
    val idx = elif_cond.len()
    elif_cond.push(cond)
    elif_body.push(body)
    elif_else.push(else_body)
    idx

fn elif_get_cond(idx: i64) -> i64:
    elif_cond[idx]

fn elif_get_body(idx: i64) -> [i64]:
    elif_body[idx]

fn elif_get_else(idx: i64) -> [i64]:
    elif_else[idx]

