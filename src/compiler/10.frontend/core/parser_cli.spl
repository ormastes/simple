# Parser — CLI Declaration
#
# Parses `cli Name:` declarative arg parsing blocks.
#
# Syntax:
#   cli Name:
#       """Top-level docstring"""
#       -s option_name = default   """Option docstring"""
#       option_name = default      """Option docstring"""
#       file: ".spl"
#       prefetch: true
#       default: .command_name
#       sub command_name:
#           """Subcommand docstring"""
#           -s sub_opt = default   """Sub-option docstring"""
#       sub pass1, pass2, pass3
#
# Option metadata is encoded in decl_field_names[] as:
#   "name|type_char|default|short|doc"
# where type_char is: b=bool, s=text, i=i64, f=f64, a=array

use compiler.core.tokens.{TOK_IDENT, TOK_STRING_LIT, TOK_INT_LIT, TOK_FLOAT_LIT, TOK_BOOL_LIT}
use compiler.core.tokens.{TOK_MINUS, TOK_ASSIGN, TOK_DOT, TOK_COMMA, TOK_COLON}
use compiler.core.tokens.{TOK_LBRACKET, TOK_RBRACKET}
use compiler.core.tokens.{TOK_NEWLINE, TOK_INDENT, TOK_DEDENT, TOK_EOF}
use compiler.core.tokens.{tok_kind_name}
use compiler.core.ast.{decl_cli_def}
use compiler.core.ast.{expr_string_lit, expr_int_lit, expr_float_lit, expr_bool_lit, expr_nil_lit, expr_array_lit}
use compiler.core.parser.{par_kind_get, par_text_get, par_line_get, par_col_get, par_errors}
use compiler.core.parser.{parser_advance, parser_expect, parser_error}
use compiler.core.parser.{parser_skip_newlines, parser_skip_newlines_and_semicolons}
use compiler.core.types.{TYPE_BOOL, TYPE_TEXT, TYPE_I64, TYPE_F64}

# ===== CLI Declaration Parser =====

fn parse_cli_decl() -> i64:
    # Already consumed 'cli' keyword
    parser_advance()

    # Parse struct name (e.g., Args)
    val cli_name = par_text_get()
    parser_expect(TOK_IDENT)
    parser_expect(TOK_COLON)
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    var field_names: [text] = []
    var field_types: [i64] = []
    var field_defaults: [i64] = []
    var sub_decl_ids: [i64] = []
    var directives: [text] = []

    # Check for top-level docstring
    parser_skip_newlines()
    if par_kind_get() == TOK_STRING_LIT:
        val top_doc = par_text_get()
        directives.push("doc:" + top_doc)
        parser_advance()
        parser_skip_newlines_and_semicolons()

    # Parse body: options, directives, subcommands
    for cli_i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip docstrings between items
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Check for short name prefix: -s option_name = default
        if par_kind_get() == TOK_MINUS:
            parser_advance()
            val short_name = par_text_get()
            parser_expect(TOK_IDENT)
            val opt_name = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_ASSIGN)
            val opt_result = parse_cli_option_value()
            val opt_type_char = opt_result.type_char
            val opt_default_str = opt_result.default_str
            val opt_default_expr = opt_result.default_expr
            val opt_type = opt_result.type_tag
            # Parse optional docstring
            var opt_doc = ""
            if par_kind_get() == TOK_STRING_LIT:
                opt_doc = par_text_get()
                parser_advance()
            # Encode as "name|type_char|default|short|doc"
            val meta = opt_name + "|" + opt_type_char + "|" + opt_default_str + "|" + short_name + "|" + opt_doc
            field_names.push(meta)
            field_types.push(opt_type)
            field_defaults.push(opt_default_expr)
            parser_skip_newlines_and_semicolons()
            continue

        # Check for identifiers: option, directive, or subcommand keyword
        if par_kind_get() == TOK_IDENT:
            val ident_text = par_text_get()

            # Directive: file: ".spl"
            if ident_text == "file":
                parser_advance()
                parser_expect(TOK_COLON)
                val file_ext = par_text_get()
                parser_expect(TOK_STRING_LIT)
                directives.push("file:" + file_ext)
                parser_skip_newlines_and_semicolons()
                continue

            # Directive: prefetch: true
            if ident_text == "prefetch":
                parser_advance()
                parser_expect(TOK_COLON)
                val pf_val = par_text_get()
                parser_advance()
                directives.push("prefetch:" + pf_val)
                parser_skip_newlines_and_semicolons()
                continue

            # Directive: default: .command_name
            if ident_text == "default":
                parser_advance()
                parser_expect(TOK_COLON)
                parser_expect(TOK_DOT)
                val default_cmd = par_text_get()
                parser_expect(TOK_IDENT)
                directives.push("default:" + default_cmd)
                parser_skip_newlines_and_semicolons()
                continue

            # Subcommand: sub name: or sub name1, name2
            if ident_text == "sub":
                parser_advance()
                val sub_name = par_text_get()
                parser_expect(TOK_IDENT)

                # Check if this is a pass-through list: sub name1, name2, name3
                if par_kind_get() == TOK_COMMA:
                    # Pass-through subcommands — encode as directive
                    var pass_list = sub_name
                    for pi in 0..100:
                        if par_kind_get() != TOK_COMMA:
                            break
                        parser_advance()
                        val next_name = par_text_get()
                        parser_expect(TOK_IDENT)
                        pass_list = pass_list + "," + next_name
                    directives.push("passthrough:" + pass_list)
                    parser_skip_newlines_and_semicolons()
                    continue

                # Named subcommand with body: sub name:
                parser_expect(TOK_COLON)
                val sub_decl = parse_cli_subcommand(sub_name)
                sub_decl_ids.push(sub_decl)
                continue

            # Otherwise it's an option without short name: option_name = default
            parser_advance()
            parser_expect(TOK_ASSIGN)
            val opt2_result = parse_cli_option_value()
            val opt2_type_char = opt2_result.type_char
            val opt2_default_str = opt2_result.default_str
            val opt2_default_expr = opt2_result.default_expr
            val opt2_type = opt2_result.type_tag
            # Parse optional docstring
            var opt2_doc = ""
            if par_kind_get() == TOK_STRING_LIT:
                opt2_doc = par_text_get()
                parser_advance()
            # Encode as "name|type_char|default||doc" (empty short)
            val meta2 = ident_text + "|" + opt2_type_char + "|" + opt2_default_str + "||" + opt2_doc
            field_names.push(meta2)
            field_types.push(opt2_type)
            field_defaults.push(opt2_default_expr)
            parser_skip_newlines_and_semicolons()
            continue

        # Skip unknown tokens
        parser_advance()
        parser_skip_newlines_and_semicolons()

    decl_cli_def(cli_name, field_names, field_types, field_defaults, sub_decl_ids, directives, 0)

# ===== Option Value Parser =====
# Parses the default value after = and returns type info

struct CliOptionResult:
    type_char: text
    default_str: text
    default_expr: i64
    type_tag: i64

fn parse_cli_option_value() -> CliOptionResult:
    # Parse default value: false, true, "string", 0, 0.0, [type]
    if par_kind_get() == TOK_BOOL_LIT:
        val bval = par_text_get()
        parser_advance()
        val bexpr = expr_bool_lit(bval == "true", 0)
        return CliOptionResult(type_char: "b", default_str: bval, default_expr: bexpr, type_tag: TYPE_BOOL)

    if par_kind_get() == TOK_STRING_LIT:
        val sval = par_text_get()
        parser_advance()
        val sexpr = expr_string_lit(sval, 0)
        return CliOptionResult(type_char: "s", default_str: sval, default_expr: sexpr, type_tag: TYPE_TEXT)

    if par_kind_get() == TOK_INT_LIT:
        val ival = par_text_get()
        parser_advance()
        val iexpr = expr_int_lit(ival.to_int(), 0)
        return CliOptionResult(type_char: "i", default_str: ival, default_expr: iexpr, type_tag: TYPE_I64)

    if par_kind_get() == TOK_FLOAT_LIT:
        val fval = par_text_get()
        parser_advance()
        val fexpr = expr_float_lit(fval.to_float(), 0)
        return CliOptionResult(type_char: "f", default_str: fval, default_expr: fexpr, type_tag: TYPE_F64)

    if par_kind_get() == TOK_LBRACKET:
        # Array default: [text] or [i64] etc.
        parser_advance()
        val arr_type = par_text_get()
        parser_advance()
        parser_expect(TOK_RBRACKET)
        var aexprs: [i64] = []
        val aexpr = expr_array_lit(aexprs, 0)
        return CliOptionResult(type_char: "a", default_str: arr_type, default_expr: aexpr, type_tag: TYPE_TEXT)

    # Fallback: parse as identifier (e.g., false/true as idents in some contexts)
    if par_kind_get() == TOK_IDENT:
        val id_val = par_text_get()
        parser_advance()
        if id_val == "false" or id_val == "true":
            val id_bexpr = expr_bool_lit(id_val == "true", 0)
            return CliOptionResult(type_char: "b", default_str: id_val, default_expr: id_bexpr, type_tag: TYPE_BOOL)
        val id_sexpr = expr_string_lit(id_val, 0)
        return CliOptionResult(type_char: "s", default_str: id_val, default_expr: id_sexpr, type_tag: TYPE_TEXT)

    # Error fallback
    parser_error("expected option default value")
    val nil_expr = expr_nil_lit(0)
    CliOptionResult(type_char: "s", default_str: "", default_expr: nil_expr, type_tag: TYPE_TEXT)

# ===== Subcommand Parser =====

fn parse_cli_subcommand(sub_name: text) -> i64:
    # Parse subcommand body: indented block with options and docstring
    parser_skip_newlines()
    parser_expect(TOK_INDENT)

    var sub_fields: [text] = []
    var sub_types: [i64] = []
    var sub_defaults: [i64] = []
    var sub_directives: [text] = []

    # Check for subcommand docstring
    parser_skip_newlines()
    if par_kind_get() == TOK_STRING_LIT:
        val sub_doc = par_text_get()
        sub_directives.push("doc:" + sub_doc)
        parser_advance()
        parser_skip_newlines_and_semicolons()

    for sub_i in 0..200:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Skip docstrings
        if par_kind_get() == TOK_STRING_LIT:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Short-name option: -s name = default
        if par_kind_get() == TOK_MINUS:
            parser_advance()
            val sub_short = par_text_get()
            parser_expect(TOK_IDENT)
            val sub_opt_name = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_ASSIGN)
            val sub_opt = parse_cli_option_value()
            var sub_opt_doc = ""
            if par_kind_get() == TOK_STRING_LIT:
                sub_opt_doc = par_text_get()
                parser_advance()
            val sub_meta = sub_opt_name + "|" + sub_opt.type_char + "|" + sub_opt.default_str + "|" + sub_short + "|" + sub_opt_doc
            sub_fields.push(sub_meta)
            sub_types.push(sub_opt.type_tag)
            sub_defaults.push(sub_opt.default_expr)
            parser_skip_newlines_and_semicolons()
            continue

        # Option without short: name = default
        if par_kind_get() == TOK_IDENT:
            val so_name = par_text_get()
            parser_advance()
            parser_expect(TOK_ASSIGN)
            val so_result = parse_cli_option_value()
            var so_doc = ""
            if par_kind_get() == TOK_STRING_LIT:
                so_doc = par_text_get()
                parser_advance()
            val so_meta = so_name + "|" + so_result.type_char + "|" + so_result.default_str + "||" + so_doc
            sub_fields.push(so_meta)
            sub_types.push(so_result.type_tag)
            sub_defaults.push(so_result.default_expr)
            parser_skip_newlines_and_semicolons()
            continue

        parser_advance()
        parser_skip_newlines_and_semicolons()

    # Create subcommand as a nested DECL_CLI
    var empty_body: [i64] = []
    decl_cli_def(sub_name, sub_fields, sub_types, sub_defaults, empty_body, sub_directives, 0)

