# Core Simple — Struct-Based Lexer
#
# Struct-based lexer for bootstrap-compatible frontend code.
# Converts source text into a stream of tokens using a CoreLexer struct
# with methods, instead of module-level mutable state.
#
# Handles indentation tracking, literals, identifiers, keywords,
# operators, delimiters, and comments.
#
# Design: All state in CoreLexer struct fields. Methods modify self.
# Compatible with the minimal bootstrap subset: no generics, no closures, no lambdas.

use compiler.core.tokens.{keyword_lookup, token_requires_rhs}
use compiler.core.lexer_chars.{is_digit, is_hex_digit, is_alpha, is_ident_char, is_space}
use std.string_core.{char_from_code}

# Digit-value helpers for string escape decoding (\NNN octal, \xNN hex,
# \u{...} unicode). Return -1 for non-digits so callers can stop consuming.
fn lex_escape_hex_value(c: text) -> i64:
    val lower: text = "0123456789abcdef"
    val upper: text = "0123456789ABCDEF"
    for k in 0..16:
        if lower[k:k+1] == c:
            return k
        if upper[k:k+1] == c:
            return k
    return -1

fn lex_escape_octal_value(c: text) -> i64:
    val digits: text = "01234567"
    for k in 0..8:
        if digits[k:k+1] == c:
            return k
    return -1

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
fn rt_array_len_safe<T>(array: [T]) -> i64:
    return array.len()

var core_last_token_text_slot: [text] = [""]
var core_last_token_line_slot: [i64] = [0]
var core_last_token_col_slot: [i64] = [0]
var core_last_token_suffix_slot: [text] = [""]
var core_token_env_save_slot: [bool] = [false]

fn core_token_env_save_set(enabled: bool):
    if rt_array_len_safe(core_token_env_save_slot) == 0:
        core_token_env_save_slot = [false]
    core_token_env_save_slot[0] = enabled

fn core_token_env_save_enabled() -> bool:
    if rt_array_len_safe(core_token_env_save_slot) == 0:
        return false
    core_token_env_save_slot[0]

fn core_token_text_save(value: text):
    if core_token_env_save_enabled():
        rt_env_set("SIMPLE_BOOTSTRAP_CORE_TOKEN_TEXT", value)

fn core_token_suffix_save(value: text):
    if rt_array_len_safe(core_last_token_suffix_slot) == 0:
        core_last_token_suffix_slot = [""]
    core_last_token_suffix_slot[0] = value
    if core_token_env_save_enabled():
        rt_env_set("SIMPLE_BOOTSTRAP_CORE_TOKEN_SUFFIX", value)

fn core_token_capture(tok_text: text, line: i64, col: i64):
    if rt_array_len_safe(core_last_token_text_slot) == 0:
        core_last_token_text_slot = [""]
    if rt_array_len_safe(core_last_token_line_slot) == 0:
        core_last_token_line_slot = [0]
    if rt_array_len_safe(core_last_token_col_slot) == 0:
        core_last_token_col_slot = [0]
    if rt_array_len_safe(core_last_token_suffix_slot) == 0:
        core_last_token_suffix_slot = [""]
    core_last_token_text_slot[0] = tok_text
    core_last_token_line_slot[0] = line
    core_last_token_col_slot[0] = col
    core_last_token_suffix_slot[0] = ""

fn core_lexer_last_text_get() -> text:
    if rt_array_len_safe(core_last_token_text_slot) == 0:
        return ""
    core_last_token_text_slot[0]

fn core_lexer_last_line_get() -> i64:
    if rt_array_len_safe(core_last_token_line_slot) == 0:
        return 0
    core_last_token_line_slot[0]

fn core_lexer_last_col_get() -> i64:
    if rt_array_len_safe(core_last_token_col_slot) == 0:
        return 0
    core_last_token_col_slot[0]

fn core_lexer_last_suffix_get() -> text:
    if rt_array_len_safe(core_last_token_suffix_slot) == 0:
        return ""
    core_last_token_suffix_slot[0]

# ===== CoreLexer Struct =====

struct CoreLexer:
    source: text
    # Char-indexed view of `source`, built once (O(N)). Every scan reads chars
    # via this array in O(1), instead of `source[pos:pos+1]` which rebuilds a
    # full Vec<char> per call (O(N)) -> O(N^2)/file. Per-instance, so nested/
    # re-entrant lexing is isolated (no shared-cache staleness). Char-indexed
    # also removes the pos(char)-vs-len(byte) mismatch that stalled the scanner.
    source_chars: [text]
    pos: i64
    line: i64
    col: i64
    indent_stack: [i64]
    pending_dedents: i64
    at_line_start: bool
    paren_depth: i64
    cur_kind: i64
    cur_text: text
    cur_line: i64
    cur_col: i64
    cur_start: i64

# ===== Constructor (free function) =====

fn make_core_lexer(source: text) -> CoreLexer:
    CoreLexer(source: source, source_chars: source.chars(), pos: 0, line: 1, col: 1, indent_stack: [0], pending_dedents: 0, at_line_start: true, paren_depth: 0, cur_kind: 0, cur_text: "", cur_line: 0, cur_col: 0, cur_start: 0)

# ===== CoreLexer Methods =====

impl CoreLexer:

    # ----- Read-only accessors -----

    fn at_end() -> bool:
        # Char-indexed: pos and length are both in chars, so this is exact
        # (no byte-vs-char mismatch that previously stalled the scanner).
        self.pos >= self.source_chars.len()

    fn peek() -> text:
        if self.pos >= self.source_chars.len():
            return ""
        self.source_chars[self.pos]

    fn peek_next() -> text:
        val next_pos: i64 = self.pos + 1
        if next_pos >= self.source_chars.len():
            return ""
        self.source_chars[next_pos]

    fn peek_at(offset: i64) -> text:
        val target: i64 = self.pos + offset
        if target >= self.source_chars.len():
            return ""
        self.source_chars[target]

    # Token-text extraction over a [start,end) char range: O(span) via array
    # slice + join, replacing `source[start:end]` which was O(N) per call.
    fn char_slice(start: i64, end: i64) -> text:
        var s: i64 = start
        if s < 0:
            s = 0
        var e: i64 = end
        val n: i64 = self.source_chars.len()
        if e > n:
            e = n
        if e <= s:
            return ""
        # Build char-by-char via index access instead of `source_chars[s:e].join("")`:
        # the array-slice `[s:e]` (and/or `.join`) returns an EMPTY string in the
        # SimpleOS guest (native value-type array-slice bug), so every identifier
        # token text came out empty and no name resolved in the in-guest
        # interpreter. Individual index access `source_chars[i]` works, so a manual
        # concatenation loop is correct on both host and guest.
        var result: text = ""
        var i: i64 = s
        while i < e:
            result = result + self.source_chars[i]
            i = i + 1
        result

    fn token_kind() -> i64:
        self.cur_kind

    fn token_text() -> text:
        self.cur_text

    fn token_line() -> i64:
        self.cur_line

    fn token_col() -> i64:
        self.cur_col

    # ----- Mutating methods -----

    me advance() -> text:
        if self.pos >= self.source_chars.len():
            return ""
        val c: text = self.source_chars[self.pos]
        self.pos = self.pos + 1
        if c == "\n":
            self.line = self.line + 1
            self.col = 1
            self.at_line_start = true
        else:
            self.col = self.col + 1
        c

    me match_char(expected: text) -> bool:
        if self.pos >= self.source_chars.len():
            return false
        if self.source_chars[self.pos] != expected:
            return false
        self.pos = self.pos + 1
        self.col = self.col + 1
        true

    # ----- Token Construction -----

    me make_token(kind: i64, tok_text: text, start_line: i64, start_col: i64):
        self.cur_kind = kind
        self.cur_text = tok_text
        self.cur_line = start_line
        self.cur_col = start_col
        core_token_capture(tok_text, start_line, start_col)
        val nul = char_from_code(0)
        if tok_text.contains(nul):
            core_token_text_save("")
        else:
            core_token_text_save(tok_text)
        if core_token_env_save_enabled():
            rt_env_set("SIMPLE_BOOTSTRAP_CORE_TOKEN_LINE", "{start_line}")
            rt_env_set("SIMPLE_BOOTSTRAP_CORE_TOKEN_COL", "{start_col}")

    me make_simple(kind: i64, tok_text: text):
        val sl: i64 = self.line
        val sc: i64 = self.col
        self.make_token(kind, tok_text, sl, sc)

    # ----- Skip Whitespace (not newlines) -----

    me skip_spaces():
        for i in 0..100000:
            val c: text = self.peek()
            if c == " ":
                self.advance()
            elif c == "\t":
                self.advance()
            elif c == "\r":
                # CRLF tolerance (#145): consume the carriage return so the
                # following "\n" is lexed as a normal newline.
                self.advance()
            else:
                break

    # ----- Number Scanning -----

    me scan_number():
        val start: i64 = self.pos
        val start_line: i64 = self.line
        val start_col: i64 = self.col
        self.cur_start = start
        var is_float: bool = false
        val src: [text] = self.source_chars
        val src_len: i64 = src.len()
        var pos: i64 = self.pos

        # Check for hex, binary, octal prefix
        val first: text = if pos < src_len then src[pos] else ""
        if first == "0":
            val second: text = if pos + 1 < src_len then src[pos + 1] else ""
            if second == "x":
                # Hex literal
                pos = pos + 2
                for i in 0..64:
                    if pos >= src_len:
                        break
                    val hc: text = src[pos]
                    if hc == "_":
                        pos = pos + 1
                    elif is_hex_digit(hc):
                        pos = pos + 1
                    else:
                        break
                var num_text: text = self.char_slice(start, pos)
                # Type suffix: 0x10000000u64 / 0x1234_u64 (decimal parity;
                # the hex-digit loop already stopped at the non-hex alpha).
                var hex_suffix: text = ""
                val hxlen: i64 = num_text.len()
                val after_hex: text = if pos < src_len then src[pos] else ""
                if is_alpha(after_hex):
                    if hxlen > 0 and num_text[hxlen - 1:hxlen] == "_":
                        num_text = num_text[0:hxlen - 1]
                    var hsuf_start: i64 = pos
                    for si in 0..1000:
                        if pos >= src_len:
                            break
                        if is_ident_char(src[pos]):
                            pos = pos + 1
                        else:
                            break
                    hex_suffix = self.char_slice(hsuf_start, pos)
                core_token_suffix_save(hex_suffix)
                if hex_suffix != "":
                    self.pos = pos
                    self.col = self.col + (pos - start)
                    self.make_token(7, num_text, start_line, start_col)
                else:
                    self.pos = pos
                    self.col = self.col + (pos - start)
                    self.make_token(1, num_text, start_line, start_col)
                self.cur_text = num_text
                core_token_text_save(num_text)
                return
            if second == "b":
                # Binary literal
                pos = pos + 2
                for i in 0..64:
                    if pos >= src_len:
                        break
                    val bc: text = src[pos]
                    val is_bin: bool = bc == "0"
                    val is_bin1: bool = bc == "1"
                    val is_under: bool = bc == "_"
                    val is_bin_char: bool = is_bin or is_bin1
                    val valid: bool = is_bin_char or is_under
                    if valid:
                        pos = pos + 1
                    else:
                        break
                val num_text: text = self.char_slice(start, pos)
                self.pos = pos
                self.col = self.col + (pos - start)
                self.make_token(1, num_text, start_line, start_col)
                self.cur_text = num_text
                core_token_text_save(num_text)
                return
            if second == "o":
                # Octal literal
                pos = pos + 2
                for i in 0..64:
                    if pos >= src_len:
                        break
                    val oc: text = src[pos]
                    val is_oct: bool = is_digit(oc)
                    val is_under: bool = oc == "_"
                    val valid: bool = is_oct or is_under
                    if valid:
                        pos = pos + 1
                    else:
                        break
                val num_text: text = self.char_slice(start, pos)
                self.pos = pos
                self.col = self.col + (pos - start)
                self.make_token(1, num_text, start_line, start_col)
                self.cur_text = num_text
                core_token_text_save(num_text)
                return

        # Decimal number
        for i in 0..100:
            if pos >= src_len:
                break
            val dc: text = src[pos]
            val is_d: bool = is_digit(dc)
            val is_u: bool = dc == "_"
            val valid: bool = is_d or is_u
            if valid:
                pos = pos + 1
            else:
                break

        # Check for float
        val maybe_dot: text = if pos < src_len then src[pos] else ""
        val after_dot: text = if pos + 1 < src_len then src[pos + 1] else ""
        val dot_then_digit: bool = maybe_dot == "."
        if dot_then_digit:
            val is_next_dig: bool = is_digit(after_dot)
            if is_next_dig:
                is_float = true
                pos = pos + 1
                for i in 0..100:
                    if pos >= src_len:
                        break
                    val fc: text = src[pos]
                    val is_fd: bool = is_digit(fc)
                    val is_fu: bool = fc == "_"
                    val fvalid: bool = is_fd or is_fu
                    if fvalid:
                        pos = pos + 1
                    else:
                        break

        # Check for exponent
        val exp_c: text = if pos < src_len then src[pos] else ""
        val is_exp_e: bool = exp_c == "e"
        val is_exp_E: bool = exp_c == "E"
        val has_exp: bool = is_exp_e or is_exp_E
        if has_exp:
            is_float = true
            pos = pos + 1
            val sign: text = if pos < src_len then src[pos] else ""
            val is_plus: bool = sign == "+"
            val is_minus: bool = sign == "-"
            val has_sign: bool = is_plus or is_minus
            if has_sign:
                pos = pos + 1
            for i in 0..100:
                if pos >= src_len:
                    break
                val ec: text = src[pos]
                if is_digit(ec):
                    pos = pos + 1
                else:
                    break

        var num_text: text = self.char_slice(start, pos)

        # Unit/type suffix: `10_u8` (underscore form) or `10u8`/`5ms` (direct
        # alpha, seed lexer parity — an alpha run glued to a number can only
        # be a suffix, since identifiers cannot start with a digit). Exponent
        # forms (`1e5`) were consumed above and never reach here with an
        # alpha follower. Suffix travels via the CORE_TOKEN_SUFFIX env channel.
        var suffix: text = ""
        val nlen: i64 = num_text.len()
        val next_ch: text = if pos < src_len then src[pos] else ""
        if is_alpha(next_ch):
            if nlen > 0 and num_text[nlen - 1:nlen] == "_":
                num_text = num_text[0:nlen - 1]
            var suf_start: i64 = pos
            for i in 0..1000:
                if pos >= src_len:
                    break
                if is_ident_char(src[pos]):
                    pos = pos + 1
                else:
                    break
            suffix = self.char_slice(suf_start, pos)
        self.pos = pos
        self.col = self.col + (pos - start)
        if suffix != "":
            if is_float:
                self.make_token(8, num_text, start_line, start_col)
            else:
                self.make_token(7, num_text, start_line, start_col)
        elif is_float:
            self.make_token(2, num_text, start_line, start_col)
        else:
            self.make_token(1, num_text, start_line, start_col)
        core_token_suffix_save(suffix)
        self.cur_text = num_text
        core_token_text_save(num_text)

    # ----- String Scanning -----

    me scan_string():
        val start_line: i64 = self.line
        val start_col: i64 = self.col
        self.cur_start = self.pos
        val quote: text = self.advance()

        # Triple-quoted string: """ or ''' — content may span newlines.
        # Mirrors lex_scan_string in lexer_scanners.spl; without this branch
        # docstrings lex as `""` + unterminated string (parse errors on every
        # module with a multi-line docstring).
        val tq1: text = self.peek()
        val tq2: text = self.peek_next()
        val is_tq1: bool = tq1 == quote
        val is_tq2: bool = tq2 == quote
        if is_tq1 and is_tq2:
            self.advance()
            self.advance()
            val seg_start: i64 = self.pos
            for i in 0..1000000:
                if self.at_end():
                    break
                val c0: text = self.peek()
                val c1: text = self.peek_next()
                val c2: text = self.peek_at(2)
                val close01: bool = c0 == quote and c1 == quote
                val close_all: bool = close01 and c2 == quote
                if close_all:
                    break
                self.advance()
            val content: text = self.char_slice(seg_start, self.pos)
            if not self.at_end():
                self.advance()
                self.advance()
                self.advance()
            # We are mid-line right after the closing quotes; clear any stale
            # line-start flag set by newlines consumed inside the string.
            self.at_line_start = false
            self.make_token(3, content, start_line, start_col)
            self.cur_text = content
            val nul3 = char_from_code(0)
            if content.contains(nul3):
                core_token_text_save("")
            else:
                core_token_text_save(content)
            return

        var parts: [text] = []
        var done: bool = false
        var has_nul: bool = false

        for i in 0..100000:
            if done:
                break
            if self.at_end():
                self.make_token(191, "unterminated string", start_line, start_col)
                return
            val c: text = self.peek()
            if c == "\n":
                self.make_token(191, "unterminated string", start_line, start_col)
                return
            if c == quote:
                self.advance()
                done = true
            elif c == "\\":
                self.advance()
                val esc: text = self.advance()
                if esc == "n":
                    parts.push("\n")
                elif esc == "t":
                    parts.push("\t")
                elif esc == "r":
                    parts.push("\r")
                elif esc == "\\":
                    parts.push("\\")
                elif esc == "\"":
                    parts.push("\"")
                elif esc == "'":
                    parts.push("'")
                elif esc == "x":
                    var hv: i64 = 0
                    var hn: i64 = 0
                    for j in 0..2:
                        val hd: i64 = lex_escape_hex_value(self.peek())
                        if hd >= 0:
                            hv = hv * 16 + hd
                            self.advance()
                            hn = hn + 1
                    if hn > 0:
                        if hv == 0:
                            has_nul = true
                        parts.push(char_from_code(hv))
                    else:
                        parts.push("\\")
                        parts.push("x")
                elif esc == "u":
                    if self.peek() == "{":
                        self.advance()
                        var uv: i64 = 0
                        for j in 0..8:
                            val ud: i64 = lex_escape_hex_value(self.peek())
                            if ud >= 0:
                                uv = uv * 16 + ud
                                self.advance()
                        if self.peek() == "}":
                            self.advance()
                        if uv == 0:
                            has_nul = true
                        parts.push(char_from_code(uv))
                    else:
                        parts.push("\\")
                        parts.push("u")
                elif lex_escape_octal_value(esc) >= 0:
                    var ov: i64 = lex_escape_octal_value(esc)
                    for j in 0..2:
                        val od: i64 = lex_escape_octal_value(self.peek())
                        if od >= 0:
                            ov = ov * 8 + od
                            self.advance()
                    if ov == 0:
                        has_nul = true
                    parts.push(char_from_code(ov))
                else:
                    parts.push("\\")
                    parts.push(esc)
            elif c == "{":
                # G38: "{expr}" interpolation may contain nested strings whose
                # quotes must not terminate the outer string (seed
                # scan_fstring_impl parity). `{` immediately followed by a
                # quote is a literal brace (seed special case). Otherwise
                # lookahead for the matching `}` tracking brace depth and
                # nested-string state; if none before end-of-line, the `{`
                # is a literal brace (CSS/JSON patterns). On success the
                # whole `{...}` is copied verbatim (inner escapes kept raw
                # for the downstream interpolation re-parse).
                val la_next: text = self.peek_next()
                val la_is_quote: bool = la_next == "\"" or la_next == "'"
                var la_found: i64 = -1
                if not la_is_quote:
                    var la: i64 = self.pos + 1
                    val src_len: i64 = self.source_chars.len()
                    var la_depth: i64 = 1
                    var la_str: text = ""
                    var la_esc: bool = false
                    for j in 0..100000:
                        if la >= src_len:
                            break
                        val lc: text = self.source_chars[la]
                        if lc == "\n":
                            break
                        if la_str != "":
                            if la_esc:
                                la_esc = false
                            elif lc == "\\":
                                la_esc = true
                            elif lc == la_str:
                                la_str = ""
                        else:
                            if lc == "\"":
                                la_str = lc
                            elif lc == "'":
                                la_str = lc
                            elif lc == "{":
                                la_depth = la_depth + 1
                            elif lc == "}":
                                la_depth = la_depth - 1
                                if la_depth == 0:
                                    la_found = la
                                    break
                        la = la + 1
                if la_found >= 0:
                    for j in 0..100000:
                        if self.pos > la_found:
                            break
                        parts.push(self.advance())
                else:
                    parts.push(self.advance())
            else:
                parts.push(self.advance())
        val result: text = parts.join("")

        self.make_token(3, result, start_line, start_col)
        self.cur_text = result
        # has_nul flag, not contains(): NUL-bearing text breaks contains()
        # (C-string truncation) — proven by rt_env_set panics on "\033" files.
        if has_nul:
            core_token_text_save("")
        else:
            core_token_text_save(result)

    # ----- Raw String Scanning (r"...") -----

    me scan_raw_string(start_line: i64, start_col: i64):
        # Consume the opening double-quote (the `r` was already consumed by scan_ident).
        self.advance()  # consume opening "
        # Raw triple strings preserve backslashes/interpolation markers and may
        # span lines, matching the Rust seed's r"""...""" grammar.
        if self.peek() == "\"" and self.peek_next() == "\"":
            self.advance()
            self.advance()
            val raw_start: i64 = self.pos
            for i in 0..1000000:
                if self.at_end():
                    self.make_token(191, "unterminated string", start_line, start_col)
                    return
                if self.peek() == "\"" and self.peek_next() == "\"" and self.peek_at(2) == "\"":
                    val raw_triple = self.char_slice(raw_start, self.pos)
                    self.advance()
                    self.advance()
                    self.advance()
                    self.at_line_start = false
                    self.make_token(3, raw_triple, start_line, start_col)
                    self.cur_text = raw_triple
                    core_token_text_save(raw_triple)
                    return
                self.advance()

        # No escape processing: backslashes and all chars are literal.
        # Terminated by the first `"`.  Cannot span newlines.
        var raw_parts: [text] = []
        var raw_done: bool = false
        for i in 0..100000:
            if raw_done:
                break
            if self.at_end():
                self.make_token(191, "unterminated string", start_line, start_col)
                return
            val rc: text = self.peek()
            if rc == "\n":
                self.make_token(191, "unterminated string", start_line, start_col)
                return
            if rc == "\"":
                self.advance()
                raw_done = true
            else:
                raw_parts.push(self.advance())
        val raw_result: text = raw_parts.join("")
        self.make_token(3, raw_result, start_line, start_col)
        self.cur_text = raw_result
        core_token_text_save(raw_result)

    # ----- Identifier/Keyword Scanning -----

    me scan_ident():
        val start: i64 = self.pos
        val start_line: i64 = self.line
        val start_col: i64 = self.col
        self.cur_start = start
        val src: [text] = self.source_chars
        val src_len: i64 = src.len()
        var pos: i64 = self.pos

        for i in 0..1000:
            if pos >= src_len:
                break
            val c: text = src[pos]
            if is_ident_char(c):
                pos = pos + 1
            else:
                break

        self.pos = pos
        # identifiers never contain newlines
        self.col = self.col + (pos - start)
        # `src[start:pos].join("")` returns "" in the SimpleOS guest (native
        # value-type array-slice bug); char_slice builds it via an index loop.
        val ident_text: text = self.char_slice(start, pos)

        # G36: r"..." raw string — backslashes are literal, no escape processing.
        # Matches Rust seed scan_raw_double_string semantics: read until closing "
        # (cannot span newlines). Emits kind 3 (StringLit) with raw content.
        if ident_text == "r":
            val next_ch: text = if pos < src_len then src[pos] else ""
            if next_ch == "\"":
                self.scan_raw_string(start_line, start_col)
                return

        # Check for keyword
        val kw_kind: i64 = keyword_lookup(ident_text)
        if kw_kind != 6:
            # Special: true/false -> bool literal, nil -> nil literal
            if kw_kind == 58:
                self.make_token(4, "true", start_line, start_col)
                self.cur_text = "true"
                core_token_text_save("true")
            elif kw_kind == 59:
                self.make_token(4, "false", start_line, start_col)
                self.cur_text = "false"
                core_token_text_save("false")
            elif kw_kind == 5:
                self.make_token(5, "nil", start_line, start_col)
                self.cur_text = "nil"
                core_token_text_save("nil")
            else:
                self.make_token(kw_kind, ident_text, start_line, start_col)
                self.cur_text = ident_text
                core_token_text_save(ident_text)
        else:
            # Check for underscore-only as special token
            if ident_text == "_":
                self.make_token(169, "_", start_line, start_col)
                self.cur_text = "_"
                core_token_text_save("_")
            else:
                self.make_token(6, ident_text, start_line, start_col)
                self.cur_text = ident_text
                core_token_text_save(ident_text)

    # ----- Indentation Handling -----

    me handle_indentation():
        # Count leading whitespace
        var indent_level: i64 = 0
        for i in 0..10000:
            val c: text = self.peek()
            if c == " ":
                indent_level = indent_level + 1
                self.advance()
            elif c == "\t":
                indent_level = indent_level + 4
                self.advance()
            elif c == "\r":
                # CRLF tolerance (#145): zero-width — "\r" only precedes "\n".
                self.advance()
            else:
                break

        # Skip blank lines and comment-only lines
        val next_c: text = self.peek()
        val is_blank: bool = next_c == "\n"
        val is_end: bool = next_c == ""
        val is_comment: bool = next_c == "#"
        if is_blank:
            self.advance()
            self.at_line_start = true
            self.scan_token()
            return
        if is_end:
            return
        if is_comment:
            # Skip comment, then the newline
            for i in 0..100000:
                val cc: text = self.peek()
                val is_nl: bool = cc == "\n"
                val is_eof: bool = cc == ""
                val done: bool = is_nl or is_eof
                if done:
                    break
                self.advance()
            val peek_nl: text = self.peek()
            if peek_nl == "\n":
                self.advance()
            self.at_line_start = true
            self.scan_token()
            return

        self.at_line_start = false

        # Leading-dot method-chain / leading-pipe pattern-alternative
        # continuation: a line starting with `.` or `|` continues the
        # previous expression — suppress Indent/Dedent.
        if next_c == "." or next_c == "|":
            self.scan_token()
            return

        # Inside parentheses/brackets: suppress Indent/Dedent tokens entirely.
        # The indent stack is left unchanged so it remains valid after the closing bracket.
        if self.paren_depth > 0:
            self.scan_token()
            return

        # G27: a trailing RHS-requiring token continues the logical line.
        if token_requires_rhs(self.cur_kind):
            self.scan_token()
            return

        # Compare with current indent level
        val stack_len: i64 = self.indent_stack.len()
        val current_indent: i64 = self.indent_stack[stack_len - 1]

        if indent_level > current_indent:
            self.indent_stack.push(indent_level)
            val tl: i64 = self.line
            self.make_token(181, "", tl, 1)
        elif indent_level < current_indent:
            # Pop indent stack and count dedents
            var dedent_count: i64 = 0
            for i in 0..100:
                val slen: i64 = self.indent_stack.len()
                if slen <= 1:
                    break
                val top: i64 = self.indent_stack[slen - 1]
                if top <= indent_level:
                    break
                self.indent_stack.pop()
                dedent_count = dedent_count + 1

            # First dedent is returned immediately, rest are pending
            if dedent_count > 0:
                self.pending_dedents = dedent_count - 1
                val tl: i64 = self.line
                self.make_token(182, "", tl, 1)
            else:
                # Indent level doesn't match any in stack - error
                val tl: i64 = self.line
                self.make_token(191, "inconsistent indentation", tl, 1)
        else:
            # Same indentation - no token needed, continue scanning
            self.scan_token()

    # ----- Main Token Scanner -----

    # ponytail: trampoline — the Rust seed interpreter cannot dispatch a
    # self-recursive `me` call (Function 'CoreLexer.scan_token' not found);
    # routing the rescan through this second method makes every hop a
    # cross-method call, which the seed resolves fine.
    me scan_token_rescan():
        self.scan_token()

    me scan_token():
        # Skip spaces (not newlines) - but NOT at line start (indentation needs them)
        if not self.at_line_start:
            self.skip_spaces()

        if self.at_end():
            # Emit pending dedents for remaining indentation
            val slen: i64 = self.indent_stack.len()
            if slen > 1:
                self.indent_stack.pop()
                self.pending_dedents = slen - 2
                val tl: i64 = self.line
                val tc: i64 = self.col
                self.make_token(182, "", tl, tc)
                return
            val tl: i64 = self.line
            val tc: i64 = self.col
            self.make_token(190, "", tl, tc)
            return

        val start_line: i64 = self.line
        val start_col: i64 = self.col
        val c: text = self.peek()
        self.cur_start = self.pos

        # Newline
        if c == "\n":
            self.advance()
            self.at_line_start = true
            if self.paren_depth > 0:
                # Inside parens: suppress newline, scan next token
                self.scan_token_rescan()
                return
            # G27: a trailing RHS-requiring token continues the logical line.
            if token_requires_rhs(self.cur_kind):
                self.scan_token_rescan()
                return
            # Leading-dot / leading-pipe continuation: if the next line's first
            # non-blank char is `.` or `|`, suppress the newline (continuation).
            var dot_la: i64 = self.pos
            for _di in 0..100000:
                val dc: text = if dot_la < self.source_chars.len() then self.source_chars[dot_la] else ""
                if dc == " " or dc == "\t":
                    dot_la = dot_la + 1
                else:
                    break
            val la_c: text = if dot_la < self.source_chars.len() then self.source_chars[dot_la] else ""
            if la_c == "." or la_c == "|":
                self.scan_token_rescan()
                return
            self.make_token(180, "\n", start_line, start_col)
            return

        # Handle indentation at line start
        if self.at_line_start:
            self.handle_indentation()
            return

        # Comment
        if c == "#":
            # Skip comment to end of line
            for i in 0..100000:
                val cc: text = self.peek()
                val is_nl: bool = cc == "\n"
                val is_eof: bool = cc == ""
                val done: bool = is_nl or is_eof
                if done:
                    break
                self.advance()
            # Recurse to get next real token
            self.scan_token_rescan()
            return

        # String literal
        val is_dquote: bool = c == "\""
        val is_squote: bool = c == "'"
        if is_dquote:
            self.scan_string()
            return
        if is_squote:
            self.scan_string()
            return

        # Number literal
        if is_digit(c):
            self.scan_number()
            return

        # Identifier or keyword
        val is_al: bool = is_alpha(c)
        val is_un: bool = c == "_"
        val starts_ident: bool = is_al or is_un
        if starts_ident:
            self.scan_ident()
            return

        # Operators and delimiters (single char consumed via advance)
        self.advance()

        # Two+ character operators
        if c == "=":
            if self.match_char("="):
                self.make_token(80, "==", start_line, start_col)
            elif self.match_char(">"):
                self.make_token(168, "=>", start_line, start_col)
            else:
                self.make_token(100, "=", start_line, start_col)
            return

        if c == "!":
            if self.match_char("="):
                self.make_token(81, "!=", start_line, start_col)
            else:
                self.make_token(57, "!", start_line, start_col)
            return

        if c == "<":
            if self.match_char("="):
                self.make_token(84, "<=", start_line, start_col)
            else:
                self.make_token(82, "<", start_line, start_col)
            return

        if c == ">":
            if self.match_char("="):
                self.make_token(85, ">=", start_line, start_col)
            else:
                self.make_token(83, ">", start_line, start_col)
            return

        if c == "+":
            if self.match_char("="):
                self.make_token(101, "+=", start_line, start_col)
            else:
                self.make_token(60, "+", start_line, start_col)
            return

        if c == "-":
            if self.match_char(">"):
                self.make_token(167, "->", start_line, start_col)
            elif self.match_char("="):
                self.make_token(102, "-=", start_line, start_col)
            else:
                self.make_token(61, "-", start_line, start_col)
            return

        if c == "*":
            if self.match_char("*"):
                self.make_token(65, "**", start_line, start_col)
            elif self.match_char("="):
                self.make_token(103, "*=", start_line, start_col)
            else:
                self.make_token(62, "*", start_line, start_col)
            return

        if c == "/":
            if self.match_char("/"):
                self.make_token(191, "use # for comments", start_line, start_col)
            elif self.match_char("="):
                self.make_token(104, "/=", start_line, start_col)
            else:
                self.make_token(63, "/", start_line, start_col)
            return

        if c == "%":
            if self.match_char("="):
                self.make_token(105, "%=", start_line, start_col)
            else:
                self.make_token(64, "%", start_line, start_col)
            return

        if c == ".":
            val d1: text = self.peek()
            if d1 == ".":
                self.advance()
                val d2: text = self.peek()
                if d2 == ".":
                    self.advance()
                    self.make_token(173, "...", start_line, start_col)
                elif d2 == "=":
                    self.advance()
                    self.make_token(166, "..=", start_line, start_col)
                else:
                    self.make_token(165, "..", start_line, start_col)
            elif d1 == "?":
                self.advance()
                self.make_token(133, ".?", start_line, start_col)
            else:
                self.make_token(164, ".", start_line, start_col)
            return

        if c == "?":
            val q1: text = self.peek()
            if q1 == "?":
                self.advance()
                self.make_token(132, "??", start_line, start_col)
            elif q1 == ".":
                self.advance()
                self.make_token(131, "?.", start_line, start_col)
            else:
                self.make_token(130, "?", start_line, start_col)
            return

        if c == "|":
            if self.match_char(">"):
                self.make_token(175, "|>", start_line, start_col)
            elif self.match_char("|"):
                # G32: `||` is logical-or — same kind as keyword `or`
                self.make_token(56, "||", start_line, start_col)
            else:
                self.make_token(121, "|", start_line, start_col)
            return

        if c == "&":
            if self.match_char("&"):
                # G32: `&&` is logical-and — same kind as keyword `and`
                self.make_token(55, "&&", start_line, start_col)
            elif self.match_char(":"):
                # `&:method` method-reference sigil (AmpColon, seed parity)
                self.make_token(210, "&:", start_line, start_col)
            else:
                self.make_token(120, "&", start_line, start_col)
            return

        if c == "^":
            self.make_token(122, "^", start_line, start_col)
            return

        if c == "~":
            self.make_token(123, "~", start_line, start_col)
            return

        if c == "@":
            self.make_token(171, "@", start_line, start_col)
            return

        if c == ";":
            self.make_token(163, ";", start_line, start_col)
            return

        # Delimiters (track paren depth)
        if c == "(":
            self.paren_depth = self.paren_depth + 1
            self.make_token(140, "(", start_line, start_col)
            return

        if c == ")":
            if self.paren_depth > 0:
                self.paren_depth = self.paren_depth - 1
            self.make_token(141, ")", start_line, start_col)
            return

        if c == "[":
            self.paren_depth = self.paren_depth + 1
            self.make_token(144, "[", start_line, start_col)
            return

        if c == "]":
            if self.paren_depth > 0:
                self.paren_depth = self.paren_depth - 1
            self.make_token(145, "]", start_line, start_col)
            return

        if c == "{":
            self.paren_depth = self.paren_depth + 1
            self.make_token(142, "{", start_line, start_col)
            return

        if c == "}":
            if self.paren_depth > 0:
                self.paren_depth = self.paren_depth - 1
            self.make_token(143, "}", start_line, start_col)
            return

        if c == ":":
            # G34: fuse `::` into TOK_COLON_COLON (kind 162) for path separators
            if self.match_char(":"):
                self.make_token(162, "::", start_line, start_col)
            else:
                self.make_token(161, ":", start_line, start_col)
            return

        if c == ",":
            self.make_token(160, ",", start_line, start_col)
            return

        if c == "\\":
            self.make_token(220, "\\", start_line, start_col)
            return

        # Unknown character
        val err_msg: text = "unexpected character: {c}"
        self.make_token(191, err_msg, start_line, start_col)

    # ----- Public API -----

    me next_token() -> i64:
        # Check for pending dedents
        if self.pending_dedents > 0:
            self.pending_dedents = self.pending_dedents - 1
            self.cur_kind = 182
            self.cur_text = ""
            return 182

        self.scan_token()
        return self.cur_kind

    # Parser-owned generic type closing uses the same `>` token as binary
    # greater-than. Clear the prior token inside the CoreLexer owner so newline
    # scanning does not apply binary RHS continuation and swallow a dedent.
    me next_token_after_generic_close() -> i64:
        self.cur_kind = 0
        self.next_token()

fn core_lexer_next_token(lexer: CoreLexer) -> (CoreLexer, i64):
    var next_lexer = lexer
    if next_lexer.pending_dedents > 0:
        next_lexer.pending_dedents = next_lexer.pending_dedents - 1
        next_lexer.cur_kind = 182
        next_lexer.cur_text = ""
        return (next_lexer, 182)
    next_lexer.scan_token()
    val kind = next_lexer.cur_kind
    (next_lexer, kind)

fn core_lexer_token_text(lexer: CoreLexer) -> text:
    lexer.token_text()

fn core_lexer_token_line(lexer: CoreLexer) -> i64:
    lexer.token_line()

fn core_lexer_token_col(lexer: CoreLexer) -> i64:
    lexer.token_col()

fn core_lexer_token_start(lexer: CoreLexer) -> i64:
    lexer.cur_start

fn core_lexer_token_end(lexer: CoreLexer) -> i64:
    lexer.pos

export core_lexer_last_text_get, core_lexer_last_line_get, core_lexer_last_col_get, core_lexer_last_suffix_get, core_token_env_save_set
export core_lexer_token_start, core_lexer_token_end
