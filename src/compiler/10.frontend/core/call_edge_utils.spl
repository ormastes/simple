# Core Simple — Shared Call-Edge Extraction
#
# Common call-graph building logic used by both alloc_inference and call_graph.

use compiler.core.ast.{DECL_FN, EXPR_CALL, EXPR_IDENT}
use compiler.core.ast.{STMT_IF}
use compiler.core.ast.{decl_count, decl_get_tag, decl_get_name, decl_get_body}
use compiler.core.ast.{stmt_get_tag, stmt_get_expr, stmt_get_body, stmt_get_type}
use compiler.core.ast.{expr_get_tag, expr_get_str, expr_get_left, expr_get_right, expr_get_extra}
use compiler.core.ast.{expr_get_args, expr_get_stmts}
use compiler.core.ast.{elif_get_cond, elif_get_body, elif_get_else}

# ===== Module State =====

var ceu_fn_names: [text] = []
var ceu_fn_count: i64 = 0
var ceu_fn_index = {}
var ceu_callees: [[text]] = []

# ===== Public API =====

fn ceu_reset():
    ceu_fn_names = []
    ceu_fn_count = 0
    ceu_fn_index = {}
    ceu_callees = []

fn ceu_register_functions():
    val total = decl_count()
    for i in range(0, total):
        val tag = decl_get_tag(i)
        if tag == DECL_FN:
            val name = decl_get_name(i)
            ceu_fn_index[name] = ceu_fn_count
            ceu_fn_names.push(name)
            ceu_callees.push([])
            ceu_fn_count = ceu_fn_count + 1

fn ceu_extract_call_edges():
    var fn_idx = 0
    val total = decl_count()
    for i in range(0, total):
        val tag = decl_get_tag(i)
        if tag == DECL_FN:
            val body = decl_get_body(i)
            for stmt_idx in body:
                ceu_collect_calls_from_stmt(stmt_idx, fn_idx)
            fn_idx = fn_idx + 1

fn ceu_get_fn_names() -> [text]:
    ceu_fn_names

fn ceu_get_fn_count() -> i64:
    ceu_fn_count

fn ceu_get_fn_index():
    ceu_fn_index

fn ceu_get_callees() -> [[text]]:
    ceu_callees

# ===== Internal Helpers =====

fn ceu_add_callee(fn_idx: i64, callee_name: text):
    val existing = ceu_callees[fn_idx]
    for name in existing:
        if name == callee_name:
            return
    var updated = ceu_callees[fn_idx]
    updated.push(callee_name)
    ceu_callees[fn_idx] = updated

fn ceu_collect_calls_from_stmt(stmt_idx: i64, fn_idx: i64):
    val tag = stmt_get_tag(stmt_idx)
    val expr_idx = stmt_get_expr(stmt_idx)
    val body = stmt_get_body(stmt_idx)

    if expr_idx >= 0:
        ceu_collect_calls_from_expr(expr_idx, fn_idx)

    for nested in body:
        ceu_collect_calls_from_stmt(nested, fn_idx)

    if tag == STMT_IF:
        val elif_idx = stmt_get_type(stmt_idx)
        if elif_idx >= 0:
            ceu_collect_calls_from_elif(elif_idx, fn_idx)

fn ceu_collect_calls_from_elif(elif_idx: i64, fn_idx: i64):
    if elif_idx < 0:
        return
    val cond = elif_get_cond(elif_idx)
    if cond >= 0:
        ceu_collect_calls_from_expr(cond, fn_idx)
    val body = elif_get_body(elif_idx)
    for stmt_idx in body:
        ceu_collect_calls_from_stmt(stmt_idx, fn_idx)
    val else_body = elif_get_else(elif_idx)
    for stmt_idx in else_body:
        ceu_collect_calls_from_stmt(stmt_idx, fn_idx)

fn ceu_collect_calls_from_expr(expr_idx: i64, fn_idx: i64):
    if expr_idx < 0:
        return
    val tag = expr_get_tag(expr_idx)

    if tag == EXPR_CALL:
        val callee = expr_get_left(expr_idx)
        if callee >= 0:
            val callee_tag = expr_get_tag(callee)
            if callee_tag == EXPR_IDENT:
                val callee_name = expr_get_str(callee)
                ceu_add_callee(fn_idx, callee_name)

    val left = expr_get_left(expr_idx)
    val right = expr_get_right(expr_idx)
    val extra = expr_get_extra(expr_idx)
    val args = expr_get_args(expr_idx)
    val stmts = expr_get_stmts(expr_idx)

    if left >= 0:
        ceu_collect_calls_from_expr(left, fn_idx)
    if right >= 0:
        ceu_collect_calls_from_expr(right, fn_idx)
    if extra >= 0:
        ceu_collect_calls_from_expr(extra, fn_idx)
    for arg_idx in args:
        ceu_collect_calls_from_expr(arg_idx, fn_idx)
    for stmt_idx in stmts:
        ceu_collect_calls_from_stmt(stmt_idx, fn_idx)
