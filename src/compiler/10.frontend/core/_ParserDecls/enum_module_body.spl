# Declaration parsing: enum, top-level visibility, module body.
use compiler.frontend.core.parser_decls.*
# Parser — Declaration Module
#
# Declaration parsing: fn, extern fn, struct/class, enum.
# Use/export/binding/impl declarations extracted to parser_decls_use.spl.

use compiler.core.ast.{expr_ident, expr_call, expr_unit, expr_block, expr_binary, expr_field_access}
use compiler.core.ast.{expr_method_call, expr_bool_lit, expr_string_lit, expr_int_lit}
use compiler.core.ast.{stmt_expr_stmt}
use compiler.core.ast.{DECL_FN, DECL_EXTERN_FN, DECL_STRUCT, DECL_USE, DECL_EXPORT}
use compiler.core.ast.{DECL_VAL, DECL_VAR, DECL_ENUM, DECL_LAZY_VAL}
use compiler.core.ast.{DECL_CE, decl_ce_block}
use compiler.core.ast.{decl_fn, decl_extern_fn, decl_struct_def}
use compiler.core.ast.{decl_val_binding, decl_lazy_val_binding, decl_var_binding}
use compiler.core.ast.{decl_use_import, decl_export_names, decl_enum_def, decl_set_lazy}
use compiler.core.ast.{decl_set_hardware, decl_set_clocked_args}
use compiler.core.ast.{decl_impl_block}
use compiler.core.ast.{decl_set_comptime}
use compiler.core.ast.{decl_set_visibility_text}
use compiler.core.ast.{decl_set_gpu_target_text, decl_set_gpu_target_arg_name_text, decl_set_gpu_backends_text}
use compiler.core.ast.{decl_set_unroll_factor, decl_set_pipeline_ii, decl_set_memory_banks}
use compiler.core.ast.{decl_is_gpu_kernel, decl_is_simd, decl_is_packed, decl_derives}
use compiler.core.ast.{decl_get_name, decl_get_fields, decl_get_field_bits, decl_get_derives, decl_set_derives}
use compiler.core.ast.{module_set_path, module_add_decl}
use compiler.frontend.core.lexer.{lex_pos_get, lex_pos_set, lex_line_get, lex_line_set, lex_col_get, lex_col_set, lex_token_start_get}
use compiler.frontend.core.lexer.{lex_source_char_at, lex_source_len, lex_source_slice}
use compiler.core.types.{TYPE_I64, TYPE_F64, TYPE_TEXT, TYPE_BOOL, TYPE_VOID}
use compiler.core.types.{TYPE_OPTION, TYPE_OPTION_I64, TYPE_OPTION_F64, TYPE_OPTION_TEXT, TYPE_OPTION_BOOL}
use compiler.core.types.{TYPE_RESULT, TYPE_NAMED_BASE, TYPE_DICT, TYPE_FN, TYPE_ANY}
use compiler.core.types.{int_to_str, type_tag_name, flat_span_new}
use compiler.core.types.{named_type_register, named_type_update, named_type_find, custom_primitive_register}
use compiler.core.types.{primitive_integer_bit_width_from_name, primitive_backing_bits_from_name}
use compiler.core.types.{custom_primitive_integer_bit_width_by_name, custom_primitive_backing_bits_by_name}
use compiler.core.parser.{par_kind_get, par_text_get, par_line_get, par_col_get, par_errors, par_struct_names}
use compiler.core.parser.{parser_advance, parser_expect, parser_error, parser_warn, parser_warn_print_if_needed}
use compiler.core.parser.{parser_skip_newlines, parser_skip_newlines_and_semicolons}
use compiler.core.parser.{parser_parse_type, parser_parse_type_with_union}
use compiler.core.tokens.{TOK_KW_AS, TOK_KW_CE}

# Import from sibling split modules
use compiler.frontend.core.parser_expr.{parse_expr, parse_int_text}
use compiler.frontend.core.parser_stmts.{parse_block, parse_if_expr, parse_for_expr, parse_while_expr}

# Re-export use/export/binding/impl declarations (extracted to parser_decls_use.spl)
use compiler.frontend.core.parser_decls_use.*
use std.nogc_sync_mut.io.process_ops.{eprint}

# Import CLI parser
use compiler.core.parser_cli.{parse_cli_decl}
extern fn rt_env_get(key: text) -> text

# ===== Helper Functions =====

fn parser_module_trace_enabled() -> bool:
    (rt_env_get("SIMPLE_COMPILER_TRACE") ?? "") == "1"

fn parse_enum_decl() -> i64:
    parser_advance()
    val enum_name = par_text_get()
    parser_expect(6)

    # Parse optional type parameters: enum Result<T, E>:
    val type_params = parse_type_params()

    # Pre-register enum name so type references resolve during parsing (same
    # reason struct decls do this -- see parse_struct_decl). Without this,
    # `named_type_find(enum_name)` never finds the enum, so any type-annotation
    # use of it (e.g. `-> MyEnum`, `x: MyEnum`, a struct/enum field of enum
    # type) falls through parser_parse_type's identifier branch all the way to
    # `return TYPE_VOID` -- an enum name silently types as void everywhere.
    # Most of the time this goes unnoticed because enum match/construct is
    # dispatched dynamically off the runtime-boxed value, not the static
    # declared type. But a function whose declared return type resolves to
    # TYPE_VOID reads as "no `-> T` was written" to decl_get_ret_type's
    # `ret > 0` check, so the flat-AST bridge's `has_ret` goes false and HIR
    # lowering picks the untyped-return-inference path
    # (`infer_untyped_return_type`), which hard-errors with "returns a value
    # but declares no return type" the moment the body actually returns one --
    # e.g. `fn make(n: i64) -> MyEnum: return MyEnum.A(n)`.
    val enum_type_id = named_type_register(enum_name, [], [])

    parser_expect(161)
    parser_skip_newlines()
    parser_expect(181)

    var variant_names: [text] = []
    var parse_enum_method_ids: [i64] = []

    for i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == 182:
            parser_advance()
            break
        if par_kind_get() == 190:
            break

        # Skip docstrings in enum body
        if par_kind_get() == 3:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # G10: fn method inside enum body (e.g. MatchResult.is_pass())
        if par_kind_get() == 20:
            val em_id = parse_class_body_method(enum_name, false, false)
            if em_id >= 0:
                parse_enum_method_ids.push(em_id)
            continue
        if par_kind_get() == 30:
            val esm_id = parse_class_body_method(enum_name, true, false)
            if esm_id >= 0:
                parse_enum_method_ids.push(esm_id)
            continue
        if par_kind_get() == 34:
            val emm_id = parse_class_body_method(enum_name, false, true)
            if emm_id >= 0:
                parse_enum_method_ids.push(emm_id)
            continue

        # G41: skip commas between same-line enum variants (e.g. A, B, C, D)
        if par_kind_get() == 160:
            parser_advance()
            continue

        # Skip comments that may appear as idents
        val vname = par_text_get()
        if par_kind_get() != 6:
            # Non-advancing guard: report once, advance, continue so loop does not stall
            parser_error("expected enum variant name, got " + tok_kind_name(par_kind_get()))
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue
        parser_expect(6)
        # Handle enum variant data: Variant(field: type, ...)
        if par_kind_get() == 140:
            parser_advance()
            for j in 0..100:
                if par_kind_get() == 141:
                    break
                if par_kind_get() == 190:
                    break
                # Skip field_name: type pairs
                if par_kind_get() == 6:
                    parser_advance()
                    if par_kind_get() == 161:
                        parser_advance()
                        parser_parse_type()
                        # Handle optional ? after type
                        if par_kind_get() == 130:
                            parser_advance()
                elif par_kind_get() == 144:
                    parser_parse_type()
                else:
                    parser_advance()
                if par_kind_get() == 160:
                    parser_advance()
            parser_expect(141)
        variant_names.push(vname)
        # G41: skip trailing comma after variant (same-line or end-of-line comma separation)
        if par_kind_get() == 160:
            parser_advance()
            continue
        parser_skip_newlines_and_semicolons()

    val enum_d = decl_enum_def(enum_name, variant_names, 0)
    if parse_enum_method_ids.len() > 0:
        val enum_impl = decl_impl_block(enum_name, parse_enum_method_ids, 0)
        module_add_decl(enum_impl)
    enum_d

# ===== Top-Level Module Parsing =====

fn parse_top_level_visibility() -> text:
    if par_kind_get() == 29:
        parser_advance()
        if par_kind_get() == 140:
            parser_advance()
            var modifier_name = ""
            if par_kind_get() == 6:
                modifier_name = par_text_get()
                parser_advance()
            parser_expect(141)
            if modifier_name == "peer":
                return "peer"
            if modifier_name == "up":
                return "up"
            if modifier_name == "friend":
                return "internal"
            if modifier_name == "package":
                return "package"
            if modifier_name != "" and modifier_name != "public":
                parser_warn("unknown visibility modifier `pub(" + modifier_name + ")`; using public")
            return "public"
        return "public"
    if par_kind_get() == 6 and par_text_get() == "pri":
        parser_advance()
        return "private"
    "private"

fn finalize_decl_visibility(decl_id: i64, visibility: text) -> i64:
    decl_set_visibility_text(decl_id, visibility)
    decl_id

fn parse_module_decl_with_visibility(loop_index: i64, visibility: text) -> i64:
    if par_kind_get() == 53:
        parser_advance()
        if par_kind_get() == 20:
            return finalize_decl_visibility(parse_fn_decl(1), visibility)
        parser_error("expected 'fn' after 'async'")
        return -1
    if par_kind_get() == 20:
        return finalize_decl_visibility(parse_fn_decl(0), visibility)
    if par_kind_get() == 25:
        parser_advance()
        return finalize_decl_visibility(parse_extern_fn_decl(), visibility)
    if par_kind_get() == 23:
        return finalize_decl_visibility(parse_struct_decl(false), visibility)
    if par_kind_get() == 24:
        return finalize_decl_visibility(parse_enum_decl(), visibility)
    if par_kind_get() == 31:
        return finalize_decl_visibility(parse_struct_decl(true), visibility)
    if par_kind_get() == 33:
        return finalize_decl_visibility(parse_struct_or_trait_decl(false, true), visibility)
    if par_kind_get() == 21:
        return finalize_decl_visibility(parse_val_decl(), visibility)
    if par_kind_get() == 194:
        parser_advance()
        return finalize_decl_visibility(parse_lazy_val_decl(), visibility)
    if par_kind_get() == 22:
        return finalize_decl_visibility(parse_var_decl(), visibility)
    if par_kind_get() == 188:
        val decl_start = lex_token_start_get()
        val decl_line = par_line_get()
        val decl_col = par_col_get()
        parser_advance()
        if par_kind_get() == 20:
            val cfd = parse_fn_decl(0)
            decl_set_comptime(cfd)
            return finalize_decl_visibility(cfd, visibility)
        val const_name = par_text_get()
        parser_expect(6)
        var const_type = 0
        if par_kind_get() == 161:
            parser_advance()
            const_type = parser_parse_type_with_union()
        parser_expect(100)
        val const_init = parse_expr()
        val decl_span = flat_span_new(decl_start, lex_token_start_get(), decl_line, decl_col)
        return finalize_decl_visibility(decl_val_binding(const_name, const_type, const_init, decl_span), visibility)
    if par_kind_get() == 27:
        # `pub use path.{names}` — re-export, identical to `export use` (delegates to use-decl parser)
        return parse_use_decl()
    if par_kind_get() == 26:
        # `pub export ...` — delegate to export-decl parser
        return parse_export_decl()
    parser_error("expected declaration after visibility modifier")
    -1

fn parser_decorator_arg_text(raw: text) -> text:
    if raw.len() >= 2:
        val first = raw.substring(0, 1)
        val last = raw.substring(raw.len() - 1, raw.len())
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return raw.substring(1, raw.len() - 1)
    raw

# Pending @hardware/@clocked annotations: they stack ahead of the fn decl
# (each decorator is consumed by its own module-body loop iteration), so the
# flags must survive until the fn itself is parsed.
var PENDING_HARDWARE: i64 = 0
var PENDING_CLOCKED_ARGS: [text] = []

fn parse_module_body():
    for i in 0..100000:
        parser_skip_newlines_and_semicolons()
        if par_kind_get() == 190:
            break
        if parser_module_trace_enabled():
            eprint("[parser-module] decl:start i={i} kind={par_kind_get()} text={par_text_get()} line={par_line_get()} col={par_col_get()}")
        val parsed_visibility = parse_top_level_visibility()
        if parsed_visibility != "private":
            parser_skip_newlines_and_semicolons()
            val visible_decl = parse_module_decl_with_visibility(i, parsed_visibility)
            if visible_decl >= 0:
                module_add_decl(visible_decl)
            continue
        if par_kind_get() == 182:
            # Stray dedent at module level -- skip it
            parser_advance()
        elif par_kind_get() == 53:
            # Async function: async fn name()
            parser_advance()
            if par_kind_get() == 20:
                val d = parse_fn_decl(1)  # 1 = is_async
                module_add_decl(d)
            else:
                parser_error("expected 'fn' after 'async'")
        elif par_kind_get() == 20:
            val d = parse_fn_decl(0)  # 0 = not async
            if PENDING_HARDWARE == 1:
                decl_set_hardware(d, 1)
                decl_set_clocked_args(d, PENDING_CLOCKED_ARGS)
                PENDING_HARDWARE = 0
                PENDING_CLOCKED_ARGS = []
            module_add_decl(d)
        elif par_kind_get() == 34:
            # Module-level `me name(self: T, ...)` — parsed as a plain fn with
            # an explicit self param (parity with the Rust parser, which routes
            # top-level Me to parse_function).
            val me_d = parse_fn_decl(0)
            module_add_decl(me_d)
        elif par_kind_get() == 25:
            parser_advance()
            val d = parse_extern_fn_decl()
            module_add_decl(d)
        elif par_kind_get() == 23:
            val d = parse_struct_decl(false)
            module_add_decl(d)
        elif par_kind_get() == 24:
            val d = parse_enum_decl()
            module_add_decl(d)
        elif par_kind_get() == 31:
            # class is treated like struct (fields + methods) but keeps
            # reference semantics — see decl_set_is_value_type in parse_struct_decl.
            val d = parse_struct_decl(true)
            module_add_decl(d)
        elif par_kind_get() == 32:
            val d = parse_impl_decl()
            module_add_decl(d)
        elif par_kind_get() == 27:
            val d = parse_use_decl()
            module_add_decl(d)
        elif par_kind_get() == 26:
            val d = parse_export_decl()
            module_add_decl(d)
        elif par_kind_get() == 21:
            val d = parse_val_decl()
            module_add_decl(d)
        elif par_kind_get() == 194:
            parser_advance()
            val d = parse_lazy_val_decl()
            module_add_decl(d)
        elif par_kind_get() == 22:
            val d = parse_var_decl()
            module_add_decl(d)
        elif par_kind_get() == 188:
            # const fn name(): or const binding: same as val/fn at module level
            val decl_start = lex_token_start_get()
            val decl_line = par_line_get()
            val decl_col = par_col_get()
            parser_advance()
            if par_kind_get() == 20:
                # const fn -- parse as normal function with comptime flag
                val cfd = parse_fn_decl(0)
                decl_set_comptime(cfd)
                module_add_decl(cfd)
            else:
                val const_name = par_text_get()
                parser_expect(6)
                var const_type = 0
                if par_kind_get() == 161:
                    parser_advance()
                    const_type = parser_parse_type_with_union()
                parser_expect(100)
                val const_init = parse_expr()
                val decl_span = flat_span_new(decl_start, lex_token_start_get(), decl_line, decl_col)
                val cd = decl_val_binding(const_name, const_type, const_init, decl_span)
                module_add_decl(cd)
        elif par_kind_get() == 40:
            val if_expr = parse_if_expr()
            val d = decl_val_binding("_if_" + int_to_str(i), -1, if_expr, -1)
            module_add_decl(d)
        elif par_kind_get() == 45:
            val for_expr = parse_for_expr()
            val d = decl_val_binding("_for_" + int_to_str(i), -1, for_expr, -1)
            module_add_decl(d)
        elif par_kind_get() == 46:
            val while_expr = parse_while_expr()
            val d = decl_val_binding("_while_" + int_to_str(i), -1, while_expr, -1)
            module_add_decl(d)
        elif par_kind_get() == 28:
            # import X.{Y, Z} -- treat like use
            val d = parse_use_decl()
            module_add_decl(d)
        elif par_kind_get() == 6 and par_text_get() == "mod":
            # `mod pkg.member` package-member declaration (260+ uses across
            # src/lib, e.g. std.common.json's `mod json.types`). Not a lexer
            # keyword here, so it used to fall through to the expression-
            # statement path and die as "unresolved name: mod". Lower it as a
            # SIBLING import (`.member`) — the path after `mod` is rooted at
            # the declaring file's own package, so the last segment names the
            # sibling file; the relative-import machinery resolves the rest.
            parser_advance()
            var mod_last_seg = ""
            if par_kind_get() == 6:
                mod_last_seg = par_text_get()
                parser_advance()
                while par_kind_get() == 164:
                    parser_advance()
                    if par_kind_get() == 6:
                        mod_last_seg = par_text_get()
                        parser_advance()
                    else:
                        break
            if mod_last_seg != "":
                val mod_d = decl_use_import("." + mod_last_seg, [], 0)
                module_add_decl(mod_d)
        elif par_kind_get() == 6 and is_domain_block_kind(par_text_get()) and current_ident_followed_by_lbrace():
            val block_kind = par_text_get()
            val d = parse_module_domain_block_decl(i, block_kind)
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 33:
            # trait is parsed like struct (skip body), but must NOT
            # synthesize a phantom impl block for its own methods (see
            # parse_struct_or_trait_decl's is_trait doc comment) -- doing
            # so collides with real `impl Trait for Struct` dispatch.
            val d = parse_struct_or_trait_decl(false, true)
            module_add_decl(d)
        elif par_kind_get() == 196:
            # extend TypeName: adds methods to an existing type
            val d = parse_impl_decl()
            module_add_decl(d)
        elif par_kind_get() == 209:
            val d = parse_bitfield_decl()
            module_add_decl(d)
        elif par_kind_get() == 212:
            # cli Name: declarative arg parsing block
            val cli_d = parse_cli_decl()
            module_add_decl(cli_d)
        elif par_kind_get() == 205:
            # ce NAME: computation expression block at module level
            parser_advance()
            val ce_d = parse_ce_decl()
            module_add_decl(ce_d)
        elif par_kind_get() == 171:
            # Decorator: @gpu, @gpu_kernel, @simd, @bounds(...), @derive(Eq, Hash, Debug), etc.
            # Also: @allow(...), @inline, @no_gc, @tag:... and other file-level annotations
            parser_advance()
            var decorator_name = ""
            if par_kind_get() == 6:
                decorator_name = par_text_get()
                parser_advance()
            elif par_kind_get() != 190:
                # Keyword token used as annotation name (e.g. `allow` kind 218, `forbid` kind 217)
                # Capture its text and consume it so we don't mis-dispatch to AOP parser
                decorator_name = par_text_get()
                parser_advance()
            # SPipe helper labels use the compact `@step "label"` spelling.
            # The label is source metadata; consume it here so the following
            # declaration remains the next module item.
            if decorator_name == "step" and par_kind_get() == 3:
                parser_advance()
            # Parse parenthesized arguments, collecting ident names for @derive
            var derive_traits: [text] = []
            var gpu_target_arg = ""
            var gpu_target_arg_name = ""
            var gpu_backends_arg = ""
            if par_kind_get() == 140:
                parser_advance()
                for dec_j in 0..100:
                    val dec_end1: bool = par_kind_get() == 141
                    val dec_end2: bool = par_kind_get() == 190
                    if dec_end1 or dec_end2:
                        break
                    if decorator_name == "derive":
                        if par_kind_get() == 6:
                            derive_traits.push(par_text_get())
                            parser_advance()
                            if par_kind_get() == 160:
                                parser_advance()
                        else:
                            parser_advance()
                    elif decorator_name == "gpu" or decorator_name == "gpu_kernel":
                        if par_kind_get() == 6:
                            val arg_name = par_text_get()
                            parser_advance()
                            if par_kind_get() == 100:
                                parser_advance()
                                val arg_value = parser_decorator_arg_text(par_text_get())
                                if par_kind_get() == 3 or par_kind_get() == 6:
                                    if arg_name == "target" or arg_name == "backend":
                                        gpu_target_arg = arg_value
                                        gpu_target_arg_name = arg_name
                                    elif arg_name == "backends":
                                        gpu_backends_arg = arg_value
                                    parser_advance()
                            elif gpu_target_arg == "":
                                gpu_target_arg = parser_decorator_arg_text(arg_name)
                        elif par_kind_get() == 3:
                            if gpu_target_arg == "":
                                gpu_target_arg = parser_decorator_arg_text(par_text_get())
                            parser_advance()
                        else:
                            parser_advance()
                        if par_kind_get() == 160:
                            parser_advance()
                    elif decorator_name == "clocked":
                        if par_kind_get() == 6:
                            PENDING_CLOCKED_ARGS.push(par_text_get())
                        parser_advance()
                    else:
                        parser_advance()
                parser_expect(141)
            parser_skip_newlines_and_semicolons()
            if decorator_name == "hardware":
                PENDING_HARDWARE = 1
            elif decorator_name == "clocked":
                # Args already collected into PENDING_CLOCKED_ARGS above.
                pass_dn
            elif decorator_name == "gpu_kernel" or decorator_name == "gpu":
                if par_kind_get() == 20 or par_kind_get() == 34:
                    val d = parse_fn_decl(0)
                    decl_is_gpu_kernel[d] = 1
                    if gpu_target_arg.len() > 0:
                        decl_set_gpu_target_text(d, gpu_target_arg)
                        if gpu_target_arg_name.len() > 0:
                            decl_set_gpu_target_arg_name_text(d, gpu_target_arg_name)
                    if gpu_backends_arg.len() > 0:
                        decl_set_gpu_backends_text(d, gpu_backends_arg)
                    module_add_decl(d)
            elif decorator_name == "simd":
                if par_kind_get() == 20 or par_kind_get() == 34:
                    val d = parse_fn_decl(0)
                    decl_is_simd[d] = 1
                    module_add_decl(d)
            elif decorator_name == "packed":
                if par_kind_get() == 23:
                    val d = parse_struct_decl(false)
                    val packed_field_bits = decl_get_field_bits(d)
                    var pfi = 0
                    while pfi < packed_field_bits.len():
                        if packed_field_bits[pfi] <= 0:
                            parser_error("@packed struct fields must use explicit bit widths; use an explicit nested struct instead")
                        pfi = pfi + 1
                    decl_is_packed[d] = 1
                    module_add_decl(d)
            elif decorator_name == "derive":
                val is_class: bool = par_kind_get() == 31
                val is_struct: bool = par_kind_get() == 23
                if is_class or is_struct:
                    val d = parse_struct_decl(is_class)
                    decl_derives[d] = derive_traits
                    module_add_decl(d)
                    # Generate derived trait method implementations
                    generate_derive_impls(d, derive_traits)
            else:
                # Unknown annotation (e.g. @allow(...), @inline, @no_gc, @bounds(...), etc.)
                # The annotation tokens have already been consumed above (@ + name + args).
                # The following declaration is handled by the next outer loop iteration,
                # which dispatches via the full elif chain (fn, use, struct, val, etc.).
                # Multiple stacked annotations also work: each loop iteration consumes one @.
                pass_dn
        elif par_kind_get() == 219:
            # newunit UserId: i64 as uid -- nominal ABI-transparent wrapper.
            # The suffix is accepted by this frontend for syntax parity; runtime
            # suffix literal registration is handled by the Rust unit parser path.
            parser_advance()
            val nt_name = par_text_get()
            parser_expect(6)
            parser_expect(161)
            val inner_type = parser_parse_type()
            if par_kind_get() == TOK_KW_AS:
                parser_advance()
            else:
                parser_error("expected 'as' in newunit declaration")
            val suffix_name = par_text_get()
            parser_expect(6)
            pass_dn
            named_type_register(nt_name, ["value"], [inner_type])
            custom_primitive_register(nt_name, inner_type)
            val nt_field_names: [text] = ["value"]
            val nt_field_types: [i64] = [inner_type]
            val nt_field_defaults: [i64] = [-1]
            val nt_field_bits: [i64] = [-1]
            val nt_d = decl_struct_def(nt_name, nt_field_names, nt_field_types, nt_field_defaults, nt_field_bits, 0)
            module_add_decl(nt_d)
        elif par_kind_get() == 198:
            # newtype Meters = i64 -- wrapper struct with single 'value' field
            # For numeric inner types, auto-derives __add__, __sub__, __mul__, __div__, __eq__, __lt__, __gt__
            parser_advance()
            val nt_name = par_text_get()
            parser_expect(6)
            parser_expect(100)
            val inner_type = parser_parse_type()
            # Pre-register newtype so type references resolve (same as parse_struct_decl)
            pass_dn
            named_type_register(nt_name, ["value"], [inner_type])
            custom_primitive_register(nt_name, inner_type)
            val nt_field_names: [text] = ["value"]
            val nt_field_types: [i64] = [inner_type]
            val nt_field_defaults: [i64] = [-1]
            val nt_field_bits: [i64] = [-1]
            val nt_d = decl_struct_def(nt_name, nt_field_names, nt_field_types, nt_field_defaults, nt_field_bits, 0)
            module_add_decl(nt_d)

            # Check if inner type is numeric — auto-derive operator methods
            val inner_name = type_tag_name(inner_type)
            val is_i64: bool = inner_name == "i64"
            val is_i32: bool = inner_name == "i32"
            val is_i16: bool = inner_name == "i16"
            val is_i8: bool = inner_name == "i8"
            val is_u64: bool = inner_name == "u64"
            val is_u32: bool = inner_name == "u32"
            val is_u16: bool = inner_name == "u16"
            val is_u8: bool = inner_name == "u8"
            val is_f64: bool = inner_name == "f64"
            val is_f32: bool = inner_name == "f32"
            val is_int: bool = inner_name == "Int"
            val is_float: bool = inner_name == "Float"
            val is_numeric_a: bool = is_i64 or is_i32
            val is_numeric_b: bool = is_i16 or is_i8
            val is_numeric_c: bool = is_u64 or is_u32
            val is_numeric_d: bool = is_u16 or is_u8
            val is_numeric_e: bool = is_f64 or is_f32
            val is_numeric_f: bool = is_int or is_float
            val is_numeric_ab: bool = is_numeric_a or is_numeric_b
            val is_numeric_cd: bool = is_numeric_c or is_numeric_d
            val is_numeric_ef: bool = is_numeric_e or is_numeric_f
            val is_numeric_abcd: bool = is_numeric_ab or is_numeric_cd
            val is_numeric: bool = is_numeric_abcd or is_numeric_ef

            if is_numeric:
                # Resolve the newtype's type tag for return types
                val nt_type_id = named_type_find(nt_name)
                var nt_type_tag: i64 = 0
                if nt_type_id >= 0:
                    nt_type_tag = TYPE_NAMED_BASE + nt_type_id
                else:
                    nt_type_tag = inner_type

                var nt_method_ids: [i64] = []

                # Generate arithmetic dunder methods: __add__, __sub__, __mul__, __div__
                # Each: fn __op__(self, other: T) -> T: T(value: self.value OP other.value)
                var arith_ops: [text] = ["__add__", "__sub__", "__mul__", "__div__"]
                var arith_toks: [i64] = [60, 61, 62, 63]
                for ai in 0..4:
                    val op_name = arith_ops[ai]
                    val op_tok = arith_toks[ai]
                    # Build body: self.value OP other.value -> wrap in constructor
                    val self_e = expr_ident("self", 0)
                    val self_val = expr_field_access(self_e, "value", 0)
                    val other_e = expr_ident("other", 0)
                    val other_val = expr_field_access(other_e, "value", 0)
                    val bin_expr = expr_binary(op_tok, self_val, other_val, 0)
                    # Constructor call: TypeName(result) — single positional arg for single-field struct
                    val ctor = expr_ident(nt_name, 0)
                    var ctor_args: [i64] = []
                    ctor_args.push(bin_expr)
                    val ctor_call = expr_call(ctor, ctor_args, 0)
                    val body_stmt = stmt_expr_stmt(ctor_call, 0)
                    var body: [i64] = []
                    body.push(body_stmt)
                    var pnames: [text] = ["self", "other"]
                    var ptypes: [i64] = [nt_type_tag, nt_type_tag]
                    var tparams: [text] = []
                    val m = decl_fn(op_name, pnames, ptypes, nt_type_tag, body, 0, tparams, 0)
                    nt_method_ids.push(m)

                # Generate comparison dunder methods: __eq__, __lt__, __gt__
                # Each: fn __op__(self, other: T) -> bool: self.value OP other.value
                var cmp_ops: [text] = ["__eq__", "__lt__", "__gt__"]
                var cmp_toks: [i64] = [80, 82, 83]
                for ci in 0..3:
                    val cmp_name = cmp_ops[ci]
                    val cmp_tok = cmp_toks[ci]
                    val self_c = expr_ident("self", 0)
                    val self_cv = expr_field_access(self_c, "value", 0)
                    val other_c = expr_ident("other", 0)
                    val other_cv = expr_field_access(other_c, "value", 0)
                    val cmp_expr = expr_binary(cmp_tok, self_cv, other_cv, 0)
                    val cmp_body_stmt = stmt_expr_stmt(cmp_expr, 0)
                    var cmp_body: [i64] = []
                    cmp_body.push(cmp_body_stmt)
                    var cpnames: [text] = ["self", "other"]
                    var cptypes: [i64] = [nt_type_tag, nt_type_tag]
                    var ctparams: [text] = []
                    val cm = decl_fn(cmp_name, cpnames, cptypes, TYPE_BOOL, cmp_body, 0, ctparams, 0)
                    nt_method_ids.push(cm)

                # Create impl block for the auto-derived methods
                val nt_impl = decl_impl_block(nt_name, nt_method_ids, 0)
                module_add_decl(nt_impl)

            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 3:
            # Skip module-level docstrings
            parser_advance()
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 35:
            # Type alias: type X = Y -- skip it
            parser_advance()
            # Skip until newline
            for j in 0..1000:
                val type_is_nl: bool = par_kind_get() == 180
                val type_is_ded: bool = par_kind_get() == 182
                val type_is_eof: bool = par_kind_get() == 190
                val type_done: bool = type_is_nl or type_is_ded
                val type_done2: bool = type_done or type_is_eof
                if type_done2:
                    break
                parser_advance()
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 36:
            val asm_expr = parse_expr()
            val d = decl_val_binding("_asm_" + int_to_str(i), -1, asm_expr, -1)
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 181:
            # Stray indent at module level -- skip it
            parser_advance()
        elif par_kind_get() == 216:
            # on pc{...} use handler form [priority N]
            val d = parse_aop_advice_decl()
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 217:
            # forbid pc{...} "message"
            val d = parse_arch_rule_decl("forbid")
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        elif par_kind_get() == 218:
            # allow pc{...} "message"
            val d = parse_arch_rule_decl("allow")
            module_add_decl(d)
            parser_skip_newlines_and_semicolons()
        else:
            # Handle bare 'print' and 'from' at module level
            if par_kind_get() == 6:
                if par_text_get() == "from":
                    # from X import {Y, Z}
                    parser_advance()
                    var from_path: text = ""
                    if par_kind_get() == 6:
                        from_path = par_text_get()
                        parser_advance()
                    for j in 0..100:
                        if par_kind_get() != 164:
                            break
                        parser_advance()
                        if par_kind_get() == 6:
                            from_path = from_path + "." + par_text_get()
                            parser_advance()
                        else:
                            break
                    # Expect 'import' keyword
                    if par_kind_get() == 28:
                        parser_advance()
                    # Parse import list {name1, name2}
                    var from_names: [text] = []
                    val from_has_brace: bool = par_kind_get() == 142
                    val from_has_paren: bool = par_kind_get() == 140
                    val from_has_list: bool = from_has_brace or from_has_paren
                    if from_has_list:
                        parser_advance()
                        for j in 0..100:
                            val from_at_end1: bool = par_kind_get() == 143
                            val from_at_end2: bool = par_kind_get() == 141
                            val from_at_end: bool = from_at_end1 or from_at_end2
                            if from_at_end:
                                break
                            if par_kind_get() == 190:
                                break
                            if par_kind_get() == 6:
                                from_names.push(par_text_get())
                                parser_advance()
                            if par_kind_get() == 160:
                                parser_advance()
                        parser_advance()
                    val fd = decl_use_import(from_path, from_names, 0)
                    module_add_decl(fd)
                    parser_skip_newlines_and_semicolons()
                elif par_text_get() == "comptime":
                    # comptime val name = expr -- evaluated eagerly (treat like val)
                    parser_advance()
                    if par_kind_get() == 21 or par_kind_get() == 22:
                        val d = parse_val_decl()
                        module_add_decl(d)
                    elif par_kind_get() == 20:
                        val ctfd = parse_fn_decl(0)
                        decl_set_comptime(ctfd)
                        module_add_decl(ctfd)
                    elif par_kind_get() == 161:
                        # comptime: block at module level -- wrap body stmts in an expr_block
                        parser_advance()
                        val ct_blk_body = parse_block()
                        val ct_blk_unit = expr_unit(0)
                        val ct_blk_expr = expr_block(ct_blk_body, ct_blk_unit, 0)
                        val ctbd = decl_val_binding("_ct_blk_" + int_to_str(i), -1, ct_blk_expr, -1)
                        module_add_decl(ctbd)
                    else:
                        val ct_expr = parse_expr()
                        val ctd = decl_val_binding("_ct_" + int_to_str(i), -1, ct_expr, -1)
                        module_add_decl(ctd)
                    parser_skip_newlines_and_semicolons()
                elif par_text_get() == "print":
                    parser_warn_print_if_needed()
                    parser_advance()
                    val is_nl = par_kind_get() == 180
                    val is_ded = par_kind_get() == 182
                    val is_eof = par_kind_get() == 190
                    val no_arg = is_nl or is_ded
                    val no_arg2 = no_arg or is_eof
                    var print_call: i64 = 0
                    if no_arg2:
                        val callee0 = expr_ident("print", 0)
                        var args0: [i64] = []
                        print_call = expr_call(callee0, args0, 0)
                    else:
                        val print_arg = parse_expr()
                        val callee1 = expr_ident("print", 0)
                        var args1: [i64] = []
                        args1.push(print_arg)
                        print_call = expr_call(callee1, args1, 0)
                    val d = decl_val_binding("_expr_" + int_to_str(i), -1, print_call, -1)
                    module_add_decl(d)
                    parser_skip_newlines_and_semicolons()
                else:
                    val expression = parse_expr()
                    val d = decl_val_binding("_expr_" + int_to_str(i), -1, expression, -1)
                    module_add_decl(d)
                    parser_skip_newlines_and_semicolons()
            else:
                # Module-level expression/statement
                val expression = parse_expr()
                val d = decl_val_binding("_expr_" + int_to_str(i), -1, expression, -1)
                module_add_decl(d)
                parser_skip_newlines_and_semicolons()

# ===== Exports =====

export parse_enum_decl, parse_module_body

# ===== Bitfield Declaration =====
