# ===== Helper Functions =====

fn parser_skip_tilde_if_present():
    # Skip ~ prefix for keyword-only parameter marker
    if par_kind_get() == 123:
        parser_advance()

fn parser_skip_mut_if_present() -> bool:
    # Skip a leading `mut` modifier in a parameter declaration (`mut buf: [u8]`).
    # `mut` lexes as a plain identifier (kind 6) — it is NOT reserved, so it CAN
    # be used as a parameter name (`fn f(mut: i32)`). Consuming it on a bare
    # text match would wrongly eat that parameter's name. Peek one token ahead
    # (save/advance/check/restore, the idiom used by parser_stmts.spl's `me`
    # disambiguation and parser_expr.spl's try_skip_ident_generic_args) and only
    # treat `mut` as the modifier when the following token is itself a valid
    # parameter-name token (identifier or `self`) — i.e. `mut buf`/`mut self`,
    # not `mut:` or `mut)` where `mut` is the parameter name.
    # Returns true when a `mut` modifier was actually consumed, so callers can
    # thread the marker into PARAM_MUTS (native_freefn_mut_param_no_mutate):
    # a free-function `mut` param must reach MIR lowering to bind by-reference
    # instead of taking the Bug #167 defensive struct-value-copy.
    if par_kind_get() == 6 and par_text_get() == "mut":
        val (mut_snap_nums, mut_snap_txts) = lex_snapshot_save()
        val (mut_tok_nums, mut_tok_text) = parser_tok_save()
        parser_advance()
        val next_is_param_name = par_kind_get() == 6 or par_kind_get() == 38
        lex_snapshot_restore(mut_snap_nums, mut_snap_txts)
        parser_tok_restore(mut_tok_nums, mut_tok_text)
        if next_is_param_name:
            parser_advance()
            return true
    false

fn parser_expect_param_name():
    # Accept IDENT, SELF, UNDERSCORE, or any keyword as parameter name (e.g. cli, mcp, type)
    val is_ident: bool = par_kind_get() == 6
    val is_self: bool = par_kind_get() == 38
    val is_under: bool = par_kind_get() == 169
    val epn_kw_name: text = tok_kind_name(par_kind_get())
    val is_kw: bool = keyword_lookup(epn_kw_name) == par_kind_get()
    val is_valid: bool = is_ident or is_self or is_under or is_kw
    if is_valid:
        parser_advance()
    else:
        parser_error("expected parameter name")
        parser_advance()

fn is_domain_block_kind(name: text) -> bool:
    name == "schema" or
        name == "style" or
        name == "ui" or
        name == "music" or
        name == "bim" or
        name == "cad" or
        name == "city" or
        name == "rtl"

fn current_ident_followed_by_lbrace() -> bool:
    var pos = lex_pos_get()
    val source_len = lex_source_len()
    while pos < source_len:
        val ch = lex_source_char_at(pos)
        if ch == " " or ch == "\t" or ch == "\r":
            pos = pos + 1
            continue
        return ch == "{"
    false

fn parse_raw_domain_block_advance_lexer(start_pos: i64, end_pos: i64):
    var line = lex_line_get()
    var col = lex_col_get()
    var pos = start_pos
    while pos < end_pos:
        val ch = lex_source_char_at(pos)
        if ch == "\n":
            line = line + 1
            col = 1
        else:
            col = col + 1
        pos = pos + 1
    lex_pos_set(end_pos)
    lex_line_set(line)
    lex_col_set(col)

fn parse_raw_domain_block_payload(kind: text) -> text:
    val content_start = lex_pos_get()
    val source_len = lex_source_len()
    var pos = content_start
    var depth = 1
    var in_string = false
    var string_quote = ""
    var escaped = false
    while pos < source_len:
        val ch = lex_source_char_at(pos)
        if in_string:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == string_quote:
                in_string = false
        else:
            if ch == "\"" or ch == "'":
                in_string = true
                string_quote = ch
            elif ch == "{":
                depth = depth + 1
            elif ch == "}":
                depth = depth - 1
                if depth == 0:
                    val payload = lex_source_slice(content_start, pos).trim()
                    parse_raw_domain_block_advance_lexer(content_start, pos + 1)
                    parser_advance()
                    return payload
        pos = pos + 1
    parser_error("unterminated {kind}{...} block")
    val payload = lex_source_slice(content_start, source_len).trim()
    parse_raw_domain_block_advance_lexer(content_start, source_len)
    parser_advance()
    payload

fn parse_module_domain_block_decl(loop_index: i64, kind: text) -> i64:
    parser_advance()
    val payload = parse_raw_domain_block_payload(kind)
    val helper = expr_ident("__domain_block", 0)
    var args: [i64] = []
    args.push(expr_string_lit(kind, 0))
    args.push(expr_string_lit(payload, 0))
    val marker = expr_call(helper, args, 0)
    decl_val_binding("_expr_" + int_to_str(loop_index), -1, marker, -1)

# ===== Generic Type Parameter Parsing =====

# Module-level generic constraint declarations (populated by `val generic T limits [...]`)
var file_generic_constraints: {text: [text]} = {}
var file_generic_constraint_modes: {text: text} = {}

fn parse_type_param_constraint_list() -> [text]:
    # Parses [f32, i32, f64, i64] or [f32, i32, *] constraint list (the
    # hardware/primitive-set candidate form), OR a bare trait-bound name
    # (or `+`-joined names) as in `fn f<T: Speaker>` / `fn f<T: A + B>` --
    # the standard trait-bound syntax used throughout the language
    # (test/03_system/feature/language/traits_spec.spl,
    # static_polymorphism_spec.spl). Without this branch, `T: Speaker`
    # (no brackets) hit the `!= 144` guard below, returned an EMPTY list
    # having consumed nothing, and left the unconsumed "Speaker>" tokens
    # to desync the rest of parse_type_params' loop -- confirmed
    # empirically: `fn announce<T: Speaker>(s: T) -> i64:` derailed into a
    # cascade of "unexpected token in expression" parser errors starting
    # at the arg list's closing `)`.
    var types: [text] = []
    if par_kind_get() != 144:
        if par_kind_get() == 6:
            types.push(par_text_get())
            parser_advance()
            for pi2 in 0..100:
                if par_kind_get() != 60:
                    break
                parser_advance()
                if par_kind_get() != 6:
                    break
                types.push(par_text_get())
                parser_advance()
        return types
    parser_advance()
    for ci in 0..100:
        if par_kind_get() == 145:
            break
        if ci > 0:
            if par_kind_get() != 160:
                break
            parser_advance()
        if par_kind_get() == 6:
            types.push(par_text_get())
            parser_advance()
        elif par_kind_get() == 62:
            types.push("*")
            parser_advance()
        else:
            break
    parser_expect(145)
    types

fn parse_type_params() -> [text]:
    # Parses <T>, <T, U>, <T limits [f32, i32]>, <T: [f32, i32]>, etc.
    # Returns list of type parameter names (e.g., ["T", "U"])
    # Side effect: populates last_type_param_constraints and last_type_param_modes
    var type_params: [text] = []

    # Check for < token (either TOK_LT or TOK_LT_GENERIC)
    val has_lt: bool = par_kind_get() == 82
    val has_lt_gen: bool = par_kind_get() == 86
    val has_generic: bool = has_lt or has_lt_gen
    if not has_generic:
        return type_params

    parser_advance()

    # Parse type parameters with optional inline constraints
    for pi in 0..100:
        if pi > 0:
            if par_kind_get() != 160:
                break
            parser_advance()

        if par_kind_get() != 6:
            if pi == 0:
                parser_error("expected type parameter name")
            break

        val param_name = par_text_get()
        type_params.push(param_name)
        parser_advance()

        # Check for inline constraint: `T limits [...]` or `T: [...]`
        val is_limits: bool = par_kind_get() == 214
        val is_candidates: bool = par_kind_get() == 215
        val is_colon_constraint: bool = par_kind_get() == 161
        if is_limits or is_candidates or is_colon_constraint:
            parser_advance()
            val constraint_types = parse_type_param_constraint_list()
            if constraint_types.len() > 0:
                # Check for * (candidate mode marker)
                var has_star = false
                var filtered: [text] = []
                for ct in constraint_types:
                    if ct == "*":
                        has_star = true
                    else:
                        filtered.push(ct)
                val mode_str = if is_candidates or has_star: "candidate" else: "limit"
                file_generic_constraints[param_name] = filtered
                file_generic_constraint_modes[param_name] = mode_str

    # Expect closing >
    parser_expect(83)

    type_params

fn bitfield_backing_bits_from_name(type_name: text) -> i64:
    val primitive_bits = primitive_backing_bits_from_name(type_name)
    if primitive_bits > 0:
        return primitive_bits
    custom_primitive_backing_bits_by_name(type_name)

fn bitfield_field_bits_from_name(type_name: text) -> i64:
    if type_name == "bool":
        return 1
    val primitive_bits = primitive_integer_bit_width_from_name(type_name)
    if primitive_bits > 0:
        return primitive_bits
    custom_primitive_integer_bit_width_by_name(type_name)

fn has_seen_name(names: [text], target: text) -> bool:
    for nm in names:
        if nm == target:
            return true
    false

# ===== Function Declarations =====

fn parse_fn_decl(is_async: i64) -> i64:
    parser_advance()
    val fn_name = par_text_get()
    parser_expect(6)

    # Parse optional type parameters: fn name<T, U>(...)
    val type_params = parse_type_params()

    var param_names: [text] = []
    var param_types: [i64] = []
    var param_defaults: [i64] = []
    var param_muts: [i64] = []

    # Canonical zero-argument Simple syntax permits `fn main:` without `()`.
    if par_kind_get() == 140:
        parser_advance()
        if par_kind_get() != 141:
            # First parameter (skip ~ keyword-only marker + optional `mut` modifier)
            parser_skip_tilde_if_present()
            val p0_is_mut = parser_skip_mut_if_present()
            val pname = par_text_get()
            parser_expect_param_name()
            param_names.push(pname)
            param_muts.push(if p0_is_mut: 1 else: 0)
            var ptype = 0
            if par_kind_get() == 161:
                parser_advance()
                ptype = parser_parse_type_with_union()
            param_types.push(ptype)
            # Optional default value: `= expr`
            if par_kind_get() == 100:
                parser_advance()
                param_defaults.push(parse_expr())
            else:
                param_defaults.push(-1)

            for i in 0..100:
                if par_kind_get() != 160:
                    break
                parser_advance()
                if par_kind_get() == 141:
                    break
                parser_skip_tilde_if_present()
                val pn_is_mut = parser_skip_mut_if_present()
                val pn = par_text_get()
                parser_expect_param_name()
                param_names.push(pn)
                param_muts.push(if pn_is_mut: 1 else: 0)
                var pt = 0
                if par_kind_get() == 161:
                    parser_advance()
                    pt = parser_parse_type_with_union()
                param_types.push(pt)
                # Optional default value: `= expr`
                if par_kind_get() == 100:
                    parser_advance()
                    param_defaults.push(parse_expr())
                else:
                    param_defaults.push(-1)

        parser_expect(141)

    # Return type
    var ret_type = TYPE_VOID
    if par_kind_get() == 167:
        parser_advance()
        ret_type = parser_parse_type_with_union()
        # G11: allow Newline+Indent between `-> Type` and `:` body (multiline fn sig)
        if par_kind_get() == 180:
            parser_advance()
            if par_kind_get() == 181:
                parser_advance()

    # Skip optional where clause: where T: Bound
    if par_kind_get() == 189:
        parser_advance()
        # Skip until the body colon
        for where_i in 0..200:
            val at_colon: bool = par_kind_get() == 161
            val at_eof: bool = par_kind_get() == 190
            if at_colon or at_eof:
                break
            parser_advance()

    # Function body
    parser_expect(161)
    val body = parse_block()

    val fn_decl_idx = decl_fn(fn_name, param_names, param_types, ret_type, body, is_async, type_params, 0)
    decl_set_param_defaults(fn_decl_idx, param_defaults)
    decl_set_param_muts(fn_decl_idx, param_muts)
    fn_decl_idx

fn parse_extern_fn_decl() -> i64:
    # Already consumed 'extern'
    parser_expect(20)
    val fn_name = par_text_get()
    parser_expect(6)

    # Parse optional type parameters: extern fn name<T>(...)
    val type_params = parse_type_params()

    parser_expect(140)

    var param_names: [text] = []
    var param_types: [i64] = []

    if par_kind_get() != 141:
        val pname = par_text_get()
        parser_expect_param_name()
        param_names.push(pname)
        var ptype = 0
        if par_kind_get() == 161:
            parser_advance()
            ptype = parser_parse_type()
        param_types.push(ptype)

        for i in 0..100:
            if par_kind_get() != 160:
                break
            parser_advance()
            if par_kind_get() == 141:
                break
            val pn = par_text_get()
            parser_expect_param_name()
            param_names.push(pn)
            var pt = 0
            if par_kind_get() == 161:
                parser_advance()
                pt = parser_parse_type()
            param_types.push(pt)

    parser_expect(141)

    var ret_type = TYPE_VOID
    if par_kind_get() == 167:
        parser_advance()
        ret_type = parser_parse_type()

    decl_extern_fn(fn_name, param_names, param_types, ret_type, type_params, 0)

# ===== @derive Implementation Generator =====

fn generate_derive_impls(struct_idx: i64, traits: [text]):
    """Generate impl blocks for @derive(Trait1, Trait2, ...) on a struct/class."""
    val sname = decl_get_name(struct_idx)
    val fnames = decl_get_fields(struct_idx)
    val nfields = fnames.len()

    # Resolve struct type tag for method signatures
    val type_id = named_type_find(sname)
    var stype_tag: i64 = 0
    if type_id >= 0:
        stype_tag = TYPE_NAMED_BASE + type_id
    else:
        stype_tag = TYPE_ANY

    var derive_method_ids: [i64] = []

    for ti in 0..traits.len():
        val trait_name = traits[ti]

        if trait_name == "Eq":
            # fn __eq__(self, other: T) -> bool:
            #     self.f0 == other.f0 and self.f1 == other.f1 and ...
            var eq_expr: i64 = -1
            for fi in 0..nfields:
                val fname = fnames[fi]
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                val other_e = expr_ident("other", 0)
                val other_f = expr_field_access(other_e, fname, 0)
                val cmp = expr_binary(80, self_f, other_f, 0)
                if eq_expr < 0:
                    eq_expr = cmp
                else:
                    eq_expr = expr_binary(55, eq_expr, cmp, 0)
            # Handle zero-field struct: always equal
            if eq_expr < 0:
                eq_expr = expr_bool_lit(1, 0)
            val eq_body_stmt = stmt_expr_stmt(eq_expr, 0)
            var eq_body: [i64] = []
            eq_body.push(eq_body_stmt)
            var eq_pnames: [text] = ["self", "other"]
            var eq_ptypes: [i64] = [stype_tag, stype_tag]
            var eq_tparams: [text] = []
            val eq_m = decl_fn("__eq__", eq_pnames, eq_ptypes, TYPE_BOOL, eq_body, 0, eq_tparams, 0)
            derive_method_ids.push(eq_m)

        elif trait_name == "Hash":
            # fn __hash__(self) -> i64:
            #     var h: i64 = 0
            #     h = h * 31 + self.f0.__hash__()  (or hash via XOR)
            # Simplified: XOR all field hashes with prime multiplier
            var hash_expr: i64 = expr_int_lit(0, 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                # self.field.__hash__() -- method call
                var hash_args: [i64] = []
                val field_hash = expr_method_call(self_f, "__hash__", hash_args, 0)
                # h * 31 + field_hash
                val mul_31 = expr_int_lit(31, 0)
                val h_mul = expr_binary(62, hash_expr, mul_31, 0)
                hash_expr = expr_binary(60, h_mul, field_hash, 0)
            val hash_body_stmt = stmt_expr_stmt(hash_expr, 0)
            var hash_body: [i64] = []
            hash_body.push(hash_body_stmt)
            var hash_pnames: [text] = ["self"]
            var hash_ptypes: [i64] = [stype_tag]
            var hash_tparams: [text] = []
            val hash_m = decl_fn("__hash__", hash_pnames, hash_ptypes, TYPE_I64, hash_body, 0, hash_tparams, 0)
            derive_method_ids.push(hash_m)

        elif trait_name == "Debug":
            # fn to_string(self) -> text:
            #     "ClassName(f0: " + self.f0.to_string() + ", f1: " + self.f1.to_string() + ")"
            var dbg_expr: i64 = expr_string_lit(sname + "(", 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                if fi > 0:
                    val comma_e = expr_string_lit(", ", 0)
                    dbg_expr = expr_binary(60, dbg_expr, comma_e, 0)
                val label_e = expr_string_lit(fname + ": ", 0)
                dbg_expr = expr_binary(60, dbg_expr, label_e, 0)
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                var ts_args: [i64] = []
                val field_str = expr_method_call(self_f, "to_string", ts_args, 0)
                dbg_expr = expr_binary(60, dbg_expr, field_str, 0)
            val close_e = expr_string_lit(")", 0)
            dbg_expr = expr_binary(60, dbg_expr, close_e, 0)
            val dbg_body_stmt = stmt_expr_stmt(dbg_expr, 0)
            var dbg_body: [i64] = []
            dbg_body.push(dbg_body_stmt)
            var dbg_pnames: [text] = ["self"]
            var dbg_ptypes: [i64] = [stype_tag]
            var dbg_tparams: [text] = []
            val dbg_m = decl_fn("to_string", dbg_pnames, dbg_ptypes, TYPE_TEXT, dbg_body, 0, dbg_tparams, 0)
            derive_method_ids.push(dbg_m)

        elif trait_name == "Display":
            # Same as Debug for Display — generates to_string
            var disp_expr: i64 = expr_string_lit(sname + "(", 0)
            for fi in 0..nfields:
                val fname = fnames[fi]
                if fi > 0:
                    val comma_e = expr_string_lit(", ", 0)
                    disp_expr = expr_binary(60, disp_expr, comma_e, 0)
                val label_e = expr_string_lit(fname + ": ", 0)
                disp_expr = expr_binary(60, disp_expr, label_e, 0)
                val self_e = expr_ident("self", 0)
                val self_f = expr_field_access(self_e, fname, 0)
                var ts_args: [i64] = []
                val field_str = expr_method_call(self_f, "to_string", ts_args, 0)
                disp_expr = expr_binary(60, disp_expr, field_str, 0)
            val close_e = expr_string_lit(")", 0)
            disp_expr = expr_binary(60, disp_expr, close_e, 0)
            val disp_body_stmt = stmt_expr_stmt(disp_expr, 0)
            var disp_body: [i64] = []
            disp_body.push(disp_body_stmt)
            var disp_pnames: [text] = ["self"]
            var disp_ptypes: [i64] = [stype_tag]
            var disp_tparams: [text] = []
            val disp_m = decl_fn("to_string", disp_pnames, disp_ptypes, TYPE_TEXT, disp_body, 0, disp_tparams, 0)
            derive_method_ids.push(disp_m)

    # Create impl block for all derived methods
    if derive_method_ids.len() > 0:
        val derive_impl = decl_impl_block(sname, derive_method_ids, 0)
        module_add_decl(derive_impl)

# ===== Struct/Class Declarations =====

fn parse_struct_decl(is_class: bool) -> i64:
    parse_struct_or_trait_decl(is_class, false)

fn parse_struct_or_trait_decl(is_class: bool, is_trait: bool) -> i64:
    parser_advance()
    val struct_name = par_text_get()
    parser_expect(6)
    # Stage1 bootstrap cannot safely mutate imported text-array parser state here.

    # Parse optional type parameters: class Box<T>:, struct Node<T>:
    val type_params = parse_type_params()

    # Pre-register struct name so type references resolve during parsing
    val struct_type_id = named_type_register(struct_name, [], [])
    # Handle struct inheritance: struct X(Parent):
    if par_kind_get() == 140:
        parser_advance()
        # Skip parent type name(s)
        for i in 0..10:
            if par_kind_get() == 141:
                break
            parser_advance()
        parser_expect(141)
    # Handle one or more mixins: class X with Read, Write, Close:
    if par_kind_get() == 6:
        if par_text_get() == "with":
            parser_advance()
            parser_expect(6)
            while par_kind_get() == 160:
                parser_advance()
                parser_expect(6)
    parser_expect(161)
    parser_skip_newlines()
    parser_expect(181)

    var field_names: [text] = []
    var field_types: [i64] = []
    var field_defaults: [i64] = []
    var field_bits: [i64] = []
    var class_method_ids: [i64] = []

    for i in 0..1000:
        parser_skip_newlines()
        if par_kind_get() == 182:
            parser_advance()
            break
        if par_kind_get() == 190:
            break

        # Skip docstrings in class/struct body
        if par_kind_get() == 3:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Associated types: type Item = T (skip for now, just parse and ignore)
        if par_kind_get() == 35:
            parser_advance()
            # Skip: 'type IDENT' or 'type IDENT = Type'
            if par_kind_get() == 6:
                parser_advance()
            if par_kind_get() == 100:
                parser_advance()
                parser_parse_type()
            parser_skip_newlines_and_semicolons()
            continue

        # G15: pass_dn / pass_todo / pass_do_nothing / pass as trait/class body placeholder
        val cb_kind = par_kind_get()
        val is_pass_dn: bool = cb_kind == 185
        val is_pass_todo: bool = cb_kind == 183
        val is_pass_dn2: bool = cb_kind == 184
        val is_pass_kw: bool = cb_kind == 174
        val is_any_pass: bool = is_pass_dn or is_pass_todo
        val is_any_pass2: bool = is_pass_dn2 or is_pass_kw
        val is_pass: bool = is_any_pass or is_any_pass2
        if is_pass:
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue

        # Handle methods in class/struct body
        if par_kind_get() == 30:
            val sm_id = parse_class_body_method(struct_name, true, false)
            if sm_id >= 0:
                class_method_ids.push(sm_id)
            continue
        if par_kind_get() == 20:
            val fm_id = parse_class_body_method(struct_name, false, false)
            if fm_id >= 0:
                class_method_ids.push(fm_id)
            continue
        if par_kind_get() == 34:
            val mm_id = parse_class_body_method(struct_name, false, true)
            if mm_id >= 0:
                class_method_ids.push(mm_id)
            continue

        # Field prefixes: `val name: T` / `var name: T`
        if par_kind_get() == 21 or par_kind_get() == 22:
            parser_advance()
        if par_kind_get() != 6:
            # Unparseable member: report once and advance so the loop cannot
            # stall on the same token for the full iteration budget.
            parser_error("unexpected token in class body")
            parser_advance()
            parser_skip_newlines_and_semicolons()
            continue
        val fname = par_text_get()
        parser_expect(6)
        parser_expect(161)
        val ftype = parser_parse_type()
        field_names.push(fname)
        field_types.push(ftype)
        var fbits: i64 = -1
        # T:N syntax — e.g. u32:16 (bit width after type)
        if par_kind_get() == 161:
            parser_advance()
            if par_kind_get() == 1 or par_kind_get() == 2:
                fbits = parse_int_text(par_text_get())
                parser_advance()
            else:
                parser_error("expected integer bit width after ':'")
        elif par_kind_get() == 171:
            parser_advance()
            if par_kind_get() == 6 and par_text_get() == "bits":
                parser_advance()
                parser_expect(140)
                if par_kind_get() == 1 or par_kind_get() == 2:
                    fbits = parse_int_text(par_text_get())
                    parser_advance()
                else:
                    parser_error("expected integer literal in @bits(N)")
                parser_expect(141)
            else:
                parser_error("expected @bits(N) after field type")
        var fdefault: i64 = -1
        if par_kind_get() == 100:
            parser_advance()
            fdefault = parse_expr()
        field_defaults.push(fdefault)
        field_bits.push(fbits)
        parser_skip_newlines_and_semicolons()

    named_type_update(struct_type_id, field_names, field_types)
    val struct_d = decl_struct_def(struct_name, field_names, field_types, field_defaults, field_bits, 0)
    if is_class:
        decl_set_is_value_type(struct_d, 0)
    # `type_params` (parsed above, e.g. `struct Box<T>:` / `class Node<T>:`)
    # was previously parsed and then silently discarded here -- `decl_struct_def`
    # has no type-params argument, so a generic struct/class's own `<T>` never
    # reached the flat-AST decl node at all. Thread it through the same
    # generic per-decl TYPE_PARAMS side-table `decl_fn` already uses (mirrors
    # the #158 Phase A fix for plain generic functions, which threaded
    # decl_get_type_params(idx) through convert_decl_fn). Without this, HIR
    # lowering never registers `T` as a real SymbolKind.TypeParam symbol for
    # the struct/impl scope, so a struct method's use of `T` (e.g. `fn
    # get(self) -> T`) silently resolves through the unrelated
    # bareword-forward-declared-type fallback instead, producing an opaque
    # zero-field struct that crashes `llc` far downstream with a cryptic
    # "void type only allowed for function results" instead of a clear
    # diagnostic at HIR time.
    if type_params.len() > 0:
        decl_set_type_params(struct_d, type_params)

    # #157: a `trait T:` is parsed via this same struct-body path, collecting its
    # method decls (abstract + default bodies) in class_method_ids. Mark the decl
    # as a trait and carry those method ids so module_assembly can rebuild the
    # trait into module.traits -- without this, module.traits is empty on the
    # native path and un-overridden trait default methods never resolve. This is
    # separate from the phantom-impl synthesis skipped below (that route feeds
    # module.impls; this one feeds module.traits).
    if is_trait:
        decl_set_trait(struct_d, class_method_ids)

    # If class had methods, create an impl block for them. `trait T: fn m()
    # ...` is parsed via this SAME struct-body path (is_trait=true), so
    # without this guard the trait's own method bodies would ALSO
    # synthesize a real `impl T: ...` block keyed by the trait's bare NAME
    # -- module.impls then holds a phantom entry (e.g. "Speaker::speak")
    # alongside the real "impl Speaker for Dog:" -> "Dog::speak" entry.
    # MIR's struct_method_first_owner collision scan (module_lowering.spl)
    # sees two different "owners" of the bare name `speak` and marks it
    # struct_method_ambiguous, which permanently disables the Unresolved
    # fast-dispatch fallback (method_calls_literals.spl) for EVERY struct
    # implementing EVERY trait method -- confirmed empirically: a single
    # `impl Speaker for Dog` made `d.speak()` fail native-build with
    # "unresolved method call" even though Dog is the only real
    # implementor. The trait's own method bodies are never a valid
    # dispatch target (no value is ever an instance of the phantom trait
    # struct), so skip generating this impl block entirely for a trait
    # declaration; whatever trait-default-method support MIR/HIR need is
    # sourced through the real `impl Trait for Struct` blocks instead.
    if class_method_ids.len() > 0 and not is_trait:
        val impl_d = decl_impl_block(struct_name, class_method_ids, 0)
        # Same gap as above, for the synthesized impl block: without this,
        # `Impl.type_params` (module_assembly.spl tag "9") is always `[]`
        # even when the enclosing struct/class is generic.
        if type_params.len() > 0:
            decl_set_type_params(impl_d, type_params)
        module_add_decl(impl_d)

    struct_d

export parse_type_params
export parse_fn_decl, parse_extern_fn_decl, parse_struct_decl, parse_struct_or_trait_decl
