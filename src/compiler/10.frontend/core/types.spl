# @no_alloc
# Core Simple — Monomorphized Runtime Types
#
# Shared core library: type system, spans, tokens, symbols, scopes.
# All operations are free functions — no generics, no me methods, no closures.
# Arena pattern: parallel arrays instead of structs.
#
# Types are represented as integer tags and opaque i64 handles.
# The C codegen translates these to proper spl_* calls.

# ===== String Operations (delegated to runtime built-ins) =====
# Call runtime externs directly to avoid method-dispatch recursion in compiled mode.

extern fn rt_string_contains(s: text, substr: text) -> bool
extern fn rt_string_len(s: text) -> i64
extern fn rt_string_starts_with(s: text, prefix: text) -> bool
extern fn rt_string_ends_with(s: text, suffix: text) -> bool
extern fn rt_string_trim(s: text) -> text
extern fn rt_string_replace(s: text, from: text, to: text) -> text
extern fn rt_string_index_of(s: text, needle: text) -> i64

fn str_concat(a: text, b: text) -> text:
    a + b

fn str_len(s: text) -> i64:
    rt_string_len(s)

fn str_eq(a: text, b: text) -> bool:
    a == b

fn str_slice(s: text, start: i64, end_idx: i64) -> text:
    s[start:end_idx]

fn str_char_at(s: text, idx: i64) -> text:
    s[idx]

fn str_contains(s: text, needle: text) -> bool:
    rt_string_contains(s, needle)

fn str_starts_with(s: text, prefix: text) -> bool:
    rt_string_starts_with(s, prefix)

fn str_ends_with(s: text, suffix: text) -> bool:
    rt_string_ends_with(s, suffix)

fn str_index_of(s: text, needle: text) -> i64:
    rt_string_index_of(s, needle)

fn str_trim(s: text) -> text:
    rt_string_trim(s)

fn str_replace(s: text, old_s: text, new_s: text) -> text:
    rt_string_replace(s, old_s, new_s)

# ===== Integer/Text Conversion =====

fn int_to_str(n: i64) -> text:
    if n == 0:
        return "0"
    var neg: bool = false
    var v: i64 = n
    if n < 0:
        neg = true
        v = 0 - n
    var result: text = ""
    for k in 0..20:
        if v == 0:
            break
        val d = v % 10
        var ch: text = "0"
        if d == 1: ch = "1"
        if d == 2: ch = "2"
        if d == 3: ch = "3"
        if d == 4: ch = "4"
        if d == 5: ch = "5"
        if d == 6: ch = "6"
        if d == 7: ch = "7"
        if d == 8: ch = "8"
        if d == 9: ch = "9"
        result = ch + result
        v = v / 10
    if neg:
        return "-" + result
    result

fn bool_to_str(b: bool) -> text:
    if b:
        return "true"
    "false"

# ===== Span (Source Location) =====
# Stored as 4 integers per span to avoid struct issues with the runtime parser.

var span_pool_start: [i64] = []
var span_pool_end: [i64] = []
var span_pool_line: [i64] = []
var span_pool_col: [i64] = []

fn span_new(start: i64, end_pos: i64, line: i64, col: i64) -> i64:
    val idx = span_pool_start.len()
    span_pool_start.push(start)
    span_pool_end.push(end_pos)
    span_pool_line.push(line)
    span_pool_col.push(col)
    idx

fn span_start(span_id: i64) -> i64:
    span_pool_start[span_id]

fn span_end(span_id: i64) -> i64:
    span_pool_end[span_id]

fn span_line(span_id: i64) -> i64:
    span_pool_line[span_id]

fn span_col(span_id: i64) -> i64:
    span_pool_col[span_id]

fn span_dummy() -> i64:
    span_new(0, 0, 0, 0)

# ===== Token =====
# A token is (kind: i64, span: i64, text: text)
# Stored in parallel arrays for arena allocation.

var tok_pool_kind: [i64] = []
var tok_pool_span: [i64] = []
var tok_pool_text: [text] = []

fn token_new(kind: i64, span_id: i64, value: text) -> i64:
    val idx = tok_pool_kind.len()
    tok_pool_kind.push(kind)
    tok_pool_span.push(span_id)
    tok_pool_text.push(value)
    idx

fn token_kind(tok_id: i64) -> i64:
    tok_pool_kind[tok_id]

fn token_span(tok_id: i64) -> i64:
    tok_pool_span[tok_id]

fn token_text(tok_id: i64) -> text:
    tok_pool_text[tok_id]

# ===== Symbol Table =====
# Maps names to (type_tag, scope_depth, declaration_index)
# Uses Simple built-in dict (string keys).

var sym_names: [text] = []
var sym_types: [i64] = []
var sym_depths: [i64] = []
var sym_decl_ids: [i64] = []
var sym_mutable: [i64] = []

# Symbol type constants
val SYM_VAR = 1
val SYM_VAL = 2
val SYM_FN = 3
val SYM_STRUCT = 4
val SYM_EXTERN_FN = 5
val SYM_PARAM = 6
val SYM_MODULE = 7

fn symbol_new(name: text, sym_type: i64, depth: i64, decl_id: i64, is_mut: i64) -> i64:
    val idx = sym_names.len()
    sym_names.push(name)
    sym_types.push(sym_type)
    sym_depths.push(depth)
    sym_decl_ids.push(decl_id)
    sym_mutable.push(is_mut)
    idx

fn symbol_name(sym_id: i64) -> text:
    sym_names[sym_id]

fn symbol_type(sym_id: i64) -> i64:
    sym_types[sym_id]

fn symbol_depth(sym_id: i64) -> i64:
    sym_depths[sym_id]

fn symbol_decl(sym_id: i64) -> i64:
    sym_decl_ids[sym_id]

fn symbol_is_mutable(sym_id: i64) -> bool:
    sym_mutable[sym_id] == 1

# ===== Scope Stack =====
# Simple scope tracking: each scope has a start index into the symbol table.
# When exiting scope, symbols after that index are "hidden" (not removed).

var scope_starts: [i64] = []
var current_scope_depth: i64 = 0

fn scope_push() -> i64:
    scope_starts.push(sym_names.len())
    current_scope_depth = current_scope_depth + 1
    current_scope_depth

fn scope_pop() -> i64:
    current_scope_depth = current_scope_depth - 1
    val start = scope_starts[scope_starts.len() - 1]
    # We don't actually remove symbols, just track depth
    start

fn scope_depth() -> i64:
    current_scope_depth

# ===== Type Tags =====
# Bootstrap uses integer tags for types instead of a full type system.

val TYPE_VOID = 0
val TYPE_BOOL = 1
val TYPE_I64 = 2
val TYPE_F64 = 3
val TYPE_TEXT = 4
val TYPE_ARRAY_I64 = 5
val TYPE_ARRAY_TEXT = 6
val TYPE_ARRAY_BOOL = 7
val TYPE_ARRAY_ANY = 8
val TYPE_DICT = 9
val TYPE_STRUCT = 10
val TYPE_FN = 11
val TYPE_ANY = 12
val TYPE_NIL = 13
val TYPE_OPTION = 14
val TYPE_OPTION_I64 = 15
val TYPE_OPTION_F64 = 16
val TYPE_OPTION_TEXT = 17
val TYPE_OPTION_BOOL = 18
val TYPE_RESULT = 19
val TYPE_FUTURE = 20
val TYPE_POLL = 21
val TYPE_TASK = 22
val TYPE_GENERIC_ERASED = 23
val TYPE_UNION = 24
val TYPE_INTERSECTION = 25
val TYPE_REFINEMENT = 26
# Fixed-width integer primitives. i64 already has TYPE_I64 (=2); these carry the
# concrete bit width and signedness of u8/u16/u32/u64/i8/i16/i32 through the
# flat parser -> AST bridge -> HIR Int(bits, signed) -> MIR I8..U64 -> backend
# type mappers (e.g. VHDL unsigned/signed(W-1 downto 0)). Without them these
# widths collapse to TYPE_I64 and every backend renders a 64-bit lane.
val TYPE_U8 = 27
val TYPE_U16 = 28
val TYPE_U32 = 29
val TYPE_U64 = 30
val TYPE_I8 = 31
val TYPE_I16 = 32
val TYPE_I32 = 33
# Encoded ranges: union/intersection/refinement IDs are encoded into type tags
# TYPE_UNION_BASE + id => specific union, TYPE_INTERSECTION_BASE + id => specific intersection, etc.
val TYPE_UNION_BASE = 500
val TYPE_INTERSECTION_BASE = 600
val TYPE_REFINEMENT_BASE = 700
# Dict<K,V> generic-arg specializations: bare TYPE_DICT (=9) has no room to
# carry K/V, so a `Dict<text,i64>` annotation registers its two component
# tags here and encodes TYPE_DICT_BASE + id, mirroring the union/intersection/
# refinement registries above (bug: dicttype -- generic args were silently
# dropped, turning every dict-typed param/local into a plain TYPE_DICT with
# no key/value info by the time it reached the AST bridge).
val TYPE_DICT_BASE = 1000
val TYPE_RESULT_BASE = 2000
val TYPE_RESULT_LIMIT = 3000
# Tuple type annotations `(A, B, C)`: the flat tag lane previously collapsed
# every parenthesized tuple type to bare TYPE_ANY (parser.spl paren-type
# branch), so e.g. a tuple-returning extern's declared `(text, text, i32)`
# lost its element types entirely and a destructure of the call result
# defaulted every element local to i64 (parity case process_run_timeout:
# text handles printed as decimal integers). Mirrors the Dict<K,V>/Result
# registries directly above.
val TYPE_TUPLE_BASE = 3000
val TYPE_TUPLE_LIMIT = 4000
# Array element-type specializations for element types without their own
# dedicated flat tag (bug: array-class-param-sigsegv). The array-type parser
# (parser.spl's `[T]` branch) only had dedicated flat tags for
# i64/text/bool/Any element types (TYPE_ARRAY_I64/TEXT/BOOL/ANY); a named
# class/struct/enum element (e.g. `[Counter]`) fell through to the default
# and silently became bare TYPE_ARRAY_I64 -- MIR then integer-decoded (>>3)
# class handles read from such arrays into garbage pointers, SIGSEGVing on
# field access. Register the real element tag here (mirrors the
# Dict/Result/Tuple registries above) and encode TYPE_ARRAY_GENERIC_BASE + id
# so the AST bridge can rebuild the true element Type instead of losing it.
# parser.spl currently only routes TYPE_NAMED_BASE+ element tags (real
# struct/class/enum/dyn handles) through this registry -- fixed-width ints
# and Dict/Result/Tuple/Option-as-element are value types, not part of this
# bug, and intentionally keep the pre-existing TYPE_ARRAY_I64 default so
# their encoding stays byte-identical. The registry/predicate functions below
# are general (any i64 tag), so a future writer site could reuse them for a
# different element kind without changing this encoding.
val TYPE_ARRAY_GENERIC_BASE = 4000
val TYPE_ARRAY_GENERIC_LIMIT = 5000
val TYPE_NAMED_BASE = 10000

# Helper predicates for encoded type tags
fn is_union_tag(tag: i64) -> bool:
    tag >= TYPE_UNION_BASE and tag < TYPE_INTERSECTION_BASE

fn union_tag_to_id(tag: i64) -> i64:
    tag - TYPE_UNION_BASE

fn is_intersection_tag(tag: i64) -> bool:
    tag >= TYPE_INTERSECTION_BASE and tag < TYPE_REFINEMENT_BASE

fn intersection_tag_to_id(tag: i64) -> i64:
    tag - TYPE_INTERSECTION_BASE

fn is_refinement_tag(tag: i64) -> bool:
    tag >= TYPE_REFINEMENT_BASE and tag < TYPE_DICT_BASE

fn refinement_tag_to_id(tag: i64) -> i64:
    tag - TYPE_REFINEMENT_BASE

fn is_dict_tag(tag: i64) -> bool:
    tag >= TYPE_DICT_BASE and tag < TYPE_RESULT_BASE

fn dict_tag_to_id(tag: i64) -> i64:
    tag - TYPE_DICT_BASE

fn is_result_tag(tag: i64) -> bool:
    tag >= TYPE_RESULT_BASE and tag < TYPE_RESULT_LIMIT

fn result_tag_to_id(tag: i64) -> i64:
    tag - TYPE_RESULT_BASE

fn is_tuple_type_tag(tag: i64) -> bool:
    tag >= TYPE_TUPLE_BASE and tag < TYPE_TUPLE_LIMIT

fn tuple_type_tag_to_id(tag: i64) -> i64:
    tag - TYPE_TUPLE_BASE

fn is_array_generic_tag(tag: i64) -> bool:
    tag >= TYPE_ARRAY_GENERIC_BASE and tag < TYPE_ARRAY_GENERIC_LIMIT

fn array_generic_tag_to_id(tag: i64) -> i64:
    tag - TYPE_ARRAY_GENERIC_BASE

fn type_tag_name(tag: i64) -> text:
    if tag >= TYPE_NAMED_BASE:
        val nid = tag - TYPE_NAMED_BASE
        val nm = named_type_name(nid)
        if nm != "":
            return nm
        return "named_" + int_to_str(nid)
    if tag == TYPE_VOID:
        return "void"
    if tag == TYPE_BOOL:
        return "bool"
    if tag == TYPE_I64:
        return "i64"
    if tag == TYPE_U8:
        return "u8"
    if tag == TYPE_U16:
        return "u16"
    if tag == TYPE_U32:
        return "u32"
    if tag == TYPE_U64:
        return "u64"
    if tag == TYPE_I8:
        return "i8"
    if tag == TYPE_I16:
        return "i16"
    if tag == TYPE_I32:
        return "i32"
    if tag == TYPE_F64:
        return "f64"
    if tag == TYPE_TEXT:
        return "text"
    if tag == TYPE_ARRAY_I64:
        return "[i64]"
    if tag == TYPE_ARRAY_TEXT:
        return "[text]"
    if tag == TYPE_ARRAY_BOOL:
        return "[bool]"
    if tag == TYPE_ARRAY_ANY:
        return "[any]"
    if tag == TYPE_DICT:
        return "dict"
    if tag == TYPE_STRUCT:
        return "struct"
    if tag == TYPE_FN:
        return "fn"
    if tag == TYPE_ANY:
        return "any"
    if tag == TYPE_NIL:
        return "nil"
    if tag == TYPE_OPTION:
        return "Option"
    if tag == TYPE_OPTION_I64:
        return "Option<i64>"
    if tag == TYPE_OPTION_F64:
        return "Option<f64>"
    if tag == TYPE_OPTION_TEXT:
        return "Option<text>"
    if tag == TYPE_OPTION_BOOL:
        return "Option<bool>"
    if tag == TYPE_RESULT:
        return "Result"
    if tag == TYPE_FUTURE:
        return "Future"
    if tag == TYPE_POLL:
        return "Poll"
    if tag == TYPE_TASK:
        return "Task"
    if tag == TYPE_GENERIC_ERASED:
        return "Generic"
    if tag == TYPE_UNION:
        return "Union"
    if tag == TYPE_INTERSECTION:
        return "Intersection"
    if tag == TYPE_REFINEMENT:
        return "Refinement"
    # Encoded union/intersection/refinement ranges
    if is_union_tag(tag):
        val uid = union_tag_to_id(tag)
        val members = union_type_get_members(uid)
        var parts: [text] = []
        for m in members:
            parts.push(type_tag_name(m))
        return parts.join(" | ")
    if is_intersection_tag(tag):
        val iid = intersection_tag_to_id(tag)
        return "Intersection_" + int_to_str(iid)
    if is_refinement_tag(tag):
        val rid = refinement_tag_to_id(tag)
        return "Refinement_" + int_to_str(rid)
    if is_dict_tag(tag):
        val did = dict_tag_to_id(tag)
        val key_name = type_tag_name(dict_type_get_key(did))
        val value_name = type_tag_name(dict_type_get_value(did))
        return "Dict<" + key_name + "," + value_name + ">"
    if is_result_tag(tag):
        val rid = result_tag_to_id(tag)
        return "Result<" + type_tag_name(result_type_get_ok(rid)) + "," + type_tag_name(result_type_get_err(rid)) + ">"
    "unknown"

fn type_tag_to_c(tag: i64) -> text:
    if tag == TYPE_VOID:
        return "void"
    if tag == TYPE_BOOL:
        return "int"
    if tag == TYPE_I64:
        return "int64_t"
    if tag == TYPE_U8:
        return "uint8_t"
    if tag == TYPE_U16:
        return "uint16_t"
    if tag == TYPE_U32:
        return "uint32_t"
    if tag == TYPE_U64:
        return "uint64_t"
    if tag == TYPE_I8:
        return "int8_t"
    if tag == TYPE_I16:
        return "int16_t"
    if tag == TYPE_I32:
        return "int32_t"
    if tag == TYPE_F64:
        return "double"
    if tag == TYPE_TEXT:
        return "const char*"
    if tag == TYPE_ARRAY_I64:
        return "SplArray*"
    if tag == TYPE_ARRAY_TEXT:
        return "SplArray*"
    if tag == TYPE_ARRAY_BOOL:
        return "SplArray*"
    if tag == TYPE_ARRAY_ANY:
        return "SplArray*"
    if tag == TYPE_DICT:
        return "SplDict*"
    if tag == TYPE_STRUCT:
        return "void*"
    if tag == TYPE_FN:
        return "void*"
    if tag == TYPE_ANY:
        return "SplValue"
    if tag == TYPE_NIL:
        return "SplValue"
    if tag == TYPE_OPTION:
        return "SplOption*"
    if tag == TYPE_OPTION_I64:
        return "SplOption*"
    if tag == TYPE_OPTION_F64:
        return "SplOption*"
    if tag == TYPE_OPTION_TEXT:
        return "SplOption*"
    if tag == TYPE_OPTION_BOOL:
        return "SplOption*"
    if tag == TYPE_RESULT:
        return "SplResult*"
    if tag == TYPE_FUTURE:
        return "SplFuture*"
    if tag == TYPE_POLL:
        return "SplPoll*"
    if tag == TYPE_TASK:
        return "SplTask*"
    if tag == TYPE_GENERIC_ERASED:
        return "SplValue"
    if tag == TYPE_UNION:
        return "SplValue"
    if tag == TYPE_INTERSECTION:
        return "SplValue"
    if tag == TYPE_REFINEMENT:
        return "SplValue"
    # Encoded union/intersection/refinement ranges map to SplValue in C
    if is_union_tag(tag):
        return "SplValue"
    if is_intersection_tag(tag):
        return "SplValue"
    if is_refinement_tag(tag):
        return "SplValue"
    if is_dict_tag(tag):
        return "SplDict*"
    if is_result_tag(tag):
        return "SplResult*"
    if tag >= TYPE_NAMED_BASE:
        val nid = tag - TYPE_NAMED_BASE
        val nm = named_type_name(nid)
        if nm != "":
            return nm
        return "int64_t"
    "int64_t"

# ===== Named Type Registry =====
# Maps struct/enum names to their field information.

var named_type_names: [text] = []
var named_type_field_names: [[text]] = []
var named_type_field_types: [[i64]] = []

# Custom primitive registry.
# Newtypes are still constructible single-field structs, but ABI-sensitive
# phases can ask this registry for their transparent primitive representation.
var custom_primitive_names: [text] = []
var custom_primitive_underlying_type_tags: [i64] = []
var custom_primitive_symbol_ids: [i64] = []

fn named_type_register(name: text, field_names: [text], field_types: [i64]) -> i64:
    val idx = named_type_names.len()
    named_type_names.push(name)
    named_type_field_names.push(field_names)
    named_type_field_types.push(field_types)
    idx

fn named_type_update(type_id: i64, field_names: [text], field_types: [i64]):
    named_type_field_names[type_id] = field_names
    named_type_field_types[type_id] = field_types

fn named_type_find(name: text) -> i64:
    var i = 0
    while i < named_type_names.len():
        if named_type_names[i] == name:
            return i
        i = i + 1
    -1

fn named_type_name(type_id: i64) -> text:
    named_type_names[type_id]

fn named_type_fields(type_id: i64) -> [text]:
    named_type_field_names[type_id]

fn named_type_field_type_tags(type_id: i64) -> [i64]:
    named_type_field_types[type_id]

fn primitive_bit_width_from_name(type_name: text) -> i64:
    if type_name == "bool":
        return 1
    if type_name == "i8" or type_name == "u8":
        return 8
    if type_name == "i16" or type_name == "u16":
        return 16
    if type_name == "i32" or type_name == "u32":
        return 32
    if type_name == "i64" or type_name == "u64":
        return 64
    if type_name == "f32":
        return 32
    if type_name == "f64":
        return 64
    0

fn parse_positive_int_text_digits(value: text) -> i64:
    var result: i64 = 0
    if value.len() == 0:
        return 0
    for i in 0..value.len():
        val ch = value[i]
        if ch < "0" or ch > "9":
            return 0
        var digit: i64 = 0
        if ch == "1": digit = 1
        if ch == "2": digit = 2
        if ch == "3": digit = 3
        if ch == "4": digit = 4
        if ch == "5": digit = 5
        if ch == "6": digit = 6
        if ch == "7": digit = 7
        if ch == "8": digit = 8
        if ch == "9": digit = 9
        result = result * 10 + digit
    result

fn primitive_integer_bit_width_from_name(type_name: text) -> i64:
    val has_u_prefix: bool = type_name.starts_with("u")
    val has_i_prefix: bool = type_name.starts_with("i")
    if not (has_u_prefix or has_i_prefix):
        return 0
    if type_name.len() <= 1:
        return 0
    for bi in 1..type_name.len():
        val ch = type_name[bi]
        if ch < "0" or ch > "9":
            return 0
    val bits = parse_positive_int_text_digits(type_name[1:type_name.len()])
    if bits <= 0 or bits > 64:
        return 0
    bits

fn primitive_backing_bits_from_name(type_name: text) -> i64:
    if type_name == "u8":
        return 8
    if type_name == "u16":
        return 16
    if type_name == "u32":
        return 32
    if type_name == "u64":
        return 64
    0

fn custom_primitive_find(name: text) -> i64:
    var i = 0
    while i < custom_primitive_names.len():
        if custom_primitive_names[i] == name:
            return i
        i = i + 1
    -1

fn custom_primitive_register(name: text, underlying_type_tag: i64) -> i64:
    val existing = custom_primitive_find(name)
    if existing >= 0:
        custom_primitive_underlying_type_tags[existing] = underlying_type_tag
        return existing
    val idx = custom_primitive_names.len()
    custom_primitive_names.push(name)
    custom_primitive_underlying_type_tags.push(underlying_type_tag)
    custom_primitive_symbol_ids.push(-1)
    idx

fn custom_primitive_bind_symbol(name: text, symbol_id: i64):
    val idx = custom_primitive_find(name)
    if idx >= 0:
        custom_primitive_symbol_ids[idx] = symbol_id

fn custom_primitive_is_name(name: text) -> bool:
    custom_primitive_find(name) >= 0

fn custom_primitive_underlying_type_tag_by_name(name: text) -> i64:
    val idx = custom_primitive_find(name)
    if idx < 0:
        return -1
    custom_primitive_underlying_type_tags[idx]

fn custom_primitive_underlying_type_tag_by_symbol(symbol_id: i64) -> i64:
    var i = 0
    while i < custom_primitive_symbol_ids.len():
        if custom_primitive_symbol_ids[i] == symbol_id:
            return custom_primitive_underlying_type_tags[i]
        i = i + 1
    -1

fn custom_primitive_underlying_name_by_name(name: text) -> text:
    val tag = custom_primitive_underlying_type_tag_by_name(name)
    if tag < 0:
        return ""
    type_tag_name(tag)

fn custom_primitive_abi_type_name(type_name: text) -> text:
    val inner = custom_primitive_underlying_name_by_name(type_name)
    if inner == "":
        return type_name
    inner

fn custom_primitive_bit_width_by_name(name: text) -> i64:
    val inner = custom_primitive_underlying_name_by_name(name)
    if inner == "":
        return 0
    primitive_bit_width_from_name(inner)

fn custom_primitive_integer_bit_width_by_name(name: text) -> i64:
    val inner = custom_primitive_underlying_name_by_name(name)
    if inner == "":
        return 0
    if inner == "bool":
        return 1
    primitive_integer_bit_width_from_name(inner)

fn custom_primitive_backing_bits_by_name(name: text) -> i64:
    val inner = custom_primitive_underlying_name_by_name(name)
    if inner == "":
        return 0
    primitive_backing_bits_from_name(inner)

fn custom_primitive_c_type_by_name(name: text) -> text:
    val inner = custom_primitive_underlying_name_by_name(name)
    if inner == "":
        return ""
    type_tag_to_c(custom_primitive_underlying_type_tag_by_name(name))

fn custom_primitive_c_type_by_symbol(symbol_id: i64) -> text:
    val tag = custom_primitive_underlying_type_tag_by_symbol(symbol_id)
    if tag < 0:
        return ""
    type_tag_to_c(tag)

fn custom_primitive_llvm_type_from_tag(tag: i64) -> text:
    if tag == TYPE_BOOL:
        return "i1"
    if tag == TYPE_I64:
        return "i64"
    if tag == TYPE_F64:
        return "double"
    val name = type_tag_name(tag)
    if name == "i8" or name == "u8":
        return "i8"
    if name == "i16" or name == "u16":
        return "i16"
    if name == "i32" or name == "u32":
        return "i32"
    if name == "i64" or name == "u64":
        return "i64"
    if name == "f32":
        return "float"
    if name == "f64":
        return "double"
    ""

fn custom_primitive_llvm_type_by_name(name: text) -> text:
    val tag = custom_primitive_underlying_type_tag_by_name(name)
    if tag < 0:
        return ""
    custom_primitive_llvm_type_from_tag(tag)

fn custom_primitive_llvm_type_by_symbol(symbol_id: i64) -> text:
    val tag = custom_primitive_underlying_type_tag_by_symbol(symbol_id)
    if tag < 0:
        return ""
    custom_primitive_llvm_type_from_tag(tag)

# ===== Function Signature Registry =====
# Tracks function signatures for cross-file resolution and C forward declarations.

var fn_sig_names: [text] = []
var fn_sig_param_names: [[text]] = []
var fn_sig_param_types: [[i64]] = []
var fn_sig_ret_types: [i64] = []
var fn_sig_is_extern: [i64] = []

fn fn_sig_register(name: text, param_names: [text], param_types: [i64], ret_type: i64, is_ext: i64) -> i64:
    val idx = fn_sig_names.len()
    fn_sig_names.push(name)
    fn_sig_param_names.push(param_names)
    fn_sig_param_types.push(param_types)
    fn_sig_ret_types.push(ret_type)
    fn_sig_is_extern.push(is_ext)
    idx

fn fn_sig_find(name: text) -> i64:
    var i = 0
    while i < fn_sig_names.len():
        if fn_sig_names[i] == name:
            return i
        i = i + 1
    -1

fn fn_sig_name(sig_id: i64) -> text:
    fn_sig_names[sig_id]

fn fn_sig_ret_type(sig_id: i64) -> i64:
    fn_sig_ret_types[sig_id]

fn fn_sig_param_count(sig_id: i64) -> i64:
    fn_sig_param_names[sig_id].len()

fn fn_sig_is_extern_fn(sig_id: i64) -> bool:
    fn_sig_is_extern[sig_id] == 1

fn fn_sig_get_param_names(sig_id: i64) -> [text]:
    fn_sig_param_names[sig_id]

fn fn_sig_get_param_types(sig_id: i64) -> [i64]:
    fn_sig_param_types[sig_id]

# ===== Generic Parameter Registry =====
# Tracks type parameters for generic classes and functions.
# Each entry represents a type parameter (T, U, K, V, etc.)

var generic_param_names: [text] = []
var generic_param_contexts: [text] = []
var generic_param_ids: [i64] = []

fn generic_param_register(name: text, context: text) -> i64:
    val idx = generic_param_names.len()
    generic_param_names.push(name)
    generic_param_contexts.push(context)
    generic_param_ids.push(idx)
    idx

fn generic_param_find(name: text, context: text) -> i64:
    var i = 0
    while i < generic_param_names.len():
        if (generic_param_names[i] == name and
            generic_param_contexts[i] == context):
            return i
        i = i + 1
    -1

fn generic_param_name(param_id: i64) -> text:
    generic_param_names[param_id]

fn generic_param_context(param_id: i64) -> text:
    generic_param_contexts[param_id]

fn generic_param_count() -> i64:
    generic_param_names.len()

# ===== Union Type Registry =====
# Tracks union types (A | B | C)

var union_type_members: [[i64]] = []

fn type_tag_list_find(items: [[i64]], target: [i64]) -> i64:
    var i = 0
    while i < items.len():
        val item = items[i]
        if item.len() == target.len():
            var j = 0
            while j < target.len() and item[j] == target[j]:
                j = j + 1
            if j == target.len():
                return i
        i = i + 1
    -1

fn type_tag_pair_find(firsts: [i64], seconds: [i64], first: i64, second: i64) -> i64:
    var i = 0
    while i < firsts.len():
        if firsts[i] == first and seconds[i] == second:
            return i
        i = i + 1
    -1

fn union_type_register(member_types: [i64]) -> i64:
    val existing = type_tag_list_find(union_type_members, member_types)
    if existing >= 0:
        return TYPE_UNION_BASE + existing
    val idx = union_type_members.len()
    if idx >= TYPE_INTERSECTION_BASE - TYPE_UNION_BASE:
        return -1
    union_type_members.push(member_types)
    TYPE_UNION_BASE + idx

fn union_type_get_members(union_id: i64) -> [i64]:
    if union_id >= 0 and union_id < union_type_members.len():
        return union_type_members[union_id]
    []

# ===== Tuple Type Registry =====
# Tracks tuple type annotations `(A, B, C)` -- see TYPE_TUPLE_BASE.

var tuple_type_elem_tags: [[i64]] = []

fn tuple_type_register(elem_types: [i64]) -> i64:
    val existing = type_tag_list_find(tuple_type_elem_tags, elem_types)
    if existing >= 0:
        return TYPE_TUPLE_BASE + existing
    val idx = tuple_type_elem_tags.len()
    if idx >= TYPE_TUPLE_LIMIT - TYPE_TUPLE_BASE:
        return -1
    tuple_type_elem_tags.push(elem_types)
    TYPE_TUPLE_BASE + idx

fn tuple_type_get_elems(tuple_id: i64) -> [i64]:
    if tuple_id >= 0 and tuple_id < tuple_type_elem_tags.len():
        return tuple_type_elem_tags[tuple_id]
    []

# ===== Intersection Type Registry =====
# Tracks intersection types (A & B & C)

var intersection_type_members: [[i64]] = []

fn intersection_type_register(member_types: [i64]) -> i64:
    val existing = type_tag_list_find(intersection_type_members, member_types)
    if existing >= 0:
        return TYPE_INTERSECTION_BASE + existing
    val idx = intersection_type_members.len()
    if idx >= TYPE_REFINEMENT_BASE - TYPE_INTERSECTION_BASE:
        return -1
    intersection_type_members.push(member_types)
    TYPE_INTERSECTION_BASE + idx

fn intersection_type_get_members(inter_id: i64) -> [i64]:
    if inter_id >= 0 and inter_id < intersection_type_members.len():
        return intersection_type_members[inter_id]
    []

# ===== Refinement Type Registry =====
# Tracks refinement types (x: i64 where x > 0)

var refinement_base_types: [i64] = []
var refinement_predicates: [text] = []

fn refinement_type_register(base_type: i64, predicate: text) -> i64:
    var existing = 0
    while existing < refinement_base_types.len():
        if refinement_base_types[existing] == base_type and refinement_predicates[existing] == predicate:
            return TYPE_REFINEMENT_BASE + existing
        existing = existing + 1
    val idx = refinement_base_types.len()
    if idx >= TYPE_DICT_BASE - TYPE_REFINEMENT_BASE:
        return -1
    refinement_base_types.push(base_type)
    refinement_predicates.push(predicate)
    TYPE_REFINEMENT_BASE + idx

fn refinement_type_base(ref_id: i64) -> i64:
    if ref_id >= 0 and ref_id < refinement_base_types.len():
        return refinement_base_types[ref_id]
    TYPE_ANY

fn refinement_type_predicate(ref_id: i64) -> text:
    if ref_id >= 0 and ref_id < refinement_predicates.len():
        return refinement_predicates[ref_id]
    ""

# ===== Dict Specialization Registry =====
# Tracks Dict<K,V> generic-arg specializations (bug: dicttype). Each distinct
# Dict<K,V> annotation registers its key/value tags and is referenced later
# (AST bridge, HIR lowering) via the encoded TYPE_DICT_BASE + id tag.

var dict_type_keys: [i64] = []
var dict_type_values: [i64] = []

fn dict_type_register(key_tag: i64, value_tag: i64) -> i64:
    val existing = type_tag_pair_find(dict_type_keys, dict_type_values, key_tag, value_tag)
    if existing >= 0:
        return TYPE_DICT_BASE + existing
    val idx = dict_type_keys.len()
    if idx >= TYPE_RESULT_BASE - TYPE_DICT_BASE:
        return -1
    dict_type_keys.push(key_tag)
    dict_type_values.push(value_tag)
    TYPE_DICT_BASE + idx

fn dict_type_get_key(dict_id: i64) -> i64:
    if dict_id >= 0 and dict_id < dict_type_keys.len():
        return dict_type_keys[dict_id]
    TYPE_ANY

fn dict_type_get_value(dict_id: i64) -> i64:
    if dict_id >= 0 and dict_id < dict_type_values.len():
        return dict_type_values[dict_id]
    TYPE_ANY

# ===== Result Specialization Registry =====

var result_type_ok: [i64] = []
var result_type_err: [i64] = []

fn result_type_register(ok_tag: i64, err_tag: i64) -> i64:
    val existing = type_tag_pair_find(result_type_ok, result_type_err, ok_tag, err_tag)
    if existing >= 0:
        return TYPE_RESULT_BASE + existing
    val idx = result_type_ok.len()
    if idx >= TYPE_RESULT_LIMIT - TYPE_RESULT_BASE:
        return -1
    result_type_ok.push(ok_tag)
    result_type_err.push(err_tag)
    TYPE_RESULT_BASE + idx

fn result_type_get_ok(result_id: i64) -> i64:
    if result_id >= 0 and result_id < result_type_ok.len():
        return result_type_ok[result_id]
    TYPE_ANY

fn result_type_get_err(result_id: i64) -> i64:
    if result_id >= 0 and result_id < result_type_err.len():
        return result_type_err[result_id]
    TYPE_ANY

# ===== Array Element-Type Specialization Registry =====
# Tracks array element types with no dedicated flat tag (bug:
# array-class-param-sigsegv) -- see TYPE_ARRAY_GENERIC_BASE.

var array_generic_elem_tags: [i64] = []

fn array_generic_type_register(elem_tag: i64) -> i64:
    var existing = 0
    while existing < array_generic_elem_tags.len():
        if array_generic_elem_tags[existing] == elem_tag:
            return TYPE_ARRAY_GENERIC_BASE + existing
        existing = existing + 1
    val idx = array_generic_elem_tags.len()
    if idx >= TYPE_ARRAY_GENERIC_LIMIT - TYPE_ARRAY_GENERIC_BASE:
        return -1
    array_generic_elem_tags.push(elem_tag)
    TYPE_ARRAY_GENERIC_BASE + idx

fn array_generic_type_get_elem(arr_id: i64) -> i64:
    if arr_id >= 0 and arr_id < array_generic_elem_tags.len():
        return array_generic_elem_tags[arr_id]
    TYPE_ANY

# ===== Pool Reset =====
# Call before parsing a new file to reset all pools.

fn reset_all_pools():
    span_pool_start = []
    span_pool_end = []
    span_pool_line = []
    span_pool_col = []
    tok_pool_kind = []
    tok_pool_span = []
    tok_pool_text = []
    sym_names = []
    sym_types = []
    sym_depths = []
    sym_decl_ids = []
    sym_mutable = []
    scope_starts = []
    current_scope_depth = 0
    named_type_names = []
    named_type_field_names = []
    named_type_field_types = []
    custom_primitive_names = []
    custom_primitive_underlying_type_tags = []
    custom_primitive_symbol_ids = []
    fn_sig_names = []
    fn_sig_param_names = []
    fn_sig_param_types = []
    fn_sig_ret_types = []
    fn_sig_is_extern = []
    generic_param_names = []
    generic_param_contexts = []
    generic_param_ids = []
    union_type_members = []
    tuple_type_elem_tags = []
    intersection_type_members = []
    refinement_base_types = []
    refinement_predicates = []
    dict_type_keys = []
    dict_type_values = []
    result_type_ok = []
    result_type_err = []
    array_generic_elem_tags = []

export TYPE_VOID, TYPE_BOOL, TYPE_I64, TYPE_F64, TYPE_TEXT
export TYPE_U8, TYPE_U16, TYPE_U32, TYPE_U64, TYPE_I8, TYPE_I16, TYPE_I32
export TYPE_ARRAY_I64, TYPE_ARRAY_TEXT, TYPE_ARRAY_BOOL, TYPE_ARRAY_ANY
export TYPE_STRUCT, TYPE_FN, TYPE_DICT, TYPE_ANY, TYPE_NIL
export TYPE_OPTION, TYPE_OPTION_I64, TYPE_OPTION_F64, TYPE_OPTION_TEXT, TYPE_OPTION_BOOL, TYPE_RESULT
export TYPE_UNION, TYPE_INTERSECTION, TYPE_REFINEMENT, TYPE_NAMED_BASE
export TYPE_FUTURE, TYPE_POLL, TYPE_TASK, TYPE_GENERIC_ERASED
export TYPE_UNION_BASE, TYPE_INTERSECTION_BASE, TYPE_REFINEMENT_BASE
export TYPE_DICT_BASE, is_dict_tag, dict_tag_to_id
export dict_type_register, dict_type_get_key, dict_type_get_value
export TYPE_RESULT_BASE, is_result_tag, result_tag_to_id
export result_type_register, result_type_get_ok, result_type_get_err
export TYPE_ARRAY_GENERIC_BASE, is_array_generic_tag, array_generic_tag_to_id
export array_generic_type_register, array_generic_type_get_elem
export SYM_UNKNOWN, SYM_FN, SYM_VAL, SYM_VAR, SYM_STRUCT, SYM_ENUM, SYM_CLASS
export scope_push, scope_pop, scope_depth
