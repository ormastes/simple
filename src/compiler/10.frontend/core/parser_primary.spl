# Parser — Primary Expression & ASM Parsing
#
# Extracted from parser_expr.spl. Contains:
# - parse_primary: primary expression parsing (literals, identifiers, keywords, etc.)
# - ASM parsing: asm match, asm assert, target spec parsing

use compiler.core.tokens.{tok_kind_name}
use compiler.core.tokens.{TOK_INT_LIT, TOK_FLOAT_LIT, TOK_STRING_LIT}
use compiler.core.tokens.{TOK_BOOL_LIT, TOK_NIL_LIT, TOK_IDENT}
use compiler.core.tokens.{TOK_KW_IF, TOK_KW_MATCH, TOK_KW_CASE}
use compiler.core.tokens.{TOK_KW_RETURN, TOK_KW_BREAK, TOK_KW_CONTINUE}
use compiler.core.tokens.{TOK_KW_NOT}
use compiler.core.tokens.{TOK_KW_PASS, TOK_KW_PASS_TODO, TOK_KW_PASS_DO_NOTHING, TOK_KW_PASS_DN}
use compiler.core.tokens.{TOK_KW_SELF}
use compiler.core.tokens.{TOK_KW_ASYNC, TOK_KW_AWAIT, TOK_KW_YIELD, TOK_KW_SPAWN}
use compiler.core.tokens.{TOK_KW_NEW}
use compiler.core.tokens.{TOK_KW_ASM}
use compiler.core.tokens.{TOK_MINUS, TOK_NOT}
use compiler.core.tokens.{TOK_EQ, TOK_LT, TOK_GEQ}
use compiler.core.tokens.{TOK_LPAREN, TOK_RPAREN, TOK_LBRACKET, TOK_RBRACKET}
use compiler.core.tokens.{TOK_LBRACE, TOK_RBRACE}
use compiler.core.tokens.{TOK_COLON, TOK_COMMA, TOK_PIPE}
use compiler.core.tokens.{TOK_NEWLINE, TOK_INDENT, TOK_DEDENT, TOK_EOF, TOK_ERROR}
use compiler.core.tokens.{TOK_UNDERSCORE, TOK_SEMICOLON}
use compiler.core.tokens.{TOK_SUFFIXED_INT, TOK_SUFFIXED_FLOAT}
use compiler.core.tokens.{TOK_KW_DO, TOK_KW_CE}
use compiler.core.tokens.{TOK_BACKTICK_IDENT}
use compiler.core.tokens.{TOK_AT, TOK_KW_KEYOF, TOK_KW_MIXIN, TOK_STAR}
use compiler.core.tokens.{TOK_AMP_COLON}
use compiler.core.tokens.{TOK_KW_FOR, TOK_KW_IF, TOK_KW_IN}
use compiler.core.ast.{expr_int_lit, expr_float_lit, expr_string_lit}
use compiler.core.ast.{expr_bool_lit, expr_nil_lit, expr_ident}
use compiler.core.ast.{expr_unary, expr_call, expr_array_lit, expr_method_call, expr_lambda}
use compiler.core.ast.{expr_return_expr, expr_break_expr, expr_continue_expr}
use compiler.core.ast.{expr_unit, expr_pass, expr_pass_with_msg, expr_pass_todo, expr_pass_do_nothing, expr_pass_dn}
use compiler.core.ast.{expr_dict_lit}
use compiler.core.ast.{expr_suffixed_int, expr_suffixed_float, expr_suffixed_bool}
use compiler.core.ast.{expr_await, expr_yield, expr_spawn, expr_do_block, expr_atom, expr_new_alloc}
use compiler.core.ast.{expr_list_comp, expr_dict_comp}
use compiler.core.ast.{expr_asm, expr_asm_match, expr_asm_assert}
use compiler.core.ast.{asm_arm_new, asm_arm_is_compile_error, asm_arm_error_msg, asm_arm_asm_text}
use compiler.frontend.core.lexer.{lex_cur_suffix_get}
use compiler.frontend.core.lexer.{lex_pos_get, lex_pos_set, lex_line_get, lex_line_set, lex_col_get, lex_col_set}
use compiler.frontend.core.lexer.{lex_source_char_at, lex_source_len, lex_source_slice}
use compiler.core.parser.{par_kind_get, par_text_get, par_line_get, par_col_get, par_errors}
use compiler.core.parser.{parser_advance, parser_expect, parser_error, parser_warn, parser_skip_newlines}
use compiler.core.parser.{parser_parse_type}

# Forward declarations for mutual recursion
use compiler.core.parser_stmts.{parse_block, parse_match_stmt, parse_if_expr}
use compiler.core.parser_expr.{parse_expr, parse_not, parse_unary}

fn parse_optional_rationale_args() -> text:
    var msg = ""
    if par_kind_get() == TOK_LPAREN:
        parser_advance()
        if par_kind_get() == TOK_STRING_LIT:
            msg = par_text_get()
            parser_advance()
            if par_kind_get() == TOK_COMMA:
                parser_advance()
                if par_kind_get() == TOK_STRING_LIT:
                    val hint = par_text_get()
                    parser_advance()
                    if hint != "":
                        if msg != "":
                            msg = msg + " | " + hint
                        else:
                            msg = hint
        parser_expect(TOK_RPAREN)
    msg

fn parse_raw_asm_normalize(payload: text) -> text:
    var parts: [text] = []
    for line in payload.split("\n"):
        var trimmed = line.trim()
        while trimmed.ends_with(";") or trimmed.ends_with(","):
            trimmed = trimmed[0:trimmed.len() - 1].trim()
        if trimmed.len() >= 2:
            val first = trimmed[0:1]
            val last = trimmed[trimmed.len() - 1:trimmed.len()]
            if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
                trimmed = trimmed[1:trimmed.len() - 1]
        if trimmed != "":
            parts.push(trimmed)
    parts.join("\n")

fn parse_raw_asm_advance_lexer(start_pos: i64, end_pos: i64):
    var line = lex_line_get()
    var col = lex_col_get()
    var pos = start_pos
    while pos < end_pos:
        val ch = lex_source_char_at(pos)
        if ch == "\n":
            line = line + 1
            col = 1
        else:
            col = col + 1
        pos = pos + 1
    lex_pos_set(end_pos)
    lex_line_set(line)
    lex_col_set(col)

fn parse_raw_asm_braced_payload() -> text:
    val content_start = lex_pos_get()
    val source_len = lex_source_len()
    var pos = content_start
    var depth = 1
    var in_string = false
    var string_quote = ""
    var escaped = false
    while pos < source_len:
        val ch = lex_source_char_at(pos)
        if in_string:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == string_quote:
                in_string = false
        else:
            if ch == "\"" or ch == "'":
                in_string = true
                string_quote = ch
            elif ch == "{":
                depth = depth + 1
            elif ch == "}":
                depth = depth - 1
                if depth == 0:
                    val payload = lex_source_slice(content_start, pos)
                    parse_raw_asm_advance_lexer(content_start, pos + 1)
                    parser_advance()
                    return parse_raw_asm_normalize(payload)
        pos = pos + 1
    parser_error("unterminated asm { ... } block")
    val payload = lex_source_slice(content_start, source_len)
    parse_raw_asm_advance_lexer(content_start, source_len)
    parser_advance()
    parse_raw_asm_normalize(payload)

fn parse_legacy_parenthesized_asm() -> text:
    parser_warn("legacy inline asm syntax; use asm { ... }")
    parser_expect(TOK_LPAREN)
    var depth = 1
    var asm_lines: [text] = []
    for ai in 0..100000:
        if depth <= 0:
            break
        if par_kind_get() == TOK_EOF:
            break
        if par_kind_get() == TOK_LPAREN:
            depth = depth + 1
            parser_advance()
            continue
        if par_kind_get() == TOK_RPAREN:
            depth = depth - 1
            parser_advance()
            continue
        if par_kind_get() == TOK_STRING_LIT:
            asm_lines.push(par_text_get())
            parser_advance()
            continue
        parser_advance()
    asm_lines.join("\n")

fn parse_primary_expr() -> i64:
    # @annotation(...) -- compile-time introspection built-ins
    # @traits(query, T, ...) desugars to __traits("query", "T", ...)
    # @file, @line, @function desugar to __builtin_file etc.
    if par_kind_get() == TOK_AT:
        parser_advance()
        val ann_name = par_text_get()
        if par_kind_get() == TOK_IDENT:
            parser_advance()
        if par_kind_get() == TOK_LPAREN:
            parser_advance()
            var at_args: [i64] = []
            # First argument: the annotation name as a string literal
            at_args.push(expr_string_lit(ann_name, 0))
            for at_i in 0..20:
                if par_kind_get() == TOK_RPAREN:
                    break
                if par_kind_get() == TOK_COMMA:
                    parser_advance()
                    continue
                if par_kind_get() == TOK_EOF:
                    break
                # Identifier args (type names) become string literals
                if par_kind_get() == TOK_IDENT:
                    val id_arg = par_text_get()
                    parser_advance()
                    at_args.push(expr_string_lit(id_arg, 0))
                else:
                    val expr_arg = parse_expr()
                    at_args.push(expr_arg)
            parser_expect(TOK_RPAREN)
            val at_callee = expr_ident("__traits", 0)
            return expr_call(at_callee, at_args, 0)
        # Simple @identifier (no parens): @file, @line, @function
        val at_builtin_name = "__builtin_" + ann_name
        return expr_ident(at_builtin_name, 0)

    # keyof T -- compile-time field name list (sugar for @traits("fields", "T"))
    if par_kind_get() == TOK_KW_KEYOF:
        parser_advance()
        val keyof_type = par_text_get()
        if par_kind_get() == TOK_IDENT:
            parser_advance()
        var keyof_args: [i64] = []
        keyof_args.push(expr_string_lit("fields", 0))
        keyof_args.push(expr_string_lit(keyof_type, 0))
        val keyof_callee = expr_ident("__traits", 0)
        return expr_call(keyof_callee, keyof_args, 0)

    # mixin(code_text) -- compile-time code generation
    # Desugars to __mixin(code_text) builtin call
    if par_kind_get() == TOK_KW_MIXIN:
        parser_advance()
        parser_expect(TOK_LPAREN)
        val mixin_arg = parse_expr()
        parser_expect(TOK_RPAREN)
        var mixin_args_list: [i64] = []
        mixin_args_list.push(mixin_arg)
        val mixin_callee = expr_ident("__mixin", 0)
        return expr_call(mixin_callee, mixin_args_list, 0)

    # asm "..." | asm: "..." | asm { ... } | asm volatile { ... } | asm match: | asm assert [...]
    if par_kind_get() == TOK_KW_ASM:
        parser_advance()

        # asm match: -- multi-target dispatch
        if par_kind_get() == TOK_KW_MATCH:
            parser_advance()
            parser_expect(TOK_COLON)
            return parse_asm_match()

        # asm assert [...] -- compile-time target guard (parsed as expression, handled as stmt)
        if par_kind_get() == TOK_IDENT and par_text_get() == "assert":
            parser_advance()
            return parse_asm_assert_expr()

        if par_kind_get() == TOK_IDENT and par_text_get() == "volatile":
            parser_advance()

        if par_kind_get() == TOK_LPAREN:
            return expr_asm(parse_legacy_parenthesized_asm(), 0)

        if par_kind_get() == TOK_STRING_LIT:
            parser_warn("legacy inline asm syntax; use asm { ... }")
            val inline_asm = par_text_get()
            parser_advance()
            return expr_asm(inline_asm, 0)

        if par_kind_get() == TOK_COLON:
            parser_warn("legacy inline asm syntax; use asm { ... }")
            parser_advance()
            parser_skip_newlines()
            if par_kind_get() != TOK_INDENT:
                parser_error("expected indented asm block after 'asm:'")
                return expr_asm("", 0)
            parser_advance()
            var asm_lines: [text] = []
            for ai in 0..100000:
                parser_skip_newlines()
                if par_kind_get() == TOK_DEDENT:
                    parser_advance()
                    break
                if par_kind_get() == TOK_EOF:
                    break
                if par_kind_get() == TOK_STRING_LIT:
                    asm_lines.push(par_text_get())
                    parser_advance()
                    continue
                parser_error("expected string literal in asm block")
                for aj in 0..10000:
                    val is_nl = par_kind_get() == TOK_NEWLINE
                    val is_ded = par_kind_get() == TOK_DEDENT
                    val is_eof = par_kind_get() == TOK_EOF
                    if is_nl or is_ded or is_eof:
                        break
                    parser_advance()
            return expr_asm(asm_lines.join("\n"), 0)

        if par_kind_get() == TOK_LBRACE:
            val raw_asm = parse_raw_asm_braced_payload()
            return expr_asm(raw_asm, 0)

        parser_error("expected string literal, ':' block, or '{...}' after 'asm'")
        return expr_asm("", 0)

    if par_kind_get() == TOK_INT_LIT:
        val int_text = par_text_get()
        parser_advance()
        # Parse integer from text (supporting _ separators and 0x/0b/0o prefixes)
        var int_val = 0
        if int_text.len() > 2:
            val prefix = int_text[0:2]
            if prefix == "0x":
                # Hex literal: parse digit by digit
                val hex_digits = int_text[2:]
                var hex_val = 0
                var hi = 0
                while hi < hex_digits.len():
                    val hc = hex_digits[hi:hi+1]
                    if hc != "_":
                        var hd = 0
                        if hc >= "0" and hc <= "9":
                            hd = int(hc)
                        elif hc >= "a" and hc <= "f":
                            hd = int(hc) - int("a") + 10
                        elif hc >= "A" and hc <= "F":
                            hd = int(hc) - int("A") + 10
                        hex_val = hex_val * 16 + hd
                    hi = hi + 1
                return expr_int_lit(hex_val, 0)
            if prefix == "0b":
                # Binary literal: parse digit by digit
                val bin_digits = int_text[2:]
                var bin_val = 0
                var bi = 0
                while bi < bin_digits.len():
                    val bc = bin_digits[bi:bi+1]
                    if bc == "1":
                        bin_val = bin_val * 2 + 1
                    elif bc == "0":
                        bin_val = bin_val * 2
                    bi = bi + 1
                return expr_int_lit(bin_val, 0)
            if prefix == "0o":
                # Octal literal: parse digit by digit
                val oct_digits = int_text[2:]
                var oct_val = 0
                var oi = 0
                while oi < oct_digits.len():
                    val oc = oct_digits[oi:oi+1]
                    if oc != "_":
                        oct_val = oct_val * 8 + int(oc)
                    oi = oi + 1
                return expr_int_lit(oct_val, 0)
        # Decimal -- strip _ separators then parse
        var stripped: text = ""
        var si = 0
        while si < int_text.len():
            val sc = int_text[si:si+1]
            if sc != "_":
                stripped = stripped + sc
            si = si + 1
        if stripped.len() > 0:
            int_val = int(stripped)
        return expr_int_lit(int_val, 0)

    if par_kind_get() == TOK_FLOAT_LIT:
        val float_text = par_text_get()
        parser_advance()
        return expr_float_lit(float_text, 0)

    if par_kind_get() == TOK_SUFFIXED_INT:
        val suf_text = par_text_get()
        val suf_name = lex_cur_suffix_get()
        parser_advance()
        val int_val = int(suf_text)
        return expr_suffixed_int(int_val, suf_name, 0)

    if par_kind_get() == TOK_SUFFIXED_FLOAT:
        val suf_text = par_text_get()
        val suf_name = lex_cur_suffix_get()
        parser_advance()
        return expr_suffixed_float(suf_text, suf_name, 0)

    if par_kind_get() == TOK_STRING_LIT:
        val str_text = par_text_get()
        parser_advance()
        return expr_string_lit(str_text, 0)

    if par_kind_get() == TOK_BOOL_LIT:
        val bool_text = par_text_get()
        parser_advance()
        if bool_text == "true":
            return expr_bool_lit(1, 0)
        return expr_bool_lit(0, 0)

    if par_kind_get() == TOK_NIL_LIT:
        parser_advance()
        return expr_nil_lit(0)

    if par_kind_get() == TOK_IDENT:
        val id_name = par_text_get()
        parser_advance()
        return expr_ident(id_name, 0)

    if par_kind_get() == TOK_KW_SELF:
        parser_advance()
        return expr_ident("self", 0)

    if par_kind_get() == TOK_KW_AWAIT:
        parser_advance()
        val future_expr = parse_expr()
        return expr_await(future_expr, 0)

    if par_kind_get() == TOK_KW_YIELD:
        parser_advance()
        val value_expr = parse_expr()
        return expr_yield(value_expr, 0)

    # new expr | new() expr | new(alloc) expr — explicit allocation
    if par_kind_get() == TOK_KW_NEW:
        parser_advance()
        # alloc_kind: 0 = default, 1 = pool, 2 = explicit allocator
        var alloc_kind = 0
        var alloc_expr_id = -1
        # Check for allocator spec: new() or new(allocator)
        if par_kind_get() == TOK_LPAREN:
            parser_advance()
            if par_kind_get() == TOK_RPAREN:
                # new() — type pool
                parser_advance()
                alloc_kind = 1
            else:
                # new(allocator_expr) — explicit allocator
                alloc_expr_id = parse_expr()
                parser_expect(TOK_RPAREN)
                alloc_kind = 2
        val inner = parse_expr()
        return expr_new_alloc(alloc_kind, alloc_expr_id, inner, 0)

    if par_kind_get() == TOK_KW_SPAWN:
        parser_advance()
        val call_expr = parse_expr()
        return expr_spawn(call_expr, 0)

    if par_kind_get() == TOK_KW_DO:
        parser_advance()
        parser_expect(TOK_COLON)
        val do_body = parse_block()
        return expr_do_block(do_body, 0)

    if par_kind_get() == TOK_KW_CE:
        # ce NAME: block as expression -- returns last value like do:
        parser_advance()
        var ce_builder_name = par_text_get()
        parser_expect(TOK_IDENT)
        parser_expect(TOK_COLON)
        val ce_body = parse_block()
        return expr_do_block(ce_body, 0)

    if par_kind_get() == TOK_BACKTICK_IDENT:
        val atom_name = par_text_get()
        parser_advance()
        return expr_atom(atom_name, 0)

    if par_kind_get() == TOK_LPAREN:
        parser_advance()
        if par_kind_get() == TOK_RPAREN:
            parser_advance()
            return expr_unit(0)
        val inner = parse_expr()
        parser_expect(TOK_RPAREN)
        return inner

    if par_kind_get() == TOK_LBRACKET:
        # Array literal or list comprehension
        parser_advance()
        # Empty array
        if par_kind_get() == TOK_RBRACKET:
            parser_advance()
            return expr_array_lit([], 0)
        # For-first comprehension: [for x in items if cond: expr]
        if par_kind_get() == TOK_KW_FOR:
            parser_advance()
            val comp_iter_var = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_KW_IN)
            val comp_iterable = parse_expr()
            var comp_cond = -1
            if par_kind_get() == TOK_KW_IF:
                parser_advance()
                comp_cond = parse_expr()
            parser_expect(TOK_COLON)
            val comp_body = parse_expr()
            parser_expect(TOK_RBRACKET)
            return expr_list_comp(comp_iter_var, comp_iterable, comp_body, comp_cond, 0)
        # Parse first element
        val first_elem = parse_expr()
        # For-last comprehension: [expr for x in items if cond]
        if par_kind_get() == TOK_KW_FOR:
            parser_advance()
            val comp_iter_var = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_KW_IN)
            val comp_iterable = parse_expr()
            var comp_cond = -1
            if par_kind_get() == TOK_KW_IF:
                parser_advance()
                comp_cond = parse_expr()
            parser_expect(TOK_RBRACKET)
            return expr_list_comp(comp_iter_var, comp_iterable, first_elem, comp_cond, 0)
        # Regular array literal: [first, second, ...]
        var elements: [i64] = [first_elem]
        for i in 0..10000:
            if par_kind_get() != TOK_COMMA:
                break
            parser_advance()
            if par_kind_get() == TOK_RBRACKET:
                break
            elements.push(parse_expr())
        parser_expect(TOK_RBRACKET)
        return expr_array_lit(elements, 0)

    if par_kind_get() == TOK_KW_RETURN:
        parser_advance()
        val is_nl = par_kind_get() == TOK_NEWLINE
        val is_ded = par_kind_get() == TOK_DEDENT
        val is_eof = par_kind_get() == TOK_EOF
        val no_value = is_nl or is_ded
        val no_val2 = no_value or is_eof
        if no_val2:
            return expr_return_expr(-1, 0)
        val ret_val = parse_expr()
        return expr_return_expr(ret_val, 0)

    if par_kind_get() == TOK_KW_BREAK:
        parser_advance()
        return expr_break_expr(0)

    if par_kind_get() == TOK_KW_CONTINUE:
        parser_advance()
        return expr_continue_expr(0)

    if par_kind_get() == TOK_KW_PASS:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            return expr_pass(0)
        return expr_pass_with_msg(msg, 0)

    if par_kind_get() == TOK_KW_PASS_TODO:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_todo requires a comment string: pass_todo(\"what remains\", \"hint or issue\")")
        return expr_pass_todo(msg, 0)

    if par_kind_get() == TOK_KW_PASS_DO_NOTHING:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_do_nothing requires a comment string: pass_do_nothing(\"reason\")")
        return expr_pass_do_nothing(msg, 0)

    if par_kind_get() == TOK_KW_PASS_DN:
        parser_advance()
        val msg = parse_optional_rationale_args()
        if msg == "":
            parser_warn("REQC001: pass_dn requires a comment string: pass_dn(\"reason\")")
        return expr_pass_dn(msg, 0)

    if par_kind_get() == TOK_KW_NOT:
        parser_advance()
        val operand = parse_not()
        return expr_unary(TOK_NOT, operand, 0)

    if par_kind_get() == TOK_MINUS:
        parser_advance()
        val operand = parse_unary()
        return expr_unary(TOK_MINUS, operand, 0)

    # Method reference: &:method_name → \__p0: __p0.method_name()
    if par_kind_get() == TOK_AMP_COLON:
        parser_advance()
        if par_kind_get() != TOK_IDENT:
            parser_error("expected method name after '&:'")
            return expr_nil_lit(0)
        val method_name = par_text_get()
        parser_advance()
        var param_names: [i64] = []
        val param = expr_ident("__p0", 0)
        param_names.push(expr_ident("__p0", 0))
        var empty_args: [i64] = []
        val call = expr_method_call(param, method_name, empty_args, 0)
        var body_stmts: [i64] = []
        body_stmts.push(call)
        return expr_lambda(param_names, body_stmts, 0)

    if par_kind_get() == TOK_UNDERSCORE:
        parser_advance()
        return expr_ident("_", 0)

    # Dict literal, dict comprehension, or empty {}
    if par_kind_get() == TOK_LBRACE:
        parser_advance()
        var key_exprs: [i64] = []
        var value_exprs: [i64] = []

        # Check for empty dict {}
        if par_kind_get() == TOK_RBRACE:
            parser_advance()
            return expr_dict_lit(key_exprs, value_exprs, 0)

        # Dict comprehension for-first: {for x in items if cond: (key, val)}
        if par_kind_get() == TOK_KW_FOR:
            parser_advance()
            val dc_iter_var = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_KW_IN)
            val dc_iterable = parse_expr()
            var dc_cond = -1
            if par_kind_get() == TOK_KW_IF:
                parser_advance()
                dc_cond = parse_expr()
            parser_expect(TOK_COLON)
            # Parse (key, value) tuple
            parser_expect(TOK_LPAREN)
            val dc_key = parse_expr()
            parser_expect(TOK_COMMA)
            val dc_val = parse_expr()
            parser_expect(TOK_RPAREN)
            parser_expect(TOK_RBRACE)
            return expr_dict_comp(dc_iter_var, dc_iterable, dc_key, dc_val, dc_cond, 0)

        # Parse first key
        val key = parse_expr()
        parser_expect(TOK_COLON)
        val value = parse_expr()

        # Dict comprehension for-last: {k: v for x in items if cond}
        if par_kind_get() == TOK_KW_FOR:
            parser_advance()
            val dc_iter_var = par_text_get()
            parser_expect(TOK_IDENT)
            parser_expect(TOK_KW_IN)
            val dc_iterable = parse_expr()
            var dc_cond = -1
            if par_kind_get() == TOK_KW_IF:
                parser_advance()
                dc_cond = parse_expr()
            parser_expect(TOK_RBRACE)
            return expr_dict_comp(dc_iter_var, dc_iterable, key, value, dc_cond, 0)

        # Regular dict literal continues
        key_exprs.push(key)
        value_exprs.push(value)

        # Parse remaining key-value pairs
        for i in 0..10000:
            # Check for comma or closing brace
            if par_kind_get() == TOK_COMMA:
                parser_advance()
                # Allow trailing comma before }
                if par_kind_get() == TOK_RBRACE:
                    parser_advance()
                    break
            elif par_kind_get() == TOK_RBRACE:
                parser_advance()
                break
            else:
                parser_error("expected , or } in dict literal")
                break

            # Parse next key-value pair
            val next_key = parse_expr()
            key_exprs.push(next_key)
            parser_expect(TOK_COLON)
            val next_value = parse_expr()
            value_exprs.push(next_value)

        return expr_dict_lit(key_exprs, value_exprs, 0)

    # Lambda: \x: expr or \x, y: expr
    if par_kind_get() == TOK_ERROR:
        if par_text_get() == "unexpected character: \\":
            parser_advance()
            # Skip lambda params
            for i in 0..100:
                if par_kind_get() == TOK_COLON:
                    parser_advance()
                    break
                if par_kind_get() == TOK_EOF:
                    break
                if par_kind_get() == TOK_NEWLINE:
                    break
                parser_advance()
            val lbody = parse_expr()
            return lbody

    # Handle keywords that may appear in expression position
    if par_kind_get() == TOK_KW_MATCH:
        return parse_match_stmt()
    if par_kind_get() == TOK_KW_IF:
        return parse_if_expr()

    parser_error("unexpected token in expression: " + tok_kind_name(par_kind_get()) + " '" + par_text_get() + "'")
    parser_advance()
    expr_nil_lit(0)

# ===== Asm Match/Assert Parsing =====

fn parse_asm_target_spec() -> i64:
    """Parse target spec: [arch | arch2, os, abi, backend >= ver]
    Returns index into asm_arm_* arena (as spec, not full arm).
    """
    parser_expect(TOK_LBRACKET)
    # Parse arch(es) with pipe grouping
    var archs: [text] = []
    if par_kind_get() == TOK_IDENT:
        archs.push(par_text_get())
        parser_advance()
        # Check for pipe groups: arch | arch2
        for pi in 0..20:
            if par_kind_get() == TOK_PIPE:
                parser_advance()
                if par_kind_get() == TOK_IDENT:
                    archs.push(par_text_get())
                    parser_advance()
                else:
                    parser_error("expected architecture name after '|'")
            else:
                break
    else:
        parser_error("expected architecture name in target spec")

    # Parse optional os, abi, backend (comma-separated)
    var os_val = ""
    var abi_val = ""
    var backend_val = ""
    var ver_ops: [text] = []
    var ver_vals: [i64] = []
    var field_pos = 1  # 1=os, 2=abi, 3=backend

    for fi in 0..3:
        if par_kind_get() != TOK_COMMA:
            break
        parser_advance()
        if par_kind_get() == TOK_UNDERSCORE:
            # Wildcard _
            parser_advance()
            field_pos = field_pos + 1
            continue
        if par_kind_get() == TOK_IDENT:
            val field_text = par_text_get()
            parser_advance()
            if field_pos == 1:
                os_val = field_text
            elif field_pos == 2:
                abi_val = field_text
            elif field_pos == 3:
                backend_val = field_text
                # Check for version constraints after backend
                for vi in 0..4:
                    if par_kind_get() == TOK_GEQ:
                        parser_advance()
                        if par_kind_get() == TOK_INT_LIT:
                            ver_ops.push(">=")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '>='")
                    elif par_kind_get() == TOK_EQ:
                        # Could be == (two tokens) or a single ==
                        parser_advance()
                        if par_kind_get() == TOK_EQ:
                            parser_advance()
                        if par_kind_get() == TOK_INT_LIT:
                            ver_ops.push("==")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '=='")
                    elif par_kind_get() == TOK_LT:
                        parser_advance()
                        if par_kind_get() == TOK_INT_LIT:
                            ver_ops.push("<")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '<'")
                    elif par_kind_get() == TOK_IDENT and par_text_get() == "~=":
                        parser_advance()
                        if par_kind_get() == TOK_INT_LIT:
                            ver_ops.push("~=")
                            ver_vals.push(parse_int_text(par_text_get()))
                            parser_advance()
                        else:
                            parser_error("expected version number after '~='")
                    else:
                        break
            field_pos = field_pos + 1
        else:
            parser_error("expected identifier or '_' in target spec")
            break

    parser_expect(TOK_RBRACKET)

    val arm_idx = asm_arm_new(archs, os_val, abi_val, backend_val,
                              ver_ops, ver_vals, "", false, "", false)
    arm_idx

fn parse_int_text(txt: text) -> i64:
    """Parse integer from text (simple decimal)."""
    var result = 0
    for i in 0..txt.len():
        val ch = txt[i]
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.ord() - 48)
    result

fn parse_asm_match() -> i64:
    """Parse asm match: block with case arms.

    Syntax:
        asm match:
            case [spec]: asm_body
            case _: compile_error("msg")
    """
    parser_skip_newlines()
    if par_kind_get() != TOK_INDENT:
        parser_error("expected indented block after 'asm match:'")
        return expr_asm("", 0)
    parser_advance()

    var arm_indices: [i64] = []
    for mi in 0..100:
        parser_skip_newlines()
        if par_kind_get() == TOK_DEDENT:
            parser_advance()
            break
        if par_kind_get() == TOK_EOF:
            break

        # Each arm starts with 'case'
        if par_kind_get() != TOK_KW_CASE:
            parser_error("expected 'case' in asm match arm")
            parser_advance()
            continue

        parser_advance()  # consume 'case'

        # Check for wildcard: case _:
        if par_kind_get() == TOK_UNDERSCORE:
            parser_advance()
            parser_expect(TOK_COLON)

            # Parse body: either compile_error("msg") or asm lines
            parser_skip_newlines()
            if par_kind_get() == TOK_INDENT:
                parser_advance()
                parser_skip_newlines()

            if par_kind_get() == TOK_IDENT and par_text_get() == "compile_error":
                parser_advance()
                parser_expect(TOK_LPAREN)
                var err_msg = ""
                if par_kind_get() == TOK_STRING_LIT:
                    err_msg = par_text_get()
                    parser_advance()
                parser_expect(TOK_RPAREN)
                val arm_idx = asm_arm_new([], "", "", "", [], [], "", true, err_msg, true)
                arm_indices.push(arm_idx)
                # Skip to end of arm
                parser_skip_newlines()
                if par_kind_get() == TOK_DEDENT:
                    parser_advance()
            else:
                # Wildcard with asm body
                var asm_lines: [text] = []
                for ai in 0..10000:
                    parser_skip_newlines()
                    if par_kind_get() == TOK_DEDENT or par_kind_get() == TOK_EOF:
                        break
                    if par_kind_get() == TOK_KW_CASE:
                        break
                    if par_kind_get() == TOK_STRING_LIT:
                        asm_lines.push(par_text_get())
                        parser_advance()
                    else:
                        parser_advance()
                val asm_text = asm_lines.join("\n")
                val arm_idx = asm_arm_new([], "", "", "", [], [], asm_text, false, "", true)
                arm_indices.push(arm_idx)
                if par_kind_get() == TOK_DEDENT:
                    parser_advance()
            continue

        # case [spec]:
        val spec_idx = parse_asm_target_spec()
        parser_expect(TOK_COLON)

        # Parse body: either compile_error("msg") or asm lines
        parser_skip_newlines()
        if par_kind_get() == TOK_INDENT:
            parser_advance()
            parser_skip_newlines()

        if par_kind_get() == TOK_IDENT and par_text_get() == "compile_error":
            parser_advance()
            parser_expect(TOK_LPAREN)
            var err_msg = ""
            if par_kind_get() == TOK_STRING_LIT:
                err_msg = par_text_get()
                parser_advance()
            parser_expect(TOK_RPAREN)
            # Update the arm to be compile_error
            asm_arm_is_compile_error[spec_idx] = true
            asm_arm_error_msg[spec_idx] = err_msg
            arm_indices.push(spec_idx)
            parser_skip_newlines()
            if par_kind_get() == TOK_DEDENT:
                parser_advance()
        else:
            # Collect asm body lines
            var asm_lines: [text] = []
            for ai in 0..10000:
                parser_skip_newlines()
                if par_kind_get() == TOK_DEDENT or par_kind_get() == TOK_EOF:
                    break
                if par_kind_get() == TOK_KW_CASE:
                    break
                if par_kind_get() == TOK_STRING_LIT:
                    asm_lines.push(par_text_get())
                    parser_advance()
                else:
                    parser_advance()
            val asm_text = asm_lines.join("\n")
            asm_arm_asm_text[spec_idx] = asm_text
            arm_indices.push(spec_idx)
            if par_kind_get() == TOK_DEDENT:
                parser_advance()

    return expr_asm_match(arm_indices, 0)

fn parse_asm_assert_expr() -> i64:
    """Parse asm assert [spec] -- compile-time target guard.

    Returns an expression (value is 0/unit in interpreter).
    Uses EXPR_ASM_MATCH with i_val=1 to distinguish from asm match.
    """
    val spec_idx = parse_asm_target_spec()
    return expr_asm_assert(spec_idx, 0)
