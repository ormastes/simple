# Core Simple — Lexer Scanners
#
# All scanning functions: number, string, identifier, whitespace,
# indentation, and the main token scanner dispatcher.
#
# Relies on module-level state defined in lexer.spl:
#   lex_source_slot, lex_pos_slot, lex_line_slot, lex_col_slot, lex_indent_stack_text_slot,
#   lex_pending_dedents_slot, lex_at_line_start_slot, lex_paren_depth_slot,
#   lex_round_paren_depth_slot, lex_cur_kind_slot, lex_cur_text_slot,
#   lex_cur_line_slot, lex_cur_col_slot, lex_cur_suffix_slot

val _NL = "\n"
use compiler.core.tokens.{keyword_lookup}
use compiler.core.lexer_chars.{is_digit, is_hex_digit, is_alpha, is_ident_char, is_space}
use compiler.frontend.core.lexer.{lex_indent_stack_len, lex_indent_stack_top, lex_indent_stack_push, lex_indent_stack_pop}

# ===== Number Scanning =====

fn lex_scan_number():
    val start: i64 = lex_pos_get()
    val start_line: i64 = lex_line_get()
    val start_col: i64 = lex_col_get()
    var is_float: bool = false

    # Check for hex, binary, octal prefix
    val first: text = lex_peek()
    if first == "0":
        val second: text = lex_peek_next()
        if second == "x":
            # Hex literal
            lex_advance()
            lex_advance()
            for i in 0..64:
                val hc: text = lex_peek()
                if hc == "_":
                    lex_advance()
                elif is_hex_digit(hc):
                    lex_advance()
                else:
                    break
            val num_text: text = lex_source_slice(start, lex_pos_get())
            lex_make_token(1, num_text, start_line, start_col)
            return
        if second == "b":
            # Binary literal
            lex_advance()
            lex_advance()
            for i in 0..64:
                val bc: text = lex_peek()
                val is_bin: bool = bc == "0"
                val is_bin1: bool = bc == "1"
                val is_under: bool = bc == "_"
                val is_bin_char: bool = is_bin or is_bin1
                val valid: bool = is_bin_char or is_under
                if valid:
                    lex_advance()
                else:
                    break
            val num_text: text = lex_source_slice(start, lex_pos_get())
            lex_make_token(1, num_text, start_line, start_col)
            return
        if second == "o":
            # Octal literal
            lex_advance()
            lex_advance()
            for i in 0..64:
                val oc: text = lex_peek()
                val is_oct: bool = is_digit(oc)
                val is_under: bool = oc == "_"
                val valid: bool = is_oct or is_under
                if valid:
                    lex_advance()
                else:
                    break
            val num_text: text = lex_source_slice(start, lex_pos_get())
            lex_make_token(1, num_text, start_line, start_col)
            return

    # Decimal number
    for i in 0..100:
        val dc: text = lex_peek()
        val is_d: bool = is_digit(dc)
        val is_u: bool = dc == "_"
        val valid: bool = is_d or is_u
        if valid:
            lex_advance()
        else:
            break

    # Check for float
    val maybe_dot: text = lex_peek()
    val after_dot: text = lex_peek_next()
    val dot_then_digit: bool = maybe_dot == "."
    if dot_then_digit:
        val is_next_dig: bool = is_digit(after_dot)
        if is_next_dig:
            is_float = true
            lex_advance()
            for i in 0..100:
                val fc: text = lex_peek()
                val is_fd: bool = is_digit(fc)
                val is_fu: bool = fc == "_"
                val fvalid: bool = is_fd or is_fu
                if fvalid:
                    lex_advance()
                else:
                    break

    # Check for exponent
    val exp_c: text = lex_peek()
    val is_exp_e: bool = exp_c == "e"
    val is_exp_E: bool = exp_c == "E"
    val has_exp: bool = is_exp_e or is_exp_E
    if has_exp:
        is_float = true
        lex_advance()
        val sign: text = lex_peek()
        val is_plus: bool = sign == "+"
        val is_minus: bool = sign == "-"
        val has_sign: bool = is_plus or is_minus
        if has_sign:
            lex_advance()
        for i in 0..100:
            val ec: text = lex_peek()
            if is_digit(ec):
                lex_advance()
            else:
                break

    val num_text_raw: text = lex_source_slice(start, lex_pos_get())

    # Suffix detection: if number text ends with _ and next char is alpha
    val raw_len: i64 = num_text_raw.len()
    var ends_underscore: bool = false
    if raw_len > 0:
        val last_ch: text = num_text_raw[raw_len - 1:raw_len]
        ends_underscore = last_ch == "_"
    val after_num: text = lex_peek()
    val next_is_alpha: bool = is_alpha(after_num)
    if ends_underscore and next_is_alpha:
        # Suffix detected: strip trailing _, scan suffix identifier
        val num_text: text = num_text_raw[0:raw_len - 1]
        var suffix_start: i64 = lex_pos_get()
        for i in 0..1000:
            val sc: text = lex_peek()
            if is_ident_char(sc):
                lex_advance()
            else:
                break
        val suffix: text = lex_source_slice(suffix_start, lex_pos_get())
        lex_cur_suffix_set(suffix)
        if is_float:
            lex_make_token(8, num_text, start_line, start_col)
        else:
            lex_make_token(7, num_text, start_line, start_col)
        return

    # Normal number token (no suffix)
    lex_cur_suffix_set("")
    if is_float:
        lex_make_token(2, num_text_raw, start_line, start_col)
    else:
        lex_make_token(1, num_text_raw, start_line, start_col)

# ===== String Scanning =====

fn lex_scan_string():
    val start_line: i64 = lex_line_get()
    val start_col: i64 = lex_col_get()
    val quote: text = lex_advance()
    var parts: [text] = []

    # Check for triple-quote string: """ or '''
    val tq1: text = lex_peek()
    val tq2: text = lex_peek_next()
    val is_tq1: bool = tq1 == quote
    val is_tq2: bool = tq2 == quote
    val is_triple: bool = is_tq1 and is_tq2
    if is_triple:
        lex_advance()
        lex_advance()
        # Scan until closing triple-quote — use slice-based accumulation
        var seg_start: i64 = lex_pos_get()
        for i in 0..1000000:
            if lex_at_end():
                if lex_pos_get() > seg_start:
                    parts = parts.push(lex_source_slice(seg_start, lex_pos_get()))
                lex_make_token(3, parts.join(""), start_line, start_col)
                return
            val tc: text = lex_peek()
            val tn1: text = lex_peek_next()
            val tn2: text = lex_peek_at(2)
            val close1: bool = tc == quote
            val close2: bool = tn1 == quote
            val close3: bool = tn2 == quote
            val close12: bool = close1 and close2
            val close_all: bool = close12 and close3
            if close_all:
                if lex_pos_get() > seg_start:
                    parts = parts.push(lex_source_slice(seg_start, lex_pos_get()))
                lex_advance()
                lex_advance()
                lex_advance()
                lex_make_token(3, parts.join(""), start_line, start_col)
                return
            lex_advance()
        if lex_pos_get() > seg_start:
            parts = parts.push(lex_source_slice(seg_start, lex_pos_get()))
        lex_make_token(3, parts.join(""), start_line, start_col)
        return

    var done: bool = false
    # Track start of current non-escape segment for slice-based accumulation
    var seg_start: i64 = lex_pos_get()

    for i in 0..100000:
        if done:
            break
        if lex_at_end():
            lex_make_token(191, "unterminated string", start_line, start_col)
            return
        val c: text = lex_peek()
        if c == _NL:
            lex_make_token(191, "unterminated string", start_line, start_col)
            return
        if c == quote:
            # Flush pending segment
            if lex_pos_get() > seg_start:
                parts = parts.push(lex_source_slice(seg_start, lex_pos_get()))
            lex_advance()
            done = true
        elif c == "\\":
            # Flush pending segment before escape
            if lex_pos_get() > seg_start:
                parts = parts.push(lex_source_slice(seg_start, lex_pos_get()))
            lex_advance()
            val esc: text = lex_advance()
            if esc == "n":
                parts = parts.push("\n")
            elif esc == "t":
                parts = parts.push("\t")
            elif esc == "r":
                parts = parts.push("\r")
            elif esc == "\\":
                parts = parts.push("\\")
            elif esc == "\"":
                parts = parts.push("\"")
            elif esc == "'":
                parts = parts.push("'")
            elif esc == "0":
                parts = parts.push("\0")
            else:
                parts = parts.push("\\")
                parts = parts.push(esc)
            seg_start = lex_pos_get()
        else:
            lex_advance()

    lex_make_token(3, parts.join(""), start_line, start_col)

# ===== Identifier/Keyword Scanning =====

fn lex_scan_ident():
    val start: i64 = lex_pos_get()
    val start_line: i64 = lex_line_get()
    val start_col: i64 = lex_col_get()

    for i in 0..1000:
        val c: text = lex_peek()
        if is_ident_char(c):
            lex_advance()
        else:
            break

    val ident_text: text = lex_source_slice(start, lex_pos_get())

    # Check for keyword
    val kw_kind: i64 = keyword_lookup(ident_text)
    if kw_kind != 6:
        # Special: true/false → bool literal, nil → nil literal
        if kw_kind == 58:
            lex_make_token(4, "true", start_line, start_col)
        elif kw_kind == 59:
            lex_make_token(4, "false", start_line, start_col)
        elif kw_kind == 5:
            lex_make_token(5, "nil", start_line, start_col)
        else:
            lex_make_token(kw_kind, ident_text, start_line, start_col)
    else:
        # Check for underscore-only as special token
        if ident_text == "_":
            lex_make_token(169, "_", start_line, start_col)
        else:
            lex_make_token(6, ident_text, start_line, start_col)

# ===== Skip Whitespace (not newlines) =====

fn lex_skip_spaces():
    for i in 0..100000:
        val c: text = lex_peek()
        if c == " ":
            lex_advance()
        elif c == "\t":
            lex_advance()
        else:
            break

# ===== Indentation Handling =====

fn lex_handle_indentation():
    # Count leading whitespace
    var indent_level: i64 = 0
    for i in 0..10000:
        val c: text = lex_peek()
        if c == " ":
            indent_level = indent_level + 1
            lex_advance()
        elif c == "\t":
            indent_level = indent_level + 4
            lex_advance()
        else:
            break

    # Skip blank lines and comment-only lines
    val next_c: text = lex_peek()
    val is_blank: bool = next_c == _NL
    val is_end: bool = next_c == ""
    val is_comment: bool = next_c == "#"
    if is_blank:
        lex_advance()
        lex_at_line_start_set(true)
        return
    if is_end:
        return
    if is_comment:
        # Skip comment, then the newline
        for i in 0..100000:
            val cc: text = lex_peek()
            val is_nl: bool = cc == _NL
            val is_eof: bool = cc == ""
            val done: bool = is_nl or is_eof
            if done:
                break
            lex_advance()
        if lex_peek() == _NL:
            lex_advance()
        lex_at_line_start_set(true)
        return

    lex_at_line_start_set(false)

    # Compare with current indent level
    val stack_len: i64 = lex_indent_stack_len()
    val current_indent: i64 = lex_indent_stack_top()

    if indent_level > current_indent:
        lex_indent_stack_push(indent_level)
        lex_make_token(181, "", lex_line_get(), 1)
    elif indent_level < current_indent:
        # Pop indent stack and count dedents
        var dedent_count: i64 = 0
        for i in 0..100:
            val slen: i64 = lex_indent_stack_len()
            if slen <= 1:
                break
            val top: i64 = lex_indent_stack_top()
            if top <= indent_level:
                break
            lex_indent_stack_pop()
            dedent_count = dedent_count + 1

        # First dedent is returned immediately, rest are pending
        if dedent_count > 0:
            lex_pending_dedents_set(dedent_count - 1)
            lex_make_token(182, "", lex_line_get(), 1)
        else:
            # Indent level doesn't match any in stack — error
            lex_make_token(191, "inconsistent indentation", lex_line_get(), 1)

# ===== Main Token Scanner =====

fn lex_scan_token():
    # Check EOF first (before indentation or anything else)
    if lex_at_end():
        val slen: i64 = lex_indent_stack_len()
        if slen > 1:
            lex_indent_stack_pop()
            lex_pending_dedents_set(slen - 2)
            lex_make_token(182, "", lex_line_get(), lex_col_get())
            return
        lex_make_token(190, "", lex_line_get(), lex_col_get())
        return

    # Handle indentation at line start BEFORE skipping spaces
    # (handle_indentation counts and consumes leading spaces itself)
    if lex_at_line_start_get():
        if lex_round_paren_depth_get() > 0:
            # Inside round parens: suppress indentation tokens
            lex_at_line_start_set(false)
            lex_skip_spaces()
            lex_scan_token()
            return
        lex_cur_kind_set(0)
        lex_handle_indentation()
        if lex_cur_kind_get_slot() != 0:
            return
        # Same indent or blank/comment line consumed
        lex_scan_token()
        return

    # Skip spaces (not newlines) — only for mid-line tokens
    lex_skip_spaces()

    if lex_at_end():
        # Emit pending dedents for remaining indentation
        val slen: i64 = lex_indent_stack_len()
        if slen > 1:
            lex_indent_stack_pop()
            lex_pending_dedents_set(slen - 2)
            lex_make_token(182, "", lex_line_get(), lex_col_get())
            return
        lex_make_token(190, "", lex_line_get(), lex_col_get())
        return

    val start_line: i64 = lex_line_get()
    val start_col: i64 = lex_col_get()
    val c: text = lex_peek()

    # Newline
    if c == _NL:
        lex_advance()
        lex_at_line_start_set(true)
        if lex_round_paren_depth_get() > 0:
            # Inside round parens: suppress newline, scan next token
            lex_scan_token()
            return
        lex_make_token(180, _NL, start_line, start_col)
        return

    # Comment
    if c == "#":
        # Skip comment to end of line
        for i in 0..100000:
            val cc: text = lex_peek()
            val is_nl: bool = cc == _NL
            val is_eof: bool = cc == ""
            val done: bool = is_nl or is_eof
            if done:
                break
            lex_advance()
        # Recurse to get next real token
        lex_scan_token()
        return

    # String literal
    val is_dquote: bool = c == "\""
    val is_squote: bool = c == "'"
    if is_dquote:
        lex_scan_string()
        return
    if is_squote:
        # Check if this is a label token: 'identifier
        val after_quote: text = lex_peek_next()
        val is_label_alpha: bool = is_alpha(after_quote)
        val is_label_under: bool = after_quote == "_"
        val is_label: bool = is_label_alpha or is_label_under
        if is_label:
            # Label token: 'name
            lex_advance()  # consume '
            val label_start: i64 = lex_pos_get()
            for li in 0..1000:
                val lc: text = lex_peek()
                if is_ident_char(lc):
                    lex_advance()
                else:
                    break
            val label_name: text = lex_source_slice(label_start, lex_pos_get())
            lex_make_token(192, label_name, start_line, start_col)
            return
        lex_scan_string()
        return

    # Number literal
    if is_digit(c):
        lex_scan_number()
        return

    # Identifier or keyword
    val is_al: bool = is_alpha(c)
    val is_un: bool = c == "_"
    val starts_ident: bool = is_al or is_un
    if starts_ident:
        lex_scan_ident()
        return

    # Operators and delimiters (single char consumed via advance)
    lex_advance()

    # Two+ character operators
    if c == "=":
        if lex_match_char("="):
            lex_make_token(80, "==", start_line, start_col)
        elif lex_match_char(">"):
            lex_make_token(168, "=>", start_line, start_col)
        else:
            lex_make_token(100, "=", start_line, start_col)
        return

    if c == "!":
        if lex_match_char("="):
            lex_make_token(81, "!=", start_line, start_col)
        else:
            lex_make_token(57, "!", start_line, start_col)
        return

    if c == "<":
        if lex_match_char("<"):
            lex_make_token(66, "<<", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(84, "<=", start_line, start_col)
        else:
            lex_make_token(82, "<", start_line, start_col)
        return

    if c == ">":
        if lex_match_char(">"):
            lex_make_token(67, ">>", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(85, ">=", start_line, start_col)
        else:
            lex_make_token(83, ">", start_line, start_col)
        return

    if c == "+":
        if lex_match_char("="):
            lex_make_token(101, "+=", start_line, start_col)
        else:
            lex_make_token(60, "+", start_line, start_col)
        return

    if c == "-":
        if lex_match_char(">"):
            lex_make_token(167, "->", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(102, "-=", start_line, start_col)
        else:
            lex_make_token(61, "-", start_line, start_col)
        return

    if c == "*":
        if lex_match_char("*"):
            lex_make_token(65, "**", start_line, start_col)
        elif lex_match_char("="):
            lex_make_token(103, "*=", start_line, start_col)
        else:
            lex_make_token(62, "*", start_line, start_col)
        return

    if c == "/":
        if lex_match_char("="):
            lex_make_token(104, "/=", start_line, start_col)
        else:
            lex_make_token(63, "/", start_line, start_col)
        return

    if c == "%":
        lex_make_token(64, "%", start_line, start_col)
        return

    if c == ".":
        val d1: text = lex_peek()
        if is_digit(d1):
            # .5 style float literal — synthesize "0." prefix and scan remainder
            var fstart: i64 = lex_pos_get() - 1
            for fi in 0..100:
                val fc: text = lex_peek()
                val is_fd: bool = is_digit(fc)
                val is_fu: bool = fc == "_"
                val fvalid: bool = is_fd or is_fu
                if fvalid:
                    lex_advance()
                else:
                    break
            # Check for exponent
            val fexp: text = lex_peek()
            val is_fe: bool = fexp == "e"
            val is_fE: bool = fexp == "E"
            if is_fe or is_fE:
                lex_advance()
                val fsign: text = lex_peek()
                if fsign == "+" or fsign == "-":
                    lex_advance()
                for fei in 0..100:
                    val fec: text = lex_peek()
                    if is_digit(fec):
                        lex_advance()
                    else:
                        break
            val fnum_text: text = "0" + lex_source_slice(fstart, lex_pos_get())
            lex_cur_suffix_set("")
            lex_make_token(2, fnum_text, start_line, start_col)
            return
        if d1 == ".":
            lex_advance()
            val d2: text = lex_peek()
            if d2 == ".":
                lex_advance()
                lex_make_token(173, "...", start_line, start_col)
            elif d2 == "=":
                lex_advance()
                lex_make_token(166, "..=", start_line, start_col)
            else:
                lex_make_token(165, "..", start_line, start_col)
        elif d1 == "?":
            lex_advance()
            lex_make_token(133, ".?", start_line, start_col)
        else:
            lex_make_token(164, ".", start_line, start_col)
        return

    if c == "?":
        val q1: text = lex_peek()
        if q1 == "?":
            lex_advance()
            lex_make_token(132, "??", start_line, start_col)
        elif q1 == ".":
            lex_advance()
            lex_make_token(131, "?.", start_line, start_col)
        else:
            lex_make_token(130, "?", start_line, start_col)
        return

    if c == "|":
        if lex_match_char(">"):
            lex_make_token(175, "|>", start_line, start_col)
        else:
            lex_make_token(121, "|", start_line, start_col)
        return

    if c == "@":
        lex_make_token(171, "@", start_line, start_col)
        return

    # Backtick atom token: `identifier
    if c == "`":
        val atom_start: i64 = lex_pos_get()
        for ai in 0..1000:
            val ac: text = lex_peek()
            if is_ident_char(ac):
                lex_advance()
            elif ac == "`":
                lex_advance()
                break
            else:
                break
        val atom_text: text = lex_source_slice(atom_start, lex_pos_get())
        lex_make_token(193, atom_text, start_line, start_col)
        return

    if c == "&":
        if lex_match_char(":"):
            lex_make_token(210, "&:", start_line, start_col)
        else:
            lex_make_token(120, "&", start_line, start_col)
        return

    if c == ";":
        lex_make_token(163, ";", start_line, start_col)
        return

    # Delimiters (track paren depth)
    if c == "(":
        lex_paren_depth_set(lex_paren_depth_get() + 1)
        lex_round_paren_depth_set(lex_round_paren_depth_get() + 1)
        lex_make_token(140, "(", start_line, start_col)
        return

    if c == ")":
        if lex_paren_depth_get() > 0:
            lex_paren_depth_set(lex_paren_depth_get() - 1)
        if lex_round_paren_depth_get() > 0:
            lex_round_paren_depth_set(lex_round_paren_depth_get() - 1)
        lex_make_token(141, ")", start_line, start_col)
        return

    if c == "[":
        lex_paren_depth_set(lex_paren_depth_get() + 1)
        lex_make_token(144, "[", start_line, start_col)
        return

    if c == "]":
        if lex_paren_depth_get() > 0:
            lex_paren_depth_set(lex_paren_depth_get() - 1)
        lex_make_token(145, "]", start_line, start_col)
        return

    if c == "{":
        lex_paren_depth_set(lex_paren_depth_get() + 1)
        lex_make_token(142, "{", start_line, start_col)
        return

    if c == "}":
        if lex_paren_depth_get() > 0:
            lex_paren_depth_set(lex_paren_depth_get() - 1)
        lex_make_token(143, "}", start_line, start_col)
        return

    if c == ":":
        if lex_match_char("="):
            lex_make_token(106, ":=", start_line, start_col)
        else:
            lex_make_token(161, ":", start_line, start_col)
        return

    if c == ",":
        lex_make_token(160, ",", start_line, start_col)
        return

    # Unknown character
    lex_make_token(191, "unexpected character: " + c, start_line, start_col)

