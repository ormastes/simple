# Dangerous Keywords Registry
#
# Extensible list of identifier names that require a comment string argument
# when used in statement position. Omitting the comment emits a REQC002 warning.
#
# Add new dangerous identifiers via register_dangerous_keyword().

# ============================================================================
# Registry
# ============================================================================

var DANGEROUS_KEYWORDS: [text] = [
    "dangerous_token_but_needs",
    "loss",
    "unsafe_cast",
    "raw_pointer",
    "unchecked"
]

fn is_dangerous_keyword(name: text) -> bool:
    if DANGEROUS_KEYWORDS == nil:
        return false
    for kw in DANGEROUS_KEYWORDS:
        if kw == name:
            return true
    false

fn register_dangerous_keyword(name: text):
    if DANGEROUS_KEYWORDS == nil:
        DANGEROUS_KEYWORDS = []
    for kw in DANGEROUS_KEYWORDS:
        if kw == name:
            return
    DANGEROUS_KEYWORDS.push(name)

# ============================================================================
# Argument Parsing
# ============================================================================

class DangerousKeywordArgs:
    comment: text
    symbols: [text]

fn parse_dangerous_keyword_args(name: text) -> DangerousKeywordArgs:
    # Default: no comment, no symbols
    # Actual parsing is done in parser_stmts.spl; this returns a default struct.
    DangerousKeywordArgs(comment: "", symbols: [])
