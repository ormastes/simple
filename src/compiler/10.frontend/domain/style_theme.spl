class StyleProperty:
    name (text)
    value (text)
    unit (text)
    inherited (bool)

    me is_color():
        return unit == "color"

    me is_dimension():
        return unit == "px" or unit == "em" or unit == "rem" or unit == "pct"

    me display():
        return name + ": " + value + unit

    static fn color(name: text, value: text) -> StyleProperty:
        return StyleProperty(name: name, value: value, unit: "color", inherited: true)

    static fn dimension(name: text, value: text, unit: text) -> StyleProperty:
        return StyleProperty(name: name, value: value, unit: unit, inherited: false)


class StyleRule:
    selector (text)
    prop_count (i32)
    p0_name (text)
    p0_value (text)
    p1_name (text)
    p1_value (text)
    p2_name (text)
    p2_value (text)
    p3_name (text)
    p3_value (text)

    me has_property(pname: text):
        if prop_count > 0 and p0_name == pname:
            return true
        if prop_count > 1 and p1_name == pname:
            return true
        if prop_count > 2 and p2_name == pname:
            return true
        if prop_count > 3 and p3_name == pname:
            return true
        return false

    me is_empty():
        return prop_count == 0

    static fn for_selector(sel: text) -> StyleRule:
        return StyleRule(selector: sel, prop_count: 0, p0_name: "", p0_value: "", p1_name: "", p1_value: "", p2_name: "", p2_value: "", p3_name: "", p3_value: "")


class ThemeSubset:
    theme_name (text)
    bg_color (text)
    fg_color (text)
    accent_color (text)
    font_family (text)
    font_size (i32)
    border_radius (i32)

    me is_dark():
        if bg_color.len() < 2:
            return false
        val second = bg_color.char_at(1)
        return second == "0" or second == "1" or second == "2" or second == "3"

    me has_custom_font():
        return font_family != "default" and font_family != ""

    static fn default_theme() -> ThemeSubset:
        return ThemeSubset(theme_name: "default", bg_color: "#ffffff", fg_color: "#000000", accent_color: "#0066cc", font_family: "default", font_size: 14, border_radius: 4)

    static fn dark_theme() -> ThemeSubset:
        return ThemeSubset(theme_name: "dark", bg_color: "#1a1a1a", fg_color: "#e0e0e0", accent_color: "#4da6ff", font_family: "default", font_size: 14, border_radius: 4)


class LayoutConstraint:
    constraint_type (text)
    columns (i32)
    gap (i32)
    max_width (i32)
    padding (i32)
    direction (text)

    me is_grid():
        return constraint_type == "grid"

    me is_flex():
        return constraint_type == "flex"

    me is_horizontal():
        return direction == "row"

    static fn grid(cols: i32, gap: i32) -> LayoutConstraint:
        return LayoutConstraint(constraint_type: "grid", columns: cols, gap: gap, max_width: 1200, padding: 16, direction: "row")

    static fn flex(dir: text) -> LayoutConstraint:
        return LayoutConstraint(constraint_type: "flex", columns: 1, gap: 8, max_width: 0, padding: 0, direction: dir)


fn main():
    print("style_theme loaded")
