class DomainOutlineEntry:
  kind: text
  start_line: i32
  end_line: i32
  payload_preview: text
  module_name: text

  me display_name():
    return self.kind + " (" + self.module_name + ")"

  me span_length():
    return self.end_line - self.start_line + 1

  static fn from_block(kind: text, start: i32, end_val: i32, payload: text, mod_name: text) -> DomainOutlineEntry:
    var preview = payload
    if payload.length() > 40:
      preview = payload.substring(0, 40)
    return DomainOutlineEntry(kind: kind, start_line: start, end_line: end_val, payload_preview: preview, module_name: mod_name)


class DomainOutlineList:
  count: i32
  e0_kind: text
  e0_line: i32
  e1_kind: text
  e1_line: i32
  e2_kind: text
  e2_line: i32
  e3_kind: text
  e3_line: i32

  me has_kind(k: text):
    if self.count > 0:
      if self.e0_kind == k:
        return true
    if self.count > 1:
      if self.e1_kind == k:
        return true
    if self.count > 2:
      if self.e2_kind == k:
        return true
    if self.count > 3:
      if self.e3_kind == k:
        return true
    return false

  static fn empty() -> DomainOutlineList:
    return DomainOutlineList(count: 0, e0_kind: "", e0_line: 0, e1_kind: "", e1_line: 0, e2_kind: "", e2_line: 0, e3_kind: "", e3_line: 0)


class DomainSymbolProvider:
  kind: text
  symbol_kind: text
  icon_hint: text
  detail: text

  static fn for_kind(kind: text) -> DomainSymbolProvider:
    if kind == "schema":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Struct", icon_hint: "schema-icon", detail: "Contract definition")
    if kind == "style":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Property", icon_hint: "style-icon", detail: "Theme/layout rules")
    if kind == "music":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Event", icon_hint: "music-icon", detail: "Music notation")
    if kind == "bim":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Module", icon_hint: "model-icon", detail: "3D model definition")
    if kind == "cad":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Module", icon_hint: "model-icon", detail: "3D model definition")
    if kind == "city":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Module", icon_hint: "model-icon", detail: "3D model definition")
    if kind == "rtl":
      return DomainSymbolProvider(kind: kind, symbol_kind: "Interface", icon_hint: "circuit-icon", detail: "Hardware description")
    return DomainSymbolProvider(kind: kind, symbol_kind: "Namespace", icon_hint: "block-icon", detail: "Domain block")

  me is_model_kind():
    if self.kind == "bim":
      return true
    if self.kind == "cad":
      return true
    if self.kind == "city":
      return true
    return false


class DomainSymbolReport:
  module_name: text
  total_blocks: i32
  schema_count: i32
  style_count: i32
  model_count: i32
  other_count: i32

  me has_schemas():
    return self.schema_count > 0

  me has_styles():
    return self.style_count > 0

  static fn from_counts(mod_name: text, total: i32, schemas: i32, styles: i32, models: i32, others: i32) -> DomainSymbolReport:
    return DomainSymbolReport(module_name: mod_name, total_blocks: total, schema_count: schemas, style_count: styles, model_count: models, other_count: others)


fn main():
  print("domain_outline loaded")
