# TreeSitter Outline - Top-Level Parsing Coordinator
#
# Provides the main entry points for outline parsing:
# - Attribute parsing
# - Top-level item dispatch (parse_top_level_item)
# - Import/export parsing
# - Identifier/module path parsing
# - Block outline parsing and skip policy
# - TopLevelItem enum definition
#
# Delegates to submodules:
# - outline_lexer.spl  — TreeSitter struct, token handling
# - outline_types.spl  — type expression parsing
# - outline_decls.spl  — function/class/struct/enum/trait/impl parsers
#
# Outline type definitions are in treesitter_types.spl

use compiler.frontend.core.lexer.*
use compiler.frontend.treesitter_types.*
use compiler.common.dependency.visibility.{Visibility}
use compiler.frontend.block_types.{PreLexInfo, BlockSkipPolicy, BlockOutlineInfo}
use compiler.frontend.treesitter.outline_lexer.{TreeSitter}
use compiler.frontend.treesitter.outline_types.*
use compiler.frontend.treesitter.outline_decls.*
use compiler.frontend.treesitter.outline_members.*

# Enum constructor helpers (legacy lowering expects free functions)
fn toplevelitem_Import(item: ImportOutline) -> TopLevelItem: TopLevelItem.Import(item)
fn toplevelitem_Export(item: ExportOutline) -> TopLevelItem: TopLevelItem.Export(item)
fn toplevelitem_Function(item: FunctionOutline) -> TopLevelItem: TopLevelItem.Function(item)
fn toplevelitem_StaticAssert(item: StaticAssertOutline) -> TopLevelItem: TopLevelItem.StaticAssert(item)
fn toplevelitem_FriendDecl(item: FriendDeclOutline) -> TopLevelItem: TopLevelItem.FriendDecl(item)
fn toplevelitem_InternalExportDecl(item: InternalExportOutline) -> TopLevelItem: TopLevelItem.InternalExportDecl(item)
fn toplevelitem_Class(item: ClassOutline) -> TopLevelItem: TopLevelItem.Class(item)
fn toplevelitem_ActorItem(item: ActorOutline) -> TopLevelItem: TopLevelItem.ActorItem(item)
fn toplevelitem_Struct(item: StructOutline) -> TopLevelItem: TopLevelItem.Struct(item)
fn toplevelitem_Enum(item: EnumOutline) -> TopLevelItem: TopLevelItem.Enum(item)
fn toplevelitem_Bitfield(item: BitfieldOutline) -> TopLevelItem: TopLevelItem.Bitfield(item)
fn toplevelitem_Trait(item: TraitOutline) -> TopLevelItem: TopLevelItem.Trait(item)
fn toplevelitem_Impl(item: ImplOutline) -> TopLevelItem: TopLevelItem.Impl(item)
fn toplevelitem_TypeAlias(item: TypeAliasOutline) -> TopLevelItem: TopLevelItem.TypeAlias(item)
fn toplevelitem_Const(item: ConstOutline) -> TopLevelItem: TopLevelItem.Const(item)

fn items_push(items: [TopLevelItem], item: TopLevelItem) -> [TopLevelItem]:
        items.push(item)

fn attributes_push(attrs: [AttributeOutline], item: AttributeOutline) -> [AttributeOutline]:
        attrs.push(item)

fn import_items_push(items: [text], item: text) -> [text]:
        items.push(item)

fn asm_blocks_push(blocks: [AsmBlockOutline], item: AsmBlockOutline) -> [AsmBlockOutline]:
        blocks.push(item)

fn inline_blocks_push(blocks: [BlockOutline], item: BlockOutline) -> [BlockOutline]:
        blocks.push(item)

fn parse_errors_push(items: [ParseError], item: ParseError) -> [ParseError]:
        items.push(item)

fn h_skip_policy(h: Any) -> BlockSkipPolicy:
        BlockSkipPolicy.OutlineRequired

fn h_treesitter_outline(h: Any, payload: text, pre_lex: PreLexInfo) -> BlockOutlineInfo:
        blockoutlineinfo_opaque("")

# ============================================================================
# Attribute Parsing
# ============================================================================

me treesitter_parse_attributes(self: TreeSitter) -> [AttributeOutline]:
        var attrs: [AttributeOutline] = []
        while self.check(TokenKind.At):
            attrs = attributes_push(attrs, self.parse_attribute())
            self.skip_newlines()
        attrs


me treesitter_parse_attribute(self: TreeSitter) -> AttributeOutline:
        """Parse a single attribute: @name or @name(args)."""
        val start = self.current.span

        self.advance()  # Consume '@'

        val name = self.parse_identifier()
        var args_span: Span = nil

        # Check for arguments: @name(arg1, arg2, ...)
        if self.match_token(TokenKind.LParen):
            val args_start = self.previous.span.end_pos
            # Skip to matching right paren (handles nested parens)
            var depth = 1
            while depth > 0 and not self.is_at_end():
                match self.peek():
                    case LParen:
                        depth = depth + 1
                        self.advance()
                    case RParen:
                        depth = depth - 1
                        if depth > 0:
                            self.advance()
                    case _:
                        self.advance()
            val args_end = self.current.span.start
            args_span = span_new(args_start, args_end, 0, 0)
            self.expect(TokenKind.RParen, "expected ')' after attribute arguments")

        AttributeOutline(
            name: name,
            args_span: args_span,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_import_items(self: TreeSitter) -> [text]:
        var items: [text] = []
        items = import_items_push(items, self.parse_identifier())
        while self.match_token(TokenKind.Comma):
            if self.check(TokenKind.RBrace):
                break
            items = import_items_push(items, self.parse_identifier())
        items


# ============================================================================
# Top-Level Item Dispatch
# ============================================================================

me treesitter_parse_top_level_item(self: TreeSitter) -> TopLevelItem:
        """Parse a top-level item."""
        # Parse attributes before the declaration (@repr, @packed, @align, etc.)
        val attrs = self.parse_attributes()

        val doc = self.take_doc_comment()
        val visibility = self.parse_visibility()

        # Check for `friend <package>` declaration (top-level in __init__.spl)
        if self.check(TokenKind.Ident) and self.current.text == "friend":
            val friend_start = self.current.span
            self.advance()  # consume "friend"
            val pkg_name = self.parse_identifier()
            return toplevelitem_FriendDecl(FriendDeclOutline(
                package_name: pkg_name,
                span: merge_spans(friend_start, self.previous.span)
            ))

        # Check for `internal_export` declaration (top-level in __init__.spl)
        if self.check(TokenKind.Ident) and self.current.text == "internal_export":
            val ie_start = self.current.span
            self.advance()  # consume "internal_export"
            var ie_items: [text] = []
            ie_items.push(self.parse_identifier())
            while self.match_token(TokenKind.Comma):
                ie_items.push(self.parse_identifier())
            return toplevelitem_InternalExportDecl(InternalExportOutline(
                items: ie_items,
                span: merge_spans(ie_start, self.previous.span)
            ))

        val peeked = self.peek()
        match peeked:
            case KwImport:
                toplevelitem_Import(self.parse_import())
            case KwExport:
                toplevelitem_Export(self.parse_export())
            case KwFn:
                val f = self.parse_function_outline(visibility, false, doc)
                # Check for @gpu or @gpu_kernel attribute
                var has_gpu_attr = false
                for attr in attrs:
                    if attr.name == "gpu" or attr.name == "gpu_kernel":
                        has_gpu_attr = true
                toplevelitem_Function(if has_gpu_attr: functionoutline_as_kernel(f) else: f)
            case KwMe:
                val f = self.parse_function_outline(visibility, true, doc)
                # Check for @gpu or @gpu_kernel attribute
                var has_gpu_attr = false
                for attr in attrs:
                    if attr.name == "gpu" or attr.name == "gpu_kernel":
                        has_gpu_attr = true
                toplevelitem_Function(if has_gpu_attr: functionoutline_as_kernel(f) else: f)
            case KwStatic:
                self.advance()
                if self.check(TokenKind.KwFn):
                    val f = self.parse_function_outline(visibility, false, doc)
                    toplevelitem_Function(functionoutline_as_static(f))
                elif self.check(TokenKind.Ident):
                    if self.current.text == "assert":
                        toplevelitem_StaticAssert(self.parse_static_assert_outline())
                else:
                    self.error("expected 'fn' or 'assert' after 'static'")
                    self.synchronize()
                    TopLevelItem.Error(ParseError(
                        message: "expected 'fn' or 'assert' after 'static'",
                        span: self.current.span,
                        severity: ErrorSeverity.Error
                    ))
            case KwAsync:
                self.advance()
                if self.check(TokenKind.KwFn):
                    val f = self.parse_function_outline(visibility, false, doc)
                    toplevelitem_Function(functionoutline_as_async(f))
                else:
                    self.error("expected 'fn' after 'async'")
                    self.synchronize()
                    TopLevelItem.Error(ParseError(
                        message: "expected 'fn' after 'async'",
                        span: self.current.span,
                        severity: ErrorSeverity.Error
                    ))
            case KwClass:
                toplevelitem_Class(self.parse_class_outline(visibility, doc, attrs))
            case KwActor:
                toplevelitem_ActorItem(self.parse_actor_outline(visibility, doc, attrs))
            case KwStruct:
                toplevelitem_Struct(self.parse_struct_outline(visibility, doc, attrs))
            case KwEnum:
                toplevelitem_Enum(self.parse_enum_outline(visibility, doc))
            case KwBitfield:
                toplevelitem_Bitfield(self.parse_bitfield_outline(visibility, doc, attrs))
            case KwTrait:
                toplevelitem_Trait(self.parse_trait_outline(visibility, doc))
            case KwImpl:
                toplevelitem_Impl(self.parse_impl_outline())
            case KwType:
                toplevelitem_TypeAlias(self.parse_type_alias_outline(visibility))
            case KwVal:
                toplevelitem_Const(self.parse_const_outline(visibility, attrs))
            case KwVar:
                toplevelitem_Const(self.parse_const_outline(visibility, attrs))
            case KwExtern:
                self.advance()
                if self.check(TokenKind.KwFn):
                    val f = self.parse_extern_function_outline(visibility, doc)
                    toplevelitem_Function(f)
                else:
                    self.error("expected 'fn' after 'extern'")
                    self.synchronize()
                    TopLevelItem.Error(ParseError(
                        message: "expected 'fn' after 'extern'",
                        span: self.current.span,
                        severity: ErrorSeverity.Error
                    ))
            case KwConst:
                self.advance()
                if self.check(TokenKind.KwFn):
                    val f = self.parse_function_outline(visibility, false, doc)
                    toplevelitem_Function(functionoutline_as_const(f))
                else:
                    self.error("expected 'fn' after 'const'")
                    self.synchronize()
                    TopLevelItem.Error(ParseError(
                        message: "expected 'fn' after 'const'",
                        span: self.current.span,
                        severity: ErrorSeverity.Error
                    ))
            case KwKernel:
                self.advance()
                if self.check(TokenKind.KwFn):
                    val f = self.parse_function_outline(visibility, false, doc)
                    toplevelitem_Function(functionoutline_as_kernel(f))
                else:
                    self.error("expected 'fn' after 'kernel'")
                    self.synchronize()
                    TopLevelItem.Error(ParseError(
                        message: "expected 'fn' after 'kernel'",
                        span: self.current.span,
                        severity: ErrorSeverity.Error
                    ))
            case _:
                self.error("expected top-level declaration")
                self.synchronize()
                TopLevelItem.Error(ParseError(
                    message: "unexpected token at top level",
                    span: self.current.span,
                    severity: ErrorSeverity.Error
                ))


# ============================================================================
# Import / Export Parsing
# ============================================================================

me treesitter_parse_import(self: TreeSitter) -> ImportOutline:
        """Parse import declaration."""
        val start = self.current.span
        self.advance()  # Consume 'import'

        # Check for 'use lazy' / 'import lazy' modifier
        var is_lazy = false
        if self.check(TokenKind.Ident):
            if self.current.text == "lazy":
                is_lazy = true
                self.advance()

        val module = self.parse_module_path()
        var items: [text] = []
        var alias: text = nil

        # import foo.bar.baz
        # import foo.bar.{a, b, c}
        # import foo.bar as fb

        if self.match_token(TokenKind.Dot):
            if self.match_token(TokenKind.LBrace):
                items = self.parse_import_items()
                self.expect(TokenKind.RBrace, "expected '}' after import items")
            elif self.match_token(TokenKind.Star):
                val star: text = "*"
                items = [star]
            else:
                # Continue module path
                val id: text = self.parse_identifier()
                items = [id]

        if self.match_token(TokenKind.KwAs):
            alias = self.parse_identifier()

        self.skip_newlines()

        ImportOutline(
            module: module,
            items: items,
            is_lazy: is_lazy,
            alias: alias,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_export(self: TreeSitter) -> ExportOutline:
        """Parse export declaration."""
        val start = self.current.span
        self.advance()  # Consume 'export'

        var items: [text] = []

        items = items_push(items, self.parse_identifier())
        while self.match_token(TokenKind.Comma):
            items = items_push(items, self.parse_identifier())

        self.skip_newlines()

        ExportOutline(
            items: items,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_module_path(self: TreeSitter) -> text:
        """Parse a.b.c module path."""
        var path = self.parse_identifier()

        while self.match_token(TokenKind.Dot):
            if self.check(TokenKind.LBrace) or self.check(TokenKind.Star):
                break
            path = path + "." + self.parse_identifier()

        path


me treesitter_parse_identifier(self: TreeSitter) -> text:
        """Parse an identifier."""
        if self.check(TokenKind.Ident):
            val name = self.current.text
            self.advance()
            name
        else:
            self.error("expected identifier")
            "<error>"


# ============================================================================
# Block Outline Parsing
# ============================================================================

me treesitter_parse_block_outline(self: TreeSitter) -> BlockOutline:
        """Capture block outline without parsing payload.

        Called when a BlockStart token is encountered.
        Captures the raw payload text for later resolution.
        """
        val start = self.current.span
        val kind = self.current.text
        self.advance()  # Consume BlockStart

        # Expect opening brace
        if not self.match_token(TokenKind.LBrace):
            self.error("expected '{' after block keyword '{kind}'")
            return BlockOutline(
                kind: kind,
                payload: "",
                payload_span: start,
                span: start,
                parent_context: self.current_context,
                pre_lex_info: nil,
                outline_info: nil
            )

        # Record payload start
        val payload_start = self.current.span.start
        val payload_line = self.current.span.line
        val payload_col = self.current.span.col

        # Check for BlockPayload token (raw mode blocks)
        if self.check(TokenKind.BlockPayload):
            val payload = self.current.text
            val payload_span = self.current.span
            self.advance()  # Consume BlockPayload

            # Expect BlockEnd or RBrace
            if self.check(TokenKind.BlockEnd):
                self.advance()
            elif self.check(TokenKind.RBrace):
                self.advance()
            else:
                self.error("expected '}' after block payload")

            return BlockOutline(
                kind: kind,
                payload: payload,
                payload_span: payload_span,
                span: merge_spans(start, self.previous.span),
                parent_context: self.current_context,
                pre_lex_info: nil,
                outline_info: nil
            )

        # For normal blocks, capture content by skipping
        val payload = self.skip_block_content()
        val payload_end = self.previous.span.end_pos
        val payload_span = span_new(payload_start, payload_end, payload_line, payload_col)

        # Expect closing brace
        if self.check(TokenKind.BlockEnd):
            self.advance()
        elif self.check(TokenKind.RBrace):
            self.advance()
        else:
            self.error("expected '}' after block content")

        BlockOutline(
            kind: kind,
            payload: payload,
            payload_span: payload_span,
            span: merge_spans(start, self.previous.span),
            parent_context: self.current_context,
            pre_lex_info: nil,
            outline_info: nil
        )


me treesitter_skip_block_content(self: TreeSitter) -> text:
        """Skip block content and return the raw payload text.

        Tracks brace depth to handle nested blocks/braces.
        Returns the captured text.
        """
        val start_pos = self.current.span.start
        var brace_depth = 1

        while brace_depth > 0 and not self.is_at_end():
            match self.peek():
                case LBrace:
                    brace_depth = brace_depth + 1
                    self.advance()
                case RBrace:
                    brace_depth = brace_depth - 1
                    if brace_depth > 0:
                        self.advance()
                    # Don't consume final }
                case BlockEnd:
                    brace_depth = brace_depth - 1
                    if brace_depth > 0:
                        self.advance()
                    # Don't consume final BlockEnd
                case BlockStart:
                    # Nested block - capture it
                    var nested = self.parse_block_outline()
                    nested = self.apply_outline_policy(nested)
                    self.inline_blocks = inline_blocks_push(self.inline_blocks, nested)
                case _:
                    self.advance()

        val end_pos = self.previous.span.end_pos
        # Return the raw source text for the payload
        self.source[start_pos:end_pos]


me treesitter_apply_outline_policy(self: TreeSitter, block: BlockOutline) -> BlockOutline:
        """Apply skip_policy and treesitter_outline based on fast_mode.

        In fast mode:
        - Skippable blocks get opaque outline (no analysis)
        - OutlineRequired blocks get treesitter_outline called
        - AlwaysFull blocks get treesitter_outline called

        In normal mode:
        - All blocks get treesitter_outline called (if handler exists)
        """
        if not self.has_registry:
            return block

        val reg = self.registry
        val handler = reg.lookup(block.kind)
        if handler == nil:
            return block

        val h = handler
        val policy = h_skip_policy(h)
        val pre_lex = if block.has_pre_lex_info:
            block.pre_lex_info
        else:
            prelexinfo_empty()

        if self.fast_mode:
            match policy:
                case BlockSkipPolicy.Skippable:
                    # Store opaque outline, don't analyze
                    var b = block
                    b.outline_info = blockoutlineinfo_opaque(block.kind)
                    return b
                case BlockSkipPolicy.OutlineRequired:
                    var b = block
                    b.outline_info = h_treesitter_outline(h, block.payload, pre_lex)
                    return b
                case BlockSkipPolicy.AlwaysFull:
                    var b = block
                    b.outline_info = h_treesitter_outline(h, block.payload, pre_lex)
                    return b
        else:
            # Normal mode: always call treesitter_outline
            var b = block
            b.outline_info = h_treesitter_outline(h, block.payload, pre_lex)
            return b

        block


# ============================================================================
# Inline ASM Outline Parsing
# ============================================================================

me treesitter_warn_legacy_asm(self: TreeSitter, span: Span):
        self.errors = parse_errors_push(self.errors, ParseError(
            message: "legacy inline asm syntax; use asm { ... }",
            span: span,
            severity: ErrorSeverity.Warning
        ))


fn treesitter_append_asm_payload(payload: text, piece: text) -> text:
        if piece == "":
            return payload
        if payload == "":
            return piece
        if piece == "," or piece == ";" or piece == ")" or piece == "]" or piece == "}":
            return payload + piece
        if payload.ends_with("#") or payload.ends_with("{") or payload.ends_with("(") or payload.ends_with("["):
            return payload + piece
        if piece == "#":
            return payload + " " + piece
        if piece == "{" or piece == "(" or piece == "[":
            return payload + " " + piece
        return payload + " " + piece


me treesitter_parse_asm_braced_outline(self: TreeSitter, start: Span, is_volatile: bool) -> AsmBlockOutline:
        val open_span = self.current.span
        self.advance()  # consume {

        var depth = 1
        var payload = ""
        var close_span = open_span

        while depth > 0 and not self.is_at_end():
            match self.peek():
                case LBrace:
                    depth = depth + 1
                    payload = treesitter_append_asm_payload(payload, "{")
                    self.advance()
                case RBrace:
                    depth = depth - 1
                    close_span = self.current.span
                    if depth > 0:
                        payload = treesitter_append_asm_payload(payload, "}")
                    self.advance()
                case Newline:
                    if payload != "" and not payload.ends_with("\n"):
                        payload = payload + "\n"
                    self.advance()
                case Indent:
                    self.advance()
                case Dedent:
                    self.advance()
                case _:
                    payload = treesitter_append_asm_payload(payload, self.current.text)
                    self.advance()

        AsmBlockOutline(
            payload: payload.trim(),
            payload_span: span_new(open_span.end_pos, close_span.start, open_span.line, open_span.col),
            span: merge_spans(start, close_span),
            is_volatile: is_volatile,
            syntax_form: "braced",
            is_legacy: false
        )


me treesitter_parse_asm_paren_outline(self: TreeSitter, start: Span, is_volatile: bool) -> AsmBlockOutline:
        self.warn_legacy_asm(start)
        val open_span = self.current.span
        self.advance()  # consume (

        var depth = 1
        var payload = ""
        var close_span = open_span

        while depth > 0 and not self.is_at_end():
            match self.peek():
                case LParen:
                    depth = depth + 1
                    payload = treesitter_append_asm_payload(payload, "(")
                    self.advance()
                case RParen:
                    depth = depth - 1
                    close_span = self.current.span
                    if depth > 0:
                        payload = treesitter_append_asm_payload(payload, ")")
                    self.advance()
                case Newline:
                    if payload != "" and not payload.ends_with("\n"):
                        payload = payload + "\n"
                    self.advance()
                case _:
                    payload = treesitter_append_asm_payload(payload, self.current.text)
                    self.advance()

        AsmBlockOutline(
            payload: payload.trim(),
            payload_span: span_new(open_span.end_pos, close_span.start, open_span.line, open_span.col),
            span: merge_spans(start, close_span),
            is_volatile: is_volatile,
            syntax_form: "paren",
            is_legacy: true
        )


me treesitter_parse_asm_colon_outline(self: TreeSitter, start: Span, is_volatile: bool) -> AsmBlockOutline:
        self.warn_legacy_asm(start)
        val colon_span = self.current.span
        self.advance()  # consume :

        var payload = ""
        var end_span = colon_span
        var syntax_form = "colon_string"

        if self.check(TokenKind.StringLit):
            payload = self.current.text
            end_span = self.current.span
            self.advance()
        else:
            syntax_form = "colon_block"
            self.skip_newlines()
            if self.check(TokenKind.Indent):
                self.advance()
                while not self.check(TokenKind.Dedent) and not self.is_at_end():
                    self.skip_newlines()
                    if self.check(TokenKind.Dedent) or self.is_at_end():
                        break
                    if self.check(TokenKind.StringLit):
                        payload = treesitter_append_asm_payload(payload, self.current.text)
                    end_span = self.current.span
                    self.advance()
                self.match_token(TokenKind.Dedent)

        AsmBlockOutline(
            payload: payload.trim(),
            payload_span: span_new(colon_span.end_pos, end_span.end_pos, colon_span.line, colon_span.col),
            span: merge_spans(start, end_span),
            is_volatile: is_volatile,
            syntax_form: syntax_form,
            is_legacy: true
        )


me treesitter_parse_asm_outline(self: TreeSitter) -> AsmBlockOutline:
        val start = self.current.span
        self.advance()  # consume asm

        var is_volatile = false
        if self.check(TokenKind.Ident) and self.current.text == "volatile":
            is_volatile = true
            self.advance()

        if self.check(TokenKind.LBrace):
            return self.parse_asm_braced_outline(start, is_volatile)
        if self.check(TokenKind.LParen):
            return self.parse_asm_paren_outline(start, is_volatile)
        if self.check(TokenKind.Colon):
            return self.parse_asm_colon_outline(start, is_volatile)
        if self.check(TokenKind.StringLit):
            self.warn_legacy_asm(start)
            val str_span = self.current.span
            val payload = self.current.text
            self.advance()
            return AsmBlockOutline(
                payload: payload,
                payload_span: str_span,
                span: merge_spans(start, str_span),
                is_volatile: is_volatile,
                syntax_form: "bare_string",
                is_legacy: true
            )

        self.error("expected asm body")
        AsmBlockOutline(
            payload: "",
            payload_span: start,
            span: start,
            is_volatile: is_volatile,
            syntax_form: "error",
            is_legacy: false
        )


me treesitter_skip_block(self: TreeSitter):
        """Skip an indented body while collecting inline asm outlines."""
        if self.check(TokenKind.Indent):
            self.advance()

        var depth = 1
        while depth > 0 and not self.is_at_end():
            self.skip_newlines()
            if self.is_at_end():
                break

            if self.check(TokenKind.Dedent):
                self.advance()
                depth = depth - 1
                continue

            if self.check(TokenKind.Indent):
                self.advance()
                depth = depth + 1
                continue

            if self.check(TokenKind.KwAsm):
                val asm_outline = self.parse_asm_outline()
                self.asm_blocks = asm_blocks_push(self.asm_blocks, asm_outline)
                continue

            if self.check(TokenKind.BlockStart):
                var nested = self.parse_block_outline()
                nested = self.apply_outline_policy(nested)
                self.inline_blocks = inline_blocks_push(self.inline_blocks, nested)
                continue

            self.advance()


# ============================================================================
# Helper Types
# ============================================================================

"""Friend declaration outline."""
struct FriendDeclOutline:
    package_name: text
    span: Span

"""Internal export declaration outline."""
struct InternalExportOutline:
    items: [text]
    span: Span

"""Parsed top-level item."""
enum TopLevelItem:
    Import(ImportOutline)
    Export(ExportOutline)
    Function(FunctionOutline)
    Class(ClassOutline)
    ActorItem(ActorOutline)
    Struct(StructOutline)
    Enum(EnumOutline)
    Bitfield(BitfieldOutline)
    Trait(TraitOutline)
    Impl(ImplOutline)
    TypeAlias(TypeAliasOutline)
    Const(ConstOutline)
    StaticAssert(StaticAssertOutline)
    FriendDecl(FriendDeclOutline)
    InternalExportDecl(InternalExportOutline)
    Error(ParseError)

# ============================================================================
# Main Entry Point (TreeSitter.parse_outline)
# ============================================================================
#
# NOTE: This was previously defined in the sibling facade file
# `10.frontend/treesitter.spl`, which shares the exact module path
# `compiler.frontend.treesitter` with this directory's `__init__.spl`. That
# file-vs-directory collision meant the directory form silently won module
# resolution and `treesitter.spl`'s `impl TreeSitter: parse_outline()` was
# never loaded — every `use compiler.treesitter.*` caller got a `TreeSitter`
# with no `parse_outline` method. Moved here (the directory package that
# actually owns `TreeSitter`) and the dead-shadowed facade file removed.

impl TreeSitter:
    me parse_outline() -> OutlineModule:
        """Parse source into an outline module.

        This is the main entry point that dispatches to either:
        - Heuristic mode (line-based, error-tolerant)
        - Token-based mode (tree-sitter, accurate)
        """

        # Branch based on mode
        if self.heuristic_mode:
            return self.parse_outline_heuristic()

        # Token-based parsing (default)
        var module = OutlineModule(
            name: "",
            imports: [],
            exports: [],
            functions: [],
            classes: [],
            actors: [],
            structs: [],
            enums: [],
            bitfields: [],
            traits: [],
            impls: [],
            type_aliases: [],
            constants: [],
            static_asserts: [],
            inline_blocks: [],
            asm_blocks: [],
            errors: []
        )

        while not self.is_at_end():
            self.skip_newlines()
            if self.is_at_end():
                break

            val item = self.parse_top_level_item()
            match item:
                case toplevelitem_Import(i):
                    module.imports = module.imports_push(module.imports, i)
                case toplevelitem_Export(e):
                    module.exports = module.exports_push(module.exports, e)
                case toplevelitem_Function(f):
                    module.functions = module.functions_push(module.functions, f)
                case toplevelitem_Class(c):
                    module.classes = module.classes_push(module.classes, c)
                case toplevelitem_ActorItem(a):
                    module.actors = module.actors_push(module.actors, a)
                case toplevelitem_Struct(s):
                    module.structs = module.structs_push(module.structs, s)
                case toplevelitem_Enum(e):
                    module.enums = module.enums_push(module.enums, e)
                case toplevelitem_Bitfield(b):
                    module.bitfields = module.bitfields_push(module.bitfields, b)
                case toplevelitem_Trait(t):
                    module.traits = module.traits_push(module.traits, t)
                case toplevelitem_Impl(i):
                    module.impls = module.impls_push(module.impls, i)
                case toplevelitem_TypeAlias(t):
                    module.type_aliases = module.type_aliases_push(module.type_aliases, t)
                case toplevelitem_Const(c):
                    module.constants = module.constants_push(module.constants, c)
                case toplevelitem_StaticAssert(a):
                    module.static_asserts = module.static_asserts_push(module.static_asserts, a)
                case toplevelitem_Error(e):
                    module.errors = module.errors_push(module.errors, e)
                case _:
                    pass
        module.inline_blocks = self.inline_blocks
        module.asm_blocks = self.asm_blocks
        module.errors = self.errors
        module

# ============================================================================
# Exports
# ============================================================================

export use compiler.frontend.treesitter.outline_lexer.{TreeSitter}
export TopLevelItem
