use app.llm_runtime.manifest.{LlmRuntimeManifest}
use app.llm_runtime.dashboard_live_control.{LlmRuntimeDashboardControlExecution}
use app.llm_runtime.dashboard_live_control.{llm_runtime_execute_dashboard_control}
use app.llm_runtime.dashboard_live_control.{llm_runtime_dashboard_control_execution_jsonl_event}
use app.llm_runtime.live_environment.{llm_runtime_vllm_live_environment_evidence}
use app.llm_runtime.serve_readiness.{llm_runtime_vllm_serve_readiness_preflight_with_resources, llm_runtime_vllm_serve_readiness_from_observation}
use app.llm_runtime.serve_lifecycle.{llm_runtime_start_vllm_serve, llm_runtime_vllm_serve_lifecycle_from_pid, llm_runtime_vllm_serve_running_status, llm_runtime_stop_vllm_serve}
use app.llm_runtime.live_transport.{LlmRuntimeLiveTransportResult, llm_runtime_fetch_vllm_models}

pub fn llm_runtime_execute_dashboard_control_live(manifest: LlmRuntimeManifest, action: text, pid: i64, vllm_available: bool, gpu_available: bool) -> LlmRuntimeDashboardControlExecution:
    val normalized = action.trim().to_lower()
    if normalized == "preflight":
        val preflight = llm_runtime_vllm_serve_readiness_preflight_with_resources(manifest, vllm_available, gpu_available)
        return llm_runtime_dashboard_control_execution_from_observation(normalized, preflight.status, preflight.reason, preflight.pid, preflight.running_status, preflight.endpoint_status, preflight.models_status, preflight.models_reason, preflight.http_status, -1, -1)
    if normalized == "start":
        val environment = llm_runtime_vllm_live_environment_evidence(vllm_available, gpu_available, "")
        if environment.status == "skipped":
            return llm_runtime_execute_dashboard_control(manifest, action, pid, vllm_available, gpu_available)
        val lifecycle = llm_runtime_start_vllm_serve(manifest)
        return llm_runtime_dashboard_control_execution_from_observation(normalized, lifecycle.status, lifecycle.reason, lifecycle.pid, lifecycle.running_status, "not_checked", "not_fetched", "probe_not_run", 0, lifecycle.pid, -1)
    if normalized == "poll":
        if pid <= 0:
            return llm_runtime_execute_dashboard_control(manifest, action, pid, vllm_available, gpu_available)
        return llm_runtime_dashboard_control_execution_from_observation(normalized, "observed", "process_polled", pid, llm_runtime_vllm_serve_running_status(pid), "not_checked", "not_fetched", "probe_not_run", 0, -1, -1)
    if normalized == "probe":
        val environment = llm_runtime_vllm_live_environment_evidence(vllm_available, gpu_available, "")
        if environment.status == "skipped" or pid <= 0:
            return llm_runtime_execute_dashboard_control(manifest, action, pid, vllm_available, gpu_available)
        val lifecycle = llm_runtime_vllm_serve_lifecycle_from_pid(pid, "vllm serve redacted")
        lifecycle.running_status = llm_runtime_vllm_serve_running_status(pid)
        if lifecycle.running_status != "running":
            val observed = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "process_not_ready"))
            return llm_runtime_dashboard_control_execution_from_observation(normalized, observed.status, observed.reason, observed.pid, observed.running_status, observed.endpoint_status, observed.models_status, observed.models_reason, observed.http_status, -1, -1)
        val models = llm_runtime_fetch_vllm_models(manifest)
        val result = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, models)
        return llm_runtime_dashboard_control_execution_from_observation(normalized, result.status, result.reason, result.pid, result.running_status, result.endpoint_status, result.models_status, result.models_reason, result.http_status, -1, -1)
    if normalized == "stop":
        val stopped = llm_runtime_stop_vllm_serve(pid)
        return llm_runtime_dashboard_control_execution_from_observation(normalized, stopped.status, stopped.reason, stopped.pid, stopped.running_status, "not_checked", "not_fetched", "stop_only", 0, -1, stopped.pid)
    llm_runtime_execute_dashboard_control(manifest, action, pid, vllm_available, gpu_available)

pub fn llm_runtime_dashboard_control_execution_from_observation(action: text, status: text, reason: text, pid: i64, running_status: text, endpoint_status: text, models_status: text, models_reason: text, http_status: i64, started_pid: i64, stopped_pid: i64) -> LlmRuntimeDashboardControlExecution:
    val result = LlmRuntimeDashboardControlExecution(
        action: action,
        status: status,
        reason: reason,
        pid: pid,
        running_status: running_status,
        endpoint_status: endpoint_status,
        models_status: models_status,
        models_reason: models_reason,
        http_status: http_status,
        started_pid: started_pid,
        stopped_pid: stopped_pid,
        requires_runtime_executor: action != "preflight",
        evidence_jsonl: ""
    )
    result.evidence_jsonl = llm_runtime_dashboard_control_execution_jsonl_event(result)
    result

fn _not_fetched_models(status: text, reason: text) -> LlmRuntimeLiveTransportResult:
    LlmRuntimeLiveTransportResult(
        status: status,
        reason: reason,
        endpoint_status: "not_checked",
        method: "GET",
        path: "/models",
        http_status: 0,
        response_status: "not_fetched",
        response_reason: reason,
        body_status: "empty",
        evidence_jsonl: ""
    )

export llm_runtime_execute_dashboard_control_live, llm_runtime_dashboard_control_execution_from_observation
