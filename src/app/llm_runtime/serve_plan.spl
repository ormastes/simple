use app.llm_runtime.manifest.{LlmRuntimeManifest, LlmRuntimeAdapter}
use app.mcp.main_lazy_json.{LB, RB, jp, js}
use std.io_runtime.{file_exists}

pub class LlmRuntimeServePlan:
    status: text
    reason: text
    binary: text
    backend: text
    base_model: text
    endpoint_status: text
    command_preview: text
    lora_adapter_count: i64
    dynamic_lora_status: text
    evidence_jsonl: text

pub fn llm_runtime_static_serve_plan(manifest: LlmRuntimeManifest) -> LlmRuntimeServePlan:
    val required_status = _required_status(manifest)
    val adapter_status = _adapter_status(manifest.lora_adapters)
    val dynamic_status = _dynamic_status(manifest.dynamic_lora)
    val backend_status = _backend_status(manifest.backend)
    val status = _serve_plan_status(required_status, adapter_status, dynamic_status, backend_status)
    val reason = _serve_plan_reason(status, required_status, adapter_status, dynamic_status, backend_status)
    val base_model = _public_text(manifest.base_model, "missing")
    val endpoint_status = _endpoint_status(manifest.endpoint)
    val binary = _backend_binary(manifest.backend)
    val command_preview = _command_preview(status, manifest.backend, base_model, endpoint_status, manifest.lora_adapters.len(), dynamic_status, manifest.tensor_parallel_size, manifest.data_parallel_size, manifest.memory_fraction_static)
    LlmRuntimeServePlan(
        status: status,
        reason: reason,
        binary: binary,
        backend: manifest.backend,
        base_model: base_model,
        endpoint_status: endpoint_status,
        command_preview: command_preview,
        lora_adapter_count: manifest.lora_adapters.len(),
        dynamic_lora_status: dynamic_status,
        evidence_jsonl: _serve_plan_jsonl_event(status, reason, binary, manifest.backend, base_model, endpoint_status, command_preview, manifest.lora_adapters.len(), dynamic_status)
    )

pub fn llm_runtime_serve_plan_jsonl_event(plan: LlmRuntimeServePlan) -> text:
    _serve_plan_jsonl_event(plan.status, plan.reason, plan.binary, plan.backend, plan.base_model, plan.endpoint_status, plan.command_preview, plan.lora_adapter_count, plan.dynamic_lora_status)

pub fn llm_runtime_sglang_serve_args(base_model: text, host: text, port: text, tensor_parallel_size: i64, data_parallel_size: i64, memory_fraction_static: text) -> [text]:
    var args = ["-m", "sglang.launch_server", "--model-path", base_model, "--host", host]
    if port.trim() != "":
        args.push("--port")
        args.push(port)
    if tensor_parallel_size > 0:
        args.push("--tp")
        args.push(tensor_parallel_size.to_text())
    if data_parallel_size > 0:
        args.push("--dp")
        args.push(data_parallel_size.to_text())
    if memory_fraction_static.trim() != "":
        args.push("--mem-fraction-static")
        args.push(memory_fraction_static.trim())
    args

fn _serve_plan_jsonl_event(status: text, reason: text, binary: text, backend: text, base_model: text, endpoint_status: text, command_preview: text, lora_adapter_count: i64, dynamic_lora_status: text) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_serve_plan")) +
    "," + jp("status", js(status)) +
    "," + jp("reason", js(reason)) +
    "," + jp("binary", js(binary)) +
    "," + jp("backend", js(backend)) +
    "," + jp("base_model", js(base_model)) +
    "," + jp("endpoint", js(endpoint_status)) +
    "," + jp("command_preview", js(command_preview)) +
    "," + jp("lora_adapter_count", str(lora_adapter_count)) +
    "," + jp("dynamic_lora", js(dynamic_lora_status)) +
    RB() + "\n"

fn _required_status(manifest: LlmRuntimeManifest) -> text:
    if manifest.base_model.trim() == "":
        return "missing_base_model"
    if manifest.endpoint.trim() == "":
        return "missing_endpoint"
    if _endpoint_status(manifest.endpoint) == "invalid":
        return "invalid_endpoint"
    if manifest.invalid_adapter_count > 0:
        return "invalid_adapter_entry"
    "ok"

fn _endpoint_status(endpoint: text) -> text:
    val value = endpoint.trim()
    if value == "":
        return "missing"
    if value.starts_with("http://") or value.starts_with("https://"):
        if value.contains(" "):
            return "invalid"
        return "configured"
    "invalid"

fn _adapter_status(adapters: [LlmRuntimeAdapter]) -> text:
    for adapter in adapters:
        if adapter.name.trim() == "":
            return "missing_adapter_name"
        if adapter.path.trim() == "":
            return "missing_adapter_path"
        if not file_exists(adapter.path):
            return "missing_adapter_path"
    "ok"

fn _dynamic_status(mode: text) -> text:
    if mode == "trusted":
        return "trusted"
    if mode == "disabled":
        return "disabled"
    "blocked"

fn _serve_plan_status(required_status: text, adapter_status: text, dynamic_status: text, backend_status: text) -> text:
    if backend_status != "ok":
        return "blocked"
    if required_status != "ok":
        return "missing"
    if adapter_status != "ok":
        return "missing"
    if dynamic_status == "blocked":
        return "blocked"
    "planned"

fn _serve_plan_reason(status: text, required_status: text, adapter_status: text, dynamic_status: text, backend_status: text) -> text:
    if backend_status != "ok":
        return backend_status
    if required_status != "ok":
        return required_status
    if adapter_status != "ok":
        return adapter_status
    if dynamic_status == "blocked":
        return "dynamic_lora_requires_trusted_mode"
    if status == "planned":
        return "static_serve_plan_only"
    "serve_plan_unknown"

fn _command_preview(status: text, backend: text, base_model: text, endpoint_status: text, adapter_count: i64, dynamic_status: text, tensor_parallel_size: i64, data_parallel_size: i64, memory_fraction_static: text) -> text:
    if status == "missing":
        return "missing"
    if status == "blocked":
        return "blocked"
    if backend == "sglang":
        return (["python"] + llm_runtime_sglang_serve_args(base_model, endpoint_status, endpoint_status, tensor_parallel_size, data_parallel_size, memory_fraction_static)).join(" ")
    var parts = ["vllm", "serve", base_model, "--endpoint", endpoint_status]
    if adapter_count > 0:
        parts.push("--enable-lora")
        parts.push("--lora-modules")
        parts.push(str(adapter_count) + "-redacted")
    parts.push("--dynamic-lora")
    parts.push(dynamic_status)
    parts.join(" ")

fn _backend_status(backend: text) -> text:
    if backend == "vllm" or backend == "sglang":
        return "ok"
    "unsupported_backend"

fn _backend_binary(backend: text) -> text:
    if backend == "sglang":
        return "python"
    "vllm"

fn _public_text(value: text, fallback: text) -> text:
    if value.trim() == "":
        return fallback
    if _looks_sensitive(value):
        return "redacted"
    value

fn _looks_sensitive(value: text) -> bool:
    val lower = value.to_lower()
    lower.contains("token") or lower.contains("apikey") or lower.contains("api_key") or lower.contains("password") or lower.contains("secret") or lower.contains("@") or value.contains("/") or value.starts_with("~") or value.contains("\\")

export LlmRuntimeServePlan
export llm_runtime_static_serve_plan, llm_runtime_serve_plan_jsonl_event, llm_runtime_sglang_serve_args
