use app.llm_runtime.manifest.{LlmRuntimeManifest}
use app.mcp.main_lazy_json.{LB, RB, jp, js}

pub class LlmRuntimeLiveRequestPlan:
    status: text
    reason: text
    endpoint_status: text
    method: text
    path: text
    url_preview: text
    body_status: text
    unsupported_param_count: i64
    execution_status: text
    evidence_jsonl: text

pub fn llm_runtime_vllm_models_request_plan(manifest: LlmRuntimeManifest) -> LlmRuntimeLiveRequestPlan:
    _request_plan(manifest, "GET", "/models", "none", 0)

pub fn llm_runtime_vllm_chat_request_plan(manifest: LlmRuntimeManifest, messages_json: text, unsupported_param_count: i64) -> LlmRuntimeLiveRequestPlan:
    val body_status = if messages_json.trim() == "": "missing" else: "present"
    _request_plan(manifest, "POST", "/chat/completions", body_status, unsupported_param_count)

pub fn llm_runtime_live_request_plan_jsonl_event(plan: LlmRuntimeLiveRequestPlan) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_live_request_plan")) +
    "," + jp("status", js(plan.status)) +
    "," + jp("reason", js(plan.reason)) +
    "," + jp("endpoint", js(plan.endpoint_status)) +
    "," + jp("method", js(plan.method)) +
    "," + jp("path", js(plan.path)) +
    "," + jp("url_preview", js(plan.url_preview)) +
    "," + jp("body", js(plan.body_status)) +
    "," + jp("unsupported_param_count", str(plan.unsupported_param_count)) +
    "," + jp("execution_status", js(plan.execution_status)) +
    RB() + "\n"

fn _request_plan(manifest: LlmRuntimeManifest, method: text, path: text, body_status: text, unsupported_param_count: i64) -> LlmRuntimeLiveRequestPlan:
    val endpoint_status = _endpoint_status(manifest.endpoint)
    val status = _plan_status(endpoint_status, body_status, unsupported_param_count)
    val reason = _plan_reason(status, endpoint_status, body_status, unsupported_param_count)
    val plan = LlmRuntimeLiveRequestPlan(
        status: status,
        reason: reason,
        endpoint_status: endpoint_status,
        method: method,
        path: path,
        url_preview: _url_preview(status, manifest.endpoint, path),
        body_status: body_status,
        unsupported_param_count: unsupported_param_count,
        execution_status: "plan_only_not_fetched",
        evidence_jsonl: ""
    )
    plan.evidence_jsonl = llm_runtime_live_request_plan_jsonl_event(plan)
    plan

fn _plan_status(endpoint_status: text, body_status: text, unsupported_param_count: i64) -> text:
    if endpoint_status != "configured":
        return "missing"
    if body_status == "missing":
        return "missing"
    if unsupported_param_count > 0:
        return "blocked"
    "planned"

fn _plan_reason(status: text, endpoint_status: text, body_status: text, unsupported_param_count: i64) -> text:
    if endpoint_status == "missing":
        return "missing_endpoint"
    if endpoint_status == "invalid":
        return "invalid_endpoint"
    if body_status == "missing":
        return "missing_chat_body"
    if unsupported_param_count > 0:
        return "unsupported_chat_parameters"
    if status == "planned":
        return "live_request_plan_only"
    "live_request_plan_unknown"

fn _endpoint_status(endpoint: text) -> text:
    val value = endpoint.trim()
    if value == "":
        return "missing"
    if value.starts_with("http://") or value.starts_with("https://"):
        if value.contains(" "):
            return "invalid"
        return "configured"
    "invalid"

fn _url_preview(status: text, endpoint: text, path: text) -> text:
    if status == "missing":
        return "missing"
    if status == "blocked":
        return "blocked"
    _append_path(_redact_endpoint(endpoint), path)

fn _redact_endpoint(endpoint: text) -> text:
    val value = endpoint.trim()
    val scheme = _scheme_prefix(value)
    if scheme == "":
        return value
    val rest = value.slice(scheme.len(), value.len())
    val at = rest.find("@")
    if at < 0:
        return value
    scheme + rest.slice(at + 1, rest.len())

fn _scheme_prefix(value: text) -> text:
    if value.starts_with("http://"):
        return "http://"
    if value.starts_with("https://"):
        return "https://"
    ""

fn _append_path(endpoint: text, path: text) -> text:
    var base = endpoint
    while base.ends_with("/"):
        base = base.slice(0, base.len() - 1)
    if path.starts_with("/"):
        return base + path
    base + "/" + path

export LlmRuntimeLiveRequestPlan
export llm_runtime_vllm_models_request_plan, llm_runtime_vllm_chat_request_plan, llm_runtime_live_request_plan_jsonl_event
