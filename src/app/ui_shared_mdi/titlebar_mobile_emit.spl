# Emit the shared MDI titlebar GUI as a phone-viewport HTML document for mobile capture.
use app.ui_shared_mdi.terminal_window_html.{shared_mdi_terminal_window_html}

fn main() -> i64:
    val frag = shared_mdi_terminal_window_html()
    val doc = "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>html,body{margin:0;padding:0;background:#0b0d10;height:100%;}.host{width:100%;height:280px;}</style></head><body><div class=\"host\">" + frag + "</div></body></html>"
    print doc
    return 0
