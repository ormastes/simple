# Shared MDI Demo
#
# Emits one desktop render frame followed by backend-neutral openWindow IPC
# messages. Host shells (Electron/Tauri) and pure Simple WM tests consume the
# same shared window descriptors.

use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render, build_ipc_open_window}
use app.ui_shared_mdi.desktop_html.{shared_mdi_desktop_html, shared_mdi_browser_iframe_html}
use app.ui_shared_mdi.terminal_window_html.{shared_mdi_terminal_window_html}
use common.ui.widget.{UIEvent}
use common.ui.html_window.{html_embedded_image_data_uri, html_picture, html_pre_block, html_window_content}
use common.ui.window.{normalize_window_backend}
use app.io.env_ops.{env_get}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}

extern fn rt_stdin_read_line() -> text?
extern fn rt_stdout_flush() -> i32

fn mdi_env_get(key: text) -> text:
    env_get(key)

fn _emit_ipc(message: text):
    print message
    rt_stdout_flush()

fn _open_mdi_window(window_id: text, title_text: text, html_text: text, x: i32, y: i32, width: i32, height: i32):
    _emit_ipc(build_ipc_open_window(window_id, title_text, html_text, x, y, width, height))

fn _proof_sleep(ms: i64):
    if mdi_env_get("SIMPLE_MDI_FAST_PROOF") == "1":
        return
    thread_sleep(ms)

fn run_shared_mdi_demo() -> i64:
    val backend = normalize_window_backend(mdi_env_get("SIMPLE_UI_BACKEND") ?? "simple")
    _emit_ipc(build_ipc_render(shared_mdi_desktop_html(backend)))

    _proof_sleep(300)

    val term_html = shared_mdi_terminal_window_html()
    _open_mdi_window("terminal", "Terminal", term_html, 50, 60, 600, 400)

    _proof_sleep(100)

    val editor_html = html_window_content("Editor", html_pre_block("# hello.spl\n\nfn main() -> i64:\n    print \"Hello, World!\"\n    return 0"), "")
    _open_mdi_window("editor", "Editor", editor_html, 40, 500, 700, 400)

    _proof_sleep(100)

    val browser_url = mdi_env_get("SIMPLE_BROWSER_URL") ?? "http://localhost:3333"
    val browser_body = shared_mdi_browser_iframe_html(browser_url)
    val browser_html = html_window_content("Browser", browser_body, "")
    _open_mdi_window("browser", "Browser", browser_html, 670, 60, 650, 450)

    _proof_sleep(100)

    val folder_icon = html_embedded_image_data_uri("image/svg+xml", "")
    val files_body = html_picture(folder_icon, "Embedded folder picture") + html_pre_block("src/\n  compiler/\n  lib/\n  app/\nexamples/\n  ui/\n  simple_os/")
    val files_html = html_window_content("File Manager", files_body, "")
    _open_mdi_window("files", "File Manager", files_html, 700, 520, 550, 350)

    if mdi_env_get("SIMPLE_MDI_STAY_OPEN") != "1":
        return 0

    var running = true
    while running:
        val line = rt_stdin_read_line()
        if line != nil and line != "":
            val event = parse_ipc_message(line)
            if event != nil:
                match event:
                    UIEvent.Quit:
                        running = false
                    _:
                        pass_dn
    return 0

fn main() -> i64:
    return run_shared_mdi_demo()
