# Shared MDI terminal window markup helpers.

use common.ui.html_window.{html_pre_block, html_titlebar_button, html_window_content_with_titlebar_widgets}

pub fn shared_mdi_terminal_window_html() -> text:
    val term_body = html_pre_block("$ simple --version\nSimple Language v0.9.5\n\n$ _") + "<button data-action=\"mdi_terminal_action\">Run</button><input data-target-id=\"mdi_terminal_input\" value=\"ready\">"
    val titlebar_css = ".simple-titlebar-widget{background:rgb(18,58,52);border-color:rgb(52,211,153);color:rgb(236,254,255);}"
    html_window_content_with_titlebar_widgets("Terminal", term_body, html_titlebar_button("mdi_terminal_action", "Run"), titlebar_css)
