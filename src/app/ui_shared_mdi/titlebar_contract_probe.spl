# Shared MDI titlebar contract probe.

use app.ui_shared_mdi.terminal_window_html.{shared_mdi_terminal_window_html}

fn _print_bool(key: text, value: bool):
    if value:
        print key + "=true"
    else:
        print key + "=false"

fn main() -> i64:
    val html = shared_mdi_terminal_window_html()
    val has_titlebar_button = html.contains("<button class=\"simple-titlebar-widget\" data-simple-titlebar-widget=\"button\" data-action=\"mdi_terminal_action\" type=\"button\">Run</button>")
    val has_body_button = html.contains("<button data-action=\"mdi_terminal_action\">Run</button>")
    val has_body_input = html.contains("data-target-id=\"mdi_terminal_input\"") and html.contains("value=\"ready\"")
    val has_titlebar_css = html.contains(".simple-titlebar-widgets{display:flex;align-items:center;gap:6px;margin-left:auto;}") and html.contains(".simple-titlebar-widget{background:rgb(18,58,52);border-color:rgb(52,211,153);color:rgb(236,254,255);}")
    val status = has_titlebar_button and has_body_button and has_body_input and has_titlebar_css

    if status:
        print "shared_mdi_titlebar_contract_status=pass"
    else:
        print "shared_mdi_titlebar_contract_status=fail"
    _print_bool("shared_mdi_titlebar_contract_titlebar_button_markup_present", has_titlebar_button)
    _print_bool("shared_mdi_titlebar_contract_body_button_markup_present", has_body_button)
    _print_bool("shared_mdi_titlebar_contract_body_input_markup_present", has_body_input)
    _print_bool("shared_mdi_titlebar_contract_titlebar_css_present", has_titlebar_css)
    return 0
