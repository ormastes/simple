# Simple Task - AI Assistant Dispatcher.
# Startup-light CLI surface for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Task"
val TOOL_VERSION = "0.1.0"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("task", log_opts.error)
        return 1

    val args = task_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"task\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0
    if args.len() > 0 and args[0] == "--list":
        print_drivers(log_opts.log_mode, log_opts.progress)
        return 0
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"task\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"drivers\":[\"copilot\",\"codex\",\"claude\"]}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "task")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for AI task dispatch."
        return 0

    val driver = args[0]
    if not task_is_driver(driver):
        val message = "Unknown driver: {driver}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"task\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("task", message)
        return 1
    if args.len() < 2:
        val message = "Task description required for {driver}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"task\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("task", message)
        return 1

    val description = task_description(args)
    if log_opts.log_mode == "json":
        print "{\"command\":\"task\",\"status\":\"planned\",\"driver\":\"{driver}\",\"description\":\"{description}\"}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "task-plan")
        if progress != "":
            print progress
        print "Task driver: {driver}"
        print "Description: {description}"
    0

fn print_help():
    print "{TOOL_NAME} - AI Assistant Dispatcher"
    print ""
    print "Usage: simple task [driver] [description]"
    print ""
    print "Drivers:"
    print "  copilot          GitHub Copilot CLI"
    print "  codex            OpenAI Codex CLI"
    print "  claude           Anthropic Claude CLI"
    print ""
    print "Options:"
    print "  -h, --help       Show this help message"
    print "  -v, --version    Show version information"
    print "  --list           List available drivers"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn print_drivers(log_mode: text, progress_mode: text):
    if log_mode == "json":
        print "{\"command\":\"task\",\"status\":\"ok\",\"drivers\":[\"copilot\",\"codex\",\"claude\"]}"
        return
    val progress = render_progress(progress_mode, 1, 1, "drivers")
    if progress != "":
        print progress
    print "Available AI Drivers:"
    print "  copilot"
    print "  codex"
    print "  claude"

fn task_is_driver(driver: text) -> bool:
    driver == "copilot" or driver == "codex" or driver == "claude"

fn task_description(args: [text]) -> text:
    var parts: [text] = []
    var i = 1
    while i < args.len():
        parts.push(args[i])
        i = i + 1
    parts.join(" ")

fn task_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn task_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if task_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
