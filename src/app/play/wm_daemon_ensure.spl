# WM daemon ensure/health — zero-overhead auto-connect + hang recovery.
#
# Kept separate from wm_daemon_client.spl (protocol-only, no process control)
# and wm_daemon.spl (compositor-owning server) so a hosted GUI app pulls in
# exactly this much to get a live daemon for free.
#
# Two entry points:
#
#  - wm_daemon_autoconnect(): call once per hosted GUI app launch (wired at
#    os.compositor.host_compositor_bootstrap.init_host_wm). ONE lock-file
#    probe via wm_daemon_is_running() (already a cheap lock-file + PID
#    liveness check — see daemon_sdk/lock.spl); a hit returns immediately, a
#    miss spawns `simple play daemon serve` DETACHED and returns WITHOUT
#    waiting for the daemon to finish initializing. No sleeps, no retries —
#    this must stay off the app's launch hot path (see the overhead gate in
#    scripts/check/check-wm-daemon-autoconnect-overhead-evidence.shs).
#
#  - wm_daemon_ensure_healthy(): a background sanity check — call AFTER
#    window creation (or lazily on first daemon request), never inline with
#    autoconnect. Pings the daemon's status verb with a short timeout. A hang
#    (timeout/garbage response) kills the stale pid (pid>0 GUARDED — never
#    kill(-1)/kill(0)) and relaunches detached; a stale lock file with no
#    live process behind it relaunches without a kill. See the SIGSTOP gate
#    in scripts/check/check-wm-daemon-health-recovery-evidence.shs.

use app.play.wm_daemon_client.{wm_daemon_config, wm_daemon_is_running, WMD_STATUS}
use std.daemon_sdk.types.{daemon_request_new}
use std.daemon_sdk.client.{daemon_submit_and_wait}
use std.daemon_sdk.lock.{read_daemon_pid, is_pid_alive}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_delete}
use std.nogc_sync_mut.io.process_ops.{process_spawn_async, process_kill}
use std.nogc_sync_mut.io.env_ops.{env_get}
use std.nogc_sync_mut.sffi.system.{sleep_ms}

fn _wm_daemon_spawn_detached() -> bool:
    val exe = env_get("SIMPLE_BIN") ?? "bin/simple"
    process_spawn_async(exe, ["play", "daemon", "serve"]) > 0

pub fn wm_daemon_autoconnect():
    """Zero-overhead singleton ensure for a hosted GUI app launch: one
    lock-file probe, detached spawn on miss, no waiting on daemon init. Safe
    to call on every app launch."""
    if wm_daemon_is_running():
        return
    _wm_daemon_spawn_detached()

pub fn wm_daemon_health(timeout_ms: i64) -> bool:
    """Ping the daemon's status verb with timeout_ms. True only on a prompt,
    well-formed reply — a hang (frozen/SIGSTOPped process) or garbage counts
    as unhealthy."""
    if not wm_daemon_is_running():
        return false
    val config = wm_daemon_config()
    val req = daemon_request_new(WMD_STATUS)
    val resp = daemon_submit_and_wait(req, config, timeout_ms)
    resp.request_id != "" and resp.get_field("running") == "true"

pub fn wm_daemon_ensure_healthy() -> text:
    """Background sanity check + hang recovery. Returns a short marker for
    logs/gates:
      healthy
      not-running-relaunched | not-running-relaunch-failed
      unhealthy-killed-relaunched | unhealthy-relaunch-failed
      stale-lock-relaunched | stale-lock-relaunch-failed
    """
    val config = wm_daemon_config()
    if not file_exists(config.lock_path):
        return if _wm_daemon_spawn_detached(): "not-running-relaunched" else: "not-running-relaunch-failed"
    if wm_daemon_health(500):
        return "healthy"
    val pid = read_daemon_pid(config.lock_path)
    if pid > 0 and is_pid_alive(pid):
        process_kill(pid)
        sleep_ms(250)
        file_delete(config.lock_path)
        val ok = _wm_daemon_spawn_detached()
        print "[wm-daemon] unhealthy: killed pid={pid}, relaunched"
        return if ok: "unhealthy-killed-relaunched" else: "unhealthy-relaunch-failed"
    # Stale lock: file exists but no live process behind it — relaunch
    # without a kill (pid<=0 or already dead, so no kill call is made).
    file_delete(config.lock_path)
    val ok2 = _wm_daemon_spawn_detached()
    print "[wm-daemon] stale-lock: no live process, relaunched"
    return if ok2: "stale-lock-relaunched" else: "stale-lock-relaunch-failed"
