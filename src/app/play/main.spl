# simple play CLI entrypoint.
# Startup-light surface for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Play"
val TOOL_VERSION = "0.1.0"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("play", log_opts.error)
        return 1

    val args = play_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"play\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"play\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "play")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for UI automation command planning."
        return 0

    val subcommand = args[0]
    if not play_is_subcommand(subcommand):
        val message = "Unknown play subcommand: {subcommand}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"play\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("play", message)
        return 1

    val required = play_required_arg_count(subcommand)
    if args.len() - 1 < required:
        val message = "Subcommand {subcommand} requires {required} argument(s)"
        if log_opts.log_mode == "json":
            print "{\"command\":\"play\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("play", message)
        return 1

    if log_opts.log_mode == "json":
        print "{\"command\":\"play\",\"status\":\"planned\",\"subcommand\":\"{subcommand}\",\"args\":{args.len() - 1}}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "play-plan")
        if progress != "":
            print progress
        print "Play subcommand: {subcommand}"
        print "Argument count: {args.len() - 1}"
    0

fn print_help():
    print "{TOOL_NAME} - UI automation"
    print ""
    print "Usage: simple play <subcommand> [args]"
    print ""
    print "Subcommands:"
    print "  run <target>                    Run Playwright-compatible tests"
    print "  launch <app>                    Launch an Electron app"
    print "  click <sid> <selector>          Click an element"
    print "  fill <sid> <selector> <value>   Fill a field"
    print "  type <sid> <selector> <text>    Type text"
    print "  press <sid> <selector> <key>    Press a key"
    print "  screenshot <sid> [-o path]      Capture a screenshot"
    print "  evaluate <sid> <js>             Evaluate JavaScript"
    print "  close <sid>                     Close a session"
    print "  wm-list                         List native windows"
    print "  wm-click <x> <y>                Native click"
    print "  sdl2-connect <url>              Connect to SDL2 test API"
    print "  ui-snapshot <sid>               Read canonical UI snapshot"
    print "  ui-query <sid> [flags]          Query canonical UI nodes"
    print "  ui-ensure <sid> [flags]         Await canonical UI state"
    print "  ui-act <sid> <cid> <action>     Dispatch canonical UI action"
    print ""
    print "Options:"
    print "  -h, --help                      Show this help message"
    print "  -v, --version                   Show version information"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn play_is_subcommand(name: text) -> bool:
    name == "run" or name == "launch" or name == "click" or name == "fill" or
        name == "type" or name == "press" or name == "screenshot" or
        name == "evaluate" or name == "eval" or name == "close" or
        name == "last-trace" or name == "wm-screenshot" or name == "wm-list" or
        name == "wm-click" or name == "wm-type" or name == "wm-press" or
        name == "sdl2-connect" or name == "sdl2-click" or name == "sdl2-fill" or
        name == "sdl2-screenshot" or name == "sdl2-elements" or
        name == "sdl2-state" or name == "ui-connect" or name == "ui-snapshot" or
        name == "ui-query" or name == "ui-ensure" or name == "ui-act"

fn play_required_arg_count(name: text) -> i64:
    if name == "wm-list":
        return 0
    if play_has_one_required_arg(name):
        return 1
    if play_has_two_required_args(name):
        return 2
    return 3

fn play_has_one_required_arg(name: text) -> bool:
    name == "run" or name == "launch" or name == "close" or
        name == "last-trace" or name == "sdl2-connect" or
        name == "sdl2-elements" or name == "sdl2-state" or
        name == "ui-connect" or name == "ui-snapshot" or
        name == "ui-query" or name == "ui-ensure"

fn play_has_two_required_args(name: text) -> bool:
    name == "click" or name == "screenshot" or name == "evaluate" or
        name == "eval" or name == "wm-click" or name == "wm-type" or
        name == "wm-press" or name == "sdl2-click" or
        name == "sdl2-screenshot"

fn play_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn play_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if play_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
