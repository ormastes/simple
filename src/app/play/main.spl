# ============================================================================
# ui-* — semantic /api/test/ui/* surface, shared by host WM, TUI web,
# standalone Simple apps, and the SimpleOS compositor bridge.
# ============================================================================

fn _ui_opt(rest: [text], flag: text) -> text:
    var i = 0
    while i + 1 < rest.length():
        if rest[i] == flag:
            return rest[i + 1]
        i = i + 1
    ""

fn _ui_flag(rest: [text], flag: text) -> text:
    for a in rest:
        if a == flag:
            return "true"
    ""

fn handle_ui_snapshot(rest: [text]) -> i64:
    if rest.length() < 1:
        err_json("INVALID_ARGUMENT", "ui-snapshot <session_id>")
        return 1
    val sid = rest[0]
    match _sdl2_client(sid):
        case Ok(client):
            match client.ui_snapshot():
                case Ok(body):
                    ok_json("\"session_id\":\"{sid}\",\"snapshot\":{body}")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_ui_query(rest: [text]) -> i64:
    if rest.length() < 1:
        err_json("INVALID_ARGUMENT", "ui-query <session_id> [--surface-id S] [--canonical-id C] [--kind K] [--text T] [--focused-only] [--limit N]")
        return 1
    val sid = rest[0]
    val surface_id = _ui_opt(rest, "--surface-id")
    val canonical_id = _ui_opt(rest, "--canonical-id")
    val kind = _ui_opt(rest, "--kind")
    val text_query = _ui_opt(rest, "--text")
    val focused_only = _ui_flag(rest, "--focused-only")
    val limit = _ui_opt(rest, "--limit")
    match _sdl2_client(sid):
        case Ok(client):
            match client.ui_query(surface_id, canonical_id, kind, text_query, focused_only, limit):
                case Ok(body):
                    ok_json("\"session_id\":\"{sid}\",\"result\":{body}")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_ui_ensure(rest: [text]) -> i64:
    if rest.length() < 1:
        err_json("INVALID_ARGUMENT", "ui-ensure <session_id> [--surface-id S] [--canonical-id C] [--expectation E] [--expected-value V] [--timeout-ms N] [--kind K] [--text T] [--focused-only]")
        return 1
    val sid = rest[0]
    val surface_id = _ui_opt(rest, "--surface-id")
    val canonical_id = _ui_opt(rest, "--canonical-id")
    val kind = _ui_opt(rest, "--kind")
    val text_query = _ui_opt(rest, "--text")
    val focused_only = _ui_flag(rest, "--focused-only")
    val expectation = _ui_opt(rest, "--expectation")
    val expected_value = _ui_opt(rest, "--expected-value")
    val timeout_ms = _ui_opt(rest, "--timeout-ms")
    match _sdl2_client(sid):
        case Ok(client):
            match client.ui_ensure(surface_id, canonical_id, kind, text_query, focused_only, expectation, expected_value, timeout_ms):
                case Ok(body):
                    ok_json("\"session_id\":\"{sid}\",\"result\":{body}")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_ui_act(rest: [text]) -> i64:
    if rest.length() < 3:
        err_json("INVALID_ARGUMENT", "ui-act <session_id> <canonical_id> <action> [--surface-id S]")
        return 1
    val sid = rest[0]
    val canonical_id = rest[1]
    val action = rest[2]
    val surface_id = _ui_opt(rest, "--surface-id")
    match _sdl2_client(sid):
        case Ok(client):
            match client.ui_act(surface_id, canonical_id, action):
                case Ok(body):
                    ok_json("\"session_id\":\"{sid}\",\"result\":{body}")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

# ============================================================================
# Main dispatcher
# ============================================================================

fn main() -> i64:
    val args = get_cli_args()

    if args.len() == 0:
        print_help()
        return 0

    val subcommand = args[0]
    val rest = if args.len() > 1: args[1:] else: []

    match subcommand:
        case "run":
            handle_run(rest)
        case "launch":
            handle_launch(rest)
        case "click":
            handle_click(rest)
        case "fill":
            handle_fill(rest)
        case "type":
            handle_type(rest)
        case "press":
            handle_press(rest)
        case "screenshot":
            handle_screenshot(rest)
        case "evaluate" | "eval":
            handle_evaluate(rest)
        case "close":
            handle_close(rest)
        case "last-trace":
            handle_last_trace(rest)
        case "wm-screenshot":
            handle_wm_screenshot(rest)
        case "wm-list":
            handle_wm_list(rest)
        case "wm-click":
            handle_wm_click(rest)
        case "wm-type":
            handle_wm_type(rest)
        case "wm-press":
            handle_wm_press(rest)
        case "sdl2-connect":
            handle_sdl2_connect(rest)
        case "sdl2-click":
            handle_sdl2_click(rest)
        case "sdl2-fill":
            handle_sdl2_fill(rest)
        case "sdl2-screenshot":
            handle_sdl2_screenshot(rest)
        case "sdl2-elements":
            handle_sdl2_elements(rest)
        case "sdl2-state":
            handle_sdl2_state(rest)
        case "ui-connect":
            handle_sdl2_connect(rest)
        case "ui-snapshot":
            handle_ui_snapshot(rest)
        case "ui-query":
            handle_ui_query(rest)
        case "ui-ensure":
            handle_ui_ensure(rest)
        case "ui-act":
            handle_ui_act(rest)
        case "-h" | "--help" | "help":
            print_help()
            0
        case _:
            error("play", "unknown subcommand '{subcommand}'")
            print ""
            print_help()
            1
