#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# simple play — CLI entry point
#
# Subcommands:
#   simple play run <target>          Phase 1 orchestrator: shell out to
#                                     npm/playwright/vscode-test, writes
#                                     structured results under
#                                     doc/08_tracking/test/play/<ts>/.
#   simple play launch <app>          Phase 2: spawn Electron with CDP,
#                                     print session id to stdout.
#   simple play click <sid> <sel>     Phase 2 session action.
#   simple play fill <sid> <sel> <v>
#   simple play type <sid> <sel> <v>
#   simple play press <sid> <sel> <k>
#   simple play screenshot <sid> [-o path]
#   simple play evaluate <sid> <js>
#   simple play close <sid>
#   simple play wm-screenshot <path>  Native WM shell-out backend.
#   simple play wm-click <x> <y>
#   simple play wm-type <text>
#   simple play wm-list               List native OS windows.
#   simple play last-trace [sid]      Dump the last cdp.log entry.
#
# All subcommands return JSON on stdout (single line) so Claude can parse
# results without having to understand human-formatted output.

use app.io.cli_ops.{cli_get_args}
use std.log.{error}
use app.play.orchestrator.{orchestrator_run}
use app.play.session_store.{
    session_store_init, session_store_save, session_store_load,
    session_store_delete, session_store_list
}
use std.play.types.*
use std.play.launcher.{launcher_launch}
use std.play.cdp.client.{CdpClient}
use std.play.cdp.session.{CdpSession}
use std.play.electron_application.{ElectronApplication}
use std.play.page.{Page}
use std.play.trace.{trace_init, trace_read_cdp}
use std.play.wm.mod.{
    wm_screenshot, wm_list_windows, wm_click, wm_type_text, wm_press, wm_platform
}
use std.play.sdl2_backend.{Sdl2Client}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

fn get_cli_args() -> [text]:
    val all_args = cli_get_args()
    var args = []
    var start_idx = 1
    if all_args.len() > 1 and all_args[1].ends_with("main.spl"):
        start_idx = 2
    elif all_args.len() > 1 and all_args[1] == "play":
        start_idx = 2
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn print_help():
    print "simple play — Playwright-compatible UI automation"
    print ""
    print "Usage:"
    print "  simple play run <dir>                  Orchestrate npm/playwright tests under Xvfb"
    print "  simple play launch <dir>               Launch an Electron app, print session id"
    print "  simple play click <sid> <selector>     Click an element in a session"
    print "  simple play fill <sid> <sel> <value>   Fill a form field"
    print "  simple play type <sid> <sel> <text>    Type text into a field"
    print "  simple play press <sid> <sel> <key>    Press a key in a field"
    print "  simple play screenshot <sid> [-o path] Take a screenshot"
    print "  simple play evaluate <sid> <js>        Evaluate JS in the page"
    print "  simple play close <sid>                Close the session"
    print "  simple play wm-screenshot <path>       Native desktop screenshot"
    print "  simple play wm-list                    List native OS windows"
    print "  simple play wm-click <x> <y>           Native desktop click"
    print "  simple play wm-type <text>             Native keyboard type"
    print "  simple play sdl2-connect <url>          Connect to SDL2 test API"
    print "  simple play sdl2-click <sid> <id>       Click widget in SDL2 app"
    print "  simple play sdl2-fill <sid> <id> <val>  Fill widget in SDL2 app"
    print "  simple play sdl2-screenshot <sid> [-o]  Screenshot SDL2 app"
    print "  simple play sdl2-elements <sid>         List SDL2 widgets"
    print "  simple play sdl2-state <sid>            Get SDL2 app state"
    print "  simple play ui-connect <url>            Connect to any /api/test/* endpoint"
    print "  simple play ui-snapshot <sid>           Canonical UI snapshot"
    print "  simple play ui-query <sid> [flags]      Query canonical nodes"
    print "  simple play ui-ensure <sid> [flags]     Await semantic goal state"
    print "  simple play ui-act <sid> <cid> <act>    Dispatch a canonical action"
    print "  simple play last-trace <sid>           Dump CDP trace log"
    print ""
    print "All subcommands write single-line JSON results to stdout."

# ============================================================================
# Helpers
# ============================================================================

fn emit_json(payload: text):
    print payload

fn ok_json(body: text):
    print "{{\"ok\":true,{body}}}"

fn err_json(code: text, message: text):
    print "{{\"ok\":false,\"code\":\"{code}\",\"message\":\"{_json_escape(message)}\"}}"

fn _json_escape(s: text) -> text:
    var r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    r

# ============================================================================
# Subcommand handlers
# ============================================================================

fn handle_run(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "simple play run requires a target directory")
        return 1
    val target = rest[0]
    val result = orchestrator_run(target, rest)
    match result:
        case Ok(summary):
            emit_json(summary)
            return 0
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_launch(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "simple play launch requires an app path")
        return 1
    var opts = default_launch_options()
    opts.args = rest
    val app_res = ElectronApplication.launch(opts)
    match app_res:
        case Ok(app):
            # First window attach
            val win_res = app.first_window()
            val window_id = match win_res:
                case Ok(p): p.window_id
                case Err(_): ""
            session_store_init()
            session_store_save(app.session)
            val sid = app.session.id
            val art = app.session.artifacts_dir
            val ws = app.session.ws_url
            ok_json("\"session_id\":\"{sid}\",\"artifacts_dir\":\"{art}\",\"ws_url\":\"{ws}\",\"first_window_id\":\"{window_id}\"")
            return 0
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn _reattach(session_id: text) -> Result<(CdpClient, Page, PlaySession), PlayError>:
    val sess_opt = session_store_load(session_id)
    match sess_opt:
        case Some(sess):
            val client = CdpClient.connect(sess.ws_url, 10000)?
            val cdp_sess_res = CdpSession.attach(client, sess.first_window_id)
            val cdp_sess = match cdp_sess_res:
                case Ok(s): s
                case Err(e): return Err(e)
            cdp_sess.enable()?
            val page = Page.from_cdp(cdp_sess, sess.first_window_id, sess.artifacts_dir)
            return Ok((client, page, sess))
        case nil:
            return Err(play_error("NOT_FOUND", "session not found: " + session_id))

fn handle_click(rest: [text]) -> i64:
    if rest.length() < 2:
        err_json("INVALID_ARGUMENT", "click <session_id> <selector>")
        return 1
    val sid = rest[0]
    val selector = rest[1]
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.click(selector)
            client.close()
            match action:
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_fill(rest: [text]) -> i64:
    if rest.length() < 3:
        err_json("INVALID_ARGUMENT", "fill <session_id> <selector> <value>")
        return 1
    val sid = rest[0]
    val selector = rest[1]
    val value = rest[2]
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.fill(selector, value)
            client.close()
            match action:
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_type(rest: [text]) -> i64:
    if rest.length() < 3:
        err_json("INVALID_ARGUMENT", "type <session_id> <selector> <text>")
        return 1
    val sid = rest[0]
    val selector = rest[1]
    val value = rest[2]
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.type_text(selector, value)
            client.close()
            match action:
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_press(rest: [text]) -> i64:
    if rest.length() < 3:
        err_json("INVALID_ARGUMENT", "press <session_id> <selector> <key>")
        return 1
    val sid = rest[0]
    val selector = rest[1]
    val key = rest[2]
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.press(selector, key)
            client.close()
            match action:
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_screenshot(rest: [text]) -> i64:
    if rest.length() < 1:
        err_json("INVALID_ARGUMENT", "screenshot <session_id> [-o path]")
        return 1
    val sid = rest[0]
    var path = ""
    var i = 1
    while i < rest.length():
        if rest[i] == "-o" and i + 1 < rest.length():
            path = rest[i + 1]
            i = i + 2
        else:
            i = i + 1
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.screenshot(path)
            client.close()
            match action:
                case Ok(final_path):
                    ok_json("\"session_id\":\"{sid}\",\"path\":\"{_json_escape(final_path)}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_evaluate(rest: [text]) -> i64:
    if rest.length() < 2:
        err_json("INVALID_ARGUMENT", "evaluate <session_id> <js>")
        return 1
    val sid = rest[0]
    val js = rest[1]
    val r = _reattach(sid)
    match r:
        case Ok(t):
            val (client, page, sess) = t
            val action = page.evaluate(js)
            client.close()
            match action:
                case Ok(body):
                    ok_json("\"session_id\":\"{sid}\",\"result\":\"{_json_escape(body)}\"")
                    return 0
                case Err(e):
                    err_json(e.code, e.message)
                    return 1
        case Err(e):
            err_json(e.code, e.message)
            return 1

fn handle_close(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "close <session_id>")
        return 1
    val sid = rest[0]
    val sess_opt = session_store_load(sid)
    match sess_opt:
        case Some(sess):
            session_store_delete(sid)
            ok_json("\"session_id\":\"{sid}\"")
            0
        case nil:
            err_json("NOT_FOUND", "session not found: " + sid)
            1

fn handle_last_trace(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "last-trace <session_id>")
        return 1
    val sid = rest[0]
    val log = trace_read_cdp(sid)
    ok_json("\"session_id\":\"{sid}\",\"log\":\"{_json_escape(log)}\"")
    0

# ============================================================================
# Native WM subcommands
# ============================================================================

fn handle_wm_screenshot(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "wm-screenshot <path>")
        return 1
    val path = rest[0]
    match wm_screenshot(path):
        case Ok(p):
            ok_json("\"path\":\"{_json_escape(p)}\",\"platform\":\"{wm_platform()}\"")
            0
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_wm_list(rest: [text]) -> i64:
    match wm_list_windows():
        case Ok(wins):
            var parts: [text] = []
            for w in wins:
                parts.push("{{\"id\":\"{w.window_id}\",\"title\":\"{_json_escape(w.title)}\"}}")
            val arr = "[" + parts.join(",") + "]"
            ok_json("\"platform\":\"{wm_platform()}\",\"windows\":{arr}")
            0
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_wm_click(rest: [text]) -> i64:
    if rest.length() < 2:
        err_json("INVALID_ARGUMENT", "wm-click <x> <y>")
        return 1
    val x = int(rest[0])
    val y = int(rest[1])
    match wm_click(x, y):
        case Ok(_):
            ok_json("\"x\":{x},\"y\":{y}")
            0
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_wm_type(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "wm-type <text>")
        return 1
    val text_value = rest[0]
    match wm_type_text(text_value):
        case Ok(_):
            ok_json("\"length\":{text_value.length()}")
            0
        case Err(e):
            err_json(e.code, e.message)
            1

# ============================================================================
# SDL2 backend subcommands
# ============================================================================

fn handle_sdl2_connect(rest: [text]) -> i64:
    if rest.length() == 0:
        err_json("INVALID_ARGUMENT", "sdl2-connect <base_url>")
        return 1
    val base_url = rest[0]
    val client_res = Sdl2Client.connect(base_url)
    match client_res:
        case Ok(client):
            session_store_init()
            session_store_save(client.session)
            val sid = client.session.id
            ok_json("\"session_id\":\"{sid}\",\"base_url\":\"{_json_escape(base_url)}\"")
            0
        case Err(e):
            err_json(e.code, e.message)
            1

fn _sdl2_client(session_id: text) -> Result<Sdl2Client, PlayError>:
    val sess_opt = session_store_load(session_id)
    match sess_opt:
        case Some(sess):
            if sess.backend != "sdl2":
                return Err(play_error("WRONG_BACKEND", "session is not SDL2: " + sess.backend))
            Sdl2Client.connect(sess.http_url)
        case nil:
            Err(play_error("NOT_FOUND", "session not found: " + session_id))

fn handle_sdl2_click(rest: [text]) -> i64:
    if rest.length() < 2:
        err_json("INVALID_ARGUMENT", "sdl2-click <session_id> <widget_id>")
        return 1
    val sid = rest[0]
    val widget_id = rest[1]
    match _sdl2_client(sid):
        case Ok(client):
            match client.click(widget_id):
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

fn handle_sdl2_fill(rest: [text]) -> i64:
    if rest.length() < 3:
        err_json("INVALID_ARGUMENT", "sdl2-fill <session_id> <widget_id> <value>")
        return 1
    val sid = rest[0]
    val widget_id = rest[1]
    val value = rest[2]
    match _sdl2_client(sid):
        case Ok(client):
            match client.fill(widget_id, value):
                case Ok(_):
                    ok_json("\"session_id\":\"{sid}\"")
                    0
                case Err(e):
                    err_json(e.code, e.message)
                    1
        case Err(e):
            err_json(e.code, e.message)
            1

