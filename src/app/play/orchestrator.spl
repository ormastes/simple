#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# app.play.orchestrator — Phase 1 subprocess wrapper
#
# `simple play run <dir>` detects the kind of project and shells out to the
# right existing toolchain (npm test / npx playwright test / vscode-test),
# auto-wrapping in xvfb-run on Linux when DISPLAY is unset. It captures
# stdout/stderr to artifact files and returns a JSON summary for Claude.
#
# Detection order (highest priority first):
#   1. <dir>/.vscode-test.mjs            → vscode extension tests
#   2. <dir>/playwright.config.{js,ts}   → playwright tests
#   3. <dir>/package.json                → `npm test`
#
# All runs go through std.play.xvfb.wrap_cmd on Linux.

use std.play.types.*
use std.play.xvfb.{wrap_cmd}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

val ARTIFACTS_ROOT = "doc/08_tracking/test/play"

fn _json_escape_for_summary(s: text) -> text:
    var r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    r

# ----------------------------------------------------------------------------
# Detection
# ----------------------------------------------------------------------------

struct DetectedTarget:
    kind: text         # "vscode", "playwright", "npm", "unknown"
    command: text
    args: [text]

fn _detect_target(target_dir: text) -> DetectedTarget:
    if rt_file_exists("{target_dir}/.vscode-test.mjs"):
        return DetectedTarget(kind: "vscode", command: "npx", args: ["vscode-test"])
    if rt_file_exists("{target_dir}/playwright.config.js") or rt_file_exists("{target_dir}/playwright.config.ts") or rt_file_exists("{target_dir}/playwright.config.mjs"):
        return DetectedTarget(kind: "playwright", command: "npx", args: ["playwright", "test"])
    if rt_file_exists("{target_dir}/package.json"):
        return DetectedTarget(kind: "npm", command: "npm", args: ["test"])
    DetectedTarget(kind: "unknown", command: "", args: [])

# ----------------------------------------------------------------------------
# Output parsing (best-effort, lives in stdout/stderr)
# ----------------------------------------------------------------------------

fn _count_matches(haystack: text, needle: text) -> i64:
    if needle == "": return 0
    val parts = haystack.split(needle)
    parts.length() - 1

fn _extract_number_before(haystack: text, needle: text) -> i64:
    """Scan for `<digits> <needle>` pattern (e.g. "5 passing").
    Uses .split() to find the needle, then extracts the trailing number
    from the preceding segment."""
    if not haystack.contains(needle): return -1
    val parts = haystack.split(needle)
    if parts.length() < 2: return -1
    val before = parts[0].trim()
    # Extract trailing digits: split on spaces, take last token
    val words = before.split(" ")
    if words.length() == 0: return -1
    val last_word = words[words.length() - 1].trim()
    if last_word == "": return -1
    # Also handle newline-separated: split on newline and take last
    val lines = last_word.split("\n")
    val candidate = lines[lines.length() - 1].trim()
    if candidate == "": return -1
    # Verify it looks like a number (contains only digits)
    val cleaned = candidate.replace("0", "").replace("1", "").replace("2", "").replace("3", "").replace("4", "").replace("5", "").replace("6", "").replace("7", "").replace("8", "").replace("9", "")
    if cleaned != "": return -1
    int(candidate)

fn _guess_pass_fail(stdout: text, stderr: text, exit_code: i64) -> (i64, i64):
    val combined = stdout + "\n" + stderr
    var passed = _extract_number_before(combined, "passing")
    var failed = _extract_number_before(combined, "failing")
    if passed < 0:
        passed = _extract_number_before(combined, "passed")
    if failed < 0:
        failed = _extract_number_before(combined, "failed")
    if passed < 0: passed = 0
    if failed < 0:
        failed = if exit_code == 0: 0 else: 1
    (passed, failed)

# ----------------------------------------------------------------------------
# Main entry point
# ----------------------------------------------------------------------------

fn _make_artifacts_dir() -> text:
    val ts = rt_time_now_unix_micros()
    val dir = "{ARTIFACTS_ROOT}/orch-{ts}"
    rt_mkdir_p(dir)
    dir

fn _write_summary(dir: text, target_dir: text, kind: text, cmd: text, args: [text], stdout: text, stderr: text, exit_code: i64, passed: i64, failed: i64, duration_ms: i64):
    rt_file_write_text("{dir}/stdout.log", stdout)
    rt_file_write_text("{dir}/stderr.log", stderr)
    var arg_parts: [text] = []
    for a in args:
        arg_parts.push("\"{a}\"")
    val arg_list = arg_parts.join(" ")
    val body =
        "# orchestrator run summary (SDN format)\n" +
        "target_dir: \"{target_dir}\"\n" +
        "kind: \"{kind}\"\n" +
        "command: \"{cmd}\"\n" +
        "args: [{arg_list}]\n" +
        "exit_code: {exit_code}\n" +
        "passed: {passed}\n" +
        "failed: {failed}\n" +
        "duration_ms: {duration_ms}\n"
    rt_file_write_text("{dir}/summary.sdn", body)

fn orchestrator_run(target_dir: text, _rest: [text]) -> Result<text, PlayError>:
    if not rt_file_exists(target_dir):
        return Err(play_error_with_detail(ERR_NOT_FOUND, "target directory not found", target_dir))

    val detected = _detect_target(target_dir)
    if detected.kind == "unknown":
        return Err(play_error_with_detail(
            ERR_INVALID_ARGUMENT,
            "could not detect test runner; need .vscode-test.mjs, playwright.config.*, or package.json",
            target_dir))

    val art_dir = _make_artifacts_dir()

    # Build full command: cd into target dir, then run detected command.
    # Because rt_process_run does not set cwd we use `sh -c 'cd <dir> && <cmd>'`.
    var inner_parts: [text] = [detected.command]
    for a in detected.args:
        inner_parts.push(a)
    val inner_cmd = inner_parts.join(" ")
    val shell_line = "cd " + target_dir + " && " + inner_cmd

    # Xvfb-wrap on Linux without DISPLAY.
    val (cmd, wrapped_args) = wrap_cmd("sh", ["-c", shell_line])

    val start = rt_time_now_unix_micros()
    val result = rt_process_run(cmd, wrapped_args)
    val end = rt_time_now_unix_micros()
    val duration_ms = (end - start) / 1000

    val stdout = result.0
    val stderr = result.1
    val exit_code = result.2

    val (passed, failed) = _guess_pass_fail(stdout, stderr, exit_code)

    _write_summary(art_dir, target_dir, detected.kind, detected.command, detected.args,
                   stdout, stderr, exit_code, passed, failed, duration_ms)

    val summary =
        "\"target_dir\":\"{_json_escape_for_summary(target_dir)}\"" +
        ",\"kind\":\"{detected.kind}\"" +
        ",\"exit_code\":{exit_code}" +
        ",\"passed\":{passed}" +
        ",\"failed\":{failed}" +
        ",\"duration_ms\":{duration_ms}" +
        ",\"artifacts_dir\":\"{_json_escape_for_summary(art_dir)}\"" +
        ",\"stdout_path\":\"{_json_escape_for_summary(art_dir)}/stdout.log\"" +
        ",\"stderr_path\":\"{_json_escape_for_summary(art_dir)}/stderr.log\""
    Ok("{{\"ok\":true,{summary}}}")
