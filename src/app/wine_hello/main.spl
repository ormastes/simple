use common.wine_hello_exe.{wine_hello_exe_probe_manifest_evidence}
use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes, wine_hello_fixture_execution_evidence_struct, wine_hello_fixture_precondition_manifest}

extern fn stdout_write(data: text)

fn main() -> i64:
    val result = wine_hello_exe_probe_manifest_evidence(wine_known_hello_exe_fixture_bytes(), wine_hello_fixture_precondition_manifest(), wine_hello_fixture_execution_evidence_struct())
    if result.status == "executed":
        stdout_write(result.stdout)
        return result.exit_code
    print "wine-hello failed: {result.status}:{result.error}"
    1
