# Utils Module
#
# General utility functions and helpers for the Simple toolchain.
#
# Public API:
#   - use app.utils.{common utility functions}

# All submodules are automatically available.

# Re-exported from colors.spl
export esc_char, reset, bold, dim, underline
export black, red, green, yellow, blue, magenta, cyan, white
export bg_black, bg_red, bg_green, bg_yellow, bg_blue, bg_magenta, bg_cyan, bg_white
export success, error, warning, info, debug
export colorize, strip_colors

# Re-exported from markdown.spl
export MarkdownBuilder, heading, bold, italic, code, code_block
export link, bullet_list, numbered_list, table, horizontal_rule

# Re-exported from parsing.spl
export extract_section, extract_sections, parse_key_value, parse_table
export split_lines, trim_lines, filter_empty, filter_comments
export indent_level, strip_indent, normalize_indent

# Re-exported from text_replace.spl
export find_pattern, find_all_patterns, replace_pattern, replace_all
export extract_function_name, extract_identifiers
export count_matches, has_pattern
