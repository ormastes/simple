"""
# sj client-facing jj command builder
"""

use std.io_runtime

fn is_read_bypass(argv: [text]) -> bool:
    val key = if argv.len() > 2i64 and argv[1i64] == "op":
        "op " + argv[2i64]
    else if argv.len() > 2i64 and argv[1i64] == "file":
        "file " + argv[2i64]
    else if argv.len() > 2i64 and argv[1i64] == "bookmark":
        "bookmark " + argv[2i64]
    else if argv.len() > 2i64 and argv[1i64] == "config":
        "config " + argv[2i64]
    else if argv.len() > 1i64:
        argv[1i64]
    else:
        ""
    key == "log" or
    key == "status" or
    key == "diff" or
    key == "show" or
    key == "op log" or
    key == "op show" or
    key == "evolog" or
    key == "file annotate" or
    key == "file list" or
    key == "file show" or
    key == "bookmark list" or
    key == "config list"

fn inject_flags(argv: [text]) -> [text]:
    if argv.len() == 0i64 or argv[0i64] != "jj":
        return argv
    var out: [text] = ["jj"]
    if is_read_bypass(argv):
        out.push("--ignore-working-copy")
    out.push("--no-pager")
    out.push("--color")
    out.push("never")
    var i = 1i64
    while i < argv.len():
        out.push(argv[i])
        i = i + 1i64
    out

fn build_command(argv: [text]) -> text:
    inject_flags(argv).join(" ")
