"""
# sj CLI parser
"""

use std.io_runtime

struct CliCommand:
    argv: [text]
    mode: text

fn parse_cli(argv: [text]) -> CliCommand:
    if argv.len() > 0i64 and argv[0i64] == "daemon":
        return CliCommand(argv: argv, mode: "daemon")
    if argv.len() > 1i64 and argv[0i64] == "raw":
        return CliCommand(argv: argv, mode: "raw")
    if argv.len() > 1i64 and argv[0i64] == "git":
        return CliCommand(argv: argv, mode: "git")
    CliCommand(argv: argv, mode: "jj")
