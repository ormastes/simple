"""
# sj client-facing policy helpers
"""

use std.io_runtime
use app.sj_daemon.forbidden
use app.sj_daemon.submodule_policy

fn policy_allow() -> PolicyResult:
    PolicyResult(allowed: true, exit_code: 0i64, message: "")

fn policy_forbid(message: text) -> PolicyResult:
    PolicyResult(allowed: false, exit_code: 1i64, message: message)

fn check_forbidden(argv: [text]) -> PolicyResult:
    forbidden.check_forbidden(argv)

fn classify_submodule(argv: [text]) -> SubmodulePlan:
    if argv.len() < 3i64:
        return SubmodulePlan(is_submodule: false, lease_kind: 0i64, warning: "", auto_pin_cmd: "")
    if argv[0i64] != "git" or argv[1i64] != "submodule":
        return SubmodulePlan(is_submodule: false, lease_kind: 0i64, warning: "", auto_pin_cmd: "")
    if argv[2i64] == "add":
        val path = if argv.len() > 4i64:
            argv[4i64]
        else:
            "submodule"
        return SubmodulePlan(
            is_submodule: true,
            lease_kind: 0i64,
            warning: "WARN[SUBMODULE]: submodule add is pinned immediately to preserve the gitlink in jj-managed repos",
            auto_pin_cmd: "git commit --no-verify -m 'chore: pin submodule {path}'"
        )
    if argv[2i64] == "status":
        return SubmodulePlan(
            is_submodule: true,
            lease_kind: 1i64,
            warning: "",
            auto_pin_cmd: ""
        )
    SubmodulePlan(is_submodule: true, lease_kind: 0i64, warning: "", auto_pin_cmd: "")
