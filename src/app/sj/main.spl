"""
# sj main
"""

use std.io_runtime
use app.sj.client
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_cli_get_args() -> [text]

fn main() -> i64:
    val raw_args = sj_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("sj", log_opts.error)
        return 1

    val argv = sj_clean_args(raw_args)
    if argv.len() > 0i64 and (argv[0i64] == "--help" or argv[0i64] == "-h" or argv[0i64] == "help"):
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print(progress)
        sj_print_usage()
        return 0

    if raw_args.len() > 0i64 and argv.len() == 0i64:
        if log_opts.log_mode == "json":
            print("{\"command\":\"sj\",\"status\":\"usage\"}")
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print(progress)
            return 0

    val client = sj_client_new(".", 120000i64)
    val result = exec_args(client, argv)
    if result.stdout.len() > 0i64:
        print(result.stdout)
    if result.stderr.len() > 0i64:
        eprint(result.stderr)
    result.exit_code

fn sj_print_usage():
    print("Usage: sj <jj-command> [args]")
    print("       sj git <git-command> [args]")
    print("       sj raw <jj|git> [args]")
    print("")
    print("Shared log options:")
    for line in log_options_help():
        print("  {line}")

fn sj_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn sj_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if sj_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn sj_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_sj = false
    var i = 0
    while i < all_args.len():
        if found_sj:
            args.push(all_args[i])
        elif all_args[i] == "sj":
            found_sj = true
        i = i + 1
    if found_sj:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("main.spl"):
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
