# SPipe process harness CLI.

use std.cli.cli_util (get_cli_args)
use std.nogc_async_mut.llm_diagnostics.hook_handler.{read_hook_stdin, extract_str}
use std.nogc_async_mut.llm_diagnostics.exporters.file_exporter.{append_raw_jsonl}
use std.nogc_async_mut.spipe_process_harness.core.{
    normalize_provider, state_path, event_log_path, hook_jsonl,
    gate_from_state, render_state, render_hud, deploy_snippets
}
use std.nogc_async_mut.spipe_process_harness.types.{HudSnapshot}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_env_get(name: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn main() -> i64:
    val args = clean_args()
    if args.len() == 0 or args[0] == "help" or args[0] == "--help":
        print_usage()
        return 0
    val action = args[0]
    if action == "state":
        return write_state(args)
    if action == "hook":
        return run_hook(args)
    if action == "gate":
        return run_gate(args)
    if action == "hud":
        return run_hud(args)
    if action == "deploy":
        return run_deploy()
    print_usage()
    2

fn clean_args() -> [text]:
    val raw = get_cli_args()
    var out: [text] = []
    var i = 0
    if raw.len() > 0 and raw[0] == "spipe-process-harness":
        i = 1
    while i < raw.len():
        out.push(raw[i])
        i = i + 1
    out

fn option(args: [text], name: text, default_value: text) -> text:
    var i = 0
    while i < args.len():
        if args[i] == name and i + 1 < args.len():
            return args[i + 1]
        if args[i].starts_with(name + "="):
            return args[i].slice(name.len() + 1, args[i].len())
        i = i + 1
    default_value

fn has_flag(args: [text], name: text) -> bool:
    for arg in args:
        if arg == name:
            return true
    false

fn write_state(args: [text]) -> i64:
    val feature = option(args, "--feature", "spipe-process-harness")
    val request = option(args, "--request", "SPipe production-level process harness")
    val goal = option(args, "--goal", "Common hook, deploy, HUD, and prevention infra for Codex, Claude, and Gemini")
    val approved = has_flag(args, "--approved")
    val path = state_path(feature)
    rt_dir_create(".spipe", true)
    rt_dir_create(".spipe/{feature}", true)
    if rt_file_write_text(path, render_state(feature, request, goal, approved)):
        print path
        return 0
    1

fn run_hook(args: [text]) -> i64:
    val provider = normalize_provider(option(args, "--provider", rt_env_get("SPIPE_PROVIDER")))
    val feature = option(args, "--feature", rt_env_get("SPIPE_FEATURE"))
    val require_approval = rt_env_get("SPIPE_REQUIRE_APPROVAL") == "1" or has_flag(args, "--require-approval")
    val payload = read_hook_stdin()
    val event = first_non_empty(extract_str(payload, "hook_event_name"), extract_str(payload, "event"))
    val session_id = first_non_empty(extract_str(payload, "session_id"), rt_env_get("SPIPE_SESSION_ID"))
    val model = first_non_empty(extract_str(payload, "model"), rt_env_get("SPIPE_MODEL"))
    val state = if rt_file_exists(state_path(feature)): rt_file_read_text(state_path(feature)) else: ""
    val gate = gate_from_state(state, require_approval)
    rt_dir_create(".spipe", true)
    rt_dir_create(".spipe/{feature_or_default(feature)}", true)
    append_raw_jsonl(event_log_path(feature), hook_jsonl(provider, event, session_id, model, payload))
    if not gate.allowed:
        print gate.reason
    gate.exit_code

fn run_gate(args: [text]) -> i64:
    val feature = option(args, "--feature", "spipe-process-harness")
    val require_approval = not has_flag(args, "--no-approval")
    val state = if rt_file_exists(state_path(feature)): rt_file_read_text(state_path(feature)) else: ""
    val gate = gate_from_state(state, require_approval)
    print gate.reason
    gate.exit_code

fn run_hud(args: [text]) -> i64:
    val model = first_non_empty(option(args, "--model", ""), rt_env_get("SPIPE_MODEL"))
    val hours = first_non_empty(option(args, "--hr", ""), rt_env_get("SPIPE_HOURS_REMAINING"))
    val week = first_non_empty(option(args, "--week", ""), rt_env_get("SPIPE_WEEK_REMAINING"))
    val goal = first_non_empty(option(args, "--goal", ""), rt_env_get("SPIPE_GOAL"))
    val jj = jj_line(["status", "--no-pager"])
    val commit = jj_line(["log", "--no-pager", "-r", "@", "-T", "change_id.short() ++ \" \" ++ description.first_line()"])
    val snap = HudSnapshot(
        model: if model == "": "unknown" else: model,
        jj_worktree: compact(jj),
        commit_id: compact(commit),
        hours_remaining: if hours == "": "unknown" else: hours,
        week_remaining: if week == "": "unknown" else: week,
        goal: if goal == "": "unset" else: goal
    )
    print render_hud(snap)
    0

fn run_deploy() -> i64:
    rt_dir_create(".spipe", true)
    rt_dir_create(".spipe/hook-deploy", true)
    for snippet in deploy_snippets():
        rt_file_write_text(snippet.path, snippet.content)
        print snippet.path
    0

fn jj_line(args: [text]) -> text:
    val (out, err, code) = rt_process_run("jj", args)
    if code == 0:
        return out
    err

fn first_non_empty(a: text, b: text) -> text:
    if a != "":
        return a
    return b

fn feature_or_default(feature: text) -> text:
    if feature.trim() == "":
        return "spipe-process-harness"
    return feature.trim()

fn compact(value: text) -> text:
    val line = value.trim().split("\n")
    if line.len() == 0 or line[0] == "":
        return "unknown"
    return line[0].trim()

fn print_usage():
    print "Usage: simple spipe-process-harness <state|hook|gate|hud|deploy> [options]"
    print "  state --feature <slug> --approved"
    print "  hook --provider <codex|claude|gemini> [--feature <slug>] [--require-approval]"
    print "  gate --feature <slug>"
    print "  hud [--model M] [--hr N] [--week N] [--goal text]"
    print "  deploy"
