# UI Theme Colors
#
# Extends ui.render.ansi with UI-specific theme colors.
# Provides per-widget color roles for both dark and light themes.

use app.ui.render.ansi.{RESET, BOLD, DIM, CYAN, WHITE, BLUE, YELLOW, GREEN, RED,
    BRIGHT_WHITE, BRIGHT_CYAN, BRIGHT_BLUE, BRIGHT_GREEN, BRIGHT_YELLOW, BRIGHT_RED,
    BRIGHT_MAGENTA, MAGENTA, BRIGHT_BLACK,
    colorize, fg_256}

# =========================================================================
# Theme Color Palettes
# =========================================================================

fn get_theme_color(theme: text, role: text) -> text:
    """Get a color for a specific role in the given theme.

    Supports general roles (border, text, accent) plus per-widget roles
    (button, checkbox, input, progress, tab, list, dialog, etc.).
    """
    if theme == "dark":
        return get_dark_theme_color(role)
    else:
        return get_light_theme_color(role)

fn get_dark_theme_color(role: text) -> text:
    """Dark theme color mapping."""
    match role:
        # General roles
        "border" => DIM
        "border_focused" => BRIGHT_CYAN
        "title" => BOLD
        "text" => WHITE
        "text_dim" => DIM
        "accent" => CYAN
        "status_bg" => BLUE
        "menu_bg" => DIM
        "error" => RED
        "success" => GREEN
        "warning" => YELLOW
        # Button roles
        "button" => BRIGHT_CYAN
        "button_focused" => "{BOLD}{BRIGHT_CYAN}"
        # Checkbox roles
        "checkbox" => WHITE
        "checkbox_checked" => BRIGHT_GREEN
        # Input roles
        "input" => DIM
        "input_focused" => BRIGHT_WHITE
        # Progress bar roles
        "progress_fill" => BRIGHT_GREEN
        "progress_empty" => DIM
        # Tab roles
        "tab_active" => BOLD
        "tab_inactive" => DIM
        # List roles
        "list_selected" => BRIGHT_CYAN
        "list_item" => WHITE
        # Dialog roles
        "dialog_border" => BRIGHT_MAGENTA
        # State roles
        "disabled" => BRIGHT_BLACK
        "error_fg" => BRIGHT_RED
        "error_border" => RED
        "readonly" => DIM
        "required_indicator" => BRIGHT_RED
        # Agent roles (LLM Dashboard)
        "agent_claude" => fg_256(208)
        "agent_codex" => fg_256(34)
        "agent_gemini" => fg_256(33)
        "agent_thinking" => BRIGHT_YELLOW
        "agent_reading" => BRIGHT_CYAN
        "agent_writing" => BRIGHT_GREEN
        "agent_searching" => BRIGHT_MAGENTA
        "agent_idle" => DIM
        "agent_error" => BRIGHT_RED
        "room_research" => fg_256(141)
        "room_code" => fg_256(114)
        "room_skills" => fg_256(220)
        "room_server" => fg_256(75)
        "room_chat" => fg_256(180)
        "room_testlab" => fg_256(168)
        _ => RESET

fn get_light_theme_color(role: text) -> text:
    """Light theme color mapping."""
    match role:
        # General roles
        "border" => DIM
        "border_focused" => BLUE
        "title" => BOLD
        "text" => RESET
        "text_dim" => DIM
        "accent" => BLUE
        "status_bg" => BLUE
        "menu_bg" => DIM
        "error" => RED
        "success" => GREEN
        "warning" => YELLOW
        # Button roles
        "button" => BLUE
        "button_focused" => "{BOLD}{BLUE}"
        # Checkbox roles
        "checkbox" => RESET
        "checkbox_checked" => GREEN
        # Input roles
        "input" => DIM
        "input_focused" => RESET
        # Progress bar roles
        "progress_fill" => GREEN
        "progress_empty" => DIM
        # Tab roles
        "tab_active" => BOLD
        "tab_inactive" => DIM
        # List roles
        "list_selected" => BLUE
        "list_item" => RESET
        # Dialog roles
        "dialog_border" => MAGENTA
        # State roles
        "disabled" => DIM
        "error_fg" => RED
        "error_border" => RED
        "readonly" => DIM
        "required_indicator" => RED
        # Agent roles (LLM Dashboard)
        "agent_claude" => fg_256(208)
        "agent_codex" => fg_256(34)
        "agent_gemini" => fg_256(33)
        "agent_thinking" => YELLOW
        "agent_reading" => CYAN
        "agent_writing" => GREEN
        "agent_searching" => MAGENTA
        "agent_idle" => DIM
        "agent_error" => RED
        "room_research" => fg_256(141)
        "room_code" => fg_256(114)
        "room_skills" => fg_256(220)
        "room_server" => fg_256(75)
        "room_chat" => fg_256(180)
        "room_testlab" => fg_256(168)
        _ => RESET
