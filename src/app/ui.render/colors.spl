# UI Theme Colors
#
# Extends dashboard.render.colors with UI-specific theme colors.

use dashboard.render.colors.{RESET, BOLD, DIM, CYAN, WHITE, BLUE, YELLOW, GREEN, RED,
    BRIGHT_WHITE, BRIGHT_CYAN, BRIGHT_BLUE, BRIGHT_GREEN, BRIGHT_YELLOW, BRIGHT_RED,
    colorize}

# =========================================================================
# Theme Color Palettes
# =========================================================================

fn get_theme_color(theme: text, role: text) -> text:
    """Get a color for a specific role in the given theme."""
    if theme == "dark":
        match role:
            "border" => DIM
            "border_focused" => BRIGHT_CYAN
            "title" => BOLD
            "text" => WHITE
            "text_dim" => DIM
            "accent" => CYAN
            "status_bg" => BLUE
            "menu_bg" => DIM
            "error" => RED
            "success" => GREEN
            "warning" => YELLOW
            _ => RESET
    else:
        # Light theme
        match role:
            "border" => DIM
            "border_focused" => BLUE
            "title" => BOLD
            "text" => RESET
            "text_dim" => DIM
            "accent" => BLUE
            "status_bg" => BLUE
            "menu_bg" => DIM
            "error" => RED
            "success" => GREEN
            "warning" => YELLOW
            _ => RESET
