# Shared Progress Bar Rendering
#
# General-purpose progress bar for TUI (ASCII) and HTML output.
# Used by dashboard, office/sheets, llm_dashboard, and other apps.

use app.dashboard.render.colors.{GREEN, YELLOW, RED, DIM, RESET}

# =========================================================================
# Color Helpers
# =========================================================================

# Get progress color based on percentage thresholds
fn progress_color(percent: f64) -> text:
    if percent >= 70.0:
        GREEN
    elif percent >= 30.0:
        YELLOW
    else:
        RED

# Get progress CSS color based on percentage thresholds
fn progress_css_color(percent: f64) -> text:
    if percent >= 70.0:
        "var(--green, #3fb950)"
    elif percent >= 30.0:
        "var(--yellow, #d29922)"
    else:
        "var(--red, #f85149)"

# =========================================================================
# ASCII Progress Bar
# =========================================================================

# Render ASCII progress bar from current/total counts
fn progress_bar(current: i64, total: i64, width: i32) -> text:
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0

    val filled_width = ((percent / 100.0) * (width as f64)) as i32
    val empty_width = width - filled_width

    val color = progress_color(percent)

    # Build bar
    var bar = "["
    for i in 0..filled_width:
        bar = "{bar}="
    for i in 0..empty_width:
        bar = "{bar} "
    bar = "{bar}]"

    return "{color}{bar}{RESET} {percent}%"

# =========================================================================
# HTML Progress Bar
# =========================================================================

# Render HTML progress bar from current/total counts
fn progress_bar_html(current: i64, total: i64) -> text:
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0

    val color = progress_css_color(percent)
    val width_pct = if percent > 100.0: 100.0 else: percent
    val label = "{current}/{total}"

    var h = "<div style=\"margin-top:4px\">"
    h = "{h}<div style=\"display:flex;justify-content:space-between;font-size:12px;color:var(--text-dim,#8b949e);margin-bottom:2px\"><span>{label}</span><span>{percent}%</span></div>"
    h = "{h}<div style=\"height:6px;background:var(--border,#30363d);border-radius:3px;overflow:hidden\">"
    h = "{h}<div style=\"height:100%;width:{width_pct}%;background:{color};border-radius:3px\"></div>"
    h = "{h}</div></div>"
    h

# =========================================================================
# Percentage / Fraction Display
# =========================================================================

# Formatted percentage string with color
fn percentage(current: i64, total: i64) -> text:
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0

    val color = progress_color(percent)
    return "{color}{percent}%{RESET}"

# Fraction display "current/total" with color
fn fraction(current: i64, total: i64) -> text:
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0

    val color = progress_color(percent)
    return "{color}{current}/{total}{RESET}"

# HTML fraction display
fn fraction_html(current: i64, total: i64) -> text:
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0
    val color = progress_css_color(percent)
    "<span style=\"color:{color}\">{current}/{total}</span>"

# =========================================================================
# Exports
# =========================================================================
