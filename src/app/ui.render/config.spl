# UI Render Config Layer
#
# Config precedence logic for the render feature caret.
# Layers (lowest to highest priority):
#   1. Code defaults  (RenderConfig.default())
#   2. Feature config  (from .ui.sdn file metadata, when available)
#   3. Environment variables  (SIMPLE_RENDER_*)
#   4. CLI flags  (already baked into the incoming cli_config)
#
# The parser layer produces a config with CLI flags already applied over
# defaults. This layer fills in any remaining gaps from env vars and
# feature-config metadata.

use app.ui.render.types.{RenderConfig}

extern fn rt_env_get(key: text) -> text

# =========================================================================
# Public API
# =========================================================================

fn resolve_config(cli_config: RenderConfig) -> RenderConfig:
    """Apply full precedence chain and return the resolved config.

    The incoming cli_config already has code-defaults + CLI overrides.
    This function layers env-var and feature-config fallbacks underneath.
    """
    var config = cli_config

    # --- Layer 2: feature config from .ui.sdn metadata ---
    # If the asset file provides embedded config hints we could read them
    # here.  For now we apply sensible feature-level defaults only when the
    # CLI left the field at its default sentinel.
    config = apply_feature_defaults(config)

    # --- Layer 3: environment variable fallbacks ---
    config = apply_env_vars(config)

    return config

# =========================================================================
# Internal helpers
# =========================================================================

fn apply_feature_defaults(config: RenderConfig) -> RenderConfig:
    """Apply feature-level defaults from .ui.sdn metadata.

    Currently a pass-through; will be extended when the .ui.sdn loader
    exposes per-feature render hints.
    """
    return config

fn apply_env_vars(config: RenderConfig) -> RenderConfig:
    """Fill unset fields from SIMPLE_RENDER_* environment variables."""
    var result = config

    val env_format = rt_env_get("SIMPLE_RENDER_FORMAT")
    if env_format.len() > 0 and result.format == "text":
        result.format = env_format

    val env_theme = rt_env_get("SIMPLE_RENDER_THEME")
    if env_theme.len() > 0 and result.theme == "dark":
        result.theme = env_theme

    val env_adapter = rt_env_get("SIMPLE_RENDER_ADAPTER")
    if env_adapter.len() > 0 and result.adapter_name == "":
        result.adapter_name = env_adapter

    val env_backend = rt_env_get("SIMPLE_RENDER_BACKEND")
    if env_backend.len() > 0 and result.backend == "auto":
        result.backend = env_backend

    val env_width = rt_env_get("SIMPLE_RENDER_WIDTH")
    if env_width.len() > 0 and result.width == 80:
        result.width = env_width.to_int()

    val env_height = rt_env_get("SIMPLE_RENDER_HEIGHT")
    if env_height.len() > 0 and result.height == 24:
        result.height = env_height.to_int()

    return result
