# UI Render Export Layer
#
# Utilities for exporting a RenderResult to text, HTML, or a file on disk.

use app.ui.render.types.{RenderResult}

extern fn rt_file_write_text(path: text, content: text) -> bool

# =========================================================================
# Public API
# =========================================================================

fn export_text(result: RenderResult) -> text:
    """Return the text representation of a render result.

    When the result format is "both", prefer the text output.
    Falls back to an empty string when no text content is available.
    """
    if result.text_output.len() > 0:
        return result.text_output
    return ""

fn export_html(result: RenderResult) -> text:
    """Return the HTML representation of a render result.

    When the result format is "both", prefer the html output.
    Falls back to an empty string when no HTML content is available.
    """
    if result.html_output.len() > 0:
        return result.html_output
    return ""

fn export_to_file(result: RenderResult, path: text):
    """Write the render result to a file at the given path.

    Chooses content based on the result format:
      - "html"  -> writes html_output
      - "both"  -> writes text + separator + html
      - default -> writes text_output
    """
    var content = ""
    match result.format:
        "html" =>
            content = result.html_output
        "both" =>
            content = result.text_output + "\n---\n" + result.html_output
        _ =>
            content = result.text_output

    rt_file_write_text(path, content)
