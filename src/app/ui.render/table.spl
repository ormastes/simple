# Shared Table Rendering
#
# General-purpose table builder for TUI (ASCII) and HTML output.
# Used by dashboard, office/sheets, llm_dashboard, and other apps.

use dashboard.render.colors.{BOLD, RESET, DIM}

# =========================================================================
# Column Alignment
# =========================================================================

val ALIGN_LEFT: i32 = 0
val ALIGN_RIGHT: i32 = 1
val ALIGN_CENTER: i32 = 2

# =========================================================================
# Table Builder
# =========================================================================

class TableBuilder:
    headers: [text]
    rows: [[text]]
    column_widths: [i32]
    alignments: [i32]
    max_widths: [i32]
    use_borders: bool
    sort_column: i32
    sort_ascending: bool

    static fn new(headers: [text]) -> TableBuilder:
        var aligns: [i32] = []
        var maxw: [i32] = []
        for h in headers:
            aligns.append(ALIGN_LEFT)
            maxw.append(0)
        return TableBuilder {
            headers: headers,
            rows: [],
            column_widths: [],
            alignments: aligns,
            max_widths: maxw,
            use_borders: true,
            sort_column: -1,
            sort_ascending: true
        }

    # Add a row
    fn add_row(row: [text]) -> TableBuilder:
        var new_rows = self.rows
        new_rows.append(row)
        return TableBuilder {
            headers: self.headers,
            rows: new_rows,
            column_widths: self.column_widths,
            alignments: self.alignments,
            max_widths: self.max_widths,
            use_borders: self.use_borders,
            sort_column: self.sort_column,
            sort_ascending: self.sort_ascending
        }

    # Set column alignment
    fn set_alignment(column: i32, alignment: i32) -> TableBuilder:
        var new_aligns = self.alignments
        if column < new_aligns.len():
            new_aligns[column] = alignment
        return TableBuilder {
            headers: self.headers,
            rows: self.rows,
            column_widths: self.column_widths,
            alignments: new_aligns,
            max_widths: self.max_widths,
            use_borders: self.use_borders,
            sort_column: self.sort_column,
            sort_ascending: self.sort_ascending
        }

    # Set max width for a column (0 = no limit)
    fn set_max_width(column: i32, width: i32) -> TableBuilder:
        var new_maxw = self.max_widths
        if column < new_maxw.len():
            new_maxw[column] = width
        return TableBuilder {
            headers: self.headers,
            rows: self.rows,
            column_widths: self.column_widths,
            alignments: self.alignments,
            max_widths: new_maxw,
            use_borders: self.use_borders,
            sort_column: self.sort_column,
            sort_ascending: self.sort_ascending
        }

    # Enable/disable box-drawing borders
    fn set_borders(enabled: bool) -> TableBuilder:
        return TableBuilder {
            headers: self.headers,
            rows: self.rows,
            column_widths: self.column_widths,
            alignments: self.alignments,
            max_widths: self.max_widths,
            use_borders: enabled,
            sort_column: self.sort_column,
            sort_ascending: self.sort_ascending
        }

    # Sort by column index
    fn sort_by(column: i32, ascending: bool) -> TableBuilder:
        return TableBuilder {
            headers: self.headers,
            rows: self.rows,
            column_widths: self.column_widths,
            alignments: self.alignments,
            max_widths: self.max_widths,
            use_borders: self.use_borders,
            sort_column: column,
            sort_ascending: ascending
        }

    # Truncate text to max width with ellipsis
    fn truncate_cell(cell: text, max_width: i32) -> text:
        if max_width <= 0:
            return cell
        if cell.len() <= max_width:
            return cell
        if max_width <= 3:
            return cell.slice(0, max_width)
        return "{cell.slice(0, max_width - 3)}..."

    # Calculate column widths
    fn calculate_widths():
        var widths: [i32] = []

        # Initialize with header widths
        for i in 0..self.headers.len():
            var w = self.headers[i].len()
            if i < self.max_widths.len() and self.max_widths[i] > 0:
                if w > self.max_widths[i]:
                    w = self.max_widths[i]
            widths.append(w)

        # Update with row widths
        for row in self.rows:
            for i in 0..row.len():
                if i < widths.len():
                    var cell_len = row[i].len()
                    if i < self.max_widths.len() and self.max_widths[i] > 0:
                        if cell_len > self.max_widths[i]:
                            cell_len = self.max_widths[i]
                    if cell_len > widths[i]:
                        widths[i] = cell_len

        self.column_widths = widths

    # Get sorted rows (simple insertion sort)
    fn get_sorted_rows() -> [[text]]:
        if self.sort_column < 0:
            return self.rows
        var sorted = self.rows
        val col = self.sort_column
        val asc = self.sort_ascending
        # Simple bubble sort for stability
        var swapped = true
        while swapped:
            swapped = false
            for i in 0..(sorted.len() - 1):
                val a = if col < sorted[i].len(): sorted[i][col] else: ""
                val b = if col < sorted[i + 1].len(): sorted[i + 1][col] else: ""
                val should_swap = if asc: a > b else: a < b
                if should_swap:
                    val tmp = sorted[i]
                    sorted[i] = sorted[i + 1]
                    sorted[i + 1] = tmp
                    swapped = true
        return sorted

    # Apply alignment to a cell
    fn align_cell(cell: text, width: i32, alignment: i32) -> text:
        match alignment:
            1 => pad_left(cell, width)
            2 => center(cell, width)
            _ => pad_right(cell, width)

    # Build text table (TUI output)
    fn build() -> text:
        self.calculate_widths()
        val sorted_rows = self.get_sorted_rows()

        var output = ""

        if self.use_borders:
            # Top border
            output = "{output}{self.render_border()}\n"

        # Headers
        output = "{output}{self.render_header()}\n"

        if self.use_borders:
            # Separator
            output = "{output}{self.render_border()}\n"

        # Rows
        for row in sorted_rows:
            output = "{output}{self.render_row(row)}\n"

        if self.use_borders:
            # Bottom border
            output = "{output}{self.render_border()}\n"

        return output

    # Build HTML table
    fn build_html() -> text:
        self.calculate_widths()
        val sorted_rows = self.get_sorted_rows()

        var h = "<table class=\"data-table\">"

        # Headers
        h = "{h}<thead><tr>"
        for i in 0..self.headers.len():
            val align_style = match self.alignments[i]:
                1 => " style=\"text-align:right\""
                2 => " style=\"text-align:center\""
                _ => ""
            h = "{h}<th{align_style}>{self.headers[i]}</th>"
        h = "{h}</tr></thead>"

        # Body
        h = "{h}<tbody>"
        for row in sorted_rows:
            h = "{h}<tr>"
            for i in 0..row.len():
                val cell = if i < self.max_widths.len() and self.max_widths[i] > 0:
                    self.truncate_cell(row[i], self.max_widths[i])
                else:
                    row[i]
                val align_style = if i < self.alignments.len():
                    match self.alignments[i]:
                        1 => " style=\"text-align:right\""
                        2 => " style=\"text-align:center\""
                        _ => ""
                else:
                    ""
                h = "{h}<td{align_style}>{cell}</td>"
            h = "{h}</tr>"
        h = "{h}</tbody></table>"
        return h

    # Render border line
    fn render_border() -> text:
        var line = "+"
        for width in self.column_widths:
            line = "{line}-"
            for i in 0..width:
                line = "{line}-"
            line = "{line}-+"
        return line

    # Render header row
    fn render_header() -> text:
        var line = if self.use_borders: "|" else: ""
        val sep = if self.use_borders: " |" else: "  "
        val pre = if self.use_borders: " " else: ""
        for i in 0..self.headers.len():
            val header = self.truncate_cell(self.headers[i], self.max_widths[i])
            val width = self.column_widths[i]
            val aligned = self.align_cell(header, width, self.alignments[i])
            line = "{line}{pre}{BOLD}{aligned}{RESET}{sep}"
        return line

    # Render data row
    fn render_row(row: [text]) -> text:
        var line = if self.use_borders: "|" else: ""
        val sep = if self.use_borders: " |" else: "  "
        val pre = if self.use_borders: " " else: ""
        for i in 0..row.len():
            val cell = self.truncate_cell(row[i], if i < self.max_widths.len(): self.max_widths[i] else: 0)
            val width = self.column_widths[i]
            val alignment = if i < self.alignments.len(): self.alignments[i] else: ALIGN_LEFT
            val aligned = self.align_cell(cell, width, alignment)
            line = "{line}{pre}{aligned}{sep}"
        return line

# =========================================================================
# Helper Functions
# =========================================================================

# Pad string to the right
fn pad_right(s: text, width: i32) -> text:
    val len = s.len()
    if len >= width:
        return s

    var result = s
    for i in len..width:
        result = "{result} "
    return result

# Pad string to the left
fn pad_left(s: text, width: i32) -> text:
    val len = s.len()
    if len >= width:
        return s

    var result = ""
    for i in len..width:
        result = "{result} "
    return "{result}{s}"

# Center string
fn center(s: text, width: i32) -> text:
    val len = s.len()
    if len >= width:
        return s

    val padding = width - len
    val left_pad = padding / 2
    val right_pad = padding - left_pad

    var result = ""
    for i in 0..left_pad:
        result = "{result} "
    result = "{result}{s}"
    for i in 0..right_pad:
        result = "{result} "
    return result

# =========================================================================
# Convenience Functions
# =========================================================================

# Render key-value table
fn render_kv_table(pairs: [(text, text)]) -> text:
    var builder = TableBuilder.new(["Key", "Value"])

    for pair in pairs:
        builder = builder.add_row([pair.0, pair.1])

    return builder.build()

# Render HTML table with row limit
fn render_html_table_limited(headers: [text], rows: [[text]], max_rows: i32) -> text:
    var h = "<table class=\"data-table\"><tr>"
    for header in headers:
        h = "{h}<th>{header}</th>"
    h = "{h}</tr>"
    var count = 0
    for row in rows:
        if count >= max_rows:
            break
        h = "{h}<tr>"
        for cell in row:
            h = "{h}<td>{cell}</td>"
        h = "{h}</tr>"
        count = count + 1
    h = "{h}</table>"
    h

# =========================================================================
# Exports
# =========================================================================
