#![allow(unnamed_duplicate_typed_args)]
# Shared TUI Layout Primitives
#
# Reusable layout types and functions for splitting, gridding, and measuring
# rectangular regions.  Used by llm_dashboard, office apps, and any TUI that
# needs structured panel placement.

# =========================================================================
# LayoutRect
# =========================================================================

class LayoutRect:
    """A positioned rectangle on the terminal grid (0-based coords)."""
    x: i32
    y: i32
    width: i32
    height: i32

    static fn new(x: i32, y: i32, w: i32, h: i32) -> LayoutRect:
        return LayoutRect(x: x, y: y, width: w, height: h)

    fn contains(px: i32, py: i32) -> bool:
        """True if (px, py) is inside this rectangle."""
        return (px >= self.x and px < self.x + self.width
            and py >= self.y and py < self.y + self.height)

    fn shrink(margin: i32) -> LayoutRect:
        """Return a new rect inset by `margin` on every side."""
        val m2 = margin * 2
        val w = if self.width > m2: self.width - m2 else: 0
        val h = if self.height > m2: self.height - m2 else: 0
        return LayoutRect(
            x: self.x + margin,
            y: self.y + margin,
            width: w,
            height: h
        )

    fn right() -> i32:
        """X coordinate one past the right edge."""
        return self.x + self.width

    fn bottom() -> i32:
        """Y coordinate one past the bottom edge."""
        return self.y + self.height

# =========================================================================
# Grid Layout
# =========================================================================

fn grid_layout(area: LayoutRect, rows: i32, cols: i32, gap: i32) -> [[LayoutRect]]:
    """Split `area` into a rows x cols grid with `gap` pixels between cells.

    Returns a list of rows, each row a list of LayoutRects.
    """
    if rows <= 0 or cols <= 0:
        return []

    val total_gap_x = gap * (cols - 1)
    val total_gap_y = gap * (rows - 1)
    val cell_w = if cols > 0: (area.width - total_gap_x) / cols else: 0
    val cell_h = if rows > 0: (area.height - total_gap_y) / rows else: 0

    var result: [[LayoutRect]] = []
    var r = 0
    while r < rows:
        var row_rects: [LayoutRect] = []
        var c = 0
        while c < cols:
            val cx = area.x + c * (cell_w + gap)
            val cy = area.y + r * (cell_h + gap)
            # Last column/row absorbs rounding remainder
            val w = if c == cols - 1: area.x + area.width - cx else: cell_w
            val h = if r == rows - 1: area.y + area.height - cy else: cell_h
            row_rects.push(LayoutRect(x: cx, y: cy, width: w, height: h))
            c = c + 1
        result.push(row_rects)
        r = r + 1
    return result

# =========================================================================
# Proportional Splits
# =========================================================================

fn split_horizontal(area: LayoutRect, ratios: [i32]) -> [LayoutRect]:
    """Split `area` horizontally into columns proportional to `ratios`.

    Example: split_horizontal(area, [1, 2, 1]) gives 25%/50%/25%.
    """
    if ratios.len() == 0:
        return []

    var total = 0
    for r in ratios:
        total = total + r

    if total <= 0:
        return []

    var result: [LayoutRect] = []
    var used = 0
    var i = 0
    while i < ratios.len():
        val w = if i == ratios.len() - 1:
            area.width - used
        else:
            (area.width * ratios[i]) / total
        result.push(LayoutRect(x: area.x + used, y: area.y, width: w, height: area.height))
        used = used + w
        i = i + 1
    return result

fn split_vertical(area: LayoutRect, ratios: [i32]) -> [LayoutRect]:
    """Split `area` vertically into rows proportional to `ratios`.

    Example: split_vertical(area, [1, 3]) gives 25%/75%.
    """
    if ratios.len() == 0:
        return []

    var total = 0
    for r in ratios:
        total = total + r

    if total <= 0:
        return []

    var result: [LayoutRect] = []
    var used = 0
    var i = 0
    while i < ratios.len():
        val h = if i == ratios.len() - 1:
            area.height - used
        else:
            (area.height * ratios[i]) / total
        result.push(LayoutRect(x: area.x, y: area.y + used, width: area.width, height: h))
        used = used + h
        i = i + 1
    return result

# =========================================================================
# Fixed-Size Splits
# =========================================================================

fn split_left(area: LayoutRect, width: i32) -> (LayoutRect, LayoutRect):
    """Split off a fixed-width left panel. Returns (left, rest)."""
    val w = if width > area.width: area.width else: width
    val left = LayoutRect(x: area.x, y: area.y, width: w, height: area.height)
    val rest = LayoutRect(x: area.x + w, y: area.y, width: area.width - w, height: area.height)
    return (left, rest)

fn split_right(area: LayoutRect, width: i32) -> (LayoutRect, LayoutRect):
    """Split off a fixed-width right panel. Returns (rest, right)."""
    val w = if width > area.width: area.width else: width
    val rest = LayoutRect(x: area.x, y: area.y, width: area.width - w, height: area.height)
    val right = LayoutRect(x: area.x + area.width - w, y: area.y, width: w, height: area.height)
    return (rest, right)

fn split_top(area: LayoutRect, height: i32) -> (LayoutRect, LayoutRect):
    """Split off a fixed-height top panel. Returns (top, rest)."""
    val h = if height > area.height: area.height else: height
    val top = LayoutRect(x: area.x, y: area.y, width: area.width, height: h)
    val rest = LayoutRect(x: area.x, y: area.y + h, width: area.width, height: area.height - h)
    return (top, rest)

fn split_bottom(area: LayoutRect, height: i32) -> (LayoutRect, LayoutRect):
    """Split off a fixed-height bottom panel. Returns (rest, bottom)."""
    val h = if height > area.height: area.height else: height
    val rest = LayoutRect(x: area.x, y: area.y, width: area.width, height: area.height - h)
    val bot = LayoutRect(x: area.x, y: area.y + area.height - h, width: area.width, height: h)
    return (rest, bot)

# =========================================================================
# Centering
# =========================================================================

fn center_in(area: LayoutRect, width: i32, height: i32) -> LayoutRect:
    """Return a rect centered inside `area` with the given size.

    Clamps to the area bounds.
    """
    val w = if width > area.width: area.width else: width
    val h = if height > area.height: area.height else: height
    val cx = area.x + (area.width - w) / 2
    val cy = area.y + (area.height - h) / 2
    return LayoutRect(x: cx, y: cy, width: w, height: h)

# =========================================================================
# Stack Layout
# =========================================================================

fn stack_layout(area: LayoutRect, heights: [i32]) -> [LayoutRect]:
    """Lay out items vertically with explicit heights.

    Items that would extend past the area are clipped.
    """
    var result: [LayoutRect] = []
    var used = 0
    for h in heights:
        if used + h > area.height:
            val remaining = area.height - used
            if remaining > 0:
                result.push(LayoutRect(x: area.x, y: area.y + used, width: area.width, height: remaining))
            break
        result.push(LayoutRect(x: area.x, y: area.y + used, width: area.width, height: h))
        used = used + h
    return result

# =========================================================================
# Text Measurement Helpers
# =========================================================================

fn _is_ansi_terminator(ch: text) -> bool:
    """Check if ch is a letter A-Z or a-z (terminates ANSI CSI sequence)."""
    val terminators = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    return terminators.contains(ch)

fn text_width(s: text) -> i32:
    """Visible width of `s`, stripping ANSI escape sequences."""
    var width = 0
    var in_esc = false
    val chars = s.split("")
    for ch in chars:
        if ch == "":
            pass_dn
        elif ch == "\u{001b}":
            in_esc = true
        elif in_esc:
            if _is_ansi_terminator(ch):
                in_esc = false
        else:
            width = width + 1
    return width

fn truncate_to_width(s: text, max_width: i32) -> text:
    """Truncate `s` to at most `max_width` visible characters.

    Preserves ANSI sequences that appear before the cut-off.
    Appends ellipsis if truncated.
    """
    if max_width <= 0:
        return ""
    var result = ""
    var visible = 0
    var in_esc = false
    val chars = s.split("")
    for ch in chars:
        if ch == "":
            pass_dn
        elif ch == "\u{001b}":
            in_esc = true
            result = "{result}{ch}"
        elif in_esc:
            result = "{result}{ch}"
            if _is_ansi_terminator(ch):
                in_esc = false
        else:
            if visible >= max_width:
                if max_width >= 3:
                    return "{result}..."
                return result
            result = "{result}{ch}"
            visible = visible + 1
    return result

fn pad_to_width(s: text, width: i32) -> text:
    """Pad `s` with trailing spaces to reach `width` visible chars."""
    val vis = text_width(s)
    if vis >= width:
        return s
    var padded = s
    var i = vis
    while i < width:
        padded = "{padded} "
        i = i + 1
    return padded

fn center_text(s: text, width: i32) -> text:
    """Center `s` in a field of `width` visible characters."""
    val vis = text_width(s)
    if vis >= width:
        return s
    val left_pad = (width - vis) / 2
    val right_pad = width - vis - left_pad
    var result = ""
    var i = 0
    while i < left_pad:
        result = "{result} "
        i = i + 1
    result = "{result}{s}"
    i = 0
    while i < right_pad:
        result = "{result} "
        i = i + 1
    return result
