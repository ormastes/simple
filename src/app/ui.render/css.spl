# Reusable CSS Snippets
#
# Pre-built CSS rule sets for common UI components.
# Import individual functions to compose stylesheets without
# duplicating layout, card, badge, or responsive rules.

# =========================================================================
# Card Styles
# =========================================================================

fn card_css() -> text:
    """Card component styles with hover effect."""
    var s = ""
    s = "{s}.card {\n"
    s = "{s}  background: var(--bg-card, #161b22);\n"
    s = "{s}  border: 1px solid var(--border, #30363d);\n"
    s = "{s}  border-radius: 8px;\n"
    s = "{s}  padding: 16px 20px;\n"
    s = "{s}  box-shadow: 0 2px 6px rgba(0,0,0,0.08);\n"
    s = "{s}}\n"
    s = "{s}.card:hover {\n"
    s = "{s}  background: var(--bg-card-hover, #1c2128);\n"
    s = "{s}}\n"
    s = "{s}.card h3 {\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  color: var(--text-dim, #8b949e);\n"
    s = "{s}  margin-bottom: 8px;\n"
    s = "{s}  text-transform: uppercase;\n"
    s = "{s}  letter-spacing: 0.5px;\n"
    s = "{s}}\n"
    s = "{s}.card-header {\n"
    s = "{s}  display: flex;\n"
    s = "{s}  align-items: center;\n"
    s = "{s}  margin-bottom: 8px;\n"
    s = "{s}}\n"
    s = "{s}.card-body {\n"
    s = "{s}  font-size: 14px;\n"
    s = "{s}}\n"
    s = "{s}.value {\n"
    s = "{s}  font-size: 28px;\n"
    s = "{s}  font-weight: bold;\n"
    s = "{s}}\n"
    s = "{s}.sub {\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  color: var(--text-dim, #8b949e);\n"
    s = "{s}  margin-top: 4px;\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Grid Layout Styles
# =========================================================================

fn grid_css() -> text:
    """Grid layout utility classes."""
    var s = ""
    s = "{s}.card-grid {\n"
    s = "{s}  display: grid;\n"
    s = "{s}  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n"
    s = "{s}  gap: 12px;\n"
    s = "{s}}\n"
    s = "{s}.container {\n"
    s = "{s}  max-width: 1200px;\n"
    s = "{s}  margin: 0 auto;\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Badge / Pill Styles
# =========================================================================

fn badge_css() -> text:
    """Badge and pill styles with color variants."""
    var s = ""
    s = "{s}.badge {\n"
    s = "{s}  display: inline-block;\n"
    s = "{s}  padding: 2px 8px;\n"
    s = "{s}  border-radius: 12px;\n"
    s = "{s}  font-size: 12px;\n"
    s = "{s}  font-weight: 500;\n"
    s = "{s}  color: #fff;\n"
    s = "{s}}\n"
    s = "{s}.badge-green { background: var(--green, #3fb950); }\n"
    s = "{s}.badge-red { background: var(--red, #f85149); }\n"
    s = "{s}.badge-yellow { background: var(--yellow, #d29922); }\n"
    s = "{s}.badge-blue { background: var(--blue, #58a6ff); }\n"
    s = "{s}.badge-dim { background: var(--gray, #8b949e); }\n"
    return s

# =========================================================================
# Metric Card Styles
# =========================================================================

fn metric_css() -> text:
    """Metric card styles for dashboard-style big-number displays."""
    var s = ""
    s = "{s}.metric-grid {\n"
    s = "{s}  display: grid;\n"
    s = "{s}  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));\n"
    s = "{s}  gap: 12px;\n"
    s = "{s}}\n"
    s = "{s}.metric-card {\n"
    s = "{s}  background: var(--bg-card, #161b22);\n"
    s = "{s}  border: 1px solid var(--border, #30363d);\n"
    s = "{s}  border-radius: 8px;\n"
    s = "{s}  padding: 16px;\n"
    s = "{s}  text-align: center;\n"
    s = "{s}}\n"
    s = "{s}.metric-card .metric-value {\n"
    s = "{s}  font-size: 32px;\n"
    s = "{s}  font-weight: bold;\n"
    s = "{s}  line-height: 1.2;\n"
    s = "{s}}\n"
    s = "{s}.metric-card .metric-label {\n"
    s = "{s}  font-size: 12px;\n"
    s = "{s}  color: var(--text-dim, #8b949e);\n"
    s = "{s}  text-transform: uppercase;\n"
    s = "{s}  letter-spacing: 0.5px;\n"
    s = "{s}  margin-bottom: 4px;\n"
    s = "{s}}\n"
    s = "{s}.metric-card .metric-trend {\n"
    s = "{s}  font-size: 12px;\n"
    s = "{s}  color: var(--text-dim, #8b949e);\n"
    s = "{s}  margin-top: 4px;\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Animation Styles
# =========================================================================

fn animation_css() -> text:
    """Common animation keyframes and utility classes."""
    var s = ""
    s = "{s}@keyframes fade-in {\n"
    s = "{s}  from { opacity: 0; }\n"
    s = "{s}  to { opacity: 1; }\n"
    s = "{s}}\n"
    s = "{s}@keyframes pulse {\n"
    s = "{s}  0%, 100% { opacity: 1; }\n"
    s = "{s}  50% { opacity: 0.5; }\n"
    s = "{s}}\n"
    s = "{s}@keyframes slide-up {\n"
    s = "{s}  from { transform: translateY(8px); opacity: 0; }\n"
    s = "{s}  to { transform: translateY(0); opacity: 1; }\n"
    s = "{s}}\n"
    s = "{s}.animate-fade-in { animation: fade-in 0.3s ease-in; }\n"
    s = "{s}.animate-pulse { animation: pulse 2s infinite; }\n"
    s = "{s}.animate-slide-up { animation: slide-up 0.2s ease-out; }\n"
    return s

# =========================================================================
# Responsive Breakpoints
# =========================================================================

fn responsive_css() -> text:
    """Media query breakpoints for responsive layouts."""
    var s = ""
    s = "{s}@media (max-width: 1200px) {\n"
    s = "{s}  .card-grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }\n"
    s = "{s}}\n"
    s = "{s}@media (max-width: 768px) {\n"
    s = "{s}  .card-grid { grid-template-columns: 1fr; }\n"
    s = "{s}  .container { padding: 0 12px; }\n"
    s = "{s}  body { padding: 12px; }\n"
    s = "{s}}\n"
    s = "{s}@media (max-width: 480px) {\n"
    s = "{s}  .card { padding: 12px; }\n"
    s = "{s}  .value { font-size: 22px; }\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Table Styles
# =========================================================================

fn table_css() -> text:
    """Table component styles."""
    var s = ""
    s = "{s}table {\n"
    s = "{s}  border-collapse: collapse;\n"
    s = "{s}  width: 100%;\n"
    s = "{s}}\n"
    s = "{s}th, td {\n"
    s = "{s}  border: 1px solid var(--border, #d0d7de);\n"
    s = "{s}  padding: 8px 12px;\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  text-align: left;\n"
    s = "{s}}\n"
    s = "{s}th {\n"
    s = "{s}  background: var(--bg-card, #f6f8fa);\n"
    s = "{s}  font-weight: 600;\n"
    s = "{s}}\n"
    s = "{s}tr:hover td {\n"
    s = "{s}  background: var(--bg-card-hover, #f3f4f6);\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Alert Styles
# =========================================================================

fn alert_css() -> text:
    """Alert/notification banner styles."""
    var s = ""
    s = "{s}.alert {\n"
    s = "{s}  padding: 10px 16px;\n"
    s = "{s}  border-radius: 6px;\n"
    s = "{s}  margin: 8px 0;\n"
    s = "{s}  font-size: 14px;\n"
    s = "{s}}\n"
    s = "{s}.alert-critical {\n"
    s = "{s}  background: rgba(248, 81, 73, 0.15);\n"
    s = "{s}  color: var(--red, #f85149);\n"
    s = "{s}  border: 1px solid var(--red, #f85149);\n"
    s = "{s}}\n"
    s = "{s}.alert-warning {\n"
    s = "{s}  background: rgba(210, 153, 34, 0.15);\n"
    s = "{s}  color: var(--yellow, #d29922);\n"
    s = "{s}  border: 1px solid var(--yellow, #d29922);\n"
    s = "{s}}\n"
    s = "{s}.alert-info {\n"
    s = "{s}  background: rgba(88, 166, 255, 0.15);\n"
    s = "{s}  color: var(--blue, #58a6ff);\n"
    s = "{s}  border: 1px solid var(--blue, #58a6ff);\n"
    s = "{s}}\n"
    s = "{s}.alert-success {\n"
    s = "{s}  background: rgba(63, 185, 80, 0.15);\n"
    s = "{s}  color: var(--green, #3fb950);\n"
    s = "{s}  border: 1px solid var(--green, #3fb950);\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Progress Bar Styles
# =========================================================================

fn progress_css() -> text:
    """Progress bar component styles."""
    var s = ""
    s = "{s}.progress {\n"
    s = "{s}  background: var(--border, #30363d);\n"
    s = "{s}  border-radius: 4px;\n"
    s = "{s}  height: 8px;\n"
    s = "{s}  overflow: hidden;\n"
    s = "{s}  width: 100%;\n"
    s = "{s}}\n"
    s = "{s}.progress-fill {\n"
    s = "{s}  height: 100%;\n"
    s = "{s}  border-radius: 4px;\n"
    s = "{s}  transition: width 0.3s ease;\n"
    s = "{s}}\n"
    return s
