# HTML Widget Renderers
#
# Standalone HTML renderer surface split from the mixed widgets module so
# non-terminal backends can keep using shared HTML rendering without forcing
# standalone TUI binaries to retain it.

use app.dashboard.render.table.{pad_right, pad_left, center}
use app.dashboard.render.progress.{render_progress_bar}
use common.ui.widget.{WidgetNode, WidgetRect, UIState}
use app.ui.render.capability.{RendererCapability, renderer_capability_html_widgets}

fn html_widget_renderer_capability() -> RendererCapability:
    renderer_capability_html_widgets()

fn split_by_pipe(input: text) -> [text]:
    """Split a text string by '|' delimiter."""
    return input.split("|")

fn expand_template(template_text: text, state: UIState) -> text:
    """Expand placeholders like {app.mode} and {app.title}."""
    if template_text == "":
        return ""
    var result = template_text
    val ph_mode = "{" + "app.mode" + "}"
    val ph_title = "{" + "app.title" + "}"
    # Unconditional: replace_placeholder is a no-op when absent, and the
    # interpreter's index_of can miss brace-containing needles (split does not),
    # so a contains-gate would skip valid {app.mode}/{app.title} substitutions.
    result = replace_placeholder(result, ph_mode, state.mode_name())
    result = replace_placeholder(result, ph_title, state.tree.title_text())
    return result

fn replace_placeholder(text_val: text, placeholder: text, replacement: text) -> text:
    """Simple string replacement without relying on text.replace() or slicing."""
    if placeholder == "":
        return text_val
    val parts = text_val.split(placeholder)
    return parts.join(replacement)

fn text_contains(haystack: text, needle: text) -> bool:
    if needle == "":
        return true
    val idx = haystack.index_of(needle)
    match idx:
        case Some(_):
            return true
        case _:
            return false

# =========================================================================
# HTML Widget Rendering
# =========================================================================

fn render_html_widget(node: WidgetNode, state: UIState) -> text:
    """Render a widget to an HTML string."""
    val is_focused = node.id == state.focused_id
    val focus_class = if is_focused: " focused" else: ""

    match node.kind_name():
        "vbox" =>
            return render_html_vbox(node, state, focus_class)
        "hbox" =>
            return render_html_hbox(node, state, focus_class)
        "panel" =>
            return render_html_panel(node, state, focus_class)
        "text" =>
            return render_html_text(node, focus_class)
        "list" =>
            return render_html_list(node, state, focus_class)
        "table" =>
            return render_html_table(node, state, focus_class)
        "progress" =>
            return render_html_progress(node, focus_class)
        "menubar" =>
            return render_html_menubar(node, state)
        "statusbar" =>
            return render_html_statusbar(node, state)
        "input" =>
            return render_html_input(node, focus_class)
        "tabs" =>
            return render_html_tabs(node, focus_class)
        "button" =>
            return render_html_button(node, focus_class)
        "checkbox" =>
            return render_html_checkbox(node, focus_class)
        "radio" =>
            return render_html_radio(node, focus_class)
        "dropdown" =>
            return render_html_dropdown(node, focus_class)
        "textfield" =>
            return render_html_textfield(node, focus_class)
        "image" =>
            return render_html_image(node, focus_class)
        "divider" =>
            return render_html_divider(node)
        "dialog" =>
            return render_html_dialog(node, state, focus_class)
        "tooltip" =>
            return render_html_tooltip(node, focus_class)
        "tree" =>
            return render_html_tree_widget(node, state, focus_class)
        "treenode" =>
            return render_html_tree_node(node, state)
        "scroll" =>
            return render_html_scroll(node, state, focus_class)
        "textarea" =>
            return render_html_textarea(node, focus_class)
        "heading" =>
            return render_html_heading(node, focus_class)
        "label" =>
            return render_html_text(node, focus_class)
        # iOS widgets
        "navigation_bar" =>
            return render_html_navigation_bar(node, state, focus_class)
        "tab_bar" =>
            return render_html_tab_bar(node, state, focus_class)
        "card" =>
            return render_html_card(node, state, focus_class)
        "switch" =>
            return render_html_switch(node, focus_class)
        "segmented_control" =>
            return render_html_segmented_control(node, focus_class)
        "search_bar" =>
            return render_html_search_bar(node, focus_class)
        # Glass / workspace shell widgets
        "glass_title_bar" =>
            return render_html_glass_title_bar(node, state, focus_class)
        "sidebar" =>
            return render_html_sidebar(node, state, focus_class)
        "command_bar" =>
            return render_html_command_bar(node, state, focus_class)
        "workspace_tabs" =>
            return render_html_workspace_tabs(node, focus_class)
        "command_palette" =>
            return render_html_command_palette(node, focus_class)
        "toast" =>
            return render_html_toast(node, focus_class)
        "sheet_modal" =>
            return render_html_sheet_modal(node, state, focus_class)
        "context_menu" =>
            return render_html_context_menu(node, focus_class)
        "inspector" =>
            return render_html_inspector(node, state, focus_class)
        "utility_rail" =>
            return render_html_utility_rail(node, focus_class)
        "status_chip" =>
            return render_html_status_chip(node, focus_class)
        "selection_pill" =>
            return render_html_selection_pill(node, focus_class)
        "empty_state" =>
            return render_html_empty_state(node, focus_class)

fn render_html_tree_widget(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a tree widget to HTML."""
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_tree_node(child, state)}"
    return "<div class=\"widget-tree{focus_class}\" id=\"{node.id}\"><ul class=\"tree-root\">{children_html}</ul></div>"

fn render_html_tree_node(node: WidgetNode, state: UIState) -> text:
    """Render a treenode to HTML recursively."""
    val label = node.get_prop("label")
    val expanded = node.get_prop("expanded")
    val has_children = node.child_count() > 0
    val exp_class = if has_children and expanded == "true": " expanded" elif has_children: " collapsed" else: " leaf"

    var toggle_html = ""
    if has_children:
        val toggle_marker = if expanded == "true": "\u{25bc}" else: "\u{25b6}"
        toggle_html = "<span class=\"tree-toggle\" data-action=\"toggle_{node.id}\">{toggle_marker}</span>"

    var children_html = ""
    if has_children and expanded == "true":
        var child_items = ""
        for child in node.children():
            child_items = "{child_items}{render_html_tree_node(child, state)}"
        children_html = "<ul>{child_items}</ul>"

    return "<li class=\"tree-node{exp_class}\">{toggle_html}<span class=\"tree-label\">{label}</span>{children_html}</li>"

fn render_html_vbox(node: WidgetNode, state: UIState, focus_class: text) -> text:
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    val flex_prop = node.get_prop("flex")
    var style = "display: flex; flex-direction: column;"
    if flex_prop != "":
        style = "{style} flex: {flex_prop};"
    else:
        style = "{style} flex: 1; min-height: 0;"
    return "<div class=\"layout-vbox{focus_class}\" id=\"{node.id}\" style=\"{style}\">{children_html}</div>"

fn render_html_hbox(node: WidgetNode, state: UIState, focus_class: text) -> text:
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    val flex_prop = node.get_prop("flex")
    var style = "display: flex; flex-direction: row;"
    if flex_prop != "":
        style = "{style} flex: {flex_prop};"
    else:
        style = "{style} flex: 1; min-height: 0;"
    return "<div class=\"layout-hbox{focus_class}\" id=\"{node.id}\" style=\"{style}\">{children_html}</div>"

fn render_html_panel(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"

    val flex_prop = node.get_prop("flex")
    val width_prop = node.get_prop("width")
    val height_prop = node.get_prop("height")
    var style = ""
    if flex_prop != "":
        style = "flex: {flex_prop};"
    elif width_prop != "":
        style = "width: {width_prop}px; flex: none;"
    else:
        style = "flex: 1;"
    if height_prop != "":
        style = "{style} height: {height_prop}em;"

    val layout_class = if node.layout_name() == "hbox": "layout-hbox" elif node.layout_name() == "grid": "layout-grid" else: "layout-vbox"

    # Omit empty title header for layout-only containers
    val title_html = if title != "": "<div class=\"panel-title\">{title}</div>" else: ""

    return "<div class=\"widget-panel {layout_class}{focus_class}\" id=\"{node.id}\" style=\"{style}\">{title_html}<div class=\"panel-content\">{children_html}</div></div>"

fn render_html_text(node: WidgetNode, focus_class: text) -> text:
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    return "<div class=\"widget-text{focus_class}\" id=\"{node.id}\">{display}</div>"

fn render_html_list(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val sel_str = node.get_prop("selected_index")
    var sel_idx = -1
    if sel_str != "":
        sel_idx = sel_str.to_int()
    var items_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val item_class = if idx == sel_idx: "list-item selected" else: "list-item"
        # Include prefix indicator matching TUI's "> " for selected items
        val prefix = if idx == sel_idx: "\u{25b8} " else: ""
        items_html = "{items_html}<li class=\"{item_class}\" data-index=\"{idx}\">{prefix}{label}</li>"
        idx = idx + 1
    return "<ul class=\"widget-list{focus_class}\" id=\"{node.id}\">{items_html}</ul>"

fn render_html_table(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val header_str = node.get_prop("headers")
    val sort_col = node.get_prop("sort_column")
    val sort_dir = node.get_prop("sort_dir")
    val filter_text = node.get_prop("filter_text")

    # Filter input above table
    var filter_html = "<input class=\"table-filter\" placeholder=\"Filter...\" data-action=\"filter_{node.id}\" />"

    # Build thead
    var thead_html = ""
    if header_str != "":
        var headers = split_by_pipe(header_str)
        var th_html = ""
        var hi = 0
        for hdr in headers:
            val indicator = if sort_col == "{hi}":
                if sort_dir == "desc": " \u{25bc}" else: " \u{25b2}"
            else:
                ""
            th_html = "{th_html}<th data-action=\"sort_col_{hi}\">{hdr}{indicator}</th>"
            hi = hi + 1
        thead_html = "<thead><tr>{th_html}</tr></thead>"

    # Build tbody
    var tbody_html = ""
    for child in node.children():
        val label = child.get_prop("label")
        if label != "":
            # Apply filter
            if filter_text != "" and not text_contains(label, filter_text):
                pass_dn
            else:
                val cells = split_by_pipe(label)
                var td_html = ""
                for cell in cells:
                    td_html = "{td_html}<td>{cell}</td>"
                tbody_html = "{tbody_html}<tr>{td_html}</tr>"

    return "{filter_html}<table class=\"widget-table{focus_class}\" id=\"{node.id}\">{thead_html}<tbody>{tbody_html}</tbody></table>"

fn render_html_progress(node: WidgetNode, focus_class: text) -> text:
    val value_str = node.get_prop("value")
    val value = if value_str != "": value_str else: "0"
    val label = node.get_prop("label")
    val label_html = if label != "": "<div class=\"widget-text\" style=\"font-size:12px;margin-bottom:4px;\">{label}</div>" else: ""
    return "{label_html}<div class=\"widget-progress{focus_class}\" id=\"{node.id}\"><div class=\"progress-track\"><div class=\"progress-bar\" style=\"width: {value}%\"></div></div><span class=\"progress-label\">{value}%</span></div>"

fn render_html_menubar(node: WidgetNode, state: UIState) -> text:
    var items_html = ""
    for child in node.children():
        val is_separator = child.get_prop("is_separator")
        val has_submenu = child.get_prop("has_submenu")
        val label = child.get_prop("label")
        if is_separator == "true":
            items_html = "{items_html}<span class=\"menu-separator\">|</span>"
        elif has_submenu == "true":
            var submenu_html = ""
            for sub_child in child.children():
                val sub_label = sub_child.get_prop("label")
                val sub_action = sub_child.get_prop("action")
                val is_sep = sub_child.get_prop("is_separator")
                if is_sep == "true":
                    submenu_html = "{submenu_html}<div class=\"menu-separator\"></div>"
                else:
                    submenu_html = "{submenu_html}<div class=\"submenu-item\" data-action=\"{sub_action}\">{sub_label}</div>"
            items_html = "{items_html}<div class=\"menu-item\">{label}<div class=\"menu-submenu\">{submenu_html}</div></div>"
        else:
            items_html = "{items_html}<span class=\"menu-item\">{label}</span>"
    return "<div class=\"widget-menubar\" id=\"{node.id}\">{items_html}</div>"

fn render_html_statusbar(node: WidgetNode, state: UIState) -> text:
    val left_text = expand_template(node.get_prop("left"), state)
    val right_text = expand_template(node.get_prop("right"), state)
    return "<div class=\"widget-statusbar\" id=\"{node.id}\"><span class=\"status-left\">{left_text}</span><span class=\"status-right\">{right_text}</span></div>"

fn render_html_input(node: WidgetNode, focus_class: text) -> text:
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val is_error = node.get_prop("error") == "true"
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val error_class = if is_error: " error" else: ""
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    return "<input class=\"widget-input{focus_class}{error_class}\" id=\"{node.id}\" value=\"{value}\" placeholder=\"{placeholder}\"{readonly_attr}{disabled_attr} />"

fn render_html_tabs(node: WidgetNode, focus_class: text) -> text:
    val active_idx_str = node.get_prop("active_index")
    val active_idx = if active_idx_str != "": active_idx_str.to_int() else: 0
    var tabs_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == active_idx: " active" else: ""
        tabs_html = "{tabs_html}<span class=\"tab-item{active_class}\" data-index=\"{idx}\" data-action=\"tab_{node.id}_{idx}\">{label}</span>"
        idx = idx + 1
    return "<div class=\"widget-tabs{focus_class}\" id=\"{node.id}\">{tabs_html}</div>"

# =========================================================================
# New HTML Widget Renderers
# =========================================================================
fn render_html_button(node: WidgetNode, focus_class: text) -> text:
    """Render a button as HTML."""
    val label = node.get_prop("label")
    val action = node.get_prop("action")
    val icon_id = node.get_prop("icon-id")
    val disabled = node.get_prop("disabled") == "true"
    val disabled_attr = if disabled: " disabled" else: ""

    var icon_html = ""
    var with_icon_class = ""
    if icon_id != "":
        icon_html = "<span class=\"icon icon-{icon_id}\" data-icon=\"{icon_id}\"></span> "
        with_icon_class = " with-icon"

    return "<button type=\"button\" class=\"widget-button{focus_class}{with_icon_class}\" id=\"{node.id}\" data-action=\"{action}\"{disabled_attr}>{icon_html}{label}</button>"

fn render_html_checkbox(node: WidgetNode, focus_class: text) -> text:
    val label = node.get_prop("label")
    val checked = node.get_prop("checked")
    val is_disabled = node.get_prop("disabled") == "true"
    val checked_class = if checked == "true": " checked" else: ""
    val disabled_class = if is_disabled: " disabled" else: ""
    val check_mark = if checked == "true": "\u{2713}" else: ""
    return "<div class=\"widget-checkbox{checked_class}{disabled_class}{focus_class}\" id=\"{node.id}\" data-action=\"toggle_{node.id}\"><div class=\"check-box\">{check_mark}</div><span>{label}</span></div>"

fn render_html_radio(node: WidgetNode, focus_class: text) -> text:
    """Render a radio-button group. Children are the selectable options; the
    `selected_index` prop marks the active one. Clicking an option emits
    `select_{group}_{idx}` so the host can update the selection."""
    val is_disabled = node.get_prop("disabled") == "true"
    val disabled_class = if is_disabled: " disabled" else: ""
    val sel_str = node.get_prop("selected_index")
    val sel_idx = if sel_str != "": sel_str.to_int() else: 0

    # Single radio (no children): render one labelled option keyed off `checked`.
    if node.children().length() == 0:
        val label = node.get_prop("label")
        val checked = node.get_prop("checked") == "true"
        val checked_class = if checked: " checked" else: ""
        val dot = if checked: "<div class=\"radio-dot\"></div>" else: ""
        return "<div class=\"widget-radio{checked_class}{disabled_class}{focus_class}\" id=\"{node.id}\" data-action=\"select_{node.id}\"><div class=\"radio-mark\">{dot}</div><span>{label}</span></div>"

    var options_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val selected = idx == sel_idx
        val checked_class = if selected: " checked" else: ""
        val dot = if selected: "<div class=\"radio-dot\"></div>" else: ""
        options_html = "{options_html}<div class=\"widget-radio-option{checked_class}\" id=\"{child.id}\" data-action=\"select_{node.id}_{idx}\"><div class=\"radio-mark\">{dot}</div><span>{label}</span></div>"
        idx = idx + 1
    return "<div class=\"widget-radio-group{disabled_class}{focus_class}\" id=\"{node.id}\" role=\"radiogroup\">{options_html}</div>"

fn render_html_dropdown(node: WidgetNode, focus_class: text) -> text:
    val is_disabled = node.get_prop("disabled") == "true"
    val disabled_attr = if is_disabled: " disabled" else: ""
    val sel_str = node.get_prop("selected_index")
    var sel_idx = if sel_str != "": sel_str.to_int() else: 0
    var options_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val selected_attr = if idx == sel_idx: " selected" else: ""
        options_html = "{options_html}<option{selected_attr}>{label}</option>"
        idx = idx + 1
    return "<select class=\"widget-dropdown{focus_class}\" id=\"{node.id}\"{disabled_attr}>{options_html}</select>"

fn render_html_textfield(node: WidgetNode, focus_class: text) -> text:
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val is_error = node.get_prop("error") == "true"
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    val error_class = if is_error: " error" else: ""
    return "<input type=\"text\" class=\"widget-textfield{focus_class}{error_class}\" id=\"{node.id}\" value=\"{value}\" placeholder=\"{placeholder}\"{readonly_attr}{disabled_attr} />"

fn render_html_image(node: WidgetNode, focus_class: text) -> text:
    val src = node.get_prop("src")
    val alt = node.get_prop("alt")
    return "<img class=\"widget-image{focus_class}\" id=\"{node.id}\" src=\"{src}\" alt=\"{alt}\" />"

fn render_html_divider(node: WidgetNode) -> text:
    return "<hr class=\"widget-divider\" id=\"{node.id}\" />"

fn render_html_dialog(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-dialog-overlay\"><div class=\"widget-dialog{focus_class}\" id=\"{node.id}\"><div class=\"dialog-title\">{title}</div><div class=\"dialog-content\">{children_html}</div></div></div>"

fn render_html_tooltip(node: WidgetNode, focus_class: text) -> text:
    val content = node.get_prop("content")
    val target = node.get_prop("target")
    return "<div class=\"widget-tooltip{focus_class}\" id=\"{node.id}\" data-target=\"{target}\"><span class=\"tooltip-trigger\">[?]</span><span class=\"tooltip-content\">{content}</span></div>"

fn render_html_scroll(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a scrollable container as a div with overflow:auto."""
    val max_h = node.get_prop("max_height")
    val style_attr = if max_h != "": "max-height:{max_h}px; overflow-y: auto;" else: "overflow-y: auto;"
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-scroll{focus_class}\" id=\"{node.id}\" style=\"{style_attr}\">{children_html}</div>"

fn render_html_textarea(node: WidgetNode, focus_class: text) -> text:
    """Render a multi-line textarea."""
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val rows = node.get_prop("rows")
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val is_error = node.get_prop("error") == "true"
    val rows_attr = if rows != "": " rows=\"{rows}\"" else: " rows=\"4\""
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    val error_class = if is_error: " error" else: ""
    return "<textarea class=\"widget-textarea{focus_class}{error_class}\" id=\"{node.id}\" placeholder=\"{placeholder}\"{rows_attr}{readonly_attr}{disabled_attr}>{value}</textarea>"

fn render_html_heading(node: WidgetNode, focus_class: text) -> text:
    """Render a heading element."""
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    val level = node.get_prop("level")
    val tag = if level == "1": "h1" elif level == "2": "h2" elif level == "3": "h3" else: "h2"
    return "<{tag} class=\"widget-heading{focus_class}\" id=\"{node.id}\">{display}</{tag}>"

# =========================================================================
# iOS Widget HTML Renderers
# =========================================================================

fn render_html_navigation_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style navigation bar."""
    val title = node.get_prop("title")
    val large_title = node.get_prop("large_title")
    val title_class = if large_title == "true": "nav-title nav-title-large" else: "nav-title"

    var left_html = ""
    var right_html = ""
    val children = node.children()
    # First child = left items container, second = title (skip), third = right items container
    if children.len() >= 1:
        val left_container = children[0]
        for child in left_container.children():
            left_html = "{left_html}{render_html_widget(child, state)}"
    if children.len() >= 3:
        val right_container = children[2]
        for child in right_container.children():
            right_html = "{right_html}{render_html_widget(child, state)}"

    var html = "<nav class=\"widget-navigation-bar{focus_class}\" id=\"{node.id}\">"
    html = "{html}<div class=\"nav-left\">{left_html}</div>"
    html = "{html}<div class=\"{title_class}\">{title}</div>"
    html = "{html}<div class=\"nav-right\">{right_html}</div>"
    html = "{html}</nav>"
    return html

fn render_html_tab_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style bottom tab bar."""
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var items_html = ""
    var idx = 0
    for child in node.children():
        val icon = child.get_prop("icon")
        val label = child.get_prop("label")
        val badge = child.get_prop("badge")
        val active_class = if idx == active_idx: " tab-bar-item-active" else: ""
        var badge_html = ""
        if badge != "" and badge != "0":
            badge_html = "<span class=\"tab-bar-badge\">{badge}</span>"
        items_html = "{items_html}<div class=\"tab-bar-item{active_class}\" data-action=\"tab_{node.id}_{idx}\">"
        items_html = "{items_html}<span class=\"tab-bar-icon\">{icon}{badge_html}</span>"
        items_html = "{items_html}<span class=\"tab-bar-label\">{label}</span>"
        items_html = "{items_html}</div>"
        idx = idx + 1

    return "<div class=\"widget-tab-bar{focus_class}\" id=\"{node.id}\">{items_html}</div>"

fn render_html_card(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style card."""
    val title = node.get_prop("title")
    val subtitle = node.get_prop("subtitle")

    var header_html = ""
    if title != "":
        header_html = "<div class=\"card-header\"><div class=\"card-title\">{title}</div>"
        if subtitle != "":
            header_html = "{header_html}<div class=\"card-subtitle\">{subtitle}</div>"
        header_html = "{header_html}</div>"

    var content_html = ""
    for child in node.children():
        content_html = "{content_html}{render_html_widget(child, state)}"

    val flex_prop = node.get_prop("flex")
    var style = ""
    if flex_prop != "":
        style = " style=\"flex: {flex_prop};\""

    return "<div class=\"widget-card{focus_class}\" id=\"{node.id}\"{style}>{header_html}<div class=\"card-content\">{content_html}</div></div>"

fn render_html_switch(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style toggle switch."""
    val label = node.get_prop("label")
    val on_val = node.get_prop("on")
    val disabled = node.get_prop("disabled")
    val action = node.get_prop("action")
    val on_class = if on_val == "true": " switch-on" else: ""
    val dis_class = if disabled == "true": " disabled" else: ""

    var html = "<div class=\"widget-switch{on_class}{dis_class}{focus_class}\" id=\"{node.id}\" data-action=\"{action}\">"
    html = "{html}<span class=\"switch-label\">{label}</span>"
    html = "{html}<div class=\"switch-track\"><div class=\"switch-thumb\"></div></div>"
    html = "{html}</div>"
    return html

fn render_html_segmented_control(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style segmented control."""
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var items_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == active_idx: " segment-active" else: ""
        items_html = "{items_html}<div class=\"segment-item{active_class}\" data-action=\"segment_{node.id}_{idx}\">{label}</div>"
        idx = idx + 1

    return "<div class=\"widget-segmented-control{focus_class}\" id=\"{node.id}\">{items_html}</div>"

fn render_html_search_bar(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style search bar."""
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val show_cancel = node.get_prop("show_cancel")

    var html = "<div class=\"widget-search-bar{focus_class}\" id=\"{node.id}\">"
    html = "{html}<span class=\"search-icon\">\u{1F50D}</span>"
    html = "{html}<input class=\"search-input\" type=\"text\" placeholder=\"{placeholder}\" value=\"{value}\" data-action=\"change_{node.id}\" />"
    if show_cancel == "true":
        html = "{html}<button class=\"search-cancel\" data-action=\"cancel_{node.id}\">Cancel</button>"
    html = "{html}</div>"
    return html

# =========================================================================
# Glass / Workspace Shell HTML Renderers
# =========================================================================

fn render_html_glass_title_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a glass title bar: a title plus optional control children."""
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-glass-title-bar{focus_class}\" id=\"{node.id}\"><div class=\"titlebar-title\">{title}</div>{children_html}</div>"

fn render_html_sidebar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a sidebar navigation container; children are nav entries."""
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-sidebar{focus_class}\" id=\"{node.id}\">{children_html}</div>"

fn render_html_command_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a command bar container; children are command buttons/inputs."""
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-command-bar{focus_class}\" id=\"{node.id}\">{children_html}</div>"

fn render_html_workspace_tabs(node: WidgetNode, focus_class: text) -> text:
    """Render workspace tabs; the `active_index` prop marks the active tab and
    each tab emits `ws_tab_{id}_{idx}` on click."""
    val active_idx_str = node.get_prop("active_index")
    val active_idx = if active_idx_str != "": active_idx_str.to_int() else: 0
    var tabs_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == active_idx: " active" else: ""
        tabs_html = "{tabs_html}<div class=\"ws-tab{active_class}\" data-action=\"ws_tab_{node.id}_{idx}\">{label}</div>"
        idx = idx + 1
    return "<div class=\"widget-workspace-tabs{focus_class}\" id=\"{node.id}\">{tabs_html}</div>"

fn render_html_command_palette(node: WidgetNode, focus_class: text) -> text:
    """Render a command palette: a search input plus a results list. Each result
    child carries `label` (+ optional `action`)."""
    val placeholder = node.get_prop("placeholder")
    var results_html = ""
    for child in node.children():
        val label = child.get_prop("label")
        val action = child.get_prop("action")
        results_html = "{results_html}<div class=\"palette-item\" data-action=\"{action}\">{label}</div>"
    return "<div class=\"widget-command-palette{focus_class}\" id=\"{node.id}\"><input class=\"palette-input\" placeholder=\"{placeholder}\" data-action=\"palette_input_{node.id}\" /><div class=\"palette-results\">{results_html}</div></div>"

fn render_html_toast(node: WidgetNode, focus_class: text) -> text:
    """Render a toast notification. `status` (info|success|warning|error) selects
    the variant; message text comes from `message` or `label`."""
    val message = node.get_prop("message")
    val label = node.get_prop("label")
    val display = if message != "": message else: label
    val status = node.get_prop("status")
    val status_class = if status != "": " {status}" else: ""
    return "<div class=\"widget-toast{status_class}{focus_class}\" id=\"{node.id}\">{display}</div>"

fn render_html_sheet_modal(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a bottom-sheet modal: drag handle, title, and content children."""
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-sheet-modal{focus_class}\" id=\"{node.id}\"><div class=\"sheet-handle\"></div><div class=\"sheet-title\">{title}</div><div class=\"sheet-content\">{children_html}</div></div>"

fn render_html_context_menu(node: WidgetNode, focus_class: text) -> text:
    """Render a context menu; each child carries `label` (+ optional `action`),
    or `is_separator=true` for a divider."""
    var items_html = ""
    for child in node.children():
        val is_sep = child.get_prop("is_separator")
        if is_sep == "true":
            items_html = "{items_html}<div class=\"context-separator\"></div>"
        else:
            val label = child.get_prop("label")
            val action = child.get_prop("action")
            items_html = "{items_html}<div class=\"context-item\" data-action=\"{action}\">{label}</div>"
    return "<div class=\"widget-context-menu{focus_class}\" id=\"{node.id}\">{items_html}</div>"

fn render_html_inspector(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an inspector/detail panel with a title and content children."""
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    val title_html = if title != "": "<div class=\"inspector-title\">{title}</div>" else: ""
    return "<div class=\"widget-inspector{focus_class}\" id=\"{node.id}\">{title_html}<div class=\"inspector-content\">{children_html}</div></div>"

fn render_html_utility_rail(node: WidgetNode, focus_class: text) -> text:
    """Render a vertical utility rail of icon buttons; `active_index` marks the
    active one and each emits `rail_{id}_{idx}` on click."""
    val active_idx_str = node.get_prop("active_index")
    val active_idx = if active_idx_str != "": active_idx_str.to_int() else: -1
    var icons_html = ""
    var idx = 0
    for child in node.children():
        val icon = child.get_prop("icon")
        val label = child.get_prop("label")
        val display = if icon != "": icon else: label
        val active_class = if idx == active_idx: " active" else: ""
        icons_html = "{icons_html}<div class=\"rail-icon{active_class}\" data-action=\"rail_{node.id}_{idx}\">{display}</div>"
        idx = idx + 1
    return "<div class=\"widget-utility-rail{focus_class}\" id=\"{node.id}\">{icons_html}</div>"

fn render_html_status_chip(node: WidgetNode, focus_class: text) -> text:
    """Render an inline status chip. `status` (info|success|warning|error)
    selects the color variant."""
    val label = node.get_prop("label")
    val status = node.get_prop("status")
    val status_class = if status != "": " {status}" else: ""
    return "<span class=\"widget-status-chip{status_class}{focus_class}\" id=\"{node.id}\">{label}</span>"

fn render_html_selection_pill(node: WidgetNode, focus_class: text) -> text:
    """Render a selection pill group; `selected_index` marks the active option
    and each pill emits `pill_{id}_{idx}` on click."""
    val sel_str = node.get_prop("selected_index")
    val sel_idx = if sel_str != "": sel_str.to_int() else: 0
    var pills_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == sel_idx: " active" else: ""
        pills_html = "{pills_html}<div class=\"pill-item{active_class}\" data-action=\"pill_{node.id}_{idx}\">{label}</div>"
        idx = idx + 1
    return "<div class=\"widget-selection-pill{focus_class}\" id=\"{node.id}\">{pills_html}</div>"

fn render_html_empty_state(node: WidgetNode, focus_class: text) -> text:
    """Render an empty-state placeholder: optional icon, a title, and subtitle."""
    val title = node.get_prop("title")
    val subtitle = node.get_prop("subtitle")
    val icon = node.get_prop("icon")
    val icon_html = if icon != "": "<div class=\"empty-icon\">{icon}</div>" else: ""
    val sub_html = if subtitle != "": "<div class=\"empty-subtitle\">{subtitle}</div>" else: ""
    return "<div class=\"widget-empty-state{focus_class}\" id=\"{node.id}\">{icon_html}<div class=\"empty-title\">{title}</div>{sub_html}</div>"

# =========================================================================
# Full HTML Tree Render
# =========================================================================

fn render_html_tree(node: WidgetNode, state: UIState) -> text:
    """Render the entire widget tree to HTML."""
    return render_html_widget(node, state)
