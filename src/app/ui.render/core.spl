# UI Render Core Layer
#
# Core render execution.  Dispatches to the appropriate app adapter based
# on config.adapter_name and returns a RenderResult.

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.session.{RenderSession, create_session}
use app.dashboard.render.adapter.{render_dashboard, DashboardRenderRequest}
use app.llm_dashboard.render_adapter.{render_dashboard as render_llm_dashboard}
use app.llm_dashboard.data.store.{AgentDashboardStore}
use app.office.render_adapter.{office_render}
use app.lint.render_adapter.{render_lint}
use app.check.render_adapter.{render_check}
use app.build.render_adapter.{render_build}
use app.env.render_adapter.{render_env}
use app.build.quality.{QualityResult, CheckResult, default_lint_config, default_check_config, Lint, Check}
use app.build.types.{BuildResult, BuildConfig}
use app.build.config.{parse_build_args}
use app.build.orchestrator.{orchestrate_build}
use app.ui.none.app.{run_headless}

# =========================================================================
# Public API
# =========================================================================

fn execute_render(session: RenderSession) -> RenderResult:
    """Dispatch render to the appropriate adapter and return a result.

    Adapter selection is driven by session.config.adapter_name.  Unknown
    adapters fall back to headless rendering of the asset file when a path
    is provided, or return an empty result.
    """
    val config = session.config

    match config.adapter_name:
        "dashboard" =>
            val req = DashboardRenderRequest(config: config, summary: {})
            return render_dashboard(req)

        "llm_dashboard" =>
            var store = AgentDashboardStore()
            return render_llm_dashboard(config, store)

        "word" | "sheets" | "slides" | "mail" | "planner" | "launcher" =>
            return office_render(config)

        "lint" =>
            val lint_config = default_lint_config()
            val lint_result = Lint.run(lint_config)
            return render_lint(config, lint_result)

        "check" =>
            val check_config = default_check_config()
            val check_result = Check.run(check_config)
            return render_check(config, check_result)

        "build" =>
            val build_args = parse_build_args([])
            val build_result = orchestrate_build(build_args)
            return render_build(config, build_result, build_args)

        "env" =>
            return render_env(config)

        _ =>
            if config.asset_path.len() > 0:
                run_headless(config.asset_path)
                return RenderResult.text("Rendered: {config.asset_path}")
            return RenderResult.empty()
