# Part 2 of src/app/ui.render/tui_widgets.spl
use app.ui.render.tui_widgets.*
# TUI Widget Renderers
#
# Standalone TUI renderer surface split from the mixed widgets module so
# terminal-only entry closures do not inherit HTML/web renderer code.

use app.ui.render.ansi.{RESET, BOLD, DIM, CYAN, WHITE, BLUE, YELLOW, GREEN, RED,
    BRIGHT_WHITE, BRIGHT_CYAN, BRIGHT_BLUE}
use app.dashboard.render.table.{pad_right, pad_left, center}
use app.dashboard.render.progress.{render_progress_bar}
use common.ui.widget.{WidgetNode, WidgetRect, UIState}
use app.ui.tui.screen.{Screen}
use app.ui.render.colors.{get_theme_color}

fn render_tui_textarea(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    """Render a multi-line text area with border."""
    var s = screen
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val is_readonly = node.get_prop("readonly") == "true"

    val border_style = if focused: get_theme_color(theme, "border_focused") elif is_readonly: get_theme_color(theme, "text_dim") else: get_theme_color(theme, "border")

    # Draw border
    s = s.draw_box(rect.y, rect.x, rect.w, rect.h, "")

    # Render text content inside border
    val display = if value != "": value else: placeholder
    val content_style = if value != "":
        if is_readonly: get_theme_color(theme, "readonly") else: get_theme_color(theme, "text")
    else:
        get_theme_color(theme, "text_dim")

    if display != "":
        val inner_w = rect.w - 2
        var row = rect.y + 1
        # Split display into character array to avoid byte/char mismatch
        val display_chars = display.split("")
        var text_pos = 0
        while row < rect.y + rect.h - 1 and text_pos < display_chars.len():
            # Extract a line worth of text
            var line_chars: [text] = []
            var col_count = 0
            while text_pos < display_chars.len() and col_count < inner_w:
                val ch = display_chars[text_pos]
                if ch == "" or ch == "\n":
                    text_pos = text_pos + 1
                    if ch == "\n":
                        break
                else:
                    line_chars.push(ch)
                    col_count = col_count + 1
                    text_pos = text_pos + 1
            val line_text = line_chars.join("")
            s = s.put_styled(row, rect.x + 1, line_text, content_style)
            row = row + 1

    # Show cursor indicator when focused
    if focused and not is_readonly:
        val cursor_style = get_theme_color(theme, "accent")
        s = s.put_styled(rect.y + 1, rect.x + rect.w - 2, "\u{2588}", cursor_style)

    return s

fn render_tui_heading(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a heading with bold underlined style."""
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    if display == "":
        return screen
    var s = screen
    val style = get_theme_color(theme, "title")
    s = s.put_styled(rect.y, rect.x, display, style)
    # Draw underline
    if rect.h > 1:
        var chars: [text] = []
        var i = 0
        while i < display.len() and i < rect.w:
            chars.push("\u{2500}")
            i = i + 1
        val underline = chars.join("")
        s = s.put_styled(rect.y + 1, rect.x, underline, get_theme_color(theme, "accent"))
    return s

# =========================================================================
# Template Expansion
# =========================================================================

fn expand_template(template_text: text, state: UIState) -> text:
    """Expand placeholders like {app.mode} and {app.title}."""
    if template_text == "":
        return ""
    var result = template_text
    val ph_mode = "{" + "app.mode" + "}"
    val ph_title = "{" + "app.title" + "}"
    if text_contains(result, ph_mode):
        val mode_name = state.mode_name()
        result = replace_placeholder(result, ph_mode, mode_name)
    if text_contains(result, ph_title):
        result = replace_placeholder(result, ph_title, state.tree.title_text())
    return result

fn replace_placeholder(text_val: text, placeholder: text, replacement: text) -> text:
    """Simple string replacement without relying on text.replace() or slicing."""
    if placeholder == "":
        return text_val
    val parts = text_val.split(placeholder)
    return parts.join(replacement)

fn text_contains(haystack: text, needle: text) -> bool:
    if needle == "":
        return true
    val idx = haystack.index_of(needle)
    match idx:
        case Some(_):
            return true
        case _:
            return false

# =========================================================================
# Full TUI Tree Render
# =========================================================================

fn render_tui_tree(screen: Screen, node: WidgetNode, rects: [WidgetRect], state: UIState) -> Screen:
    """Render an entire widget tree to the screen."""
    var s = screen

    var node_rect: WidgetRect? = nil
    for rect in rects:
        if rect.id == node.id:
            node_rect = rect
            break

    if node_rect != nil:
        s = render_tui_widget(s, node, node_rect, state)

    for child in node.children():
        if child.is_visible():
            s = render_tui_tree(s, child, rects, state)

    return s

# =========================================================================
# HTML Widget Rendering
# =========================================================================

fn render_tui_navigation_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a navigation bar as a bold centered title row in TUI."""
    var s = screen
    val title = node.get_prop("title")
    val color = get_theme_color(theme, "accent")
    # Center the title in the available width
    val padded = center(title, rect.w)
    s = s.write(rect.x, rect.y, "{BOLD}{color}{padded}{RESET}")
    return s

fn render_tui_tab_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a bottom tab bar as a row of icon+label pairs."""
    var s = screen
    val accent = get_theme_color(theme, "accent")
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var bar_text = ""
    var idx = 0
    for child in node.children():
        val icon = child.get_prop("icon")
        val label = child.get_prop("label")
        if idx > 0:
            bar_text = "{bar_text} | "
        if idx == active_idx:
            bar_text = "{bar_text}{accent}{BOLD}{icon} {label}{RESET}"
        else:
            bar_text = "{bar_text}{DIM}{icon} {label}{RESET}"
        idx = idx + 1

    val padded = center(bar_text, rect.w)
    s = s.write(rect.x, rect.y, padded)
    return s

fn render_tui_card(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a card as a bordered panel in TUI."""
    # Delegate to panel renderer (card is a styled panel)
    return render_tui_panel(screen, node, rect, is_focused, theme)

fn render_tui_switch(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a toggle switch in TUI."""
    var s = screen
    val label = node.get_prop("label")
    val on_val = node.get_prop("on")
    val accent = get_theme_color(theme, "accent")
    val indicator = if on_val == "true": "{GREEN}[ON ]{RESET}" else: "{DIM}[ OFF]{RESET}"
    val focus_marker = if is_focused: "{accent}>{RESET} " else: "  "
    s = s.write(rect.x, rect.y, "{focus_marker}{label}  {indicator}")
    return s

fn render_tui_segmented_control(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a segmented control in TUI."""
    var s = screen
    val accent = get_theme_color(theme, "accent")
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var seg_text = "["
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        if idx > 0:
            seg_text = "{seg_text} | "
        if idx == active_idx:
            seg_text = "{seg_text}{accent}{BOLD}*{label}*{RESET}"
        else:
            seg_text = "{seg_text}{label}"
        idx = idx + 1
    seg_text = "{seg_text}]"

    s = s.write(rect.x, rect.y, seg_text)
    return s

fn render_tui_search_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a search bar in TUI."""
    var s = screen
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val accent = get_theme_color(theme, "accent")
    val display = if value != "": value else: "{DIM}{placeholder}{RESET}"
    val focus_indicator = if is_focused: accent else: ""
    s = s.write(rect.x, rect.y, "{focus_indicator}\u{1F50D} {display}{RESET}")
    return s

