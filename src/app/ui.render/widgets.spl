#![allow(unnamed_duplicate_typed_args)]
# UI Widget Renderers
#
# Renders widgets to both TUI (ANSI) and HTML formats.
# TUI rendering writes to a Screen buffer using WidgetRect positions.
# All TUI renderers resolve colors from the theme via get_theme_color().
# HTML rendering produces HTML string fragments.

use app.ui.render.ansi.{RESET, BOLD, DIM, CYAN, WHITE, BLUE, YELLOW, GREEN, RED,
    BRIGHT_WHITE, BRIGHT_CYAN, BRIGHT_BLUE}
use app.dashboard.render.table.{pad_right, pad_left, center}
use app.dashboard.render.progress.{render_progress_bar}
use common.ui.widget.{WidgetNode, WidgetRect, UIState}
use app.ui.tui.screen.{Screen}
use app.ui.render.colors.{get_theme_color}

# =========================================================================
# Theme Helper
# =========================================================================

fn resolve_theme(state: UIState) -> text:
    """Extract the theme name from UIState."""
    return state.tree.theme_name()

# =========================================================================
# TUI Widget Rendering
# =========================================================================

fn render_tui_widget(screen: Screen, node: WidgetNode, rect: WidgetRect, state: UIState) -> Screen:
    """Render a single widget to the TUI screen buffer."""
    val is_focused = node.id == state.focused_id
    val theme = resolve_theme(state)

    match node.kind_name():
        "panel" =>
            return render_tui_panel(screen, node, rect, is_focused, theme)
        "text" =>
            return render_tui_text(screen, node, rect, is_focused, theme)
        "list" =>
            return render_tui_list(screen, node, rect, is_focused, theme)
        "table" =>
            return render_tui_table(screen, node, rect, is_focused, theme)
        "progress" =>
            return render_tui_progress(screen, node, rect, theme)
        "menubar" =>
            return render_tui_menubar(screen, node, rect, theme)
        "statusbar" =>
            return render_tui_statusbar(screen, node, rect, state)
        "input" =>
            return render_tui_input(screen, node, rect, is_focused, theme)
        "tabs" =>
            return render_tui_tabs(screen, node, rect, is_focused, theme)
        "button" =>
            return render_tui_button(screen, node, rect, is_focused, theme)
        "checkbox" =>
            return render_tui_checkbox(screen, node, rect, is_focused, theme)
        "dropdown" =>
            return render_tui_dropdown(screen, node, rect, is_focused, theme)
        "textfield" =>
            return render_tui_textfield(screen, node, rect, is_focused, theme)
        "image" =>
            return render_tui_image(screen, node, rect, theme)
        "divider" =>
            return render_tui_divider(screen, node, rect, theme)
        "dialog" =>
            return render_tui_dialog(screen, node, rect, is_focused, theme)
        "tooltip" =>
            return render_tui_tooltip(screen, node, rect, theme)
        "tree" =>
            return render_tui_tree_widget(screen, node, rect, state)
        "treenode" =>
            return render_tui_tree_node(screen, node, rect, is_focused, 0, theme)
        "scroll" =>
            return render_tui_scroll(screen, node, rect, state)
        "textarea" =>
            return render_tui_textarea(screen, node, rect, is_focused, theme)
        "heading" =>
            return render_tui_heading(screen, node, rect, theme)
        "label" =>
            return render_tui_text(screen, node, rect, is_focused, theme)
        # iOS widgets
        "navigation_bar" =>
            return render_tui_navigation_bar(screen, node, rect, theme)
        "tab_bar" =>
            return render_tui_tab_bar(screen, node, rect, is_focused, theme)
        "card" =>
            return render_tui_card(screen, node, rect, is_focused, theme)
        "switch" =>
            return render_tui_switch(screen, node, rect, is_focused, theme)
        "segmented_control" =>
            return render_tui_segmented_control(screen, node, rect, is_focused, theme)
        "search_bar" =>
            return render_tui_search_bar(screen, node, rect, is_focused, theme)

fn render_tui_tree_widget(screen: Screen, node: WidgetNode, rect: WidgetRect, state: UIState) -> Screen:
    """Render a tree container by rendering each child treenode at depth 0."""
    var s = screen
    var row = rect.y
    val theme = resolve_theme(state)
    for child in node.children():
        if row >= rect.y + rect.h:
            break
        val is_child_focused = child.id == state.focused_id
        val rows_used = render_tui_tree_node_rows(s, child, rect.x, row, rect.w, rect.y + rect.h, is_child_focused, 0, theme)
        s = rows_used.screen
        row = rows_used.next_row
    return s

struct TreeRenderResult:
    screen: Screen
    next_row: i32

fn render_tui_tree_node_rows(screen: Screen, node: WidgetNode, x: i32, y: i32, w: i32, max_y: i32, focused: bool, depth: i32, theme: text) -> TreeRenderResult:
    """Render a treenode and its children recursively, returning updated screen and next row."""
    var s = screen
    if y >= max_y:
        return TreeRenderResult(screen: s, next_row: y)

    val label = node.get_prop("label")
    val expanded = node.get_prop("expanded")
    val has_children = node.child_count() > 0

    # Build indent
    var indent = ""
    var d = 0
    while d < depth:
        indent = "{indent}  "
        d = d + 1

    # Build marker
    var marker = "  "
    if has_children:
        if expanded == "true":
            marker = "\u{25bc} "
        else:
            marker = "\u{25b6} "

    val line = "{indent}{marker}{label}"
    val style = if focused: get_theme_color(theme, "list_selected") else: get_theme_color(theme, "list_item")
    s = s.put_styled(y, x, line, style)
    var row = y + 1

    # Recursively render children if expanded
    if has_children and expanded == "true":
        for child in node.children():
            if row >= max_y:
                break
            val is_child_focused = false
            val result = render_tui_tree_node_rows(s, child, x, row, w, max_y, is_child_focused, depth + 1, theme)
            s = result.screen
            row = result.next_row

    return TreeRenderResult(screen: s, next_row: row)

fn render_tui_tree_node(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, depth: i32, theme: text) -> Screen:
    """Render a single treenode (standalone, used from render_tui_widget match)."""
    val result = render_tui_tree_node_rows(screen, node, rect.x, rect.y, rect.w, rect.y + rect.h, focused, depth, theme)
    return result.screen

fn render_tui_panel(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val title = node.get_prop("title")
    var s = screen
    val border_style = if focused: get_theme_color(theme, "border_focused") else: get_theme_color(theme, "border")
    # Draw box border
    s = s.draw_box(rect.y, rect.x, rect.w, rect.h, title)
    return s

fn render_tui_text(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    if display == "":
        return screen
    var s = screen
    val style = if focused: get_theme_color(theme, "text") else: get_theme_color(theme, "text_dim")
    s = s.put_styled(rect.y, rect.x, display, style)
    return s

fn render_tui_list(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    var s = screen
    var row = rect.y
    var idx = 0
    val sel_str = node.get_prop("selected_index")
    var sel_idx = -1
    if sel_str != "":
        sel_idx = sel_str.to_int()
    val selected_style = get_theme_color(theme, "list_selected")
    val item_style = get_theme_color(theme, "list_item")
    for child in node.children():
        if row >= rect.y + rect.h:
            break
        val label = child.get_prop("label")
        if label != "":
            val is_selected = idx == sel_idx
            # Use Unicode triangle for selected indicator (matches HTML)
            val prefix = if is_selected: "\u{25b8} " else: "  "
            if is_selected:
                val inv = "\u{001b}[7m"
                s = s.put_styled(row, rect.x, "{prefix}{label}", "{inv}{selected_style}")
            else:
                s = s.put_styled(row, rect.x, "{prefix}{label}", item_style)
            row = row + 1
        idx = idx + 1
    return s

fn split_by_pipe(input: text) -> [text]:
    """Split a text string by '|' delimiter."""
    return input.split("|")

fn render_tui_table(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    var s = screen
    var row = rect.y

    # Parse headers
    val header_str = node.get_prop("headers")
    var headers: [text] = []
    if header_str != "":
        headers = split_by_pipe(header_str)

    val sort_col = node.get_prop("sort_column")
    val sort_dir = node.get_prop("sort_dir")
    val filter_text = node.get_prop("filter_text")

    # Collect row data (split each child label by "|")
    var all_rows: [[text]] = []
    for child in node.children():
        val label = child.get_prop("label")
        if label != "":
            val cells = split_by_pipe(label)
            # Apply filter if set
            if filter_text != "":
                if text_contains(label, filter_text):
                    all_rows = all_rows.push(cells)
            else:
                all_rows = all_rows.push(cells)

    # Determine column count without indexed array access. The current
    # bootstrap compiler/runtime still miscompiles some indexed table paths.
    var col_count = headers.len()
    for data_row in all_rows:
        if data_row.len() > col_count:
            col_count = data_row.len()

    val header_style = get_theme_color(theme, "title")
    val column_width = 14

    # Render header row with sort indicator
    if col_count > 0 and row < rect.y + rect.h:
        var header_line = "| "
        var hi = 0
        for hdr in headers:
            val indicator = if sort_col == "{hi}":
                if sort_dir == "desc": " \u{25bc}" else: " \u{25b2}"
            else:
                ""
            val hdr_text = "{hdr}{indicator}"
            val padded = pad_right(hdr_text, column_width)
            header_line = "{header_line}{padded} | "
            hi = hi + 1
        while hi < col_count:
            header_line = "{header_line}{pad_right(\"\", column_width)} | "
            hi = hi + 1
        s = s.put_styled(row, rect.x, header_line, header_style)
        row = row + 1

    # Render separator line: +----+----+
    if col_count > 0 and row < rect.y + rect.h:
        var sep_line = "+"
        var si = 0
        while si < col_count:
            sep_line = "{sep_line}{\"-\".repeat(column_width + 2)}+"
            si = si + 1
        s = s.put_text(row, rect.x, sep_line)
        row = row + 1

    # Render data rows
    val text_style = get_theme_color(theme, "text")
    for data_row in all_rows:
        if row >= rect.y + rect.h:
            break
        var data_line = "| "
        var di = 0
        for cell in data_row:
            val padded = pad_right(cell, column_width)
            data_line = "{data_line}{padded} | "
            di = di + 1
        while di < col_count:
            data_line = "{data_line}{pad_right(\"\", column_width)} | "
            di = di + 1
        s = s.put_styled(row, rect.x, data_line, text_style)
        row = row + 1

    return s

fn render_tui_progress(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    val value_str = node.get_prop("value")
    var raw_val = if value_str != "": value_str.to_int() else: 0
    val value = if raw_val < 0: 0 elif raw_val > 100: 100 else: raw_val
    val label = node.get_prop("label")
    val pct_text = " {value}%"
    val label_w = if label != "": label.len() + 1 else: 0
    val bar_width = rect.w - pct_text.len() - label_w - 2
    if bar_width <= 0:
        return screen
    var s = screen
    # Label prefix
    if label != "":
        s = s.put_styled(rect.y, rect.x, "{label} ", get_theme_color(theme, "text"))

    # Build bar with Unicode block chars
    val filled = (value * bar_width) / 100
    val fill_style = get_theme_color(theme, "progress_fill")
    val empty_style = get_theme_color(theme, "progress_empty")
    var chars: [text] = []
    var i = 0
    while i < bar_width:
        if i < filled:
            chars = chars.push("\u{2588}")
        else:
            chars = chars.push("\u{2591}")
        i = i + 1
    val bar = chars.join("")
    s = s.put_styled(rect.y, rect.x + label_w, bar, fill_style)
    s = s.put_styled(rect.y, rect.x + label_w + bar_width, pct_text, get_theme_color(theme, "text"))
    return s

fn render_tui_menubar(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    var s = screen
    # Fill background
    s = s.fill_row(rect.y, " ")
    var col = rect.x
    val menu_style = get_theme_color(theme, "title")
    val sep_style = get_theme_color(theme, "text_dim")
    for child in node.children():
        val is_separator = child.get_prop("is_separator")
        val has_submenu = child.get_prop("has_submenu")
        val label = child.get_prop("label")
        if is_separator == "true":
            val sep_text = " | "
            s = s.put_styled(rect.y, col, sep_text, sep_style)
            col = col + sep_text.len()
        elif has_submenu == "true":
            if label != "":
                val menu_text = " {label} \u{25be} "
                s = s.put_styled(rect.y, col, menu_text, menu_style)
                col = col + menu_text.len() + 1
        elif label != "":
            val menu_text = " {label} "
            s = s.put_styled(rect.y, col, menu_text, menu_style)
            col = col + menu_text.len() + 1
    return s

fn render_tui_statusbar(screen: Screen, node: WidgetNode, rect: WidgetRect, state: UIState) -> Screen:
    var s = screen
    val theme = resolve_theme(state)
    val left_template = node.get_prop("left")
    val right_template = node.get_prop("right")

    val left_text = expand_template(left_template, state)
    val right_text = expand_template(right_template, state)

    val left_style = get_theme_color(theme, "title")
    val right_style = get_theme_color(theme, "text_dim")

    s = s.fill_row(rect.y, " ")
    s = s.put_styled(rect.y, rect.x, left_text, left_style)

    val right_col = rect.x + rect.w - right_text.len() - 1
    if right_col > 0:
        s = s.put_styled(rect.y, right_col, right_text, right_style)

    return s

fn render_tui_input(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val display = if value != "": value elif placeholder != "": placeholder else: ""
    val is_error = node.get_prop("error") == "true"
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    var s = screen
    val style = if is_disabled:
        get_theme_color(theme, "disabled")
    elif is_error:
        get_theme_color(theme, "error_fg")
    elif is_readonly:
        get_theme_color(theme, "readonly")
    elif focused:
        get_theme_color(theme, "input_focused")
    else:
        get_theme_color(theme, "input")
    # Show text style: dim for placeholder, normal for value
    val text_style = if value != "": style else: get_theme_color(theme, "text_dim")
    val prompt = if focused: "\u{25b8} " else: "  "
    # Underline indicator for input field
    val max_display_w = rect.w - 3
    val trimmed = if display.len() > max_display_w: display.slice(0, max_display_w) else: display
    s = s.put_styled(rect.y, rect.x, "{prompt}{trimmed}", text_style)
    # Draw underline on next row if space
    if rect.h > 1:
        var chars: [text] = ["  "]
        var i = 0
        while i < rect.w - 2:
            chars = chars.push("\u{2500}")
            i = i + 1
        val underline = chars.join("")
        val ul_style = if is_error: get_theme_color(theme, "error_border") elif focused: get_theme_color(theme, "accent") else: get_theme_color(theme, "border")
        s = s.put_styled(rect.y + 1, rect.x, underline, ul_style)
    # Error message below
    if is_error and rect.h > 2:
        val err_msg = node.get_prop("error_message")
        if err_msg != "":
            s = s.put_styled(rect.y + 2, rect.x + 2, err_msg, get_theme_color(theme, "error_fg"))
    return s

fn render_tui_tabs(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    var s = screen
    var col = rect.x
    var idx = 0
    val active_idx_str = node.get_prop("active_index")
    val active_idx = if active_idx_str != "": active_idx_str.to_int() else: 0
    val active_style = get_theme_color(theme, "tab_active")
    val inactive_style = get_theme_color(theme, "tab_inactive")
    val sep_style = get_theme_color(theme, "border")
    for child in node.children():
        val label = child.get_prop("label")
        if label != "":
            val is_active = idx == active_idx
            val style = if is_active: active_style else: inactive_style
            val tab_text = " {label} "
            s = s.put_styled(rect.y, col, tab_text, style)
            col = col + tab_text.len()
            # Separator between tabs
            s = s.put_styled(rect.y, col, "\u{2502}", sep_style)
            col = col + 1
        idx = idx + 1
    # Underline for active tab indicator (on second row if space)
    if rect.h > 1:
        var ul_col = rect.x
        var ui = 0
        for child in node.children():
            val label = child.get_prop("label")
            if label != "":
                val tab_w = label.len() + 2
                if ui == active_idx:
                    var chars: [text] = []
                    var uli = 0
                    while uli < tab_w:
                        chars = chars.push("\u{2501}")
                        uli = uli + 1
                    val underline = chars.join("")
                    s = s.put_styled(rect.y + 1, ul_col, underline, get_theme_color(theme, "accent"))
                ul_col = ul_col + tab_w + 1
            ui = ui + 1
    return s

# =========================================================================
# New TUI Widget Renderers
# =========================================================================

fn render_tui_button(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val label = node.get_prop("label")
    val is_disabled = node.get_prop("disabled") == "true"
    val style = if is_disabled:
        get_theme_color(theme, "disabled")
    elif focused:
        get_theme_color(theme, "button_focused")
    else:
        get_theme_color(theme, "button")
    # Use Unicode rounded brackets for polished button look
    val btn_text = if focused: "\u{2523} {label} \u{252b}" else: "\u{2503} {label} \u{2503}"
    return screen.put_styled(rect.y, rect.x, btn_text, style)

fn render_tui_checkbox(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val label = node.get_prop("label")
    val checked = node.get_prop("checked")
    val is_disabled = node.get_prop("disabled") == "true"
    # Use Unicode check mark for checked state
    val marker = if checked == "true": "\u{2713}" else: " "
    val style = if is_disabled:
        get_theme_color(theme, "disabled")
    elif checked == "true":
        get_theme_color(theme, "checkbox_checked")
    elif focused:
        get_theme_color(theme, "text")
    else:
        get_theme_color(theme, "checkbox")
    val focus_indicator = if focused: "\u{25b8} " else: "  "
    return screen.put_styled(rect.y, rect.x, "{focus_indicator}[{marker}] {label}", style)

fn render_tui_dropdown(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    var s = screen
    val is_disabled = node.get_prop("disabled") == "true"
    val style = if is_disabled:
        get_theme_color(theme, "disabled")
    elif focused:
        get_theme_color(theme, "input_focused")
    else:
        get_theme_color(theme, "input")
    val sel_str = node.get_prop("selected_index")
    var sel_idx = 0
    if sel_str != "":
        sel_idx = sel_str.to_int()
    val child = node.child_at(sel_idx)
    val selected = if child != nil: child.get_prop("label") else: "(none)"
    # Unicode down-pointing triangle for dropdown indicator
    val arrow = if focused: "\u{25be}" else: "\u{25bf}"
    s = s.put_styled(rect.y, rect.x, "[{arrow}] {selected}", style)
    return s

fn render_tui_textfield(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val display = if value != "": value else: placeholder
    val is_readonly = node.get_prop("readonly") == "true"
    val is_error = node.get_prop("error") == "true"
    val style = if is_error:
        get_theme_color(theme, "error_fg")
    elif is_readonly:
        get_theme_color(theme, "readonly")
    elif focused:
        get_theme_color(theme, "input_focused")
    else:
        get_theme_color(theme, "input")
    # Use box-drawing chars for field border
    val max_w = rect.w - 2
    val trimmed = if display.len() > max_w: display.slice(0, max_w) else: display
    val text_style = if value != "": style else: get_theme_color(theme, "text_dim")
    var s = screen
    s = s.put_styled(rect.y, rect.x, "\u{2502}{trimmed}\u{2502}", text_style)
    # Cursor block when focused
    if focused and not is_readonly:
        val cursor_pos = rect.x + 1 + trimmed.len()
        if cursor_pos < rect.x + rect.w - 1:
            s = s.put_styled(rect.y, cursor_pos, "\u{2588}", get_theme_color(theme, "accent"))
    return s

fn render_tui_image(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    val alt = node.get_prop("alt")
    val display = if alt != "": "[IMG: {alt}]" else: "[IMG]"
    val style = get_theme_color(theme, "text_dim")
    return screen.put_styled(rect.y, rect.x, display, style)

fn render_tui_divider(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a horizontal divider using thin Unicode line."""
    val style = get_theme_color(theme, "border")
    var s = screen
    var chars: [text] = []
    var i = 0
    while i < rect.w:
        chars = chars.push("\u{2500}")
        i = i + 1
    val line = chars.join("")
    s = s.put_styled(rect.y, rect.x, line, style)
    return s

fn render_tui_dialog(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    """Render a dialog with double-line border for visual distinction."""
    val title = node.get_prop("title")
    val border_style = get_theme_color(theme, "dialog_border")
    var s = screen
    # Use double-line border to visually distinguish dialogs from panels
    s = s.draw_box_double(rect.y, rect.x, rect.w, rect.h, title)
    return s

fn render_tui_tooltip(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a tooltip with rounded border box."""
    val content = node.get_prop("content")
    var s = screen
    if rect.h >= 3 and rect.w >= 4:
        s = s.draw_box_rounded(rect.y, rect.x, rect.w, rect.h, "")
        val style = get_theme_color(theme, "text_dim")
        val max_text_w = rect.w - 4
        val display = if content.len() > max_text_w: content.slice(0, max_text_w) else: content
        s = s.put_styled(rect.y + 1, rect.x + 2, display, style)
    else:
        val style = get_theme_color(theme, "text_dim")
        s = s.put_styled(rect.y, rect.x, "[?] {content}", style)
    return s

fn render_tui_scroll(screen: Screen, node: WidgetNode, rect: WidgetRect, state: UIState) -> Screen:
    """Render a scroll container with scrollbar indicator."""
    var s = screen
    val theme = resolve_theme(state)
    val offset_str = node.get_prop("scroll_offset")
    val offset = if offset_str != "": offset_str.to_int() else: 0
    val total_children = node.child_count()

    # Render visible children within the rect
    var row = rect.y
    var child_idx = offset
    while child_idx < total_children and row < rect.y + rect.h:
        val child = node.child_at(child_idx)
        if child != nil:
            val is_child_focused = child.id == state.focused_id
            val child_theme = resolve_theme(state)
            s = render_tui_widget(s, child, WidgetRect.new(child.id, rect.x, row, rect.w - 1, 1), state)
            row = row + 1
        child_idx = child_idx + 1

    # Draw scrollbar track on right edge
    if total_children > rect.h and rect.h > 0:
        val scrollbar_col = rect.x + rect.w - 1
        val track_style = get_theme_color(theme, "text_dim")
        val thumb_style = get_theme_color(theme, "accent")
        val thumb_pos = if total_children > 0: (offset * rect.h) / total_children else: 0
        val thumb_size = if total_children > 0: (rect.h * rect.h) / total_children else: 1
        val actual_thumb = if thumb_size < 1: 1 else: thumb_size
        var si = 0
        while si < rect.h:
            val is_thumb = si >= thumb_pos and si < thumb_pos + actual_thumb
            if is_thumb:
                s = s.put_styled(rect.y + si, scrollbar_col, "\u{2588}", thumb_style)
            else:
                s = s.put_styled(rect.y + si, scrollbar_col, "\u{2591}", track_style)
            si = si + 1

    return s

fn render_tui_textarea(screen: Screen, node: WidgetNode, rect: WidgetRect, focused: bool, theme: text) -> Screen:
    """Render a multi-line text area with border."""
    var s = screen
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val is_readonly = node.get_prop("readonly") == "true"

    val border_style = if focused: get_theme_color(theme, "border_focused") elif is_readonly: get_theme_color(theme, "text_dim") else: get_theme_color(theme, "border")

    # Draw border
    s = s.draw_box(rect.y, rect.x, rect.w, rect.h, "")

    # Render text content inside border
    val display = if value != "": value else: placeholder
    val content_style = if value != "":
        if is_readonly: get_theme_color(theme, "readonly") else: get_theme_color(theme, "text")
    else:
        get_theme_color(theme, "text_dim")

    if display != "":
        val inner_w = rect.w - 2
        var row = rect.y + 1
        # Split display into character array to avoid byte/char mismatch
        val display_chars = display.split("")
        var text_pos = 0
        while row < rect.y + rect.h - 1 and text_pos < display_chars.len():
            # Extract a line worth of text
            var line_chars: [text] = []
            var col_count = 0
            while text_pos < display_chars.len() and col_count < inner_w:
                val ch = display_chars[text_pos]
                if ch == "" or ch == "\n":
                    text_pos = text_pos + 1
                    if ch == "\n":
                        break
                else:
                    line_chars = line_chars.push(ch)
                    col_count = col_count + 1
                    text_pos = text_pos + 1
            val line_text = line_chars.join("")
            s = s.put_styled(row, rect.x + 1, line_text, content_style)
            row = row + 1

    # Show cursor indicator when focused
    if focused and not is_readonly:
        val cursor_style = get_theme_color(theme, "accent")
        s = s.put_styled(rect.y + 1, rect.x + rect.w - 2, "\u{2588}", cursor_style)

    return s

fn render_tui_heading(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a heading with bold underlined style."""
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    if display == "":
        return screen
    var s = screen
    val style = get_theme_color(theme, "title")
    s = s.put_styled(rect.y, rect.x, display, style)
    # Draw underline
    if rect.h > 1:
        var chars: [text] = []
        var i = 0
        while i < display.len() and i < rect.w:
            chars = chars.push("\u{2500}")
            i = i + 1
        val underline = chars.join("")
        s = s.put_styled(rect.y + 1, rect.x, underline, get_theme_color(theme, "accent"))
    return s

# =========================================================================
# Template Expansion
# =========================================================================

fn expand_template(template_text: text, state: UIState) -> text:
    """Expand placeholders like {app.mode} and {app.title}."""
    if template_text == "":
        return ""
    var result = template_text
    val ph_mode = "{" + "app.mode" + "}"
    val ph_title = "{" + "app.title" + "}"
    if text_contains(result, ph_mode):
        val mode_name = state.mode_name()
        result = replace_placeholder(result, ph_mode, mode_name)
    if text_contains(result, ph_title):
        result = replace_placeholder(result, ph_title, state.tree.title_text())
    return result

fn replace_placeholder(text_val: text, placeholder: text, replacement: text) -> text:
    """Simple string replacement without relying on text.replace() or slicing."""
    if placeholder == "":
        return text_val
    val parts = text_val.split(placeholder)
    return parts.join(replacement)

fn text_contains(haystack: text, needle: text) -> bool:
    if needle == "":
        return true
    val idx = haystack.index_of(needle)
    match idx:
        case Some(_):
            return true
        case _:
            return false

# =========================================================================
# Full TUI Tree Render
# =========================================================================

fn render_tui_tree(screen: Screen, node: WidgetNode, rects: [WidgetRect], state: UIState) -> Screen:
    """Render an entire widget tree to the screen."""
    var s = screen

    var node_rect: WidgetRect? = nil
    for rect in rects:
        if rect.id == node.id:
            node_rect = rect
            break

    if node_rect != nil:
        s = render_tui_widget(s, node, node_rect, state)

    for child in node.children():
        if child.is_visible():
            s = render_tui_tree(s, child, rects, state)

    return s

# =========================================================================
# HTML Widget Rendering
# =========================================================================

fn render_html_widget(node: WidgetNode, state: UIState) -> text:
    """Render a widget to an HTML string."""
    val is_focused = node.id == state.focused_id
    val focus_class = if is_focused: " focused" else: ""

    match node.kind_name():
        "vbox" =>
            return render_html_vbox(node, state, focus_class)
        "hbox" =>
            return render_html_hbox(node, state, focus_class)
        "panel" =>
            return render_html_panel(node, state, focus_class)
        "text" =>
            return render_html_text(node, focus_class)
        "list" =>
            return render_html_list(node, state, focus_class)
        "table" =>
            return render_html_table(node, state, focus_class)
        "progress" =>
            return render_html_progress(node, focus_class)
        "menubar" =>
            return render_html_menubar(node, state)
        "statusbar" =>
            return render_html_statusbar(node, state)
        "input" =>
            return render_html_input(node, focus_class)
        "tabs" =>
            return render_html_tabs(node, focus_class)
        "button" =>
            return render_html_button(node, focus_class)
        "checkbox" =>
            return render_html_checkbox(node, focus_class)
        "dropdown" =>
            return render_html_dropdown(node, focus_class)
        "textfield" =>
            return render_html_textfield(node, focus_class)
        "image" =>
            return render_html_image(node, focus_class)
        "divider" =>
            return render_html_divider(node)
        "dialog" =>
            return render_html_dialog(node, state, focus_class)
        "tooltip" =>
            return render_html_tooltip(node, focus_class)
        "tree" =>
            return render_html_tree_widget(node, state, focus_class)
        "treenode" =>
            return render_html_tree_node(node, state)
        "scroll" =>
            return render_html_scroll(node, state, focus_class)
        "textarea" =>
            return render_html_textarea(node, focus_class)
        "heading" =>
            return render_html_heading(node, focus_class)
        "label" =>
            return render_html_text(node, focus_class)
        # iOS widgets
        "navigation_bar" =>
            return render_html_navigation_bar(node, state, focus_class)
        "tab_bar" =>
            return render_html_tab_bar(node, state, focus_class)
        "card" =>
            return render_html_card(node, state, focus_class)
        "switch" =>
            return render_html_switch(node, focus_class)
        "segmented_control" =>
            return render_html_segmented_control(node, focus_class)
        "search_bar" =>
            return render_html_search_bar(node, focus_class)

fn render_html_tree_widget(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a tree widget to HTML."""
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_tree_node(child, state)}"
    return "<div class=\"widget-tree{focus_class}\" id=\"{node.id}\"><ul class=\"tree-root\">{children_html}</ul></div>"

fn render_html_tree_node(node: WidgetNode, state: UIState) -> text:
    """Render a treenode to HTML recursively."""
    val label = node.get_prop("label")
    val expanded = node.get_prop("expanded")
    val has_children = node.child_count() > 0
    val exp_class = if has_children and expanded == "true": " expanded" elif has_children: " collapsed" else: " leaf"

    var toggle_html = ""
    if has_children:
        val toggle_marker = if expanded == "true": "\u{25bc}" else: "\u{25b6}"
        toggle_html = "<span class=\"tree-toggle\" data-action=\"toggle_{node.id}\">{toggle_marker}</span>"

    var children_html = ""
    if has_children and expanded == "true":
        var child_items = ""
        for child in node.children():
            child_items = "{child_items}{render_html_tree_node(child, state)}"
        children_html = "<ul>{child_items}</ul>"

    return "<li class=\"tree-node{exp_class}\">{toggle_html}<span class=\"tree-label\">{label}</span>{children_html}</li>"

fn render_html_vbox(node: WidgetNode, state: UIState, focus_class: text) -> text:
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    val flex_prop = node.get_prop("flex")
    var style = "display: flex; flex-direction: column;"
    if flex_prop != "":
        style = "{style} flex: {flex_prop};"
    else:
        style = "{style} flex: 1; min-height: 0;"
    return "<div class=\"layout-vbox{focus_class}\" id=\"{node.id}\" style=\"{style}\">{children_html}</div>"

fn render_html_hbox(node: WidgetNode, state: UIState, focus_class: text) -> text:
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    val flex_prop = node.get_prop("flex")
    var style = "display: flex; flex-direction: row;"
    if flex_prop != "":
        style = "{style} flex: {flex_prop};"
    else:
        style = "{style} flex: 1; min-height: 0;"
    return "<div class=\"layout-hbox{focus_class}\" id=\"{node.id}\" style=\"{style}\">{children_html}</div>"

fn render_html_panel(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"

    val flex_prop = node.get_prop("flex")
    val width_prop = node.get_prop("width")
    val height_prop = node.get_prop("height")
    var style = ""
    if flex_prop != "":
        style = "flex: {flex_prop};"
    elif width_prop != "":
        style = "width: {width_prop}px; flex: none;"
    else:
        style = "flex: 1;"
    if height_prop != "":
        style = "{style} height: {height_prop}em;"

    val layout_class = if node.layout_name() == "hbox": "layout-hbox" elif node.layout_name() == "grid": "layout-grid" else: "layout-vbox"

    # Omit empty title header for layout-only containers
    val title_html = if title != "": "<div class=\"panel-title\">{title}</div>" else: ""

    return "<div class=\"widget-panel {layout_class}{focus_class}\" id=\"{node.id}\" style=\"{style}\">{title_html}<div class=\"panel-content\">{children_html}</div></div>"

fn render_html_text(node: WidgetNode, focus_class: text) -> text:
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    return "<div class=\"widget-text{focus_class}\" id=\"{node.id}\">{display}</div>"

fn render_html_list(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val sel_str = node.get_prop("selected_index")
    var sel_idx = -1
    if sel_str != "":
        sel_idx = sel_str.to_int()
    var items_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val item_class = if idx == sel_idx: "list-item selected" else: "list-item"
        # Include prefix indicator matching TUI's "> " for selected items
        val prefix = if idx == sel_idx: "\u{25b8} " else: ""
        items_html = "{items_html}<li class=\"{item_class}\" data-index=\"{idx}\">{prefix}{label}</li>"
        idx = idx + 1
    return "<ul class=\"widget-list{focus_class}\" id=\"{node.id}\">{items_html}</ul>"

fn render_html_table(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val header_str = node.get_prop("headers")
    val sort_col = node.get_prop("sort_column")
    val sort_dir = node.get_prop("sort_dir")
    val filter_text = node.get_prop("filter_text")

    # Filter input above table
    var filter_html = "<input class=\"table-filter\" placeholder=\"Filter...\" data-action=\"filter_{node.id}\" />"

    # Build thead
    var thead_html = ""
    if header_str != "":
        var headers = split_by_pipe(header_str)
        var th_html = ""
        var hi = 0
        for hdr in headers:
            val indicator = if sort_col == "{hi}":
                if sort_dir == "desc": " \u{25bc}" else: " \u{25b2}"
            else:
                ""
            th_html = "{th_html}<th data-action=\"sort_col_{hi}\">{hdr}{indicator}</th>"
            hi = hi + 1
        thead_html = "<thead><tr>{th_html}</tr></thead>"

    # Build tbody
    var tbody_html = ""
    for child in node.children():
        val label = child.get_prop("label")
        if label != "":
            # Apply filter
            if filter_text != "" and not text_contains(label, filter_text):
                pass_dn
            else:
                val cells = split_by_pipe(label)
                var td_html = ""
                for cell in cells:
                    td_html = "{td_html}<td>{cell}</td>"
                tbody_html = "{tbody_html}<tr>{td_html}</tr>"

    return "{filter_html}<table class=\"widget-table{focus_class}\" id=\"{node.id}\">{thead_html}<tbody>{tbody_html}</tbody></table>"

fn render_html_progress(node: WidgetNode, focus_class: text) -> text:
    val value_str = node.get_prop("value")
    val value = if value_str != "": value_str else: "0"
    val label = node.get_prop("label")
    val label_html = if label != "": "<div class=\"widget-text\" style=\"font-size:12px;margin-bottom:4px;\">{label}</div>" else: ""
    return "{label_html}<div class=\"widget-progress{focus_class}\" id=\"{node.id}\"><div class=\"progress-track\"><div class=\"progress-bar\" style=\"width: {value}%\"></div></div><span class=\"progress-label\">{value}%</span></div>"

fn render_html_menubar(node: WidgetNode, state: UIState) -> text:
    var items_html = ""
    for child in node.children():
        val is_separator = child.get_prop("is_separator")
        val has_submenu = child.get_prop("has_submenu")
        val label = child.get_prop("label")
        if is_separator == "true":
            items_html = "{items_html}<span class=\"menu-separator\">|</span>"
        elif has_submenu == "true":
            var submenu_html = ""
            for sub_child in child.children():
                val sub_label = sub_child.get_prop("label")
                val sub_action = sub_child.get_prop("action")
                val is_sep = sub_child.get_prop("is_separator")
                if is_sep == "true":
                    submenu_html = "{submenu_html}<div class=\"menu-separator\"></div>"
                else:
                    submenu_html = "{submenu_html}<div class=\"submenu-item\" data-action=\"{sub_action}\">{sub_label}</div>"
            items_html = "{items_html}<div class=\"menu-item\">{label}<div class=\"menu-submenu\">{submenu_html}</div></div>"
        else:
            items_html = "{items_html}<span class=\"menu-item\">{label}</span>"
    return "<div class=\"widget-menubar\" id=\"{node.id}\">{items_html}</div>"

fn render_html_statusbar(node: WidgetNode, state: UIState) -> text:
    val left_text = expand_template(node.get_prop("left"), state)
    val right_text = expand_template(node.get_prop("right"), state)
    return "<div class=\"widget-statusbar\" id=\"{node.id}\"><span class=\"status-left\">{left_text}</span><span class=\"status-right\">{right_text}</span></div>"

fn render_html_input(node: WidgetNode, focus_class: text) -> text:
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val is_error = node.get_prop("error") == "true"
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val error_class = if is_error: " error" else: ""
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    return "<input class=\"widget-input{focus_class}{error_class}\" id=\"{node.id}\" value=\"{value}\" placeholder=\"{placeholder}\"{readonly_attr}{disabled_attr} />"

fn render_html_tabs(node: WidgetNode, focus_class: text) -> text:
    val active_idx_str = node.get_prop("active_index")
    val active_idx = if active_idx_str != "": active_idx_str.to_int() else: 0
    var tabs_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == active_idx: " active" else: ""
        tabs_html = "{tabs_html}<span class=\"tab-item{active_class}\" data-index=\"{idx}\">{label}</span>"
        idx = idx + 1
    return "<div class=\"widget-tabs{focus_class}\" id=\"{node.id}\">{tabs_html}</div>"

# =========================================================================
# New HTML Widget Renderers
# =========================================================================

fn render_html_button(node: WidgetNode, focus_class: text) -> text:
    val label = node.get_prop("label")
    val action = node.get_prop("action")
    val is_disabled = node.get_prop("disabled") == "true"
    val disabled_attr = if is_disabled: " disabled" else: ""
    return "<button type=\"button\" class=\"widget-button{focus_class}\" id=\"{node.id}\" data-action=\"{action}\"{disabled_attr}>{label}</button>"

fn render_html_checkbox(node: WidgetNode, focus_class: text) -> text:
    val label = node.get_prop("label")
    val checked = node.get_prop("checked")
    val is_disabled = node.get_prop("disabled") == "true"
    val checked_class = if checked == "true": " checked" else: ""
    val disabled_class = if is_disabled: " disabled" else: ""
    val check_mark = if checked == "true": "\u{2713}" else: ""
    return "<div class=\"widget-checkbox{checked_class}{disabled_class}{focus_class}\" id=\"{node.id}\" data-action=\"toggle_{node.id}\"><div class=\"check-box\">{check_mark}</div><span>{label}</span></div>"

fn render_html_dropdown(node: WidgetNode, focus_class: text) -> text:
    val is_disabled = node.get_prop("disabled") == "true"
    val disabled_attr = if is_disabled: " disabled" else: ""
    val sel_str = node.get_prop("selected_index")
    var sel_idx = if sel_str != "": sel_str.to_int() else: 0
    var options_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val selected_attr = if idx == sel_idx: " selected" else: ""
        options_html = "{options_html}<option{selected_attr}>{label}</option>"
        idx = idx + 1
    return "<select class=\"widget-dropdown{focus_class}\" id=\"{node.id}\"{disabled_attr}>{options_html}</select>"

fn render_html_textfield(node: WidgetNode, focus_class: text) -> text:
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val is_error = node.get_prop("error") == "true"
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    val error_class = if is_error: " error" else: ""
    return "<input type=\"text\" class=\"widget-textfield{focus_class}{error_class}\" id=\"{node.id}\" value=\"{value}\" placeholder=\"{placeholder}\"{readonly_attr}{disabled_attr} />"

fn render_html_image(node: WidgetNode, focus_class: text) -> text:
    val src = node.get_prop("src")
    val alt = node.get_prop("alt")
    return "<img class=\"widget-image{focus_class}\" id=\"{node.id}\" src=\"{src}\" alt=\"{alt}\" />"

fn render_html_divider(node: WidgetNode) -> text:
    return "<hr class=\"widget-divider\" id=\"{node.id}\" />"

fn render_html_dialog(node: WidgetNode, state: UIState, focus_class: text) -> text:
    val title = node.get_prop("title")
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-dialog-overlay\"><div class=\"widget-dialog{focus_class}\" id=\"{node.id}\"><div class=\"dialog-title\">{title}</div><div class=\"dialog-content\">{children_html}</div></div></div>"

fn render_html_tooltip(node: WidgetNode, focus_class: text) -> text:
    val content = node.get_prop("content")
    val target = node.get_prop("target")
    return "<div class=\"widget-tooltip{focus_class}\" id=\"{node.id}\" data-target=\"{target}\"><span class=\"tooltip-trigger\">[?]</span><span class=\"tooltip-content\">{content}</span></div>"

fn render_html_scroll(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render a scrollable container as a div with overflow:auto."""
    val max_h = node.get_prop("max_height")
    val style_attr = if max_h != "": "max-height: {max_h}em; overflow-y: auto;" else: "overflow-y: auto;"
    var children_html = ""
    for child in node.children():
        children_html = "{children_html}{render_html_widget(child, state)}"
    return "<div class=\"widget-scroll{focus_class}\" id=\"{node.id}\" style=\"{style_attr}\">{children_html}</div>"

fn render_html_textarea(node: WidgetNode, focus_class: text) -> text:
    """Render a multi-line textarea."""
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val rows = node.get_prop("rows")
    val is_readonly = node.get_prop("readonly") == "true"
    val is_disabled = node.get_prop("disabled") == "true"
    val is_error = node.get_prop("error") == "true"
    val rows_attr = if rows != "": " rows=\"{rows}\"" else: " rows=\"4\""
    val readonly_attr = if is_readonly: " readonly" else: ""
    val disabled_attr = if is_disabled: " disabled" else: ""
    val error_class = if is_error: " error" else: ""
    return "<textarea class=\"widget-textarea{focus_class}{error_class}\" id=\"{node.id}\" placeholder=\"{placeholder}\"{rows_attr}{readonly_attr}{disabled_attr}>{value}</textarea>"

fn render_html_heading(node: WidgetNode, focus_class: text) -> text:
    """Render a heading element."""
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val display = if content != "": content else: label
    val level = node.get_prop("level")
    val tag = if level == "1": "h1" elif level == "2": "h2" elif level == "3": "h3" else: "h2"
    return "<{tag} class=\"widget-heading{focus_class}\" id=\"{node.id}\">{display}</{tag}>"

# =========================================================================
# iOS Widget HTML Renderers
# =========================================================================

fn render_html_navigation_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style navigation bar."""
    val title = node.get_prop("title")
    val large_title = node.get_prop("large_title")
    val title_class = if large_title == "true": "nav-title nav-title-large" else: "nav-title"

    var left_html = ""
    var right_html = ""
    val children = node.children()
    # First child = left items container, second = title (skip), third = right items container
    if children.len() >= 1:
        val left_container = children[0]
        for child in left_container.children():
            left_html = "{left_html}{render_html_widget(child, state)}"
    if children.len() >= 3:
        val right_container = children[2]
        for child in right_container.children():
            right_html = "{right_html}{render_html_widget(child, state)}"

    var html = "<nav class=\"widget-navigation-bar{focus_class}\" id=\"{node.id}\">"
    html = "{html}<div class=\"nav-left\">{left_html}</div>"
    html = "{html}<div class=\"{title_class}\">{title}</div>"
    html = "{html}<div class=\"nav-right\">{right_html}</div>"
    html = "{html}</nav>"
    return html

fn render_html_tab_bar(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style bottom tab bar."""
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var items_html = ""
    var idx = 0
    for child in node.children():
        val icon = child.get_prop("icon")
        val label = child.get_prop("label")
        val badge = child.get_prop("badge")
        val active_class = if idx == active_idx: " tab-bar-item-active" else: ""
        var badge_html = ""
        if badge != "" and badge != "0":
            badge_html = "<span class=\"tab-bar-badge\">{badge}</span>"
        items_html = "{items_html}<div class=\"tab-bar-item{active_class}\" data-action=\"tab_{node.id}_{idx}\">"
        items_html = "{items_html}<span class=\"tab-bar-icon\">{icon}{badge_html}</span>"
        items_html = "{items_html}<span class=\"tab-bar-label\">{label}</span>"
        items_html = "{items_html}</div>"
        idx = idx + 1

    return "<div class=\"widget-tab-bar{focus_class}\" id=\"{node.id}\">{items_html}</div>"

fn render_html_card(node: WidgetNode, state: UIState, focus_class: text) -> text:
    """Render an iOS-style card."""
    val title = node.get_prop("title")
    val subtitle = node.get_prop("subtitle")

    var header_html = ""
    if title != "":
        header_html = "<div class=\"card-header\"><div class=\"card-title\">{title}</div>"
        if subtitle != "":
            header_html = "{header_html}<div class=\"card-subtitle\">{subtitle}</div>"
        header_html = "{header_html}</div>"

    var content_html = ""
    for child in node.children():
        content_html = "{content_html}{render_html_widget(child, state)}"

    val flex_prop = node.get_prop("flex")
    var style = ""
    if flex_prop != "":
        style = " style=\"flex: {flex_prop};\""

    return "<div class=\"widget-card{focus_class}\" id=\"{node.id}\"{style}>{header_html}<div class=\"card-content\">{content_html}</div></div>"

fn render_html_switch(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style toggle switch."""
    val label = node.get_prop("label")
    val on_val = node.get_prop("on")
    val disabled = node.get_prop("disabled")
    val action = node.get_prop("action")
    val on_class = if on_val == "true": " switch-on" else: ""
    val dis_class = if disabled == "true": " disabled" else: ""

    var html = "<div class=\"widget-switch{on_class}{dis_class}{focus_class}\" id=\"{node.id}\" data-action=\"{action}\">"
    html = "{html}<span class=\"switch-label\">{label}</span>"
    html = "{html}<div class=\"switch-track\"><div class=\"switch-thumb\"></div></div>"
    html = "{html}</div>"
    return html

fn render_html_segmented_control(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style segmented control."""
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var items_html = ""
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        val active_class = if idx == active_idx: " segment-active" else: ""
        items_html = "{items_html}<div class=\"segment-item{active_class}\" data-action=\"segment_{node.id}_{idx}\">{label}</div>"
        idx = idx + 1

    return "<div class=\"widget-segmented-control{focus_class}\" id=\"{node.id}\">{items_html}</div>"

fn render_html_search_bar(node: WidgetNode, focus_class: text) -> text:
    """Render an iOS-style search bar."""
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val show_cancel = node.get_prop("show_cancel")

    var html = "<div class=\"widget-search-bar{focus_class}\" id=\"{node.id}\">"
    html = "{html}<span class=\"search-icon\">\u{1F50D}</span>"
    html = "{html}<input class=\"search-input\" type=\"text\" placeholder=\"{placeholder}\" value=\"{value}\" data-action=\"change_{node.id}\" />"
    if show_cancel == "true":
        html = "{html}<button class=\"search-cancel\" data-action=\"cancel_{node.id}\">Cancel</button>"
    html = "{html}</div>"
    return html

# =========================================================================
# iOS Widget TUI Renderers
# =========================================================================

fn render_tui_navigation_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, theme: text) -> Screen:
    """Render a navigation bar as a bold centered title row in TUI."""
    var s = screen
    val title = node.get_prop("title")
    val color = get_theme_color(theme, "accent")
    # Center the title in the available width
    val padded = center(title, rect.w)
    s = s.write(rect.x, rect.y, "{BOLD}{color}{padded}{RESET}")
    return s

fn render_tui_tab_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a bottom tab bar as a row of icon+label pairs."""
    var s = screen
    val accent = get_theme_color(theme, "accent")
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var bar_text = ""
    var idx = 0
    for child in node.children():
        val icon = child.get_prop("icon")
        val label = child.get_prop("label")
        if idx > 0:
            bar_text = "{bar_text} | "
        if idx == active_idx:
            bar_text = "{bar_text}{accent}{BOLD}{icon} {label}{RESET}"
        else:
            bar_text = "{bar_text}{DIM}{icon} {label}{RESET}"
        idx = idx + 1

    val padded = center(bar_text, rect.w)
    s = s.write(rect.x, rect.y, padded)
    return s

fn render_tui_card(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a card as a bordered panel in TUI."""
    # Delegate to panel renderer (card is a styled panel)
    return render_tui_panel(screen, node, rect, is_focused, theme)

fn render_tui_switch(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a toggle switch in TUI."""
    var s = screen
    val label = node.get_prop("label")
    val on_val = node.get_prop("on")
    val accent = get_theme_color(theme, "accent")
    val indicator = if on_val == "true": "{GREEN}[ON ]{RESET}" else: "{DIM}[ OFF]{RESET}"
    val focus_marker = if is_focused: "{accent}>{RESET} " else: "  "
    s = s.write(rect.x, rect.y, "{focus_marker}{label}  {indicator}")
    return s

fn render_tui_segmented_control(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a segmented control in TUI."""
    var s = screen
    val accent = get_theme_color(theme, "accent")
    val active_str = node.get_prop("active_index")
    var active_idx = 0
    if active_str != "":
        active_idx = active_str.to_int()

    var seg_text = "["
    var idx = 0
    for child in node.children():
        val label = child.get_prop("label")
        if idx > 0:
            seg_text = "{seg_text} | "
        if idx == active_idx:
            seg_text = "{seg_text}{accent}{BOLD}*{label}*{RESET}"
        else:
            seg_text = "{seg_text}{label}"
        idx = idx + 1
    seg_text = "{seg_text}]"

    s = s.write(rect.x, rect.y, seg_text)
    return s

fn render_tui_search_bar(screen: Screen, node: WidgetNode, rect: WidgetRect, is_focused: bool, theme: text) -> Screen:
    """Render a search bar in TUI."""
    var s = screen
    val placeholder = node.get_prop("placeholder")
    val value = node.get_prop("value")
    val accent = get_theme_color(theme, "accent")
    val display = if value != "": value else: "{DIM}{placeholder}{RESET}"
    val focus_indicator = if is_focused: accent else: ""
    s = s.write(rect.x, rect.y, "{focus_indicator}\u{1F50D} {display}{RESET}")
    return s

# =========================================================================
# Full HTML Tree Render
# =========================================================================

fn render_html_tree(node: WidgetNode, state: UIState) -> text:
    """Render the entire widget tree to HTML."""
    return render_html_widget(node, state)
