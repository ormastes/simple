# Stable pure-Simple source emitter for portable 2D and font GPU programs.

use compiler.backend.gpu_portable_compute.{PortableComputeTarget, emit_portable_2d_optimization_module, emit_portable_font_atlas_composite_kernel, emit_vulkan_font_atlas_composite_source}
use std.common.crypto.sha256.{sha256_text}
use std.nogc_sync_mut.sffi.cli.{cli_get_args}

fn emit_portable(target: PortableComputeTarget) -> i64:
    val artifact = emit_portable_2d_optimization_module(target)
    val font = emit_portable_font_atlas_composite_kernel(target)
    print_raw("__PORTABLE_COMPUTE_EMITTER_SOURCE_SHA256__={artifact.source_hash()}\n")
    print_raw("__PORTABLE_COMPUTE_EMITTER_VERSION_SHA256__={artifact.version_hash()}\n")
    print_raw("__PORTABLE_FONT_EMITTER_SOURCE_SHA256__={font.source_hash()}\n")
    print_raw("__PORTABLE_FONT_EMITTER_VERSION_SHA256__={font.version_hash()}\n")
    print_raw("__PORTABLE_COMPUTE_SOURCE_BEGIN__\n")
    print_raw(artifact.source)
    print_raw("__PORTABLE_COMPUTE_SOURCE_END__\n")
    print_raw("__PORTABLE_FONT_SOURCE_BEGIN__\n")
    print_raw(font.source)
    print_raw("__PORTABLE_FONT_SOURCE_END__\n")
    0

fn emit_vulkan() -> i64:
    val source = emit_vulkan_font_atlas_composite_source()
    print_raw("__VULKAN_FONT_EMITTER_SOURCE_SHA256__={sha256_text(source)}\n")
    print_raw("__PORTABLE_FONT_SOURCE_BEGIN__\n")
    print_raw(source)
    print_raw("__PORTABLE_FONT_SOURCE_END__\n")
    0

fn main() -> i64:
    val args = cli_get_args()
    if args.len() != 2:
        print "usage: portable_compute_emit <cuda|hip|opencl|metal|webgpu|vulkan>"
        return 2
    val target = args[1].trim().lower()
    if target == "cuda":
        return emit_portable(PortableComputeTarget.Cuda)
    if target == "hip":
        return emit_portable(PortableComputeTarget.Hip)
    if target == "opencl":
        return emit_portable(PortableComputeTarget.OpenCl)
    if target == "metal":
        return emit_portable(PortableComputeTarget.Metal)
    if target == "webgpu":
        return emit_portable(PortableComputeTarget.WebGpu)
    if target == "vulkan":
        return emit_vulkan()
    print "portable_compute_emit: unsupported target: {target}"
    2
