# AC-7: arg-parser front-end layer sample.
#
# Defines a minimal arg parser exposed as an SFM front-end (FrontArgParser)
# layer. `arg_parse_sample` is the layer's entry symbol — it parses sample args
# into a `ParsedArgs` record (flags, string options, positionals).

use std.sfm.manifest.{FeatureManifest, LayerDescriptor, LayerKind, SfmSecurityLevel}

# Parsed result of a sample arg vector.
struct ParsedArgs:
    strings: Dict<text, text>
    bools: Dict<text, bool>
    positionals: [text]

impl ParsedArgs:
    fn get_str(name: text) -> text:
        if self.strings.has(name):
            return self.strings[name]
        return ""

    fn get_bool(name: text) -> bool:
        if self.bools.has(name):
            return self.bools[name]
        return false

# The arg-parser layer entry symbol (AC-7). Recognizes `--key value` as a
# string option, `--flag` (no following value) as a boolean flag, and bare
# tokens as positionals.
fn arg_parse_sample(args: [text]) -> ParsedArgs:
    var strings: Dict<text, text> = {}
    var bools: Dict<text, bool> = {}
    var positionals: [text] = []
    var i: i32 = 0
    val n: i32 = args.len() as i32
    while i < n:
        val tok: text = args[i]
        if tok.starts_with("--"):
            val key: text = tok.slice(2, tok.len() as i32)
            if i + 1 < n and not args[i + 1].starts_with("--"):
                strings[key] = args[i + 1]
                i = i + 2
            else:
                bools[key] = true
                i = i + 1
        else:
            positionals = positionals.push(tok)
            i = i + 1
    return ParsedArgs(strings: strings, bools: bools, positionals: positionals)

# AC-7: the feature manifest declaring this arg parser as a front-end layer.
fn arg_parser_manifest(version: text) -> FeatureManifest:
    val cli = LayerDescriptor(
        role: "cli",
        kind: LayerKind.FrontArgParser,
        entry_symbol: "arg_parse_sample",
        privileged: false
    )
    return FeatureManifest(
        name: "sfm-arg-parser",
        version: version,
        security_level: SfmSecurityLevel.Ordinary,
        layers: [cli]
    )
