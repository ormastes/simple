fn _dashboard_surface_result(args: [text]) -> text:
    "status=migrated target=simple-ide args=" + args.join(" ")

fn _run_serve_result(args: [text]) -> text:
    _dashboard_surface_result(args)

fn _run_gui_result(args: [text]) -> text:
    _dashboard_surface_result(args)

fn _run_agents_result(args: [text]) -> text:
    _dashboard_surface_result(args)

fn main() -> i64:
    0
