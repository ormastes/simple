# Dashboard Web Entry
#
# Keeps web and GUI server startup out of the lightweight dashboard CLI path.

use std.cli.cli_parser.{
    cli_spec, cli_spec_option, cli_spec_flag,
    parse_cli_args, parsed_option, parsed_flag
}
use std.nogc_sync_mut.io.process_ops.{shell}
use app.ui.detect.{has_tauri_shell}
use app.web_dashboard.server.{DashboardServer}

fn main() -> i64:
    extern fn rt_cli_args() -> [text]
    val args = strip_script_path(rt_cli_args())
    if args.len() == 0:
        print_web_help()
        return 0

    val cmd = args[0]
    val sub_args = if args.len() > 1: args.slice(1, args.len()) else: []

    match cmd:
        case "serve":
            run_serve(sub_args)
            return 0
        case "gui":
            run_gui(sub_args)
            return 0
        case "help":
            print_web_help()
            return 0
        case "--help":
            print_web_help()
            return 0
        case "-h":
            print_web_help()
            return 0
        case _:
            print "Unknown dashboard web command: {cmd}"
            print_web_help()
            return 1

fn strip_script_path(args: [text]) -> [text]:
    if args.len() == 0:
        return args
    val first = args[0]
    if first.ends_with(".spl") or first.ends_with(".shs"):
        return args.slice(1, args.len())
    args

fn run_serve(args: [text]):
    val spec = cli_spec()
    val spec2 = cli_spec_option(spec, "port", "p", "Server port", default: "3000", choices: [])
    val parsed = parse_cli_args(spec2, args)
    val port = parsed_option(parsed, "port").to_i64() ?? 3000

    print "Starting dashboard server on http://localhost:{port}"
    print "Press Ctrl+C to stop"

    val server = DashboardServer.new(port)
    server.start()

fn run_gui(args: [text]):
    val spec = cli_spec()
    val spec2 = cli_spec_option(spec, "port", "p", "Server port", default: "3000", choices: [])
    val spec3 = cli_spec_flag(spec2, "browser", "b", "Open in browser instead of desktop window")
    val parsed = parse_cli_args(spec3, args)
    val port = parsed_option(parsed, "port").to_i64() ?? 3000
    val use_browser = parsed_flag(parsed, "browser")

    print "Starting Dashboard GUI on http://localhost:{port}"
    if not use_browser and has_tauri_shell():
        shell("tools/tauri-shell/src-tauri/target/release/simple-tauri-shell --url http://localhost:{port} &")
    else:
        shell("(sleep 1 && open http://localhost:{port}) &")

    val server = DashboardServer.new(port)
    server.start()

fn print_web_help():
    print "Simple Dashboard Web Entry"
    print ""
    print "USAGE:"
    print "  simple src/app/dashboard/web_entry.spl <serve|gui> [options]"
