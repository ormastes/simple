use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.mcp.assistant.{AssistantSessionRecord, AssistantTimelineRecord}

pub class AssistantDashboardDigestView:
    session_id: text
    status: text
    checkpoint_id: text
    summary: text
    recent_detail: text
    task_summary_count: i64
    warning_count: i64
    notification_count: i64

fn _digest_text(value: text) -> text:
    if value.trim() == "":
        return "none"
    value

fn _selected_session(snapshot: AssistantDashboardSnapshot) -> AssistantSessionRecord?:
    for session in snapshot.sessions:
        if session.session_id == snapshot.selected_session_id:
            return Some(session)
    nil

fn _first_session_summary(session: AssistantSessionRecord) -> text:
    if session.summary.trim() != "":
        return session.summary
    if session.objective.trim() != "":
        return session.objective
    if session.prompt.trim() != "":
        return session.prompt
    "none"

fn _latest_event_detail(events: [AssistantTimelineRecord]) -> text:
    var latest_ts: i64 = -1
    var detail = ""
    for event in events:
        if event.timestamp_ms >= latest_ts:
            latest_ts = event.timestamp_ms
            if event.detail.trim() != "":
                detail = event.detail
            elif event.message.trim() != "":
                detail = event.message
            elif event.signal.trim() != "":
                detail = event.signal
            else:
                detail = event.kind
    _digest_text(detail)

fn _task_summary_count(session: AssistantSessionRecord) -> i64:
    var count: i64 = 0
    for task in session.child_tasks:
        if task.result_summary.trim() != "":
            count = count + 1
    count

pub fn assistant_dashboard_digest_from_snapshot(snapshot: AssistantDashboardSnapshot) -> AssistantDashboardDigestView:
    match _selected_session(snapshot):
        case Some(session):
            val recent_detail = if session.last_event_detail.trim() != "": session.last_event_detail else: _latest_event_detail(snapshot.timeline)
            AssistantDashboardDigestView(
                session_id: session.session_id,
                status: "ready",
                checkpoint_id: _digest_text(session.digest_checkpoint_id),
                summary: _first_session_summary(session),
                recent_detail: _digest_text(recent_detail),
                task_summary_count: _task_summary_count(session),
                warning_count: session.warnings.len(),
                notification_count: snapshot.notifications.len()
            )
        case nil:
            AssistantDashboardDigestView(
                session_id: _digest_text(snapshot.selected_session_id),
                status: "missing",
                checkpoint_id: "none",
                summary: "none",
                recent_detail: "none",
                task_summary_count: 0,
                warning_count: 0,
                notification_count: snapshot.notifications.len()
            )

pub fn assistant_dashboard_render_digest(view: AssistantDashboardDigestView) -> [text]:
    [
        "digest session " + view.session_id,
        "status " + view.status,
        "checkpoint " + view.checkpoint_id,
        "summary " + view.summary,
        "recent " + view.recent_detail,
        "task_summaries " + str(view.task_summary_count),
        "warnings " + str(view.warning_count),
        "notifications " + str(view.notification_count)
    ]

export AssistantDashboardDigestView
export assistant_dashboard_digest_from_snapshot, assistant_dashboard_render_digest
