use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.mcp.assistant.{AssistantTimelineRecord}

pub class AssistantDashboardRetentionPolicy:
    max_timeline_events: i64
    max_notifications: i64
    coalesce_after_repeats: i64
    backpressure_after_dropped: i64

pub class AssistantDashboardRetentionProjection:
    session_id: text
    retained_timeline_count: i64
    retained_notification_count: i64
    dropped_timeline_count: i64
    dropped_notification_count: i64
    coalesced_signal_count: i64
    coalesced_notification_count: i64
    backpressure_state: text
    notice: text
    visible_timeline: [AssistantTimelineRecord]
    visible_notifications: [AssistantTimelineRecord]

pub fn assistant_dashboard_default_retention_policy() -> AssistantDashboardRetentionPolicy:
    AssistantDashboardRetentionPolicy(
        max_timeline_events: 200,
        max_notifications: 50,
        coalesce_after_repeats: 3,
        backpressure_after_dropped: 1
    )

pub fn assistant_dashboard_retention_projection(snapshot: AssistantDashboardSnapshot, policy: AssistantDashboardRetentionPolicy) -> AssistantDashboardRetentionProjection:
    val timeline_limit = _positive_limit(policy.max_timeline_events)
    val notification_limit = _positive_limit(policy.max_notifications)
    val repeat_limit = _positive_limit(policy.coalesce_after_repeats)
    val timeline_tail = _tail_events(snapshot.timeline, timeline_limit)
    val notification_tail = _tail_events(snapshot.notifications, notification_limit)
    val visible_timeline = _coalesce_timeline_signals(timeline_tail, repeat_limit)
    val visible_notifications = _coalesce_repeated_events(notification_tail, repeat_limit)
    val dropped_timeline = _dropped_count(snapshot.timeline.len(), timeline_limit)
    val dropped_notifications = _dropped_count(snapshot.notifications.len(), notification_limit)
    val coalesced_signals = timeline_tail.len() - visible_timeline.len()
    val coalesced_notifications = notification_tail.len() - visible_notifications.len()
    val dropped_total = dropped_timeline + dropped_notifications
    val state = _backpressure_state(dropped_total, policy.backpressure_after_dropped)
    AssistantDashboardRetentionProjection(
        session_id: snapshot.selected_session_id,
        retained_timeline_count: visible_timeline.len(),
        retained_notification_count: visible_notifications.len(),
        dropped_timeline_count: dropped_timeline,
        dropped_notification_count: dropped_notifications,
        coalesced_signal_count: coalesced_signals,
        coalesced_notification_count: coalesced_notifications,
        backpressure_state: state,
        notice: _retention_notice(state, dropped_timeline, dropped_notifications, coalesced_signals, coalesced_notifications),
        visible_timeline: visible_timeline,
        visible_notifications: visible_notifications
    )

fn _positive_limit(value: i64) -> i64:
    if value < 1:
        return 1
    value

fn _tail_events(events: [AssistantTimelineRecord], limit: i64) -> [AssistantTimelineRecord]:
    if events.len() <= limit:
        return events
    var tail: [AssistantTimelineRecord] = []
    var i = events.len() - limit
    while i < events.len():
        tail.push(events[i])
        i = i + 1
    tail

fn _dropped_count(total: i64, limit: i64) -> i64:
    if total <= limit:
        return 0
    total - limit

fn _coalesce_timeline_signals(events: [AssistantTimelineRecord], repeat_limit: i64) -> [AssistantTimelineRecord]:
    var visible: [AssistantTimelineRecord] = []
    var last_key = ""
    var repeat_count: i64 = 0
    for event in events:
        val key = _event_key(event)
        if key == last_key:
            repeat_count = repeat_count + 1
        else:
            last_key = key
            repeat_count = 1
        if _is_signal_event(event) and repeat_count > repeat_limit:
            continue
        visible.push(event)
    visible

fn _coalesce_repeated_events(events: [AssistantTimelineRecord], repeat_limit: i64) -> [AssistantTimelineRecord]:
    var visible: [AssistantTimelineRecord] = []
    var last_key = ""
    var repeat_count: i64 = 0
    for event in events:
        val key = _event_key(event)
        if key == last_key:
            repeat_count = repeat_count + 1
        else:
            last_key = key
            repeat_count = 1
        if repeat_count > repeat_limit:
            continue
        visible.push(event)
    visible

fn _event_key(event: AssistantTimelineRecord) -> text:
    event.kind + "|" + event.severity + "|" + event.title + "|" + event.detail + "|" + event.signal

fn _is_signal_event(event: AssistantTimelineRecord) -> bool:
    event.kind == "signal_event" or event.kind == "signal"

fn _backpressure_state(dropped_total: i64, threshold: i64) -> text:
    val minimum = _positive_limit(threshold)
    if dropped_total >= minimum:
        return "backpressure"
    "normal"

fn _retention_notice(state: text, dropped_timeline: i64, dropped_notifications: i64, coalesced_signals: i64, coalesced_notifications: i64) -> text:
    if state == "normal":
        return "retention normal"
    "retention backpressure timeline_dropped={dropped_timeline} notifications_dropped={dropped_notifications} signals_coalesced={coalesced_signals} notifications_coalesced={coalesced_notifications}"

export AssistantDashboardRetentionPolicy, AssistantDashboardRetentionProjection
export assistant_dashboard_default_retention_policy, assistant_dashboard_retention_projection
