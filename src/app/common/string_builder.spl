class StringBuilder:
    parts: [text]

impl StringBuilder:
    static fn new() -> StringBuilder:
        StringBuilder(parts: [])

    fn push(s: text):
        self.parts.push(s)

    fn push_line(s: text):
        self.parts.push(s)
        self.parts.push("\n")

    fn to_text() -> text:
        self.parts.join("")

    fn build() -> text:
        self.parts.join("")
