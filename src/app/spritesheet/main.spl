# `simple spritesheet <sub>` — 2D sprite atlas packer CLI.
#
# Subcommands:
#   pack <dir-or-files...> --out atlas.png --manifest atlas.sdn [--max-width N]
#       Decode each input PNG (`png_decode`), pack via the existing shelf
#       packer (`AtlasBuilder`/`AtlasLayout`,
#       src/lib/nogc_sync_mut/engine/sprite/atlas_builder.spl), composite
#       the packed rects into one RGBA buffer, encode with `png_encode`,
#       and emit an SDN manifest.
#
# A directory argument is scanned non-recursively; every entry inside it is
# treated as a sprite candidate (no name filtering) so a non-PNG file in the
# directory surfaces as a real, path-qualified decode error instead of being
# silently skipped.
#
# Manifest shape — the exact SDN the asset loader already parses
# (`std.nogc_sync_mut.game2d.asset.loader`/`table.load_assets`), so
# `load_assets(manifest_path)` can consume packer output with zero loader
# changes:
#
#   assets:
#     images:
#       <atlas_name>:
#         path: "<atlas.png path>"
#     atlases:
#       <atlas_name>:
#         image_width: W
#         image_height: H
#         regions:
#           <sprite_name>: [x, y, w, h]
#
# `<atlas_name>` is the --out basename without extension, shared by both
# blocks so the atlas's declared image and its region table refer to the
# same key.
#
# Exit codes: 0 success, 1 failure (missing/malformed input, write failure,
# packed atlas exceeds --max-width), 2 usage error. Every input path is a
# trust boundary: validated with a path-qualified error message; malformed
# PNG data never panics.
#
# ponytail: shelf packing has no --padding knob (hardcoded 0) and
# --max-width only validates the packed result rather than steering the
# packer — AtlasBuilder's shelf algorithm has no width-aware reflow. Upgrade
# path: wire a max-width-aware shelf break into AtlasBuilder.pack() if a
# real caller needs packing *into* a bound rather than just checking it.

use std.cli.cli_util.{get_cli_args}
use std.io_runtime.{file_exists, file_read_bytes, file_write_bytes, write_file, is_dir, dir_list}
use std.common.image.png_decode.{decode_png_to_argb, PngImage}
use std.common.image.png_encode.{encode_argb_to_png}
use std.nogc_sync_mut.engine.sprite.atlas_builder.{AtlasBuilder, AtlasLayout}

val PADDING: i32 = 0

class SpriteSrc:
    name: text
    img: PngImage

# ============================================================================
# Path helpers
# ============================================================================

fn _basename_noext(path: text) -> text:
    var base = path
    val slash = path.rfind("/")
    if slash >= 0:
        base = path.slice(slash + 1, path.len())
    val dot = base.rfind(".")
    if dot >= 0:
        base = base.slice(0, dot)
    base

fn _parse_int(s: text) -> i64?:
    if s.len() == 0:
        return None
    var i = 0
    var n: i64 = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if (ch < "0" or ch > "9"):
            return None
        n = n * 10 + (ch.to_i64())
        i = i + 1
    Some(n)

# ============================================================================
# Input collection + decode (trust boundary)
# ============================================================================

fn _collect_input_paths(inputs: [text]) -> Result<[text], text>:
    var files: [text] = []
    for a in inputs:
        if is_dir(a):
            var entries = dir_list(a)
            entries = entries.sort()
            for e in entries:
                files.push(a + "/" + e)
        elif file_exists(a):
            files.push(a)
        else:
            return Err("input not found: {a}")
    Ok(files)

fn _load_sprites(paths: [text]) -> Result<[SpriteSrc], text>:
    var sources: [SpriteSrc] = []
    for path in paths:
        val bytes = file_read_bytes(path)
        if bytes.len() == 0:
            return Err("{path}: failed to read file or file is empty")
        val decoded = decode_png_to_argb(bytes)
        if val Err(e) = decoded:
            return Err("{path}: invalid PNG: {e}")
        if val Ok(img) = decoded:
            sources.push(SpriteSrc(name: _basename_noext(path), img: img))
    Ok(sources)

# ============================================================================
# Compositing + manifest
# ============================================================================

fn _composite(sources: [SpriteSrc], layout: AtlasLayout) -> [u32]:
    var pixels: [u32] = []
    val total = layout.width * layout.height
    var p: i32 = 0
    while p < total:
        pixels.push(0u32)
        p = p + 1
    for src in sources:
        if val Some(sp) = layout.find_sprite(src.name):
            var yy: i32 = 0
            while yy < src.img.height:
                var xx: i32 = 0
                while xx < src.img.width:
                    val src_idx = yy * src.img.width + xx
                    val dst_idx = (sp.y + yy) * layout.width + (sp.x + xx)
                    pixels[dst_idx] = src.img.pixels[src_idx]
                    xx = xx + 1
                yy = yy + 1
    pixels

fn _manifest_text(atlas_path: text, layout: AtlasLayout) -> text:
    val atlas_name = _basename_noext(atlas_path)
    var regions_text = ""
    for sp in layout.sprites:
        regions_text = regions_text + "        {sp.name}: [{sp.x}, {sp.y}, {sp.width}, {sp.height}]\n"
    "assets:\n" +
        "  images:\n" +
        "    {atlas_name}:\n" +
        "      path: \"{atlas_path}\"\n" +
        "  atlases:\n" +
        "    {atlas_name}:\n" +
        "      image_width: {layout.width}\n" +
        "      image_height: {layout.height}\n" +
        "      regions:\n" +
        regions_text

# ============================================================================
# pack
# ============================================================================

fn cmd_pack(args: [text]) -> i64:
    var inputs: [text] = []
    var out_path = ""
    var manifest_path = ""
    var max_width: i64? = None
    var i: i64 = 0
    while i < args.len():
        val a = args[i]
        if (a == "--out" or a == "--manifest" or a == "--max-width"):
            if i + 1 >= args.len():
                print "error: {a} requires a value"
                return 2
            val v = args[i + 1]
            if a == "--out":
                out_path = v
            elif a == "--manifest":
                manifest_path = v
            else:
                if val Some(n) = _parse_int(v):
                    max_width = Some(n)
                else:
                    print "error: --max-width expects a positive integer, got \"{v}\""
                    return 2
            i = i + 2
        elif a.starts_with("--"):
            print "error: unknown option {a}"
            return 2
        else:
            inputs.push(a)
            i = i + 1

    if inputs.len() == 0:
        print "error: simple spritesheet pack <dir-or-files> --out atlas.png --manifest atlas.sdn — missing input"
        return 2
    if out_path == "":
        print "error: simple spritesheet pack <dir-or-files> --out atlas.png --manifest atlas.sdn — missing --out"
        return 2
    if manifest_path == "":
        print "error: simple spritesheet pack <dir-or-files> --out atlas.png --manifest atlas.sdn — missing --manifest"
        return 2

    val paths_r = _collect_input_paths(inputs)
    if val Err(e) = paths_r:
        print "error: {e}"
        return 1
    var paths: [text] = []
    if val Ok(p) = paths_r:
        paths = p
    if paths.len() == 0:
        print "error: no input files found"
        return 1

    val sources_r = _load_sprites(paths)
    if val Err(e) = sources_r:
        print "error: {e}"
        return 1
    var sources: [SpriteSrc] = []
    if val Ok(s) = sources_r:
        sources = s

    var builder = AtlasBuilder.new(PADDING)
    for src in sources:
        builder.add_sprite(src.name, src.img.width, src.img.height)
    val layout = builder.pack()

    if val Some(mw) = max_width:
        if layout.width.to_i64() > mw:
            print "error: packed atlas width {layout.width} exceeds --max-width {mw}"
            return 1

    val pixels = _composite(sources, layout)
    val png_bytes = encode_argb_to_png(pixels, layout.width, layout.height)
    if not file_write_bytes(out_path, png_bytes):
        print "error: failed to write {out_path}"
        return 1

    if not write_file(manifest_path, _manifest_text(out_path, layout)):
        print "error: failed to write {manifest_path}"
        return 1

    print "wrote {out_path} and {manifest_path} ({layout.sprite_count()} sprites, {layout.width}x{layout.height})"
    0

# ============================================================================
# entrypoint
# ============================================================================

fn print_usage():
    print "Usage: simple spritesheet <subcommand> [args]"
    print ""
    print "Subcommands:"
    print "  pack <dir-or-files> --out atlas.png --manifest atlas.sdn [--max-width N]"
    print "      Pack PNG sprites into one atlas.png + atlas.sdn manifest"
    print ""
    print "Exit codes: 0 ok, 1 failure, 2 usage error"

fn main() -> i64:
    val args = get_cli_args()
    if args.len() < 1:
        print_usage()
        return 2
    val sub = args[0]
    if (sub == "--help" or sub == "-h" or sub == "help"):
        print_usage()
        return 0
    if sub == "pack":
        var rest: [text] = []
        var i: i64 = 1
        while i < args.len():
            rest.push(args[i])
            i = i + 1
        return cmd_pack(rest)
    print "error: unknown subcommand: {sub}"
    print_usage()
    2
