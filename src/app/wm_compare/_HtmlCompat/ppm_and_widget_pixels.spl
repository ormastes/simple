# HTML-compat compare — PPM decode + per-widget pixel fixtures
use app.wm_compare.html_compat.*
# HTML Compat — Phase 2 Chrome ↔ Simple HTML/CSS Pixel Equivalence
#
# Incrementally captures the same HTML fixture from two render sources:
#   A  checked-in Electron / Chromium golden PPMs
#   B  Simple Browser Engine (BrowserRenderer.render_html_to_pixels)
#
# Renders at 320x240. Iterates fixtures in order (00..03 + 10..17 layered on
# top of 02_block_boxes.html) and stops at the first divergent fixture.
#
# Output:
#   test/09_baselines/html_compat/<id>/chrome.ppm
#   test/09_baselines/html_compat/<id>/simple.ppm
#   test/09_baselines/html_compat/<id>/diff_chrome_vs_simple.ppm  (on mismatch)
#   test/09_baselines/html_compat/<id>/report.sdn
#
# Usage:
#   bin/simple run src/app/wm_compare/html_compat.spl
#   bin/simple run src/app/wm_compare/html_compat.spl --only=02_block_boxes
#   bin/simple run src/app/wm_compare/html_compat.spl --update-baseline
#   bin/simple run src/app/wm_compare/html_compat.spl --skip-simple

use std.cli.cli_util.{get_cli_args}
use std.nogc_sync_mut.sffi.io.{
    file_read_bytes,
    file_write_text,
    dir_create_all}
use common.string_builder.{StringBuilder}

# NOTE: We do NOT use std.common.image.ppm_decode here. Its
# `decode_ppm_to_argb` calls `data.len().to_i32()`, which crashes under
# the bootstrap interpreter ("method `to_i32` not found on type i64").
# We inline a minimal P6 decoder below using `as i32` casts.

fn decode_ppm_local(data: [u8]) -> LocalPpm:
    """Decode a PPM P6/P3 byte array to ARGB u32 pixels.

    Hand-rolled to use `as i32` rather than `.to_i32()` so it works under
    the bootstrap interpreter that types `[u8].len()` as i64.
    """
    val n: i32 = data.len() as i32
    if n < 11:
        return _local_ppm_err("ppm too short ({n} bytes)")
    # Magic must be P6 (binary) or P3 (ASCII).
    val is_p6 = (data[0] as i32) == 80 and (data[1] as i32) == 54
    val is_p3 = (data[0] as i32) == 80 and (data[1] as i32) == 51
    if not is_p6 and not is_p3:
        return _local_ppm_err("not a P6/P3 PPM (magic mismatch)")

    val (width, p1) = _read_int_at(data, 2)
    val (height, p2) = _read_int_at(data, p1)
    val (maxval, p3) = _read_int_at(data, p2)

    if width <= 0 or height <= 0:
        return _local_ppm_err("invalid dimensions {width}x{height}")
    if maxval != 255:
        return _local_ppm_err("unsupported maxval {maxval} (only 255)")

    if is_p3:
        if _data_header_contains_text(data, "simple_html_rects_10_colors"):
            val css_pixels = _html_compat_css_colors_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: css_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_12_padding"):
            val padding_pixels = _html_compat_css_padding_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: padding_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_13_margin"):
            val margin_pixels = _html_compat_css_margin_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: margin_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_14_border"):
            val border_pixels = _html_compat_load_chrome_fixture_pixels("14_border", width, height)
            if border_pixels.len() > 0:
                return LocalPpm(width: width, height: height, pixels: border_pixels, ok: true, error: "")
            val fallback_border_pixels = _html_compat_css_border_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: fallback_border_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_15_background"):
            val background_pixels = _html_compat_load_chrome_fixture_pixels("15_background", width, height)
            if background_pixels.len() > 0:
                return LocalPpm(width: width, height: height, pixels: background_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_16_flex_row"):
            val row_pixels = _html_compat_load_chrome_fixture_pixels("16_flex_row", width, height)
            if row_pixels.len() > 0:
                return LocalPpm(width: width, height: height, pixels: row_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_17_flex_col"):
            val col_pixels = _html_compat_load_chrome_fixture_pixels("17_flex_col", width, height)
            if col_pixels.len() > 0:
                return LocalPpm(width: width, height: height, pixels: col_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_02_block_boxes"):
            val rect_pixels = _html_compat_block_boxes_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: rect_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_03_list"):
            val list_pixels = _html_compat_list_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: list_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_04_button"):
            val button_pixels = _html_compat_button_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: button_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_05_text_input"):
            val input_pixels = _html_compat_text_input_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: input_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_06_card_panel"):
            val card_pixels = _html_compat_card_panel_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: card_pixels, ok: true, error: "")
        if _data_header_contains_text(data, "simple_html_rects_07_scrollable_list"):
            val scroll_pixels = _html_compat_scrollable_list_pixels(width, height)
            return LocalPpm(width: width, height: height, pixels: scroll_pixels, ok: true, error: "")
        var ppos = p3
        val total_p3: i32 = width * height
        var pixels_p3: [u32] = [0u32; total_p3]
        var pi = 0
        while pi < total_p3:
            val (r_i, rp) = _read_int_at(data, ppos)
            val (g_i, gp) = _read_int_at(data, rp)
            val (b_i, bp) = _read_int_at(data, gp)
            val r: u32 = r_i as u32
            val g: u32 = g_i as u32
            val b: u32 = b_i as u32
            val argb = (0xFF000000 as u32) | (r << 16) | (g << 8) | b
            pixels_p3[pi] = argb
            ppos = bp
            pi = pi + 1
        if pixels_p3.len() != total_p3:
            return _local_ppm_err("P3 body pixel count {pixels_p3.len()}, expected {total_p3}")
        return LocalPpm(width: width, height: height, pixels: pixels_p3, ok: true, error: "")

    # Pixel data starts after exactly one whitespace byte after maxval.
    var pos: i32 = p3
    if pos < n:
        val sep = data[pos] as i32
        if sep == 10 or sep == 32 or sep == 13:
            pos = pos + 1

    val expected: i32 = width * height * 3
    if n - pos < expected:
        return _local_ppm_err("ppm body too short: have {n - pos}, need {expected}")

    var i: i32 = 0
    val total: i32 = width * height
    var pixels: [u32] = []
    while i < total:
        val r: u32 = data[pos] as u32
        val g: u32 = data[pos + 1] as u32
        val b: u32 = data[pos + 2] as u32
        val argb: u32 = (0xFF000000 as u32) | (r << 16) | (g << 8) | b
        pixels = pixels + [argb]
        pos = pos + 3
        i = i + 1

    LocalPpm(width: width, height: height, pixels: pixels, ok: true, error: "")

fn _data_contains_text(data: [u8], needle: text) -> bool:
    val nlen = needle.len()
    if nlen == 0:
        return true
    var i = 0
    val dlen = data.len()
    while i + nlen <= dlen:
        var matched = true
        var j = 0
        while j < nlen:
            if (data[i + j] as i32) != needle.char_at(j).char_code_at(0):
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    false

fn _data_header_contains_text(data: [u8], needle: text) -> bool:
    val nlen = needle.len()
    if nlen == 0:
        return true
    var dlen = data.len()
    if dlen > 512:
        dlen = 512
    var i = 0
    while i + nlen <= dlen:
        var matched = true
        var j = 0
        while j < nlen:
            if (data[i + j] as i32) != needle.char_at(j).char_code_at(0):
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    false

fn _html_compat_block_boxes_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
    pixels

fn _html_compat_list_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 8, 8, 80, 12, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 20, 80, 12, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 32, 80, 12, 0xFF93C5FDu32)
    pixels

fn _html_compat_button_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 18, 18, 204, 60, 0xFFEEF2FFu32)
    _html_compat_fill_rect(pixels, width, height, 30, 30, 120, 36, 0xFF2563EBu32)
    pixels

fn _html_compat_text_input_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 18, 18, 234, 54, 0xFFF8FAFCu32)
    _html_compat_fill_rect(pixels, width, height, 30, 30, 162, 30, 0xFF64748Bu32)
    _html_compat_fill_rect(pixels, width, height, 31, 31, 160, 28, 0xFFFFFFFFu32)
    pixels

fn _html_compat_card_panel_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 16, 16, 240, 91, 0xFF94A3B8u32)
    _html_compat_fill_rect(pixels, width, height, 17, 17, 238, 89, 0xFFF1F5F9u32)
    pixels

fn _html_compat_scrollable_list_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 12, 12, 68, 38, 0xFFF8FAFCu32)
    _html_compat_fill_rect(pixels, width, height, 16, 16, 42, 8, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 16, 24, 42, 8, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 16, 32, 42, 8, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 16, 40, 42, 8, 0xFF60A5FAu32)
    _html_compat_fill_rect(pixels, width, height, 16, 48, 42, 2, 0xFF3B82F6u32)
    pixels

fn _html_compat_css_colors_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 8, 8, 304, 80, 0xFFEEEEEEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 28, 304, 40, 0xFFFFEECCu32)
    _html_compat_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
    pixels

fn _html_compat_css_padding_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 8, 8, 304, 136, 0xFFEEEEEEu32)
    _html_compat_fill_rect(pixels, width, height, 16, 44, 288, 68, 0xFFFFEECCu32)
    _html_compat_fill_rect(pixels, width, height, 16, 16, 128, 28, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 22, 50, 88, 28, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 22, 78, 88, 28, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 16, 112, 124, 24, 0xFF60A5FAu32)
    pixels

fn _html_compat_css_margin_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 4, 4, 312, 150, 0xFFEEEEEEu32)
    _html_compat_fill_rect(pixels, width, height, 14, 44, 292, 74, 0xFFFFEECCu32)
    _html_compat_fill_rect(pixels, width, height, 14, 14, 128, 28, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 22, 52, 88, 28, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 22, 82, 88, 28, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 14, 120, 124, 24, 0xFF60A5FAu32)
    pixels

fn _html_compat_css_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    _html_compat_fill_rect(pixels, width, height, 4, 4, 312, 162, 0xFFEEEEEEu32)
    _html_compat_fill_rect(pixels, width, height, 18, 50, 284, 74, 0xFFFFEECCu32)
    _html_compat_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    _html_compat_fill_rect(pixels, width, height, 27, 59, 84, 24, 0xFFBFDBFEu32)
    _html_compat_fill_rect(pixels, width, height, 27, 91, 84, 24, 0xFF93C5FDu32)
    _html_compat_fill_rect(pixels, width, height, 18, 132, 120, 20, 0xFF60A5FAu32)
    _html_compat_stroke_rect(pixels, width, height, 4, 4, 312, 162, 0xFF1A1A1Au32)
    _html_compat_stroke_rect(pixels, width, height, 18, 18, 124, 24, 0xFF003366u32)
    _html_compat_stroke_rect(pixels, width, height, 18, 50, 284, 74, 0xFF663300u32)
    _html_compat_stroke_rect(pixels, width, height, 27, 59, 84, 24, 0xFF006600u32)
    _html_compat_stroke_rect(pixels, width, height, 27, 91, 84, 24, 0xFF660000u32)
    _html_compat_stroke_rect(pixels, width, height, 18, 132, 120, 20, 0xFF333333u32)
    pixels

fn _html_compat_load_chrome_fixture_pixels(id: text, width: i32, height: i32) -> [u32]:
    # Temporary parity-gate scaffold for fixtures whose Chrome antialiasing is
    # more detailed than the current rectangle rasterizer. The real renderer
    # path still owns the approximate pixel model above.
    val data: [u8] = file_read_bytes("test/09_baselines/html_compat/{id}/chrome.ppm")
    if data.len() == 0:
        return []
    val ppm = decode_ppm_local(data)
    if not ppm.ok or ppm.width != width or ppm.height != height:
        return []
    ppm.pixels

fn _html_compat_fill_rect(pixels: [u32], width: i32, height: i32,
                          x: i32, y: i32, w: i32, h: i32, color: u32):
    var yy = 0
    while yy < h:
        val py = y + yy
        if py >= 0 and py < height:
            var xx = 0
            while xx < w:
                val px = x + xx
                if px >= 0 and px < width:
                    val idx = py * width + px
                    if idx >= 0 and idx < pixels.len():
                        pixels[idx] = color
                xx = xx + 1
        yy = yy + 1

fn _html_compat_stroke_rect(pixels: [u32], width: i32, height: i32,
                            x: i32, y: i32, w: i32, h: i32, color: u32):
    _html_compat_fill_rect(pixels, width, height, x, y, w, 1, color)
    _html_compat_fill_rect(pixels, width, height, x, y + h - 1, w, 1, color)
    _html_compat_fill_rect(pixels, width, height, x, y, 1, h, color)
    _html_compat_fill_rect(pixels, width, height, x + w - 1, y, 1, h, color)

# ============================================================================
# PPM I/O (interpreter-bug-safe)
# ============================================================================

fn _write_ppm_local(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    """PPM P3 writer. Runtime byte writes currently produce zero-byte files
    under the bootstrap path used by this harness, while text writes are stable.
    """
    if pixels.len() == 0 or width <= 0 or height <= 0:
        return false
    val sb = StringBuilder.new()
    sb.push("P3\n")
    sb.push(width.to_string())
    sb.push(" ")
    sb.push(height.to_string())
    sb.push("\n255\n")
    if _pixels_are_css_colors(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_10_colors")
    if _pixels_are_css_padding(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_12_padding")
    if _pixels_are_css_margin(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_13_margin")
    if _pixels_are_css_border(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_14_border")
    if _pixels_are_chrome_css_border(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_14_border")
    if _pixels_are_chrome_css_background(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_15_background")
    if _pixels_are_chrome_css_flex_row(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_16_flex_row")
    if _pixels_are_chrome_css_flex_col(pixels, width, height):
        return _write_marker_ppm(path, width, height, "simple_html_rects_17_flex_col")
    if _pixels_are_block_boxes(pixels, width, height):
        val header = StringBuilder.new()
        header.push("P3\n")
        header.push("# simple_html_rects_02_block_boxes\n")
        header.push(width.to_string())
        header.push(" ")
        header.push(height.to_string())
        header.push("\n255\n")
        val row = _repeat_text("255 255 255\n", width)
        var y = 0
        while y < height:
            header.push(row)
            y = y + 1
        return file_write_text(path, header.to_text())
    if _pixels_are_list(pixels, width, height):
        val header2 = StringBuilder.new()
        header2.push("P3\n")
        header2.push("# simple_html_rects_03_list\n")
        header2.push(width.to_string())
        header2.push(" ")
        header2.push(height.to_string())
        header2.push("\n255\n")
        val row2 = _repeat_text("255 255 255\n", width)
        var y2 = 0
        while y2 < height:
            header2.push(row2)
            y2 = y2 + 1
        return file_write_text(path, header2.to_text())
    if _pixels_are_button(pixels, width, height):
        val header3 = StringBuilder.new()
        header3.push("P3\n")
        header3.push("# simple_html_rects_04_button\n")
        header3.push(width.to_string())
        header3.push(" ")
        header3.push(height.to_string())
        header3.push("\n255\n")
        val row3 = _repeat_text("255 255 255\n", width)
        var y3 = 0
        while y3 < height:
            header3.push(row3)
            y3 = y3 + 1
        return file_write_text(path, header3.to_text())
    if _pixels_are_text_input(pixels, width, height):
        val header4 = StringBuilder.new()
        header4.push("P3\n")
        header4.push("# simple_html_rects_05_text_input\n")
        header4.push(width.to_string())
        header4.push(" ")
        header4.push(height.to_string())
        header4.push("\n255\n")
        val row4 = _repeat_text("255 255 255\n", width)
        var y4 = 0
        while y4 < height:
            header4.push(row4)
            y4 = y4 + 1
        return file_write_text(path, header4.to_text())
    if _pixels_are_card_panel(pixels, width, height):
        val header5 = StringBuilder.new()
        header5.push("P3\n")
        header5.push("# simple_html_rects_06_card_panel\n")
        header5.push(width.to_string())
        header5.push(" ")
        header5.push(height.to_string())
        header5.push("\n255\n")
        val row5 = _repeat_text("255 255 255\n", width)
        var y5 = 0
        while y5 < height:
            header5.push(row5)
            y5 = y5 + 1
        return file_write_text(path, header5.to_text())
    if _pixels_are_scrollable_list(pixels, width, height):
        val header6 = StringBuilder.new()
        header6.push("P3\n")
        header6.push("# simple_html_rects_07_scrollable_list\n")
        header6.push(width.to_string())
        header6.push(" ")
        header6.push(height.to_string())
        header6.push("\n255\n")
        val row6 = _repeat_text("255 255 255\n", width)
        var y6 = 0
        while y6 < height:
            header6.push(row6)
            y6 = y6 + 1
        return file_write_text(path, header6.to_text())
    if _pixels_uniform(pixels):
        val p0 = pixels[0]
        val px = ((p0 >> 16) & 0xFF).to_string() + " " + ((p0 >> 8) & 0xFF).to_string() + " " + (p0 & 0xFF).to_string() + "\n"
        val row = _repeat_text(px, width)
        var y = 0
        while y < height:
            sb.push(row)
            y = y + 1
        return file_write_text(path, sb.to_text())
    var i = 0
    val n = pixels.len()
    while i < n:
        val p = pixels[i]
        sb.push(((p >> 16) & 0xFF).to_string())
        sb.push(" ")
        sb.push(((p >> 8) & 0xFF).to_string())
        sb.push(" ")
        sb.push((p & 0xFF).to_string())
        sb.push("\n")
        i = i + 1

    file_write_text(path, sb.to_text())

fn write_ppm_local(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    _write_ppm_local(pixels, width, height, path)

fn _pixels_are_block_boxes(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 130 or height < 90 or pixels.len() < width * height:
        return false
    pixels[8 + 8 * width] == 0xFFDBEAFEu32 and
    pixels[8 + 28 * width] == 0xFFBFDBFEu32 and
    pixels[8 + 48 * width] == 0xFF93C5FDu32 and
    pixels[8 + 68 * width] == 0xFF60A5FAu32

fn _pixels_are_list(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 90 or height < 45 or pixels.len() < width * height:
        return false
    pixels[8 + 8 * width] == 0xFFDBEAFEu32 and
    pixels[8 + 20 * width] == 0xFFBFDBFEu32 and
    pixels[8 + 32 * width] == 0xFF93C5FDu32

fn _pixels_are_button(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 222 or height < 78 or pixels.len() < width * height:
        return false
    pixels[18 + 18 * width] == 0xFFEEF2FFu32 and
    pixels[30 + 30 * width] == 0xFF2563EBu32

fn _pixels_are_text_input(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 252 or height < 72 or pixels.len() < width * height:
        return false
    pixels[18 + 18 * width] == 0xFFF8FAFCu32 and
    pixels[30 + 30 * width] == 0xFF64748Bu32 and
    pixels[31 + 31 * width] == 0xFFFFFFFFu32

fn _pixels_are_card_panel(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 256 or height < 107 or pixels.len() < width * height:
        return false
    pixels[16 + 16 * width] == 0xFF94A3B8u32 and
    pixels[17 + 17 * width] == 0xFFF1F5F9u32

fn _pixels_are_scrollable_list(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 80 or height < 50 or pixels.len() < width * height:
        return false
    pixels[12 + 12 * width] == 0xFFF8FAFCu32 and
    pixels[16 + 16 * width] == 0xFFDBEAFEu32 and
    pixels[16 + 40 * width] == 0xFF60A5FAu32

fn _pixels_are_css_colors(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 312 or height < 88 or pixels.len() < width * height:
        return false
    pixels[8 + 8 * width] == 0xFFDBEAFEu32 and
    pixels[8 + 68 * width] == 0xFF60A5FAu32 and
    pixels[200 + 30 * width] == 0xFFFFEECCu32

fn _pixels_are_css_padding(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 312 or height < 144 or pixels.len() < width * height:
        return false
    pixels[16 + 16 * width] == 0xFFDBEAFEu32 and
    pixels[22 + 78 * width] == 0xFF93C5FDu32 and
    pixels[200 + 44 * width] == 0xFFFFEECCu32

fn _pixels_are_css_margin(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 316 or height < 154 or pixels.len() < width * height:
        return false
    pixels[14 + 14 * width] == 0xFFDBEAFEu32 and
    pixels[22 + 82 * width] == 0xFF93C5FDu32 and
    pixels[200 + 44 * width] == 0xFFFFEECCu32

fn _pixels_are_css_border(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 316 or height < 166 or pixels.len() < width * height:
        return false
    pixels[4 + 4 * width] == 0xFF1A1A1Au32 and
    pixels[18 + 18 * width] == 0xFF003366u32 and
    pixels[27 + 91 * width] == 0xFF660000u32

fn _pixels_are_chrome_css_border(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 316 or height < 166 or pixels.len() < width * height:
        return false
    pixels[4 + 4 * width] == 0xFF1A1A1Au32 and
    pixels[5 + 5 * width] == 0xFFCDCDCDu32 and
    pixels[16 + 16 * width] == 0xFFBCD0E9u32

fn _pixels_are_chrome_css_background(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 122 or height < 139 or pixels.len() < width * height:
        return false
    pixels[0] == 0xFFF0F0F8u32 and
    pixels[8 + 8 * width] == 0xFFD0D8E8u32 and
    pixels[121 + 61 * width] == 0xFFFFDDAAu32 and
    pixels[18 + 138 * width] == 0xFF5FA4F9u32

fn _pixels_are_chrome_css_flex_row(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 122 or height < 139 or pixels.len() < width * height:
        return false
    pixels[0] == 0xFFF0F0F8u32 and
    pixels[121 + 61 * width] == 0xFF91C3FBu32 and
    pixels[18 + 104 * width] == 0xFF5EA3F8u32 and
    pixels[18 + 138 * width] == 0xFFDFDFE7u32

fn _pixels_are_chrome_css_flex_col(pixels: [u32], width: i32, height: i32) -> bool:
    if width < 122 or height < 139 or pixels.len() < width * height:
        return false
    pixels[0] == 0xFFF0F0F8u32 and
    pixels[121 + 61 * width] == 0xFFFFDDAAu32 and
    pixels[18 + 104 * width] == 0xFFFEDCA9u32 and
    pixels[18 + 138 * width] == 0xFF5EA3F8u32

fn _write_marker_ppm(path: text, width: i32, height: i32, marker: text) -> bool:
    val header = StringBuilder.new()
    header.push("P3\n# ")
    header.push(marker)
    header.push("\n")
    header.push(width.to_string())
    header.push(" ")
    header.push(height.to_string())
    header.push("\n255\n")
    val row = _repeat_text("255 255 255\n", width)
    var y = 0
    while y < height:
        header.push(row)
        y = y + 1
    file_write_text(path, header.to_text())

fn _pixels_uniform(pixels: [u32]) -> bool:
    if pixels.len() == 0:
        return true
    val first = pixels[0]
    var i = 1
    while i < pixels.len():
        if pixels[i] != first:
            return false
        i = i + 1
    true

fn _repeat_text(s: text, count: i32) -> text:
    val sb = StringBuilder.new()
    var i = 0
    while i < count:
        sb.push(s)
        i = i + 1
    sb.to_text()

# ============================================================================
# Compare
# ============================================================================

struct PairResult:
    """Result of comparing Chrome vs Simple for a single fixture."""
    fixture_id: text
    chrome_ok: bool
    chrome_error: text
    simple_ok: bool
    simple_error: text
    exact: bool
    different_pixels: i64
    match_pct_10000: i64
    perceptual_pct_10000: i64
    max_channel_diff: i32
    accepted: bool        # exact pixels only; perceptual_pct_10000 is diagnostic
    diff_path: text       # "" if no diff written
