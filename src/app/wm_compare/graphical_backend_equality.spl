# Common graphical backend equality contract for wm_compare tests.

use os.compositor.screenshot_compare.{ComparisonResult, compare_pixel_buffers}
use os.compositor.tolerance_profile.{ToleranceProfile, profile_strict, profile_wm_default}

pub struct GraphicalBackendSpec:
    raw: text
    primary_kind: text
    primary_name: text
    chain_count: i32
    valid: bool
    reason: text

pub struct SurfaceRect:
    x: i32
    y: i32
    width: i32
    height: i32

pub struct SurfaceGeometry:
    logical_width: i32
    logical_height: i32
    physical_width: i32
    physical_height: i32
    scale_factor: f64
    content_rect: SurfaceRect
    panel_rect: SurfaceRect
    outer_window_rect: SurfaceRect
    has_outer_window_rect: bool
    scroll_x: i32
    scroll_y: i32
    color_space: text

pub struct GraphicalCapture:
    backend: GraphicalBackendSpec
    capture_kind: text
    pixels: [u32]
    width: i32
    height: i32
    geometry: SurfaceGeometry
    success: bool
    error: text
    expected_artifact: text
    actual_artifact: text
    diff_artifact: text
    metadata_artifact: text

pub struct RenderCase:
    name: text
    logical_width: i32
    logical_height: i32
    background: text
    operations: [text]
    tolerance_profile: text

pub struct GraphicalEqualityReport:
    case_name: text
    expected_backend: text
    actual_backend: text
    backend_status: text
    capture_status: text
    metadata_status: text
    pixel_status: text
    shape_status: text
    color_status: text
    primary_status: text
    tolerance_profile: text
    tolerance_acceptance_allowed: bool
    exact_required: bool
    match_percentage: i32
    different_pixels: i32
    max_channel_diff: i32
    expected_artifact: text
    actual_artifact: text
    diff_artifact: text
    metadata_artifact: text
    accepted: bool

fn _sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn _bool_text(value: bool) -> text:
    if value: "true" else: "false"

fn _valid_backend_kind(kind: text) -> bool:
    kind == "2d" or kind == "web" or kind == "gui" or kind == "wm"

fn _valid_capture_kind(kind: text) -> bool:
    kind == "render_target" or kind == "content_viewport" or
        kind == "panel" or kind == "window_outer" or
        kind == "screen_region" or kind == "full_page"

fn _parse_primary_component(raw: text) -> text:
    val plus = raw.index_of("+")
    if plus == -1:
        raw
    else:
        raw.substring(0, plus)

fn _parse_component_kind(component: text) -> text:
    val colon = component.index_of(":")
    if colon <= 0 or colon == component.len() - 1:
        return ""
    component.substring(0, colon)

fn _parse_component_name(component: text) -> text:
    val colon = component.index_of(":")
    if colon <= 0 or colon == component.len() - 1:
        return ""
    component.substring(colon + 1)

fn _chain_count(raw: text) -> i32:
    if raw == "":
        return 0
    var count = 1
    var idx = 0
    while idx < raw.len():
        if raw.char_at(idx) == "+":
            count = count + 1
        idx = idx + 1
    count

fn _chain_valid(raw: text) -> bool:
    if raw == "":
        return false
    val parts = raw.split("+")
    for part in parts:
        val kind = _parse_component_kind(part)
        val name = _parse_component_name(part)
        if kind == "" or name == "":
            return false
        if not _valid_backend_kind(kind):
            return false
    true

fn _chain_reason(raw: text) -> text:
    if raw == "":
        return "expected kind:name"
    val parts = raw.split("+")
    for part in parts:
        val kind = _parse_component_kind(part)
        val name = _parse_component_name(part)
        if kind == "" or name == "":
            return "expected kind:name"
        if not _valid_backend_kind(kind):
            return "unknown backend kind"
    "ok"

pub fn graphical_backend_spec(raw: text) -> GraphicalBackendSpec:
    val primary = _parse_primary_component(raw)
    val reason = _chain_reason(raw)
    if reason != "ok":
        return GraphicalBackendSpec(
            raw: raw,
            primary_kind: _parse_component_kind(primary),
            primary_name: _parse_component_name(primary),
            chain_count: _chain_count(raw),
            valid: false,
            reason: reason
        )
    val kind = _parse_component_kind(primary)
    val name = _parse_component_name(primary)
    val valid = _chain_valid(raw)
    return GraphicalBackendSpec(
        raw: raw,
        primary_kind: kind,
        primary_name: name,
        chain_count: _chain_count(raw),
        valid: valid,
        reason: if valid: "ok" else: "expected kind:name"
    )

pub fn surface_rect(x: i32, y: i32, width: i32, height: i32) -> SurfaceRect:
    SurfaceRect(x: x, y: y, width: width, height: height)

pub fn surface_geometry(logical_width: i32, logical_height: i32,
                        physical_width: i32, physical_height: i32,
                        scale_factor: f64, color_space: text) -> SurfaceGeometry:
    val full = surface_rect(0, 0, physical_width, physical_height)
    SurfaceGeometry(
        logical_width: logical_width,
        logical_height: logical_height,
        physical_width: physical_width,
        physical_height: physical_height,
        scale_factor: scale_factor,
        content_rect: full,
        panel_rect: full,
        outer_window_rect: surface_rect(0, 0, 0, 0),
        has_outer_window_rect: false,
        scroll_x: 0,
        scroll_y: 0,
        color_space: color_space
    )

pub fn render_case(name: text, logical_width: i32, logical_height: i32,
                   background: text, operations: [text],
                   tolerance_profile: text) -> RenderCase:
    RenderCase(
        name: name,
        logical_width: logical_width,
        logical_height: logical_height,
        background: background,
        operations: operations,
        tolerance_profile: tolerance_profile
    )

pub fn graphical_capture(backend_raw: text, capture_kind: text,
                         pixels: [u32], geometry: SurfaceGeometry,
                         success: bool, error: text) -> GraphicalCapture:
    GraphicalCapture(
        backend: graphical_backend_spec(backend_raw),
        capture_kind: capture_kind,
        pixels: pixels,
        width: geometry.physical_width,
        height: geometry.physical_height,
        geometry: geometry,
        success: success,
        error: error,
        expected_artifact: "",
        actual_artifact: "",
        diff_artifact: "",
        metadata_artifact: ""
    )

pub fn graphical_capture_metadata_valid(capture: GraphicalCapture) -> bool:
    if not capture.success:
        return false
    if not capture.backend.valid:
        return false
    if not _valid_capture_kind(capture.capture_kind):
        return false
    if capture.width <= 0 or capture.height <= 0:
        return false
    if capture.geometry.logical_width <= 0 or capture.geometry.logical_height <= 0:
        return false
    if capture.geometry.physical_width != capture.width or capture.geometry.physical_height != capture.height:
        return false
    if capture.geometry.scale_factor <= 0.0:
        return false
    if capture.geometry.color_space == "":
        return false
    if capture.geometry.content_rect.width <= 0 or capture.geometry.content_rect.height <= 0:
        return false
    if capture.geometry.panel_rect.width <= 0 or capture.geometry.panel_rect.height <= 0:
        return false
    if capture.geometry.has_outer_window_rect and
       (capture.geometry.outer_window_rect.width <= 0 or capture.geometry.outer_window_rect.height <= 0):
        return false
    if capture.geometry.content_rect.x < 0 or capture.geometry.content_rect.y < 0:
        return false
    if capture.geometry.panel_rect.x < 0 or capture.geometry.panel_rect.y < 0:
        return false
    if capture.geometry.content_rect.x + capture.geometry.content_rect.width > capture.width:
        return false
    if capture.geometry.content_rect.y + capture.geometry.content_rect.height > capture.height:
        return false
    if capture.geometry.panel_rect.x + capture.geometry.panel_rect.width > capture.width:
        return false
    if capture.geometry.panel_rect.y + capture.geometry.panel_rect.height > capture.height:
        return false
    if capture.pixels.len() != capture.width * capture.height:
        return false
    true

fn _profile_for_name(name: text) -> ToleranceProfile:
    if name == "portable_gpu" or name == "native_chrome" or name == "wm_default":
        profile_wm_default()
    else:
        profile_strict()

fn _profile_allows_tolerance(name: text) -> bool:
    name == "portable_gpu" or name == "native_chrome" or name == "wm_default"

fn _backend_status(expected: GraphicalCapture, actual: GraphicalCapture) -> text:
    if not expected.backend.valid or not actual.backend.valid:
        "backend_invalid"
    elif not expected.success or not actual.success:
        "backend_capture_failed"
    else:
        "backend_initialized"

fn _capture_status(expected: GraphicalCapture, actual: GraphicalCapture) -> text:
    if expected.success and actual.success:
        "ok"
    else:
        "capture_failed"

fn _metadata_status(expected: GraphicalCapture, actual: GraphicalCapture) -> text:
    if not expected.success or not actual.success:
        return "not_evaluated"
    if not graphical_capture_metadata_valid(expected) or not graphical_capture_metadata_valid(actual):
        return "metadata_invalid"
    if expected.width != actual.width or expected.height != actual.height:
        return "metadata_mismatch"
    if expected.geometry.logical_width != actual.geometry.logical_width or
       expected.geometry.logical_height != actual.geometry.logical_height:
        return "metadata_mismatch"
    "ok"

fn _proxy_shape_status(pixel_status: text) -> text:
    if pixel_status == "exact_match":
        "pixel_proxy_match"
    elif pixel_status == "tolerance_match":
        "pixel_proxy_tolerated"
    elif pixel_status == "not_evaluated":
        "not_evaluated"
    else:
        "pixel_proxy_mismatch"

fn _primary_status(backend_status: text, capture_status: text,
                   metadata_status: text, pixel_status: text) -> text:
    if backend_status != "backend_initialized":
        backend_status
    elif capture_status != "ok":
        capture_status
    elif metadata_status != "ok":
        metadata_status
    elif pixel_status != "exact_match" and pixel_status != "tolerance_match":
        pixel_status
    else:
        "accepted"

fn _empty_comparison() -> ComparisonResult:
    ComparisonResult(
        exact_match: false,
        match_percentage: 0,
        different_pixels: 0,
        max_channel_diff: 0,
        total_channel_diff: 0,
        passed: false
    )

pub fn graphical_equality_compare(scenario: RenderCase,
                                  expected: GraphicalCapture,
                                  actual: GraphicalCapture) -> GraphicalEqualityReport:
    val backend_status = _backend_status(expected, actual)
    val capture_status = _capture_status(expected, actual)
    val metadata_status = _metadata_status(expected, actual)
    var comparison = _empty_comparison()
    var pixel_status = "not_evaluated"
    if backend_status == "backend_initialized" and capture_status == "ok" and metadata_status == "ok":
        val profile = _profile_for_name(scenario.tolerance_profile)
        comparison = compare_pixel_buffers(
            expected.pixels,
            actual.pixels,
            expected.width,
            expected.height,
            profile.default_threshold
        )
        if comparison.exact_match:
            pixel_status = "exact_match"
        elif comparison.match_percentage >= profile.min_match_pct and _profile_allows_tolerance(scenario.tolerance_profile):
            pixel_status = "tolerance_match"
        else:
            pixel_status = "pixel_mismatch"
    val shape_status = _proxy_shape_status(pixel_status)
    val color_status = _proxy_shape_status(pixel_status)
    val primary = _primary_status(backend_status, capture_status, metadata_status, pixel_status)
    val exact_required = not _profile_allows_tolerance(scenario.tolerance_profile)
    val accepted = primary == "accepted" and (pixel_status == "exact_match" or
        (pixel_status == "tolerance_match" and _profile_allows_tolerance(scenario.tolerance_profile)))
    GraphicalEqualityReport(
        case_name: scenario.name,
        expected_backend: expected.backend.raw,
        actual_backend: actual.backend.raw,
        backend_status: backend_status,
        capture_status: capture_status,
        metadata_status: metadata_status,
        pixel_status: pixel_status,
        shape_status: shape_status,
        color_status: color_status,
        primary_status: primary,
        tolerance_profile: scenario.tolerance_profile,
        tolerance_acceptance_allowed: _profile_allows_tolerance(scenario.tolerance_profile),
        exact_required: exact_required,
        match_percentage: comparison.match_percentage,
        different_pixels: comparison.different_pixels,
        max_channel_diff: comparison.max_channel_diff,
        expected_artifact: expected.expected_artifact,
        actual_artifact: actual.actual_artifact,
        diff_artifact: actual.diff_artifact,
        metadata_artifact: actual.metadata_artifact,
        accepted: accepted
    )

pub fn graphical_equality_report_sdn(report: GraphicalEqualityReport) -> text:
    "(graphical_equality_report " +
        "case: \"" + _sdn_escape(report.case_name) + "\" " +
        "expected_backend: \"" + _sdn_escape(report.expected_backend) + "\" " +
        "actual_backend: \"" + _sdn_escape(report.actual_backend) + "\" " +
        "backend_status: \"" + report.backend_status + "\" " +
        "capture_status: \"" + report.capture_status + "\" " +
        "metadata_status: \"" + report.metadata_status + "\" " +
        "pixel_status: \"" + report.pixel_status + "\" " +
        "shape_status: \"" + report.shape_status + "\" " +
        "color_status: \"" + report.color_status + "\" " +
        "primary_status: \"" + report.primary_status + "\" " +
        "tolerance_profile: \"" + report.tolerance_profile + "\" " +
        "policy: (exact_required: " + _bool_text(report.exact_required) +
        " tolerance_acceptance_allowed: " + _bool_text(report.tolerance_acceptance_allowed) + ") " +
        "match_percentage: " + report.match_percentage.to_string() + " " +
        "different_pixels: " + report.different_pixels.to_string() + " " +
        "max_channel_diff: " + report.max_channel_diff.to_string() + " " +
        "artifacts: (expected: \"" + _sdn_escape(report.expected_artifact) +
        "\" actual: \"" + _sdn_escape(report.actual_artifact) +
        "\" diff: \"" + _sdn_escape(report.diff_artifact) +
        "\" metadata: \"" + _sdn_escape(report.metadata_artifact) + "\") " +
        "accepted: " + _bool_text(report.accepted) + ")"
