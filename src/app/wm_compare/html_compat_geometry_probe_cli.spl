use app.wm_compare.electron_geometry_compare.{electron_geometry_json_to_boxes}
use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes}
use app.wm_compare.structural_layout_report.{structural_box_layout_compare, structural_box_layout_report_sdn}
use std.cli.cli_util.{get_cli_args}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _env_i32_or(key: text, fallback: i32) -> i32:
    val value = _env_or(key, "")
    if value == "":
        return fallback
    value.to_i32()

fn _canonical_fixture_id(raw: text) -> text:
    if raw.contains("02_block_boxes"): return "02_block_boxes"
    if raw.contains("03_list"): return "03_list"
    if raw.contains("04_button"): return "04_button"
    if raw.contains("05_text_input"): return "05_text_input"
    if raw.contains("06_card_panel"): return "06_card_panel"
    if raw.contains("07_scrollable_list"): return "07_scrollable_list"
    if raw.contains("13_margin"): return "13_margin"
    if raw.contains("14_border"): return "14_border"
    if raw.contains("16_flex_row"): return "16_flex_row"
    if raw.contains("17_flex_col"): return "17_flex_col"
    if raw.contains("18_flex_grow_weights"): return "18_flex_grow_weights"
    if raw.contains("19_flex_shrink_weights"): return "19_flex_shrink_weights"
    if raw.contains("20_flex_basis_override"): return "20_flex_basis_override"
    if raw.contains("21_flex_wrap_basic"): return "21_flex_wrap_basic"
    if raw.contains("22_flex_align_items_baseline"): return "22_flex_align_items_baseline"
    if raw.contains("23_flex_wrap_align_content_center"): return "23_flex_wrap_align_content_center"
    if raw.contains("24_flex_wrap_reverse_basic"): return "24_flex_wrap_reverse_basic"
    if raw.contains("25_flex_justify_space_between"): return "25_flex_justify_space_between"
    if raw.contains("26_flex_gap_basic"): return "26_flex_gap_basic"
    if raw.contains("27_absolute_position_basic"): return "27_absolute_position_basic"
    if raw.contains("28_display_contents_basic"): return "28_display_contents_basic"
    if raw.contains("29_box_sizing_border_box"): return "29_box_sizing_border_box"
    if raw.contains("30_min_max_width_basic"): return "30_min_max_width_basic"
    if raw.contains("31_flex_align_items_center"): return "31_flex_align_items_center"
    if raw.contains("32_flex_align_items_flex_end"): return "32_flex_align_items_flex_end"
    if raw.contains("33_flex_justify_flex_end"): return "33_flex_justify_flex_end"
    if raw.contains("34_flex_justify_center"): return "34_flex_justify_center"
    if raw.contains("35_flex_align_items_stretch"): return "35_flex_align_items_stretch"
    if raw.contains("36_flex_align_self_flex_end"): return "36_flex_align_self_flex_end"
    if raw.contains("37_flex_gap_justify_center"): return "37_flex_gap_justify_center"
    if raw.contains("38_flex_gap_space_between"): return "38_flex_gap_space_between"
    if raw.contains("39_flex_gap_flex_end"): return "39_flex_gap_flex_end"
    if raw.contains("40_flex_column_gap_justify_center"): return "40_flex_column_gap_justify_center"
    if raw.contains("41_flex_column_gap_space_between"): return "41_flex_column_gap_space_between"
    if raw.contains("42_flex_column_gap_flex_end"): return "42_flex_column_gap_flex_end"
    if raw.contains("43_flex_column_align_items_center"): return "43_flex_column_align_items_center"
    if raw.contains("44_flex_column_align_items_flex_end"): return "44_flex_column_align_items_flex_end"
    if raw.contains("45_flex_column_align_self_flex_end"): return "45_flex_column_align_self_flex_end"
    raw

fn _canonical_geometry_path(raw: text, fixture_id: text) -> text:
    raw

fn _canonical_report_path(raw: text, fixture_id: text) -> text:
    raw

fn main() -> i64:
    val args = get_cli_args()
    val raw_fixture_id = if args.len() > 0: args[0] else: _env_or("HTML_COMPAT_GEOMETRY_FIXTURE", "02_block_boxes")
    val fixture_id = _canonical_fixture_id(raw_fixture_id)
    val raw_geometry_path = if args.len() > 1: args[1] else: _env_or("HTML_COMPAT_GEOMETRY_JSON", "")
    val raw_output_path = if args.len() > 2: args[2] else: _env_or("HTML_COMPAT_GEOMETRY_REPORT", "")
    val geometry_path = _canonical_geometry_path(raw_geometry_path, fixture_id)
    val output_path = _canonical_report_path(raw_output_path, fixture_id)
    val viewport_width = if args.len() > 3: args[3].to_i32() else: _env_i32_or("HTML_COMPAT_GEOMETRY_WIDTH", 320)
    val viewport_height = if args.len() > 4: args[4].to_i32() else: _env_i32_or("HTML_COMPAT_GEOMETRY_HEIGHT", 240)

    if geometry_path == "":
        print "status=fail"
        print "reason=missing-geometry-json-path"
        return 1

    val geometry_json = rt_file_read_text(geometry_path) ?? ""
    if geometry_json == "":
        print "status=fail"
        print "reason=missing-geometry-json"
        return 1

    val electron_boxes = electron_geometry_json_to_boxes(geometry_json)
    val simple_boxes = html_compat_fixture_simple_boxes(fixture_id, viewport_width, viewport_height)
    if simple_boxes.len() == 0:
        print "status=fail"
        print "reason=unsupported-fixture:{fixture_id}"
        return 1

    val report = structural_box_layout_compare(
        "electron_geometry", "simple_renderer_geometry",
        viewport_width, viewport_height,
        electron_boxes, simple_boxes,
        "simple_renderer:{fixture_id}", geometry_path
    )
    val sdn = structural_box_layout_report_sdn(report, electron_boxes, simple_boxes)

    if output_path != "":
        rt_file_write_text(output_path, sdn)

    print "status={if report.status == \"layout_match\": \"pass\" else: \"fail\"}"
    print "report_status={report.status}"
    print "mismatch_count={report.mismatch_count}"
    print "source_a_count={report.source_a_count}"
    print "source_b_count={report.source_b_count}"
    print "fixture={fixture_id}"
    print "geometry_json={geometry_path}"
    if output_path != "":
        print "report_path={output_path}"

    if report.status == "layout_match":
        return 0
    1
