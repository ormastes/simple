#[runtime_intrinsics]
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64, size: i64)
extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64) -> i64

pub fn measurement_alloc(size: i64) -> i64:
    rt_alloc(size)

pub fn measurement_free(ptr: i64, size: i64):
    rt_free(ptr, size)

pub fn measurement_ptr_read_i32(addr: i64, offset: i64) -> i32:
    rt_ptr_read_i32(addr, offset)

pub fn measurement_ptr_write_i64(addr: i64, offset: i64, value: i64) -> i64:
    rt_ptr_write_i64(addr, offset, value)
