use app.wm_compare.site_corpus_layout_report.{build_site_corpus_div_geometry_summary_range}
use std.cli.cli_util.{get_cli_args}

extern fn rt_file_write_text(path: text, content: text) -> bool

fn _arg_i32(args: [text], index: i32, fallback: i32) -> i32:
    if args.len() > index:
        return args[index].to_i32()
    fallback

fn main() -> i64:
    val args = get_cli_args()
    val offset = _arg_i32(args, 0, 0)
    val limit = _arg_i32(args, 1, 6)
    val viewport_width = _arg_i32(args, 2, 160)
    val viewport_height = _arg_i32(args, 3, 120)
    val output_path = if args.len() > 4: args[4] else: ""
    val expected = _arg_i32(args, 5, limit)

    val report = build_site_corpus_div_geometry_summary_range(offset, limit, viewport_width, viewport_height)
    if output_path != "":
        rt_file_write_text(output_path, report)

    val expected_summary = "selected: " + expected.to_string() +
        " matched: " + expected.to_string() +
        " mismatched: 0 missing_metrics: 0"
    val ok = report.contains(expected_summary)

    print "status={if ok: \"pass\" else: \"fail\"}"
    print "offset={offset}"
    print "limit={limit}"
    print "expected={expected}"
    print "viewport_width={viewport_width}"
    print "viewport_height={viewport_height}"
    if output_path != "":
        print "report_path={output_path}"

    if ok:
        return 0
    1
