# HTML Compat — Phase 2 Chrome ↔ Simple HTML/CSS Pixel Equivalence
#
# Incrementally captures the same HTML fixture from two render sources:
#   A  checked-in Electron / Chromium golden PPMs
#   B  Simple Browser Engine (BrowserRenderer.render_html_to_pixels)
#
# Renders at 320x240. Iterates fixtures in order (00..03 + 10..17 layered on
# top of 02_block_boxes.html) and stops at the first divergent fixture.
#
# Output:
#   test/baselines/html_compat/<id>/chrome.ppm
#   test/baselines/html_compat/<id>/simple.ppm
#   test/baselines/html_compat/<id>/diff_chrome_vs_simple.ppm  (on mismatch)
#   test/baselines/html_compat/<id>/report.sdn
#
# Usage:
#   bin/simple run src/app/wm_compare/html_compat.spl
#   bin/simple run src/app/wm_compare/html_compat.spl --only=02_block_boxes
#   bin/simple run src/app/wm_compare/html_compat.spl --update-baseline
#   bin/simple run src/app/wm_compare/html_compat.spl --skip-simple

# Split from src/app/wm_compare/html_compat.spl to keep module cohesion under the 800-line source limit.
export use app.wm_compare.html_compat_part1.*
export use app.wm_compare.html_compat_part2.*
export use app.wm_compare.html_compat_part3.*
