# Representative famous-site HTML corpus for renderer compatibility checks.
#
# These fixtures are intentionally offline and deterministic. They model common
# layout patterns from widely-known sites without fetching live pages or copying
# third-party markup.

struct SiteSample:
    id: text
    name: text
    category: text
    font_family: text
    html: text

fn famous_site_names() -> [text]:
    [
        "Google", "YouTube", "Facebook", "Instagram", "X", "TikTok",
        "Wikipedia", "Amazon", "Reddit", "Netflix", "LinkedIn", "Microsoft",
        "Apple", "Yahoo", "Bing", "Twitch", "Discord", "GitHub",
        "Stack Overflow", "OpenAI", "ChatGPT", "Gmail", "Google Maps",
        "Google Drive", "Google Docs", "Google Calendar", "Google News",
        "Google Photos", "Google Translate", "Google Play", "Chrome Web Store",
        "WhatsApp", "Messenger", "Telegram", "Snapchat", "Pinterest",
        "Spotify", "SoundCloud", "Bandcamp", "IMDb", "Fandom", "Quora",
        "Medium", "Substack", "The New York Times", "BBC", "CNN",
        "The Guardian", "Reuters", "Bloomberg", "ESPN", "Yahoo Sports",
        "NBA", "NFL", "MLB", "NHL", "FIFA", "Weather.com", "AccuWeather",
        "Yelp", "Tripadvisor", "Booking.com", "Airbnb", "Uber", "Lyft",
        "DoorDash", "Instacart", "Walmart", "Target", "eBay", "Etsy",
        "Shopify", "PayPal", "Stripe", "Coinbase", "Robinhood",
        "Bank of America", "Chase", "Wells Fargo", "Visa", "Mastercard",
        "Salesforce", "Atlassian", "Jira", "Confluence", "Slack", "Zoom",
        "Dropbox", "Box", "Notion", "Figma", "Canva", "Adobe", "Behance",
        "Dribbble", "Coursera", "Khan Academy", "Udemy", "Duolingo",
        "Stack Exchange", "MDN", "npm", "Docker Hub", "Hugging Face",
        "Kaggle", "arXiv", "PubMed", "GitLab", "Bitbucket", "Cloudflare",
        "AWS", "Azure", "Google Cloud", "Vercel", "Netlify", "Heroku",
        "DigitalOcean", "Linode", "Mozilla", "WordPress", "Wix",
        "Squarespace", "Craigslist", "Indeed", "Glassdoor", "Zillow",
        "Realtor.com", "Cars.com", "Tesla", "Nvidia", "Steam", "Epic Games"
    ]

fn _slugify_site_name(name: text) -> text:
    val lower = name.lower()
    val spaces = lower.replace(" ", "_")
    spaces.replace(".", "_")

fn _site_category(index: i32) -> text:
    val categories = [
        "search", "video", "social", "commerce", "news", "productivity",
        "finance", "travel", "education", "developer", "cloud", "media"
    ]
    categories[index % categories.len()]

fn famous_site_font_families() -> [text]:
    [
        "Arial, sans-serif",
        "Roboto, Arial, sans-serif",
        "\"Segoe UI\", Arial, sans-serif",
        "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Arial, sans-serif",
        "\"Helvetica Neue\", Helvetica, Arial, sans-serif",
        "\"Times New Roman\", Times, serif",
        "Georgia, \"Times New Roman\", serif",
        "\"Noto Sans\", Arial, sans-serif",
        "\"Noto Serif\", Georgia, serif",
        "\"Fira Code\", \"Liberation Mono\", monospace",
        "\"Liberation Sans\", Arial, sans-serif",
        "\"Liberation Serif\", \"Times New Roman\", serif",
        "\"Inter\", Arial, sans-serif",
        "\"Open Sans\", Arial, sans-serif",
        "\"Source Sans 3\", Arial, sans-serif",
        "\"IBM Plex Sans\", Arial, sans-serif",
        "\"Graphik\", Arial, sans-serif",
        "\"Avenir Next\", Avenir, Arial, sans-serif",
        "\"Proxima Nova\", Arial, sans-serif",
        "\"Montserrat\", Arial, sans-serif",
        "\"Lato\", Arial, sans-serif",
        "\"Ubuntu\", Arial, sans-serif",
        "\"SF Pro Text\", -apple-system, BlinkMacSystemFont, sans-serif",
        "\"SF Mono\", \"Fira Code\", monospace"
    ]

fn famous_site_font_family_for_index(index: i32) -> text:
    val fonts = famous_site_font_families()
    fonts[index % fonts.len()]

fn build_site_sample(name: text, index: i32) -> SiteSample:
    val category = _site_category(index)
    val id = "site_" + index.to_string() + "_" + _slugify_site_name(name)
    val font_family = famous_site_font_family_for_index(index)
    val accent = [
        "#2563eb", "#dc2626", "#059669", "#7c3aed", "#ea580c", "#0f766e"
    ][index % 6]
    val html = "<html><body><div data-font-corpus=\"known-site-fonts\" style='width: 120px; height: 40px; background-color: " + accent + "; font-family: " + font_family + "'>" + name + " " + category + " deterministic compatibility fixture</div></body></html>"
    SiteSample(id: id, name: name, category: category, font_family: font_family, html: html)

fn build_famous_site_sample_corpus() -> [SiteSample]:
    val names = famous_site_names()
    var samples: [SiteSample] = []
    var index: i32 = 0
    for name in names:
        samples = samples + [build_site_sample(name, index)]
        index = index + 1
    samples

fn famous_site_sample_html_path(id: text) -> text:
    "test/fixtures/famous_site_corpus/" + id + ".html"

fn famous_site_sample_baseline_dir(id: text) -> text:
    "test/baselines/famous_site_corpus/" + id

fn famous_site_sample_chrome_ppm_path(id: text) -> text:
    famous_site_sample_baseline_dir(id) + "/chrome.ppm"

fn famous_site_sample_chrome_metrics_path(id: text) -> text:
    famous_site_sample_baseline_dir(id) + "/chrome_metrics.json"

fn famous_site_sample_simple_ppm_path(id: text) -> text:
    famous_site_sample_baseline_dir(id) + "/simple.ppm"

fn famous_site_sample_report_sdn_path(id: text) -> text:
    famous_site_sample_baseline_dir(id) + "/report.sdn"

fn _sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn build_famous_site_sample_manifest_sdn() -> text:
    val samples = build_famous_site_sample_corpus()
    var body = "(famous_site_sample_corpus\n"
    body = body + "  count: " + samples.len().to_string() + "\n"
    body = body + "  samples: [\n"
    for sample in samples:
        body = body + "    (site_sample id: \"" + sample.id + "\" name: \"" + _sdn_escape(sample.name) + "\" category: \"" + sample.category + "\" font_family: \"" + _sdn_escape(sample.font_family) + "\" html_path: \"" + famous_site_sample_html_path(sample.id) + "\" baseline_dir: \"" + famous_site_sample_baseline_dir(sample.id) + "\" chrome_ppm: \"" + famous_site_sample_chrome_ppm_path(sample.id) + "\" chrome_metrics: \"" + famous_site_sample_chrome_metrics_path(sample.id) + "\" simple_ppm: \"" + famous_site_sample_simple_ppm_path(sample.id) + "\" report_sdn: \"" + famous_site_sample_report_sdn_path(sample.id) + "\")\n"
    body = body + "  ]\n"
    body = body + ")\n"
    body
