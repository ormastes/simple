# Representative famous-site HTML corpus for renderer compatibility checks.
#
# These fixtures are intentionally offline and deterministic. They model common
# layout patterns from widely-known sites without fetching live pages or copying
# third-party markup.

struct SiteSample:
    id: text
    name: text
    category: text
    html: text

fn famous_site_names() -> [text]:
    [
        "Google", "YouTube", "Facebook", "Instagram", "X", "TikTok",
        "Wikipedia", "Amazon", "Reddit", "Netflix", "LinkedIn", "Microsoft",
        "Apple", "Yahoo", "Bing", "Twitch", "Discord", "GitHub",
        "Stack Overflow", "OpenAI", "ChatGPT", "Gmail", "Google Maps",
        "Google Drive", "Google Docs", "Google Calendar", "Google News",
        "Google Photos", "Google Translate", "Google Play", "Chrome Web Store",
        "WhatsApp", "Messenger", "Telegram", "Snapchat", "Pinterest",
        "Spotify", "SoundCloud", "Bandcamp", "IMDb", "Fandom", "Quora",
        "Medium", "Substack", "The New York Times", "BBC", "CNN",
        "The Guardian", "Reuters", "Bloomberg", "ESPN", "Yahoo Sports",
        "NBA", "NFL", "MLB", "NHL", "FIFA", "Weather.com", "AccuWeather",
        "Yelp", "Tripadvisor", "Booking.com", "Airbnb", "Uber", "Lyft",
        "DoorDash", "Instacart", "Walmart", "Target", "eBay", "Etsy",
        "Shopify", "PayPal", "Stripe", "Coinbase", "Robinhood",
        "Bank of America", "Chase", "Wells Fargo", "Visa", "Mastercard",
        "Salesforce", "Atlassian", "Jira", "Confluence", "Slack", "Zoom",
        "Dropbox", "Box", "Notion", "Figma", "Canva", "Adobe", "Behance",
        "Dribbble", "Coursera", "Khan Academy", "Udemy", "Duolingo",
        "Stack Exchange", "MDN", "npm", "Docker Hub", "Hugging Face",
        "Kaggle", "arXiv", "PubMed", "GitLab", "Bitbucket", "Cloudflare",
        "AWS", "Azure", "Google Cloud", "Vercel", "Netlify", "Heroku",
        "DigitalOcean", "Linode", "Mozilla", "WordPress", "Wix",
        "Squarespace", "Craigslist", "Indeed", "Glassdoor", "Zillow",
        "Realtor.com", "Cars.com", "Tesla", "Nvidia", "Steam", "Epic Games"
    ]

fn _slugify_site_name(name: text) -> text:
    val lower = name.lower()
    val spaces = lower.replace(" ", "_")
    spaces.replace(".", "_")

fn _site_category(index: i32) -> text:
    val categories = [
        "search", "video", "social", "commerce", "news", "productivity",
        "finance", "travel", "education", "developer", "cloud", "media"
    ]
    categories[index % categories.len()]

fn build_site_sample(name: text, index: i32) -> SiteSample:
    val category = _site_category(index)
    val id = "site_" + index.to_string() + "_" + _slugify_site_name(name)
    val accent = [
        "#2563eb", "#dc2626", "#059669", "#7c3aed", "#ea580c", "#0f766e"
    ][index % 6]
    val html = "<html><body><div style='width: 120px; height: 40px; background-color: " + accent + "'>" + name + " " + category + " deterministic compatibility fixture</div></body></html>"
    SiteSample(id: id, name: name, category: category, html: html)

fn build_famous_site_sample_corpus() -> [SiteSample]:
    val names = famous_site_names()
    var samples: [SiteSample] = []
    var index: i32 = 0
    for name in names:
        samples = samples + [build_site_sample(name, index)]
        index = index + 1
    samples
