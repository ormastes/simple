# Backend-qualified measurement evidence for wm_compare.

use std.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus, backend_status_text}

pub struct BackendMeasurementRecord:
    requested_backend: text
    selected_backend: text
    status: text
    command: text
    host: text
    warmup_count: i32
    sample_count: i32
    p50_us: i64
    p95_us: i64
    max_rss_kb: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    render_readback_scope: text
    scalar_baseline_compared: bool
    fallback_used: bool
    unavailable_reason: text

pub struct BackendComparisonSample:
    fixture_id: text
    backend_family: text
    shell: text
    requested_backend: text
    selected_backend: text
    device_id: text
    status: text
    command: text
    host: text
    warmup_count: i32
    sample_count: i32
    cold_start_us: i64
    warm_start_us: i64
    p50_frame_us: i64
    p95_frame_us: i64
    p95_input_to_paint_us: i64
    max_rss_kb: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    package_size_bytes: i64
    artifact_build_us: i64
    artifact_load_us: i64
    artifact_submit_us: i64
    artifact_sync_us: i64
    artifact_readback_us: i64
    render_readback_scope: text
    checksum: text
    pixel_proof: text
    scalar_baseline_compared: bool
    fallback_used: bool
    fallback_reason: text
    unavailable_reason: text

fn _sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn _bool_text(value: bool) -> text:
    if value: "true" else: "false"

fn _is_acceleration_lane(name: text) -> bool:
    name == "metal" or name == "vulkan" or name == "cuda" or
        name == "cpu_simd" or name == "cpu_simd_x86" or
        name == "cpu_simd_arm" or name == "cpu_simd_riscv"

fn _is_gpu_family(name: text) -> bool:
    name == "metal" or name == "vulkan" or name == "cuda" or
        name == "opencl" or name == "hip" or name == "rocm" or name == "gpu"

fn _comparison_identity_valid(sample: BackendComparisonSample) -> bool:
    sample.fixture_id != "" and sample.backend_family != "" and
        sample.shell != "" and sample.requested_backend != "" and
        sample.selected_backend != "" and sample.status != "" and
        sample.command != "" and sample.host != ""

fn _comparison_artifact_timings_valid(sample: BackendComparisonSample) -> bool:
    if not _is_gpu_family(sample.backend_family):
        return true
    sample.artifact_build_us > 0 and sample.artifact_load_us >= 0 and
        sample.artifact_submit_us > 0 and sample.artifact_sync_us >= 0 and
        sample.artifact_readback_us >= 0

pub fn backend_measurement_from_probe(probe: BackendProbeResult,
                                      command: text, host: text,
                                      warmup_count: i32, sample_count: i32,
                                      p50_us: i64, p95_us: i64,
                                      max_rss_kb: i64,
                                      binary_size_bytes: i64,
                                      baseline_binary_size_bytes: i64,
                                      render_readback_scope: text,
                                      scalar_baseline_compared: bool) -> BackendMeasurementRecord:
    val fallback_used = probe.selected_name != probe.requested_name or probe.status == BackendStatus.Fallback
    val reason = if probe.fallback_reason != "": probe.fallback_reason else: probe.reason
    BackendMeasurementRecord(
        requested_backend: probe.requested_name,
        selected_backend: probe.selected_name,
        status: backend_status_text(probe.status),
        command: command,
        host: host,
        warmup_count: warmup_count,
        sample_count: sample_count,
        p50_us: p50_us,
        p95_us: p95_us,
        max_rss_kb: max_rss_kb,
        binary_size_bytes: binary_size_bytes,
        baseline_binary_size_bytes: baseline_binary_size_bytes,
        render_readback_scope: render_readback_scope,
        scalar_baseline_compared: scalar_baseline_compared,
        fallback_used: fallback_used,
        unavailable_reason: reason
    )

pub fn backend_comparison_from_measurement(record: BackendMeasurementRecord,
                                           fixture_id: text,
                                           backend_family: text,
                                           shell: text,
                                           cold_start_us: i64,
                                           warm_start_us: i64,
                                           package_size_bytes: i64,
                                           p95_input_to_paint_us: i64,
                                           artifact_build_us: i64,
                                           artifact_load_us: i64,
                                           artifact_submit_us: i64,
                                           artifact_sync_us: i64,
                                           artifact_readback_us: i64,
                                           checksum: text,
                                           pixel_proof: text,
                                           device_id: text) -> BackendComparisonSample:
    BackendComparisonSample(
        fixture_id: fixture_id,
        backend_family: backend_family,
        shell: shell,
        requested_backend: record.requested_backend,
        selected_backend: record.selected_backend,
        device_id: device_id,
        status: record.status,
        command: record.command,
        host: record.host,
        warmup_count: record.warmup_count,
        sample_count: record.sample_count,
        cold_start_us: cold_start_us,
        warm_start_us: warm_start_us,
        p50_frame_us: record.p50_us,
        p95_frame_us: record.p95_us,
        p95_input_to_paint_us: p95_input_to_paint_us,
        max_rss_kb: record.max_rss_kb,
        binary_size_bytes: record.binary_size_bytes,
        baseline_binary_size_bytes: record.baseline_binary_size_bytes,
        package_size_bytes: package_size_bytes,
        artifact_build_us: artifact_build_us,
        artifact_load_us: artifact_load_us,
        artifact_submit_us: artifact_submit_us,
        artifact_sync_us: artifact_sync_us,
        artifact_readback_us: artifact_readback_us,
        render_readback_scope: record.render_readback_scope,
        checksum: checksum,
        pixel_proof: pixel_proof,
        scalar_baseline_compared: record.scalar_baseline_compared,
        fallback_used: record.fallback_used,
        fallback_reason: if record.fallback_used: record.unavailable_reason else: "",
        unavailable_reason: if record.status == "Unavailable" or record.status == "Failed": record.unavailable_reason else: ""
    )

pub fn backend_measurement_initialized_valid(record: BackendMeasurementRecord) -> bool:
    if record.status != "Initialized":
        return false
    if record.command == "" or record.host == "" or record.render_readback_scope == "":
        return false
    if record.warmup_count < 0 or record.sample_count <= 0:
        return false
    if record.p50_us <= 0 or record.p95_us < record.p50_us:
        return false
    if record.max_rss_kb <= 0 or record.binary_size_bytes <= 0 or record.baseline_binary_size_bytes <= 0:
        return false
    if _is_acceleration_lane(record.requested_backend) and not record.scalar_baseline_compared:
        return false
    if _is_acceleration_lane(record.requested_backend) and record.fallback_used:
        return false
    true

pub fn backend_measurement_unavailable_valid(record: BackendMeasurementRecord) -> bool:
    if record.status != "Unavailable" and record.status != "Failed":
        return false
    if record.unavailable_reason == "":
        return false
    if _is_acceleration_lane(record.requested_backend) and record.fallback_used:
        return false
    true

pub fn backend_measurement_satisfies_lane(record: BackendMeasurementRecord) -> bool:
    backend_measurement_initialized_valid(record) or backend_measurement_unavailable_valid(record)

pub fn backend_comparison_initialized_valid(sample: BackendComparisonSample) -> bool:
    if sample.status != "Initialized":
        return false
    if not _comparison_identity_valid(sample):
        return false
    if sample.warmup_count < 0 or sample.sample_count <= 0:
        return false
    if sample.cold_start_us <= 0 or sample.warm_start_us <= 0:
        return false
    if sample.p50_frame_us <= 0 or sample.p95_frame_us < sample.p50_frame_us:
        return false
    if sample.p95_input_to_paint_us < sample.p95_frame_us:
        return false
    if sample.max_rss_kb <= 0 or sample.binary_size_bytes <= 0 or sample.baseline_binary_size_bytes <= 0:
        return false
    if sample.package_size_bytes <= 0 or sample.render_readback_scope == "":
        return false
    if sample.checksum == "" or sample.pixel_proof == "":
        return false
    if sample.fallback_used and sample.fallback_reason == "":
        return false
    if _is_acceleration_lane(sample.requested_backend) and not sample.scalar_baseline_compared:
        return false
    if not _comparison_artifact_timings_valid(sample):
        return false
    true

pub fn backend_comparison_unavailable_valid(sample: BackendComparisonSample) -> bool:
    if sample.status != "Unavailable" and sample.status != "Failed":
        return false
    if not _comparison_identity_valid(sample):
        return false
    if sample.unavailable_reason == "":
        return false
    if sample.fallback_used and sample.fallback_reason == "":
        return false
    true

pub fn backend_comparison_sample_valid(sample: BackendComparisonSample) -> bool:
    backend_comparison_initialized_valid(sample) or backend_comparison_unavailable_valid(sample)

pub fn backend_comparison_samples_valid(samples: [BackendComparisonSample]) -> bool:
    if samples.len() == 0:
        return false
    for sample in samples:
        if not backend_comparison_sample_valid(sample):
            return false
    true

pub fn backend_measurement_binary_size_delta_bytes(record: BackendMeasurementRecord) -> i64:
    record.binary_size_bytes - record.baseline_binary_size_bytes

pub fn backend_measurement_binary_size_delta_valid(record: BackendMeasurementRecord) -> bool:
    if record.status != "Initialized":
        return false
    record.binary_size_bytes > 0 and record.baseline_binary_size_bytes > 0

pub fn backend_measurement_record_sdn(record: BackendMeasurementRecord) -> text:
    "(backend_measurement " +
        "requested: \"" + _sdn_escape(record.requested_backend) + "\" " +
        "selected: \"" + _sdn_escape(record.selected_backend) + "\" " +
        "status: \"" + record.status + "\" " +
        "command: \"" + _sdn_escape(record.command) + "\" " +
        "host: \"" + _sdn_escape(record.host) + "\" " +
        "warmup_count: " + record.warmup_count.to_string() + " " +
        "sample_count: " + record.sample_count.to_string() + " " +
        "p50_us: " + record.p50_us.to_string() + " " +
        "p95_us: " + record.p95_us.to_string() + " " +
        "max_rss_kb: " + record.max_rss_kb.to_string() + " " +
        "binary_size_bytes: " + record.binary_size_bytes.to_string() + " " +
        "baseline_binary_size_bytes: " + record.baseline_binary_size_bytes.to_string() + " " +
        "binary_size_delta_bytes: " + backend_measurement_binary_size_delta_bytes(record).to_string() + " " +
        "render_readback_scope: \"" + _sdn_escape(record.render_readback_scope) + "\" " +
        "scalar_baseline_compared: " + _bool_text(record.scalar_baseline_compared) + " " +
        "fallback_used: " + _bool_text(record.fallback_used) + " " +
        "reason: \"" + _sdn_escape(record.unavailable_reason) + "\")"

pub fn backend_comparison_sample_sdn(sample: BackendComparisonSample) -> text:
    "(backend_comparison_sample " +
        "fixture_id: \"" + _sdn_escape(sample.fixture_id) + "\" " +
        "backend_family: \"" + _sdn_escape(sample.backend_family) + "\" " +
        "shell: \"" + _sdn_escape(sample.shell) + "\" " +
        "requested: \"" + _sdn_escape(sample.requested_backend) + "\" " +
        "selected: \"" + _sdn_escape(sample.selected_backend) + "\" " +
        "device_id: \"" + _sdn_escape(sample.device_id) + "\" " +
        "status: \"" + sample.status + "\" " +
        "command: \"" + _sdn_escape(sample.command) + "\" " +
        "host: \"" + _sdn_escape(sample.host) + "\" " +
        "warmup_count: " + sample.warmup_count.to_string() + " " +
        "sample_count: " + sample.sample_count.to_string() + " " +
        "cold_start_us: " + sample.cold_start_us.to_string() + " " +
        "warm_start_us: " + sample.warm_start_us.to_string() + " " +
        "p50_frame_us: " + sample.p50_frame_us.to_string() + " " +
        "p95_frame_us: " + sample.p95_frame_us.to_string() + " " +
        "p95_input_to_paint_us: " + sample.p95_input_to_paint_us.to_string() + " " +
        "max_rss_kb: " + sample.max_rss_kb.to_string() + " " +
        "binary_size_bytes: " + sample.binary_size_bytes.to_string() + " " +
        "baseline_binary_size_bytes: " + sample.baseline_binary_size_bytes.to_string() + " " +
        "binary_size_delta_bytes: " + (sample.binary_size_bytes - sample.baseline_binary_size_bytes).to_string() + " " +
        "package_size_bytes: " + sample.package_size_bytes.to_string() + " " +
        "artifact_build_us: " + sample.artifact_build_us.to_string() + " " +
        "artifact_load_us: " + sample.artifact_load_us.to_string() + " " +
        "artifact_submit_us: " + sample.artifact_submit_us.to_string() + " " +
        "artifact_sync_us: " + sample.artifact_sync_us.to_string() + " " +
        "artifact_readback_us: " + sample.artifact_readback_us.to_string() + " " +
        "render_readback_scope: \"" + _sdn_escape(sample.render_readback_scope) + "\" " +
        "checksum: \"" + _sdn_escape(sample.checksum) + "\" " +
        "pixel_proof: \"" + _sdn_escape(sample.pixel_proof) + "\" " +
        "scalar_baseline_compared: " + _bool_text(sample.scalar_baseline_compared) + " " +
        "fallback_used: " + _bool_text(sample.fallback_used) + " " +
        "fallback_reason: \"" + _sdn_escape(sample.fallback_reason) + "\" " +
        "unavailable_reason: \"" + _sdn_escape(sample.unavailable_reason) + "\")"

pub fn backend_comparison_samples_sdn(samples: [BackendComparisonSample]) -> text:
    var entries: [text] = []
    var i = 0
    while i < samples.len():
        entries.push("  " + backend_comparison_sample_sdn(samples[i]))
        i = i + 1
    "(backend_comparison_samples " +
        "sample_count: " + samples.len().to_string() + " " +
        "valid: " + _bool_text(backend_comparison_samples_valid(samples)) + "\n" +
        entries.join("\n") + "\n)"

fn _status_for(records: [BackendMeasurementRecord], backend: text) -> text:
    for record in records:
        if record.requested_backend == backend:
            return record.status
    "Missing"

fn _all_core_lanes_present(records: [BackendMeasurementRecord]) -> bool:
    _status_for(records, "metal") != "Missing" and
        _status_for(records, "vulkan") != "Missing" and
        _status_for(records, "cuda") != "Missing" and
        _status_for(records, "opencl") != "Missing" and
        _status_for(records, "rocm") != "Missing" and
        (_status_for(records, "cpu_simd") != "Missing" or
         _status_for(records, "cpu_simd_x86") != "Missing" or
         _status_for(records, "cpu_simd_arm") != "Missing" or
         _status_for(records, "cpu_simd_riscv") != "Missing")

pub fn backend_measurement_matrix_valid(records: [BackendMeasurementRecord]) -> bool:
    if not _all_core_lanes_present(records):
        return false
    for record in records:
        if not backend_measurement_satisfies_lane(record):
            return false
    true

pub fn backend_measurement_matrix_sdn(records: [BackendMeasurementRecord]) -> text:
    var entries: [text] = []
    var i = 0
    while i < records.len():
        entries.push("  " + backend_measurement_record_sdn(records[i]))
        i = i + 1
    "(backend_measurement_matrix " +
        "metal_status: \"" + _status_for(records, "metal") + "\" " +
        "vulkan_status: \"" + _status_for(records, "vulkan") + "\" " +
        "cuda_status: \"" + _status_for(records, "cuda") + "\" " +
        "opencl_status: \"" + _status_for(records, "opencl") + "\" " +
        "hip_status: \"" + _status_for(records, "rocm") + "\" " +
        "cpu_simd_status: \"" + _status_for(records, "cpu_simd") + "\" " +
        "valid: " + _bool_text(backend_measurement_matrix_valid(records)) + "\n" +
        entries.join("\n") + "\n)"
