# Backend-qualified measurement evidence for wm_compare.

use std.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus, backend_status_text}

pub struct BackendMeasurementRecord:
    requested_backend: text
    selected_backend: text
    status: text
    command: text
    host: text
    warmup_count: i32
    sample_count: i32
    p50_us: i64
    p95_us: i64
    max_rss_kb: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    render_readback_scope: text
    scalar_baseline_compared: bool
    fallback_used: bool
    unavailable_reason: text

pub struct BackendComparisonSample:
    fixture_id: text
    backend_family: text
    shell: text
    requested_backend: text
    selected_backend: text
    device_id: text
    status: text
    command: text
    host: text
    warmup_count: i32
    sample_count: i32
    cold_start_us: i64
    warm_start_us: i64
    p50_frame_us: i64
    p95_frame_us: i64
    p95_input_to_paint_us: i64
    max_rss_kb: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    package_size_bytes: i64
    artifact_build_us: i64
    artifact_load_us: i64
    artifact_submit_us: i64
    artifact_sync_us: i64
    artifact_readback_us: i64
    render_readback_scope: text
    offload_tag_kind: text
    operation_family: text
    generated_operation: text
    generated_entry_symbol: text
    generated_source_format: text
    generated_binary_format: text
    generated_artifact_path_suffix: text
    runtime_compute_target: text
    runtime_execution_path: text
    runtime_launch_api: text
    runtime_entry_symbol: text
    runtime_artifact_name: text
    runtime_status: text
    checksum: text
    pixel_proof: text
    scalar_baseline_compared: bool
    fallback_used: bool
    fallback_reason: text
    unavailable_reason: text

fn _sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn _bool_text(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _is_acceleration_lane(name: text) -> bool:
    if name == "metal": return true
    if name == "vulkan": return true
    if name == "cuda": return true
    if name == "opencl": return true
    if name == "hip": return true
    if name == "rocm": return true
    if name == "cpu_simd": return true
    if name == "cpu_simd_x86": return true
    if name == "cpu_simd_arm": return true
    if name == "cpu_simd_riscv":
        return true
    false

fn _is_gpu_family(name: text) -> bool:
    if name == "metal": return true
    if name == "vulkan": return true
    if name == "cuda": return true
    if name == "opencl": return true
    if name == "hip": return true
    if name == "rocm": return true
    if name == "gpu":
        return true
    false

fn _comparison_identity_valid(sample: BackendComparisonSample) -> bool:
    if sample.fixture_id == "":
        return false
    if sample.backend_family == "":
        return false
    if sample.shell == "":
        return false
    if sample.requested_backend == "":
        return false
    if sample.selected_backend == "":
        return false
    if sample.status == "":
        return false
    if sample.command == "":
        return false
    if sample.host == "":
        return false
    true

fn _comparison_artifact_timings_valid(sample: BackendComparisonSample) -> bool:
    val is_gpu = _is_gpu_family(sample.backend_family)
    if not is_gpu:
        return true
    if sample.artifact_build_us <= 0:
        return false
    if sample.artifact_load_us < 0:
        return false
    if sample.artifact_submit_us <= 0:
        return false
    if sample.artifact_sync_us < 0:
        return false
    if sample.artifact_readback_us < 0:
        return false
    true

pub fn backend_comparison_artifact_total_us(sample: BackendComparisonSample) -> i64:
    sample.artifact_build_us + sample.artifact_load_us + sample.artifact_submit_us +
        sample.artifact_sync_us + sample.artifact_readback_us

pub fn backend_comparison_offload_overhead_verdict(sample: BackendComparisonSample) -> text:
    if not _is_gpu_family(sample.backend_family):
        return "not-gpu-offload"
    if sample.status != "Initialized":
        return "unavailable"
    val artifact_total = backend_comparison_artifact_total_us(sample)
    if artifact_total <= 0:
        return "missing-artifact-timing"
    if sample.p50_frame_us <= 0:
        return "missing-frame-timing"
    if artifact_total >= sample.p50_frame_us:
        return "offload-overhead-dominates"
    "offload-overhead-contained"

pub fn backend_comparison_speed_verdict(sample: BackendComparisonSample, scalar_p50_frame_us: i64) -> text:
    if sample.status != "Initialized":
        return "unavailable"
    if scalar_p50_frame_us <= 0:
        return "missing-scalar-baseline"
    if sample.p50_frame_us < scalar_p50_frame_us:
        return "backend-faster-than-scalar"
    if sample.p50_frame_us == scalar_p50_frame_us:
        return "backend-equal-to-scalar"
    "backend-slower-than-scalar"

pub fn backend_comparison_offload_efficiency_verdict(sample: BackendComparisonSample, scalar_p50_frame_us: i64) -> text:
    if not _is_gpu_family(sample.backend_family):
        return "not-gpu-offload"
    val speed = backend_comparison_speed_verdict(sample, scalar_p50_frame_us)
    if speed == "unavailable" or speed == "missing-scalar-baseline":
        return speed
    val overhead = backend_comparison_offload_overhead_verdict(sample)
    if overhead == "missing-artifact-timing" or overhead == "missing-frame-timing":
        return overhead
    if speed == "backend-faster-than-scalar":
        if overhead == "offload-overhead-dominates":
            return "offload-faster-but-overhead-dominates"
        return "offload-useful"
    if speed == "backend-equal-to-scalar":
        return "offload-break-even"
    if overhead == "offload-overhead-dominates":
        return "offload-slower-communication-overhead"
    "offload-slower-compute-bound"

fn _is_scalar_baseline_family(name: text) -> bool:
    if name == "software": return true
    if name == "cpu": return true
    if name == "scalar": return true
    name == "cpu_scalar"

pub fn backend_comparison_scalar_p50_us(samples: [BackendComparisonSample]) -> i64:
    for sample in samples:
        if sample.status == "Initialized":
            if _is_scalar_baseline_family(sample.backend_family):
                if sample.p50_frame_us > 0:
                    return sample.p50_frame_us
    0

fn _comparison_speed_verdict_count(samples: [BackendComparisonSample], scalar_p50_frame_us: i64, verdict: text) -> i32:
    var count = 0
    for sample in samples:
        if _is_gpu_family(sample.backend_family):
            if sample.status == "Initialized":
                if scalar_p50_frame_us > 0:
                    if verdict == "backend-faster-than-scalar":
                        if sample.p50_frame_us < scalar_p50_frame_us:
                            count = count + 1
                    if verdict == "backend-equal-to-scalar":
                        if sample.p50_frame_us == scalar_p50_frame_us:
                            count = count + 1
                    if verdict == "backend-slower-than-scalar":
                        if sample.p50_frame_us > scalar_p50_frame_us:
                            count = count + 1
    count

fn _comparison_offload_overhead_verdict_count(samples: [BackendComparisonSample], verdict: text) -> i32:
    var count = 0
    for sample in samples:
        if _is_gpu_family(sample.backend_family):
            if sample.status == "Initialized":
                val artifact_total = sample.artifact_build_us + sample.artifact_load_us + sample.artifact_submit_us +
                    sample.artifact_sync_us + sample.artifact_readback_us
                if artifact_total > 0:
                    if sample.p50_frame_us > 0:
                        if verdict == "offload-overhead-contained":
                            if artifact_total < sample.p50_frame_us:
                                count = count + 1
                        if verdict == "offload-overhead-dominates":
                            if artifact_total >= sample.p50_frame_us:
                                count = count + 1
    count

fn _comparison_offload_efficiency_verdict_count(samples: [BackendComparisonSample], scalar_p50_frame_us: i64, verdict: text) -> i32:
    var count = 0
    for sample in samples:
        if _is_gpu_family(sample.backend_family):
            if sample.status == "Initialized":
                val artifact_total = sample.artifact_build_us + sample.artifact_load_us + sample.artifact_submit_us +
                    sample.artifact_sync_us + sample.artifact_readback_us
                if scalar_p50_frame_us <= 0:
                    if verdict == "missing-scalar-baseline":
                        count = count + 1
                if scalar_p50_frame_us > 0:
                    if artifact_total <= 0:
                        if verdict == "missing-artifact-timing":
                            count = count + 1
                    if artifact_total > 0:
                        if sample.p50_frame_us <= 0:
                            if verdict == "missing-frame-timing":
                                count = count + 1
                        if sample.p50_frame_us > 0:
                            if sample.p50_frame_us < scalar_p50_frame_us:
                                if artifact_total >= sample.p50_frame_us:
                                    if verdict == "offload-faster-but-overhead-dominates":
                                        count = count + 1
                                if artifact_total < sample.p50_frame_us:
                                    if verdict == "offload-useful":
                                        count = count + 1
                            if sample.p50_frame_us == scalar_p50_frame_us:
                                if verdict == "offload-break-even":
                                    count = count + 1
                            if sample.p50_frame_us > scalar_p50_frame_us:
                                if artifact_total >= sample.p50_frame_us:
                                    if verdict == "offload-slower-communication-overhead":
                                        count = count + 1
                                if artifact_total < sample.p50_frame_us:
                                    if verdict == "offload-slower-compute-bound":
                                        count = count + 1
    count

fn _comparison_compiler_metadata_valid(sample: BackendComparisonSample) -> bool:
    val is_gpu = _is_gpu_family(sample.backend_family)
    if not is_gpu:
        return true
    if sample.offload_tag_kind == "":
        return false
    if sample.operation_family == "":
        return false
    if sample.generated_operation == "":
        return false
    if sample.generated_entry_symbol == "":
        return false
    if sample.generated_source_format == "":
        return false
    if sample.generated_binary_format == "":
        return false
    if sample.generated_artifact_path_suffix == "":
        return false
    true

fn _comparison_runtime_metadata_valid(sample: BackendComparisonSample) -> bool:
    val is_gpu = _is_gpu_family(sample.backend_family)
    if not is_gpu:
        return true
    if sample.runtime_compute_target == "":
        return false
    if sample.runtime_execution_path == "":
        return false
    if sample.runtime_launch_api == "":
        return false
    if sample.runtime_entry_symbol == "":
        return false
    if sample.runtime_artifact_name == "":
        return false
    if sample.runtime_status != "ready":
        return false
    true

pub fn backend_measurement_from_probe(probe: BackendProbeResult,
                                      command: text, host: text,
                                      warmup_count: i32, sample_count: i32,
                                      p50_us: i64, p95_us: i64,
                                      max_rss_kb: i64,
                                      binary_size_bytes: i64,
                                      baseline_binary_size_bytes: i64,
                                      render_readback_scope: text,
                                      scalar_baseline_compared: bool) -> BackendMeasurementRecord:
    val fallback_used = probe.selected_name != probe.requested_name or probe.status == BackendStatus.Fallback
    val reason = if probe.fallback_reason != "": probe.fallback_reason else: probe.reason
    BackendMeasurementRecord(
        requested_backend: probe.requested_name,
        selected_backend: probe.selected_name,
        status: backend_status_text(probe.status),
        command: command,
        host: host,
        warmup_count: warmup_count,
        sample_count: sample_count,
        p50_us: p50_us,
        p95_us: p95_us,
        max_rss_kb: max_rss_kb,
        binary_size_bytes: binary_size_bytes,
        baseline_binary_size_bytes: baseline_binary_size_bytes,
        render_readback_scope: render_readback_scope,
        scalar_baseline_compared: scalar_baseline_compared,
        fallback_used: fallback_used,
        unavailable_reason: reason
    )

pub fn backend_comparison_from_measurement(record: BackendMeasurementRecord,
                                           fixture_id: text,
                                           backend_family: text,
                                           shell: text,
                                           cold_start_us: i64,
                                           warm_start_us: i64,
                                           package_size_bytes: i64,
                                           p95_input_to_paint_us: i64,
                                           artifact_build_us: i64,
                                           artifact_load_us: i64,
                                           artifact_submit_us: i64,
                                           artifact_sync_us: i64,
                                           artifact_readback_us: i64,
                                           checksum: text,
                                           pixel_proof: text,
                                           device_id: text) -> BackendComparisonSample:
    backend_comparison_from_measurement_with_compiler_metadata(
        record,
        fixture_id,
        backend_family,
        shell,
        cold_start_us,
        warm_start_us,
        package_size_bytes,
        p95_input_to_paint_us,
        artifact_build_us,
        artifact_load_us,
        artifact_submit_us,
        artifact_sync_us,
        artifact_readback_us,
        checksum,
        pixel_proof,
        device_id,
        "",
        "",
        "",
        "",
        "",
        "",
        ""
    )

