# WM Compare — Unified Pixel Capture + Compare Orchestrator
#
# Captures a named scene from three render sources:
#   A  Electron baseline (via tools/electron-shell/screenshot.js)
#   B  macOS host Simple Web WM — in-process BrowserCompositorBackend
#      (a pure-Simple software renderer that mirrors what the host WM paints)
#   D  QEMU Simple OS self-rendering — via qemu_capture.capture_qemu_vm (QMP)
#
# Source C (in-guest webengine) is intentionally skipped — deferred to Phase 6.
#
# Compare strategy: memcmp-first (exact), fall through to YIQ perceptual,
# dump a PPM heat-map diff via export_comparison_ppm only on mismatch.
# Writes artifacts under test/baselines/wm_compare/<scene>/.
#
# Usage:
#   bin/simple run src/app/wm_compare/main.spl \
#       --source=A|B|D|all --scene=<name> [--update-baseline] \
#       [--tolerance=strict|text_tolerant|aa_aware] \
#       [--width=320 --height=240]

use std.cli.cli_util.{get_cli_args}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_text, file_write_bytes, dir_create_all, file_exists}

use os.compositor.wm_scene.{WmSceneSpec, SceneElement}
use os.compositor.electron_capture.{CaptureResult, capture_electron, capture_electron_scene, capture_error}
use os.compositor.qemu_capture.{capture_qemu_vm}
use os.compositor.screenshot_compare.{
    ComparisonResult, ChannelDiffResult, DiffRegion,
    compare_exact, compare_per_channel, compare_pixel_buffers,
    find_diff_regions, generate_diff_image}
use os.compositor.perceptual_compare.{PerceptualResult, compare_perceptual}
use os.compositor.tolerance_profile.{
    ToleranceProfile,
    profile_strict, profile_text_tolerant, profile_wm_default}
use os.compositor.diff_export.{export_comparison_ppm}
use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}

use app.wm_compare.scene_registry.{
    SceneEntry, resolve_scene, fixture_path_for, list_scene_names}
use app.wm_compare.live_capture.{
    LiveCaptureResult, capture_live_source_b}

# ============================================================================
# CLI Options
# ============================================================================

struct CliOpts:
    """Parsed command-line options for wm_compare."""
    source: text             # "A" | "B" | "D" | "all"
    scene: text              # scene name (must be in scene_registry)
    update_baseline: bool
    tolerance: text          # "strict" | "text_tolerant" | "aa_aware"
    width: i32
    height: i32
    help: bool
    mode: text               # "" (default offline) | "live_b" | "bit-compare" | "live_bd_compare"
    source_a_path: text      # --source-a=<path> for bit-compare mode
    source_b_path: text      # --source-b=<path> for bit-compare mode
    out_dir: text            # --out-dir=<dir> for bit-compare mode
    qmp_socket: text         # --qmp-socket=<path> for live_bd_compare mode

fn default_opts() -> CliOpts:
    CliOpts(
        source: "",
        scene: "",
        update_baseline: false,
        tolerance: "strict",
        width: 320,
        height: 240,
        help: false,
        mode: "",
        source_a_path: "",
        source_b_path: "",
        out_dir: "",
        qmp_socket: ""
    )

fn _parse_kv(arg: text, key: text) -> text:
    """Return value from `--key=value`, or empty string if the arg doesn't match."""
    val prefix = key + "="
    if arg.starts_with(prefix):
        return arg.substring(prefix.len())
    ""

fn parse_opts(args: [text]) -> CliOpts:
    """Parse CLI args into a CliOpts struct."""
    var opts = default_opts()
    for arg in args:
        if arg == "-h" or arg == "--help":
            opts.help = true
        elif arg == "--update-baseline":
            opts.update_baseline = true
        else:
            val v_source = _parse_kv(arg, "--source")
            if v_source != "":
                opts.source = v_source
            else:
                val v_scene = _parse_kv(arg, "--scene")
                if v_scene != "":
                    opts.scene = v_scene
                else:
                    val v_tol = _parse_kv(arg, "--tolerance")
                    if v_tol != "":
                        opts.tolerance = v_tol
                    else:
                        val v_w = _parse_kv(arg, "--width")
                        if v_w != "":
                            opts.width = v_w.to_i32()
                        else:
                            val v_h = _parse_kv(arg, "--height")
                            if v_h != "":
                                opts.height = v_h.to_i32()
                            else:
                                val v_mode = _parse_kv(arg, "--mode")
                                if v_mode != "":
                                    opts.mode = v_mode
                                else:
                                    val v_sa = _parse_kv(arg, "--source-a")
                                    if v_sa != "":
                                        opts.source_a_path = v_sa
                                    else:
                                        val v_sb = _parse_kv(arg, "--source-b")
                                        if v_sb != "":
                                            opts.source_b_path = v_sb
                                        else:
                                            val v_out = _parse_kv(arg, "--out-dir")
                                            if v_out != "":
                                                opts.out_dir = v_out
                                            else:
                                                val v_qmp = _parse_kv(arg, "--qmp-socket")
                                                if v_qmp != "":
                                                    opts.qmp_socket = v_qmp
    opts

fn print_help():
    print "Usage: simple run src/app/wm_compare/main.spl [options]"
    print ""
    print "Unified pixel capture + compare orchestrator for three render sources:"
    print "  A  Electron baseline"
    print "  B  macOS host Simple Web WM (in-process BrowserCompositorBackend)"
    print "  D  QEMU Simple OS self-rendering (via QMP screendump)"
    print ""
    print "Options:"
    print "  --source=A|B|D|all       Which source(s) to capture (required)"
    print "  --scene=<name>           Named scene (required) — see below"
    print "  --update-baseline        Overwrite the baseline PPM on disk"
    print "  --tolerance=<profile>    strict (default) | text_tolerant | aa_aware"
    print "  --width=<n>              Capture width (default 320)"
    print "  --height=<n>             Capture height (default 240)"
    print "  --mode=<mode>            live_b | bit-compare | live_bd_compare"
    print "  --qmp-socket=<path>      QMP socket (live_bd_compare, default /tmp/simpleos_engine2d_qmp.sock)"
    print "  --out-dir=<dir>          Override output dir for bit/live_bd compare"
    print "  -h, --help               Show this help"
    print ""
    print "Registered scenes:"
    for name in list_scene_names():
        print "  {name}"

# ============================================================================
# Tolerance Resolution
# ============================================================================

fn resolve_tolerance(name: text) -> ToleranceProfile:
    """Resolve the user-facing tolerance name to a ToleranceProfile preset."""
    if name == "text_tolerant":
        return profile_text_tolerant()
    if name == "aa_aware":
        return profile_wm_default()
    profile_strict()

# ============================================================================
# Filesystem Layout
# ============================================================================

fn baseline_dir(scene: text) -> text:
    "test/baselines/wm_compare/{scene}"

fn baseline_ppm_path(scene: text, source: text) -> text:
    "{baseline_dir(scene)}/{source}.ppm"

fn diff_ppm_path(scene: text, a: text, b: text) -> text:
    "{baseline_dir(scene)}/diff_{a}_vs_{b}.ppm"

fn report_sdn_path(scene: text) -> text:
    "{baseline_dir(scene)}/report.sdn"

# ============================================================================
# Capture Dispatch
# ============================================================================

fn capture_source_a(scene: SceneEntry, width: i32, height: i32) -> CaptureResult:
    """Source A: Electron baseline.

    Electron is driven by tools/electron-shell/screenshot.js. We reuse the
    scene-to-HTML conversion path only as a preview: for an actual Electron
    capture we would need real HTML for the scene. The scene_to_html() helper
    in wm_scene.spl produces preview HTML, but capture_electron() expects a
    full HTML document string. Rather than silently rendering something
    inconsistent with what Electron would actually draw, if node_modules is
    missing we return a structured error the caller can surface.
    """
    # TODO(phase-1): wire real scene-to-HTML through Electron. For now this
    # uses the preview HTML from wm_scene.scene_to_html(). Node/Electron
    # must be installed under tools/electron-shell/ for the capture to run.
    use os.compositor.wm_scene.{scene_to_html}
    val html = scene_to_html(scene.spec)
    capture_electron(html, width, height)

fn _get_prop_text(props: [text], key: text, default_val: text) -> text:
    """Get a property value by key from an alternating key-value list."""
    var i = 0
    while i + 1 < props.len():
        if props[i] == key:
            return props[i + 1]
        i = i + 2
    default_val

fn _render_minimal_scene(scene: WmSceneSpec) -> [u32]:
    """Minimal in-process software renderer for Phase 0 source B.

    NOTE: This is a deliberate workaround. The plan directs us to reuse
    `render_scene_to_backend()` / `BrowserCompositorBackend`, but the
    interpreter has a type-inference bug that turns `(u32 & i_literal)` into
    i64 so `gradient_v()` et al. fail at runtime with "method to_i32 not
    found on type i64". Until the compositor file is fixed or the bootstrap
    stage 4 binary is used to run this orchestrator, source B uses this
    simplified renderer that paints only solid-color rectangles (no blur,
    no text, no gradient) so the pipeline end-to-end still produces a valid
    baseline PPM. The bug is pre-existing and not caused by this harness.

    TODO(phase-0-followup): once the interpreter `(u32 & i_literal) -> i64`
    bug is fixed, replace this call with `capture_electron_scene(scene.spec)`.
    """
    val total = scene.width * scene.height
    var buf: [u32] = []
    var i = 0
    while i < total:
        buf = buf + [0xFF000000]
        i = i + 1

    for elem in scene.elements:
        var fill_color: u32 = 0xFF000000
        if elem.kind == "desktop_chrome":
            # Use top color as solid fill (gradient requires broken path)
            fill_color = 0xFF1A1A2E
        elif elem.kind == "decoration":
            fill_color = 0xFF2D2D44
        elif elem.kind == "glass_panel":
            fill_color = 0xFF303050
        elif elem.kind == "text_label":
            fill_color = 0xFFFFFFFF

        # Fill rectangle
        var row = 0
        while row < elem.h:
            val py = elem.y + row
            if py >= 0 and py < scene.height:
                var col = 0
                while col < elem.w:
                    val px = elem.x + col
                    if px >= 0 and px < scene.width:
                        buf[py * scene.width + px] = fill_color
                    col = col + 1
            row = row + 1
    buf

fn capture_source_b(scene: SceneEntry, width: i32, height: i32) -> CaptureResult:
    """Source B: host Simple Web WM — in-process software render.

    NOTE: The plan ultimately wants to drive `examples/ui/web_wm.spl` on
    localhost:3333 and capture its framebuffer via `play_wm_screenshot`,
    OR to use `BrowserCompositorBackend` as a bit-equivalent in-process
    fallback. The in-process BrowserCompositorBackend path currently fails
    in the interpreter (see `_render_minimal_scene` doc). Per the Phase 0
    fallback instruction ("capture whatever the in-process backend produces
    and note the issue in your report"), we use a minimal solid-color
    renderer here so the pipeline still produces a real baseline PPM.
    """
    val pixels = _render_minimal_scene(scene.spec)
    CaptureResult(
        pixels: pixels,
        width: scene.spec.width,
        height: scene.spec.height,
        backend_name: "source_b_minimal",
        success: pixels.len() > 0,
        error: if pixels.len() > 0: "" else: "Empty pixel buffer"
    )

fn capture_source_d(scene: SceneEntry, width: i32, height: i32) -> CaptureResult:
    """Source D: QEMU Simple OS — screenshot via QMP screendump.

    Requires a running QEMU instance exposing a QMP socket. The socket path
    and output path are conventional defaults; override via env vars is left
    as a follow-up (TODO phase-4).
    """
    # TODO(phase-4): parameterize QMP socket path via CLI/env. Today we use
    # the QEMU runner's default socket location.
    val qmp_socket = "/tmp/simple_os_qmp.sock"
    val out_path = "/tmp/wm_compare_qemu_{scene.name}.ppm"
    capture_qemu_vm(qmp_socket, out_path)

# ============================================================================
# Baseline I/O
# ============================================================================

fn _write_ppm_local(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    """Local PPM P6 writer that sidesteps the interpreter i64 bug.

    `export_comparison_ppm` calls `((pixel >> 16) & 0xFF).to_u8()` which
    fails in the interpreter because the bitwise-and with an int literal
    is typed as i64 and `.to_u8()` is not defined on i64 in the interpreter
    runtime. Here we use `as u8` which the interpreter accepts for i64.
    """
    if pixels.len() == 0 or width <= 0 or height <= 0:
        return false

    val header = "P6\n{width} {height}\n255\n"
    var data: [u8] = []
    for ch in header:
        data = data + [ch as u8]

    var i = 0
    val n = pixels.len()
    while i < n:
        val p = pixels[i]
        val r_byte: u8 = ((p >> 16) & 0xFF) as u8
        val g_byte: u8 = ((p >> 8) & 0xFF) as u8
        val b_byte: u8 = (p & 0xFF) as u8
        data = data + [r_byte, g_byte, b_byte]
        i = i + 1

    file_write_bytes(path, data)
    true

fn write_baseline(result: CaptureResult, scene_name: text, source: text) -> bool:
    """Write a capture result to disk as a PPM P6 baseline."""
    val dir = baseline_dir(scene_name)
    dir_create_all(dir)
    val path = baseline_ppm_path(scene_name, source)
    _write_ppm_local(result.pixels, result.width, result.height, path)

fn read_baseline(scene_name: text, source: text) -> CaptureResult:
    """Read a PPM baseline from disk into a CaptureResult."""
    val path = baseline_ppm_path(scene_name, source)
    val bytes = file_read_bytes(path)
    if bytes.len() == 0:
        return capture_error(source, 0, 0, "Missing baseline: {path}")
    val decode = decode_ppm_to_argb(bytes)
    match decode:
        case Ok(img):
            return CaptureResult(
                pixels: img.pixels,
                width: img.width,
                height: img.height,
                backend_name: source,
                success: true,
                error: ""
            )
        case Err(msg):
            return capture_error(source, 0, 0, "PPM decode failed: {msg}")

# ============================================================================
# Compare
# ============================================================================

struct CompareSummary:
    """Summary of one pairwise compare (src_a vs src_b)."""
    src_a: text
    src_b: text
    exact_match: bool
    match_percentage: i64        # 0-10000
    perceptual_percentage: i64   # 0-10000
    different_pixels: i64
    max_channel_diff: i32
    max_r_diff: i32
    max_g_diff: i32
    max_b_diff: i32
    max_a_diff: i32
    diff_ppm: text               # "" if not written

fn compare_pair(src_a: text, src_b: text,
                a: CaptureResult, b: CaptureResult,
                scene_name: text, profile: ToleranceProfile) -> CompareSummary:
    """Compare two captures: exact-first, fall through to perceptual, dump diff."""
    if not a.success or not b.success:
        return CompareSummary(
            src_a: src_a, src_b: src_b,
            exact_match: false,
            match_percentage: 0,
            perceptual_percentage: 0,
            different_pixels: 0,
            max_channel_diff: 0,
            max_r_diff: 0, max_g_diff: 0, max_b_diff: 0, max_a_diff: 0,
            diff_ppm: ""
        )

    val w = a.width
    val h = a.height
    val overall = compare_exact(a.pixels, b.pixels, w, h)
    val exact = overall.different_pixels == 0

    # Memcmp-equivalent shortcut: if exact, skip perceptual + per-channel.
    if exact:
        return CompareSummary(
            src_a: src_a, src_b: src_b,
            exact_match: true,
            match_percentage: 10000,
            perceptual_percentage: 10000,
            different_pixels: 0,
            max_channel_diff: 0,
            max_r_diff: 0, max_g_diff: 0, max_b_diff: 0, max_a_diff: 0,
            diff_ppm: ""
        )

    val perc = compare_perceptual(
        a.pixels, b.pixels, w, h,
        profile.default_yiq_threshold, true)
    val channels = compare_per_channel(a.pixels, b.pixels, w, h, 0)

    var r_max: i32 = 0
    var g_max: i32 = 0
    var b_max: i32 = 0
    var a_max: i32 = 0
    for ch in channels:
        if ch.channel == "R": r_max = ch.max_diff
        if ch.channel == "G": g_max = ch.max_diff
        if ch.channel == "B": b_max = ch.max_diff
        if ch.channel == "A": a_max = ch.max_diff

    # Dump diff heat-map
    val diff_path = diff_ppm_path(scene_name, src_a, src_b)
    dir_create_all(baseline_dir(scene_name))
    use os.compositor.screenshot_compare.{generate_diff_image}
    val diff_pixels = generate_diff_image(a.pixels, b.pixels, w, h)
    export_comparison_ppm(diff_pixels, w, h, diff_path)

    CompareSummary(
        src_a: src_a, src_b: src_b,
        exact_match: false,
        match_percentage: overall.match_percentage,
        perceptual_percentage: perc.match_percentage,
        different_pixels: overall.different_pixels,
        max_channel_diff: overall.max_channel_diff,
        max_r_diff: r_max, max_g_diff: g_max, max_b_diff: b_max, max_a_diff: a_max,
        diff_ppm: diff_path
    )

# ============================================================================
# Report
# ============================================================================

fn _bool_text(b: bool) -> text:
    if b: "true" else: "false"

fn write_report(scene_name: text, tolerance: text,
                captures: [CaptureResult],
                compares: [CompareSummary]) -> bool:
    """Write a minimal SDN report for the run."""
    var body = "(wm_compare_report\n"
    body = body + "  scene: {scene_name}\n"
    body = body + "  tolerance: {tolerance}\n"
    body = body + "  captures: [\n"
    for cap in captures:
        body = body + "    (capture backend: {cap.backend_name} success: {_bool_text(cap.success)}"
        body = body + " width: {cap.width} height: {cap.height}"
        body = body + " pixel_count: {cap.pixels.len()}"
        body = body + " error: \"{cap.error}\")\n"
    body = body + "  ]\n"
    body = body + "  compares: [\n"
    for c in compares:
        body = body + "    (compare a: {c.src_a} b: {c.src_b}"
        body = body + " exact: {_bool_text(c.exact_match)}"
        body = body + " match_pct_10000: {c.match_percentage}"
        body = body + " perceptual_pct_10000: {c.perceptual_percentage}"
        body = body + " different_pixels: {c.different_pixels}"
        body = body + " max_ch: {c.max_channel_diff}"
        body = body + " max_r: {c.max_r_diff} max_g: {c.max_g_diff}"
        body = body + " max_b: {c.max_b_diff} max_a: {c.max_a_diff}"
        body = body + " diff_ppm: \"{c.diff_ppm}\")\n"
    body = body + "  ]\n"
    body = body + ")\n"

    dir_create_all(baseline_dir(scene_name))
    file_write_text(report_sdn_path(scene_name), body)

# ============================================================================
# Entry Point
# ============================================================================

# ============================================================================
# Phase 5 — Bit-level compare of two existing PPM files
# ============================================================================

fn _skip_ppm_ws_and_comments(data: [u8], start: i32) -> i32:
    """Skip whitespace and '#'-delimited comment lines."""
    var i = start
    val n: i32 = data.len() as i32
    while i < n:
        val c = data[i]
        if c == 32 or c == 9 or c == 10 or c == 13:
            i = i + 1
        elif c == 35:
            # comment until newline
            while i < n and data[i] != 10:
                i = i + 1
        else:
            return i
    i

fn _parse_ppm_int(data: [u8], start: i32) -> (i32, i32):
    """Parse a decimal integer. Returns (value, new_pos)."""
    var pos = start
    val n: i32 = data.len() as i32
    var val_i: i32 = 0
    while pos < n and data[pos] >= 48 and data[pos] <= 57:
        val d: i32 = (data[pos] - 48) as i32
        val_i = val_i * 10 + d
        pos = pos + 1
    (val_i, pos)

fn _parse_ppm_header(data: [u8]) -> (bool, i32, i32, i32, text):
    """Parse a P6 header. Returns (ok, w, h, body_offset, err)."""
    val n_i64 = data.len()
    val n: i32 = n_i64 as i32
    if n < 11:
        return (false, 0, 0, 0, "ppm too short")
    if data[0] != 80 or data[1] != 54:
        return (false, 0, 0, 0, "not a P6 ppm")

    var pos: i32 = 2
    pos = _skip_ppm_ws_and_comments(data, pos)
    val (w, pos_after_w) = _parse_ppm_int(data, pos)
    pos = pos_after_w
    pos = _skip_ppm_ws_and_comments(data, pos)
    val (h, pos_after_h) = _parse_ppm_int(data, pos)
    pos = pos_after_h
    pos = _skip_ppm_ws_and_comments(data, pos)
    val (maxval, pos_after_mv) = _parse_ppm_int(data, pos)
    pos = pos_after_mv
    if w <= 0 or h <= 0:
        return (false, 0, 0, 0, "invalid dims")
    if maxval != 255:
        return (false, 0, 0, 0, "unsupported maxval")
    if pos < n and (data[pos] == 10 or data[pos] == 13 or data[pos] == 32 or data[pos] == 9):
        pos = pos + 1
    (true, w, h, pos, "")

fn _decode_ppm_region(data: [u8], w: i32, h: i32, body_off: i32,
                      crop_w: i32, crop_h: i32) -> [u32]:
    """Decode the top-left crop_w x crop_h region of a P6 PPM body to ARGB.

    Returns a flat [u32] of length crop_w*crop_h. The image is assumed to have
    row stride `w` in pixels (3*w bytes). No bounds checks beyond the crop.
    """
    var pixels: [u32] = []
    var y = 0
    while y < crop_h:
        val row_off = body_off + (y * w * 3)
        var x = 0
        while x < crop_w:
            val p = row_off + (x * 3)
            val r: u32 = data[p] as u32
            val g: u32 = data[p + 1] as u32
            val b: u32 = data[p + 2] as u32
            val argb: u32 = 0xFF000000 | (r << 16) | (g << 8) | b
            pixels = pixels + [argb]
            x = x + 1
        y = y + 1
    pixels

fn _decode_ppm_local(data: [u8]) -> (bool, [u32], i32, i32, text):
    """Decode a full P6 PPM to ARGB [u32]. Returns (ok, pixels, w, h, err).

    Replacement for `decode_ppm_to_argb` which fails at runtime because
    `ppm_decode.spl` references an undefined `Pair` constructor.
    """
    val (hdr_ok, w, h, body_off, err) = _parse_ppm_header(data)
    if not hdr_ok:
        return (false, [], 0, 0, err)
    val pixels = _decode_ppm_region(data, w, h, body_off, w, h)
    (true, pixels, w, h, "")

struct PpmHandle:
    """A PPM file's raw bytes + parsed header. Lets callers decide how much
    to materialize (full image or a crop) without paying O(N^2) list-append
    cost up front."""
    data: [u8]
    width: i32
    height: i32
    body_off: i32
    label: text
    ok: bool
    error: text

fn _load_ppm_handle(path: text, label: text) -> PpmHandle:
    """Read a PPM file and parse its header without decoding pixel data."""
    val data_opt = file_read_bytes(path)
    var bytes: [u8] = []
    match data_opt:
        case Some(b): bytes = b
        case nil:
            return PpmHandle(data: [], width: 0, height: 0, body_off: 0,
                             label: label, ok: false, error: "Missing PPM: {path}")
    if bytes.len() == 0:
        return PpmHandle(data: [], width: 0, height: 0, body_off: 0,
                         label: label, ok: false, error: "Empty PPM: {path}")
    val (hdr_ok, w, h, off, err) = _parse_ppm_header(bytes)
    if not hdr_ok:
        return PpmHandle(data: bytes, width: 0, height: 0, body_off: 0,
                         label: label, ok: false, error: "PPM header parse failed: {err}")
    PpmHandle(data: bytes, width: w, height: h, body_off: off,
              label: label, ok: true, error: "")

fn run_bit_compare_mode(opts: CliOpts) -> i64:
    """Phase 5 harness entry: bit-level compare of two existing PPM files.

    Loads the PPMs named by --source-a/--source-b, runs compare_exact on the
    overlapping prefix, per-channel and perceptual deltas (flagged as
    structurally invalid when dimensions differ), writes a diff PPM and an
    SDN report under --out-dir.
    """
    if opts.source_a_path == "" or opts.source_b_path == "":
        print "Error: --mode=bit-compare requires --source-a=<path> and --source-b=<path>"
        return 1
    val out_dir = if opts.out_dir != "": opts.out_dir else: "test/baselines/wm_compare/phase5"
    dir_create_all(out_dir)

    print "[wm_compare] Bit-compare mode"
    print "[wm_compare]   source A: {opts.source_a_path}"
    print "[wm_compare]   source B: {opts.source_b_path}"
    print "[wm_compare]   out dir:  {out_dir}"

    val ha = _load_ppm_handle(opts.source_a_path, "A")
    val hb = _load_ppm_handle(opts.source_b_path, "B")
    if not ha.ok:
        print "[wm_compare]   FAIL: {ha.error}"
        return 1
    if not hb.ok:
        print "[wm_compare]   FAIL: {hb.error}"
        return 1

    print "[wm_compare]   A header: {ha.width}x{ha.height}"
    print "[wm_compare]   B header: {hb.width}x{hb.height}"

    val dims_match = (ha.width == hb.width) and (ha.height == hb.height)
    if not dims_match:
        print "[wm_compare]   WARNING: dimensions differ — all numeric results are"
        print "[wm_compare]            structurally invalid. Diff is row-aligned over"
        print "[wm_compare]            the overlapping top-left rectangle only."

    # Decode only the overlapping top-left region of each image. This is
    # meaningful regardless of stride mismatch (unlike a flat memcmp) and
    # keeps the interpreter's O(N^2) list-append cost bounded.
    val overall_w = if ha.width < hb.width: ha.width else: hb.width
    val overall_h = if ha.height < hb.height: ha.height else: hb.height
    print "[wm_compare]   decoding overlap region {overall_w}x{overall_h}..."
    val pixels_a = _decode_ppm_region(ha.data, ha.width, ha.height, ha.body_off, overall_w, overall_h)
    val pixels_b = _decode_ppm_region(hb.data, hb.width, hb.height, hb.body_off, overall_w, overall_h)
    print "[wm_compare]   decoded A={pixels_a.len()} px, B={pixels_b.len()} px"

    val exact_res = compare_exact(pixels_a, pixels_b, overall_w, overall_h)
    val exact_match = exact_res.different_pixels == 0

    val profile = profile_strict()
    val perc = compare_perceptual(
        pixels_a, pixels_b, overall_w, overall_h,
        profile.default_yiq_threshold, true)
    val channels = compare_per_channel(
        pixels_a, pixels_b, overall_w, overall_h, 0)
    var r_max: i32 = 0
    var g_max: i32 = 0
    var b_max: i32 = 0
    var a_max: i32 = 0
    for ch in channels:
        if ch.channel == "R": r_max = ch.max_diff
        if ch.channel == "G": g_max = ch.max_diff
        if ch.channel == "B": b_max = ch.max_diff
        if ch.channel == "A": a_max = ch.max_diff

    # Diff heat-map over the overlapping top-left rectangle (both buffers
    # already cropped to overall_w x overall_h).
    use os.compositor.screenshot_compare.{generate_diff_image}
    val diff_pixels = generate_diff_image(pixels_a, pixels_b, overall_w, overall_h)
    val diff_path = "{out_dir}/B_vs_D_diff.ppm"
    _write_ppm_local(diff_pixels, overall_w, overall_h, diff_path)
    print "[wm_compare]   diff heat-map: {diff_path}"

    # Report SDN
    var body = "(wm_compare_phase5_report\n"
    body = body + "  mode: bit-compare\n"
    body = body + "  source_a_path: \"{opts.source_a_path}\"\n"
    body = body + "  source_b_path: \"{opts.source_b_path}\"\n"
    body = body + "  a_width: {ha.width}\n"
    body = body + "  a_height: {ha.height}\n"
    body = body + "  a_pixels_total: {ha.width * ha.height}\n"
    body = body + "  b_width: {hb.width}\n"
    body = body + "  b_height: {hb.height}\n"
    body = body + "  b_pixels_total: {hb.width * hb.height}\n"
    body = body + "  overlap_width: {overall_w}\n"
    body = body + "  overlap_height: {overall_h}\n"
    body = body + "  dimensions_match: {_bool_text(dims_match)}\n"
    body = body + "  structurally_valid: {_bool_text(dims_match)}\n"
    body = body + "  exact_match: {_bool_text(exact_match)}\n"
    body = body + "  differing_pixels: {exact_res.different_pixels}\n"
    body = body + "  matching_pixels: {exact_res.matching_pixels}\n"
    body = body + "  total_pixels: {exact_res.total_pixels}\n"
    body = body + "  match_percentage_10000: {exact_res.match_percentage}\n"
    body = body + "  max_channel_diff: {exact_res.max_channel_diff}\n"
    body = body + "  max_r_diff: {r_max}\n"
    body = body + "  max_g_diff: {g_max}\n"
    body = body + "  max_b_diff: {b_max}\n"
    body = body + "  max_a_diff: {a_max}\n"
    body = body + "  perceptual_match_percentage_10000: {perc.match_percentage}\n"
    body = body + "  tolerance_profile: strict\n"
    body = body + "  diff_ppm: \"{diff_path}\"\n"
    body = body + "  diff_width: {overall_w}\n"
    body = body + "  diff_height: {overall_h}\n"
    body = body + "  note: \"Phase 5 bit-compare. B_live is Web WM glass-theme four_windows scene at 320x240; D is Engine2D verification scene (3 hardcoded rects via rt_gui_fill4) at 1024x768. Different scenes, different resolutions, different rasterizers. ~100% divergence is expected and does not indicate a pipeline regression.\"\n"
    body = body + ")\n"

    val report_path = "{out_dir}/report.sdn"
    file_write_text(report_path, body)
    print "[wm_compare]   report: {report_path}"

    if exact_match:
        print "[wm_compare] EXACT MATCH"
        return 0
    else:
        val pct_w = exact_res.match_percentage / 100
        val pct_f = exact_res.match_percentage % 100
        print "[wm_compare] NOT EXACT: {exact_res.different_pixels} px differ ({pct_w}.{pct_f}% match)"
        print "[wm_compare] perceptual match: {perc.match_percentage / 100}.{perc.match_percentage % 100}%"
        print "[wm_compare] (Phase 5 expected outcome — see report note.)"
        return 0

fn _count_region_diffs(a: [u32], b: [u32], full_w: i32, full_h: i32,
                       rx: i32, ry: i32, rw: i32, rh: i32) -> (i64, i32):
    """Count pixels that differ inside rect (rx,ry,rw,rh) of full_w x full_h
    buffers. Returns (differing_pixels, max_channel_diff). Buffers must be
    identically sized to full_w*full_h."""
    var diff: i64 = 0
    var max_ch: i32 = 0
    val n: i32 = (a.len() as i32)
    val nb: i32 = (b.len() as i32)
    val y0 = if ry < 0: 0 else: ry
    val x0 = if rx < 0: 0 else: rx
    val y1 = if ry + rh > full_h: full_h else: ry + rh
    val x1 = if rx + rw > full_w: full_w else: rx + rw
    var y = y0
    while y < y1:
        var x = x0
        while x < x1:
            val idx = y * full_w + x
            if idx < n and idx < nb:
                val pa = a[idx]
                val pb = b[idx]
                if pa != pb:
                    diff = diff + 1
                    val ra: i32 = ((pa >> 16) & 0xFF) as i32
                    val ga: i32 = ((pa >> 8) & 0xFF) as i32
                    val ba: i32 = (pa & 0xFF) as i32
                    val rb_: i32 = ((pb >> 16) & 0xFF) as i32
                    val gb_: i32 = ((pb >> 8) & 0xFF) as i32
                    val bb_: i32 = (pb & 0xFF) as i32
                    val dr = abs_i32_local(ra - rb_)
                    val dg = abs_i32_local(ga - gb_)
                    val db = abs_i32_local(ba - bb_)
                    val m = if dr > dg: dr else: dg
                    val m2 = if m > db: m else: db
                    if m2 > max_ch:
                        max_ch = m2
            x = x + 1
        y = y + 1
    (diff, max_ch)

fn abs_i32_local(x: i32) -> i32:
    if x < 0: -x else: x

fn _rescale_to(pixels: [u32], src_w: i32, src_h: i32,
               dst_w: i32, dst_h: i32) -> [u32]:
    """Nearest-neighbor downsample/upsample src buffer to dst_w x dst_h.
    If dims already match, returns the input unchanged."""
    if src_w == dst_w and src_h == dst_h:
        return pixels
    var out: [u32] = []
    var y = 0
    while y < dst_h:
        val sy = (y * src_h) / dst_h
        var x = 0
        while x < dst_w:
            val sx = (x * src_w) / dst_w
            val idx = sy * src_w + sx
            if idx < (pixels.len() as i32):
                out = out + [pixels[idx]]
            else:
                out = out + [0xFF000000 as u32]
            x = x + 1
        y = y + 1
    out

fn run_live_bd_compare_mode(opts: CliOpts) -> i64:
    """Phase 5 live harness: capture B (host WM) and D (QEMU) in-process
    and perform a bit-level compare. Narrows divergence to known regions
    (title bar, body, traffic lights) if exact match fails and writes
    findings to doc/08_tracking/wm_compare/divergence.md.

    Exit codes:
      0  success (exact match or report written)
      1  argument/config error
      2  infrastructure unavailable (QMP socket missing)
    """
    val scene_name = if opts.scene != "": opts.scene else: "four_windows"
    val width = opts.width
    val height = opts.height
    val qmp_sock = if opts.qmp_socket != "":
                       opts.qmp_socket
                   else:
                       "/tmp/simpleos_engine2d_qmp.sock"
    val out_dir = if opts.out_dir != "":
                      opts.out_dir
                  else:
                      "test/baselines/wm_compare/{scene_name}"
    dir_create_all(out_dir)

    print "[wm_compare] Phase 5 live B vs D bit-compare"
    print "[wm_compare]   scene:     {scene_name}"
    print "[wm_compare]   size:      {width}x{height}"
    print "[wm_compare]   qmp sock:  {qmp_sock}"
    print "[wm_compare]   out dir:   {out_dir}"

    # Resolve scene
    val entry_opt = resolve_scene(scene_name, width, height)
    if entry_opt == nil:
        print "[wm_compare]   FAIL: unknown scene '{scene_name}'"
        return 1
    val entry = entry_opt

    # ----- Source B capture (in-process) -----
    print "[wm_compare] Capturing source B (host Simple WM, in-process)..."
    val cap_b = capture_source_b(entry, width, height)
    if not cap_b.success:
        print "[wm_compare]   FAIL: source B: {cap_b.error}"
        return 1
    print "[wm_compare]   B ok  {cap_b.width}x{cap_b.height} pixels={cap_b.pixels.len()}"

    # ----- Source D capture (QEMU via QMP) -----
    if not file_exists(qmp_sock):
        print ""
        print "[wm_compare] INFRA UNAVAILABLE: QMP socket '{qmp_sock}' not found."
        print "[wm_compare] Phase 5 requires a live QEMU Simple OS guest running with"
        print "[wm_compare] -qmp unix:{qmp_sock},server,nowait and the Engine2D GUI entry."
        print ""
        print "[wm_compare] To spawn the guest:"
        print "[wm_compare]   1. Build kernel:  bin/simple test test/system/engine2d_in_qemu_spec.spl"
        print "[wm_compare]      (first `it` block builds gui_entry_engine2d.spl)"
        print "[wm_compare]   2. Boot in background with a QMP socket:"
        print "[wm_compare]      qemu-system-x86_64 -machine q35 -cpu qemu64 -m 2G \\"
        print "[wm_compare]         -kernel build/os/simpleos_engine2d_x86_64.elf \\"
        print "[wm_compare]         -vga std -qmp unix:{qmp_sock},server,nowait &"
        print "[wm_compare]   3. Re-run this command."
        print ""
        print "[wm_compare] Exiting with code 2 (infra unavailable, not a failure)."
        return 2

    print "[wm_compare] Capturing source D (QEMU Simple OS via QMP)..."
    val cap_d = capture_qemu_vm(qmp_sock, "{out_dir}/D_raw.ppm")
    if not cap_d.success:
        print "[wm_compare]   FAIL: source D: {cap_d.error}"
        return 1
    print "[wm_compare]   D ok  {cap_d.width}x{cap_d.height} pixels={cap_d.pixels.len()}"

    # Align D to (width, height) if guest framebuffer is a different size.
    var pixels_d: [u32] = cap_d.pixels
    if cap_d.width != width or cap_d.height != height:
        print "[wm_compare]   D dimensions differ — nearest-neighbor resample to {width}x{height}"
        pixels_d = _rescale_to(cap_d.pixels, cap_d.width, cap_d.height, width, height)

    # ----- Full-frame compare -----
    val profile = profile_strict()
    val full = compare_pixel_buffers(cap_b.pixels, pixels_d, width, height, 0)
    val exact = full.different_pixels == 0
    if exact:
        print "[wm_compare] Phase 5 PASS: byte-identical ({width}x{height})"
        return 0

    print "[wm_compare] NOT byte-identical: {full.different_pixels} px differ"
    print "[wm_compare]   match pct (10000): {full.match_percentage}"
    print "[wm_compare]   max channel diff:  {full.max_channel_diff}"

    # Heat-map dump
    dir_create_all(out_dir)
    val diff_img = generate_diff_image(cap_b.pixels, pixels_d, width, height)
    val diff_path = "{out_dir}/bit_diff_B_vs_D.ppm"
    export_comparison_ppm(diff_img, width, height, diff_path)
    print "[wm_compare]   heat-map: {diff_path}"

    # Find diff regions (auto-clustered)
    val regions = find_diff_regions(cap_b.pixels, pixels_d, width, height, 0)
    print "[wm_compare]   auto-detected diff regions: {regions.len()}"

    # Narrow to named sub-regions: title bar (top 30 rows), body (below),
    # traffic lights (top-left 60x30). Counts are over the full frame.
    val title_h: i32 = 30
    val (title_diff, title_max) = _count_region_diffs(
        cap_b.pixels, pixels_d, width, height, 0, 0, width, title_h)
    val (body_diff, body_max) = _count_region_diffs(
        cap_b.pixels, pixels_d, width, height, 0, title_h, width, height - title_h)
    val (tl_diff, tl_max) = _count_region_diffs(
        cap_b.pixels, pixels_d, width, height, 0, 0, 60, 30)

    print "[wm_compare]   title-bar region (0,0 {width}x{title_h}): {title_diff} diff, max ch {title_max}"
    print "[wm_compare]   body region       (0,{title_h} {width}x{height - title_h}): {body_diff} diff, max ch {body_max}"
    print "[wm_compare]   traffic-lights    (0,0 60x30):         {tl_diff} diff, max ch {tl_max}"

    # Write findings md
    val md_dir = "doc/08_tracking/wm_compare"
    dir_create_all(md_dir)
    val md_path = "{md_dir}/divergence.md"
    var md = "# WM Compare Phase 5 — B vs D Divergence\n\n"
    md = md + "Generated by `src/app/wm_compare/main.spl --mode=live_bd_compare`.\n\n"
    md = md + "## Scene\n\n"
    md = md + "- Name: `{scene_name}`\n"
    md = md + "- Size: {width}x{height}\n\n"
    md = md + "## Sources\n\n"
    md = md + "- **B**: host Simple WM (in-process `capture_source_b`, backend `{cap_b.backend_name}`)\n"
    md = md + "- **D**: QEMU Simple OS via QMP socket `{qmp_sock}`\n"
    md = md + "    - native framebuffer: {cap_d.width}x{cap_d.height}\n"
    md = md + "    - resampled: {_bool_text(cap_d.width != width or cap_d.height != height)}\n\n"
    md = md + "## Full-frame\n\n"
    md = md + "- Differing pixels: {full.different_pixels}\n"
    md = md + "- Match % (x10000): {full.match_percentage}\n"
    md = md + "- Max channel diff: {full.max_channel_diff}\n"
    md = md + "- Auto-detected diff clusters: {regions.len()}\n"
    md = md + "- Heat-map PPM: `{diff_path}`\n\n"
    md = md + "## Per-region pixel deltas\n\n"
    md = md + "| Region        | Rect                  | Diff px | Max ch diff |\n"
    md = md + "|---------------|-----------------------|---------|-------------|\n"
    md = md + "| title bar     | (0,0 {width}x{title_h})    | {title_diff} | {title_max} |\n"
    md = md + "| body          | (0,{title_h} {width}x{height - title_h}) | {body_diff} | {body_max} |\n"
    md = md + "| traffic lights| (0,0 60x30)           | {tl_diff} | {tl_max} |\n\n"
    md = md + "## Recommended next step\n\n"
    if full.max_channel_diff <= 2:
        md = md + "Max per-channel delta <= 2 LSB. Consider promoting to a `bit_tolerant` "
        md = md + "profile in `tolerance_profile.spl` and gating on that instead of strict.\n"
    elif title_diff == 0 and body_diff > 0:
        md = md + "Title bar matches byte-for-byte; divergence is in the body. Inspect the "
        md = md + "body rasterizer path (likely text / glass effects).\n"
    elif title_diff > 0 and body_diff == 0:
        md = md + "Body matches; divergence is in the title bar. Inspect decoration/traffic-light "
        md = md + "code paths in `src/os/compositor/decorations.spl`.\n"
    else:
        md = md + "Divergence spans both regions. Start by diffing the raw scene element "
        md = md + "list vs the guest Engine2D verification scene to ensure they are rendering "
        md = md + "the same scene, not different scenes.\n"

    file_write_text(md_path, md)
    print "[wm_compare]   findings: {md_path}"
    return 0

fn capture_one(source: text, scene: SceneEntry, width: i32, height: i32) -> CaptureResult:
    """Dispatch a single-source capture."""
    if source == "A":
        return capture_source_a(scene, width, height)
    if source == "B":
        return capture_source_b(scene, width, height)
    if source == "D":
        return capture_source_d(scene, width, height)
    capture_error(source, width, height, "Unknown source: {source}")

fn run_capture_phase(sources: [text], scene: SceneEntry,
                     width: i32, height: i32,
                     update_baseline: bool) -> [CaptureResult]:
    """Capture each requested source. If update_baseline, overwrite PPMs."""
    var results: [CaptureResult] = []
    for src in sources:
        print "[wm_compare] Capturing source {src} for scene '{scene.name}'..."
        val r = capture_one(src, scene, width, height)
        if r.success:
            print "[wm_compare]   ok  width={r.width} height={r.height} pixels={r.pixels.len()}"
            if update_baseline:
                val ok = write_baseline(r, scene.name, src)
                if ok:
                    print "[wm_compare]   wrote baseline: {baseline_ppm_path(scene.name, src)}"
                else:
                    print "[wm_compare]   FAILED to write baseline"
        else:
            print "[wm_compare]   fail reason: {r.error}"
        results = results + [r]
    results

fn sources_for_option(source_opt: text) -> [text]:
    """Expand --source=all into [A,B,D], otherwise return a single-element list."""
    if source_opt == "all":
        return ["A", "B", "D"]
    [source_opt]

fn main() -> i64:
    val args = get_cli_args()
    val opts = parse_opts(args)

    if opts.help:
        print_help()
        return 0

    # Phase 5 bit-compare mode is a separate branch that only needs two PPM
    # paths — it does not require --source or --scene to be set.
    if opts.mode == "bit-compare":
        return run_bit_compare_mode(opts)

    # Phase 5 live B vs D bit-level compare — in-process captures both
    # sources and runs the compare pipeline end-to-end. Requires a live
    # QEMU guest with a QMP socket (exits 2 with instructions if missing).
    if opts.mode == "live_bd_compare":
        return run_live_bd_compare_mode(opts)

    if opts.source == "":
        print "Error: --source=A|B|D|all is required"
        print_help()
        return 1

    if opts.scene == "":
        print "Error: --scene=<name> is required"
        print_help()
        return 1

    val entry_opt = resolve_scene(opts.scene, opts.width, opts.height)
    if entry_opt == nil:
        print "Error: unknown scene '{opts.scene}'"
        print "Registered scenes:"
        for name in list_scene_names():
            print "  {name}"
        return 1

    val entry = entry_opt
    val profile = resolve_tolerance(opts.tolerance)
    val sources = sources_for_option(opts.source)

    print "[wm_compare] Scene: {entry.name}  fixture: {entry.fixture_path}"
    print "[wm_compare] Size: {opts.width}x{opts.height}  tolerance: {profile.name}"
    if opts.mode != "":
        print "[wm_compare] Mode: {opts.mode}"

    # ------------------------------------------------------------------
    # Phase 1 live source-B path
    # ------------------------------------------------------------------
    # When --mode=live_b, bypass the offline pipeline entirely and capture
    # the running Web WM via Electron headless. Writes the PPM to
    # test/baselines/wm_compare/<scene>/B_live.ppm so the Phase 0 placeholder
    # baseline at B.ppm is preserved.
    if opts.mode == "live_b":
        if opts.source != "B":
            print "Error: --mode=live_b requires --source=B"
            return 1
        dir_create_all(baseline_dir(opts.scene))
        val out_path = "{baseline_dir(opts.scene)}/B_live.ppm"
        print "[wm_compare] Live capturing source B from localhost:3333..."
        val live = capture_live_source_b(opts.width, opts.height, out_path)
        if live.success:
            print "[wm_compare]   ok  width={live.width} height={live.height} bytes={live.ppm_bytes_len}"
            print "[wm_compare]   wrote: {live.out_path}"
            return 0
        else:
            print "[wm_compare]   FAIL: {live.error}"
            return 1

    val captures = run_capture_phase(
        sources, entry, opts.width, opts.height, opts.update_baseline)

    # Build an index source -> CaptureResult
    var compares: [CompareSummary] = []

    # Pairwise compare all successful captures
    var i = 0
    while i < captures.len():
        var j = i + 1
        while j < captures.len():
            val a = captures[i]
            val b = captures[j]
            val summary = compare_pair(
                sources[i], sources[j], a, b, entry.name, profile)
            compares = compares + [summary]
            if summary.exact_match:
                print "[wm_compare] {summary.src_a} vs {summary.src_b}: EXACT MATCH"
            else:
                val pct_w = summary.match_percentage / 100
                val pct_f = summary.match_percentage % 100
                print "[wm_compare] {summary.src_a} vs {summary.src_b}: {pct_w}.{pct_f}% exact, {summary.different_pixels} px differ, max ch diff {summary.max_channel_diff}"
                if summary.diff_ppm != "":
                    print "[wm_compare]   diff heat-map: {summary.diff_ppm}"
            j = j + 1
        i = i + 1

    # Always write a report SDN so the baseline tree is discoverable
    val report_ok = write_report(opts.scene, opts.tolerance, captures, compares)
    if report_ok:
        print "[wm_compare] Report: {report_sdn_path(opts.scene)}"

    # Exit code: 0 if all captures succeeded AND all compares passed or we
    # were just updating baselines.
    var all_ok = true
    for cap in captures:
        if not cap.success:
            all_ok = false
    if not opts.update_baseline:
        for c in compares:
            if not c.exact_match:
                all_ok = false

    if all_ok: 0 else: 1
