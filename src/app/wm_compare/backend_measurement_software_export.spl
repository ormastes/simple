# Software-only Simple Web render-loop measurement export.
#
# Keep this entrypoint narrow: it intentionally avoids backend_measurement_capture
# and CUDA/OpenCL/ROCm measurement modules so the pure software profile row does
# not pay GPU probe/import costs before the render loop starts.

use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_software_pixels, simple_web_layout_render_html_software_pixels_traced}
use std.gc_async_mut.gpu.browser_engine.simple_web_layout_engine2d_cpu.{simple_web_render_html_to_pixels_with_cpu_draw_ir_backend}
use std.nogc_sync_mut.gpu.engine2d.simd_provider.{reset_simd_hits, simd_hit_counts}
use std.nogc_sync_mut.gpu.engine2d.simd_native_rows.{engine2d_simd_native_hits, engine2d_simd_native_reset}
use std.nogc_sync_mut.io_runtime.{get_args}
use std.nogc_sync_mut.sffi.io.{file_write_text}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}

fn _sdn_escape(value: text) -> text:
    val slash_escaped = value.replace("\\", "\\\\")
    slash_escaped.replace("\"", "\\\"")

fn _bool_text(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _arg_value(args: [text], key: text, fallback: text) -> text:
    var i = 0
    while i + 1 < args.len():
        if args[i] == key:
            return args[i + 1]
        i = i + 1
    fallback

fn _arg_i64(args: [text], key: text, fallback: i64) -> i64:
    val raw = _arg_value(args, key, "")
    if raw == "":
        return fallback
    raw.parse_int() ?? fallback

fn _arg_i32(args: [text], key: text, fallback: i32) -> i32:
    val raw = _arg_value(args, key, "")
    if raw == "":
        return fallback
    val parsed = raw.parse_int() ?? fallback.to_i64()
    parsed.to_i32()

fn _arg_dpi_source(args: [text]) -> text:
    if _arg_value(args, "--dpi", "") == "":
        return "default"
    "override"

fn _arg_enabled(args: [text], key: text) -> bool:
    val raw = _arg_value(args, key, "")
    if raw == "1": return true
    if raw == "true": return true
    raw == "yes"

fn _positive_elapsed_us(start_us: i64) -> i64:
    val elapsed = time_now_micros() - start_us
    if elapsed <= 0:
        return 1
    elapsed

fn _positive_or_one(value: i64) -> i64:
    if value <= 0:
        return 1
    value

fn _sort_i64(values: [i64]) -> [i64]:
    var out = values
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j] < out[i]:
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn _percentile_nearest_rank(sorted: [i64], pct: i32) -> i64:
    if sorted.len() == 0:
        return 0
    var rank = ((sorted.len() * pct + 99) / 100) - 1
    if rank < 0:
        rank = 0
    if rank >= sorted.len():
        rank = sorted.len() - 1
    sorted[rank]

fn _sample_html(fixture_id: text) -> text:
    if fixture_id == "gui-perf-cpu-base-solid":
        return "<html><body style='margin:0;background:#102030'></body></html>"
    "<html><head><title>GUI Perf</title><style>body{background:#102030;color:#f8fafc} .panel{padding:12px;border:1px solid #38bdf8}</style></head><body><main class='panel'><h1>Simple GUI Perf</h1><p>" + fixture_id + "</p><button>Render</button><section><h2>Text lane</h2><p>abcdefghijklmnopqrstuvwxyz 0123456789</p></section></main></body></html>"

fn _is_supported_software_backend(backend: text) -> bool:
    if backend == "software": return true
    if backend == "cpu": return true
    backend == "cpu_simd"

fn _render_software_pixels(html: text, width: i32, height: i32, backend: text) -> [u32]:
    simple_web_render_html_to_pixels_with_cpu_draw_ir_backend(html, width, height, backend)

fn _backend_family(backend: text) -> text:
    if backend == "cpu_simd":
        return "cpu_simd"
    "software"

fn _runtime_compute_target(backend: text) -> text:
    if backend == "cpu_simd":
        return "cpu_simd"
    "cpu_scalar"

fn _runtime_execution_path(backend: text) -> text:
    if backend == "cpu_simd":
        return "simple_web_layout_engine2d_cpu_simd"
    "simple_web_layout_software"

fn _runtime_status(backend: text, supported: bool) -> text:
    if supported:
        if backend == "cpu_simd":
            return "cpu-simd-render-loop-ready"
        return "cpu-scalar-baseline-ready"
    "unsupported-backend"

fn _checksum_u32_pixels(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = checksum + ((pixels[i] as i64) & 0xFFFFFFFF)
        i = i + 1
    checksum

fn _nonzero_pixels(pixels: [u32]) -> i64:
    var count: i64 = 0
    var i = 0
    while i < pixels.len():
        if (pixels[i] as i64) != 0:
            count = count + 1
        i = i + 1
    count

fn _scalar_baseline_p50_us(backend_family: text, p50: i64) -> i64:
    if backend_family == "software":
        return p50
    if backend_family == "cpu":
        return p50
    0

fn _native_simd_executed_text(native_simd_hits: i64) -> text:
    _bool_text(native_simd_hits > 0)

fn _software_sample_sdn(fixture_id: text, backend: text, supported_backend: bool, args: [text],
                        warmup_count: i32, sample_count: i32, p50: i64, p95: i64,
                        checksum_value: i64, proof_count: i64, simd_provider_hits: i64,
                        native_simd_hits: i64) -> text:
    _software_sample_sdn_values(fixture_id, backend, supported_backend,
        _arg_value(args, "--shell", "simple-web"),
        _arg_value(args, "--command", "software-render-loop"),
        _arg_value(args, "--host", "unknown"),
        _arg_value(args, "--operation-family", "text_blit"),
        _positive_or_one(_arg_i64(args, "--max-rss-kb", 0)),
        _positive_or_one(_arg_i64(args, "--binary-size-bytes", 0)),
        _positive_or_one(_arg_i64(args, "--baseline-binary-size-bytes", 0)),
        _positive_or_one(_arg_i64(args, "--package-size-bytes", 0)),
        warmup_count, sample_count, p50, p95, checksum_value, proof_count, simd_provider_hits, native_simd_hits)

fn _software_sample_sdn_values(fixture_id: text, backend: text, supported_backend: bool,
                               shell: text, command: text, host: text,
                               operation_family: text,
                               max_rss_kb: i64, binary_size_bytes: i64,
                               baseline_binary_size_bytes: i64, package_size_bytes: i64,
                               warmup_count: i32, sample_count: i32, p50: i64, p95: i64,
                               checksum_value: i64, proof_count: i64, simd_provider_hits: i64,
                               native_simd_hits: i64) -> text:
    val backend_family = _backend_family(backend)
    val selected_backend = if supported_backend: backend else: "software"
    val unavailable_reason = if supported_backend: "" else: "software-only exporter supports software|cpu|cpu_simd"
    val scalar_baseline_p50_us = _scalar_baseline_p50_us(backend_family, p50)
    "(backend_comparison_samples " +
        "sample_count: 1 " +
        "scalar_baseline_p50_us: " + scalar_baseline_p50_us.to_string() + " " +
        "backend_faster_than_scalar_count: 0 " +
        "backend_equal_to_scalar_count: 0 " +
        "backend_slower_than_scalar_count: 0 " +
        "offload_overhead_contained_count: 0 " +
        "offload_overhead_dominates_count: 0 " +
        "offload_useful_count: 0 " +
        "offload_faster_but_overhead_dominates_count: 0 " +
        "offload_break_even_count: 0 " +
        "offload_slower_communication_overhead_count: 0 " +
        "offload_slower_compute_bound_count: 0 " +
        "offload_missing_scalar_baseline_count: 0 " +
        "valid: " + _bool_text(supported_backend) + "\n" +
        "  (backend_comparison_sample " +
        "fixture_id: \"" + _sdn_escape(fixture_id) + "\" " +
        "backend_family: \"" + _sdn_escape(backend_family) + "\" " +
        "shell: \"" + _sdn_escape(shell) + "\" " +
        "requested: \"" + _sdn_escape(backend) + "\" " +
        "selected: \"" + _sdn_escape(selected_backend) + "\" " +
        "device_id: \"host-software\" " +
        "status: \"Initialized\" " +
        "command: \"" + _sdn_escape(command) + "\" " +
        "host: \"" + _sdn_escape(host) + "\" " +
        "warmup_count: " + warmup_count.to_string() + " " +
        "sample_count: " + sample_count.to_string() + " " +
        "cold_start_us: " + p50.to_string() + " " +
        "warm_start_us: " + p50.to_string() + " " +
        "p50_frame_us: " + p50.to_string() + " " +
        "p95_frame_us: " + p95.to_string() + " " +
        "p95_input_to_paint_us: " + p95.to_string() + " " +
        "max_rss_kb: " + max_rss_kb.to_string() + " " +
        "binary_size_bytes: " + binary_size_bytes.to_string() + " " +
        "baseline_binary_size_bytes: " + baseline_binary_size_bytes.to_string() + " " +
        "binary_size_delta_bytes: 0 " +
        "package_size_bytes: " + package_size_bytes.to_string() + " " +
        "artifact_build_us: 0 " +
        "artifact_load_us: 0 " +
        "artifact_submit_us: " + p50.to_string() + " " +
        "artifact_sync_us: 0 " +
        "artifact_readback_us: 0 " +
        "artifact_total_us: " + p50.to_string() + " " +
        "offload_overhead_verdict: \"not-gpu-offload\" " +
        "speed_verdict: \"missing-scalar-baseline\" " +
        "offload_efficiency_verdict: \"not-gpu-offload\" " +
        "render_readback_scope: \"software-render-loop\" " +
        "offload_tag_kind: \"@gpu\" " +
        "operation_family: \"" + _sdn_escape(operation_family) + "\" " +
        "generated_operation: \"\" " +
        "generated_entry_symbol: \"\" " +
        "generated_source_format: \"none\" " +
        "generated_binary_format: \"none\" " +
        "generated_artifact_path_suffix: \"\" " +
        "runtime_compute_target: \"" + _runtime_compute_target(backend) + "\" " +
        "runtime_execution_path: \"" + _runtime_execution_path(backend) + "\" " +
        "runtime_launch_api: \"RenderBackend\" " +
        "runtime_entry_symbol: \"RenderBackend.draw_text_or_text_blit\" " +
        "runtime_artifact_name: \"\" " +
        "runtime_status: \"" + _runtime_status(backend, supported_backend) + "\" " +
        "simd_provider_hits: " + simd_provider_hits.to_string() + " " +
        "native_simd_hits: " + native_simd_hits.to_string() + " " +
        "native_simd_executed: " + _native_simd_executed_text(native_simd_hits) + " " +
        "checksum: \"sum32:" + checksum_value.to_string() + "\" " +
        "pixel_proof: \"nonzero_pixels:" + proof_count.to_string() + "\" " +
        "scalar_baseline_compared: true " +
        "fallback_used: false " +
        "fallback_reason: \"\" " +
        "unavailable_reason: \"" + _sdn_escape(unavailable_reason) + "\")\n)"

pub fn software_only_render_loop_export_sdn(args: [text]) -> text:
    val width = _arg_i32(args, "--width", 64)
    val height = _arg_i32(args, "--height", 64)
    var dpi = _arg_i32(args, "--dpi", 300)
    if dpi <= 0:
        dpi = 300
    val warmup_count = _arg_i32(args, "--warmup-count", 0)
    val sample_count = _arg_i32(args, "--sample-count", 1)
    val backend = _arg_value(args, "--software-render-backend", "software")
    val fixture_id = _arg_value(args, "--fixture", "software-render-loop")
    val html = _sample_html(fixture_id)
    if _arg_enabled(args, "--trace-layout-stages"):
        val trace_start_us = time_now_micros()
        val trace_pixels = simple_web_layout_render_html_software_pixels_traced(html, width, height)
        val trace_elapsed_us = _positive_elapsed_us(trace_start_us)
        val trace_checksum = _checksum_u32_pixels(trace_pixels)
        val trace_nonzero = _nonzero_pixels(trace_pixels)
        return "gui_perf_layout_trace_total_us=" + trace_elapsed_us.to_string() + "\n" +
            "gui_perf_layout_trace_checksum=sum32:" + trace_checksum.to_string() + "\n" +
            "gui_perf_layout_trace_pixel_proof=nonzero_pixels:" + trace_nonzero.to_string() + "\n" +
            "gui_perf_benchmark_dpi=" + dpi.to_string() + "\n" +
            "gui_perf_benchmark_dpi_default=300\n" +
            "gui_perf_benchmark_dpi_source=" + _arg_dpi_source(args) + "\n" +
            "gui_perf_benchmark_density_profile=retina\n" +
            "gui_perf_benchmark_logical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
            "gui_perf_benchmark_physical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
            "gui_perf_benchmark_screen_size_reduced=false"
    val supported_backend = _is_supported_software_backend(backend)
    var warmup = 0
    if supported_backend:
        while warmup < warmup_count:
            _render_software_pixels(html, width, height, backend)
            warmup = warmup + 1
    var samples: [i64] = []
    var pixels: [u32] = []
    var i = 0
    reset_simd_hits()
    engine2d_simd_native_reset()
    if supported_backend:
        while i < sample_count:
            val start_us = time_now_micros()
            pixels = _render_software_pixels(html, width, height, backend)
            samples.push(_positive_elapsed_us(start_us))
            i = i + 1
    val hits = simd_hit_counts()
    val simd_provider_hits = hits.fill_hits + hits.copy_hits + hits.alpha_hits + hits.blit_hits + hits.scroll_hits
    val native_simd_hits = engine2d_simd_native_hits()
    val sorted = _sort_i64(samples)
    val p50 = _percentile_nearest_rank(sorted, 50)
    val p95 = _percentile_nearest_rank(sorted, 95)
    val checksum_value = _checksum_u32_pixels(pixels)
    val proof_count = _nonzero_pixels(pixels)
    val samples_sdn = _software_sample_sdn(fixture_id, backend, supported_backend, args,
        warmup_count, sample_count, p50, p95, checksum_value, proof_count, simd_provider_hits, native_simd_hits)
    samples_sdn + "\n" +
        "gui_perf_benchmark_dpi=" + dpi.to_string() + "\n" +
        "gui_perf_benchmark_dpi_default=300\n" +
        "gui_perf_benchmark_dpi_source=" + _arg_dpi_source(args) + "\n" +
        "gui_perf_benchmark_density_profile=retina\n" +
        "gui_perf_benchmark_logical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
        "gui_perf_benchmark_physical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
        "gui_perf_benchmark_simd_provider_hits=" + simd_provider_hits.to_string() + "\n" +
        "gui_perf_benchmark_native_simd_hits=" + native_simd_hits.to_string() + "\n" +
        "gui_perf_benchmark_native_simd_executed=" + _native_simd_executed_text(native_simd_hits) + "\n" +
        "gui_perf_benchmark_screen_size_reduced=false"

pub fn software_only_render_loop_export_values(backend: text, width: i32, height: i32,
                                               dpi_input: i32, dpi_source: text,
                                               warmup_count: i32, sample_count: i32,
                                               fixture_id: text, shell: text, command: text,
                                               host: text, binary_size_bytes: i64,
                                               baseline_binary_size_bytes: i64,
                                               package_size_bytes: i64) -> text:
    var dpi = dpi_input
    if dpi <= 0:
        dpi = 300
    val html = _sample_html(fixture_id)
    val supported_backend = _is_supported_software_backend(backend)
    var warmup = 0
    if supported_backend:
        while warmup < warmup_count:
            _render_software_pixels(html, width, height, backend)
            warmup = warmup + 1
    var samples: [i64] = []
    var pixels: [u32] = []
    var i = 0
    reset_simd_hits()
    engine2d_simd_native_reset()
    if supported_backend:
        while i < sample_count:
            val start_us = time_now_micros()
            pixels = _render_software_pixels(html, width, height, backend)
            samples.push(_positive_elapsed_us(start_us))
            i = i + 1
    val hits = simd_hit_counts()
    val simd_provider_hits = hits.fill_hits + hits.copy_hits + hits.alpha_hits + hits.blit_hits + hits.scroll_hits
    val native_simd_hits = engine2d_simd_native_hits()
    val sorted = _sort_i64(samples)
    val p50 = _percentile_nearest_rank(sorted, 50)
    val p95 = _percentile_nearest_rank(sorted, 95)
    val checksum_value = _checksum_u32_pixels(pixels)
    val proof_count = _nonzero_pixels(pixels)
    val samples_sdn = _software_sample_sdn_values(fixture_id, backend, supported_backend,
        shell, command, host, "text_blit", 1, _positive_or_one(binary_size_bytes),
        _positive_or_one(baseline_binary_size_bytes), _positive_or_one(package_size_bytes),
        warmup_count, sample_count, p50, p95, checksum_value, proof_count, simd_provider_hits, native_simd_hits)
    samples_sdn + "\n" +
        "gui_perf_benchmark_dpi=" + dpi.to_string() + "\n" +
        "gui_perf_benchmark_dpi_default=300\n" +
        "gui_perf_benchmark_dpi_source=" + dpi_source + "\n" +
        "gui_perf_benchmark_density_profile=retina\n" +
        "gui_perf_benchmark_logical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
        "gui_perf_benchmark_physical_pixels=" + width.to_string() + "x" + height.to_string() + "\n" +
        "gui_perf_benchmark_simd_provider_hits=" + simd_provider_hits.to_string() + "\n" +
        "gui_perf_benchmark_native_simd_hits=" + native_simd_hits.to_string() + "\n" +
        "gui_perf_benchmark_native_simd_executed=" + _native_simd_executed_text(native_simd_hits) + "\n" +
        "gui_perf_benchmark_screen_size_reduced=false"

fn main() -> i64:
    val args = get_args()
    val out_path = _arg_value(args, "--out", "")
    val sdn = software_only_render_loop_export_sdn(args)
    if out_path != "":
        if file_write_text(out_path, sdn):
            return 0
        print "failed to write normalized software backend measurement: " + out_path
        return 1
    print(sdn)
    0
