use std.common.json.parser.{json_parse}
use std.common.json.object_ops.{json_object_get}
use std.common.json.array_ops.{json_array_get, json_array_length}
use std.common.json.types.{json_to_number, json_to_string}
use app.wm_compare.structural_layout_report.{StructuralLayoutBox, structural_layout_box, StructuralLayoutReport, structural_box_layout_compare}

fn _json_text(value: any) -> text:
    val out = json_to_string(value)
    if out == nil:
        return ""
    out

fn _json_i32(value: any) -> i32:
    val out = json_to_number(value)
    if out == nil:
        return 0
    (out as i64) as i32

pub fn electron_geometry_json_to_boxes(json_text: text) -> [StructuralLayoutBox]:
    val parsed = json_parse(json_text)
    if parsed == nil:
        return []
    val items = json_object_get(parsed, "items")
    val count = json_array_length(items) as i32
    var boxes: [StructuralLayoutBox] = []
    var i: i32 = 0
    while i < count:
        val item = json_array_get(items, i)
        val label = _json_text(json_object_get(item, "label"))
        if label != "":
            boxes.push(structural_layout_box(
                label,
                _json_i32(json_object_get(item, "x")),
                _json_i32(json_object_get(item, "y")),
                _json_i32(json_object_get(item, "width")),
                _json_i32(json_object_get(item, "height")),
                _json_text(json_object_get(item, "text"))
            ))
        i = i + 1
    boxes

pub fn compare_electron_geometry_json(source_a: text, source_b: text,
                                      viewport_width: i32, viewport_height: i32,
                                      source_a_json: text, source_b_boxes: [StructuralLayoutBox],
                                      backend_evidence: text, pixel_link: text) -> StructuralLayoutReport:
    val source_a_boxes = electron_geometry_json_to_boxes(source_a_json)
    structural_box_layout_compare(
        source_a, source_b, viewport_width, viewport_height,
        source_a_boxes, source_b_boxes,
        backend_evidence, pixel_link
    )
