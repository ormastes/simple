pub struct SoftwareRenderLoopMeasurementOptions:
    backend: text
    operation_family: text
    fixture_id: text
    shell: text
    command: text
    host: text
    width: i64
    height: i64
    warmup_count: i32
    sample_count: i32
    max_rss_kb: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    package_size_bytes: i64

fn _field_after(line: text, key: text) -> text:
    val marker = key + "="
    val idx = line.index_of(marker)
    if idx == -1:
        return ""
    val rest = line.substring(idx + marker.len())
    var end = 0
    while end < rest.len():
        val c = rest.char_at(end)
        if c == " " or c == "\n" or c == "\t":
            break
        end = end + 1
    rest.substring(0, end)

fn _elapsed_seconds_to_us(value: text) -> i64:
    if value == "":
        return 0
    val dot = value.index_of(".")
    if dot == -1:
        return value.to_i64() * 1000000
    val seconds = value.substring(0, dot).to_i64()
    var frac = value.substring(dot + 1)
    while frac.len() < 6:
        frac = frac + "0"
    if frac.len() > 6:
        frac = frac.substring(0, 6)
    seconds * 1000000 + frac.to_i64()

fn _sort_i64(values: [i64]) -> [i64]:
    var out = values
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j] < out[i]:
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn _percentile_nearest_rank(sorted: [i64], pct: i32) -> i64:
    if sorted.len() == 0:
        return 0
    var idx = ((sorted.len() * pct) + 99) / 100
    if idx <= 0:
        idx = 1
    if idx > sorted.len():
        idx = sorted.len()
    sorted[idx - 1]

fn _positive_elapsed_us(start_us: i64) -> i64:
    val elapsed = time_now_micros() - start_us
    if elapsed <= 0:
        return 1
    elapsed

fn _positive_or_one(value: i64) -> i64:
    if value <= 0:
        return 1
    value

fn _software_render_loop_html(fixture_id: text) -> text:
    "<html><head><title>GUI Perf</title><style>body{background:#102030;color:#f8fafc} .panel{padding:12px;border:1px solid #38bdf8}</style></head><body><main class='panel'><h1>Simple GUI Perf</h1><p>" + fixture_id + "</p><button>Render</button><section><h2>Text lane</h2><p>abcdefghijklmnopqrstuvwxyz 0123456789</p></section></main></body></html>"

fn _checksum_u32_pixels(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = checksum + ((pixels[i] as i64) & 0xFFFFFFFF)
        i = i + 1
    checksum

fn _nonzero_pixels(pixels: [u32]) -> i64:
    var count: i64 = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] != 0u32:
            count = count + 1
        i = i + 1
    count

pub fn software_render_loop_measurement_sample(opts: SoftwareRenderLoopMeasurementOptions) -> BackendComparisonSample:
    val html = _software_render_loop_html(opts.fixture_id)
    var warmup = 0
    while warmup < opts.warmup_count:
        simple_web_render_html_to_pixels_with_engine2d_backend(html, opts.width.to_i32(), opts.height.to_i32(), opts.backend)
        warmup = warmup + 1
    var samples: [i64] = []
    var pixels: [u32] = []
    var i = 0
    while i < opts.sample_count:
        val start_us = time_now_micros()
        pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, opts.width.to_i32(), opts.height.to_i32(), opts.backend)
        samples.push(_positive_elapsed_us(start_us))
        i = i + 1
    val sorted = _sort_i64(samples)
    val p50 = _percentile_nearest_rank(sorted, 50)
    val p95 = _percentile_nearest_rank(sorted, 95)
    val measurement = HostCommandMeasurement(
        command: opts.command,
        host: opts.host,
        sample_count: opts.sample_count,
        p50_us: p50,
        p95_us: p95,
        max_rss_kb: _positive_or_one(opts.max_rss_kb),
        binary_size_bytes: _positive_or_one(opts.binary_size_bytes),
        baseline_binary_size_bytes: _positive_or_one(opts.baseline_binary_size_bytes),
        render_readback_scope: "software-render-loop"
    )
    var record = host_measurement_record(
        opts.backend,
        opts.backend,
        "Initialized",
        measurement,
        true,
        false,
        ""
    )
    record.warmup_count = opts.warmup_count
    backend_comparison_from_measurement_with_runtime_metadata(
        record,
        opts.fixture_id,
        "software",
        opts.shell,
        p50,
        p50,
        _positive_or_one(opts.package_size_bytes),
        p95,
        0,
        0,
        p50,
        0,
        0,
        "sum32:" + _checksum_u32_pixels(pixels).to_string(),
        "nonzero_pixels:" + _nonzero_pixels(pixels).to_string(),
        "host-software",
        "baseline",
        opts.operation_family,
        "simple_web_render_html_to_pixels",
        "RenderBackend.draw_text_or_text_blit",
        "simple",
        "none",
        "",
        "cpu_scalar",
        "engine2d-cpu_scalar",
        "RenderBackend",
        "RenderBackend.draw_text_or_text_blit",
        "",
        "cpu-render-loop-ready"
    )

pub fn parse_usr_bin_time_measurements(command: text, host: text,
                                       time_output: text,
                                       binary_size_bytes: i64,
                                       baseline_binary_size_bytes: i64,
                                       render_readback_scope: text) -> HostCommandMeasurement:
    val lines = time_output.split("\n")
    var elapsed: [i64] = []
    var max_rss: i64 = 0
    for line in lines:
        val elapsed_text = _field_after(line, "elapsed_s")
        if elapsed_text != "":
            elapsed.push(_elapsed_seconds_to_us(elapsed_text))
        val rss_text = _field_after(line, "max_rss_kb")
        if rss_text != "":
            val rss = rss_text.to_i64()
            if rss > max_rss:
                max_rss = rss
    val sorted = _sort_i64(elapsed)
    HostCommandMeasurement(
        command: command,
        host: host,
        sample_count: sorted.len(),
        p50_us: _percentile_nearest_rank(sorted, 50),
        p95_us: _percentile_nearest_rank(sorted, 95),
        max_rss_kb: max_rss,
        binary_size_bytes: binary_size_bytes,
        baseline_binary_size_bytes: baseline_binary_size_bytes,
        render_readback_scope: render_readback_scope
    )

pub fn host_measurement_record(requested_backend: text, selected_backend: text,
                               status: text, measurement: HostCommandMeasurement,
                               scalar_baseline_compared: bool,
                               fallback_used: bool,
                               unavailable_reason: text) -> BackendMeasurementRecord:
    BackendMeasurementRecord(
        requested_backend: requested_backend,
        selected_backend: selected_backend,
        status: status,
        command: measurement.command,
        host: measurement.host,
        warmup_count: 0,
        sample_count: measurement.sample_count,
        p50_us: measurement.p50_us,
        p95_us: measurement.p95_us,
        max_rss_kb: measurement.max_rss_kb,
        binary_size_bytes: measurement.binary_size_bytes,
        baseline_binary_size_bytes: measurement.baseline_binary_size_bytes,
        render_readback_scope: measurement.render_readback_scope,
        scalar_baseline_compared: scalar_baseline_compared,
        fallback_used: fallback_used,
        unavailable_reason: unavailable_reason
    )

fn _empty_measurement(command: text, host: text) -> HostCommandMeasurement:
    HostCommandMeasurement(
        command: command,
        host: host,
        sample_count: 0,
        p50_us: 0,
        p95_us: 0,
        max_rss_kb: 0,
        binary_size_bytes: 0,
        baseline_binary_size_bytes: 0,
        render_readback_scope: ""
    )

fn _gpu_probe_measurement_record(probe: BackendProbeResult, command: text, host: text) -> BackendMeasurementRecord:
    if probe.status == BackendStatus.Initialized:
        return host_measurement_record(
            probe.requested_name,
            probe.selected_name,
            "Failed",
            _empty_measurement(command, host),
            false,
            false,
            "backend-specific measurement missing"
        )
    backend_measurement_from_probe(
        probe,
        command,
        host,
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        "",
        false
    )

pub fn host_comparison_sample(record: BackendMeasurementRecord,
                              fixture_id: text,
                              backend_family: text,
                              shell: text,
                              package_size_bytes: i64,
                              checksum: text,
                              pixel_proof: text,
                              device_id: text) -> BackendComparisonSample:
    backend_comparison_from_measurement_with_runtime_metadata(
        record,
        fixture_id,
        backend_family,
        shell,
        record.p95_us,
        record.p50_us,
        package_size_bytes,
        record.p95_us,
        0,
        0,
        0,
        0,
        0,
        checksum,
        pixel_proof,
        device_id,
        "baseline",
        "cpu_simd",
        "cpu_simd_baseline",
        "RenderBackend",
        "engine2d-cpu",
        "none",
        "",
        "cpu_simd",
        "engine2d-cpu-simd",
        "RenderBackend",
        "RenderBackend",
        "",
        "cpu-simd-baseline-ready"
    )

pub fn initialized_gpu_comparison_sample_from_measurement(evidence: InitializedGpuRuntimeMeasurement) -> BackendComparisonSample:
    val measurement = HostCommandMeasurement(
        command: evidence.command,
        host: evidence.host,
        sample_count: evidence.sample_count,
        p50_us: evidence.p50_frame_us,
        p95_us: evidence.p95_frame_us,
        max_rss_kb: evidence.max_rss_kb,
        binary_size_bytes: evidence.binary_size_bytes,
        baseline_binary_size_bytes: evidence.baseline_binary_size_bytes,
        render_readback_scope: evidence.render_readback_scope
    )
    var record = host_measurement_record(
        evidence.backend,
        evidence.backend,
        "Initialized",
        measurement,
        true,
        false,
        ""
    )
    record.warmup_count = evidence.warmup_count
    val metadata = portable_compute_operation_metadata("@gpu", evidence.backend, evidence.operation_family, "simple_2d_optimization")
    val runtime = generated_2d_operation_provenance(
        evidence.backend,
        evidence.operation_family,
        evidence.width,
        evidence.height,
        evidence.runtime_ready,
        evidence.module_ready,
        evidence.args_ptr
    )
    if metadata.rows.len() == 0:
        return backend_comparison_from_measurement_with_runtime_metadata(
            record,
            evidence.fixture_id,
            evidence.backend,
            evidence.shell,
            evidence.cold_start_us,
            evidence.warm_start_us,
            evidence.package_size_bytes,
            evidence.p95_input_to_paint_us,
            evidence.artifact_build_us,
            evidence.artifact_load_us,
            evidence.artifact_submit_us,
            evidence.artifact_sync_us,
            evidence.artifact_readback_us,
            evidence.checksum,
            evidence.pixel_proof,
            evidence.device_id,
            "",
            evidence.operation_family,
            "",
            "",
            "",
            "",
            "",
            runtime.compute_target,
            runtime.execution_path,
            runtime.launch_api,
            runtime.entry_name,
            runtime.artifact_name,
            runtime.typed_status
        )
    val row = metadata.rows[0]
    backend_comparison_from_measurement_with_runtime_metadata(
        record,
        evidence.fixture_id,
        evidence.backend,
        evidence.shell,
        evidence.cold_start_us,
        evidence.warm_start_us,
        evidence.package_size_bytes,
        evidence.p95_input_to_paint_us,
        evidence.artifact_build_us,
        evidence.artifact_load_us,
        evidence.artifact_submit_us,
        evidence.artifact_sync_us,
        evidence.artifact_readback_us,
        evidence.checksum,
        evidence.pixel_proof,
        evidence.device_id,
        row.tag_kind,
        row.operation_family,
        row.generated_operation,
        row.entry_symbol,
        row.source_format,
        row.binary_format,
        row.artifact_path_suffix,
        runtime.compute_target,
        runtime.execution_path,
        runtime.launch_api,
        runtime.entry_name,
        runtime.artifact_name,
        runtime.typed_status
    )

pub fn initialized_gpu_comparison_sample_fixture(backend: text,
                                                 operation_family: text,
                                                 fixture_id: text,
                                                 shell: text) -> BackendComparisonSample:
    initialized_gpu_comparison_sample_from_measurement(
        InitializedGpuRuntimeMeasurement(
        backend: backend,
        operation_family: operation_family,
        fixture_id: fixture_id,
        shell: shell,
        command: "simple wm_compare initialized gpu fixture",
        host: "host-safe-fixture",
        warmup_count: 0,
        sample_count: 5,
        p50_frame_us: 900,
        p95_frame_us: 1200,
        max_rss_kb: 64000,
        binary_size_bytes: 1000000,
        baseline_binary_size_bytes: 990000,
        render_readback_scope: "render+readback",
        cold_start_us: 42000,
        warm_start_us: 9000,
        package_size_bytes: 1250000,
        p95_input_to_paint_us: 1800,
        artifact_build_us: 310,
        artifact_load_us: 75,
        artifact_submit_us: 140,
        artifact_sync_us: 25,
        artifact_readback_us: 110,
        checksum: "sha256:" + backend + ":fixture",
        pixel_proof: "nonzero_pixels:4096",
        device_id: backend + ":fixture",
        width: 64,
        height: 64,
        runtime_ready: true,
        module_ready: true,
        args_ptr: 4096
        )
    )

fn _gpu_probe_comparison_sample(probe: BackendProbeResult,
                                family: text,
                                command: text,
                                host: text,
                                fixture_id: text,
                                shell: text,
                                operation_family: text) -> BackendComparisonSample:
    val record = _gpu_probe_measurement_record(probe, command, host)
    val metadata = portable_compute_operation_metadata("@gpu", probe.requested_name, operation_family, "simple_2d_optimization")
    if metadata.rows.len() > 0:
        val row = metadata.rows[0]
        val runtime = generated_2d_operation_provenance(probe.requested_name, operation_family, 64, 64, false, false, 0)
        return backend_comparison_from_measurement_with_runtime_metadata(
            record,
            fixture_id,
            family,
            shell,
            0,
            0,
            0,
            0,
            0,
            0,
            0,
            0,
            0,
            "",
            "",
            "",
            row.tag_kind,
            row.operation_family,
            row.generated_operation,
            row.entry_symbol,
            row.source_format,
            row.binary_format,
            row.artifact_path_suffix,
            runtime.compute_target,
            runtime.execution_path,
            runtime.launch_api,
            runtime.entry_name,
            runtime.artifact_name,
            runtime.typed_status
        )
    host_comparison_sample(record, fixture_id, family, shell, 0, "", "", "")

fn _generated_runtime_ready(evidence: InitializedGpuRuntimeMeasurement) -> bool:
    evidence.runtime_ready and evidence.module_ready and evidence.args_ptr != 0

fn _initialized_gpu_runner_not_ready_probe(evidence: InitializedGpuRuntimeMeasurement) -> BackendProbeResult:
    val reason = if not evidence.runtime_ready:
        "generated Engine2D runtime not ready"
    elif not evidence.module_ready:
        "generated Engine2D module not loaded"
    elif evidence.args_ptr == 0:
        "generated Engine2D args pointer missing"
    else:
        "generated Engine2D session not ready"
    var probe = BackendProbeResult.failed(evidence.backend, reason)
    probe.api_name = evidence.backend
    probe.feature_gate = "generated_engine2d_runtime"
    probe.has_compute = true
    probe.has_graphics = false
    probe.has_present = false
    probe

pub fn initialized_gpu_runner_comparison_sample_from_probe(evidence: InitializedGpuRuntimeMeasurement,
                                                           probe: BackendProbeResult) -> BackendComparisonSample:
    if probe.status != BackendStatus.Initialized:
        return _gpu_probe_comparison_sample(
            probe,
            evidence.backend,
            evidence.command,
            evidence.host,
            evidence.fixture_id,
            evidence.shell,
            evidence.operation_family
        )
    if not _generated_runtime_ready(evidence):
        return _gpu_probe_comparison_sample(
            _initialized_gpu_runner_not_ready_probe(evidence),
            evidence.backend,
            evidence.command,
            evidence.host,
            evidence.fixture_id,
            evidence.shell,
            evidence.operation_family
        )
    initialized_gpu_comparison_sample_from_measurement(evidence)

pub fn initialized_gpu_runner_comparison_sample(evidence: InitializedGpuRuntimeMeasurement) -> BackendComparisonSample:
    val probe = StrictBackendFactory.strict().create_backend(evidence.backend)
    initialized_gpu_runner_comparison_sample_from_probe(evidence, probe)

pub fn current_host_backend_measurement_matrix(command: text, host: text,
                                               time_output: text,
                                               binary_size_bytes: i64,
                                               baseline_binary_size_bytes: i64,
                                               render_readback_scope: text) -> [BackendMeasurementRecord]:
    val measurement = parse_usr_bin_time_measurements(
        command, host, time_output,
        binary_size_bytes, baseline_binary_size_bytes,
        render_readback_scope
    )
    val factory = StrictBackendFactory.strict()
    val metal = backend_measurement_from_probe(
        factory.create_backend("metal"),
        "", host, 0, 0, 0, 0, 0, 0, 0, "", false
    )
    val vulkan = backend_measurement_from_probe(
        factory.create_backend("vulkan"),
        "", host, 0, 0, 0, 0, 0, 0, 0, "", false
    )
    val cuda = backend_measurement_from_probe(
        factory.create_backend("cuda"),
        "", host, 0, 0, 0, 0, 0, 0, 0, "", false
    )
    val opencl = backend_measurement_from_probe(
        factory.create_backend("opencl"),
        "", host, 0, 0, 0, 0, 0, 0, 0, "", false
    )
    val rocm = backend_measurement_from_probe(
        factory.create_backend("rocm"),
        "", host, 0, 0, 0, 0, 0, 0, 0, "", false
    )
    val cpu_simd = host_measurement_record(
        "cpu_simd", "cpu_simd", "Initialized",
        measurement, true, false, "host measurement"
    )
    [metal, vulkan, cuda, opencl, rocm, cpu_simd]

pub fn current_host_backend_comparison_samples(command: text, host: text,
                                               time_output: text,
                                               binary_size_bytes: i64,
                                               baseline_binary_size_bytes: i64,
                                               package_size_bytes: i64,
                                               render_readback_scope: text,
                                               fixture_id: text,
                                               shell: text,
                                               operation_family: text,
                                               checksum: text,
                                               pixel_proof: text) -> [BackendComparisonSample]:
    val measurement = parse_usr_bin_time_measurements(
        command, host, time_output,
        binary_size_bytes, baseline_binary_size_bytes,
        render_readback_scope
    )
    val factory = StrictBackendFactory.strict()
    val metal = _gpu_probe_comparison_sample(
        factory.create_backend("metal"), "metal", command, host, fixture_id, shell, operation_family
    )
    val vulkan = _gpu_probe_comparison_sample(
        factory.create_backend("vulkan"), "vulkan", command, host, fixture_id, shell, operation_family
    )
    val cuda = _gpu_probe_comparison_sample(
        factory.create_backend("cuda"), "cuda", command, host, fixture_id, shell, operation_family
    )
    val opencl = _gpu_probe_comparison_sample(
        factory.create_backend("opencl"), "opencl", command, host, fixture_id, shell, operation_family
    )
    val rocm = _gpu_probe_comparison_sample(
        factory.create_backend("rocm"), "hip", command, host, fixture_id, shell, operation_family
    )
    val cpu_record = host_measurement_record(
        "cpu_simd", "cpu_simd", "Initialized",
        measurement, true, false, "host measurement"
    )
    val cpu_simd = host_comparison_sample(
        cpu_record,
        fixture_id,
        "cpu_simd",
        shell,
        package_size_bytes,
        checksum,
        pixel_proof,
        "host-cpu"
    )
    [metal, vulkan, cuda, opencl, rocm, cpu_simd]
