use app.wm_compare.structural_layout_report.{
    StructuralLayoutBox,
    structural_layout_box
}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_draw_ir}
use common.ui.draw_ir.{DrawIrCommand, DrawIrComposition}
extern fn rt_file_read_text(path: text) -> text

fn _fixture_html_path(fixture_id: text) -> text:
    if fixture_id == "10_colors" or fixture_id == "11_font_size" or fixture_id == "12_padding" or
       fixture_id == "13_margin" or fixture_id == "14_border" or fixture_id == "15_background" or
       fixture_id == "16_flex_row" or fixture_id == "17_flex_col":
        return "test/fixtures/html_compat/02_block_boxes.html"
    "test/fixtures/html_compat/{fixture_id}.html"

fn _fixture_css_path(fixture_id: text) -> text:
    if _is_css_layer_fixture(fixture_id):
        return "test/fixtures/html_compat/{fixture_id}.css"
    ""

fn _is_css_layer_fixture(fixture_id: text) -> bool:
    fixture_id == "10_colors" or fixture_id == "11_font_size" or fixture_id == "12_padding" or
        fixture_id == "13_margin" or fixture_id == "14_border" or fixture_id == "15_background" or
        fixture_id == "16_flex_row" or fixture_id == "17_flex_col"

fn _fixture_html(fixture_id: text) -> text:
    val html = rt_file_read_text(_fixture_html_path(fixture_id)) ?? ""
    if html == "":
        return ""
    val css_path = _fixture_css_path(fixture_id)
    if css_path == "":
        return html
    val css = rt_file_read_text(css_path) ?? ""
    if css == "":
        return html
    val style_tag = "<style>\n" + css + "</style>\n</head>"
    html.replace("</head>", style_tag)

fn _fixture_label_text(fixture_id: text, label: text) -> text:
    if fixture_id == "06_card_panel":
        if label == "card_panel":
            return "Panel Status ready"
        if label == "card_title":
            return "Panel"
        if label == "card_body":
            return "Status ready"
    if fixture_id == "22_flex_align_items_baseline":
        if label == "baseline_shell":
            return "A B"
        if label == "baseline_big":
            return "A"
        if label == "baseline_small":
            return "B"
    ""

fn _draw_ir_command_by_id(commands: [DrawIrCommand], component_id: text) -> DrawIrCommand?:
    for command in commands:
        if command.component_id == component_id:
            return command
    nil

pub fn simple_layout_boxes_to_structural(fixture_id: text, commands: [DrawIrCommand], labels: [text]) -> [StructuralLayoutBox]:
    var out: [StructuralLayoutBox] = []
    for label in labels:
        if val command = _draw_ir_command_by_id(commands, label):
            val text_value = if command.text_value != "": command.text_value else: _fixture_label_text(fixture_id, label)
            out.push(structural_layout_box(label, command.x, command.y, command.width, command.height, text_value))
    out

pub fn html_compat_fixture_simple_boxes(fixture_id: text, viewport_width: i32, viewport_height: i32) -> [StructuralLayoutBox]:
    val html = _fixture_html(fixture_id)
    html_compat_fixture_simple_boxes_from_html(fixture_id, html, viewport_width, viewport_height)

pub fn html_compat_fixture_simple_boxes_from_html(fixture_id: text, html: text, viewport_width: i32, viewport_height: i32) -> [StructuralLayoutBox]:
    if html == "":
        return []
    val composition = simple_web_layout_render_html_draw_ir(html, viewport_width, viewport_height)
    if composition.batches.len() == 0:
        return []
    val labels = if fixture_id == "02_block_boxes":
        ["outer", "header", "middle", "left", "right", "footer"]
    elif fixture_id == "03_list":
        ["list_root", "list_item_0", "list_item_1", "list_item_2"]
    elif fixture_id == "04_button":
        ["button_panel", "primary_button"]
    elif fixture_id == "05_text_input":
        ["panel", "search_input"]
    elif fixture_id == "06_card_panel":
        ["card_panel", "card_title", "card_body"]
    elif fixture_id == "07_scrollable_list":
        ["scroll_shell", "scroll_list", "scroll_item_0", "scroll_item_1", "scroll_item_2"]
    elif fixture_id == "18_flex_grow_weights":
        ["grow_shell", "grow_fixed", "grow_one", "grow_two"]
    elif fixture_id == "19_flex_shrink_weights":
        ["shrink_shell", "shrink_one", "shrink_two", "shrink_three"]
    elif fixture_id == "20_flex_basis_override":
        ["basis_shell", "basis_one", "basis_two", "basis_three"]
    elif fixture_id == "21_flex_wrap_basic":
        ["wrap_shell", "wrap_a", "wrap_b", "wrap_c"]
    elif fixture_id == "22_flex_align_items_baseline":
        ["baseline_shell", "baseline_big", "baseline_small"]
    elif fixture_id == "23_flex_wrap_align_content_center":
        ["wrap_center_shell", "wrap_center_a", "wrap_center_b", "wrap_center_c"]
    elif fixture_id == "24_flex_wrap_reverse_basic":
        ["wrap_reverse_shell", "wrap_reverse_a", "wrap_reverse_b", "wrap_reverse_c"]
    elif _is_css_layer_fixture(fixture_id):
        ["outer", "header", "middle", "left", "right", "footer"]
    else:
        []
    simple_layout_boxes_to_structural(fixture_id, composition.batches[0].commands, labels)
