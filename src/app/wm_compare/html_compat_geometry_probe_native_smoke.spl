use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes_from_html}

extern fn rt_env_get(key: text) -> text

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _env_i32_or(key: text, fallback: i32) -> i32:
    val value = _env_or(key, "")
    if value == "":
        return fallback
    value.to_i32()

fn _inline_fixture_html(fixture_id: text) -> text:
    if fixture_id == "24_flex_wrap_reverse_basic":
        return "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>24 flex wrap reverse basic</title></head><body style=\"margin:0; background-color:#ffffff;\"><div id=\"wrap_reverse_shell\" data-geom-label=\"wrap_reverse_shell\" style=\"margin:16px; width:140px; display:flex; flex-direction:row; flex-wrap:wrap-reverse; background-color:#e2e8f0;\"><div id=\"wrap_reverse_a\" data-geom-label=\"wrap_reverse_a\" style=\"width:60px; height:24px; background-color:#94a3b8;\"></div><div id=\"wrap_reverse_b\" data-geom-label=\"wrap_reverse_b\" style=\"width:60px; height:24px; background-color:#60a5fa;\"></div><div id=\"wrap_reverse_c\" data-geom-label=\"wrap_reverse_c\" style=\"width:60px; height:24px; background-color:#2563eb;\"></div></div></body></html>"
    ""

fn main() -> i64:
    val fixture_id = _env_or("HTML_COMPAT_NATIVE_FIXTURE", "24_flex_wrap_reverse_basic")
    val viewport_width = _env_i32_or("HTML_COMPAT_NATIVE_WIDTH", 320)
    val viewport_height = _env_i32_or("HTML_COMPAT_NATIVE_HEIGHT", 240)
    val html = _inline_fixture_html(fixture_id)
    val boxes = html_compat_fixture_simple_boxes_from_html(fixture_id, html, viewport_width, viewport_height)
    if boxes.len() == 0:
        print "status=fail"
        print "reason=no-boxes"
        print "fixture={fixture_id}"
        return 1
    print "status=pass"
    print "fixture={fixture_id}"
    print "box_count={boxes.len()}"
    print "first_label={boxes[0].label}"
    print "first_x={boxes[0].x}"
    print "first_y={boxes[0].y}"
    0
