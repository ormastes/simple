use app.wm_compare.v1_v2_parity.{
    render_v1, render_v2,
    scene_solid_fill, _pack_argb,
}

fn test_clear(color: u32) -> u32:
    var buf: [u32] = [0u32, 0u32, 0u32]
    var i: u32 = 0
    while i < 3u32:
        buf[i] = color
        i = i + 1
    buf[0]

fn main():
    val packed = _pack_argb(255u8, 0x11u8, 0x22u8, 0x33u8)
    print("packed={packed}")
    val result = test_clear(packed)
    print("test_clear(packed)={result}")

    val scene = scene_solid_fill()
    val v2 = render_v2(scene)
    print("v2[0]={v2[0]}  v2.len={v2.len()}")
    val v1 = render_v1(scene)
    print("v1[0]={v1[0]}  v1.len={v1.len()}")
