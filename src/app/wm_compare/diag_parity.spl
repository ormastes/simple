use app.wm_compare.golden_gate.{check_golden}

fn fill_array(arr: [u32], val_in: u32):
    var i: u32 = 0
    while i < arr.len().to_u32():
        arr[i] = val_in
        i = i + 1

fn main():
    # test array mutation through function param
    var arr: [u32] = [0u32, 0u32, 0u32]
    fill_array(arr, 42u32)
    print("arr[0] after fill_array(42)={arr[0]}")

    fill_array(arr, 4279312947u32)
    print("arr[0] after fill_array(0xFF112233)={arr[0]}")

    val g1 = check_golden(scene_solid_fill())
    print("golden solid_fill pass_gate={g1.pass_gate} max_delta={g1.diff.max_channel_delta}")
