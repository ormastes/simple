fn clear_arr(arr: [u32], color: u32):
    var i: u32 = 0
    val n = arr.len().to_u32()
    while i < n:
        arr[i] = color
        i = i + 1

fn make_buf(n: u32) -> [u32]:
    var buf: [u32] = []
    var i: u32 = 0
    while i < n:
        buf = buf + [0u32]
        i = i + 1
    buf

fn main():
    # test: does clear_arr mutate buffer built by make_buf?
    var b = make_buf(4u32)
    print("before clear: b[0]={b[0]}")
    clear_arr(b, 42u32)
    print("after clear(42): b[0]={b[0]}")
    clear_arr(b, 4279312947u32)
    print("after clear(0xFF112233): b[0]={b[0]}")
