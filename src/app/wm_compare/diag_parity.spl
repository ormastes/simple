use app.wm_compare.v1_v2_parity.{
    render_v1, render_v2, diff_buffers,
    scene_solid_fill,
}
use app.wm_compare.golden_gate.{check_golden, decode_ppm_p6, encode_ppm_p6}

fn main():
    val scene = scene_solid_fill()
    val v1 = render_v1(scene)
    val v2 = render_v2(scene)

    val v1_0 = v1[0]
    val v2_0 = v2[0]
    print("v1[0]={v1_0}  v2[0]={v2_0}")
    # test _pack_argb by hand: a=255, r=0x11, g=0x22, b=0x33
    val a: u8 = 255u8
    val r: u8 = 0x11u8
    val g: u8 = 0x22u8
    val b: u8 = 0x33u8
    val packed = (a << 24) | (r << 16) | (g << 8) | b
    print("manual _pack_argb(255,0x11,0x22,0x33)={packed}")
    # check what the golden decoder produces
    val enc = encode_ppm_p6(32u32, 16u32, v1)
    val decoded = decode_ppm_p6(enc)
    val d0 = decoded[0]
    print("roundtrip pixel[0]={d0}")

    val g1 = check_golden(scene_solid_fill())
    print("golden solid_fill pass_gate={g1.pass_gate} max_delta={g1.diff.max_channel_delta} differing={g1.diff.differing_pixels}")
