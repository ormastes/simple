# CUDA device-buffer measurement capture for wm_compare backend evidence.

use app.wm_compare.backend_measurement_capture.{InitializedGpuRuntimeMeasurement, initialized_gpu_runner_comparison_sample_from_probe}
use app.wm_compare.backend_measurement_report.{BackendComparisonSample}
use app.wm_compare.backend_measurement_runtime_ops.{measurement_alloc, measurement_free, measurement_ptr_read_i32, measurement_ptr_write_i64}
use std.gpu.engine2d.backend_cuda_kernels.{cuda_2d_ptx_source}
use std.gpu.engine2d.backend_probe.{BackendProbeResult}
use std.gpu.engine2d.generated_kernel_dispatch.{GENERATED_2D_FILL}
use std.gc_async_mut.gpu.engine2d.cuda_session.{CudaSession}
use std.gc_async_mut.cuda.{cuda_available, cuda_memcpy_dtoh, CUDA_SUCCESS}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}

pub struct CudaDeviceMeasurementOptions:
    fixture_id: text
    shell: text
    command: text
    host: text
    width: i64
    height: i64
    color: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    package_size_bytes: i64

fn _elapsed_us(start_us: i64) -> i64:
    val elapsed = time_now_micros() - start_us
    if elapsed <= 0:
        return 1
    elapsed

fn _positive_or_one(value: i64) -> i64:
    if value > 0: value else: 1

fn _checksum_u32_host(ptr: i64, count: i64) -> i64:
    var checksum: i64 = 0
    var i: i64 = 0
    while i < count:
        val pixel = measurement_ptr_read_i32(ptr, i * 4) as i64
        checksum = checksum + (pixel & 0xFFFFFFFF)
        i = i + 1
    checksum

fn _nonzero_u32_host(ptr: i64, count: i64) -> i64:
    var nonzero: i64 = 0
    var i: i64 = 0
    while i < count:
        if measurement_ptr_read_i32(ptr, i * 4) != 0:
            nonzero = nonzero + 1
        i = i + 1
    nonzero

fn _cuda_probe_from_evidence(status: text, reason: text) -> BackendProbeResult:
    var probe = if status == "initialized":
        BackendProbeResult.success("cuda", reason)
    elif status == "failed":
        BackendProbeResult.failed("cuda", reason)
    else:
        BackendProbeResult.unavailable("cuda", reason)
    probe.api_name = "cuda"
    probe.feature_gate = "cuda_device_buffer_measurement"
    probe.shader_format = "ptx"
    probe.has_compute = true
    probe.has_graphics = false
    probe.has_present = false
    probe

fn _measurement_evidence(opts: CudaDeviceMeasurementOptions,
                         artifact_build_us: i64,
                         artifact_load_us: i64,
                         artifact_submit_us: i64,
                         artifact_sync_us: i64,
                         artifact_readback_us: i64,
                         checksum: text,
                         pixel_proof: text,
                         runtime_ready: bool,
                         module_ready: bool,
                         args_ptr: i64) -> InitializedGpuRuntimeMeasurement:
    val frame_us = artifact_submit_us + artifact_sync_us + artifact_readback_us
    val warm_us = artifact_load_us + frame_us
    val cold_us = artifact_build_us + warm_us
    InitializedGpuRuntimeMeasurement(
        backend: "cuda",
        operation_family: "fill",
        fixture_id: opts.fixture_id,
        shell: opts.shell,
        command: opts.command,
        host: opts.host,
        warmup_count: 0,
        sample_count: 1,
        p50_frame_us: _positive_or_one(frame_us),
        p95_frame_us: _positive_or_one(frame_us),
        max_rss_kb: 1,
        binary_size_bytes: _positive_or_one(opts.binary_size_bytes),
        baseline_binary_size_bytes: _positive_or_one(opts.baseline_binary_size_bytes),
        render_readback_scope: "render+readback",
        cold_start_us: _positive_or_one(cold_us),
        warm_start_us: _positive_or_one(warm_us),
        package_size_bytes: _positive_or_one(opts.package_size_bytes),
        p95_input_to_paint_us: _positive_or_one(frame_us),
        artifact_build_us: _positive_or_one(artifact_build_us),
        artifact_load_us: _positive_or_one(artifact_load_us),
        artifact_submit_us: _positive_or_one(artifact_submit_us),
        artifact_sync_us: _positive_or_one(artifact_sync_us),
        artifact_readback_us: _positive_or_one(artifact_readback_us),
        checksum: checksum,
        pixel_proof: pixel_proof,
        device_id: "cuda:0",
        width: opts.width,
        height: opts.height,
        runtime_ready: runtime_ready,
        module_ready: module_ready,
        args_ptr: args_ptr
    )

fn _cuda_unavailable_sample(opts: CudaDeviceMeasurementOptions, reason: text) -> BackendComparisonSample:
    val evidence = _measurement_evidence(opts, 0, 0, 0, 0, 0, "", "", false, false, 0)
    initialized_gpu_runner_comparison_sample_from_probe(
        evidence,
        _cuda_probe_from_evidence("unavailable", reason)
    )

pub fn cuda_device_buffer_measurement_sample(opts: CudaDeviceMeasurementOptions) -> BackendComparisonSample:
    if opts.width <= 0 or opts.height <= 0:
        return _cuda_unavailable_sample(opts, "invalid CUDA measurement dimensions")
    if not cuda_available():
        return _cuda_unavailable_sample(opts, "CUDA runtime unavailable")
    val init_start = time_now_micros()
    val session = CudaSession.create()
    val session_rc = session.init()
    val init_us = _elapsed_us(init_start)
    if session_rc != CUDA_SUCCESS:
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA init/device/context unavailable")

    val load_start = time_now_micros()
    val module = session.load_module(cuda_2d_ptx_source())
    val load_us = _elapsed_us(load_start)
    if module == 0:
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA generated 2D PTX module load failed")
    session.module_cache = module

    val count = opts.width * opts.height
    val byte_count = count * 4
    val alloc_start = time_now_micros()
    val device_buffer = session.alloc(byte_count)
    val readback_ptr = measurement_alloc(byte_count)
    val val_ptr = measurement_alloc(32)
    val args_ptr = measurement_alloc(32)
    val alloc_us = _elapsed_us(alloc_start)
    if device_buffer == 0 or readback_ptr == 0 or val_ptr == 0 or args_ptr == 0:
        if device_buffer != 0:
            session.free(device_buffer)
        if readback_ptr != 0:
            measurement_free(readback_ptr, byte_count)
        if val_ptr != 0:
            measurement_free(val_ptr, 32)
        if args_ptr != 0:
            measurement_free(args_ptr, 32)
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA measurement allocation failed")

    measurement_ptr_write_i64(val_ptr, 0, device_buffer)
    measurement_ptr_write_i64(val_ptr, 8, opts.width)
    measurement_ptr_write_i64(val_ptr, 16, opts.height)
    measurement_ptr_write_i64(val_ptr, 24, opts.color)
    measurement_ptr_write_i64(args_ptr, 0, val_ptr)
    measurement_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    measurement_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    measurement_ptr_write_i64(args_ptr, 24, val_ptr + 24)

    val submit_start = time_now_micros()
    val launch_rc = session.launch_generated_2d(GENERATED_2D_FILL, opts.width, opts.height, args_ptr)
    val submit_us = _elapsed_us(submit_start)
    if launch_rc != CUDA_SUCCESS:
        session.free(device_buffer)
        measurement_free(readback_ptr, byte_count)
        measurement_free(val_ptr, 32)
        measurement_free(args_ptr, 32)
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA generated fill launch failed")

    val sync_start = time_now_micros()
    val sync_rc = session.sync()
    val sync_us = _elapsed_us(sync_start)
    if sync_rc != CUDA_SUCCESS:
        session.free(device_buffer)
        measurement_free(readback_ptr, byte_count)
        measurement_free(val_ptr, 32)
        measurement_free(args_ptr, 32)
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA sync failed")

    val read_start = time_now_micros()
    val read_rc = cuda_memcpy_dtoh(readback_ptr, device_buffer, byte_count)
    val read_us = _elapsed_us(read_start)
    if read_rc != CUDA_SUCCESS:
        session.free(device_buffer)
        measurement_free(readback_ptr, byte_count)
        measurement_free(val_ptr, 32)
        measurement_free(args_ptr, 32)
        session.shutdown()
        return _cuda_unavailable_sample(opts, "CUDA device readback failed")

    val checksum_value = _checksum_u32_host(readback_ptr, count)
    val nonzero = _nonzero_u32_host(readback_ptr, count)
    session.free(device_buffer)
    measurement_free(readback_ptr, byte_count)
    measurement_free(val_ptr, 32)
    measurement_free(args_ptr, 32)
    session.shutdown()

    val proof = if nonzero > 0: "nonzero_pixels:" + nonzero.to_string() else: ""
    val checksum = if checksum_value > 0: "sum32:" + checksum_value.to_string() else: ""
    val evidence = _measurement_evidence(
        opts,
        load_us,
        init_us + alloc_us,
        submit_us,
        sync_us,
        read_us,
        checksum,
        proof,
        true,
        true,
        args_ptr
    )
    initialized_gpu_runner_comparison_sample_from_probe(
        evidence,
        _cuda_probe_from_evidence("initialized", "CUDA generated Engine2D device-buffer measurement initialized")
    )
