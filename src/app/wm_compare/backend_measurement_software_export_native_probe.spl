use app.wm_compare.backend_measurement_software_export.{software_only_render_loop_export_sdn}

fn main() -> i64:
    val sdn = software_only_render_loop_export_sdn([
        "--software-render-backend", "cpu_simd",
        "--width", "64",
        "--height", "64",
        "--sample-count", "1",
        "--warmup-count", "0",
        "--dpi", "300",
        "--trace-layout-stages", "1"
    ])
    if sdn.len() <= 0:
        return 1
    0
