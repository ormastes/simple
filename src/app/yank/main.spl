# Simple CLI - yank command
# Mark a package version as yanked in the registry

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.package.registry.config (default_config)
use app.package.registry.auth (has_credentials, print_auth_error, get_token)
use app.package.registry.index (fetch_index_entry, find_version)

use app.io.mod (process_run, process_output)
use std.log.{error, warn}

fn print_help():
    print "Usage: simple yank <package> <version> [options]"
    print ""
    print "Mark a version as yanked (not recommended for new installs)."
    print "Yanked versions remain downloadable but won't be selected by default."
    print ""
    print "Options:"
    print "  --undo          Undo a yank"
    print "  --token=TOKEN   Override auth token"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help      Show this help"
    print ""
    print "Examples:"
    print "  simple yank http 1.0.0"
    print "  simple yank http 1.0.0 --undo"

fn print_error(msg: text):
    error("yank", msg)

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("yank", log_opts.error)
        return 1

    var name = ""
    var version = ""
    var undo = false
    var positional = 0
    var as_json = log_opts.log_mode == "json"

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--undo":
            undo = true
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif arg == "yank":
            pass
        elif arg.starts_with("--token="):
            pass
        elif _is_log_option(arg):
            pass
        elif positional == 0:
            name = arg
            positional = positional + 1
        elif positional == 1:
            version = arg
            positional = positional + 1
        ai = ai + 1

    if name == "" or version == "":
        if log_opts.progress != "summary" and not as_json:
            val progress_line = render_progress(log_opts.progress, 0, 1, "yank")
            if progress_line != "":
                print progress_line
        if as_json:
            print "{\"command\":\"yank\",\"status\":\"error\",\"package\":\"{name}\",\"version\":\"{version}\"}"
        else:
            print_error("yank requires <package> and <version> arguments")
            print ""
            print_help()
        return 1

    # Check auth
    if not has_credentials():
        print_auth_error()
        return 1

    # Verify the version exists
    val config = default_config()
    val entry = fetch_index_entry(config, name)
    val ver = find_version(entry, version)

    if ver.version == "":
        error("yank", "version {version} not found for package '{name}'")
        return 1

    if undo:
        if not ver.yanked:
            print "Version {version} of '{name}' is not yanked"
            return 0
        print "Unyanking {name}@{version}..."
        warn("yank", "Index repo PR submission not implemented; cannot set yanked=false automatically")
        print "Submitted unyank request for {name}@{version}"
        print "This will take effect after the index repo PR is merged."
    else:
        if ver.yanked:
            print "Version {version} of '{name}' is already yanked"
            return 0
        print "Yanking {name}@{version}..."
        warn("yank", "Index repo PR submission not implemented; cannot set yanked=true automatically")
        print "Submitted yank request for {name}@{version}"
        print "This will take effect after the index repo PR is merged."

    return 0
