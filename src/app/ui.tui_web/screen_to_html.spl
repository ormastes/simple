# ANSI-to-HTML Converter
#
# Converts TUI Screen.render() output (containing ANSI escape sequences)
# into HTML with CSS color spans. Strips terminal control sequences
# (cursor movement, line clearing) and translates color/style codes
# into inline CSS.

val ESC_CHAR: text = "\u{001b}"

# =========================================================================
# ANSI 256-Color to CSS Mapping
# =========================================================================

fn ansi_color_to_css(code: i32) -> text:
    """Map ANSI 256-color code to CSS color string.
    0-7: standard colors, 8-15: bright colors,
    16-231: 6x6x6 color cube, 232-255: grayscale."""
    # Standard colors (0-7)
    if code == 0:
        return "#000000"
    if code == 1:
        return "#cd0000"
    if code == 2:
        return "#00cd00"
    if code == 3:
        return "#cdcd00"
    if code == 4:
        return "#0000ee"
    if code == 5:
        return "#cd00cd"
    if code == 6:
        return "#00cdcd"
    if code == 7:
        return "#e5e5e5"
    # Bright colors (8-15)
    if code == 8:
        return "#7f7f7f"
    if code == 9:
        return "#ff0000"
    if code == 10:
        return "#00ff00"
    if code == 11:
        return "#ffff00"
    if code == 12:
        return "#5c5cff"
    if code == 13:
        return "#ff00ff"
    if code == 14:
        return "#00ffff"
    if code == 15:
        return "#ffffff"
    # 6x6x6 color cube (16-231)
    if code >= 16 and code <= 231:
        val idx = code - 16
        val b_val = idx % 6
        val g_val = (idx / 6) % 6
        val r_val = idx / 36
        val r = if r_val == 0: 0 else: 55 + r_val * 40
        val g = if g_val == 0: 0 else: 55 + g_val * 40
        val b = if b_val == 0: 0 else: 55 + b_val * 40
        return _rgb_to_hex(r, g, b)
    # Grayscale ramp (232-255)
    if code >= 232 and code <= 255:
        val level = 8 + (code - 232) * 10
        return _rgb_to_hex(level, level, level)
    return "#d4d4d4"

fn _rgb_to_hex(r: i32, g: i32, b: i32) -> text:
    """Convert RGB values to hex color string."""
    val rh = _byte_to_hex(r)
    val gh = _byte_to_hex(g)
    val bh = _byte_to_hex(b)
    return "#{rh}{gh}{bh}"

fn _byte_to_hex(n: i32) -> text:
    """Convert a byte value (0-255) to two-digit hex string."""
    val hi = n / 16
    val lo = n % 16
    val hi_ch = _nibble_to_hex(hi)
    val lo_ch = _nibble_to_hex(lo)
    return "{hi_ch}{lo_ch}"

fn _nibble_to_hex(n: i32) -> text:
    """Convert a nibble (0-15) to single hex character."""
    if n == 0: return "0"
    if n == 1: return "1"
    if n == 2: return "2"
    if n == 3: return "3"
    if n == 4: return "4"
    if n == 5: return "5"
    if n == 6: return "6"
    if n == 7: return "7"
    if n == 8: return "8"
    if n == 9: return "9"
    if n == 10: return "a"
    if n == 11: return "b"
    if n == 12: return "c"
    if n == 13: return "d"
    if n == 14: return "e"
    if n == 15: return "f"
    return "0"

# =========================================================================
# Basic ANSI Color Code to CSS
# =========================================================================

fn _basic_fg_to_css(code: i32) -> text:
    """Map basic ANSI foreground codes (30-37, 90-97) to CSS color."""
    if code == 30: return "#000000"
    if code == 31: return "#cd0000"
    if code == 32: return "#00cd00"
    if code == 33: return "#cdcd00"
    if code == 34: return "#0000ee"
    if code == 35: return "#cd00cd"
    if code == 36: return "#00cdcd"
    if code == 37: return "#e5e5e5"
    if code == 90: return "#7f7f7f"
    if code == 91: return "#ff0000"
    if code == 92: return "#00ff00"
    if code == 93: return "#ffff00"
    if code == 94: return "#5c5cff"
    if code == 95: return "#ff00ff"
    if code == 96: return "#00ffff"
    if code == 97: return "#ffffff"
    return ""

fn _basic_bg_to_css(code: i32) -> text:
    """Map basic ANSI background codes (40-47, 100-107) to CSS color."""
    if code == 40: return "#000000"
    if code == 41: return "#cd0000"
    if code == 42: return "#00cd00"
    if code == 43: return "#cdcd00"
    if code == 44: return "#0000ee"
    if code == 45: return "#cd00cd"
    if code == 46: return "#00cdcd"
    if code == 47: return "#e5e5e5"
    if code == 100: return "#7f7f7f"
    if code == 101: return "#ff0000"
    if code == 102: return "#00ff00"
    if code == 103: return "#ffff00"
    if code == 104: return "#5c5cff"
    if code == 105: return "#ff00ff"
    if code == 106: return "#00ffff"
    if code == 107: return "#ffffff"
    return ""

# =========================================================================
# HTML Escaping
# =========================================================================

fn _escape_html(input: text) -> text:
    """Escape HTML special characters in content text."""
    var result = ""
    var i = 0
    while i < input.len():
        val ch = input[i]
        if ch == "&":
            result = "{result}&amp;"
        elif ch == "<":
            result = "{result}&lt;"
        elif ch == ">":
            result = "{result}&gt;"
        elif ch == "\"":
            result = "{result}&quot;"
        else:
            result = "{result}{ch}"
        i = i + 1
    return result

# =========================================================================
# ANSI Sequence Parser
# =========================================================================

fn _is_digit(ch: text) -> bool:
    """Check if a character is a digit."""
    if ch == "0": return true
    if ch == "1": return true
    if ch == "2": return true
    if ch == "3": return true
    if ch == "4": return true
    if ch == "5": return true
    if ch == "6": return true
    if ch == "7": return true
    if ch == "8": return true
    if ch == "9": return true
    return false

fn _parse_int(s: text) -> i32:
    """Parse a text string as integer."""
    if s == "":
        return 0
    return s.to_int()

fn _split_semicolons(s: text) -> [text]:
    """Split a string by semicolons."""
    var parts: [text] = []
    var current = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == ";":
            parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
        i = i + 1
    parts = parts.push(current)
    return parts

# =========================================================================
# Style State
# =========================================================================

struct _StyleState:
    fg: text
    bg: text
    is_bold: bool

fn _default_style() -> _StyleState:
    return _StyleState(fg: "", bg: "", is_bold: false)

fn _style_to_span_open(state: _StyleState) -> text:
    """Generate an opening <span> tag from current style state.
    Returns empty string if no styling is active."""
    val has_fg = state.fg != ""
    val has_bg = state.bg != ""
    val has_bold = state.is_bold
    if not has_fg and not has_bg and not has_bold:
        return ""
    var css = ""
    if has_fg:
        css = "color:{state.fg}"
    if has_bg:
        if css != "":
            css = "{css};"
        css = "{css}background:{state.bg}"
    if has_bold:
        if css != "":
            css = "{css};"
        css = "{css}font-weight:bold"
    return "<span style=\"{css}\">"

fn _styles_equal(a: _StyleState, b: _StyleState) -> bool:
    """Check if two style states are identical."""
    if a.fg != b.fg:
        return false
    if a.bg != b.bg:
        return false
    if a.is_bold != b.is_bold:
        return false
    return true

# =========================================================================
# Main Converter
# =========================================================================

fn screen_to_html(rendered: text) -> text:
    """Convert Screen.render() output text (with ANSI escape sequences)
    into HTML with CSS color spans.

    Strips terminal control sequences (cursor positioning, line clearing,
    cursor hide/show, alt screen) and translates color/style codes into
    inline CSS spans.

    The output is wrapped in a <pre> block styled for dark-background
    monospace display."""

    var html = ""
    var style = _default_style()
    var span_open = false
    var i = 0
    val len = rendered.len()

    while i < len:
        val ch = rendered[i]

        # Check for ESC character (start of ANSI sequence)
        if ch == ESC_CHAR:
            # Must have at least ESC + [
            val next_i = i + 1
            if next_i < len:
                val next_ch = rendered[next_i]
                if next_ch == "[":
                    # Parse CSI sequence: ESC [ <params> <final_byte>
                    var param_str = ""
                    var j = i + 2
                    while j < len:
                        val pch = rendered[j]
                        val is_param_char = _is_digit(pch)
                        if is_param_char or pch == ";":
                            param_str = "{param_str}{pch}"
                            j = j + 1
                        else:
                            break
                    # j now points to the final byte (or end of string)
                    if j < len:
                        val final_byte = rendered[j]
                        if final_byte == "m":
                            # SGR (Select Graphic Rendition) sequence
                            val new_style = _apply_sgr(param_str, style)
                            val styles_changed = not _styles_equal(style, new_style)
                            if styles_changed:
                                # Close previous span if open
                                if span_open:
                                    html = "{html}</span>"
                                    span_open = false
                                style = new_style
                                # Open new span if needed
                                val open_tag = _style_to_span_open(style)
                                if open_tag != "":
                                    html = "{html}{open_tag}"
                                    span_open = true
                            i = j + 1
                        elif final_byte == "H" or final_byte == "f":
                            # Cursor position — skip (terminal control)
                            i = j + 1
                        elif final_byte == "J":
                            # Erase in display — skip
                            i = j + 1
                        elif final_byte == "K":
                            # Erase in line — skip
                            i = j + 1
                        elif final_byte == "h" or final_byte == "l":
                            # Private mode set/reset (e.g., cursor hide, alt screen)
                            i = j + 1
                        else:
                            # Unknown CSI sequence — skip
                            i = j + 1
                    else:
                        # Malformed sequence — skip ESC [
                        i = j
                else:
                    # Non-CSI escape — skip ESC + next char
                    i = i + 2
            else:
                # Trailing ESC at end — skip
                i = i + 1
        elif ch == "\n":
            html = "{html}\n"
            i = i + 1
        elif ch == "\r":
            # Skip carriage return
            i = i + 1
        else:
            # Regular character — escape HTML and append
            val escaped = _escape_html(ch)
            html = "{html}{escaped}"
            i = i + 1

    # Close any remaining open span
    if span_open:
        html = "{html}</span>"

    val wrapper_open = "<pre class=\"tui-screen\" style=\"font-family:monospace;background:#1e1e1e;color:#d4d4d4;padding:8px;margin:0;line-height:1.2;\">"
    val wrapper_close = "</pre>"
    return "{wrapper_open}{html}{wrapper_close}"

# =========================================================================
# SGR Parameter Processor
# =========================================================================

fn _apply_sgr(param_str: text, current: _StyleState) -> _StyleState:
    """Apply SGR (Select Graphic Rendition) parameters to the current style.
    Handles: 0 (reset), 1 (bold), 2 (dim), 30-37/90-97 (fg),
    38;5;N (256-color fg), 39 (default fg), 40-47/100-107 (bg),
    48;5;N (256-color bg), 49 (default bg),
    38;2;R;G;B (truecolor fg), 48;2;R;G;B (truecolor bg)."""
    if param_str == "" or param_str == "0":
        return _default_style()

    val parts = _split_semicolons(param_str)
    var fg = current.fg
    var bg = current.bg
    var is_bold = current.is_bold
    var idx = 0

    while idx < parts.len():
        val code = _parse_int(parts[idx])

        if code == 0:
            # Reset
            fg = ""
            bg = ""
            is_bold = false
        elif code == 1:
            # Bold
            is_bold = true
        elif code == 2:
            # Dim — treat as no-op for HTML (no standard dim in CSS)
            pass_dn
        elif code >= 30 and code <= 37:
            # Basic foreground color
            fg = _basic_fg_to_css(code)
        elif code == 38:
            # Extended foreground: 38;5;N or 38;2;R;G;B
            val next_idx = idx + 1
            if next_idx < parts.len():
                val sub = _parse_int(parts[next_idx])
                if sub == 5:
                    # 256-color: 38;5;N
                    val color_idx = idx + 2
                    if color_idx < parts.len():
                        val n = _parse_int(parts[color_idx])
                        fg = ansi_color_to_css(n)
                        idx = color_idx
                    else:
                        idx = next_idx
                elif sub == 2:
                    # Truecolor: 38;2;R;G;B
                    val r_idx = idx + 2
                    val g_idx = idx + 3
                    val b_idx = idx + 4
                    if b_idx < parts.len():
                        val r = _parse_int(parts[r_idx])
                        val g = _parse_int(parts[g_idx])
                        val b = _parse_int(parts[b_idx])
                        fg = _rgb_to_hex(r, g, b)
                        idx = b_idx
                    else:
                        idx = next_idx
                else:
                    idx = next_idx
            else:
                pass_dn
        elif code == 39:
            # Default foreground
            fg = ""
        elif code >= 40 and code <= 47:
            # Basic background color
            bg = _basic_bg_to_css(code)
        elif code == 48:
            # Extended background: 48;5;N or 48;2;R;G;B
            val next_idx = idx + 1
            if next_idx < parts.len():
                val sub = _parse_int(parts[next_idx])
                if sub == 5:
                    # 256-color: 48;5;N
                    val color_idx = idx + 2
                    if color_idx < parts.len():
                        val n = _parse_int(parts[color_idx])
                        bg = ansi_color_to_css(n)
                        idx = color_idx
                    else:
                        idx = next_idx
                elif sub == 2:
                    # Truecolor: 48;2;R;G;B
                    val r_idx = idx + 2
                    val g_idx = idx + 3
                    val b_idx = idx + 4
                    if b_idx < parts.len():
                        val r = _parse_int(parts[r_idx])
                        val g = _parse_int(parts[g_idx])
                        val b = _parse_int(parts[b_idx])
                        bg = _rgb_to_hex(r, g, b)
                        idx = b_idx
                    else:
                        idx = next_idx
                else:
                    idx = next_idx
            else:
                pass_dn
        elif code == 49:
            # Default background
            bg = ""
        elif code >= 90 and code <= 97:
            # Bright foreground color
            fg = _basic_fg_to_css(code)
        elif code >= 100 and code <= 107:
            # Bright background color
            bg = _basic_bg_to_css(code)
        else:
            pass_dn

        idx = idx + 1

    return _StyleState(fg: fg, bg: bg, is_bold: is_bold)
