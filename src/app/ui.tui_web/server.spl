# TUI Web Server
#
# HTTP+WebSocket server that wraps TuiWebBackend and serves
# TUI-style HTML output over the network. Allows TUI apps to be
# viewed and interacted with in a browser or via HTTP clients.

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use common.ui.widget.{UIState, UITree, UIEvent}
use common.ui.parse.sdn.{parse_ui_file}
use common.ui.state.{init_state, update_state, update_tree}
use common.ui.event.{process_event}
use app.ui.tui_web.backend.{TuiWebBackend}
use app.ui.tui_web.html.{generate_tui_html_page}
use app.ui.tui_web.screen_to_html.{screen_to_html}
use app.ui.web.ws_handler.{extract_ws_key, compute_ws_accept, send_ws_text, escape_json_string}
use app.ui.test_api.handler.{handle_test_request}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# TUI Web Server
# =========================================================================

class TuiWebServer:
    port: i32
    state: UIState
    backend: TuiWebBackend
    file_path: text
    last_file_content: text

    static fn new(file_path: text, port: i32) -> Result<TuiWebServer, text>:
        """Create a TUI web server by parsing the UI file."""
        val tree_result = parse_ui_file(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                val state = init_state(tree)
                var backend = TuiWebBackend.new()
                val init_result = backend.init()
                match init_result:
                    Err(e):
                        return Err("Backend init failed: {e}")
                    Ok(_):
                        pass_dn

                # Initial render
                val render_result = backend.render(state)
                match render_result:
                    Err(e):
                        return Err("Initial render failed: {e}")
                    Ok(_):
                        pass_dn

                val content = if rt_file_exists(file_path):
                    rt_file_read_text(file_path)
                else:
                    ""
                return Ok(TuiWebServer(
                    port: port,
                    state: state,
                    backend: backend,
                    file_path: file_path,
                    last_file_content: content
                ))

    fn start():
        """Start the HTTP+WebSocket server."""
        print "Starting TUI Web Proxy on port {self.port}..."
        print "Open http://localhost:{self.port} in your browser"
        print "Press Ctrl+C to stop"
        print ""

        match TcpListener.bind("0.0.0.0:{self.port}"):
            Err(e):
                print "Error: Failed to bind to port {self.port}: {e}"
                return
            Ok(listener):
                self.serve_loop(listener)

    fn serve_loop(listener: TcpListener):
        """Main server loop -- accept and handle connections."""
        loop:
            match listener.accept():
                Ok(stream):
                    self.handle_connection(stream)
                Err(e):
                    print "Accept error: {e}"

    me handle_connection(stream: TcpStream):
        """Handle a single HTTP connection. Routes to HTML page, API, WS, or test API."""
        match stream.read_line():
            Err(e):
                print "Error reading request: {e}"
            Ok(request_line):
                # Check for file changes before each response
                self.check_file_changes()

                val parts = request_line.split(" ")
                if parts.len() < 2:
                    return

                val method = parts[0]
                val path = parts[1]

                # Read remaining headers
                var headers = ""
                var is_ws = false
                var content_length = 0
                loop:
                    match stream.read_line():
                        Ok(header_line):
                            if header_line.trim() == "":
                                break
                            headers = "{headers}{header_line}\n"
                            if header_line.contains("Upgrade: websocket"):
                                is_ws = true
                            if header_line.starts_with("Content-Length:"):
                                val len_str = header_line[15:]
                                val trimmed_len = len_str.trim()
                                content_length = trimmed_len.to_int()
                        Err(_):
                            break

                # Read body for POST requests
                var body = ""
                if method == "POST" and content_length > 0:
                    match stream.read_bytes(content_length):
                        Ok(data):
                            body = data
                        Err(_):
                            pass_dn

                # WebSocket upgrade
                if is_ws:
                    self.handle_ws_connection(stream, headers)
                    return

                # Route HTTP requests
                if path == "/":
                    val tui_html = self.backend.current_html
                    val page = generate_tui_html_page(tui_html, self.port)
                    val response = http_response(200, "text/html", page)
                    stream.write_all(response)
                elif path == "/api/state":
                    val state_json = _state_to_json(self.state)
                    val response = http_response(200, "application/json", state_json)
                    stream.write_all(response)
                elif path == "/api/widgets":
                    val widgets_json = _widgets_to_json(self.state)
                    val response = http_response(200, "application/json", widgets_json)
                    stream.write_all(response)
                elif path.starts_with("/api/test/"):
                    # Delegate to test API handler
                    val inject_fn = \event: self.backend.push_event(event)
                    val result = handle_test_request(path, method, body, self.state, inject_fn)
                    val response = http_response(result.0, result.1, result.2)
                    stream.write_all(response)
                else:
                    val response = http_response(404, "text/plain", "Not Found")
                    stream.write_all(response)

    me check_file_changes():
        """Check if the .ui.sdn file has changed and reload if so."""
        if not rt_file_exists(self.file_path):
            return

        val current_content = rt_file_read_text(self.file_path)
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_file(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.state = update_tree(self.state, new_tree)
                    # Re-render with updated state
                    val render_result = self.backend.render(self.state)
                    match render_result:
                        Err(e):
                            print "Warning: Re-render failed: {e}"
                        Ok(_):
                            pass_dn
                Err(e):
                    print "Warning: UI parse error: {e}"

    me handle_ws_connection(stream: TcpStream, headers: text):
        """Upgrade to WebSocket, send initial render, then loop reading events."""
        val key = extract_ws_key(headers)
        if key == "":
            return

        val accept = compute_ws_accept(key)

        var response = "HTTP/1.1 101 Switching Protocols\r\n"
        response = "{response}Upgrade: websocket\r\n"
        response = "{response}Connection: Upgrade\r\n"
        response = "{response}Sec-WebSocket-Accept: {accept}\r\n"
        response = "{response}\r\n"
        stream.write_all(response)

        # Send initial TUI HTML render via WebSocket
        val tui_html = self.backend.current_html
        val escaped = escape_json_string(tui_html)
        val msg = "{\"type\": \"render\", \"html\": \"{escaped}\"}"
        send_ws_text(stream, msg)

        # Read loop for incoming WebSocket messages (events from browser)
        loop:
            match stream.read_ws_frame():
                Ok(frame_data):
                    if frame_data == "":
                        break
                    # Parse event from JSON-like message
                    val event = _parse_ws_event(frame_data)
                    if event != nil:
                        self.backend.push_event(event)
                        # Process event and re-render
                        self.state = update_state(self.state, event)
                        val render_result = self.backend.render(self.state)
                        match render_result:
                            Err(_):
                                pass_dn
                            Ok(_):
                                # Send updated render
                                val updated_html = self.backend.current_html
                                val esc = escape_json_string(updated_html)
                                val update_msg = "{\"type\": \"render\", \"html\": \"{esc}\"}"
                                send_ws_text(stream, update_msg)
                Err(_):
                    break

# =========================================================================
# HTTP Response Helper
# =========================================================================

fn http_response(status: i32, content_type: text, body: text) -> text:
    val status_text = match status:
        200: "OK"
        400: "Bad Request"
        404: "Not Found"
        405: "Method Not Allowed"
        500: "Internal Server Error"
        _: "OK"
    var response = "HTTP/1.1 {status} {status_text}\r\n"
    response = "{response}Content-Type: {content_type}\r\n"
    response = "{response}Content-Length: {body.len()}\r\n"
    response = "{response}Access-Control-Allow-Origin: *\r\n"
    response = "{response}Connection: close\r\n"
    response = "{response}\r\n"
    response = "{response}{body}"
    return response

# =========================================================================
# JSON Serialization
# =========================================================================

fn _state_to_json(state: UIState) -> text:
    var json = "{"
    json = "{json}\"mode\": \"{state.mode_name()}\","
    json = "{json}\"focused_id\": \"{state.focused_id}\","
    json = "{json}\"title\": \"{state.tree.title_text()}\","
    json = "{json}\"theme\": \"{state.tree.theme_name()}\""
    json = "{json}}"
    return json

fn _widgets_to_json(state: UIState) -> text:
    val ids = state.tree.all_widget_ids()
    var items = ""
    var first = true
    for id in ids:
        val widget = state.tree.find_widget(id)
        if widget != nil:
            val sep = if first: "" else: ","
            first = false
            val summary = widget.widget_summary()
            items = "{items}{sep}{\"id\": \"{id}\", \"summary\": \"{summary}\"}"
    return "[{items}]"

# =========================================================================
# WebSocket Event Parsing
# =========================================================================

fn _parse_ws_event(data: text) -> UIEvent?:
    """Parse a JSON WebSocket message into a UIEvent.
    Expected formats:
      {"type":"key","key":"j"}
      {"type":"focus","id":"panel1"}
      {"type":"action","name":"click_btn1"}
    """
    # Simple JSON field extraction
    val event_type = _extract_field(data, "type")

    if event_type == "key":
        val key = _extract_field(data, "key")
        if key != "":
            return UIEvent.KeyPress(key: key)
    elif event_type == "focus":
        val id = _extract_field(data, "id")
        if id != "":
            return UIEvent.Action(name: "focus_{id}")
    elif event_type == "action":
        val name = _extract_field(data, "name")
        if name != "":
            return UIEvent.Action(name: name)

    return nil

fn _extract_field(json: text, field: text) -> text:
    """Extract a string field value from a simple JSON object."""
    val search = "\"{field}\""
    val idx = json.find(search)
    if idx < 0:
        return ""

    # Find the colon after the field name
    var pos = idx + search.len()
    while pos < json.len() and json[pos] != ":":
        pos = pos + 1
    pos = pos + 1

    # Skip whitespace
    while pos < json.len() and (json[pos] == " " or json[pos] == "\t"):
        pos = pos + 1

    # Expect opening quote
    if pos >= json.len() or json[pos] != "\"":
        return ""
    pos = pos + 1

    # Read until closing quote
    var value = ""
    while pos < json.len() and json[pos] != "\"":
        val ch = json[pos]
        if ch == "\\":
            pos = pos + 1
            if pos < json.len():
                value = "{value}{json[pos]}"
        else:
            value = "{value}{ch}"
        pos = pos + 1

    return value
