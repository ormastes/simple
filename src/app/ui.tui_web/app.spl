# TUI Web App Entry Point
#
# Provides the run_tui_web function that creates a TuiWebServer
# and starts serving TUI output over HTTP+WebSocket.

use app.ui.tui_web.server.{TuiWebServer}
use app.io.env_ops.{env_get}
use common.window_protocol.geometry.{Size}
use os.compositor.host_compositor_entry.{HostBackendKind, HostWmConfig, HostWmHandle, init_host_wm}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_cli_get_args() -> [text]

# =========================================================================
# Shared WM helpers
# =========================================================================

fn _shared_wm_requested(args: [text]) -> bool:
    for a in args:
        if a == "--shared-wm":
            return true
    val env_val = env_get("SIMPLE_UI_TUI_WEB_SHARED_WM")
    env_val == "1"

fn run_shared_wm_tui_web(title: text) -> i64:
    val config = HostWmConfig(
        backend: HostBackendKind.Tui,
        initial_size: Size.wh(80, 24),
        title: title
    )
    val handle = init_host_wm(config)
    if handle == nil:
        print "Error: failed to initialise shared WM (Tui backend)"
        return 1
    handle.tick_forever()
    return 0

# =========================================================================
# Entry Point
# =========================================================================

fn run_tui_web(file_path: text, port: i32) -> i64:
    return run_tui_web_with_access_store(file_path, port, "")

fn run_tui_web_with_access_store(file_path: text, port: i32, access_db_path: text) -> i64:
    """Start the TUI web proxy server for a .ui.sdn file.

    Creates a TuiWebServer that renders the UI as a TUI-style
    terminal view and serves it over HTTP with WebSocket live updates.
    """
    val args = rt_cli_get_args()
    if _shared_wm_requested(args):
        return run_shared_wm_tui_web("simple tui_web")

    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    print "TUI Web Proxy"
    print "  File: {file_path}"
    print "  URL:  http://localhost:{port}"
    print ""

    val server_result = TuiWebServer.new_with_access_store_path(file_path, port, access_db_path)
    match server_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(server):
            server.start()
            return 0
