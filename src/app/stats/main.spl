# Project statistics aggregation and reporting.
# Startup-light entrypoint for shared CLI log/progress preflight.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.io.mod.{process_run}

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("stats", log_opts.error)
        return 1

    val args = stats_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h"):
        print_help_with_progress(log_opts.progress)
        return 0

    val file_count = count_project_files()
    if log_opts.log_mode == "json":
        print "{\"command\":\"stats\",\"status\":\"ok\",\"files\":{file_count}}"
        return 0

    val progress = render_progress(log_opts.progress, 1, 1, "stats")
    if progress != "":
        print progress
    print "Project statistics"
    print "Files scanned: {file_count}"
    0

fn print_help():
    print "Usage: simple stats [options]"
    print ""
    print "Show project statistics without loading the compiler tooling graph."
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn count_project_files() -> text:
    val (stdout, stderr, code) = process_run("/bin/sh", [
        "-c",
        "find src test doc -type f 2>/dev/null | wc -l | tr -d ' '"
    ])
    if code != 0:
        return "0"
    stdout.trim()

fn stats_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn stats_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if stats_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
