#![allow(unnamed_duplicate_typed_args)]
# MCP UI Tools
#
# Provides MCP tool definitions for LLM-controllable UI modifications.
# Tools allow an AI agent to inspect and modify .ui.sdn files and
# query the current UI state.

use common.sdn.document.{SdnDocument}
use common.ui.widget.{UIState, UITree, UIEvent, WidgetNode}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}

extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# MCP Tool Definitions
# =========================================================================

class McpUiTools:
    file_path: text

    static fn new(file_path: text) -> McpUiTools:
        return McpUiTools(file_path: file_path)

    # ----- ui_render_file -----
    fn ui_render_file() -> Result<text, text>:
        """Parse and render a .ui.sdn file, returning a widget tree summary."""
        val tree_result = parse_ui_to_tree(self.file_path)
        match tree_result:
            Err(e) =>
                return Err(e)
            Ok(tree) =>
                val ids = tree.all_widget_ids()
                var summary = "UI Tree: {tree.title_text()} (theme: {tree.theme_name()})\n"
                summary = "{summary}Widgets ({ids.len()}):\n"
                for id in ids:
                    val widget = tree.find_widget(id)
                    if widget != nil:
                        summary = "{summary}  - {widget.widget_summary()}\n"
                return Ok(summary)

    # ----- ui_list_widgets -----
    fn ui_list_widgets() -> Result<text, text>:
        """List all widget IDs with their types."""
        val tree_result = parse_ui_to_tree(self.file_path)
        match tree_result:
            Err(e) => return Err(e)
            Ok(tree) =>
                val ids = tree.all_widget_ids()
                var result = ""
                for id in ids:
                    val widget = tree.find_widget(id)
                    if widget != nil:
                        result = "{result}{widget.widget_summary()}\n"
                return Ok(result)

    # ----- ui_get_state -----
    fn ui_get_state() -> Result<text, text>:
        """Get the current UI state (mode, focused widget, visible widgets)."""
        val tree_result = parse_ui_to_tree(self.file_path)
        match tree_result:
            Err(e) => return Err(e)
            Ok(tree) =>
                val state = init_state(tree)
                var result = "Mode: {state.mode_name()}\n"
                result = "{result}Focused: {state.focused_id}\n"
                result = "{result}Title: {tree.title_text()}\n"
                result = "{result}Theme: {tree.theme_name()}\n"
                val ids = tree.all_widget_ids()
                result = "{result}Widgets: {ids.len()}\n"
                return Ok(result)

    # ----- ui_set_widget -----
    fn ui_set_widget(widget_id: text, prop: text, value: text) -> Result<text, text>:
        """Modify a widget property by writing to the .ui.sdn file."""
        val doc_result = SdnDocument.from_file(self.file_path)
        match doc_result:
            Err(e) =>
                return Err("Failed to load file: {e}")
            Ok(doc) =>
                # Find the widget's SDN path
                val sdn_path = find_widget_sdn_path(doc, widget_id)
                if sdn_path == "":
                    return Err("Widget not found: {widget_id}")

                # Set the property
                val full_path = "{sdn_path}.{prop}"
                doc.set(full_path, value)

                # Write back
                val write_result = doc.write_file(self.file_path)
                match write_result:
                    Err(e) =>
                        return Err("Failed to write: {e}")
                    Ok(_) =>
                        return Ok("Set {widget_id}.{prop} = {value}")

    # ----- ui_add_widget -----
    fn ui_add_widget(parent_id: text, widget_type: text, widget_id: text) -> Result<text, text>:
        """Add a new widget to a parent container."""
        val doc_result = SdnDocument.from_file(self.file_path)
        match doc_result:
            Err(e) =>
                return Err("Failed to load file: {e}")
            Ok(doc) =>
                val parent_path = find_widget_sdn_path(doc, parent_id)
                if parent_path == "":
                    return Err("Parent not found: {parent_id}")

                # Count existing children to find next index
                var idx = 0
                var has_more = true
                while has_more:
                    val check_path = "{parent_path}.children.{idx}"
                    val check_val = doc.get("{check_path}.type")
                    if check_val != nil:
                        idx = idx + 1
                    else:
                        has_more = false

                # Add new widget
                val new_path = "{parent_path}.children.{idx}"
                doc.set("{new_path}.type", widget_type)
                doc.set("{new_path}.id", widget_id)

                val write_result = doc.write_file(self.file_path)
                match write_result:
                    Err(e) =>
                        return Err("Failed to write: {e}")
                    Ok(_) =>
                        return Ok("Added {widget_type} '{widget_id}' to {parent_id}")

    # ----- ui_remove_widget -----
    fn ui_remove_widget(widget_id: text) -> Result<text, text>:
        """Remove a widget by ID."""
        val doc_result = SdnDocument.from_file(self.file_path)
        match doc_result:
            Err(e) =>
                return Err("Failed to load file: {e}")
            Ok(doc) =>
                val sdn_path = find_widget_sdn_path(doc, widget_id)
                if sdn_path == "":
                    return Err("Widget not found: {widget_id}")

                doc.delete(sdn_path)
                val write_result = doc.write_file(self.file_path)
                match write_result:
                    Err(e) =>
                        return Err("Failed to write: {e}")
                    Ok(_) =>
                        return Ok("Removed widget: {widget_id}")

    # ----- ui_send_event -----
    fn ui_send_event(event_type: text, event_data: text) -> Result<text, text>:
        """Simulate an event (key press or action)."""
        val tree_result = parse_ui_to_tree(self.file_path)
        match tree_result:
            Err(e) => return Err(e)
            Ok(tree) =>
                val state = init_state(tree)
                val event = match event_type:
                    "key" => UIEvent.KeyPress(key: event_data)
                    "action" => UIEvent.Action(name: event_data)
                    "quit" => UIEvent.Quit
                    "focus_next" => UIEvent.FocusNext
                    "focus_prev" => UIEvent.FocusPrev
                    _ => UIEvent.Action(name: event_data)
                return Ok("Event sent: {event_type} {event_data}")

# =========================================================================
# SDN Path Helpers
# =========================================================================

fn find_widget_sdn_path(doc: SdnDocument, widget_id: text) -> text:
    """Search the SDN document tree to find the path for a widget ID."""
    return search_widget_path(doc, "layout", widget_id)

fn search_widget_path(doc: SdnDocument, path: text, target_id: text) -> text:
    """Recursively search for a widget by ID in the SDN tree."""
    val id_val = doc.get("{path}.id")
    if id_val != nil and "{id_val}" == target_id:
        return path

    # Search children
    var idx = 0
    var has_more = true
    while has_more:
        val child_path = "{path}.children.{idx}"
        val child_type = doc.get("{child_path}.type")
        if child_type != nil:
            val found = search_widget_path(doc, child_path, target_id)
            if found != "":
                return found
            idx = idx + 1
        else:
            has_more = false

    return ""
