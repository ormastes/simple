{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "outDir": "../vscode_extension/out/rich",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "vscode": ["../vscode_extension/node_modules/@types/vscode/index.d.ts"],
      "katex": ["../vscode_extension/node_modules/katex/katex.d.ts"],
      "*": ["../vscode_extension/node_modules/*", "../vscode_extension/node_modules/@types/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/webview"]
}
