# MCP Lazy Server - JSON helpers
# Extracted from main_lazy.spl

# --- Safe string helpers (workaround for 2-arg substring bug) ---

fn strip_last(s: text) -> text:
    val n = s.len()
    if n <= 0:
        return ""
    s.substring(0, n - 1)

fn strip_first_last(s: text) -> text:
    strip_last(s.substring(1))

fn first_n_chars(s: text, n: i64) -> text:
    var parts: [text] = []
    var count = 0
    for ch in s:
        if count >= n:
            break
        parts.push(ch)
        count = count + 1
    parts.join("")

fn char_at_index(s: text, target: i64) -> text:
    var i = 0
    for ch in s:
        if i == target:
            return ch
        i = i + 1
    ""

# --- JSON helpers (inlined for zero-import startup) ---

fn Q() -> text:
    "\""

fn LB() -> text:
    "{"

fn RB() -> text:
    "}"

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

fn escape_json(s: text) -> text:
    var result = s
    result = result.replace(r"\", r"\\")
    result = result.replace(Q(), r"\" + Q())
    result = result.replace("\n", r"\n")
    result = result.replace("\r", r"\r")
    result = result.replace("\t", r"\t")
    result

fn js(s: text) -> text:
    Q() + escape_json(s) + Q()

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

fn jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + RB()

# Manual JSON value scanner.
#
# NOTE: These helpers use manual character scanning rather than
# `text.index_of()` + `match Some(i)`. There is a Cranelift codegen
# bug where `match idx_opt: Some(i): ... nil: ...` on the result of
# `index_of()` segfaults at runtime in native binaries. The manual
# scanner pattern below is the same one used successfully in
# examples/10_tooling/trace32_tools/t32_mcp/frontend_cold.spl.
# Do NOT re-introduce `match Some(i)` on `index_of` results here.

fn _char_at(s: text, i: i64) -> text:
    s.substring(i, i + 1)

fn _is_ws(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn _find_json_value_start(json: text, key: text) -> i64:
    val search = Q() + key + Q()
    var offset = 0
    while offset + search.len() <= json.len():
        var matches = true
        var j = 0
        while j < search.len():
            if json.substring(offset + j, offset + j + 1) != search.substring(j, j + 1):
                matches = false
                break
            j = j + 1
        if not matches:
            offset = offset + 1
            continue
        var value_start = offset + search.len()
        while value_start < json.len() and _is_ws(_char_at(json, value_start)):
            value_start = value_start + 1
        if value_start < json.len() and _char_at(json, value_start) == ":":
            value_start = value_start + 1
            while value_start < json.len() and _is_ws(_char_at(json, value_start)):
                value_start = value_start + 1
            return value_start
        offset = offset + search.len()
    return -1

fn extract_field(json: text, key: text) -> text:
    val start = _find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return ""
    val first = _char_at(json, start)
    if first == Q():
        var i = start + 1
        var escaped = false
        while i < json.len():
            val ch = _char_at(json, i)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return json.substring(start + 1, i)
            i = i + 1
        return ""
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == RB() or ch == SB_R() or _is_ws(ch):
            break
        end = end + 1
    return json.substring(start, end)

fn extract_field_raw(json: text, key: text) -> text:
    val start = _find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return "null"
    val first = _char_at(json, start)
    if first == Q():
        var i2 = start + 1
        var escaped = false
        while i2 < json.len():
            val ch = _char_at(json, i2)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return json.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    if first == LB() or first == SB_L():
        var depth = 0
        var i3 = start
        var in_str = false
        var esc = false
        while i3 < json.len():
            val ch = _char_at(json, i3)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_str = false
            else:
                if ch == Q():
                    in_str = true
                elif ch == LB() or ch == SB_L():
                    depth = depth + 1
                elif ch == RB() or ch == SB_R():
                    depth = depth - 1
                    if depth == 0:
                        return json.substring(start, i3 + 1)
            i3 = i3 + 1
        return "null"
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == RB() or ch == SB_R() or _is_ws(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    return raw

fn extract_id(json: text) -> text:
    extract_field_raw(json, "id")

fn extract_nested(json: text, key: text) -> text:
    val params = extract_field_raw(json, "params")
    if params == "null":
        return ""
    extract_field(params, key)

fn make_json_result(id: text, result: text) -> text:
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn make_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", str(code)), jp("message", js(message)))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

# --- MCP Tool Result helpers ---

fn infer_json_value_type(raw: text) -> text:
    val t = raw.trim()
    if t == "":
        return "empty"
    if t.starts_with("{"):
        return "object"
    if t.starts_with("["):
        return "array"
    if t.starts_with(Q()):
        return "string"
    if t == "true" or t == "false":
        return "boolean"
    if t == "null":
        return "null"
    var has_digit = false
    var all_num = true
    for ch in t:
        if ch >= "0" and ch <= "9":
            has_digit = true
        elif ch == "." or ch == "-" or ch == "+":
            pass
        else:
            all_num = false
            break
    if has_digit and all_num:
        return "number"
    "text"

fn top_level_item_count(raw: text) -> i64:
    val t = raw.trim()
    if t == "":
        return 0
    if not t.starts_with("[") and not t.starts_with("{"):
        return 1
    var depth = 0
    var in_string = false
    var escaped = false
    var count = 0
    var saw_value = false
    for ch in t:
        if in_string:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                in_string = false
            continue
        if ch == Q():
            in_string = true
            if depth == 1:
                saw_value = true
        elif ch == "[" or ch == "{":
            depth = depth + 1
            if depth == 2:
                saw_value = true
        elif ch == "]" or ch == "}":
            if depth == 1 and saw_value:
                count = count + 1
                saw_value = false
            depth = depth - 1
        elif ch == "," and depth == 1:
            count = count + 1
            saw_value = false
        elif depth == 1 and ch != " " and ch != "\n" and ch != "\r" and ch != "\t":
            saw_value = true
    if t.starts_with("[") or t.starts_with("{"):
        if count < 0:
            return 0
    count

fn summarize_json_shape(raw: text, depth: i64) -> text:
    val value_type = infer_json_value_type(raw)
    if depth <= 0:
        return value_type
    if value_type == "array":
        var inner = raw.trim()
        if inner.len() >= 2:
            inner = strip_first_last(inner).trim()
        var first = ""
        var d = 0
        var in_s = false
        var esc = false
        var parts: [text] = []
        for ch in inner:
            if in_s:
                parts.push(ch)
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_s = false
                continue
            if ch == Q():
                in_s = true
                parts.push(ch)
            elif ch == "[" or ch == "{":
                d = d + 1
                parts.push(ch)
            elif ch == "]" or ch == "}":
                d = d - 1
                parts.push(ch)
            elif ch == "," and d == 0:
                first = parts.join("").trim()
                break
            else:
                parts.push(ch)
        if first == "":
            first = parts.join("").trim()
        var elem_shape = "unknown"
        if first != "":
            elem_shape = summarize_json_shape(first, depth - 1)
        return "array<" + elem_shape + ">"
    if value_type == "object":
        var pair_count = 0
        var in_s = false
        var esc = false
        for ch in raw:
            if in_s:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_s = false
                continue
            if ch == Q():
                in_s = true
            elif ch == ":":
                pair_count = pair_count + 1
        val lb = "{"
        val rb = "}"
        return "object" + lb + "pairs=" + str(pair_count) + rb
    value_type

fn make_tool_result(id: text, output: text) -> text:
    val escaped = escape_json(output)
    val quoted = Q() + escaped + Q()
    val content = SB_L() + jo2(jp("type", js("text")), jp("text", quoted)) + SB_R()
    val inferred = infer_json_value_type(output)
    val shape = summarize_json_shape(output, 2)
    val structured = jo2(
        jp("inferredType", js(inferred)),
        jp("shape", js(shape))
    )
    val result = jo2(jp("content", content), jp("structuredContent", structured))
    make_json_result(id, result)

fn make_tool_error(id: text, code: i64, msg: text) -> text:
    val content = SB_L() + jo2(jp("type", js("text")), jp("text", js("ERROR " + str(code) + ": " + msg))) + SB_R()
    val structured = jo2(jp("code", str(code)), jp("message", js(msg)))
    var err_result = LB() + jp("content", content) + "," + jp("isError", "true") + "," + jp("structuredContent", structured) + RB()
    make_json_result(id, err_result)

# --- Shell helper ---
# Uses rt_process_run (returns tuple). Note: val (a,b) = expr is broken
# in interpreter, so we use var + assignment destructuring instead.

fn _mcp_detect_shell() -> text:
    # On Windows, /bin/sh doesn't resolve for native PE binaries.
    # Use "sh" (found on PATH via Git Bash/MSYS2) or fall back to "cmd".
    val os_env = rt_env_get("OS") ?? ""
    if os_env.contains("Windows"):
        # Check for sh on PATH (Git Bash / MSYS2)
        var sh_out = ""
        var sh_err = ""
        var sh_rc: i64 = 0
        (sh_out, sh_err, sh_rc) = rt_process_run("sh", ["-c", "echo ok"])
        if sh_rc == 0 and sh_out.trim() == "ok":
            return "sh"
        return "cmd"
    "/bin/sh"

fn _get_shell() -> text:
    _mcp_detect_shell()

fn strip_ansi(s: text) -> text:
    val shell = _get_shell()
    if shell == "cmd":
        # No ANSI stripping needed on Windows cmd
        return s
    var e_out = ""
    var e_err = ""
    var e_rc: i64 = 0
    (e_out, e_err, e_rc) = rt_process_run(shell, ["-c", r"printf '\033'"])
    if e_out == "" or not s.contains(e_out):
        return s
    s.replace(e_out, "")

fn _strip_timeout_prefix(command: text) -> text:
    """Strip Unix 'timeout N' prefix for cmd.exe compatibility.
    Git Bash has coreutils timeout, so only strip for cmd."""
    if not command.starts_with("timeout "):
        return command
    # Skip "timeout " then skip the number and trailing space
    var i = 8
    var found_digit = false
    for ch in command[8:]:
        if ch >= "0" and ch <= "9":
            i = i + 1
            found_digit = true
        elif ch == " " and found_digit:
            i = i + 1
            return command[i:]
        else:
            return command
    command

fn shell_cmd(command: text) -> (text, i64):
    var stdout = ""
    var stderr = ""
    var code: i64 = 0
    val shell = _get_shell()
    if shell == "cmd":
        # Strip Unix timeout prefix — cmd.exe doesn't have coreutils timeout
        val cmd = _strip_timeout_prefix(command)
        (stdout, stderr, code) = rt_process_run("cmd", ["/C", cmd])
    elif shell == "sh":
        # Windows Git Bash: < /dev/null breaks piped commands, so omit it
        (stdout, stderr, code) = rt_process_run(shell, ["-c", "export NO_COLOR=1 TERM=dumb; " + command])
    else:
        (stdout, stderr, code) = rt_process_run(shell, ["-c", "export NO_COLOR=1 TERM=dumb; " + command + " < /dev/null"])
    if stdout != "":
        stdout = strip_ansi(stdout)
    (stdout, code)

fn text_byte_len(s: text) -> i64:
    s.len()

fn file_read(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn file_write(path: text, content: text) -> bool:
    rt_file_write_text(path, content) ?? false
