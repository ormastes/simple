# MCP Lazy Server - CLI tool handlers (Tier 1)
# Handles: simple_test, simple_build, simple_format, simple_lint, simple_fix, simple_doc_coverage
#
# Uses shell_cmd() with timeout wrappers to prevent indefinite blocking.
# IMPORTANT: Cannot use bg_task_spawn() — module vars (BG_NEXT_TASK_ID, BG_TASKS)
# from imported modules are not accessible in interpreter mode.
# Cannot use rt_process_execute — not registered in current runtime binary.
# Must use shell_cmd() which uses rt_process_run (tuple destructuring works).

# ============================================================================
# simple_test — Run tests (timeout 600s)
# ============================================================================

fn handle_simple_test(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val filter_str = extract_field(body, "filter")
    val only_slow = extract_field(body, "only_slow")
    val list_flag = extract_field(body, "list")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 600 " + _bin + " test"
    if list_flag == "true":
        # --list produces ~29K lines; redirect to file then show summary.
        # Limit output to 50 lines to avoid large JSON response buffer issues.
        val _tmp = rt_env_get("TEMP") ?? rt_env_get("TMP") ?? "/tmp"
        cmd = "timeout 30 " + _bin + " test --list 1>" + _tmp + "/mcp_test_list.txt 2>/dev/null; echo '--- test list (first 50 of '$(wc -l < " + _tmp + "/mcp_test_list.txt)' total) ---'; head -50 " + _tmp + "/mcp_test_list.txt"
    elif path != "":
        cmd = cmd + " " + path
    if filter_str != "":
        cmd = cmd + " --filter " + filter_str
    if only_slow == "true":
        cmd = cmd + " --only-slow"
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_test", cmd, "600s")

# ============================================================================
# simple_build — Build project (timeout 300s)
# ============================================================================

fn handle_simple_build(id: text, body: text) -> text:
    val release = extract_field(body, "release")
    val target = extract_field(body, "target")
    val warn_docs = extract_field(body, "warn_docs")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 300 " + _bin + " build"
    if release == "true":
        cmd = cmd + " --release"
    if target != "":
        cmd = cmd + " --target " + target
    if warn_docs == "true":
        cmd = cmd + " --warn-docs"
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_build", cmd, "300s")

# ============================================================================
# simple_format — Format file or project (timeout 60s)
# ============================================================================

fn handle_simple_format(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val check = extract_field(body, "check")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 60 " + _bin + " fmt"
    if check == "true":
        cmd = cmd + " --check"
    if path != "":
        cmd = cmd + " " + path
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_format", cmd, "60s")

# ============================================================================
# simple_lint — Lint with output (timeout 60s)
# ============================================================================

fn handle_simple_lint(id: text, body: text) -> text:
    val path = extract_field(body, "path")

    val _bin = _mcp_find_simple_binary()
    # Project-wide lint can take >60s on large codebases; use 180s timeout.
    # Single-file lint is fast (<1s).
    val timeout_s = if path != "" then "60" else "180"
    var cmd = "timeout " + timeout_s + " " + _bin + " lint"
    if path != "":
        cmd = cmd + " " + path
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_lint", cmd, timeout_s + "s")

# ============================================================================
# simple_fix — Auto-fix issues (timeout 60s)
# ============================================================================

fn handle_simple_fix(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val dry_run = extract_field(body, "dry_run")

    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 60 " + _bin + " fix " + path
    if dry_run == "true":
        cmd = cmd + " --dry-run"
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_fix", cmd, "60s")

# ============================================================================
# simple_doc_coverage — Documentation coverage report (timeout 60s)
# ============================================================================

fn handle_simple_doc_coverage(id: text, body: text) -> text:
    val format_str = extract_field(body, "format")
    val missing = extract_field(body, "missing")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 60 " + _bin + " doc-coverage"
    if format_str != "":
        cmd = cmd + " --format=" + format_str
    if missing == "true":
        cmd = cmd + " --missing"
    cmd = cmd + " 2>&1"

    run_cli_tool(id, "simple_doc_coverage", cmd, "60s")

# ============================================================================
# simple_build_verbose — Build with full untruncated output (timeout 300s)
# ============================================================================

fn handle_simple_build_verbose(id: text, body: text) -> text:
    val release = extract_field(body, "release")
    val target = extract_field(body, "target")
    val warn_docs = extract_field(body, "warn_docs")

    val _bin = _mcp_find_simple_binary()
    var cmd = "timeout 300 " + _bin + " build"
    if release == "true":
        cmd = cmd + " --release"
    if target != "":
        cmd = cmd + " --target " + target
    if warn_docs == "true":
        cmd = cmd + " --warn-docs"
    cmd = cmd + " 2>&1"

    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = shell_cmd(cmd)

    var out_parts: [text] = []
    out_parts.push("-- simple_build_verbose --" + NL)
    out_parts.push(out)
    if exit_code == 0:
        out_parts.push(NL + "Build succeeded.")
    else:
        out_parts.push(NL + "Build FAILED (exit code " + str(exit_code) + ").")
    make_tool_result(id, out_parts.join(""))

