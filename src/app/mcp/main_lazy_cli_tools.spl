# MCP Lazy Server - CLI tool handlers (Tier 1)
# Handles: simple_test, simple_build, simple_format, simple_lint, simple_fix, simple_doc_coverage
#
# Long-running tools use bg_task_spawn() for async-with-wait:
# - Wait up to default_wait_ms for completion
# - If still running, return task handle for polling via task_status

# ============================================================================
# simple_test — Run tests (async, 10s wait)
# ============================================================================

fn handle_simple_test(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val filter_str = extract_field(body, "filter")
    val only_slow = extract_field(body, "only_slow")
    val list_flag = extract_field(body, "list")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " test"
    if list_flag == "true":
        cmd = cmd + " --list"
    elif path != "":
        cmd = cmd + " " + path
    if filter_str != "":
        cmd = cmd + " --filter " + filter_str
    if only_slow == "true":
        cmd = cmd + " --only-slow"

    val task = bg_task_spawn("simple_test", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)

# ============================================================================
# simple_build — Build project (async, 10s wait)
# ============================================================================

fn handle_simple_build(id: text, body: text) -> text:
    val release = extract_field(body, "release")
    val target = extract_field(body, "target")
    val warn_docs = extract_field(body, "warn_docs")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " build"
    if release == "true":
        cmd = cmd + " --release"
    if target != "":
        cmd = cmd + " --target " + target
    if warn_docs == "true":
        cmd = cmd + " --warn-docs"

    val task = bg_task_spawn("simple_build", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)

# ============================================================================
# simple_format — Format file or project (async, 10s wait)
# ============================================================================

fn handle_simple_format(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val check = extract_field(body, "check")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " fmt"
    if check == "true":
        cmd = cmd + " --check"
    if path != "":
        cmd = cmd + " " + path

    val task = bg_task_spawn("simple_format", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)

# ============================================================================
# simple_lint — Lint with output (async, 10s wait)
# ============================================================================

fn handle_simple_lint(id: text, body: text) -> text:
    val path = extract_field(body, "path")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " lint"
    if path != "":
        cmd = cmd + " " + path

    val task = bg_task_spawn("simple_lint", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)

# ============================================================================
# simple_fix — Auto-fix issues (async, 10s wait)
# ============================================================================

fn handle_simple_fix(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val dry_run = extract_field(body, "dry_run")

    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " fix " + path
    if dry_run == "true":
        cmd = cmd + " --dry-run"

    val task = bg_task_spawn("simple_fix", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)

# ============================================================================
# simple_doc_coverage — Documentation coverage report (async, 10s wait)
# ============================================================================

fn handle_simple_doc_coverage(id: text, body: text) -> text:
    val format_str = extract_field(body, "format")
    val missing = extract_field(body, "missing")

    val _bin = _mcp_find_simple_binary()
    var cmd = _bin + " doc-coverage"
    if format_str != "":
        cmd = cmd + " --format=" + format_str
    if missing == "true":
        cmd = cmd + " --missing"

    val task = bg_task_spawn("simple_doc_coverage", id, cmd, 10000)
    if task.status == "completed" or task.status == "failed":
        return make_tool_result(id, task_result_text(task))
    make_task_handle_response(id, task)
