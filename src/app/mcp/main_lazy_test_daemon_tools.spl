# MCP Lazy Server - Test Daemon tool handlers
# Handles: test_daemon_run, test_daemon_clean, test_daemon_status, test_daemon_stop
#
# Uses file-based IPC with the test daemon process via daemon_sdk.
# Auto-starts daemon on first request.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_hash_text(s: text) -> i64
extern fn rt_getpid() -> i64

# ============================================================================
# test_daemon_run — Run test with change detection
# ============================================================================

fn handle_test_daemon_run(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val filter_str = extract_field(body, "filter")
    val clean = extract_field(body, "clean")

    # Ensure daemon is running
    if not ensure_test_daemon():
        return make_tool_error(id, -32603, "Failed to start test daemon")

    # Build request
    val is_clean = clean == "true"
    val kind = if is_clean: 3 else: 1
    val req_id = build_and_submit_test_request(kind, path, filter_str)

    if req_id == "":
        # Fallback: run test directly
        val _bin = _mcp_find_simple_binary()
        var cmd = "timeout 600 " + _bin + " test"
        if path != "":
            cmd = cmd + " " + path
        if filter_str != "":
            cmd = cmd + " --filter " + filter_str
        cmd = cmd + " 2>&1"
        var out = ""
        var exit_code: i64 = 0
        (out, exit_code) = shell_cmd(cmd)
        var output = "-- test_daemon_run (fallback, exit: " + str(exit_code) + ") --\n" + out
        return make_tool_result(id, output)

    # Poll for result
    val resp = poll_test_response(req_id, 600000)
    if resp == "":
        return make_tool_result(id, "Test queued (request_id: " + req_id + "). Use test_daemon_status to check progress.")

    make_tool_result(id, resp)

# ============================================================================
# test_daemon_clean — Force-run test (bypass cache)
# ============================================================================

fn handle_test_daemon_clean(id: text, body: text) -> text:
    val path = extract_field(body, "path")

    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")

    if not ensure_test_daemon():
        return make_tool_error(id, -32603, "Failed to start test daemon")

    val req_id = build_and_submit_test_request(3, path, "")

    if req_id == "":
        val _bin = _mcp_find_simple_binary()
        val cmd = "timeout 600 " + _bin + " test " + path + " 2>&1"
        var out = ""
        var exit_code: i64 = 0
        (out, exit_code) = shell_cmd(cmd)
        var output = "-- test_daemon_clean (fallback, exit: " + str(exit_code) + ") --\n" + out
        return make_tool_result(id, output)

    val resp = poll_test_response(req_id, 600000)
    if resp == "":
        return make_tool_result(id, "Clean test queued (request_id: " + req_id + ")")

    make_tool_result(id, resp)

# ============================================================================
# test_daemon_status — Get daemon status
# ============================================================================

fn handle_test_daemon_status(id: text, body: text) -> text:
    val lock_path = ".build/test_daemon/test_daemon.lock"

    if not rt_file_exists(lock_path):
        return make_tool_result(id, "Test daemon: not running")

    val lock_content = rt_file_read_text(lock_path) ?? ""
    if lock_content == "":
        return make_tool_result(id, "Test daemon: not running (empty lock)")

    val lines = lock_content.split("\n")
    val pid_str = lines[0].trim()

    # Check if PID is alive
    extern fn rt_process_exists(pid: i64) -> bool
    val pid = pid_str.to_i64() ?? 0
    if pid <= 0 or not rt_process_exists(pid):
        return make_tool_result(id, "Test daemon: not running (stale lock, pid: " + pid_str + ")")

    # Submit status request
    val req_id = build_and_submit_test_request(4, "", "")
    if req_id == "":
        return make_tool_result(id, "Test daemon: running (pid: " + pid_str + ", status request failed)")

    val resp = poll_test_response(req_id, 5000)
    if resp == "":
        return make_tool_result(id, "Test daemon: running (pid: " + pid_str + ", status timeout)")

    make_tool_result(id, "Test daemon: running (pid: " + pid_str + ")\n" + resp)

# ============================================================================
# test_daemon_stop — Shut down test daemon
# ============================================================================

fn handle_test_daemon_stop(id: text, body: text) -> text:
    val lock_path = ".build/test_daemon/test_daemon.lock"

    if not rt_file_exists(lock_path):
        return make_tool_result(id, "Test daemon: already stopped")

    val req_id = build_and_submit_test_request(5, "", "")
    if req_id == "":
        return make_tool_result(id, "Test daemon: stop request failed")

    val resp = poll_test_response(req_id, 5000)
    make_tool_result(id, "Test daemon: stopped")

# ============================================================================
# Internal helpers — file-based IPC (no module imports)
# ============================================================================

fn ensure_test_daemon() -> bool:
    val lock_path = ".build/test_daemon/test_daemon.lock"

    if rt_file_exists(lock_path):
        val content = rt_file_read_text(lock_path) ?? ""
        if content != "":
            val lines = content.split("\n")
            val pid_str = lines[0].trim()
            val pid = pid_str.to_i64() ?? 0
            if pid > 0:
                extern fn rt_process_exists(pid: i64) -> bool
                if rt_process_exists(pid):
                    return true

    # Start daemon
    rt_mkdir_p(".build/test_daemon/requests")
    rt_mkdir_p(".build/test_daemon/responses")

    val _bin = _mcp_find_simple_binary()
    val cmd = _bin + " test-daemon start &"
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = shell_cmd(cmd)

    # Brief wait for daemon to acquire lock
    extern fn rt_sleep_ms(ms: i64)
    rt_sleep_ms(500)

    rt_file_exists(lock_path)

fn build_and_submit_test_request(kind: i64, test_path: text, filter: text) -> text:
    val request_dir = ".build/test_daemon/requests"
    rt_mkdir_p(request_dir)

    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    val req_id = "{pid}_{ts}"

    var content = "id={req_id}\n"
    content = content + "kind={kind}\n"
    content = content + "timestamp={ts}\n"
    if test_path != "":
        content = content + "field.test_path={test_path}\n"
    if filter != "":
        content = content + "field.filter={filter}\n"

    val hash = rt_hash_text(req_id)
    val req_path = "{request_dir}/{hash}_{req_id}.req"

    val tmp_path = "{req_path}.tmp"
    if rt_file_write_text(tmp_path, content):
        extern fn rt_file_rename(from: text, to: text) -> bool
        if rt_file_rename(tmp_path, req_path):
            return req_id
        extern fn rt_file_delete(path: text) -> bool
        rt_file_delete(tmp_path)

    if rt_file_write_text(req_path, content):
        return req_id
    ""

fn poll_test_response(request_id: text, timeout_ms: i64) -> text:
    val response_dir = ".build/test_daemon/responses"
    val resp_path = "{response_dir}/{request_id}.resp"
    val deadline = rt_time_now_unix_micros() + (timeout_ms * 1000)

    extern fn rt_sleep_ms(ms: i64)
    var attempts = 0
    while rt_time_now_unix_micros() < deadline and attempts < 6000:
        if rt_file_exists(resp_path):
            val content = rt_file_read_text(resp_path) ?? ""
            if content != "":
                return format_test_response(content)
        rt_sleep_ms(100)
        attempts = attempts + 1

    ""

fn format_test_response(content: text) -> text:
    var status_str = ""
    var test_path = ""
    var passed = ""
    var failed = ""
    var skipped = ""
    var duration = ""
    var output = ""
    var cached = ""

    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("status="):
            val code = line.substring(7)
            if code == "2":
                status_str = "COMPLETED"
            elif code == "3":
                status_str = "FAILED"
            elif code == "6":
                status_str = "CACHED"
            elif code == "0":
                status_str = "QUEUED"
            elif code == "1":
                status_str = "RUNNING"
            else:
                status_str = "STATUS:" + code
        elif line.starts_with("field.test_path="):
            test_path = line.substring(16)
        elif line.starts_with("field.passed="):
            passed = line.substring(13)
        elif line.starts_with("field.failed="):
            failed = line.substring(13)
        elif line.starts_with("field.skipped="):
            skipped = line.substring(14)
        elif line.starts_with("field.duration_ms="):
            duration = line.substring(18)
        elif line.starts_with("field.output="):
            output = line.substring(13)
        elif line.starts_with("field.cached="):
            cached = line.substring(13)
        elif line.starts_with("field.daemon_status="):
            status_str = line.substring(20)
        elif line.starts_with("field.items_processed="):
            output = output + "items_processed: " + line.substring(22) + "\n"
        elif line.starts_with("field.cache_entries="):
            output = output + "cache_entries: " + line.substring(19) + "\n"
        elif line.starts_with("field.qemu_active="):
            output = output + "qemu_active: " + line.substring(18) + "\n"
        elif line.starts_with("field.qemu_idle="):
            output = output + "qemu_idle: " + line.substring(16) + "\n"
        elif line.starts_with("field.error="):
            output = "ERROR: " + line.substring(12)
        i = i + 1

    var result = "Status: " + status_str
    if test_path != "":
        result = result + "\nTest: " + test_path
    if cached == "true":
        result = result + " (cached)"
    if passed != "":
        result = result + "\nPassed: " + passed
    if failed != "":
        result = result + ", Failed: " + failed
    if skipped != "":
        result = result + ", Skipped: " + skipped
    if duration != "":
        result = result + "\nDuration: " + duration + "ms"
    if output != "":
        result = result + "\n" + output
    result
