# MCP Lazy Server - Background Task Manager
#
# Spawns long-running tools as async subprocesses. If the tool finishes
# within default_wait_ms, returns result normally. If still running,
# returns a task handle for polling via task_status / task_cancel.

extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_time_now_unix_micros() -> i64

# --- Background Task State ---

class BackgroundTask:
    task_id: text
    tool_name: text
    request_id: text
    pid: i64
    start_time_us: i64
    status: text
    exit_code: i64
    output_file: text
    default_wait_ms: i64

var BG_TASKS: [BackgroundTask] = []
var BG_NEXT_TASK_ID: i64 = 1

# --- Task Management Functions ---

fn bg_task_spawn(tool_name: text, request_id: text, cmd: text, default_wait_ms: i64) -> BackgroundTask:
    val tid = "t" + str(BG_NEXT_TASK_ID)
    BG_NEXT_TASK_ID = BG_NEXT_TASK_ID + 1

    val out_file = "/tmp/mcp_task_" + tid + ".out"
    val full_cmd = cmd + " > " + out_file + " 2>&1"

    val now = rt_time_now_unix_micros()
    val pid = rt_process_spawn_async("/bin/sh", ["-c", full_cmd])

    var task = BackgroundTask(
        task_id: tid,
        tool_name: tool_name,
        request_id: request_id,
        pid: pid,
        start_time_us: now,
        status: "working",
        exit_code: -1,
        output_file: out_file,
        default_wait_ms: default_wait_ms
    )

    if pid < 0:
        task.status = "failed"
        task.exit_code = -1
        return task

    # Wait up to default_wait_ms for completion
    val wait_result = rt_process_wait(pid, default_wait_ms)

    if wait_result == -2:
        # Timeout — still running
        task.status = "working"
        BG_TASKS = BG_TASKS + [task]
    elif wait_result >= 0:
        # Completed
        task.status = "completed"
        task.exit_code = wait_result
    else:
        # Error
        task.status = "failed"
        task.exit_code = wait_result

    task

fn bg_task_check(task_id: text) -> BackgroundTask:
    var i = 0
    while i < BG_TASKS.len():
        var task = BG_TASKS[i]
        if task.task_id == task_id:
            if task.status == "working":
                val running = rt_process_is_running(task.pid)
                if not running:
                    val exit_code = rt_process_wait(task.pid, 0)
                    task.status = "completed"
                    if exit_code < 0:
                        task.status = "failed"
                    task.exit_code = exit_code
                    BG_TASKS[i] = task
            return task
        i = i + 1

    # Not found
    BackgroundTask(
        task_id: task_id,
        tool_name: "",
        request_id: "",
        pid: -1,
        start_time_us: 0,
        status: "not_found",
        exit_code: -1,
        output_file: "",
        default_wait_ms: 0
    )

fn bg_task_cancel(task_id: text) -> bool:
    var i = 0
    while i < BG_TASKS.len():
        var task = BG_TASKS[i]
        if task.task_id == task_id:
            if task.status == "working":
                val killed = rt_process_kill(task.pid)
                task.status = "cancelled"
                task.exit_code = -1
                BG_TASKS[i] = task
                return killed
            return false
        i = i + 1
    false

fn bg_task_list() -> [BackgroundTask]:
    # Refresh status for all working tasks
    var i = 0
    while i < BG_TASKS.len():
        var task = BG_TASKS[i]
        if task.status == "working":
            val running = rt_process_is_running(task.pid)
            if not running:
                val exit_code = rt_process_wait(task.pid, 0)
                task.status = "completed"
                if exit_code < 0:
                    task.status = "failed"
                task.exit_code = exit_code
                BG_TASKS[i] = task
        i = i + 1
    BG_TASKS

fn bg_task_cleanup():
    val now = rt_time_now_unix_micros()
    val five_min_us: i64 = 300000000
    var kept: [BackgroundTask] = []
    for task in BG_TASKS:
        val age = now - task.start_time_us
        if task.status == "working" or age < five_min_us:
            kept = kept + [task]
    BG_TASKS = kept

fn bg_task_elapsed_ms(task: BackgroundTask) -> i64:
    val now = rt_time_now_unix_micros()
    (now - task.start_time_us) / 1000

fn bg_task_read_output(task: BackgroundTask) -> text:
    val content = rt_file_read_text(task.output_file) ?? ""
    content

# --- Response Builders ---

fn task_result_text(task: BackgroundTask) -> text:
    val output = bg_task_read_output(task)
    "-- " + task.tool_name + " (exit: " + str(task.exit_code) + ") --\n" + output

fn make_task_handle_response(id: text, task: BackgroundTask) -> text:
    val elapsed = bg_task_elapsed_ms(task)
    val msg = "Task " + task.task_id + " started (" + task.tool_name + "). Poll with task_status."
    val content = SB_L() + jo2(jp("type", js("text")), jp("text", js(msg))) + SB_R()
    val structured = jo4(
        jp("taskId", js(task.task_id)),
        jp("status", js("working")),
        jp("elapsed_ms", str(elapsed)),
        jp("pollInterval", "5")
    )
    var result = jo1(jp("content", content))
    result = result.substring(0, result.len() - 1) + "," + jp("structuredContent", structured) + RB()
    make_json_result(id, result)

fn make_task_status_response(id: text, task: BackgroundTask) -> text:
    val elapsed = bg_task_elapsed_ms(task)
    if task.status == "completed" or task.status == "failed":
        val output = task_result_text(task)
        return make_tool_result(id, output)

    if task.status == "not_found":
        return make_tool_error(id, -32602, "Task not found: " + task.task_id)

    if task.status == "cancelled":
        return make_tool_result(id, "Task " + task.task_id + ": cancelled")

    # Still working — show partial output
    val partial = bg_task_read_output(task)
    val elapsed_s = elapsed / 1000
    var msg = "Task " + task.task_id + ": working (" + str(elapsed_s) + "s elapsed)"
    if partial.len() > 0:
        # Show last 2000 chars of partial output
        var tail = partial
        if tail.len() > 2000:
            tail = tail.substring(tail.len() - 2000)
        msg = msg + "\nPartial output:\n" + tail
    val content = SB_L() + jo2(jp("type", js("text")), jp("text", js(msg))) + SB_R()
    val structured = jo3(
        jp("taskId", js(task.task_id)),
        jp("status", js("working")),
        jp("elapsed_ms", str(elapsed))
    )
    var result = jo1(jp("content", content))
    result = result.substring(0, result.len() - 1) + "," + jp("structuredContent", structured) + RB()
    make_json_result(id, result)

# --- Tool Handlers ---

fn handle_task_status(id: text, body: text) -> text:
    val task_id = extract_field(body, "task_id")
    if task_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: task_id")
    val task = bg_task_check(task_id)
    bg_task_cleanup()
    make_task_status_response(id, task)

fn handle_task_cancel(id: text, body: text) -> text:
    val task_id = extract_field(body, "task_id")
    if task_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: task_id")
    val cancelled = bg_task_cancel(task_id)
    if cancelled:
        make_tool_result(id, "Task " + task_id + " cancelled successfully")
    else:
        make_tool_error(id, -32602, "Task not found or not running: " + task_id)

fn handle_task_list(id: text, body: text) -> text:
    val tasks = bg_task_list()
    bg_task_cleanup()
    if tasks.len() == 0:
        return make_tool_result(id, "No background tasks")
    var lines: [text] = []
    for task in tasks:
        val elapsed = bg_task_elapsed_ms(task)
        val elapsed_s = elapsed / 1000
        var line = task.task_id + " | " + task.tool_name + " | " + task.status
        if task.status == "working":
            line = line + " (" + str(elapsed_s) + "s)"
        elif task.status == "completed" or task.status == "failed":
            line = line + " (exit: " + str(task.exit_code) + ")"
        lines = lines + [line]
    make_tool_result(id, lines.join("\n"))
