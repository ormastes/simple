#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# MCP Assistant Surface — KAIROS-like session bridge
#
# Self-contained, file-backed assistant sessions with timeline and
# notification logs. The dashboard can read the same store later, but this
# surface does not depend on any assistant-core implementation being present.

use app.mcp.main_lazy_json
use app.llm_dashboard.collectors.{collect_daemons, collect_remote_sessions, collect_schedules}
use app.llm_dashboard.data.types.{ManagedTask, task_kind_name, task_state_name}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

val ASSIST_ROOT = ".build/llm_dashboard/assistant"
val ASSIST_SESSIONS = ASSIST_ROOT + "/sessions"
val ASSIST_TIMELINES = ASSIST_ROOT + "/timelines"
val ASSIST_NOTIFICATIONS = ASSIST_ROOT + "/notifications"

fn _assistant_now_ms() -> i64:
    rt_time_now_unix_micros() / 1000

fn _assistant_ensure_dirs():
    rt_dir_create_all(ASSIST_SESSIONS)
    rt_dir_create_all(ASSIST_TIMELINES)
    rt_dir_create_all(ASSIST_NOTIFICATIONS)

fn _assistant_session_path(session_id: text) -> text:
    ASSIST_SESSIONS + "/" + session_id + ".json"

fn _assistant_timeline_path(session_id: text) -> text:
    ASSIST_TIMELINES + "/" + session_id + ".jsonl"

fn _assistant_notifications_path(session_id: text) -> text:
    ASSIST_NOTIFICATIONS + "/" + session_id + ".jsonl"

fn _assistant_session_exists(session_id: text) -> bool:
    rt_file_exists(_assistant_session_path(session_id))

fn _assistant_make_session_id(now_ms: i64) -> text:
    "assistant-" + str(now_ms)

fn _assistant_default_name(session_id: text, prompt: text) -> text:
    if prompt != "":
        val preview = prompt
        if preview.len() > 48:
            return "Assistant " + preview.slice(0, 48)
        return "Assistant " + preview
    "Assistant " + session_id

fn _assistant_default_summary(name: text, prompt: text) -> text:
    if prompt != "":
        if prompt.len() > 160:
            return prompt.slice(0, 160)
        return prompt
    name

fn _assistant_write_session(
    session_id: text,
    name: text,
    prompt: text,
    mode: text,
    parent_session_id: text,
    state: text,
    summary: text,
    created_at: i64,
    updated_at: i64,
    last_signal: text
):
    var obj = LB()
    obj = obj + jp("id", js(session_id))
    obj = obj + "," + jp("name", js(name))
    obj = obj + "," + jp("prompt", js(prompt))
    obj = obj + "," + jp("mode", js(mode))
    obj = obj + "," + jp("parent_session_id", js(parent_session_id))
    obj = obj + "," + jp("state", js(state))
    obj = obj + "," + jp("summary", js(summary))
    obj = obj + "," + jp("created_at", str(created_at))
    obj = obj + "," + jp("updated_at", str(updated_at))
    obj = obj + "," + jp("last_signal", js(last_signal))
    obj = obj + RB()
    file_write(_assistant_session_path(session_id), obj)

fn _assistant_load_session(session_id: text) -> text:
    if not _assistant_session_exists(session_id):
        return ""
    file_read(_assistant_session_path(session_id))

fn _assistant_update_session_state(session_id: text, new_state: text, last_signal: text) -> text:
    val current = _assistant_load_session(session_id)
    if current == "":
        return ""

    val name = extract_field(current, "name")
    val prompt = extract_field(current, "prompt")
    val mode = extract_field(current, "mode")
    val parent_session_id = extract_field(current, "parent_session_id")
    val summary = extract_field(current, "summary")
    val created_at = extract_field(current, "created_at")
    val updated_at = _assistant_now_ms()
    _assistant_write_session(
        session_id,
        name,
        prompt,
        mode,
        parent_session_id,
        new_state,
        summary,
        created_at.to_i64() ?? updated_at,
        updated_at,
        last_signal
    )
    _assistant_load_session(session_id)

fn _assistant_append_jsonl(path: text, line: text):
    var content = file_read(path)
    if content != "" and not content.ends_with("\n"):
        content = content + "\n"
    content = content + line + "\n"
    file_write(path, content)

fn _assistant_count_lines(content: text) -> i64:
    if content == "":
        return 0
    var count: i64 = 0
    for line in content.split("\n"):
        if line.trim() != "":
            count = count + 1
    count

fn _assistant_last_jsonl_line(content: text) -> text:
    if content == "":
        return ""
    var last = ""
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed != "":
            last = trimmed
    last

fn _assistant_event_object(session_id: text, timestamp: i64, kind: text, message: text, signal: text) -> text:
    var obj = LB()
    obj = obj + jp("timestamp", str(timestamp))
    obj = obj + "," + jp("session_id", js(session_id))
    obj = obj + "," + jp("kind", js(kind))
    obj = obj + "," + jp("message", js(message))
    obj = obj + "," + jp("signal", js(signal))
    obj + RB()
    obj

fn _assistant_record_event(session_id: text, kind: text, message: text, signal: text):
    val ts = _assistant_now_ms()
    val line = _assistant_event_object(session_id, ts, kind, message, signal)
    _assistant_append_jsonl(_assistant_timeline_path(session_id), line)
    _assistant_append_jsonl(_assistant_notifications_path(session_id), line)

fn _assistant_session_detail_object(session_json: text) -> text:
    val session_id = extract_field(session_json, "id")
    val name = extract_field(session_json, "name")
    val prompt = extract_field(session_json, "prompt")
    val mode = extract_field(session_json, "mode")
    val state = extract_field(session_json, "state")
    val summary = extract_field(session_json, "summary")
    val parent_session_id = extract_field(session_json, "parent_session_id")
    val created_at = extract_field(session_json, "created_at")
    val updated_at = extract_field(session_json, "updated_at")
    val last_signal = extract_field(session_json, "last_signal")

    val timeline_content = file_read(_assistant_timeline_path(session_id))
    val notifications_content = file_read(_assistant_notifications_path(session_id))
    val timeline_count = _assistant_count_lines(timeline_content)
    val notification_count = _assistant_count_lines(notifications_content)
    val last_event_line = _assistant_last_jsonl_line(timeline_content)

    var obj = LB()
    obj = obj + jp("session_id", js(session_id))
    obj = obj + "," + jp("name", js(name))
    obj = obj + "," + jp("prompt", js(prompt))
    obj = obj + "," + jp("mode", js(mode))
    obj = obj + "," + jp("state", js(state))
    obj = obj + "," + jp("summary", js(summary))
    obj = obj + "," + jp("parent_session_id", js(parent_session_id))
    obj = obj + "," + jp("created_at", created_at)
    obj = obj + "," + jp("updated_at", updated_at)
    obj = obj + "," + jp("last_signal", js(last_signal))
    obj = obj + "," + jp("timeline_count", str(timeline_count))
    obj = obj + "," + jp("notification_count", str(notification_count))
    if last_event_line != "":
        obj = obj + "," + jp("last_event_kind", js(extract_field(last_event_line, "kind")))
        obj = obj + "," + jp("last_event_message", js(extract_field(last_event_line, "message")))
        obj = obj + "," + jp("last_event_signal", js(extract_field(last_event_line, "signal")))
        obj = obj + "," + jp("last_event_at", extract_field(last_event_line, "timestamp"))
    obj = obj + RB()
    obj

fn _assistant_session_brief(session_json: text) -> text:
    val detail = _assistant_session_detail_object(session_json)
    val session_id = extract_field(detail, "session_id")
    val name = extract_field(detail, "name")
    val state = extract_field(detail, "state")
    val mode = extract_field(detail, "mode")
    val summary = extract_field(detail, "summary")
    val timeline_count = extract_field(detail, "timeline_count")
    val notification_count = extract_field(detail, "notification_count")
    val last_event_kind = extract_field(detail, "last_event_kind")
    val last_event_message = extract_field(detail, "last_event_message")

    var lines: [text] = []
    lines.push("session: " + session_id)
    lines.push("name: " + name)
    lines.push("state: " + state)
    lines.push("mode: " + mode)
    if summary != "":
        lines.push("summary: " + summary)
    lines.push("timeline events: " + timeline_count)
    lines.push("notifications: " + notification_count)
    if last_event_kind != "":
        var tail = "last event: " + last_event_kind
        if last_event_message != "":
            tail = tail + " - " + last_event_message
        lines.push(tail)
    lines.join("\n")

fn _assistant_list_session_ids() -> [text]:
    _assistant_ensure_dirs()
    var ids: [text] = []
    if not rt_file_exists(ASSIST_SESSIONS):
        return ids
    val files = rt_dir_list(ASSIST_SESSIONS)
    for fname in files:
        if fname.ends_with(".json"):
            ids.push(fname.slice(0, fname.len() - 5))
    ids

fn _assistant_session_task_json(session_json: text) -> text:
    val detail = _assistant_session_detail_object(session_json)
    var obj = LB()
    obj = obj + jp("id", js(extract_field(detail, "session_id")))
    obj = obj + "," + jp("source", js("assistant"))
    obj = obj + "," + jp("kind", js("assistant"))
    obj = obj + "," + jp("state", js(extract_field(detail, "state")))
    obj = obj + "," + jp("name", js(extract_field(detail, "name")))
    obj = obj + "," + jp("command", js(extract_field(detail, "prompt")))
    obj = obj + "," + jp("created_at", extract_field(detail, "created_at"))
    obj = obj + "," + jp("updated_at", extract_field(detail, "updated_at"))
    obj = obj + "," + jp("last_signal", js(extract_field(detail, "last_signal")))
    obj = obj + RB()
    obj

fn _assistant_managed_task_json(task: ManagedTask, source: text) -> text:
    var obj = LB()
    obj = obj + jp("id", js(task.id))
    obj = obj + "," + jp("source", js(source))
    obj = obj + "," + jp("kind", js(task_kind_name(task.kind)))
    obj = obj + "," + jp("state", js(task_state_name(task.state)))
    obj = obj + "," + jp("name", js(task.name))
    obj = obj + "," + jp("command", js(task.command))
    obj = obj + "," + jp("created_at", str(task.created_at))
    obj = obj + "," + jp("updated_at", str(task.last_run_time))
    obj = obj + "," + jp("last_result", js(task.last_result))
    obj = obj + "," + jp("agent_id", js(task.agent_id))
    obj = obj + RB()
    obj

fn _assistant_collect_dashboard_tasks() -> [text]:
    var tasks: [text] = []
    for task in collect_schedules():
        tasks.push(_assistant_managed_task_json(task, "dashboard"))
    for task in collect_daemons():
        tasks.push(_assistant_managed_task_json(task, "dashboard"))
    for task in collect_remote_sessions():
        tasks.push(_assistant_managed_task_json(task, "dashboard"))
    tasks

fn _assistant_collect_all_tasks() -> [text]:
    var tasks: [text] = []
    for session_id in _assistant_list_session_ids():
        val session_json = _assistant_load_session(session_id)
        if session_json != "":
            tasks.push(_assistant_session_task_json(session_json))
    for task_json in _assistant_collect_dashboard_tasks():
        tasks.push(task_json)
    tasks

fn _assistant_collect_filtered_notifications(session_id: text, limit: i64, since_ts: i64) -> [text]:
    var notifications: [text] = []
    if session_id != "":
        val content = file_read(_assistant_notifications_path(session_id))
        for line in content.split("\n"):
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val event_ts = extract_field(trimmed, "timestamp").to_i64() ?? 0
            if since_ts > 0 and event_ts <= since_ts:
                continue
            notifications.push(_assistant_event_object(
                extract_field(trimmed, "session_id"),
                event_ts,
                extract_field(trimmed, "kind"),
                extract_field(trimmed, "message"),
                extract_field(trimmed, "signal")
            ))
    else:
        for sid in _assistant_list_session_ids():
            val content = file_read(_assistant_notifications_path(sid))
            for line in content.split("\n"):
                val trimmed = line.trim()
                if trimmed == "":
                    continue
                val event_ts = extract_field(trimmed, "timestamp").to_i64() ?? 0
                if since_ts > 0 and event_ts <= since_ts:
                    continue
                notifications.push(_assistant_event_object(
                    extract_field(trimmed, "session_id"),
                    event_ts,
                    extract_field(trimmed, "kind"),
                    extract_field(trimmed, "message"),
                    extract_field(trimmed, "signal")
                ))
    if limit <= 0 or notifications.len() <= limit:
        return notifications
    var trimmed_notifications: [text] = []
    var start = notifications.len() - limit
    var i = start
    while i < notifications.len():
        trimmed_notifications.push(notifications[i])
        i = i + 1
    trimmed_notifications

fn _assistant_collect_timeline_events(session_id: text, limit: i64, since_ts: i64) -> [text]:
    var events: [text] = []
    val content = file_read(_assistant_timeline_path(session_id))
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val event_ts = extract_field(trimmed, "timestamp").to_i64() ?? 0
        if since_ts > 0 and event_ts <= since_ts:
            continue
        events.push(_assistant_event_object(
            extract_field(trimmed, "session_id"),
            event_ts,
            extract_field(trimmed, "kind"),
            extract_field(trimmed, "message"),
            extract_field(trimmed, "signal")
        ))
    if limit <= 0 or events.len() <= limit:
        return events
    var trimmed_events: [text] = []
    var start = events.len() - limit
    var i = start
    while i < events.len():
        trimmed_events.push(events[i])
        i = i + 1
    trimmed_events

# ---------------------------------------------------------------------------
# Tool handlers
# ---------------------------------------------------------------------------

fn handle_assistant_start(id: text, body: text) -> text:
    _assistant_ensure_dirs()
    val now = _assistant_now_ms()
    val session_id = _assistant_make_session_id(now)
    var name = extract_field(body, "name")
    val prompt = extract_field(body, "prompt")
    var mode = extract_field(body, "mode")
    val parent_session_id = extract_field(body, "parent_session_id")
    if name == "":
        name = _assistant_default_name(session_id, prompt)
    if mode == "":
        mode = "proactive"
    val summary = _assistant_default_summary(name, prompt)
    _assistant_write_session(session_id, name, prompt, mode, parent_session_id, "running", summary, now, now, "start")
    _assistant_record_event(session_id, "start", summary, "start")
    make_tool_result(id, _assistant_session_detail_object(_assistant_load_session(session_id)))

fn handle_assistant_pause(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    if not _assistant_session_exists(session_id):
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    val updated = _assistant_update_session_state(session_id, "paused", "pause")
    if updated == "":
        return make_tool_error(id, -32603, "Failed to pause session: " + session_id)
    _assistant_record_event(session_id, "pause", "session paused", "pause")
    make_tool_result(id, _assistant_session_detail_object(updated))

fn handle_assistant_resume(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    if not _assistant_session_exists(session_id):
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    val updated = _assistant_update_session_state(session_id, "running", "resume")
    if updated == "":
        return make_tool_error(id, -32603, "Failed to resume session: " + session_id)
    _assistant_record_event(session_id, "resume", "session resumed", "resume")
    make_tool_result(id, _assistant_session_detail_object(updated))

fn handle_assistant_brief(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    val session_json = _assistant_load_session(session_id)
    if session_json == "":
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    make_tool_result(id, _assistant_session_brief(session_json))

fn handle_assistant_list_sessions(id: text, body: text) -> text:
    _assistant_ensure_dirs()
    val state_filter = extract_field(body, "state")
    var items: [text] = []
    for session_id in _assistant_list_session_ids():
        val session_json = _assistant_load_session(session_id)
        if session_json == "":
            continue
        val detail = _assistant_session_detail_object(session_json)
        val state = extract_field(detail, "state")
        if state_filter != "" and state != state_filter:
            continue
        items.push(detail)
    make_tool_result(id, jo1(jp("sessions", "[" + items.join(",") + "]")))

fn handle_assistant_get_session(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    val session_json = _assistant_load_session(session_id)
    if session_json == "":
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    make_tool_result(id, _assistant_session_detail_object(session_json))

fn handle_assistant_get_timeline(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    if not _assistant_session_exists(session_id):
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    val limit_str = extract_field(body, "limit")
    val since_ts_str = extract_field(body, "since_ts")
    val limit: i64 = if limit_str != "": limit_str.to_i64() ?? 20 else: 20
    val since_ts: i64 = if since_ts_str != "": since_ts_str.to_i64() ?? 0 else: 0
    val events = _assistant_collect_timeline_events(session_id, limit, since_ts)
    make_tool_result(id, jo2(jp("session_id", js(session_id)), jp("events", "[" + events.join(",") + "]")))

fn handle_assistant_push_signal(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    val signal = extract_field(body, "signal")
    val payload = extract_field(body, "payload")
    if session_id == "" or signal == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id/signal")
    if not _assistant_session_exists(session_id):
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    val message = if payload != "": payload else: signal
    _assistant_record_event(session_id, "signal", message, signal)
    val updated = _assistant_update_session_state(session_id, extract_field(_assistant_load_session(session_id), "state"), signal)
    if updated == "":
        return make_tool_error(id, -32603, "Failed to record signal: " + signal)
    make_tool_result(id, jo4(jp("session_id", js(session_id)), jp("signal", js(signal)), jp("message", js(message)), jp("status", js("ok"))))

fn handle_assistant_list_tasks(id: text, body: text) -> text:
    _assistant_ensure_dirs()
    val source_filter = extract_field(body, "source")
    var items: [text] = []
    for session_id in _assistant_list_session_ids():
        val session_json = _assistant_load_session(session_id)
        if session_json == "":
            continue
        if source_filter == "" or source_filter == "assistant":
            items.push(_assistant_session_task_json(session_json))
    if source_filter == "" or source_filter == "dashboard":
        for task_json in _assistant_collect_dashboard_tasks():
            items.push(task_json)
    make_tool_result(id, jo2(jp("tasks", "[" + items.join(",") + "]"), jp("count", str(items.len()))))

fn handle_assistant_get_notifications(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    val limit_str = extract_field(body, "limit")
    val since_ts_str = extract_field(body, "since_ts")
    val limit: i64 = if limit_str != "": limit_str.to_i64() ?? 20 else: 20
    val since_ts: i64 = if since_ts_str != "": since_ts_str.to_i64() ?? 0 else: 0
    if session_id != "" and not _assistant_session_exists(session_id):
        return make_tool_error(id, -32602, "Session not found: " + session_id)
    val notifications = _assistant_collect_filtered_notifications(session_id, limit, since_ts)
    make_tool_result(id, jo2(jp("session_id", js(session_id)), jp("notifications", "[" + notifications.join(",") + "]")))
