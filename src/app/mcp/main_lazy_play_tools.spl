# play_evaluate
# ----------------------------------------------------------------------------

fn handle_play_evaluate(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    val js = extract_field(body, "js")
    if session_id == "" or js == "":
        return make_tool_error(id, -32602, "Missing required parameter(s): session_id, js")
    val (out, code) = _play_run_cli("evaluate", [session_id, js])
    _play_ok_or_error(id, "play_evaluate", out, code)

