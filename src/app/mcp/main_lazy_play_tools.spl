# ============================================================================
# play_ui_* — semantic /api/test/ui/* surface. Drives any embedding that
# mounts the shared handler (host WM, TUI web, standalone Simple app,
# SimpleOS compositor bridge) uniformly. Not backend-specific — the name
# "ui" avoids the legacy "sdl2" label for non-SDL2 endpoints.
# ============================================================================

fn handle_play_ui_connect(id: text, body: text) -> text:
    val base_url = extract_field(body, "base_url")
    if base_url == "":
        return make_tool_error(id, -32602, "Missing required parameter: base_url")
    val (out, code) = _play_run_cli("ui-connect", [base_url])
    _play_ok_or_error(id: id, tool: "play_ui_connect", body: out, exit_code: code)

fn handle_play_ui_snapshot(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    val (out, code) = _play_run_cli("ui-snapshot", [session_id])
    _play_ok_or_error(id: id, tool: "play_ui_snapshot", body: out, exit_code: code)

fn _push_opt(args: [text], flag: text, value: text) -> [text]:
    if value == "":
        return args
    var out = args
    out.push(flag)
    out.push(value)
    return out

fn handle_play_ui_query(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    var args: [text] = [session_id]
    args = _push_opt(args: args, flag: "--surface-id", value: extract_field(body, "surface_id"))
    args = _push_opt(args: args, flag: "--canonical-id", value: extract_field(body, "canonical_id"))
    args = _push_opt(args: args, flag: "--kind", value: extract_field(body, "kind"))
    args = _push_opt(args: args, flag: "--text", value: extract_field(body, "text"))
    if extract_field(body, "focused_only") == "true":
        args.push("--focused-only")
    args = _push_opt(args: args, flag: "--limit", value: extract_field(body, "limit"))
    val (out, code) = _play_run_cli("ui-query", args)
    _play_ok_or_error(id: id, tool: "play_ui_query", body: out, exit_code: code)

fn handle_play_ui_ensure(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    var args: [text] = [session_id]
    args = _push_opt(args: args, flag: "--surface-id", value: extract_field(body, "surface_id"))
    args = _push_opt(args: args, flag: "--canonical-id", value: extract_field(body, "canonical_id"))
    args = _push_opt(args: args, flag: "--kind", value: extract_field(body, "kind"))
    args = _push_opt(args: args, flag: "--text", value: extract_field(body, "text"))
    if extract_field(body, "focused_only") == "true":
        args.push("--focused-only")
    args = _push_opt(args: args, flag: "--expectation", value: extract_field(body, "expectation"))
    args = _push_opt(args: args, flag: "--expected-value", value: extract_field(body, "expected_value"))
    args = _push_opt(args: args, flag: "--timeout-ms", value: extract_field(body, "timeout_ms"))
    val (out, code) = _play_run_cli("ui-ensure", args)
    _play_ok_or_error(id: id, tool: "play_ui_ensure", body: out, exit_code: code)

fn handle_play_ui_act(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    val canonical_id = extract_field(body, "canonical_id")
    val action = extract_field(body, "action")
    if session_id == "" or canonical_id == "" or action == "":
        return make_tool_error(id, -32602, "Missing required parameter(s): session_id, canonical_id, action")
    var args: [text] = [session_id, canonical_id, action]
    args = _push_opt(args: args, flag: "--surface-id", value: extract_field(body, "surface_id"))
    val (out, code) = _play_run_cli("ui-act", args)
    _play_ok_or_error(id: id, tool: "play_ui_act", body: out, exit_code: code)
