# ----------------------------------------------------------------------------
# play_wm_list — list native OS windows
# ----------------------------------------------------------------------------

fn handle_play_wm_list(id: text, body: text) -> text:
    val (out, code) = _play_run_cli("wm-list", [])
    _play_ok_or_error(id, "play_wm_list", out, code)

# ----------------------------------------------------------------------------
# play_wm_click — click at screen coordinates
# ----------------------------------------------------------------------------

fn handle_play_wm_click(id: text, body: text) -> text:
    val x = extract_field(body, "x")
    val y = extract_field(body, "y")
    if x == "" or y == "":
        return make_tool_error(id, -32602, "Missing required parameter(s): x, y")
    val (out, code) = _play_run_cli("wm-click", [x, y])
    _play_ok_or_error(id, "play_wm_click", out, code)

# ----------------------------------------------------------------------------
# play_wm_type — type text via native keyboard
# ----------------------------------------------------------------------------

fn handle_play_wm_type(id: text, body: text) -> text:
    val text_value = extract_field(body, "text")
    if text_value == "":
        return make_tool_error(id, -32602, "Missing required parameter: text")
    val (out, code) = _play_run_cli("wm-type", [text_value])
    _play_ok_or_error(id, "play_wm_type", out, code)
