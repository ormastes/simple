# MCP Play Tool Handlers — Playwright-compatible UI automation
#
# Provides MCP tools for driving Electron / VS Code / SDL2 / native WM
# targets from Claude. Each handler shells out to `bin/simple play <sub>`
# so the MCP layer reuses the CLI's session store, artifact paths, and
# backend dispatch logic without duplicating state.
#
# Tool layout (Phase 1 + Phase 2 + WM + SDL2):
#
#   play_run          — Phase 1 orchestrator (npm / playwright / vscode-test + xvfb)
#   play_launch       — Phase 2 Electron launch with CDP
#   play_first_window — Get the first window id of a session
#   play_click        — Session action: click a selector
#   play_fill         — Session action: fill a field
#   play_type         — Session action: type text
#   play_press        — Session action: press a key
#   play_screenshot   — Session action: save a screenshot
#   play_evaluate     — Session action: evaluate JS in the page
#   play_close        — Close a session
#   play_last_trace   — Dump the last CDP trace log
#   play_wm_screenshot — Native WM: take a desktop screenshot
#   play_wm_list      — Native WM: list OS windows
#   play_wm_click     — Native WM: click at (x, y)
#   play_wm_type      — Native WM: type text via keyboard
#   play_wm_text_status — Common window-to-text adapter contract status
#   play_wm_text_snapshot — Common window-to-text scalar adapter snapshot
#   play_wm_text_find — Common window-to-text scalar adapter query
#   play_wm_text_act  — Common window-to-text scalar adapter action routing

use .main_lazy_json
use common.ui.access.{
    UiAccessProp,
    UiAccessNode,
    UiAccessSurface,
    UiAccessSnapshot,
    ui_access_canonical_id,
    ui_access_snapshot_to_json,
    ui_access_query_result,
    ui_access_query_to_json,
    win_text_trace32_snapshot,
    win_text_simple_ui_snapshot,
    win_text_host_wm_single_window_snapshot,
    win_text_compositor_snapshot,
    GttiSurface,
    win_text_make_node,
    win_text_find_nodes,
    win_text_route_action,
    WinTextActionRequest,
    WinTextActionResult,
    WinTextSnapshot
}

use std.io_runtime.{process_run}

# ----------------------------------------------------------------------------
# Shared helper: run `bin/simple play <subcmd> <args...>` and return the
# trimmed stdout. The Play CLI emits single-line JSON on stdout, which we
# pass through verbatim so the MCP client can parse a structured response.
# ----------------------------------------------------------------------------

fn _play_run_cli(subcmd: text, args: [text]) -> (text, i64):
    val _bin = _mcp_find_simple_binary()
    var full_args: [text] = ["play", subcmd]
    for a in args:
        full_args.push(a)
    val (stdout, stderr, code) = process_run(_bin, full_args)
    var out = stdout
    if out == "":
        out = stderr
    (out.trim(), code)

fn _play_ok_or_error(id: text, tool: text, body: text, exit_code: i64) -> text:
    if body == "":
        return make_tool_error(id, -32603, tool + " produced no output (exit " + str(exit_code) + ")")
    # The CLI always writes valid JSON; forward as-is.
    make_tool_result(id, body)

# ----------------------------------------------------------------------------
# play_run — Phase 1 orchestrator
# ----------------------------------------------------------------------------

fn handle_play_run(id: text, body: text) -> text:
    val target_dir = extract_field(body, "target_dir")
    if target_dir == "":
        return make_tool_error(id, -32602, "Missing required parameter: target_dir")
    val (out, code) = _play_run_cli("run", [target_dir])
    _play_ok_or_error(id: id, tool: "play_run", body: out, exit_code: code)

# ----------------------------------------------------------------------------
# play_launch — Phase 2 Electron launch (CDP)
# ----------------------------------------------------------------------------

fn handle_play_launch(id: text, body: text) -> text:
    val app_path = extract_field(body, "app_path")
    if app_path == "":
        return make_tool_error(id, -32602, "Missing required parameter: app_path")
    val (out, code) = _play_run_cli("launch", [app_path])
    _play_ok_or_error(id: id, tool: "play_launch", body: out, exit_code: code)

# ----------------------------------------------------------------------------
# play_first_window — derived via last-trace for now (session data persists
# across launch via the file-backed store; the first_window_id is embedded
# in the launch JSON output). Kept as a thin stub: client reads `launch`
# response for first_window_id.
# ----------------------------------------------------------------------------

fn handle_play_first_window(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return make_tool_error(id, -32602, "Missing required parameter: session_id")
    val (out, code) = _play_run_cli("last-trace", [session_id])
    _play_ok_or_error(id: id, tool: "play_first_window", body: out, exit_code: code)

