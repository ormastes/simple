# MCP CLI Passthrough Handler
#
# Generic handler that builds a bin/simple command from tool table entry
# and executes it via shell_cmd(). Works for any tool with handler_kind="cli".

use .tool_registry
use .main_lazy_json.{extract_field, make_tool_result, shell_cmd}
use .main_lazy_diag_tools.{handle_simple_diagnostics, handle_simple_symbols}
use .main_lazy_query_tools.{_mcp_find_simple_binary}

fn handle_cli_passthrough(id: text, body: text, entry: McpToolEntry) -> text:
    handle_cli_passthrough_direct(id, body, entry.tool_name, entry.cli_command, entry.timeout_s)

fn handle_cli_passthrough_direct(id: text, body: text, name: text, cli_command: text, timeout_s: i64) -> text:
    if name == "simple_symbols":
        return handle_simple_symbols(id, body)
    if name == "simple_diagnostics":
        return handle_simple_diagnostics(id, body)

    val _bin = _mcp_find_simple_binary()

    val effective_timeout_s = _effective_cli_timeout_s(name, body, timeout_s)

    # Build command: timeout <N> bin/simple <cli_command> <args...>
    var cmd = "timeout " + str(effective_timeout_s) + " " + _bin + " " + cli_command

    # Extract known parameters from body and append as CLI args
    cmd = _append_cli_args_for_name(cmd, body, name)

    var out = ""
    var exit_code: i64 = 0

    # simple_test spawns async child processes (test workers) that inherit the
    # popen pipe as their stdout.  Even after `timeout` kills bin/simple, those
    # workers keep the pipe write-end open, so popen's fgets never sees EOF and
    # the MCP server hangs.  Fix: redirect the test command's output to a temp
    # file so workers hold a file fd (not the popen pipe), then read the file
    # back with `cat` after the command finishes.
    if name == "simple_test":
        # < /dev/null is explicitly placed on the test command itself so it doesn't
        # read from the MCP stdin pipe.
        # mktemp uses trailing X's only (no suffix) for BSD/macOS compatibility.
        val wrapped = "tmp=$(mktemp /tmp/simple_mcp_test_XXXXXX); " + cmd + " < /dev/null > \"$tmp\" 2>&1; EC=$?; cat \"$tmp\"; rm -f \"$tmp\"; exit $EC"
        (out, exit_code) = shell_cmd(wrapped)
    else:
        cmd = cmd + " 2>&1"
        (out, exit_code) = shell_cmd(cmd)

    var output = "-- " + name + " (exit: " + str(exit_code) + ") --\n" + out
    if exit_code == 124:
        output = "TIMEOUT: " + name + " timed out after " + str(effective_timeout_s) + "s\n" + out
    make_tool_result(id, output)

fn _effective_cli_timeout_s(name: text, body: text, default_timeout_s: i64) -> i64:
    if name != "simple_test":
        return default_timeout_s
    val requested_timeout_s = _parse_positive_int_or_zero(extract_field(body, "timeout"))
    if requested_timeout_s <= default_timeout_s:
        return default_timeout_s
    requested_timeout_s + 30

fn _parse_positive_int_or_zero(value: text) -> i64:
    if value == "":
        return 0
    for ch in value:
        if ch < "0" or ch > "9":
            return 0
    val parsed = value.trim().to_int() ?? 0
    if parsed > 0:
        return parsed
    0

fn _append_cli_args(cmd: text, body: text, entry: McpToolEntry) -> text:
    _append_cli_args_for_name(cmd, body, entry.tool_name)

fn _append_cli_args_for_name(cmd: text, body: text, name: text) -> text:
    var result = cmd

    # Tool-specific argument mapping
    # Each tool maps its JSON params to CLI flags/positional args

    # --- simple_check, simple_symbols, simple_run, simple_diagnostics, simple_desugar, simple_lex ---
    if name == "simple_check" or name == "simple_run" or name == "simple_desugar" or name == "simple_lex":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    if name == "simple_symbols":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    if name == "simple_diagnostics":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_test ---
    if name == "simple_test":
        val path = extract_field(body, "path")
        val filter_str = extract_field(body, "filter")
        val only_slow = extract_field(body, "only_slow")
        val list_flag = extract_field(body, "list")
        val timeout = extract_field(body, "timeout")
        if list_flag == "true":
            result = result + " --list"
        elif path != "":
            result = result + " " + path
        if filter_str != "":
            result = result + " --filter " + filter_str
        if only_slow == "true":
            result = result + " --only-slow"
        val timeout_s = _parse_positive_int_or_zero(timeout)
        if timeout_s > 0:
            result = result + " --timeout " + str(timeout_s)
        else:
            result = result + " --timeout 60"
        return result

    # --- simple_build ---
    if name == "simple_build":
        val release = extract_field(body, "release")
        val target = extract_field(body, "target")
        val warn_docs = extract_field(body, "warn_docs")
        if release == "true":
            result = result + " --release"
        if target != "":
            result = result + " --target " + target
        if warn_docs == "true":
            result = result + " --warn-docs"
        return result

    # --- simple_format ---
    if name == "simple_format":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        if _extract_bool_arg(body, "check"):
            result = result + " --check"
        return result

    # --- simple_lint ---
    if name == "simple_lint":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_fix ---
    if name == "simple_fix":
        val path = extract_field(body, "path")
        val dry_run = extract_field(body, "dry_run")
        if path != "":
            result = result + " " + path
        if dry_run == "true":
            result = result + " --dry-run"
        return result

    # --- simple_doc_coverage ---
    if name == "simple_doc_coverage":
        val format_str = extract_field(body, "format")
        val missing = extract_field(body, "missing")
        if format_str != "":
            result = result + " --format=" + format_str
        if missing == "true":
            result = result + " --missing"
        return result

    # --- query tools (ast-query, sem-query, query-schema) ---
    if name == "simple_ast_query" or name == "simple_sem_query":
        val query = extract_field(body, "query")
        val files = extract_field(body, "files")
        val format_str = extract_field(body, "format")
        if query != "":
            result = result + " '" + query + "'"
        if files != "":
            result = result + " " + files
        if format_str != "":
            result = result + " --format " + format_str
        return result

    if name == "simple_query_schema":
        val kind = extract_field(body, "kind")
        if kind != "":
            result = result + " " + kind
        return result

    # --- simple_add ---
    if name == "simple_add":
        val package = extract_field(body, "package")
        val version = extract_field(body, "version")
        val dev = extract_field(body, "dev")
        if package != "":
            result = result + " " + package
        if version != "":
            result = result + "@" + version
        if dev == "true":
            result = result + " --dev"
        return result

    # --- simple_remove ---
    if name == "simple_remove":
        val package = extract_field(body, "package")
        if package != "":
            result = result + " " + package
        return result

    # --- simple_stats ---
    if name == "simple_stats":
        val format_str = extract_field(body, "format")
        if format_str == "json":
            result = result + " --json"
        return result

    # --- simple_duplicate_check ---
    if name == "simple_duplicate_check":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_check_arch ---
    if name == "simple_check_arch":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_info ---
    if name == "simple_info":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_init ---
    if name == "simple_init":
        val proj_name = extract_field(body, "name")
        val path = extract_field(body, "path")
        if proj_name != "":
            result = result + " " + proj_name
        if path != "":
            result = result + " " + path
        return result

    # --- simple_spec_coverage ---
    if name == "simple_spec_coverage":
        val missing = extract_field(body, "missing")
        if missing == "true":
            result = result + " --missing"
        return result

    # --- Codegen tools with path param ---
    if (name == "simple_spec_gen" or name == "simple_sffi_gen" or name == "simple_wrapper_gen" or
        name == "simple_spipe_docgen" or name == "simple_gen_lean"):
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- simple_cache ---
    if name == "simple_cache":
        val action = extract_field(body, "action")
        if action != "":
            result = result + " " + action
        return result

    # --- simple_i18n ---
    if name == "simple_i18n":
        val action = extract_field(body, "action")
        if action != "":
            result = result + " " + action
        return result

    # --- task_status / task_cancel ---
    if name == "task_status" or name == "task_cancel":
        val task_id = extract_field(body, "task_id")
        if task_id != "":
            result = result + " " + task_id
        return result

    # --- test_daemon_run ---
    if name == "test_daemon_run":
        val path = extract_field(body, "path")
        val filter_str = extract_field(body, "filter")
        val clean = extract_field(body, "clean")
        if path != "":
            result = result + " " + path
        if filter_str != "":
            result = result + " --filter " + filter_str
        return result

    # --- test_daemon_clean ---
    if name == "test_daemon_clean":
        val path = extract_field(body, "path")
        if path != "":
            result = result + " " + path
        return result

    # --- debug_log_enable ---
    if name == "debug_log_enable":
        val pattern = extract_field(body, "pattern")
        if pattern != "":
            result = result + " --pattern " + pattern
        return result

    # --- debug_log_query ---
    if name == "debug_log_query":
        val since_id = extract_field(body, "since_id")
        val entry_type = extract_field(body, "entry_type")
        val max_results = extract_field(body, "max_results")
        if since_id != "":
            result = result + " --since-id " + since_id
        if entry_type != "":
            result = result + " --type " + entry_type
        if max_results != "":
            result = result + " --max " + max_results
        return result

    # --- debug_log_tree ---
    if name == "debug_log_tree":
        val format_str = extract_field(body, "format")
        if format_str != "":
            result = result + " --format " + format_str
        return result

    # --- Default: no extra args (brief, todo_scan, todo_gen, env, log disable/clear/status, etc.) ---
    result

fn _extract_bool_arg(body: text, key: text) -> bool:
    val quoted = Q() + key + Q()
    body.contains(quoted + ":true") or body.contains(quoted + ": true") or
    body.contains(quoted + ":" + Q() + "true" + Q()) or
    body.contains(quoted + ": " + Q() + "true" + Q())
