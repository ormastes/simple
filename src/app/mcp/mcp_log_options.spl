# MCP-local log option parsing — trimmed copy of std.cli.log_modes.
# Contains only the three functions used by the MCP server entry point.
# No external imports required.

# struct + free-fn constructor, NOT a class with `static fn defaults()`:
# class static calls silently lower to nil in entry-closure natives
# (doc/08_tracking/bug/native_class_static_ctor_missing_2026-07-23.md).
struct SimpleLogOptions:
    log_mode: text      # "human" | "llm" | "json"
    surface: text       # "stdout" | "tui"
    progress: text      # "summary" | "count" | "dot" | "none"
    quiet: bool
    verbose: bool
    valid: bool
    error: text

fn simple_log_options_defaults() -> SimpleLogOptions:
    SimpleLogOptions(
        log_mode: "human",
        surface: "stdout",
        progress: "summary",
        quiet: false,
        verbose: false,
        valid: true,
        error: ""
    )

fn _mlo_str_eq(a: text, b: text) -> bool:
    a.len() == b.len() and a.starts_with(b)

fn _mlo_is_log_mode(value: text) -> bool:
    _mlo_str_eq(value, "human") or _mlo_str_eq(value, "llm") or _mlo_str_eq(value, "json")

fn _mlo_is_surface(value: text) -> bool:
    _mlo_str_eq(value, "stdout") or _mlo_str_eq(value, "tui")

fn _mlo_is_progress(value: text) -> bool:
    _mlo_str_eq(value, "summary") or _mlo_str_eq(value, "count") or _mlo_str_eq(value, "dot") or _mlo_str_eq(value, "none")

fn _mlo_next_value(args: [text], index: i32) -> text:
    if index + 1 < args.len() as i32:
        return args[index + 1]
    ""

fn parse_log_options(args: [text]) -> SimpleLogOptions:
    var opts = simple_log_options_defaults()
    var i: i32 = 0
    while i < args.len() as i32:
        val arg = args[i]
        if _mlo_str_eq(arg, "--human"):
            opts.log_mode = "human"
        elif _mlo_str_eq(arg, "--llm"):
            opts.log_mode = "llm"
        elif _mlo_str_eq(arg, "--json"):
            opts.log_mode = "json"
        elif _mlo_str_eq(arg, "--tui"):
            opts.surface = "tui"
        elif _mlo_str_eq(arg, "--stdout"):
            opts.surface = "stdout"
        elif _mlo_str_eq(arg, "--quiet"):
            opts.quiet = true
            opts.progress = "none"
        elif _mlo_str_eq(arg, "--verbose"):
            opts.verbose = true
        elif _mlo_str_eq(arg, "--dots"):
            opts.progress = "dot"
        elif _mlo_str_eq(arg, "--count"):
            opts.progress = "count"
        elif _mlo_str_eq(arg, "--no-progress"):
            opts.progress = "none"
        elif arg.starts_with("--log-mode="):
            val value = arg.slice(11, arg.len())
            if _mlo_is_log_mode(value):
                opts.log_mode = value
            else:
                opts.valid = false
                opts.error = "invalid --log-mode: " + value
        elif _mlo_str_eq(arg, "--log-mode"):
            val value = _mlo_next_value(args, i)
            if _mlo_is_log_mode(value):
                opts.log_mode = value
                i = i + 1
            else:
                opts.valid = false
                opts.error = "invalid --log-mode: " + value
        elif arg.starts_with("--surface="):
            val value = arg.slice(10, arg.len())
            if _mlo_is_surface(value):
                opts.surface = value
            else:
                opts.valid = false
                opts.error = "invalid --surface: " + value
        elif arg.starts_with("--progress="):
            val value = arg.slice(11, arg.len())
            if _mlo_is_progress(value):
                opts.progress = value
            else:
                opts.valid = false
                opts.error = "invalid --progress: " + value
        elif _mlo_str_eq(arg, "--progress"):
            val value = _mlo_next_value(args, i)
            if _mlo_is_progress(value):
                opts.progress = value
                i = i + 1
            else:
                opts.valid = false
                opts.error = "invalid --progress: " + value
        i = i + 1
    opts

fn log_options_help() -> [text]:
    [
        "--log-mode <human|llm|json>  Select log rendering mode",
        "--human | --llm | --json     Shorthand log modes",
        "--stdout | --tui             Select output surface",
        "--progress <summary|count|dot|none>",
        "--dots | --count | --no-progress",
        "--quiet | --verbose"
    ]

fn render_progress(mode: text, done: i64, total: i64, label: text) -> text:
    if mode == "none":
        return ""
    if mode == "dot":
        return "."
    var safe_total = total
    if safe_total <= 0:
        safe_total = 1
    if mode == "count":
        if label == "":
            return str(done) + "/" + str(safe_total)
        return str(done) + "/" + str(safe_total) + " " + label
    var pct = done * 100 / safe_total
    if label == "":
        return str(done) + "/" + str(safe_total) + " (" + str(pct) + "%)"
    label + ": " + str(done) + "/" + str(safe_total) + " (" + str(pct) + "%)"
