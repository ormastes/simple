#![allow(unnamed_duplicate_typed_args)]
"""Registration shim for the wiki_keyword MCP tool.

Opts the tool in to the `DispatchRegistry`-based wrap boundary from
`src/lib/nogc_sync_mut/mcp/dispatch.spl`. The authoritative handler
lives in `wiki_tool.spl`; this file is the only piece that imports the
dispatcher, so the tool file stays pure.

Feature: spm-winfs-llm-suite AC-6.
"""

use lib.common.privilege.id_path.{id_path_intern}
use lib.common.privilege.authority_token.{AuthorityLevel}
use lib.nogc_sync_mut.mcp.dispatch.{DispatchRegistry, DispatchEntry}
use app.mcp.wiki_keyword.wiki_tool.{wiki_handler}

fn register_wiki_tool(reg: DispatchRegistry) -> ():
    """Register `wiki.lookup` with the given registry."""
    val entry = DispatchEntry(
        tool_name: "wiki.lookup",
        required: id_path_intern("id.public"),
        level: AuthorityLevel.Public,
        handler: wiki_handler)
    reg.register(entry)
