# MCP Startup Log Library
# Writes startup diagnostics to .simple/logs/<server>_startup.log
# Uses only extern fn calls — no stdlib imports (matches MCP zero-import pattern)

extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_dir_create_all(path: text) -> bool

fn mcp_startup_log(server_name: text, server_version: text):
    val cwd = rt_env_cwd() ?? ""
    val simple_lib = rt_env_get("SIMPLE_LIB") ?? ""
    val simple_binary = rt_env_get("SIMPLE_BINARY") ?? ""
    val memory_limit = rt_env_get("SIMPLE_MEMORY_LIMIT_MB") ?? "unset"
    val timeout_s = rt_env_get("SIMPLE_TIMEOUT_SECONDS") ?? "unset"
    val log_level = rt_env_get("SIMPLE_LOG") ?? "unset"
    val now = rt_time_now_unix_micros() ?? 0

    val nl = "\n"
    var entry = "=== MCP Startup ===" + nl
    entry = entry + "server: " + server_name + nl
    entry = entry + "version: " + server_version + nl
    entry = entry + "timestamp_us: " + str(now) + nl
    entry = entry + "cwd: " + cwd + nl
    entry = entry + "simple_lib: " + simple_lib + nl
    entry = entry + "simple_binary: " + simple_binary + nl
    entry = entry + "memory_limit_mb: " + memory_limit + nl
    entry = entry + "timeout_s: " + timeout_s + nl
    entry = entry + "log_level: " + log_level + nl
    entry = entry + "==================" + nl + nl

    val log_dir = ".simple/logs"
    rt_dir_create_all(log_dir)
    val log_path = log_dir + "/" + server_name + "_startup.log"
    rt_file_append_text(log_path, entry)
