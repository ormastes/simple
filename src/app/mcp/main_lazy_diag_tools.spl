#![allow(unnamed_duplicate_typed_args)]
# MCP Lazy Server - Diagnostic tool handlers
# Extracted from main_lazy.spl
# Handles: simple_read, simple_status, simple_edit, simple_multi_edit, simple_api
# NOTE: simple_check, simple_symbols, simple_run, simple_diagnostics
#       are now handled by cli_passthrough via tool_table.spl

val _DIAG_NL = "\n"

# ============================================================================
# Structured diagnostics helpers
# ============================================================================

fn _diag_to_int_or(s: text, default_val: i64) -> i64:
    # Inline int parser — MCP servers avoid stdlib imports to prevent OOM
    val t = s.trim()
    if t == "":
        return default_val
    var i = 0
    for ch in t:
        if ch >= "0" and ch <= "9":
            i = i + 1
            continue
        if i == 0 and ch == "-":
            i = i + 1
            continue
        return default_val
    int(t)

fn strip_ansi(s: text) -> text:
    # Strip ANSI escape codes: \033[...m patterns
    var parts: [text] = []
    var in_escape = false
    for ch in s:
        if in_escape:
            if ch == "m":
                in_escape = false
            continue
        if ch == "\033" or ch == "\x1b":
            in_escape = true
            continue
        parts.push(ch)
    parts.join("")

fn parse_diag_text_line(line: text) -> text:
    # Parses: path:line:col: error/warning: message
    # Returns formatted: "  Error (line N, col N): message (simple)"
    # Or empty string if not a diagnostic line
    val clean = strip_ansi(line)
    val trimmed = clean.trim()
    if trimmed == "":
        return ""

    # Match pattern: something:N:N: severity_word
    # Find first colon after path
    var colon1 = -1
    var colon2 = -1
    var colon3 = -1
    var pos = 0
    for ch in trimmed:
        if ch == ":":
            if colon1 < 0:
                colon1 = pos
            elif colon2 < 0:
                colon2 = pos
            elif colon3 < 0:
                colon3 = pos
                break
        pos = pos + 1

    if colon3 < 0:
        return ""

    # Extract line number and column
    val line_str = trimmed.substring(colon1 + 1, colon2)
    val col_str = trimmed.substring(colon2 + 1, colon3)

    # Check these are numbers
    val line_num = _diag_to_int_or(line_str.trim(), 0)
    val col_num = _diag_to_int_or(col_str.trim(), 0)
    if line_num == 0 and line_str.trim() != "0":
        return ""

    # Extract severity + message after third colon
    val after = trimmed.substring(colon3 + 1, trimmed.len()).trim()

    var severity = "Error"
    var message = after
    if after.starts_with("error"):
        severity = "Error"
        message = after.substring(5, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("warning"):
        severity = "Warning"
        message = after.substring(7, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("info"):
        severity = "Information"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("hint"):
        severity = "Hint"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    else:
        # Not a recognized severity — could be a non-diagnostic line
        return ""

    if message == "":
        message = after

    "  " + severity + " (line " + line_str.trim() + ", col " + col_str.trim() + "): " + message + " (simple)"

fn format_new_diagnostics_block(path: text, check_output: text) -> text:
    val lines = check_output.split(_DIAG_NL)
    var diag_lines: [text] = []
    for line in lines:
        val formatted = parse_diag_text_line(line)
        if formatted != "":
            diag_lines.push(formatted)
    if diag_lines.len() == 0:
        return ""
    var parts: [text] = []
    parts.push("<new-diagnostics>" + _DIAG_NL)
    parts.push(path + ":" + _DIAG_NL)
    for dl in diag_lines:
        parts.push(dl + _DIAG_NL)
    parts.push("</new-diagnostics>")
    parts.join("")

fn run_structured_diagnostics(path: text) -> (text, i64):
    val _bin = _mcp_find_simple_binary()
    shell_cmd("timeout 30 " + _bin + " check " + path + " 2>&1")

# ============================================================================
# simple_read — Read source file with line numbers + diagnostics
# ============================================================================

fn handle_simple_read(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")

    val source = file_read(path)
    if source == "":
        return make_tool_error(id, -32602, "Could not read file: " + path)

    # Add line numbers
    val lines = source.split(_DIAG_NL)
    var num_parts: [text] = []
    var line_num = 0
    for line in lines:
        line_num = line_num + 1
        num_parts.push(str(line_num) + " | " + line + _DIAG_NL)
    val numbered = num_parts.join("")

    # Run diagnostics
    var check_out = ""
    var check_exit: i64 = 0
    (check_out, check_exit) = run_structured_diagnostics(path)

    var out_parts: [text] = []
    out_parts.push("-- " + path)
    if check_exit == 0:
        out_parts.push(" [clean]")
    else:
        out_parts.push(" [has diagnostics]")
    out_parts.push(" --" + _DIAG_NL)
    out_parts.push(numbered)

    if check_exit != 0:
        val diag_block = format_new_diagnostics_block(path, check_out)
        if diag_block != "":
            out_parts.push(_DIAG_NL + diag_block)
        else:
            out_parts.push(_DIAG_NL + "-- diagnostics --" + _DIAG_NL)
            out_parts.push(check_out)

    make_tool_result(id, out_parts.join(""))

# simple_check, simple_symbols — removed (now CLI passthrough via tool_table)

fn _parse_diag_json_line(line: text) -> text:
    val clean = strip_ansi(line)
    val trimmed = clean.trim()
    if trimmed == "":
        return ""

    var colon1 = -1
    var colon2 = -1
    var colon3 = -1
    var pos = 0
    for ch in trimmed:
        if ch == ":":
            if colon1 < 0:
                colon1 = pos
            elif colon2 < 0:
                colon2 = pos
            elif colon3 < 0:
                colon3 = pos
                break
        pos = pos + 1

    if colon3 < 0:
        return ""

    val line_str = trimmed.substring(colon1 + 1, colon2).trim()
    val col_str = trimmed.substring(colon2 + 1, colon3).trim()
    val line_num = _diag_to_int_or(line_str, -1)
    val col_num = _diag_to_int_or(col_str, -1)
    if line_num < 0 or col_num < 0:
        return ""

    val after = trimmed.substring(colon3 + 1, trimmed.len()).trim()
    var severity = ""
    var message = after

    if after.starts_with("error"):
        severity = "error"
        message = after.substring(5, after.len()).trim()
    elif after.starts_with("warning"):
        severity = "warning"
        message = after.substring(7, after.len()).trim()
    elif after.starts_with("info"):
        severity = "info"
        message = after.substring(4, after.len()).trim()
    elif after.starts_with("hint"):
        severity = "hint"
        message = after.substring(4, after.len()).trim()
    else:
        return ""

    if message.starts_with(":"):
        message = message.substring(1, message.len()).trim()

    jo4(
        jp("line", str(line_num)),
        jp("column", str(col_num)),
        jp("severity", js(severity)),
        jp("message", js(message))
    )

fn _parse_diag_entries_json(check_output: text) -> (text, i64):
    val lines = check_output.split(_DIAG_NL)
    var entries: [text] = []
    for line in lines:
        val entry = _parse_diag_json_line(line)
        if entry != "":
            entries.push(entry)
    ("[" + entries.join(",") + "]", entries.len())

fn handle_simple_symbols(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")
    val _bin = _mcp_find_simple_binary()
    val (out, exit_code) = shell_cmd("timeout 30 " + _bin + " run src/app/cli/query_visibility.spl symbols " + path + " --requester " + path + " 2>&1")
    if exit_code != 0:
        return make_tool_error(id, "Could not list symbols for: " + path)
    make_tool_result(id, out)

fn handle_simple_diagnostics(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")

    var check_out = ""
    var check_exit: i64 = 0
    (check_out, check_exit) = run_structured_diagnostics(path)

    if check_exit == 124:
        return make_tool_error(id, -32001, "simple_diagnostics timed out for " + path)

    var entries_json = "[]"
    var entry_count: i64 = 0
    (entries_json, entry_count) = _parse_diag_entries_json(check_out)

    var summary = "OK: no diagnostics for " + path
    if entry_count > 0:
        summary = "Found " + str(entry_count) + " diagnostic(s) for " + path

    val content = "[" + jo2(jp("type", js("text")), jp("text", js(summary))) + "]"
    val structured = jo4(
        jp("path", js(path)),
        jp("diagnostics", entries_json),
        jp("count", str(entry_count)),
        jp("isError", if check_exit == 0 then "false" else "true")
    )
    val result = jo2(jp("content", content), jp("structuredContent", structured))
    make_json_result(id, result)

# ============================================================================
# simple_status — Project diagnostic overview
# ============================================================================

fn handle_simple_status(id: text, body: text) -> text:
    val paths_str = extract_field(body, "paths")

    var file_list_str = ""
    if paths_str != "":
        file_list_str = paths_str
    else:
        # Get changed files from jj
        var jj_out = ""
        var jj_exit: i64 = 0
        (jj_out, jj_exit) = shell_cmd("timeout 10 jj --no-pager --color never diff -r @ --stat 2>/dev/null")
        if jj_exit == 0 and jj_out.trim() != "":
            file_list_str = extract_spl_from_stat(jj_out)
        if file_list_str == "":
            # Fallback: find spl files
            val dir = extract_field(body, "directory")
            var scan_dir = "src/"
            if dir != "":
                scan_dir = dir
            var find_out = ""
            var _unused: i64 = 0
            (find_out, _unused) = shell_cmd("timeout 10 find " + scan_dir + " -name '*.spl' -type f | sort | head -30")
            file_list_str = find_out.trim()

    if file_list_str == "":
        return make_tool_result(id, "-- Project Diagnostics --" + _DIAG_NL + "No .spl files found to check.")

    # Keep native MCP status bounded and non-recursive: do not invoke the
    # compiler from inside the MCP process. Detailed diagnostics are available
    # via simple_diagnostics/simple_check.
    val files = file_list_str.split(_DIAG_NL)
    var out_parts: [text] = []
    out_parts.push("-- Project Diagnostics --" + _DIAG_NL)
    var total_files = 0

    for fpath in files:
        val fp = fpath.trim()
        if fp == "" or not fp.ends_with(".spl"):
            continue
        total_files = total_files + 1
        if total_files > 10:
            continue
        out_parts.push("  " + fp + "  queued" + _DIAG_NL)

    out_parts.push("-- " + str(total_files) + " candidate file(s)")
    if total_files > 10:
        out_parts.push(" (showing first 10)")
    out_parts.push(" --")
    make_tool_result(id, out_parts.join(""))

fn extract_spl_from_stat(stat_output: text) -> text:
    var parts: [text] = []
    val lines = stat_output.split(_DIAG_NL)
    for line in lines:
        val t = line.trim()
        val pipe_idx = t.index_of(" |") ?? -1
        if pipe_idx > 0:
            val fname = first_n_chars(t, pipe_idx).trim()
            if fname.ends_with(".spl"):
                parts.push(fname)
        elif t.ends_with(".spl"):
            parts.push(t)
    parts.join(_DIAG_NL)

# ============================================================================
# simple_edit — Edit file (find/replace) with diagnostic check
# ============================================================================

fn handle_simple_edit(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val old_string = extract_field(body, "old_string")
    val new_string = extract_field(body, "new_string")

    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")
    if old_string == "":
        return make_tool_error(id, -32602, "Missing required parameter: old_string")

    val content = file_read(path)
    if content == "":
        return make_tool_error(id, -32602, "Could not read file: " + path)

    val idx = content.index_of(old_string) ?? -1
    if idx < 0:
        return make_tool_error(id, -32602, "old_string not found in file")

    # Perform replacement
    val before = first_n_chars(content, idx)
    val after = content.substring(idx + old_string.len())
    val new_content = before + new_string + after

    # Write file
    file_write(path, new_content)

    # Check diagnostics after edit
    var check_out = ""
    var check_exit: i64 = 0
    (check_out, check_exit) = run_structured_diagnostics(path)

    # Find edit line number
    val before_lines = before.split(_DIAG_NL)
    val edit_line = before_lines.len()

    var out_parts: [text] = []
    out_parts.push("-- edit " + path + ":" + str(edit_line) + " --" + _DIAG_NL)
    out_parts.push("Replaced " + str(old_string.len()) + " chars with " + str(new_string.len()) + " chars" + _DIAG_NL)

    if check_exit == 0:
        out_parts.push("Diagnostics: clean (no errors)")
    else:
        val diag_block = format_new_diagnostics_block(path, check_out)
        if diag_block != "":
            out_parts.push(diag_block)
        else:
            out_parts.push(_DIAG_NL + "-- post-edit diagnostics --" + _DIAG_NL)
            out_parts.push(check_out)

    make_tool_result(id, out_parts.join(""))

# ============================================================================
# simple_multi_edit — Batch edits with single recheck
# ============================================================================

fn handle_simple_multi_edit(id: text, body: text) -> text:
    val path = extract_field(body, "path")
    val edits_str = extract_field(body, "edits")

    if path == "":
        return make_tool_error(id, -32602, "Missing required parameter: path")
    if edits_str == "":
        return make_tool_error(id, -32602, "Missing required parameter: edits")

    var content = file_read(path)
    if content == "":
        return make_tool_error(id, -32602, "Could not read file: " + path)

    # Parse and apply edits: find each old_string/new_string pair
    var edit_count = 0
    var search_pos = 0
    var _edit_loop = true
    while _edit_loop:
        val old_key_search = "\"old_string\":"
        val old_idx = find_in_text(edits_str, old_key_search, search_pos)
        if old_idx < 0:
            _edit_loop = false
            continue
        val old_val = extract_quoted_after(edits_str, old_idx + old_key_search.len())

        val new_key_search = "\"new_string\":"
        val new_idx = find_in_text(edits_str, new_key_search, old_idx)
        if new_idx < 0:
            _edit_loop = false
            continue
        val new_val = extract_quoted_after(edits_str, new_idx + new_key_search.len())

        # Apply edit
        val rep_idx = content.index_of(old_val) ?? -1
        if rep_idx >= 0:
            val before = first_n_chars(content, rep_idx)
            val after = content.substring(rep_idx + old_val.len())
            content = before + new_val + after
            edit_count = edit_count + 1

        search_pos = new_idx + new_key_search.len() + new_val.len()

    file_write(path, content)

    var check_out = ""
    var check_exit: i64 = 0
    (check_out, check_exit) = run_structured_diagnostics(path)

    var out_parts: [text] = []
    out_parts.push("-- multi-edit " + path + " (" + str(edit_count) + " edits applied) --" + _DIAG_NL)
    if check_exit == 0:
        out_parts.push("Diagnostics: clean (no errors)")
    else:
        val diag_block = format_new_diagnostics_block(path, check_out)
        if diag_block != "":
            out_parts.push(diag_block)
        else:
            out_parts.push(_DIAG_NL + "-- post-edit diagnostics --" + _DIAG_NL)
            out_parts.push(check_out)

    make_tool_result(id, out_parts.join(""))

fn find_in_text(haystack: text, needle: text, start: i64) -> i64:
    if start >= haystack.len():
        return -1
    val sub = haystack.substring(start)
    val idx = sub.index_of(needle) ?? -1
    if idx < 0:
        return -1
    start + idx

fn extract_quoted_after(s: text, start: i64) -> text:
    # Find opening quote after start position, then read until closing quote
    var pos = 0
    var found_open = false
    var parts: [text] = []
    var escaped = false
    for ch in s:
        if pos < start:
            pos = pos + 1
            continue
        if not found_open:
            if ch == "\"":
                found_open = true
            pos = pos + 1
            continue
        if escaped:
            if ch == "n":
                parts.push(_DIAG_NL)
            elif ch == "t":
                parts.push("\t")
            else:
                parts.push(ch)
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            break
        else:
            parts.push(ch)
        pos = pos + 1
    parts.join("")

# simple_diagnostics, simple_run — removed (now CLI passthrough via tool_table)

# ============================================================================
# simple_api — Search module API
# ============================================================================

fn handle_simple_api(id: text, body: text) -> text:
    val module_name = extract_field(body, "module")
    val query = extract_field(body, "query")
    val visibility = extract_field(body, "visibility")

    if module_name == "" and query == "":
        return make_tool_error(id, -32602, "Provide 'module' or 'query' parameter")

    var search_cmd = ""
    if module_name != "":
        # Search for module file and grep for fn/class/struct/export
        search_cmd = "timeout 15 find src/ -name '*.spl' -path '*" + module_name + "*' | head -5 | xargs timeout 15 grep -n '^fn \\|^class \\|^struct \\|^enum \\|^export ' 2>/dev/null | head -50"
    else:
        # Search all files for query
        search_cmd = "timeout 15 grep -rn '" + query + "' src/ --include='*.spl' 2>/dev/null | head -50"

    var api_out = ""
    var _unused: i64 = 0
    (api_out, _unused) = shell_cmd(search_cmd)

    var out_parts: [text] = []
    out_parts.push("-- simple_api")
    if module_name != "":
        out_parts.push(" module=" + module_name)
    if query != "":
        out_parts.push(" query=" + query)
    out_parts.push(" --" + _DIAG_NL)
    if api_out.trim() == "":
        out_parts.push("No results found.")
    else:
        out_parts.push(api_out)
    make_tool_result(id, out_parts.join(""))
