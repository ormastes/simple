    e.required_json = build_required(["session_id"])
    e.idempotent = true
    t.push(e)

    e = tool_entry("play_ui_ensure", "[play] Await a semantic UI goal state", "play", "in_process", "", 15)
    e.props_json = build_props([
        "session_id", prop_str("session_id", "Session ID"),
        "surface_id", prop_str("surface_id", "Optional surface filter"),
        "canonical_id", prop_str("canonical_id", "Optional exact canonical id"),
        "kind", prop_str("kind", "Optional kind filter"),
        "text", prop_str("text", "Optional text substring match"),
        "focused_only", prop_str("focused_only", "\"true\" to require focus"),
        "expectation", prop_str("expectation", "present | absent | focused | value_eq | ..."),
        "expected_value", prop_str("expected_value", "Expected value for value_eq"),
