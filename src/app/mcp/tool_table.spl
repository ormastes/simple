    e = tool_entry("play_ui_query", "[play] Query canonical UI nodes", "play", "in_process", "", 15)
    e.props_json = build_props([
        "session_id", prop_str("session_id", "Session ID"),
        "surface_id", prop_str("surface_id", "Optional surface filter"),
        "canonical_id", prop_str("canonical_id", "Optional exact canonical id"),
