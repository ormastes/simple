    e = tool_entry("play_sdl2_screenshot", "[play] Screenshot SDL2 app", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Session ID"), "path", prop_str("path", "Output path (optional)")])
    e.required_json = build_required(["session_id"])
