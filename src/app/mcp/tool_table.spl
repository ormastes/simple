# MCP Tool Table — all tool definitions in one place
#
# handler_kind values:
#   "cli"           — generic CLI passthrough: bin/simple <cli_command> <args>
#   "vcs"           — custom VCS handler (jj multi-step commands)
#   "in_process"    — in-process handler (edit, read, debug, tasks)
#   "query"         — custom query handler (deps, context, api_diff, search)
#   "test_daemon"   — test daemon IPC handler
#
# For "cli" tools, cli_passthrough.spl builds the command automatically.
# For others, dispatch routes to existing named handler functions.

use .tool_registry

fn get_tool_table() -> [McpToolEntry]:
    var t: [McpToolEntry] = []

    # =========================================================================
    # Debug tools (19) — in_process (will be dap_bridge in Phase 3)
    # =========================================================================
    var e = tool_entry("debug_create_session", "[debug] Create a debug session (native DAP handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["program", prop_str("program", "Path to program"), "target_type", prop_str("target_type", "interpreter|smf|native|remote|t32|t32_gdb|openocd")])
    e.required_json = build_required(["program"])
    t.push(e)

    e = tool_entry("debug_list_sessions", "[debug] List active debug sessions (native DAP handler)", "debug", "in_process", "", 10)
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_close_session", "[debug] Close a debug session (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.destructive = true
    t.push(e)

    e = tool_entry("debug_set_breakpoint", "[debug] Set a breakpoint (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "file", prop_str_nodesc("file"), "line", prop_str_nodesc("line"), "condition", prop_str_nodesc("condition")])
    e.required_json = build_required(["session_id", "file", "line"])
    t.push(e)

    e = tool_entry("debug_remove_breakpoint", "[debug] Remove a breakpoint (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "breakpoint_id", prop_str_nodesc("breakpoint_id")])
    e.required_json = build_required(["session_id", "breakpoint_id"])
    e.destructive = true
    t.push(e)

    e = tool_entry("debug_continue", "[debug] Continue execution (native DAP handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("debug_step", "[debug] Step through code (native DAP handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "mode", prop_str("mode", "over|in|out")])
    e.required_json = build_required(["session_id", "mode"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("debug_get_variables", "[debug] Get variable values (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_stack_trace", "[debug] Get stack trace (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_evaluate", "[debug] Evaluate expression (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "expression", prop_str_nodesc("expression")])
    e.required_json = build_required(["session_id", "expression"])
    t.push(e)

    e = tool_entry("debug_set_function_breakpoint", "[debug] Set function breakpoint (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "function_name", prop_str_nodesc("function_name")])
    e.required_json = build_required(["session_id", "function_name"])
    t.push(e)

    e = tool_entry("debug_enable_breakpoint", "[debug] Enable/disable breakpoint (native DAP handler)", "debug", "in_process", "", 10)
