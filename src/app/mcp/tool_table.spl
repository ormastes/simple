    e.required_json = build_required(["session_id", "breakpoint_id", "enabled"])
    t.push(e)

    e = tool_entry("debug_get_source", "[debug] Get source code (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "file", prop_str_nodesc("file"), "start_line", prop_str_nodesc("start_line"), "count", prop_str_nodesc("count")])
    e.required_json = build_required(["session_id", "file"])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_watch", "[debug] Add watch expression (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "action", prop_str_nodesc("action"), "expression", prop_str_nodesc("expression")])
    e.required_json = build_required(["session_id", "action"])
    t.push(e)

    e = tool_entry("debug_set_variable", "[debug] Set variable value (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "name", prop_str_nodesc("name"), "value", prop_str_nodesc("value"), "frame_index", prop_str_nodesc("frame_index")])
    e.required_json = build_required(["session_id", "name", "value"])
    t.push(e)

    e = tool_entry("debug_set_data_breakpoint", "[debug] Set variable-change breakpoint (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "name", prop_str_nodesc("name"), "access_type", prop_str_nodesc("access_type"), "condition", prop_str_nodesc("condition")])
    e.required_json = build_required(["session_id", "name"])
    t.push(e)

    e = tool_entry("debug_list_data_breakpoints", "[debug] List variable-change breakpoints (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_remove_data_breakpoint", "[debug] Remove variable-change breakpoint (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id"), "breakpoint_id", prop_str_nodesc("breakpoint_id")])
    e.required_json = build_required(["session_id", "breakpoint_id"])
    e.destructive = true
    t.push(e)

    e = tool_entry("debug_terminate", "[debug] Terminate debug session (native DAP handler)", "debug", "in_process", "", 10)
    e.props_json = build_props(["session_id", prop_str_nodesc("session_id")])
    e.required_json = build_required(["session_id"])
    e.destructive = true
    t.push(e)

    # Hardware debug tools (6) — in_process stubs
    e = tool_entry("debug_trace_capture", "[debug] T32 ETM trace capture (native hardware handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Debug session id"), "duration_ms", prop_str("duration_ms", "Trace duration in ms")])
    e.required_json = build_required(["session_id"])
    t.push(e)

    e = tool_entry("debug_coverage_collect", "[debug] T32 code coverage (native hardware handler)", "debug", "in_process", "", 30)
