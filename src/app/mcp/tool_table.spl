    t.push(e)

    e = tool_entry("play_sdl2_elements", "[play] List elements in SDL2 app", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Session ID")])
    e.required_json = build_required(["session_id"])
    e.idempotent = true
    t.push(e)

    e = tool_entry("play_sdl2_state", "[play] Get SDL2 app state", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Session ID")])
    e.required_json = build_required(["session_id"])
    e.idempotent = true
    t.push(e)

    # play_ui_* — universal /api/test/ui/* surface (host WM, TUI web,
    # standalone Simple app, SimpleOS compositor bridge).
    e = tool_entry("play_ui_connect", "[play] Connect to any Simple UI test API endpoint", "play", "in_process", "", 15)
    e.props_json = build_props(["base_url", prop_str("base_url", "Base URL of the test API (e.g. http://127.0.0.1:8765)")])
    e.required_json = build_required(["base_url"])
