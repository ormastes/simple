    # SDL2 backend tools
    e = tool_entry("play_sdl2_connect", "[play] Connect to SDL2 app test API", "play", "in_process", "", 15)
    e.props_json = build_props(["base_url", prop_str("base_url", "Base URL of the test API (e.g. http://127.0.0.1:17645)")])
    e.required_json = build_required(["base_url"])
    e.idempotent = true
    t.push(e)

    e = tool_entry("play_sdl2_click", "[play] Click widget in SDL2 app", "play", "in_process", "", 15)
