    e.required_json = build_required(["session_id", "widget_id"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_sdl2_fill", "[play] Fill widget in SDL2 app", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Session ID"), "widget_id", prop_str("widget_id", "Widget ID"), "value", prop_str("value", "Value to fill")])
    e.required_json = build_required(["session_id", "widget_id", "value"])
