    # =========================================================================
    # Debug log tools (6) — CLI passthrough to bin/simple log
    # =========================================================================
    e = tool_entry("debug_log_enable", "[debug-log] Enable debug logging", "debug-log", "cli", "log enable", 10)
    e.props_json = build_props(["pattern", prop_str_nodesc("pattern")])
    t.push(e)

    e = tool_entry("debug_log_disable", "[debug-log] Disable debug logging", "debug-log", "cli", "log disable", 10)
    t.push(e)

    e = tool_entry("debug_log_clear", "[debug-log] Clear debug logs", "debug-log", "cli", "log clear", 10)
    e.destructive = true
    t.push(e)

    e = tool_entry("debug_log_query", "[debug-log] Query debug logs", "debug-log", "cli", "log query", 10)
    e.props_json = build_props(["since_id", prop_int("since_id", "Return entries after this ID"), "entry_type", prop_str_nodesc("entry_type"), "max_results", prop_int("max_results", "Max entries to return"), "function_pattern", prop_str_nodesc("function_pattern")])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_log_tree", "[debug-log] Get debug log tree", "debug-log", "cli", "log tree", 10)
    e.props_json = build_props(["format", prop_str_nodesc("format"), "max_depth", prop_int("max_depth", "Max tree depth"), "since_id", prop_int("since_id", "Since entry ID"), "expanded_groups", prop_str_nodesc("expanded_groups")])
    e.read_only = true
    t.push(e)

    e = tool_entry("debug_log_status", "[debug-log] Get debug log status", "debug-log", "cli", "log status", 10)
    e.read_only = true
    t.push(e)

    # =========================================================================
    # Diagnostic tools — in_process (read, edit, multi_edit)
