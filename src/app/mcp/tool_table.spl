    e = tool_entry("debug_system_reset", "[debug] Hardware reset (native hardware handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Debug session id")])
    e.required_json = build_required(["session_id"])
    e.destructive = true
    e.idempotent = false
    e.open_world = true
    t.push(e)

    e = tool_entry("debug_practice_script", "[debug] T32 PRACTICE script execution (native hardware handler)", "debug", "in_process", "", 60)
    e.props_json = build_props(["session_id", prop_str("session_id", "Debug session id"), "script", prop_str("script", "PRACTICE script path or command")])
    e.required_json = build_required(["session_id", "script"])
    e.idempotent = false
    e.open_world = true
    t.push(e)

    e = tool_entry("debug_openocd_monitor", "[debug] Raw OpenOCD telnet command (native hardware handler)", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Debug session id"), "command", prop_str("command", "OpenOCD telnet command")])
    e.required_json = build_required(["session_id", "command"])
    e.idempotent = false
    e.open_world = true
    t.push(e)

    # T32 Dialog tools (5) — in_process, t32rem-based
    e = tool_entry("debug_dialog_list", "[debug] List T32 windows and open PRACTICE dialogs", "debug", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "T32 debug session id")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
