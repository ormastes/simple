    e = tool_entry("play_last_trace", "[play] Dump CDP protocol trace log for session", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("play_wm_screenshot", "[play] Native desktop screenshot", "play", "in_process", "", 15)
    e.props_json = build_props(["path", prop_str("path", "Output file path")])
    e.required_json = build_required(["path"])
    e.read_only = true
    t.push(e)

    e = tool_entry("play_wm_list", "[play] List native OS windows", "play", "in_process", "", 15)
    e.read_only = true
    t.push(e)

    e = tool_entry("play_wm_click", "[play] Click at screen coordinates (native WM)", "play", "in_process", "", 15)
    e.props_json = build_props(["x", prop_str("x", "X coordinate"), "y", prop_str("y", "Y coordinate")])
    e.required_json = build_required(["x", "y"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_wm_type", "[play] Type text via native keyboard", "play", "in_process", "", 15)
    e.props_json = build_props(["text", prop_str("text", "Text to type")])
    e.required_json = build_required(["text"])
