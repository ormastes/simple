    e.required_json = build_required(["session_id"])
    e.idempotent = false
    e.open_world = true
    t.push(e)

    e = tool_entry("debug_dialog_set", "[debug] Set T32 PRACTICE dialog field value", "debug", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "T32 debug session id"), "item_name", prop_str("item_name", "Dialog control name"), "value", prop_str("value", "Value to set")])
    e.required_json = build_required(["session_id", "item_name"])
    e.idempotent = false
    e.open_world = true
    t.push(e)

    e = tool_entry("debug_dialog_track", "[debug] Execute T32 command and track dialog state changes", "debug", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "T32 debug session id"), "command", prop_str("command", "T32 command to execute"), "item_names", prop_str("item_names", "Comma-separated dialog control names to monitor"), "timeout_ms", prop_str("timeout_ms", "Max wait for state change (default 3000)")])
    e.required_json = build_required(["session_id", "command"])
    e.idempotent = false
    e.open_world = true
    t.push(e)

    # =========================================================================
    # Play tools (15) — Playwright-compatible UI automation (in_process)
    # =========================================================================

    e = tool_entry("play_run", "[play] Orchestrate npm/playwright/vscode-test run under xvfb", "play", "in_process", "", 120)
    e.props_json = build_props(["target_dir", prop_str("target_dir", "Directory containing tests (auto-detects runner)")])
    e.required_json = build_required(["target_dir"])
    t.push(e)

    e = tool_entry("play_launch", "[play] Launch Electron app with CDP, return session_id", "play", "in_process", "", 60)
    e.props_json = build_props(["app_path", prop_str("app_path", "Path to Electron app directory or binary")])
    e.required_json = build_required(["app_path"])
    t.push(e)

    e = tool_entry("play_first_window", "[play] Get first window info for a session", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id from play_launch")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("play_click", "[play] Click element by CSS selector", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "selector", prop_str("selector", "CSS selector")])
    e.required_json = build_required(["session_id", "selector"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_fill", "[play] Fill form field by selector", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "selector", prop_str("selector", "CSS selector"), "value", prop_str("value", "Value to fill")])
    e.required_json = build_required(["session_id", "selector", "value"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_type", "[play] Type text into element by selector", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "selector", prop_str("selector", "CSS selector"), "text", prop_str("text", "Text to type")])
    e.required_json = build_required(["session_id", "selector", "text"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_press", "[play] Press key in element by selector", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "selector", prop_str("selector", "CSS selector"), "key", prop_str("key", "Key name (Enter, Tab, etc.)")])
    e.required_json = build_required(["session_id", "selector", "key"])
    e.idempotent = false
    t.push(e)

    e = tool_entry("play_screenshot", "[play] Take screenshot of session page", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "path", prop_str("path", "Output file path (optional, default: artifacts dir)")])
    e.required_json = build_required(["session_id"])
    e.read_only = true
    t.push(e)

    e = tool_entry("play_evaluate", "[play] Evaluate JavaScript in session page", "play", "in_process", "", 30)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id"), "js", prop_str("js", "JavaScript expression to evaluate")])
    e.required_json = build_required(["session_id", "js"])
    t.push(e)

    e = tool_entry("play_close", "[play] Close a play session", "play", "in_process", "", 15)
    e.props_json = build_props(["session_id", prop_str("session_id", "Play session id")])
    e.required_json = build_required(["session_id"])
    e.destructive = true
