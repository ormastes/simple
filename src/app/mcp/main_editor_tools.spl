use .main_lazy_json
use std.editor.core.session.{EditSession}
use std.editor.mcp.session_tools.*

var MCP_EDITOR_SESSION = EditSession.new()

fn is_editor_mcp_tool(name: text) -> bool:
    editor_mcp_session_tool_supported(name)

fn handle_editor_mcp_tool(id: text, name: text, body: text) -> text:
    if not is_editor_mcp_tool(name):
        return make_tool_error(id, -32601, "Unknown editor tool: " + name)

    var args: [text] = []
    if name == "editor.open_file":
        args.push(extract_nested(body, "path"))

    val result = editor_mcp_session_dispatch(MCP_EDITOR_SESSION, name, args)
    if result.ok:
        return make_tool_result(id, result.content)
    make_tool_error(id, -32602, result.content)
