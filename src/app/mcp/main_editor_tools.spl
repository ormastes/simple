use .main_lazy_json
use std.io_runtime.{file_read, file_write}

fn editor_mcp_state_path() -> text:
    "/tmp/simple_mcp_editor_session_state.txt"

fn editor_mcp_argument(body: text, name: text) -> text:
    val params = extract_field_raw(body, "params")
    if params == "null":
        return ""
    val args = extract_field_raw(params, "arguments")
    if args == "null":
        return ""
    extract_field(args, name)

fn handle_editor_mcp_open_file(id: text, body: text) -> text:
    val path = editor_mcp_argument(body, "path")
    if path == "":
        return make_tool_error(id, -32602, "missing path argument")
    val _ = file_write(editor_mcp_state_path(), path)
    make_tool_result(id, "opened " + path)

fn handle_editor_mcp_read_buffer(id: text, body: text) -> text:
    val path = file_read(editor_mcp_state_path()).trim()
    if path == "":
        return make_tool_error(id, -32602, "no active buffer")
    make_tool_result(id, file_read(path))

fn handle_editor_mcp_list_open_files(id: text, body: text) -> text:
    val path = file_read(editor_mcp_state_path()).trim()
    make_tool_result(id, path)
