use .main_lazy_json
use std.editor.mcp.session_tools.*

fn is_editor_mcp_tool(name: text) -> bool:
    editor_mcp_session_tool_supported(name)

fn editor_mcp_argument(body: text, name: text) -> text:
    val params = extract_field_raw(body, "params")
    if params == "null":
        return ""
    val args = extract_field_raw(params, "arguments")
    if args == "null":
        return ""
    extract_field(args, name)

fn editor_mcp_args(name: text, body: text) -> [text]:
    var args: [text] = []
    if name == "editor.open_file":
        args.push(editor_mcp_argument(body, "path"))
    args

fn editor_mcp_response(id: text, result: EditorMcpSessionResult) -> text:
    if result.ok:
        return make_tool_result(id, result.content)
    make_tool_error(id, -32602, result.content)
