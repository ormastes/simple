use .main_lazy_json
use std.editor.mcp.session_tools.*

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

fn editor_mcp_state_path() -> text:
    "/tmp/simple_mcp_editor_session_state.txt"

fn is_editor_mcp_tool(name: text) -> bool:
    editor_mcp_session_tool_supported(name)

fn editor_mcp_argument(body: text, name: text) -> text:
    val params = extract_field_raw(body, "params")
    if params == "null":
        return ""
    val args = extract_field_raw(params, "arguments")
    if args == "null":
        return ""
    extract_field(args, name)

fn editor_mcp_args(name: text, body: text) -> [text]:
    var args: [text] = []
    if name == "editor.open_file":
        args.push(editor_mcp_argument(body, "path"))
    args

fn editor_mcp_response(id: text, result: EditorMcpSessionResult) -> text:
    if result.ok:
        return make_tool_result(id, result.content)
    make_tool_error(id, -32602, result.content)

fn handle_editor_mcp_open_file(id: text, body: text) -> text:
    val path = editor_mcp_argument(body, "path")
    if path == "":
        return make_tool_error(id, -32602, "missing path argument")
    val _ = rt_file_write_text(editor_mcp_state_path(), path)
    make_tool_result(id, "opened " + path)

fn handle_editor_mcp_read_buffer(id: text, body: text) -> text:
    val path = rt_file_read_text(editor_mcp_state_path()).trim()
    if path == "":
        return make_tool_error(id, -32602, "no active buffer")
    make_tool_result(id, rt_file_read_text(path))

fn handle_editor_mcp_list_open_files(id: text, body: text) -> text:
    val path = rt_file_read_text(editor_mcp_state_path()).trim()
    make_tool_result(id, path)
