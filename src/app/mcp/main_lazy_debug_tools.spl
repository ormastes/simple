        return err
    _unsupported_hw_backend(id, session_id, "debug_practice_script")

fn handle_debug_openocd_monitor(id: text, body: text) -> text:
    val session_id = extract_field(body, "session_id")
    val command = extract_field(body, "command")
    if command == "":
        return make_tool_error(id, -32602, "Missing required parameter: command")
    val (err, _) = _require_hw_session(id, session_id, ["openocd"])
    if err != "":
        return err
    _unsupported_hw_backend(id, session_id, "debug_openocd_monitor")
