#![allow(unnamed_duplicate_typed_args)]
# MCP Lazy Server - Protocol I/O, initialize, tools list, schemas, resources, prompts
# Extracted from main_lazy.spl

extern fn stdin_read_char() -> text

# --- Protocol I/O ---

fn mcp_read_line() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            if result == "":
                return ""
            return result
        result = result + ch
        if ch == "\n":
            return result

fn mcp_read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn read_stdin_message() -> text:
    var content_length = 0
    while true:
        var line = mcp_read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        if line.ends_with("\r\n"):
            line = line.substring(0, line.len() - 2)
        elif line.ends_with("\n"):
            line = line.substring(0, line.len() - 1)
        elif line.ends_with("\r"):
            line = line.substring(0, line.len() - 1)
        if line.starts_with(LB()):
            USE_JSON_LINES = true
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = int(len_str)
    if content_length <= 0:
        return ""
    mcp_read_chars(content_length)

fn write_stdout_message(body: text):
    if USE_JSON_LINES:
        print_raw(body + NL)
    else:
        val byte_count = text_byte_len(body)
        var header = "Content-Length: " + str(byte_count) + "\r" + NL + "\r" + NL
        print_raw(header)
        print_raw(body)

# --- Initialize response ---

fn make_init_response(id: text) -> text:
    if INIT_CACHE != "":
        return make_json_result(id, INIT_CACHE)
    var tools_cap = jo1(jp("listChanged", "true"))
    var resources_cap = jo2(jp("subscribe", "true"), jp("listChanged", "true"))
    var prompts_cap = jo1(jp("listChanged", "true"))
    var caps = jo3(
        jp("tools", tools_cap),
        jp("resources", resources_cap),
        jp("prompts", prompts_cap)
    )
    caps = caps.substring(0, caps.len() - 1) + "," + jp("logging", LB() + RB()) + "," + jp("completions", LB() + RB()) + "," + jp("roots", jo1(jp("listChanged", "false"))) + RB()
    val server_info = jo3(
        jp("name", js(SERVER_NAME)),
        jp("version", js(SERVER_VERSION)),
        jp("instructions", js("Full-featured MCP server with inline tool handlers. All 68 tools available with zero-import fast execution. Long-running tools return task handles for async polling."))
    )
    val result = jo3(
        jp("protocolVersion", js("2025-06-18")),
        jp("capabilities", caps),
        jp("serverInfo", server_info)
    )
    INIT_CACHE = result
    make_json_result(id, result)

# --- Tools list (all 68 tools, minimal schemas) ---

fn make_tools_list(id: text) -> text:
    if TOOLS_CACHE != "":
        return make_json_result(id, TOOLS_CACHE)

    var tool_parts: [text] = []

    # Debug tools (16)
    tool_parts.push(make_tool_schema("debug_create_session", "[debug] Create a debug session (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_list_sessions", "[debug] List active debug sessions (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_close_session", "[debug] Close a debug session (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_set_breakpoint", "[debug] Set a breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_remove_breakpoint", "[debug] Remove a breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_continue", "[debug] Continue execution (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_step", "[debug] Step through code (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_get_variables", "[debug] Get variable values (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_stack_trace", "[debug] Get stack trace (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_evaluate", "[debug] Evaluate expression (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_set_function_breakpoint", "[debug] Set function breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_enable_breakpoint", "[debug] Enable/disable breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_get_source", "[debug] Get source code (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_watch", "[debug] Add watch expression (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_set_variable", "[debug] Set variable value (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_set_data_breakpoint", "[debug] Set variable-change breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_list_data_breakpoints", "[debug] List variable-change breakpoints (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_remove_data_breakpoint", "[debug] Remove variable-change breakpoint (native DAP handler)"))
    tool_parts.push(make_tool_schema("debug_terminate", "[debug] Terminate debug session (native DAP handler)"))

    # Hardware debug tools (6)
    tool_parts.push(make_tool_schema("debug_trace_capture", "[debug] T32 ETM trace capture (native hardware handler)"))
    tool_parts.push(make_tool_schema("debug_coverage_collect", "[debug] T32 code coverage (native hardware handler)"))
    tool_parts.push(make_tool_schema("debug_flash_program", "[debug] Flash ELF to target. Wraps external flash tool; interacts with hardware state"))
    tool_parts.push(make_tool_schema("debug_system_reset", "[debug] Hardware reset. Wraps external reset command; interacts with hardware state"))
    tool_parts.push(make_tool_schema("debug_practice_script", "[debug] T32 PRACTICE script execution. Wraps TRACE32 command interface; interacts with hardware state"))
    tool_parts.push(make_tool_schema("debug_openocd_monitor", "[debug] Raw OpenOCD telnet command. Wraps OpenOCD monitor; interacts with hardware state"))

    # Debug log tools (6)
    tool_parts.push(make_tool_schema("debug_log_enable", "[debug-log] Enable debug logging (native handler)"))
    tool_parts.push(make_tool_schema("debug_log_disable", "[debug-log] Disable debug logging (native handler)"))
    tool_parts.push(make_tool_schema("debug_log_clear", "[debug-log] Clear debug logs (native handler)"))
    tool_parts.push(make_tool_schema("debug_log_query", "[debug-log] Query debug logs (native handler)"))
    tool_parts.push(make_tool_schema("debug_log_tree", "[debug-log] Get debug log tree (native handler)"))
    tool_parts.push(make_tool_schema("debug_log_status", "[debug-log] Get debug log status (native handler)"))

    # Diagnostic read tools (4)
    tool_parts.push(make_tool_schema("simple_read", "[diagnostics] Read Simple source with diagnostics. Wraps bin/simple check; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_check", "[diagnostics] Check Simple source for errors. Wraps bin/simple check; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_symbols", "[diagnostics] List symbols in file. Wraps bin/simple symbols; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_status", "[diagnostics] Get project status. Wraps bin/simple status; default 30s timeout"))

    # MCP diagnostics tool (1)
    tool_parts.push(make_tool_schema("simple_diagnostics", "[diagnostics] Run diagnostics on a file or directory, returning MCP-formatted structured content with diagnostics array. Wraps bin/simple check; default 30s timeout"))

    # Diagnostic edit tools (3)
    tool_parts.push(make_tool_schema("simple_edit", "[diagnostics] Edit Simple source file (native handler)"))
    tool_parts.push(make_tool_schema("simple_multi_edit", "[diagnostics] Edit multiple files (native handler)"))
    tool_parts.push(make_tool_schema("simple_run", "[diagnostics] Run Simple code. Wraps bin/simple run; default 30s timeout"))

    # Diagnostic VCS tools (8)
    tool_parts.push(make_tool_schema("simple_diff", "[vcs] Show file diff. Wraps jj diff; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_log", "[vcs] Show jj log. Wraps jj log; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_squash", "[vcs] Squash commits. Wraps jj squash; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_new", "[vcs] Create new change. Wraps jj new; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_commit", "[vcs] Commit working copy with message. Wraps jj commit; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_push", "[vcs] Set bookmark and push to remote. Wraps jj bookmark set + jj git push; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_rebase", "[vcs] Rebase revision onto destination. Wraps jj rebase; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_pull", "[vcs] Fetch from remote and rebase. Wraps jj git fetch + jj rebase; default 30s timeout"))

    # API search tools (1)
    tool_parts.push(make_tool_schema("simple_api", "[diagnostics] Search module API with visibility-aware filtering. Wraps bin/simple api; default 30s timeout"))

    # CLI tools — Tier 1 (6)
    tool_parts.push(make_tool_schema("simple_test", "[cli] Run tests. Wraps bin/simple test; default 120s timeout"))
    tool_parts.push(make_tool_schema("simple_build", "[cli] Build project. Wraps bin/simple build; default 120s timeout"))
    tool_parts.push(make_tool_schema("simple_format", "[cli] Format file/project. Wraps bin/simple build fmt; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_lint", "[cli] Lint with output. Wraps bin/simple build lint; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_fix", "[cli] Auto-fix issues. Wraps bin/simple fix; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_doc_coverage", "[cli] Doc coverage report. Wraps bin/simple doc-coverage; default 30s timeout"))

    # Analysis tools — Tier 3 (4)
    tool_parts.push(make_tool_schema("simple_dependencies", "[query] Module dependency graph. Wraps bin/simple dependencies; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_api_diff", "[query] API surface diff. Wraps bin/simple api-diff; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_context", "[query] Context pack for AI/docs. Wraps bin/simple context; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_search", "[query] Language-aware code search. Wraps bin/simple search; default 30s timeout"))

    # Background task management (3)
    tool_parts.push(make_tool_schema("task_status", "[task] Get status of a background task (native handler)"))
    tool_parts.push(make_tool_schema("task_cancel", "[task] Cancel a running background task (native handler)"))
    tool_parts.push(make_tool_schema("task_list", "[task] List all background tasks (native handler)"))

    # Code query tools (3)
    tool_parts.push(make_tool_schema("simple_ast_query", "[query] S-expression structural pattern matching against code outline. Wraps bin/simple ast-query; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_sem_query", "[query] CodeQL-style semantic query with SQL-like syntax. Wraps bin/simple sem-query; default 30s timeout"))
    tool_parts.push(make_tool_schema("simple_query_schema", "[query] List available query node types and predicates. Wraps bin/simple query-schema; default 30s timeout"))

    # Test daemon tools (4)
    tool_parts.push(make_tool_schema("test_daemon_run", "[test-daemon] Run test with change detection via test daemon. Wraps IPC to .build/test_daemon; default 120s timeout"))
    tool_parts.push(make_tool_schema("test_daemon_clean", "[test-daemon] Force-run test bypassing cache. Wraps IPC to .build/test_daemon; default 120s timeout"))
    tool_parts.push(make_tool_schema("test_daemon_status", "[test-daemon] Get test daemon status and queue info. Wraps IPC to .build/test_daemon; default 30s timeout"))
    tool_parts.push(make_tool_schema("test_daemon_stop", "[test-daemon] Shut down test daemon. Wraps IPC to .build/test_daemon; default 30s timeout"))

    val tools = SB_L() + tool_parts.join(",") + SB_R()
    val result = jo1(jp("tools", tools))
    TOOLS_CACHE = result
    make_json_result(id, result)

fn make_tool_schema(name: text, description: text) -> text:
    var props = LB() + RB()
    var req = "[]"

    if name == "debug_create_session":
        props = jo2(
            jp("program", jo2(jp("type", js("string")), jp("description", js("Path to program")))),
            jp("target_type", jo2(jp("type", js("string")), jp("description", js("interpreter|smf|native|remote"))))
        )
        req = "[" + js("program") + "]"
    elif name == "debug_close_session" or name == "debug_continue" or name == "debug_get_variables" or name == "debug_stack_trace" or name == "debug_terminate":
        props = jo1(jp("session_id", jo2(jp("type", js("string")), jp("description", js("Debug session id")))))
        req = "[" + js("session_id") + "]"
    elif name == "debug_set_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("file", jo1(jp("type", js("string"))))
        p = p + "," + jp("line", jo1(jp("type", js("string"))))
        p = p + "," + jp("condition", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("file") + "," + js("line") + "]"
    elif name == "debug_remove_breakpoint":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("breakpoint_id", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("breakpoint_id") + "]"
    elif name == "debug_step":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("mode", jo2(jp("type", js("string")), jp("description", js("over|in|out"))))
        )
        req = "[" + js("session_id") + "," + js("mode") + "]"
    elif name == "debug_evaluate":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("expression", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("expression") + "]"
    elif name == "debug_set_function_breakpoint":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("function_name", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("function_name") + "]"
    elif name == "debug_enable_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("breakpoint_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("enabled", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("breakpoint_id") + "," + js("enabled") + "]"
    elif name == "debug_get_source":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("file", jo1(jp("type", js("string"))))
        p = p + "," + jp("start_line", jo1(jp("type", js("string"))))
        p = p + "," + jp("count", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("file") + "]"
    elif name == "debug_watch":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("action", jo1(jp("type", js("string"))))
        p = p + "," + jp("expression", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("action") + "]"
    elif name == "debug_set_variable":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("name", jo1(jp("type", js("string"))))
        p = p + "," + jp("value", jo1(jp("type", js("string"))))
        p = p + "," + jp("frame_index", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("name") + "," + js("value") + "]"
    elif name == "debug_set_data_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("name", jo1(jp("type", js("string"))))
        p = p + "," + jp("access_type", jo1(jp("type", js("string"))))
        p = p + "," + jp("condition", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("name") + "]"
    elif name == "debug_list_data_breakpoints":
        props = jo1(jp("session_id", jo1(jp("type", js("string")))))
        req = "[" + js("session_id") + "]"
    elif name == "debug_remove_data_breakpoint":
