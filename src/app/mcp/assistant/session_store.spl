        _assistant_json_text_any(value, ["child_session_id"])
    )
    task.task_id = _assistant_json_text_any(value, ["id", "task_id"])
    task.session_id = _assistant_json_text_any(value, ["session_id"])
    task.parent_session_id = _assistant_json_text_any(value, ["parent_session_id"])
    task.parent_task_id = _assistant_json_text_any(value, ["parent_task_id"])
    task.child_session_id = _assistant_json_text_any(value, ["child_session_id"])
    task.objective = _assistant_json_text_any(value, ["objective"])
    task.owner_kind = assistant_first_non_empty([_assistant_json_text_any(value, ["owner_kind"]), "assistant"])
    task.status = assistant_first_non_empty([_assistant_json_text_any(value, ["status", "state"]), "queued"])
    task.resource_policy = assistant_first_non_empty([_assistant_json_text_any(value, ["resource_policy"]), "bounded"])
    task.result_summary = _assistant_json_text_any(value, ["result_summary"])
