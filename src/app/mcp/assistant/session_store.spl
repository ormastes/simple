#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Assistant Core File-Backed Store
#
# Persists assistant sessions, timeline events, notifications, and child-task
# metadata under .build/llm_dashboard/assistant so the dashboard collector can
# consume the same files without a live MCP bridge.

use std.common.json.parser.{json_parse}
use std.common.json.serializer.{json_stringify}
use std.common.json.types.{json_get_type, json_is_array, json_object, json_array,
    json_string, json_number, json_to_string, json_to_number}
use std.common.json.object_ops.{json_object_get, json_object_set}
use std.common.json.array_ops.{json_array_get, json_array_length}
use app.mcp.assistant.types.{
    AssistantSessionRecord, AssistantTimelineRecord, AssistantChildTaskRecord,
    assistant_first_non_empty, assistant_now_ms, assistant_generate_session_id,
    assistant_generate_event_id, assistant_generate_task_id, assistant_timeline_severity,
    assistant_timeline_title, assistant_timeline_detail, assistant_session_summary
}

extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

val ASSISTANT_STORE_ROOT = ".build/llm_dashboard/assistant"
val ASSISTANT_STORE_SESSIONS = ASSISTANT_STORE_ROOT + "/sessions"
val ASSISTANT_STORE_TIMELINES = ASSISTANT_STORE_ROOT + "/timelines"
val ASSISTANT_STORE_NOTIFICATIONS = ASSISTANT_STORE_ROOT + "/notifications"

# =========================================================================
# Store Object
# =========================================================================

class AssistantStore:
    root: text

impl AssistantStore:

    static fn new(root: text) -> AssistantStore:
        val resolved = if root.trim() == "": ASSISTANT_STORE_ROOT else: root
        AssistantStore(root: resolved)

    static fn default() -> AssistantStore:
        AssistantStore.new(ASSISTANT_STORE_ROOT)

    fn sessions_dir() -> text:
        "{self.root}/sessions"

    fn timelines_dir() -> text:
        "{self.root}/timelines"

    fn notifications_dir() -> text:
        "{self.root}/notifications"

    fn session_path(session_id: text) -> text:
        "{self.sessions_dir()}/{session_id}.json"

    fn timeline_path(session_id: text) -> text:
        "{self.timelines_dir()}/{session_id}.jsonl"

    fn notifications_path(session_id: text) -> text:
        "{self.notifications_dir()}/{session_id}.jsonl"

    fn ensure_dirs() -> bool:
        rt_mkdir_p(self.sessions_dir()) and rt_mkdir_p(self.timelines_dir()) and rt_mkdir_p(self.notifications_dir())

    fn create_session(session: AssistantSessionRecord) -> AssistantSessionRecord?:
        var normalized = _assistant_normalize_session(session)
        if normalized.session_id == "":
            normalized.session_id = assistant_generate_session_id(assistant_now_ms())
        normalized.updated_at_ms = if normalized.updated_at_ms > 0: normalized.updated_at_ms else: assistant_now_ms()
        normalized.created_at_ms = if normalized.created_at_ms > 0: normalized.created_at_ms else: normalized.updated_at_ms
        if normalized.name.trim() == "":
            normalized.name = normalized.session_id
        if normalized.summary.trim() == "":
            normalized.summary = assistant_session_summary(normalized.name, normalized.prompt, normalized.objective)
        if normalized.objective.trim() == "":
            normalized.objective = assistant_first_non_empty([normalized.summary, normalized.prompt, normalized.name])
        if normalized.mode.trim() == "":
            normalized.mode = "proactive"
        if normalized.state.trim() == "":
            normalized.state = "running"
        if normalized.policy.trim() == "":
            normalized.policy = "bounded"
        if normalized.last_signal.trim() == "":
            normalized.last_signal = ""
        if normalized.last_event_kind.trim() == "":
            normalized.last_event_kind = ""
        if normalized.last_event_detail.trim() == "":
            normalized.last_event_detail = ""
        self.ensure_dirs()
        if not _assistant_write_json(self.session_path(normalized.session_id), _assistant_session_record_to_json_value(normalized)):
            return nil
        self.load_session(normalized.session_id)

    fn load_session(session_id: text) -> AssistantSessionRecord?:
        if session_id.trim() == "":
            return nil
        val path = self.session_path(session_id)
        if not rt_file_exists(path):
            return nil
        val content = rt_file_read_text(path)
        if content.trim() == "":
            return nil
        val record = json_parse(content)
        if record == nil:
            return nil
        var session = _assistant_session_record_from_json_value(record)
        session = _assistant_session_reconcile_paths(self, session)
        session = _assistant_session_merge_timeline(self, session)
        session = _assistant_session_merge_notifications(self, session)
        session = _assistant_session_finalize(session)
        session

    fn list_sessions() -> [AssistantSessionRecord]:
        self.ensure_dirs()
        val entries = rt_dir_list(self.sessions_dir())
        var sessions: [AssistantSessionRecord] = []
        for entry in entries:
            if entry.ends_with(".json"):
                val session_id = entry.slice(0, entry.len() - 5)
                if val loaded = self.load_session(session_id):
                    sessions.push(loaded)
        _assistant_sort_sessions_by_updated_at(sessions)

    fn append_event(event: AssistantTimelineRecord) -> AssistantSessionRecord?:
        var normalized = _assistant_normalize_event(event)
        if normalized.session_id.trim() == "":
            return nil
        self.ensure_dirs()
        val path = self.timeline_path(normalized.session_id)
        if not _assistant_append_jsonl(path, _assistant_timeline_record_to_json_text(normalized)):
            return nil
        _assistant_append_jsonl(self.notifications_path(normalized.session_id), _assistant_timeline_record_to_json_text(normalized))
        if val session = self.load_session(normalized.session_id):
            session.last_signal = if normalized.signal.trim() != "": normalized.signal else: session.last_signal
            session.last_event_kind = normalized.kind
            session.last_event_detail = assistant_first_non_empty([normalized.detail, normalized.message, normalized.signal, normalized.kind])
            session.last_event_time_ms = normalized.timestamp_ms
            session.updated_at_ms = if normalized.timestamp_ms > 0: normalized.timestamp_ms else: assistant_now_ms()
            self._save_session(session)
            return self.load_session(normalized.session_id)
        nil

    fn update_state(session_id: text, new_state: text, wake_reason: text) -> AssistantSessionRecord?:
        if session_id.trim() == "":
            return nil
        if val session = self.load_session(session_id):
            session.state = if new_state.trim() == "": session.state else: new_state
            if wake_reason.trim() != "":
                session.last_signal = wake_reason
            session.updated_at_ms = assistant_now_ms()
            session.last_event_kind = "state"
            session.last_event_detail = session.state
            session.last_event_time_ms = session.updated_at_ms
            val state_event = AssistantTimelineRecord.new(session.session_id, "state", session.state, wake_reason)
            state_event.parent_session_id = session.parent_session_id
            state_event.title = "state"
            state_event.detail = "state -> {session.state}"
            state_event.message = "state -> {session.state}"
            state_event.signal = wake_reason
            state_event.source = "assistant"
            if not _assistant_append_jsonl(self.timeline_path(session.session_id), _assistant_timeline_record_to_json_text(state_event)):
                return nil
            _assistant_append_jsonl(self.notifications_path(session.session_id), _assistant_timeline_record_to_json_text(state_event))
            self._save_session(session)
            return self.load_session(session_id)
        nil

    fn create_child_task(task: AssistantChildTaskRecord) -> AssistantSessionRecord?:
        if task.session_id.trim() == "":
            return nil
        if val session = self.load_session(task.session_id):
            var normalized = task
            if normalized.task_id.trim() == "":
                normalized.task_id = assistant_generate_task_id(session.session_id, assistant_now_ms())
            normalized.parent_session_id = session.session_id
            normalized.updated_at_ms = assistant_now_ms()
            normalized.created_at_ms = if normalized.created_at_ms > 0: normalized.created_at_ms else: normalized.updated_at_ms
            if normalized.status.trim() == "":
                normalized.status = "queued"
            if normalized.owner_kind.trim() == "":
                normalized.owner_kind = "assistant"
            if normalized.resource_policy.trim() == "":
                normalized.resource_policy = "bounded"
            if normalized.objective.trim() == "":
                normalized.objective = normalized.result_summary
            session.child_tasks = _assistant_child_tasks_append(session.child_tasks, normalized)
            if normalized.child_session_id.trim() != "":
                session.children = _assistant_text_list_append_unique(session.children, normalized.child_session_id)
            session.updated_at_ms = normalized.updated_at_ms
            session.last_event_kind = "child_task"
            session.last_event_detail = assistant_first_non_empty([normalized.objective, normalized.child_session_id, normalized.task_id])
            session.last_signal = assistant_first_non_empty([normalized.status, session.last_signal])
            session.event_count = session.event_count + 1
            val child_event = AssistantTimelineRecord.new(session.session_id, "child_task", normalized.objective, normalized.status)
            child_event.child_task_id = normalized.task_id
            child_event.parent_session_id = session.parent_session_id
            child_event.title = "child_task"
            child_event.detail = assistant_first_non_empty([normalized.objective, normalized.child_session_id, normalized.task_id])
            child_event.message = child_event.detail
            child_event.signal = normalized.status
            if not _assistant_append_jsonl(self.timeline_path(session.session_id), _assistant_timeline_record_to_json_text(child_event)):
                return nil
            _assistant_append_jsonl(self.notifications_path(session.session_id), _assistant_timeline_record_to_json_text(child_event))
            self._save_session(session)
            return self.load_session(session.session_id)
        nil

    fn _save_session(session: AssistantSessionRecord) -> bool:
        _assistant_write_json(self.session_path(session.session_id), _assistant_session_record_to_json_value(session))

fn assistant_store_default() -> AssistantStore:
    AssistantStore.default()

fn assistant_store_new(root: text) -> AssistantStore:
    AssistantStore.new(root)

# =========================================================================
# Internal Path / File Helpers
# =========================================================================

fn _assistant_write_json(path: text, value: any) -> bool:
    rt_file_write_text(path, json_stringify(value))

fn _assistant_append_jsonl(path: text, line: text) -> bool:
    var content = ""
    if rt_file_exists(path):
        content = rt_file_read_text(path)
    if content != "" and not content.ends_with("\n"):
        content = content + "\n"
    content = content + line + "\n"
    rt_file_write_text(path, content)

fn _assistant_session_reconcile_paths(store: AssistantStore, session: AssistantSessionRecord) -> AssistantSessionRecord:
    if session.session_id.trim() == "":
        return session
    session

fn _assistant_normalize_session(session: AssistantSessionRecord) -> AssistantSessionRecord:
    var normalized = session
    if normalized.session_id.trim() == "":
        normalized.session_id = assistant_generate_session_id(assistant_now_ms())
    if normalized.name.trim() == "":
        normalized.name = normalized.session_id
    if normalized.summary.trim() == "":
        normalized.summary = assistant_session_summary(normalized.name, normalized.prompt, normalized.objective)
    if normalized.objective.trim() == "":
        normalized.objective = assistant_first_non_empty([normalized.summary, normalized.prompt, normalized.name])
    if normalized.mode.trim() == "":
        normalized.mode = "proactive"
    if normalized.state.trim() == "":
        normalized.state = "running"
    if normalized.policy.trim() == "":
        normalized.policy = "bounded"
    if normalized.created_at_ms <= 0:
        normalized.created_at_ms = assistant_now_ms()
    if normalized.updated_at_ms <= 0:
        normalized.updated_at_ms = normalized.created_at_ms
    if normalized.last_event_detail.trim() == "":
        normalized.last_event_detail = assistant_first_non_empty([normalized.summary, normalized.objective, normalized.state])
    if normalized.last_event_kind.trim() == "":
        normalized.last_event_kind = assistant_first_non_empty([normalized.state, "session"])
    normalized

fn _assistant_normalize_event(event: AssistantTimelineRecord) -> AssistantTimelineRecord:
    var normalized = event
    if normalized.session_id.trim() == "":
        normalized.session_id = ""
    if normalized.kind.trim() == "":
        normalized.kind = "note"
    if normalized.timestamp_ms <= 0:
        normalized.timestamp_ms = assistant_now_ms()
    if normalized.event_id.trim() == "":
        normalized.event_id = assistant_generate_event_id(normalized.session_id, normalized.timestamp_ms, normalized.kind)
    if normalized.severity.trim() == "":
        normalized.severity = assistant_timeline_severity(normalized.kind)
    if normalized.title.trim() == "":
        normalized.title = assistant_timeline_title(normalized.kind, normalized.message, normalized.signal)
    if normalized.detail.trim() == "":
        normalized.detail = assistant_timeline_detail(normalized.kind, normalized.message, normalized.signal)
    if normalized.source.trim() == "":
        normalized.source = "assistant"
    normalized

fn _assistant_session_merge_timeline(store: AssistantStore, session: AssistantSessionRecord) -> AssistantSessionRecord:
    val path = store.timeline_path(session.session_id)
    if not rt_file_exists(path):
        return session
    val content = rt_file_read_text(path)
    if content.trim() == "":
        return session
    var saw_timeline = false
    var last_kind = session.last_event_kind
    var last_detail = session.last_event_detail
    var last_signal = session.last_signal
    var last_time = session.last_event_time_ms
    var event_count = session.event_count
    var error_count = session.error_count
    for raw in content.split("\n"):
        val line = raw.trim()
        if line == "":
            continue
        val record = json_parse(line)
        if record == nil:
            session.warnings = _assistant_text_list_append_unique(session.warnings, "unparsed assistant store timeline line")
            continue
        val event = _assistant_timeline_record_from_json_value(record)
        saw_timeline = true
        event_count = event_count + 1
        if event.timestamp_ms > 0:
            last_time = event.timestamp_ms
        if event.kind.trim() != "":
            last_kind = event.kind
        val summary = assistant_first_non_empty([event.detail, event.message, event.signal, event.kind])
        if summary != "":
            last_detail = summary
        if event.signal.trim() != "":
            last_signal = event.signal
        if event.severity == "danger" or event.kind == "error":
            error_count = error_count + 1
    if saw_timeline:
        if session.summary.trim() == "":
            session.summary = last_detail
        if session.objective.trim() == "":
            session.objective = session.summary
        if session.name.trim() == "":
            session.name = assistant_first_non_empty([session.summary, session.session_id])
        if session.state.trim() == "" and last_kind != "":
            session.state = _assistant_infer_session_state(last_kind, session.state)
        session.last_event_kind = last_kind
        session.last_event_detail = last_detail
        session.last_signal = last_signal
        session.last_event_time_ms = last_time
        session.event_count = event_count
        session.error_count = error_count
    session

fn _assistant_session_merge_notifications(store: AssistantStore, session: AssistantSessionRecord) -> AssistantSessionRecord:
    val path = store.notifications_path(session.session_id)
    if not rt_file_exists(path):
        return session
    val content = rt_file_read_text(path)
    if content.trim() == "":
        return session
    var count = 0
    for raw in content.split("\n"):
        if raw.trim() != "":
            count = count + 1
    session.event_count = if session.event_count > count: session.event_count else: count
    session

fn _assistant_session_finalize(session: AssistantSessionRecord) -> AssistantSessionRecord:
    if session.summary.trim() == "":
        session.summary = assistant_session_summary(session.name, session.prompt, session.objective)
    if session.objective.trim() == "":
        session.objective = assistant_first_non_empty([session.summary, session.prompt, session.name])
    if session.state.trim() == "":
        session.state = "running"
    if session.mode.trim() == "":
        session.mode = "proactive"
    if session.policy.trim() == "":
        session.policy = "bounded"
    if session.last_event_detail.trim() == "":
        session.last_event_detail = assistant_first_non_empty([session.summary, session.objective, session.state])
    if session.last_event_kind.trim() == "":
        session.last_event_kind = assistant_first_non_empty([session.state, "session"])
    if session.updated_at_ms <= 0:
        session.updated_at_ms = assistant_now_ms()
    if session.created_at_ms <= 0:
        session.created_at_ms = session.updated_at_ms
    if session.children.len() == 0 and session.child_tasks.len() > 0:
        for task in session.child_tasks:
            if task.child_session_id.trim() != "":
                session.children = _assistant_text_list_append_unique(session.children, task.child_session_id)
    session

fn _assistant_infer_session_state(kind: text, current: text) -> text:
    match kind:
        "error" => "failed"
        "completed" | "session_end" | "sessionend" | "stop" => "completed"
        "pause" => "paused"
        "resume" | "start" => "running"
        "child_task" => if current.trim() != "": current else: "running"
        _ => if current.trim() != "": current else: "running"

# =========================================================================
# JSON Helpers
# =========================================================================

fn _assistant_json_text(value: any, key: text) -> text:
    val target = json_object_get(value, key)
    if target == nil:
        return ""
    val kind = json_get_type(target)
    if kind == "string":
        val s = json_to_string(target)
        if s == nil:
            return ""
        return s
    if kind == "number":
        val n = json_to_number(target)
        if n == nil:
            return ""
        return "{n as i64}"
    if kind == "boolean":
        if target == nil:
            return ""
        if target.1:
            return "true"
        return "false"
    ""

fn _assistant_json_text_any(value: any, keys: [text]) -> text:
    for key in keys:
        val text_value = _assistant_json_text(value, key)
        if text_value != "":
            return text_value
    ""

fn _assistant_json_number(value: any, key: text) -> i64:
    val target = json_object_get(value, key)
    if target == nil:
        return 0
    if json_get_type(target) != "number":
        return 0
    val n = json_to_number(target)
    if n == nil:
        return 0
    n as i64

fn _assistant_json_number_any(value: any, keys: [text]) -> i64:
    for key in keys:
        val n = _assistant_json_number(value, key)
        if n != 0:
            return n
    0

fn _assistant_json_text_list(value: any, key: text) -> [text]:
    val target = json_object_get(value, key)
    if target == nil or not json_is_array(target):
        return []
    var items: [text] = []
    var i = 0
    val count = json_array_length(target)
    while i < count:
        val entry = json_array_get(target, i)
        val s = _assistant_json_text_any(entry, ["id", "value", "text", "name"])
        if s != "":
            items.push(s)
        i = i + 1
    items

fn _assistant_json_child_tasks(value: any, key: text) -> [AssistantChildTaskRecord]:
    val target = json_object_get(value, key)
    if target == nil or not json_is_array(target):
        return []
    var items: [AssistantChildTaskRecord] = []
    var i = 0
    val count = json_array_length(target)
    while i < count:
        val entry = json_array_get(target, i)
        if entry != nil:
            items.push(_assistant_child_task_record_from_json_value(entry))
        i = i + 1
    items

fn _assistant_put_text(obj: any, key: text, value: text) -> any:
    json_object_set(obj, key, json_string(value))

fn _assistant_put_number(obj: any, key: text, value: i64) -> any:
    json_object_set(obj, key, json_number(value as f64))

fn _assistant_put_text_list(obj: any, key: text, values: [text]) -> any:
    var items: [any] = []
    for value in values:
        items.push(json_string(value))
    json_object_set(obj, key, json_array(items))

fn _assistant_put_child_tasks(obj: any, key: text, tasks: [AssistantChildTaskRecord]) -> any:
    var items: [any] = []
    for task in tasks:
        items.push(_assistant_child_task_record_to_json_value(task))
    json_object_set(obj, key, json_array(items))

fn _assistant_session_record_to_json_value(session: AssistantSessionRecord) -> any:
    var obj = json_object({})
    obj = _assistant_put_text(obj, "id", session.session_id)
    obj = _assistant_put_text(obj, "session_id", session.session_id)
    obj = _assistant_put_text(obj, "name", session.name)
    obj = _assistant_put_text(obj, "summary", session.summary)
    obj = _assistant_put_text(obj, "objective", session.objective)
    obj = _assistant_put_text(obj, "prompt", session.prompt)
    obj = _assistant_put_text(obj, "mode", session.mode)
    obj = _assistant_put_text(obj, "state", session.state)
    obj = _assistant_put_text(obj, "status", session.state)
    obj = _assistant_put_text(obj, "policy", session.policy)
    obj = _assistant_put_text(obj, "parent_session_id", session.parent_session_id)
    obj = _assistant_put_text(obj, "parent_tool_use_id", session.parent_tool_use_id)
    obj = _assistant_put_text(obj, "last_signal", session.last_signal)
    obj = _assistant_put_text(obj, "last_event_kind", session.last_event_kind)
    obj = _assistant_put_text(obj, "last_event_detail", session.last_event_detail)
    obj = _assistant_put_number(obj, "last_event_time", session.last_event_time_ms)
    obj = _assistant_put_number(obj, "last_event_time_ms", session.last_event_time_ms)
    obj = _assistant_put_number(obj, "last_tick_at", session.last_tick_at_ms)
    obj = _assistant_put_number(obj, "last_tick_at_ms", session.last_tick_at_ms)
    obj = _assistant_put_number(obj, "created_at", session.created_at_ms)
    obj = _assistant_put_number(obj, "created_at_ms", session.created_at_ms)
    obj = _assistant_put_number(obj, "updated_at", session.updated_at_ms)
    obj = _assistant_put_number(obj, "updated_at_ms", session.updated_at_ms)
    obj = _assistant_put_number(obj, "event_count", session.event_count)
    obj = _assistant_put_number(obj, "error_count", session.error_count)
    obj = _assistant_put_text(obj, "model", session.model)
    obj = _assistant_put_text(obj, "provider", session.provider)
    obj = _assistant_put_text(obj, "digest_checkpoint_id", session.digest_checkpoint_id)
    obj = _assistant_put_text_list(obj, "tool_use_ids", session.tool_use_ids)
    obj = _assistant_put_text_list(obj, "children", session.children)
    obj = _assistant_put_child_tasks(obj, "child_tasks", session.child_tasks)
    obj = _assistant_put_text_list(obj, "warnings", session.warnings)
    obj

fn _assistant_session_record_from_json_value(value: any) -> AssistantSessionRecord:
    var session = AssistantSessionRecord.new(
        _assistant_json_text_any(value, ["id", "session_id"]),
        _assistant_json_text_any(value, ["name"]),
        _assistant_json_text_any(value, ["prompt"]),
        _assistant_json_text_any(value, ["mode"]),
        _assistant_json_text_any(value, ["parent_session_id"]),
        _assistant_json_text_any(value, ["parent_tool_use_id"]),
        _assistant_json_text_any(value, ["objective", "summary", "prompt", "name"])
    )
    session.summary = _assistant_json_text_any(value, ["summary", "objective", "prompt", "name"])
    session.objective = _assistant_json_text_any(value, ["objective", "summary", "prompt", "name"])
    session.prompt = _assistant_json_text_any(value, ["prompt"])
    session.mode = assistant_first_non_empty([_assistant_json_text_any(value, ["mode"]), "proactive"])
    session.state = assistant_first_non_empty([_assistant_json_text_any(value, ["state", "status"]), "running"])
    session.policy = assistant_first_non_empty([_assistant_json_text_any(value, ["policy"]), "bounded"])
    session.parent_session_id = _assistant_json_text_any(value, ["parent_session_id"])
    session.parent_tool_use_id = _assistant_json_text_any(value, ["parent_tool_use_id", "parentToolUseID"])
    session.last_signal = _assistant_json_text_any(value, ["last_signal", "lastWakeReason", "wake_reason"])
    session.last_event_kind = _assistant_json_text_any(value, ["last_event_kind", "lastEventKind"])
    session.last_event_detail = _assistant_json_text_any(value, ["last_event_detail", "lastEventDetail", "summary"])
    session.last_event_time_ms = _assistant_json_number_any(value, ["last_event_time_ms", "last_event_time", "updated_at_ms", "updated_at"])
    session.last_tick_at_ms = _assistant_json_number_any(value, ["last_tick_at_ms", "last_tick_at"])
    session.created_at_ms = _assistant_json_number_any(value, ["created_at_ms", "created_at"])
    session.updated_at_ms = _assistant_json_number_any(value, ["updated_at_ms", "updated_at"])
    session.event_count = _assistant_json_number_any(value, ["event_count", "timeline_count"])
    session.error_count = _assistant_json_number_any(value, ["error_count"])
    session.model = _assistant_json_text_any(value, ["model"])
    session.provider = _assistant_json_text_any(value, ["provider"])
    session.digest_checkpoint_id = _assistant_json_text_any(value, ["digest_checkpoint_id"])
    session.tool_use_ids = _assistant_json_text_list(value, "tool_use_ids")
    session.children = _assistant_json_text_list(value, "children")
    session.child_tasks = _assistant_json_child_tasks(value, "child_tasks")
    session.warnings = _assistant_json_text_list(value, "warnings")
    session

fn _assistant_timeline_record_to_json_value(event: AssistantTimelineRecord) -> any:
    var obj = json_object({})
    obj = _assistant_put_text(obj, "id", event.event_id)
    obj = _assistant_put_text(obj, "event_id", event.event_id)
    obj = _assistant_put_text(obj, "session_id", event.session_id)
    obj = _assistant_put_text(obj, "parent_session_id", event.parent_session_id)
    obj = _assistant_put_text(obj, "child_task_id", event.child_task_id)
    obj = _assistant_put_number(obj, "timestamp", event.timestamp_ms)
    obj = _assistant_put_number(obj, "timestamp_ms", event.timestamp_ms)
    obj = _assistant_put_number(obj, "created_at", event.timestamp_ms)
    obj = _assistant_put_number(obj, "created_at_ms", event.timestamp_ms)
    obj = _assistant_put_text(obj, "kind", event.kind)
    obj = _assistant_put_text(obj, "event_type", event.kind)
    obj = _assistant_put_text(obj, "severity", event.severity)
    obj = _assistant_put_text(obj, "title", event.title)
    obj = _assistant_put_text(obj, "detail", event.detail)
    obj = _assistant_put_text(obj, "summary", event.detail)
    obj = _assistant_put_text(obj, "message", event.message)
    obj = _assistant_put_text(obj, "signal", event.signal)
    obj = _assistant_put_text(obj, "wake_reason", event.signal)
    obj = _assistant_put_text(obj, "source", event.source)
    obj = _assistant_put_text(obj, "correlation_id", event.correlation_id)
    obj

fn _assistant_timeline_record_from_json_value(value: any) -> AssistantTimelineRecord:
    var event = AssistantTimelineRecord.new(
        _assistant_json_text_any(value, ["session_id"]),
        _assistant_json_text_any(value, ["kind", "event_type"]),
        _assistant_json_text_any(value, ["message", "summary", "detail"]),
        _assistant_json_text_any(value, ["signal", "wake_reason"])
    )
    event.event_id = _assistant_json_text_any(value, ["id", "event_id"])
    event.session_id = _assistant_json_text_any(value, ["session_id"])
    event.parent_session_id = _assistant_json_text_any(value, ["parent_session_id"])
    event.child_task_id = _assistant_json_text_any(value, ["child_task_id"])
    event.timestamp_ms = _assistant_json_number_any(value, ["timestamp_ms", "timestamp", "created_at_ms", "created_at"])
    event.kind = _assistant_json_text_any(value, ["kind", "event_type"])
    event.severity = assistant_first_non_empty([_assistant_json_text_any(value, ["severity"]), assistant_timeline_severity(event.kind)])
    event.title = assistant_first_non_empty([_assistant_json_text_any(value, ["title"]), assistant_timeline_title(event.kind, event.message, event.signal)])
    event.detail = assistant_first_non_empty([_assistant_json_text_any(value, ["detail", "summary"]), assistant_timeline_detail(event.kind, event.message, event.signal)])
    event.message = _assistant_json_text_any(value, ["message", "summary", "detail"])
    event.signal = _assistant_json_text_any(value, ["signal", "wake_reason"])
    event.source = assistant_first_non_empty([_assistant_json_text_any(value, ["source"]), "assistant"])
    event.correlation_id = _assistant_json_text_any(value, ["correlation_id"])
    event

