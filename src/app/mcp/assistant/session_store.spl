# Assistant Core File-Backed Store
#
# Persists assistant sessions, timeline events, notifications, and child-task
# metadata under .build/llm_dashboard/assistant so the dashboard collector can
# consume the same files without a live MCP bridge.

# Split from src/app/mcp/assistant/session_store.spl to keep module cohesion under the 800-line source limit.
export use app.mcp.assistant.session_store_helpers.*
export use app.mcp.assistant.session_store_part1.*
export use app.mcp.assistant.session_store_part2.*
