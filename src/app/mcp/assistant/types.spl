#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Assistant Core Record Types
#
# File-backed assistant store records for the KAIROS-like assistant core.
# The store persists session summaries, timeline events, and child-task
# metadata under .build/llm_dashboard/assistant.

extern fn rt_time_now_unix_micros() -> i64

fn assistant_now_ms() -> i64:
    rt_time_now_unix_micros() / 1000

fn assistant_first_non_empty(values: [text]) -> text:
    for value in values:
        val trimmed = value.trim()
        if trimmed != "":
            return trimmed
    ""

fn assistant_generate_session_id(now_ms: i64) -> text:
    "assistant-{now_ms}"

fn assistant_generate_event_id(session_id: text, now_ms: i64, kind: text) -> text:
    "{session_id}-{kind}-{now_ms}"

fn assistant_generate_task_id(session_id: text, now_ms: i64) -> text:
    "{session_id}-task-{now_ms}"

fn assistant_timeline_severity(kind: text) -> text:
    match kind:
        "error" | "failed" | "failure" => "danger"
        "completed" | "stop" | "session_end" | "sessionend" => "success"
        "pause" | "suppressed" => "muted"
        "child_task" | "spawn" | "start" | "resume" | "state" => "info"
        _ => "normal"

fn assistant_timeline_title(kind: text, message: text, signal: text) -> text:
    assistant_first_non_empty([message, signal, kind])

fn assistant_timeline_detail(kind: text, message: text, signal: text) -> text:
    assistant_first_non_empty([message, signal, kind])

fn assistant_session_summary(name: text, prompt: text, objective: text) -> text:
    assistant_first_non_empty([objective, prompt, name, "assistant session"])

# =========================================================================
# Assistant Child Task Metadata
# =========================================================================

class AssistantChildTaskRecord:
    task_id: text
    session_id: text
    parent_session_id: text
    parent_task_id: text
    child_session_id: text
    objective: text
    owner_kind: text
    status: text
    resource_policy: text
    result_summary: text
    created_at_ms: i64
    updated_at_ms: i64
    started_at_ms: i64
    ended_at_ms: i64

    static fn new(session_id: text, objective: text, owner_kind: text, resource_policy: text, parent_task_id: text, child_session_id: text) -> AssistantChildTaskRecord:
        val now = assistant_now_ms()
        AssistantChildTaskRecord(
            task_id: assistant_generate_task_id(session_id, now),
            session_id: session_id,
            parent_session_id: "",
            parent_task_id: parent_task_id,
            child_session_id: child_session_id,
            objective: objective,
            owner_kind: owner_kind,
            status: "queued",
            resource_policy: resource_policy,
            result_summary: "",
            created_at_ms: now,
            updated_at_ms: now,
            started_at_ms: 0,
            ended_at_ms: 0
        )

# =========================================================================
# Assistant Timeline Event Records
# =========================================================================

class AssistantTimelineRecord:
    event_id: text
    session_id: text
    parent_session_id: text
    child_task_id: text
    timestamp_ms: i64
    kind: text
    severity: text
    title: text
    detail: text
    message: text
    signal: text
    source: text
    correlation_id: text

    static fn new(session_id: text, kind: text, message: text, signal: text) -> AssistantTimelineRecord:
        val now = assistant_now_ms()
        AssistantTimelineRecord(
            event_id: assistant_generate_event_id(session_id, now, kind),
            session_id: session_id,
            parent_session_id: "",
            child_task_id: "",
            timestamp_ms: now,
            kind: kind,
            severity: assistant_timeline_severity(kind),
            title: assistant_timeline_title(kind, message, signal),
            detail: assistant_timeline_detail(kind, message, signal),
            message: message,
            signal: signal,
            source: "assistant",
            correlation_id: ""
        )

# =========================================================================
# Assistant Session Records
# =========================================================================

class AssistantSessionRecord:
    session_id: text
    name: text
    summary: text
    objective: text
    prompt: text
    mode: text
    state: text
    policy: text
    parent_session_id: text
    parent_tool_use_id: text
    last_signal: text
    last_event_kind: text
    last_event_detail: text
    last_event_time_ms: i64
    last_tick_at_ms: i64
    created_at_ms: i64
    updated_at_ms: i64
    event_count: i64
    error_count: i64
    model: text
    provider: text
    digest_checkpoint_id: text
    tool_use_ids: [text]
    children: [text]
    child_tasks: [AssistantChildTaskRecord]
    warnings: [text]

    static fn new(session_id: text, name: text, prompt: text, mode: text, parent_session_id: text, parent_tool_use_id: text, objective: text) -> AssistantSessionRecord:
        val now = assistant_now_ms()
        val summary = assistant_session_summary(name, prompt, objective)
        AssistantSessionRecord(
            session_id: session_id,
            name: assistant_first_non_empty([name, session_id]),
            summary: summary,
            objective: assistant_first_non_empty([objective, summary]),
            prompt: prompt,
            mode: assistant_first_non_empty([mode, "proactive"]),
            state: "running",
            policy: "bounded",
            parent_session_id: parent_session_id,
            parent_tool_use_id: parent_tool_use_id,
            last_signal: "",
            last_event_kind: "",
            last_event_detail: "",
            last_event_time_ms: 0,
            last_tick_at_ms: 0,
            created_at_ms: now,
            updated_at_ms: now,
            event_count: 0,
            error_count: 0,
            model: "",
            provider: "",
            digest_checkpoint_id: "",
            tool_use_ids: [],
            children: [],
            child_tasks: [],
            warnings: []
        )
