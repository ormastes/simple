# --- Server loop ---

fn start_server():
    var running = true
    while running:
        var line = read_stdin_message()
        if line == "":
            running = false
        else:
            var method = extract_field(line, "method")
            var id = extract_id(line)
            var response = ""
            if method == "initialize":
                response = make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = make_json_result(id, "null")
            elif method == "tools/list":
                response = make_json_result(id, _mcp_static_tools_result())
            elif method == "tools/call":
                var tool_name = extract_nested(line, "name")
                response = dispatch_tool(id, tool_name, line)
            elif method == "resources/list":
                response = handle_resources_list(id)
            elif method == "resources/templates/list":
                response = handle_resource_templates_list(id)
            elif method == "resources/read":
                val uri = extract_nested(line, "uri")
                response = handle_resources_read(id, uri)
            elif method == "prompts/list":
                response = handle_prompts_list(id)
            elif method == "prompts/get":
                val prompt_name = extract_nested(line, "name")
                response = handle_prompts_get(id, prompt_name, line)
            elif method == "completion/complete" or method == "completions/complete":
                response = handle_completion_req(id, line)
            elif method == "logging/setLevel":
                val level = extract_nested(line, "level")
                if level != "":
                    MCP_LOG_LEVEL = level
                response = make_json_result(id, jo1(jp("level", js(MCP_LOG_LEVEL))))
            elif method == "roots/list":
                val cwd = get_cwd()
                var root = LB()
                root = root + jp("uri", js("file://" + cwd))
                root = root + "," + jp("name", js("workspace"))
                root = root + RB()
                response = make_json_result(id, jo1(jp("roots", "[" + root + "]")))
            elif method == "ping":
                response = make_json_result(id, LB() + RB())
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if id != "" and id != "null":
                    response = make_error(id, -32601, "Method not found: " + method)
            if response != "":
                write_stdout_message(response)

# ============================================================================
# Tool dispatch — table-driven with handler routing
# ============================================================================

fn dispatch_tool(id: text, tool_name: text, body: text) -> text:
    if tool_name == "":
        return make_tool_error(id, -32602, "Missing tool name")

    if _is_in_process_tool(tool_name):
        return _dispatch_in_process(id, tool_name, body)

    if _is_vcs_tool(tool_name):
        return _dispatch_vcs(id, tool_name, body)

    if _is_query_tool(tool_name):
        return _dispatch_query(id, tool_name, body)

    val cli_result = _dispatch_cli_direct(id, tool_name, body)
    if cli_result != "":
        return cli_result

    return make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn _is_vcs_tool(name: text) -> bool:
    name == "simple_diff" or name == "simple_log" or name == "simple_squash" or
    name == "simple_new" or name == "simple_commit" or name == "simple_push" or
    name == "simple_rebase" or name == "simple_pull"

fn _is_query_tool(name: text) -> bool:
    name == "simple_dependencies" or name == "simple_api_diff" or
    name == "simple_context" or name == "simple_search"

fn _is_in_process_tool(name: text) -> bool:
    name == "simple_read" or name == "simple_status" or name == "simple_edit" or
    name == "simple_multi_edit" or name == "simple_api" or
    name == "debug_create_session" or name == "debug_list_sessions" or
    name == "debug_close_session" or name == "debug_set_breakpoint" or
    name == "debug_remove_breakpoint" or name == "debug_continue" or
    name == "debug_step" or name == "debug_get_variables" or
    name == "debug_stack_trace" or name == "debug_evaluate" or
    name == "debug_set_function_breakpoint" or name == "debug_enable_breakpoint" or
    name == "debug_get_source" or name == "debug_watch" or
    name == "debug_set_variable" or name == "debug_set_data_breakpoint" or
    name == "debug_list_data_breakpoints" or name == "debug_remove_data_breakpoint" or
    name == "debug_terminate" or name == "debug_trace_capture" or
    name == "debug_coverage_collect" or name == "debug_flash_program" or
    name == "debug_system_reset" or name == "debug_practice_script" or
    name == "debug_openocd_monitor" or name == "debug_dialog_list" or
    name == "debug_dialog_read" or name == "debug_dialog_click" or
    name == "debug_dialog_set" or name == "debug_dialog_track" or
    name == "play_run" or name == "play_launch" or name == "play_first_window" or
    name == "play_click" or name == "play_fill" or name == "play_type" or
    name == "play_press" or name == "play_screenshot" or name == "play_evaluate" or
    name == "play_close" or name == "play_last_trace" or name == "play_wm_screenshot" or
    name == "play_wm_list" or name == "play_wm_click" or name == "play_wm_type" or
    name == "play_sdl2_connect" or name == "play_sdl2_click" or name == "play_sdl2_fill" or
    name == "play_sdl2_screenshot" or name == "play_sdl2_elements" or
    name == "play_sdl2_state" or name == "play_ui_connect" or name == "play_ui_snapshot" or
    name == "play_ui_query" or name == "play_ui_ensure" or name == "play_ui_act" or
    name == "assistant_start" or name == "assistant_spawn_task" or
    name == "assistant_pause" or name == "assistant_resume" or
    name == "assistant_brief" or name == "assistant_list_sessions" or
    name == "assistant_get_session" or name == "assistant_get_timeline" or
    name == "assistant_push_signal" or name == "assistant_list_tasks" or
    name == "assistant_get_notifications"

