# MCP Server Entry Point — migrated to McpServer facade (Wave C1).
#
# Apps own only tool handlers + wiring (design rule D5).
# 151 tools registered via mcp_server_tool; serve loop uses StdioTransport.
#
# Module files:
#   - tool_registry.spl        — McpToolEntry struct
#   - tool_table.spl           — All tool definitions (name, schema, annotations, handler_kind)
#   - cli_passthrough.spl      — Generic CLI passthrough handler for handler_kind="cli"
#   - main_lazy_json.spl       — JSON helpers, tool result helpers, shell helpers
#   - main_lazy_protocol.spl   — Resources, prompts, completion handlers
#   - main_lazy_diag_tools.spl — In-process diagnostic handlers (read, edit, multi_edit, status, api)
#   - main_lazy_vcs_tools.spl  — VCS tool handlers (diff, log, squash, new, commit, push, rebase, pull)
#   - main_lazy_debug_tools.spl — Debug session/breakpoint/variable handlers
#   - main_lazy_query_tools.spl   — Query + Analysis tool handlers (deps, context, api_diff, search)
#   - main_dispatch.spl        — dispatch_tool / dispatch_tool_content
#   - main_static_tools.spl    — _mcp_static_tools_result (tools/list cache)

use std.io_runtime.{env_get, file_exists, exit, get_args}
use std.nogc_sync_mut.io.stderr_ops.{stderr_write, stderr_flush}
use .mcp_log_options

extern fn stdin_read_char() -> text
extern fn print_raw(s: text)

var _MCP_TRANSPORT_MODE = "framed"

fn _mcp_error(scope: text, msg: text):
    stderr_write("[error] " + scope + ": " + msg + "\n")
    stderr_flush()
use std.mcp_sdk.server.app.{app_extract_id, app_extract_str, app_extract_obj}
use std.mcp_sdk.server.method_detect.{has_method}

fn _mcp_find_simple_binary() -> text:
    val env_bin = env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    if file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if file_exists("bin/release/x86_64-unknown-linux-gnu/simple"):
        return "bin/release/x86_64-unknown-linux-gnu/simple"
    if file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    if file_exists("bin/release/simple"):
        return "bin/release/simple"
    if file_exists("bin/simple"):
        return "bin/simple"

    val os_env = env_get("OS") ?? ""
    if os_env.contains("Windows"):
        if file_exists("bin/simple.exe"):
            return "bin/simple.exe"
        if file_exists("bin/release/x86_64-pc-windows-msvc/simple.exe"):
            return "bin/release/x86_64-pc-windows-msvc/simple.exe"
        if file_exists("bin/release/x86_64-pc-windows-gnu/simple.exe"):
            return "bin/release/x86_64-pc-windows-gnu/simple.exe"
    "bin/simple"

# Load split module implementations from sibling files.
# Startup path (initialize / tools/list / --probe) needs only JSON helpers,
# protocol handlers, and the static tool table. The per-tool handler modules
# (diag/vcs/debug/dialog/query/play/assistant/editor) are reached only through
# dispatch_tool, so they are imported by main_dispatch — not duplicated here.
use .main_lazy_json
use .main_lazy_protocol
use .main_static_tools
use .main_dispatch

val SERVER_NAME = "simple-mcp-full"
val SERVER_VERSION = "4.0.0"
val NL = "\n"

# MCP log level (protocol-level, not debug log)
var MCP_LOG_LEVEL = "info"

# Active tool set for advertisement ("all" | "core").
# Controlled by SIMPLE_MCP_TOOL_SET env var or --tool-set=<set> argv flag.
# Default is "all" — existing clients are never affected unless they opt in.
var _MCP_TOOL_SET = "all"

# Tools/list response cache (built on first request, reused thereafter)
var _MCP_TOOLS_LIST_CACHE = ""

# --- Server loop ---

fn print_help():
    print "Simple MCP Server"
    print ""
    print "Usage: simple mcp [options]"
    print ""
    print "Runs the Simple MCP JSON-RPC server on stdin/stdout."
    print ""
    print "Options:"
    print "  -h, --help          Show this help message"
    print "  -v, --version       Show version information"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn mcp_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or arg == "--tui" or arg == "--stdout" or arg == "--quiet" or arg == "--verbose" or arg == "--dots" or arg == "--count" or arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or arg == "--progress" or arg.starts_with("--log-mode=") or arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn mcp_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if mcp_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn mcp_has_explicit_json_ready_arg(args: [text]) -> bool:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--json" or arg == "--log-mode=json":
            return true
        if arg == "--log-mode" and i + 1 < args.len() and args[i + 1] == "json":
            return true
        i = i + 1
    false

fn mcp_has_explicit_progress_arg(args: [text]) -> bool:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--dots" or arg == "--count" or arg == "--progress=dot" or arg == "--progress=count" or arg == "--progress=summary":
            return true
        if arg == "--progress" and i + 1 < args.len() and args[i + 1] != "none":
            return true
        i = i + 1
    false

fn mcp_get_cli_args() -> [text]:
    val raw_args = get_args()
    var args: [text] = []
    var start_idx = 1
    if raw_args.len() > 2 and raw_args[1] == "run" and raw_args[2].ends_with(".spl"):
        start_idx = 3
    elif raw_args.len() > 1 and raw_args[1].ends_with(".spl"):
        start_idx = 2
    var i = start_idx
    while i < raw_args.len():
        args.push(raw_args[i])
        i = i + 1
    args

# --- Tool set selection ---

# Return the active tool set name ("all" or "core").
fn _mcp_get_tool_set() -> text:
    _MCP_TOOL_SET

# Read tool-set selection from environment and argv.
# Env var SIMPLE_MCP_TOOL_SET ("core" | "all") is checked first;
# --tool-set=<set> argv flag overrides it.  Unknown values are silently ignored
# so "all" is always the safe fallback.
fn _mcp_init_tool_set(args: [text]):
    val env_set = env_get("SIMPLE_MCP_TOOL_SET") ?? ""
    if env_set == "core" or env_set == "all":
        _MCP_TOOL_SET = env_set
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--tool-set="):
            val v = arg.replace("--tool-set=", "")
            if v == "core" or v == "all":
                _MCP_TOOL_SET = v
        i = i + 1

# Strip --tool-set=... flags from the arg list so the unknown-arg check in
# main() does not reject them.
fn mcp_strip_tool_set_args(args: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if not arg.starts_with("--tool-set="):
            out.push(arg)
        i = i + 1
    out

# --- Tool registration helpers ---

# Build an inputSchema JSON object from pre-built properties and required arrays.
fn _mcp_input_schema(props: text, req: text) -> text:
    "{\"type\":\"object\",\"properties\":" + props + ",\"required\":" + req + "}"

# Lazily build and cache the tools/list result JSON for the active tool set.
# "all" path is byte-identical to the original — default behavior unchanged.
# "core" delegates to the T1 contract function _mcp_tools_list_json_for_set.
fn _mcp_tools_list_result() -> text:
    if _MCP_TOOLS_LIST_CACHE != "":
        return _MCP_TOOLS_LIST_CACHE
    if _MCP_TOOL_SET == "core":
        _MCP_TOOLS_LIST_CACHE = _mcp_tools_list_json_for_set("core")
    else:
        _MCP_TOOLS_LIST_CACHE = _mcp_static_tools_result()
    _MCP_TOOLS_LIST_CACHE

fn _mcp_initialize_result() -> text:
    var caps = LB()
    caps = caps + jp("tools", LB() + RB())
    caps = caps + "," + jp("resources", jo1(jp("listChanged", "false")))
    caps = caps + "," + jp("prompts", jo1(jp("listChanged", "false")))
    caps = caps + "," + jp("logging", LB() + RB())
    caps = caps + "," + jp("roots", jo1(jp("listChanged", "false")))
    caps = caps + RB()
    val info = jo2(jp("name", js(SERVER_NAME)), jp("version", js(SERVER_VERSION)))
    var result = LB()
    result = result + jp("protocolVersion", js("2025-06-18"))
    result = result + "," + jp("capabilities", caps)
    result = result + "," + jp("serverInfo", info)
    result = result + RB()
    result

# Extract JSON-RPC id from message, with sensible fallbacks.
fn _mcp_extract_id(msg: text, method: text) -> text:
    val parsed = app_extract_id(msg)
    if parsed != "" and parsed != "null":
        return parsed
    if method == "initialize":
        return "\"1\""
    if method == "tools/list":
        return "\"2\""
    parsed

fn _mcp_read_line() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            return result
        result = result + ch
        if ch == "\n":
            return result

fn _mcp_read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn _mcp_strip_line_end(line: text) -> text:
    val n = line.len()
    if n >= 2 and line.substring(n - 2, n) == "\r\n":
        return line.substring(0, n - 2)
    if n >= 1 and line.substring(n - 1, n) == "\n":
        return line.substring(0, n - 1)
    if n >= 1 and line.substring(n - 1, n) == "\r":
        return line.substring(0, n - 1)
    line

fn _mcp_parse_decimal_raw(s: text) -> i64:
    var result: i64 = 0
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "0":
            result = result * 10
        elif ch == "1":
            result = result * 10 + 1
        elif ch == "2":
            result = result * 10 + 2
        elif ch == "3":
            result = result * 10 + 3
        elif ch == "4":
            result = result * 10 + 4
        elif ch == "5":
            result = result * 10 + 5
        elif ch == "6":
            result = result * 10 + 6
        elif ch == "7":
            result = result * 10 + 7
        elif ch == "8":
            result = result * 10 + 8
        elif ch == "9":
            result = result * 10 + 9
        else:
            return result
        i = i + 1
    result

fn _mcp_read_message() -> text:
    var content_length = 0
    while true:
        var line = _mcp_read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        line = _mcp_strip_line_end(line)
        if line.starts_with(LB()):
            _MCP_TRANSPORT_MODE = "jsonl"
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = _mcp_parse_decimal_raw(len_str)
    if content_length <= 0:
        return ""
    _mcp_read_chars(content_length)

fn _mcp_write_message(body: text):
    if _MCP_TRANSPORT_MODE == "jsonl":
        print_raw(body + "\n")
        return
    val nl = "\n"
    print_raw("Content-Length: " + str(body.len()) + "\r" + nl + "\r" + nl)
    print_raw(body)

fn main() -> i64:
    val raw_args = mcp_get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        _mcp_error("mcp", log_opts.error)
        return 1

    val args_log_stripped = mcp_clean_log_args(raw_args)
    # Initialise active tool set from env var + argv before stripping the flag.
    _mcp_init_tool_set(args_log_stripped)
    val args = mcp_strip_tool_set_args(args_log_stripped)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"mcp\",\"status\":\"ok\",\"version\":\"{SERVER_VERSION}\"}"
        else:
            print "Simple MCP Server v{SERVER_VERSION}"
        return 0
    # Cheap self-check probe (B1): no MCP framing, no handler module work, no
    # full tools/list JSON. Walks only the lightweight descriptor table for a
    # tool count + stable manifest hash, then exits. Used by the wrapper to
    # validate a native candidate without a full server boot + handshake.
    if args.len() > 0 and args[0] == "--probe":
        val probe_count = _mcp_probe_tool_count()
        val probe_hash = _mcp_probe_manifest_hash()
        val active_set = _mcp_get_tool_set()
        print "simple-mcp probe ok version={SERVER_VERSION} tools={probe_count} manifest_hash={probe_hash} tool_set={active_set}"
        return 0
    if args.len() > 0:
        val message = "Unknown mcp option: {args[0]}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"mcp\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            _mcp_error("mcp", message)
        return 1
    if raw_args.len() > 0 and mcp_has_explicit_json_ready_arg(raw_args):
        print "{\"command\":\"mcp\",\"status\":\"ready\",\"tool\":\"Simple MCP Server\",\"version\":\"{SERVER_VERSION}\"}"
        return 0
    if raw_args.len() > 0 and mcp_has_explicit_progress_arg(raw_args):
        val progress = render_progress(log_opts.progress, 1, 1, "mcp")
        if progress != "":
            print progress
        return 0

    # Initialize server metadata. Tool metadata and calls are routed through
    # the static table below; native builds cannot safely register closure
    # handlers into the generic SDK registry.
    mcp_server_init(SERVER_NAME, SERVER_VERSION)

    # Serve loop — uses direct stdio framing to avoid native Optional transport
    # issues that can stop after the first framed request.
    while true:
        val msg = _mcp_read_message()
        if msg == "":
            exit(0)
            return 0

        # Core methods: delegate to the McpServer facade.
        # tools/list is handled locally so we return the full 151-tool list
        # without registry pagination (smoke check requires all tools in one response).
        var response = ""
        if has_method(msg, "initialize"):
            val id = _mcp_extract_id(msg, "initialize")
            response = make_json_result(id, _mcp_initialize_result())
        elif has_method(msg, "tools/call"):
            val id = _mcp_extract_id(msg, "tools/call")
            val params = app_extract_obj(msg, "params")
            var tool_name = ""
            var args_raw = "{}"
            if params != "":
                tool_name = app_extract_str(params, "name")
                val extracted_args = app_extract_obj(params, "arguments")
                if extracted_args != "":
                    args_raw = extracted_args
            response = dispatch_tool(id, tool_name, args_raw)
        elif has_method(msg, "tools/list"):
            val id = _mcp_extract_id(msg, "tools/list")
            response = make_json_result(id, _mcp_tools_list_result())
        elif has_method(msg, "notifications/initialized") or (
            has_method(msg, "notifications/cancelled")) or (
            has_method(msg, "notifications/roots/list_changed")) or (
            has_method(msg, "initialized")):
            response = ""
        elif has_method(msg, "shutdown"):
            val id = _mcp_extract_id(msg, "shutdown")
            response = make_json_result(id, "null")
        elif has_method(msg, "resources/list"):
            val id = _mcp_extract_id(msg, "resources/list")
            response = handle_resources_list(id)
        elif has_method(msg, "resources/templates/list"):
            val id = _mcp_extract_id(msg, "resources/templates/list")
            response = handle_resource_templates_list(id)
        elif has_method(msg, "resources/read"):
            val id = _mcp_extract_id(msg, "resources/read")
            val uri = extract_nested(msg, "uri")
            response = handle_resources_read(id, uri)
        elif has_method(msg, "prompts/list"):
            val id = _mcp_extract_id(msg, "prompts/list")
            response = handle_prompts_list(id)
        elif has_method(msg, "prompts/get"):
            val id = _mcp_extract_id(msg, "prompts/get")
            val prompt_name = extract_nested(msg, "name")
            response = handle_prompts_get(id, prompt_name, msg)
        elif has_method(msg, "completion/complete") or has_method(msg, "completions/complete"):
            val id = _mcp_extract_id(msg, "completion/complete")
            response = handle_completion_req(id, msg)
        elif has_method(msg, "logging/setLevel"):
            val id = _mcp_extract_id(msg, "logging/setLevel")
            val level = extract_nested(msg, "level")
            if level != "":
                MCP_LOG_LEVEL = level
            response = make_json_result(id, jo1(jp("level", js(MCP_LOG_LEVEL))))
        elif has_method(msg, "roots/list"):
            val id = _mcp_extract_id(msg, "roots/list")
            val cwd = get_cwd()
            var root = LB()
            root = root + jp("uri", js("file://" + cwd))
            root = root + "," + jp("name", js("workspace"))
            root = root + RB()
            response = make_json_result(id, jo1(jp("roots", "[" + root + "]")))
        elif has_method(msg, "ping"):
            val id = _mcp_extract_id(msg, "ping")
            response = make_json_result(id, LB() + RB())
        else:
            val id = _mcp_extract_id(msg, "")
            if id != "" and id != "null":
                response = make_error(id, -32601, "Method not found")
        if response != "":
            _mcp_write_message(response)
    0

export _mcp_get_tool_set
