use .main_lazy_dialog_tools
# main_lazy_debug_log_tools removed — debug log tools now CLI passthrough
# main_lazy_tasks removed — task tools now CLI passthrough
use .main_lazy_query_tools
use .main_lazy_play_tools
use .main_lazy_assistant
# main_lazy_test_daemon_tools removed — test daemon tools now CLI passthrough
use .tool_registry
use .tool_table
use .cli_passthrough
use .dap_bridge
use .startup_log

val SERVER_NAME = "simple-mcp-full"
val SERVER_VERSION = "4.0.0"
val NL = "\n"

# Protocol auto-detection
var USE_JSON_LINES = false

# Caches
var TOOLS_CACHE = ""
var INIT_CACHE = ""

# Debug session state managed by dap_bridge.spl (DapSession class)

# MCP log level (protocol-level, not debug log)
var MCP_LOG_LEVEL = "info"

fn _mcp_static_prop(param_name: text) -> text:
    jp(param_name, jo2(jp("type", js("string")), jp("description", js(param_name))))

fn _mcp_static_append_prop(props: text, required_json: text, param_name: text) -> text:
    val separator = if props == "": "" else: ","
    props + separator + _mcp_static_prop(param_name)

fn _mcp_static_props(required_json: text) -> text:
    var props = ""
    props = _mcp_static_append_prop(props, required_json, "program")
    props = _mcp_static_append_prop(props, required_json, "target_type")
    props = _mcp_static_append_prop(props, required_json, "session_id")
    props = _mcp_static_append_prop(props, required_json, "breakpoint_id")
    props = _mcp_static_append_prop(props, required_json, "file")
    props = _mcp_static_append_prop(props, required_json, "line")
    props = _mcp_static_append_prop(props, required_json, "mode")
    props = _mcp_static_append_prop(props, required_json, "enabled")
    props = _mcp_static_append_prop(props, required_json, "condition")
    props = _mcp_static_append_prop(props, required_json, "expression")
    props = _mcp_static_append_prop(props, required_json, "action")
    props = _mcp_static_append_prop(props, required_json, "name")
    props = _mcp_static_append_prop(props, required_json, "value")
    props = _mcp_static_append_prop(props, required_json, "item_names")
    props = _mcp_static_append_prop(props, required_json, "item_name")
    props = _mcp_static_append_prop(props, required_json, "module")
    props = _mcp_static_append_prop(props, required_json, "elf_path")
    props = _mcp_static_append_prop(props, required_json, "script")
    props = _mcp_static_append_prop(props, required_json, "command")
    props = _mcp_static_append_prop(props, required_json, "function_name")
    props = _mcp_static_append_prop(props, required_json, "url")
    props = _mcp_static_append_prop(props, required_json, "path")
    props = _mcp_static_append_prop(props, required_json, "target_dir")
    props = _mcp_static_append_prop(props, required_json, "app_path")
    props = _mcp_static_append_prop(props, required_json, "selector")
    props = _mcp_static_append_prop(props, required_json, "text")
    props = _mcp_static_append_prop(props, required_json, "key")
    props = _mcp_static_append_prop(props, required_json, "js")
    props = _mcp_static_append_prop(props, required_json, "x")
    props = _mcp_static_append_prop(props, required_json, "y")
    props = _mcp_static_append_prop(props, required_json, "base_url")
    props = _mcp_static_append_prop(props, required_json, "widget_id")
    props = _mcp_static_append_prop(props, required_json, "canonical_id")
    props = _mcp_static_append_prop(props, required_json, "old_string")
    props = _mcp_static_append_prop(props, required_json, "new_string")
    props = _mcp_static_append_prop(props, required_json, "edits")
    props = _mcp_static_append_prop(props, required_json, "query")
    props = _mcp_static_append_prop(props, required_json, "task_id")
    props = _mcp_static_append_prop(props, required_json, "prompt")
    props = _mcp_static_append_prop(props, required_json, "signal")
    props = _mcp_static_append_prop(props, required_json, "package")
    LB() + props + RB()

fn _mcp_static_tool_schema(name: text, desc: text, required_json: text) -> text:
    val input_schema = jo3(
        jp("type", js("object")),
        jp("properties", _mcp_static_props(required_json)),
        jp("required", required_json)
    )
    val annotations = jo4(
        jp("readOnlyHint", "false"),
        jp("destructiveHint", "false"),
        jp("idempotentHint", "true"),
        jp("openWorldHint", "false")
    )
    jo4(
        jp("name", js(name)),
        jp("description", js(desc)),
        jp("inputSchema", input_schema),
        jp("annotations", annotations)
    )

