        return handle_play_ui_query(id, body)
    if name == "play_ui_ensure":
        return handle_play_ui_ensure(id, body)
    if name == "play_ui_act":
        return handle_play_ui_act(id, body)

    # Assistant tools
    if name == "assistant_start":
        return handle_assistant_start(id, body)
    if name == "assistant_spawn_task":
        return handle_assistant_spawn_task(id, body)
    if name == "assistant_pause":
