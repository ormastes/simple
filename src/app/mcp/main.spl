    # Debug log tools — now CLI passthrough (handled by table dispatch)

    # Background task management — now CLI passthrough (handled by table dispatch)

    make_tool_error(id, -32601, "Unknown in-process tool: " + name)

fn main() -> i64:
    start_server()
    rt_exit(0)
    0
