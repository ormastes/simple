#![allow(unnamed_duplicate_typed_args)]
# MCP Server Entry Point
#
# Table-driven tool dispatch with ~100 tools (68 original + ~33 new CLI wrappers).
# Uses only extern fn calls for I/O — no subprocess dispatch, no hangs.
#
# Architecture:
#   - Zero stdlib imports: all JSON helpers and tool logic inlined
#   - Table-driven dispatch: tool_table.spl defines all tool metadata
#   - CLI passthrough: most tools delegate to bin/simple via cli_passthrough.spl
#   - Fast startup (~200ms), fast tool calls (<1s)
#
# Module files:
#   - tool_registry.spl        — McpToolEntry struct
#   - tool_table.spl           — All tool definitions (name, schema, annotations, handler_kind)
#   - cli_passthrough.spl      — Generic CLI passthrough handler for handler_kind="cli"
#   - main_lazy_json.spl       — JSON helpers, tool result helpers, shell helpers
#   - main_lazy_protocol.spl   — Protocol I/O, initialize, tools list, schemas, resources, prompts
#   - main_lazy_diag_tools.spl — In-process diagnostic handlers (read, edit, multi_edit, status, api)
#   - main_lazy_vcs_tools.spl  — VCS tool handlers (diff, log, squash, new, commit, push, rebase, pull)
#   - main_lazy_debug_tools.spl — Debug session/breakpoint/variable handlers
#   - main_lazy_debug_log_tools.spl — Debug log tool handlers
#   - main_lazy_tasks.spl         — Background task manager
#   - main_lazy_query_tools.spl   — Query + Analysis tool handlers (deps, context, api_diff, search)
#   - main_lazy_test_daemon_tools.spl — Test daemon IPC handlers

extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

fn _mcp_find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    val os_env = rt_env_get("OS") ?? ""
    val is_win = os_env.contains("Windows")
    if is_win:
        if rt_file_exists("bin/release/simple.exe"):
            return "bin/release/simple.exe"
        if rt_file_exists("bin/simple.exe"):
            return "bin/simple.exe"
    if rt_file_exists("bin/release/simple"):
        return "bin/release/simple"
    "bin/simple"

# Load split module implementations from sibling files.
use app.mcp.main_lazy_json
use app.mcp.main_lazy_protocol
use app.mcp.main_lazy_diag_tools
use app.mcp.main_lazy_vcs_tools
use app.mcp.main_lazy_debug_tools
# main_lazy_debug_log_tools removed — debug log tools now CLI passthrough
# main_lazy_tasks removed — task tools now CLI passthrough
use app.mcp.main_lazy_query_tools
# main_lazy_test_daemon_tools removed — test daemon tools now CLI passthrough
use app.mcp.tool_registry
use app.mcp.tool_table
use app.mcp.cli_passthrough
use app.mcp.dap_bridge

val SERVER_NAME = "simple-mcp-full"
val SERVER_VERSION = "4.0.0"
val NL = "\n"

# Protocol auto-detection
var USE_JSON_LINES = false

# Caches
var TOOLS_CACHE = ""
var INIT_CACHE = ""

# Debug session state managed by dap_bridge.spl (DapSession class)

# MCP log level (protocol-level, not debug log)
var MCP_LOG_LEVEL = "info"

# --- Server loop ---

fn start_server():
    var running = true
    while running:
        var line = read_stdin_message()
        if line == "":
            running = false
        else:
            var method = extract_field(line, "method")
            var id = extract_id(line)
            var response = ""
            if method == "initialize":
                response = make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = make_json_result(id, "null")
            elif method == "tools/list":
                response = make_tools_list(id)
            elif method == "tools/call":
                var tool_name = extract_nested(line, "name")
                response = dispatch_tool(id, tool_name, line)
            elif method == "resources/list":
                response = handle_resources_list(id)
            elif method == "resources/templates/list":
                response = handle_resource_templates_list(id)
            elif method == "resources/read":
                val uri = extract_nested(line, "uri")
                response = handle_resources_read(id, uri)
            elif method == "prompts/list":
                response = handle_prompts_list(id)
            elif method == "prompts/get":
                val prompt_name = extract_nested(line, "name")
                response = handle_prompts_get(id, prompt_name, line)
            elif method == "completion/complete" or method == "completions/complete":
                response = handle_completion_req(id, line)
            elif method == "logging/setLevel":
                val level = extract_nested(line, "level")
                if level != "":
                    MCP_LOG_LEVEL = level
                response = make_json_result(id, jo1(jp("level", js(MCP_LOG_LEVEL))))
            elif method == "roots/list":
                val cwd = get_cwd()
                var root = LB()
                root = root + jp("uri", js("file://" + cwd))
                root = root + "," + jp("name", js("workspace"))
                root = root + RB()
                response = make_json_result(id, jo1(jp("roots", "[" + root + "]")))
            elif method == "ping":
                response = make_json_result(id, LB() + RB())
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if id != "" and id != "null":
                    response = make_error(id, -32601, "Method not found: " + method)
            if response != "":
                write_stdout_message(response)

# ============================================================================
# Tool dispatch — table-driven with handler routing
# ============================================================================

fn dispatch_tool(id: text, tool_name: text, body: text) -> text:
    if tool_name == "":
        return make_tool_error(id, -32602, "Missing tool name")

    # Look up tool in table
    val table = get_tool_table()
    var found = false
    var entry = tool_entry("", "", "", "", "", 0)
    for t in table:
        if t.name == tool_name:
            entry = t
            found = true
            break
    if not found:
        return make_tool_error(id, -32601, "Unknown tool: " + tool_name)

    # Route by handler_kind
    if entry.handler_kind == "cli":
        return handle_cli_passthrough(id, body, entry)

    if entry.handler_kind == "vcs":
        return _dispatch_vcs(id, tool_name, body)

    if entry.handler_kind == "query":
        return _dispatch_query(id, tool_name, body)

    # test_daemon tools now handled by cli passthrough

    # in_process — route to specific handler functions
    return _dispatch_in_process(id, tool_name, body)

fn _dispatch_vcs(id: text, name: text, body: text) -> text:
    if name == "simple_diff":
        return handle_simple_diff(id, body)
    if name == "simple_log":
        return handle_simple_log(id, body)
    if name == "simple_squash":
        return handle_simple_squash(id, body)
    if name == "simple_new":
        return handle_simple_new(id, body)
    if name == "simple_commit":
        return handle_simple_commit(id, body)
    if name == "simple_push":
        return handle_simple_push(id, body)
    if name == "simple_rebase":
        return handle_simple_rebase(id, body)
    if name == "simple_pull":
        return handle_simple_pull(id, body)
    make_tool_error(id, -32601, "Unknown VCS tool: " + name)

fn _dispatch_query(id: text, name: text, body: text) -> text:
    if name == "simple_dependencies":
        return handle_simple_dependencies(id, body)
    if name == "simple_api_diff":
        return handle_simple_api_diff(id, body)
    if name == "simple_context":
        return handle_simple_context(id, body)
    if name == "simple_search":
        return handle_simple_search(id, body)
    make_tool_error(id, -32601, "Unknown query tool: " + name)

fn _dispatch_in_process(id: text, name: text, body: text) -> text:
    # Diagnostic tools (in-process)
    if name == "simple_read":
        return handle_simple_read(id, body)
    if name == "simple_status":
        return handle_simple_status(id, body)
    if name == "simple_edit":
        return handle_simple_edit(id, body)
    if name == "simple_multi_edit":
        return handle_simple_multi_edit(id, body)
    if name == "simple_api":
        return handle_simple_api(id, body)

    # Debug tools
    if name == "debug_create_session":
        return handle_debug_create_session(id, body)
    if name == "debug_list_sessions":
        return handle_debug_list_sessions(id)
    if name == "debug_close_session":
        return handle_debug_close_session(id, body)
    if name == "debug_set_breakpoint":
        return handle_debug_set_breakpoint(id, body)
    if name == "debug_remove_breakpoint":
        return handle_debug_remove_breakpoint(id, body)
    if name == "debug_continue":
        return handle_debug_continue(id, body)
    if name == "debug_step":
        return handle_debug_step(id, body)
    if name == "debug_get_variables":
        return handle_debug_get_variables(id, body)
    if name == "debug_stack_trace":
        return handle_debug_stack_trace(id, body)
    if name == "debug_evaluate":
        return handle_debug_evaluate(id, body)
    if name == "debug_set_function_breakpoint":
        return handle_debug_set_function_breakpoint(id, body)
    if name == "debug_enable_breakpoint":
        return handle_debug_enable_breakpoint(id, body)
    if name == "debug_get_source":
        return handle_debug_get_source(id, body)
    if name == "debug_watch":
        return handle_debug_watch(id, body)
    if name == "debug_set_variable":
        return handle_debug_set_variable(id, body)
    if name == "debug_set_data_breakpoint":
        return handle_debug_set_data_breakpoint(id, body)
    if name == "debug_list_data_breakpoints":
        return handle_debug_list_data_breakpoints(id, body)
    if name == "debug_remove_data_breakpoint":
        return handle_debug_remove_data_breakpoint(id, body)
    if name == "debug_terminate":
        return handle_debug_terminate(id, body)

    # Hardware debug tools
    if name == "debug_trace_capture":
        return handle_debug_trace_capture(id, body)
    if name == "debug_coverage_collect":
        return handle_debug_coverage_collect(id, body)
    if name == "debug_flash_program":
        return handle_debug_flash_program(id, body)
    if name == "debug_system_reset":
        return handle_debug_system_reset(id, body)
    if name == "debug_practice_script":
        return handle_debug_practice_script(id, body)
    if name == "debug_openocd_monitor":
        return handle_debug_openocd_monitor(id, body)

    # Debug log tools — now CLI passthrough (handled by table dispatch)

    # Background task management — now CLI passthrough (handled by table dispatch)

    make_tool_error(id, -32601, "Unknown in-process tool: " + name)

fn main() -> i64:
    start_server()
    0
