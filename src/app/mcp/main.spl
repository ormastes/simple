# MCP Server Entry Point
#
# Table-driven tool dispatch with ~100 tools (68 original + ~33 new CLI wrappers).
# Uses only extern fn calls for I/O — no subprocess dispatch, no hangs.
#
# Architecture:
#   - Zero stdlib imports: all JSON helpers and tool logic inlined
#   - Table-driven dispatch: tool_table.spl defines all tool metadata
#   - CLI passthrough: most tools delegate to bin/simple via cli_passthrough.spl
#   - Fast startup (~200ms), fast tool calls (<1s)
#
# Module files:
#   - tool_registry.spl        — McpToolEntry struct
#   - tool_table.spl           — All tool definitions (name, schema, annotations, handler_kind)
#   - cli_passthrough.spl      — Generic CLI passthrough handler for handler_kind="cli"
#   - main_lazy_json.spl       — JSON helpers, tool result helpers, shell helpers
#   - main_lazy_protocol.spl   — Protocol I/O, initialize, tools list, schemas, resources, prompts
#   - main_lazy_diag_tools.spl — In-process diagnostic handlers (read, edit, multi_edit, status, api)
#   - main_lazy_vcs_tools.spl  — VCS tool handlers (diff, log, squash, new, commit, push, rebase, pull)
#   - main_lazy_debug_tools.spl — Debug session/breakpoint/variable handlers
#   - main_lazy_debug_log_tools.spl — Debug log tool handlers
#   - main_lazy_tasks.spl         — Background task manager
#   - main_lazy_query_tools.spl   — Query + Analysis tool handlers (deps, context, api_diff, search)
#   - main_lazy_test_daemon_tools.spl — Test daemon IPC handlers

extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_exit(code: i64)
extern fn rt_cli_get_args() -> [text]

use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

fn _mcp_find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if rt_file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if rt_file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if rt_file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"

    val os_env = rt_env_get("OS") ?? ""
    if os_env.contains("Windows"):
        if rt_file_exists("bin/simple.exe"):
            return "bin/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-msvc/simple.exe"):
            return "bin/release/x86_64-pc-windows-msvc/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-gnu/simple.exe"):
            return "bin/release/x86_64-pc-windows-gnu/simple.exe"
    "bin/simple"

# Load split module implementations from sibling files.
use .main_lazy_json
use .main_lazy_protocol
use .main_lazy_diag_tools
use .main_lazy_vcs_tools
use .main_lazy_debug_tools
use .main_lazy_dialog_tools
