@allow(unnamed_duplicate_typed_args)
# MCP Dialog Tool Handlers — T32 PRACTICE dialog interaction
#
# Provides 5 MCP tools for T32 dialog management:
#   debug_dialog_list  — list open windows and detect active PRACTICE dialogs
#   debug_dialog_read  — read dialog control values by item name
#   debug_dialog_click — click a button or close a dialog
#   debug_dialog_set   — set a dialog field value
#   debug_dialog_track — execute T32 command and report dialog state changes
#
# Communication with T32 is via t32rem shell utility.
# Dialog state tracked via t32_dialog_manager module (pure snapshots + diff).

use app.mcp.dap_bridge
use std.nogc_sync_mut.debug.remote.protocol.t32_dialog_manager.{
    T32DialogItem, T32DialogSnapshot, T32DialogChange,
    dialog_snapshot_store, dialog_snapshot_get,
    dialog_compute_changes, dialog_empty_snapshot
}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# ---------------------------------------------------------------------------
# T32 connection and command helpers
# ---------------------------------------------------------------------------

# Parse T32 connection from session program field.
# Accepts "host:port", "t32://host:port", or bare "host"
fn _parse_t32_connection(program: text) -> (text, text):
    var p = program
    # Strip t32:// prefix
    val slash_parts = p.split("//")
    if slash_parts.len() >= 2:
        p = slash_parts[1]
    val colon_parts = p.split(":")
    if colon_parts.len() >= 2:
        return (colon_parts[0], colon_parts[1])
    if p.len() > 0:
        return (p, "20000")
    ("localhost", "20000")

# Execute a T32 remote command via t32rem.
# Returns (stdout, exit_code).
fn _t32_remote(host: text, port: text, command: text) -> (text, i64):
    val (stdout, stderr, rc) = rt_process_run("t32rem", [host, "port=" + port, command])
    if rc != 0:
        if stderr.len() > 0:
            return (stderr, rc)
        return (stdout, rc)
    (stdout, 0)

# Execute a T32 EVAL expression and return the trimmed result
fn _t32_eval(host: text, port: text, expr: text) -> (text, i64):
    _t32_remote(host, port, "EVAL " + expr)

# Query PRACTICE.STATE()
fn _t32_practice_state(host: text, port: text) -> text:
    val (result, rc) = _t32_eval(host, port, "PRACTICE.STATE()")
    if rc != 0:
        return "unknown"
    result.trim()

# Check if a dialog item exists
fn _t32_dialog_item_exists(host: text, port: text, name: text) -> bool:
    val (result, rc) = _t32_eval(host, port, "DIALOG.EXIST(" + name + ")")
    if rc != 0:
        return false
    val upper = result.trim().to_upper()
    upper == "TRUE()" or upper == "TRUE"

# Read a dialog item's string value
fn _t32_dialog_item_string(host: text, port: text, name: text) -> text:
    val (result, rc) = _t32_eval(host, port, "DIALOG.STRing(" + name + ")")
    if rc != 0:
        return ""
    result.trim()

# Read a dialog item's boolean value
fn _t32_dialog_item_boolean(host: text, port: text, name: text) -> text:
    val (result, rc) = _t32_eval(host, port, "DIALOG.BOOLEAN(" + name + ")")
    if rc != 0:
        return ""
    result.trim()

# Determine the kind of a dialog item by probing its type
fn _t32_dialog_item_kind(host: text, port: text, name: text) -> text:
    val bool_val = _t32_dialog_item_boolean(host, port, name)
    val upper = bool_val.to_upper()
    if (upper == "TRUE()" or upper == "TRUE" or
        upper == "FALSE()" or upper == "FALSE"):
        return "checkbox"
    "edit"

# Collect all queried items into T32DialogItems
fn _t32_collect_items(host: text, port: text, names: [text]) -> [T32DialogItem]:
    var items: [T32DialogItem] = []
    for name in names:
        val exists = _t32_dialog_item_exists(host, port, name)
        if exists:
            val kind = _t32_dialog_item_kind(host, port, name)
            val value = _t32_dialog_item_string(host, port, name)
            items.push(T32DialogItem(name: name, kind: kind, value: value, exists: true))
        else:
            items.push(T32DialogItem(name: name, kind: "unknown", value: "", exists: false))
    items

# Parse comma-separated item names from parameter string
fn _parse_item_names(param: text) -> [text]:
    var names: [text] = []
    if param.len() == 0:
        return names
    val parts = param.split(",")
    for p in parts:
        val trimmed = p.trim()
        if trimmed.len() > 0:
            names.push(trimmed)
    names

# Validate session and extract T32 connection info.
# Returns (error_response, session_id, host, port).
fn _require_t32_dialog(id: text, body: text) -> (text, text, text, text):
    val session_id = extract_field(body, "session_id")
    if session_id == "":
        return (make_tool_error(id, -32602, "Missing required parameter: session_id"), "", "", "")
    val (err, _) = _require_hw_session(id, session_id, ["t32", "t32_gdb"])
    if err != "":
        return (err, "", "", "")
    val session = dap_find_session(session_id)
    val (host, port) = _parse_t32_connection(session.program)
    ("", session_id, host, port)

# Brief sleep helper
fn _sleep_ms(ms: i64):
    val secs = ms / 1000
    val frac = ms % 1000
    if secs > 0:
        rt_process_run("sleep", [str(secs) + "." + str(frac)])
    else:
        rt_process_run("sleep", ["0." + str(frac)])

# ============================================================================
# Tool: debug_dialog_list — List open T32 windows and active dialogs
# ============================================================================
fn handle_debug_dialog_list(id: text, body: text) -> text:
    val (err, session_id, host, port) = _require_t32_dialog(id, body)
    if err != "":
        return err

    val state = _t32_practice_state(host, port)

    # Try to enumerate windows via WinPAGE.List
    val (win_raw, win_rc) = _t32_remote(host, port, "WinPAGE.List")
    var windows_arr = SB_L()
    var first = true

    if win_rc == 0 and win_raw.trim().len() > 0:
        val lines = win_raw.split(NL)
        for line in lines:
            val trimmed = line.trim()
            if trimmed.len() > 0:
                if not first:
                    windows_arr = windows_arr + ","
                first = false
                var wobj = LB()
                wobj = wobj + jp("name", js(trimmed))
                wobj = wobj + "," + jp("kind", js("window"))
                wobj = wobj + RB()
                windows_arr = windows_arr + wobj

    # If PRACTICE is in dialog state, add the active dialog entry
    if state == "dialog":
        if not first:
            windows_arr = windows_arr + ","
        first = false
        var dobj = LB()
        dobj = dobj + jp("name", js("practice_dialog"))
        dobj = dobj + "," + jp("kind", js("dialog"))
        dobj = dobj + "," + jp("active", "true")
        dobj = dobj + RB()
        windows_arr = windows_arr + dobj

    windows_arr = windows_arr + SB_R()

    var r = LB()
    r = r + jp("session_id", js(session_id))
    r = r + "," + jp("practice_state", js(state))
    r = r + "," + jp("windows", windows_arr)
    r = r + RB()
    make_tool_result(id, r)

# ============================================================================
# Tool: debug_dialog_read — Read dialog contents (controls + values)
# ============================================================================
fn handle_debug_dialog_read(id: text, body: text) -> text:
    val (err, session_id, host, port) = _require_t32_dialog(id, body)
    if err != "":
        return err

    val state = _t32_practice_state(host, port)
    if state != "dialog":
        return make_tool_error(id, -32602, "No dialog is currently open (practice_state: " + state + ")")

    val item_names = _parse_item_names(extract_field(body, "item_names"))
    if item_names.len() == 0:
        return make_tool_error(id, -32602, "Missing required parameter: item_names (comma-separated dialog control names)")

    # Query all items
    val items = _t32_collect_items(host, port, item_names)

    # Build JSON items array
    var items_arr = SB_L()
    var first = true
    for item in items:
        if not first:
            items_arr = items_arr + ","
        first = false
        var iobj = LB()
        iobj = iobj + jp("name", js(item.name))
        iobj = iobj + "," + jp("exists", bool_text(item.exists))
        iobj = iobj + "," + jp("kind", js(item.kind))
        iobj = iobj + "," + jp("value", js(item.value))
        iobj = iobj + RB()
        items_arr = items_arr + iobj
    items_arr = items_arr + SB_R()

    # Store snapshot for later tracking
    val snap = T32DialogSnapshot(
        session_id: session_id,
        practice_state: state,
        items: items,
        window_names: []
    )
    dialog_snapshot_store(snap)

    var r = LB()
    r = r + jp("session_id", js(session_id))
    r = r + "," + jp("practice_state", js(state))
    r = r + "," + jp("items", items_arr)
    r = r + "," + jp("item_count", str(items.len()))
    r = r + RB()
    make_tool_result(id, r)

# ============================================================================
# Tool: debug_dialog_click — Click a button or close dialog
# ============================================================================
fn handle_debug_dialog_click(id: text, body: text) -> text:
    val (err, session_id, host, port) = _require_t32_dialog(id, body)
    if err != "":
        return err

    val state = _t32_practice_state(host, port)
    if state != "dialog":
        return make_tool_error(id, -32602, "No dialog is currently open (practice_state: " + state + ")")

    val button_name = extract_field(body, "button_name")
    val action = extract_field(body, "action")

    # Handle close/end action
    if (action == "end" or action == "close" or action == "ok"):
        val (_, rc) = _t32_remote(host, port, "DIALOG.END")
        if rc != 0:
            return make_tool_error(id, -32603, "Failed to close dialog (DIALOG.END)")
        _sleep_ms(300)
        val new_state = _t32_practice_state(host, port)
        return make_tool_result(id, jo3(
            jp("action", js("dialog_end")),
            jp("practice_state", js(new_state)),
            jp("status", js("ok"))))

    if button_name == "":
        return make_tool_error(id, -32602, "Missing required parameter: button_name or action (end/close/ok)")

    # Verify button exists
    if not _t32_dialog_item_exists(host, port, button_name):
        return make_tool_error(id, -32602, "Dialog item not found: " + button_name)

    # Click button via DIALOG.Set with empty string
    val (_, rc) = _t32_remote(host, port, "DIALOG.Set " + button_name + " \"\"")
    if rc != 0:
        return make_tool_error(id, -32603, "Failed to click button: " + button_name)

    _sleep_ms(300)
    val new_state = _t32_practice_state(host, port)

    var r = LB()
    r = r + jp("session_id", js(session_id))
    r = r + "," + jp("button", js(button_name))
    r = r + "," + jp("practice_state", js(new_state))
    r = r + "," + jp("status", js("ok"))
    r = r + RB()
    make_tool_result(id, r)

# ============================================================================
# Tool: debug_dialog_set — Set a dialog field value
# ============================================================================
fn handle_debug_dialog_set_value(id: text, body: text) -> text:
    val (err, session_id, host, port) = _require_t32_dialog(id, body)
    if err != "":
        return err

    val state = _t32_practice_state(host, port)
    if state != "dialog":
        return make_tool_error(id, -32602, "No dialog is currently open (practice_state: " + state + ")")

    val item_name = extract_field(body, "item_name")
    val value = extract_field(body, "value")
    if item_name == "":
        return make_tool_error(id, -32602, "Missing required parameter: item_name")

    # Verify item exists
    if not _t32_dialog_item_exists(host, port, item_name):
        return make_tool_error(id, -32602, "Dialog item not found: " + item_name)

    # Set value via DIALOG.Set
    val (_, rc) = _t32_remote(host, port, "DIALOG.Set " + item_name + " \"" + value + "\"")
    if rc != 0:
        return make_tool_error(id, -32603, "Failed to set dialog item: " + item_name)

    # Read back to confirm
    val new_value = _t32_dialog_item_string(host, port, item_name)

    var r = LB()
    r = r + jp("session_id", js(session_id))
    r = r + "," + jp("item_name", js(item_name))
    r = r + "," + jp("value", js(new_value))
    r = r + "," + jp("status", js("ok"))
    r = r + RB()
    make_tool_result(id, r)

# ============================================================================
# Tool: debug_dialog_track — Execute command and track dialog changes
# ============================================================================
fn handle_debug_dialog_track(id: text, body: text) -> text:
    val (err, session_id, host, port) = _require_t32_dialog(id, body)
    if err != "":
        return err

    val command = extract_field(body, "command")
    if command == "":
        return make_tool_error(id, -32602, "Missing required parameter: command")

    val item_names = _parse_item_names(extract_field(body, "item_names"))

    var timeout_ms: i64 = 3000
    val timeout_str = extract_field(body, "timeout_ms")
    if timeout_str != "":
        timeout_ms = int(timeout_str)
        if timeout_ms < 500:
            timeout_ms = 3000

    # --- Pre-command snapshot ---
    val pre_state = _t32_practice_state(host, port)
    var pre_items: [T32DialogItem] = []
    if pre_state == "dialog" and item_names.len() > 0:
        pre_items = _t32_collect_items(host, port, item_names)
    val pre_snap = T32DialogSnapshot(
        session_id: session_id,
        practice_state: pre_state,
        items: pre_items,
        window_names: []
    )

    # --- Execute the T32 command ---
    val (cmd_output, cmd_rc) = _t32_remote(host, port, command)

    # --- Poll for state change ---
    var elapsed: i64 = 0
    val poll_ms: i64 = 200
    var post_state = _t32_practice_state(host, port)

    while elapsed < timeout_ms:
        if post_state != pre_state:
            break
        if post_state == "dialog":
            break
        if (post_state == "0" or post_state == "idle" or post_state == "stopped"):
            break
        _sleep_ms(poll_ms)
        elapsed = elapsed + poll_ms
        post_state = _t32_practice_state(host, port)

    # --- Post-command snapshot ---
    var post_items: [T32DialogItem] = []
    if post_state == "dialog" and item_names.len() > 0:
        post_items = _t32_collect_items(host, port, item_names)
    val post_snap = T32DialogSnapshot(
        session_id: session_id,
        practice_state: post_state,
        items: post_items,
        window_names: []
    )

    # Compute diff
    val changes = dialog_compute_changes(pre_snap, post_snap)

    # Store the new snapshot
    dialog_snapshot_store(post_snap)

    # --- Build changes JSON array ---
    var changes_arr = SB_L()
    var c_first = true
    for c in changes:
        if not c_first:
            changes_arr = changes_arr + ","
        c_first = false
        var cobj = LB()
        cobj = cobj + jp("change_type", js(c.change_type))
        cobj = cobj + "," + jp("window_name", js(c.window_name))
        if c.item_name.len() > 0:
            cobj = cobj + "," + jp("item_name", js(c.item_name))
        if c.old_value.len() > 0:
            cobj = cobj + "," + jp("old_value", js(c.old_value))
        if c.new_value.len() > 0:
            cobj = cobj + "," + jp("new_value", js(c.new_value))
        cobj = cobj + RB()
        changes_arr = changes_arr + cobj
    changes_arr = changes_arr + SB_R()

    # --- Build current items JSON array ---
    var items_arr = SB_L()
    var i_first = true
    for item in post_items:
        if not i_first:
            items_arr = items_arr + ","
        i_first = false
        var iobj = LB()
        iobj = iobj + jp("name", js(item.name))
        iobj = iobj + "," + jp("exists", bool_text(item.exists))
        iobj = iobj + "," + jp("kind", js(item.kind))
        iobj = iobj + "," + jp("value", js(item.value))
        iobj = iobj + RB()
        items_arr = items_arr + iobj
    items_arr = items_arr + SB_R()

    var r = LB()
    r = r + jp("session_id", js(session_id))
    r = r + "," + jp("command", js(command))
    r = r + "," + jp("command_output", js(cmd_output.trim()))
    r = r + "," + jp("command_rc", str(cmd_rc))
    r = r + "," + jp("pre_state", js(pre_state))
    r = r + "," + jp("post_state", js(post_state))
    r = r + "," + jp("changes", changes_arr)
    r = r + "," + jp("change_count", str(changes.len()))
    r = r + "," + jp("current_items", items_arr)
    r = r + RB()
    make_tool_result(id, r)
