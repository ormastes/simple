extern fn print_raw(s: text)

fn mcp_write_framed_message(body: text):
    val nl = "\n"
    var header = "Content-Length: " + str(body.len()) + "\r" + nl + "\r" + nl
    print_raw(header)
    print_raw(body)

# Honor the transport the client used: newline-delimited JSON (MCP stdio) or
# LSP-style Content-Length framing. Lets Claude Code talk to the server with no
# JS reframing bridge in front of it.
fn mcp_write_message(body: text, jsonl: bool):
    if jsonl:
        print_raw(body + "\n")
    else:
        mcp_write_framed_message(body)

export mcp_write_framed_message
export mcp_write_message
