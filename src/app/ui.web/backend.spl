# Web Render Backend
#
# Implements RenderBackend for browser-based rendering.
# Wraps the existing HTML generator and WebSocket server.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent}
use app.ui.render.widgets.{render_html_tree}
use app.ui.web.html.{generate_html_page, generate_css, generate_js}

# =========================================================================
# Web Backend
# =========================================================================

class WebBackend:
    port: i32
    ws_port: i32
    initialized: bool

    static fn new(port: i32) -> WebBackend:
        return WebBackend(
            port: port,
            ws_port: port,
            initialized: false
        )

    # --- Lifecycle ---

    fn init() -> Result<bool, text>:
        self.initialized = true
        return Ok(true)

    fn shutdown():
        self.initialized = false

    # --- Rendering ---

    fn render(state: UIState) -> Result<bool, text>:
        # Web backend renders by generating HTML
        # The server pushes updates via WebSocket
        return Ok(true)

    fn render_html(state: UIState) -> text:
        return render_html_tree(state.tree.root, state)

    # --- Events ---

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        # Events come from WebSocket messages, handled by ws_handler
        return nil

    # --- Capabilities ---

    fn supports_mouse() -> bool:
        return true

    fn supports_color() -> bool:
        return true

    fn supports_images() -> bool:
        return true

    fn supports_touch() -> bool:
        return true

    # --- Viewport ---

    fn viewport_width() -> i32:
        return 1920

    fn viewport_height() -> i32:
        return 1080

    # --- Backend Info ---

    fn backend_name() -> text:
        return "web"

    # --- Web-specific ---

    fn generate_full_page(state: UIState) -> text:
        """Generate a complete HTML page with CSS and JS."""
        return generate_html_page(state, self.ws_port)

    fn generate_page_css(theme: text) -> text:
        """Generate CSS for the given theme."""
        return generate_css(theme)

    fn generate_page_js() -> text:
        """Generate JavaScript for WebSocket communication."""
        return generate_js(self.ws_port)
