# Web Render Backend
#
# Implements RenderBackend for browser-based rendering.
# Wraps the existing HTML generator and WebSocket server.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent, WidgetNode, WidgetRect}
use common.ui.capability.{Capability, NotSupported}
use common.ui.web_render_api.{
    WEB_RENDER_TARGET_SIMPLE_WEB,
    WebRenderRequest,
    web_render_capabilities_for_target,
    web_render_full_html
}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css, generate_js}

# =========================================================================
# Web Backend
# =========================================================================

class WebBackend:
    port: i32
    ws_port: i32
    initialized: bool

    static fn new(port: i32) -> WebBackend:
        return WebBackend(
            port: port,
            ws_port: port,
            initialized: false
        )

    # --- Lifecycle ---

    me init() -> Result<bool, text>:
        self.initialized = true
        return Ok(true)

    me shutdown():
        self.initialized = false

    # --- Rendering ---

    fn render(state: UIState) -> Result<bool, text>:
        # Web backend renders by generating HTML
        # The server pushes updates via WebSocket
        return Ok(true)

    fn render_html(state: UIState) -> text:
        val body = render_html_tree(state.tree.root_node(), state)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, "", body, "", "", self.viewport_width(), self.viewport_height())
        return req.body_html

    # --- Events ---

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        # Events come from WebSocket messages, handled by ws_handler
        return nil

    # --- Capabilities ---

    fn capabilities() -> [Capability]:
        return web_render_capabilities_for_target(WEB_RENDER_TARGET_SIMPLE_WEB)

    fn supports_mouse() -> bool:
        return true

    fn supports_color() -> bool:
        return true

    fn supports_images() -> bool:
        return true

    fn supports_touch() -> bool:
        return true

    fn render_image(node: WidgetNode, rect: WidgetRect) -> Result<bool, NotSupported>:
        return Ok(true)

    # --- Viewport ---

    fn viewport_width() -> i32:
        return 1920

    fn viewport_height() -> i32:
        return 1080

    # --- Backend Info ---

    fn backend_name() -> text:
        return "web"

    # --- Web-specific ---

    fn generate_full_page(state: UIState) -> text:
        """Generate a complete HTML page with CSS and JS."""
        val body = render_html_tree(state.tree.root_node(), state)
        val css = generate_css(state.tree.theme_name())
        val js = generate_js(self.ws_port)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, "", body, css, js, self.viewport_width(), self.viewport_height())
        return web_render_full_html(req)

    fn generate_page_css(theme: text) -> text:
        """Generate CSS for the given theme."""
        return generate_css(theme)

    fn generate_page_js() -> text:
        """Generate JavaScript for WebSocket communication."""
        return generate_js(self.ws_port)
