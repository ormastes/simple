# Host Taskbar Shell — Server-Side Model Builder
#
# Converts the authoritative UiWindowSurfaceRegistry + a list of pinned
# AppRefs into a TaskbarModel (src/lib/common/ui/taskbar_model.spl) that
# the browser client consumes via the existing WebSocket renderer.
#
# This file is the host counterpart to src/os/desktop/taskbar_shell.spl
# — both produce the same schema, so Classic/Taskbar rendering on either
# side is portable.

use common.ui.taskbar_model.{TaskbarModel, AppRef, WindowRef, TrayItem}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry, UiWindowSurfaceBinding}

# =========================================================================
# WindowSnapshot — small record including surface_kind for smoke tests
# =========================================================================

struct WindowSnapshot:
    """Minimal per-window projection used by tests and the taskbar builder."""
    surface_id: text
    window_id: text
    app_id: text
    title: text
    surface_kind: text   # UI_SURFACE_KIND_*

fn snapshot_windows(registry: UiWindowSurfaceRegistry) -> [WindowSnapshot]:
    """Project the registry into a kind-aware list for introspection."""
    var out: [WindowSnapshot] = []
    for b in registry.bindings:
        out = out.push(WindowSnapshot(
            surface_id: b.surface_id,
            window_id: b.window_id,
            app_id: b.app_id,
            title: b.title,
            surface_kind: b.surface_kind
        ))
    out

# =========================================================================
# Taskbar Model Builder
# =========================================================================

fn build_taskbar_model(registry: UiWindowSurfaceRegistry, pinned: [AppRef], tray: [TrayItem]) -> TaskbarModel:
    """Build a TaskbarModel from the live registry + caller-supplied pinned + tray.

    Running-window entries are materialised from every registry binding;
    the caller decides pinning (persisted elsewhere — out of scope for
    Wave 4) and tray items.
    """
    var running: [WindowRef] = []
    for b in registry.bindings:
        running = running.push(WindowRef(
            window_id: b.window_id,
            app_id: b.app_id,
            title: b.title,
            minimized: false
        ))
    TaskbarModel(pinned: pinned, running: running, tray: tray)

fn build_taskbar_model_with_minimized(registry: UiWindowSurfaceRegistry, pinned: [AppRef], tray: [TrayItem], minimized_surface_ids: [text]) -> TaskbarModel:
    var running: [WindowRef] = []
    for b in registry.bindings:
        running = running.push(WindowRef(
            window_id: b.window_id,
            app_id: b.app_id,
            title: b.title,
            minimized: _contains_text(minimized_surface_ids, b.surface_id)
        ))
    TaskbarModel(pinned: pinned, running: running, tray: tray)

fn taskbar_model_to_json(model: TaskbarModel) -> text:
    var pinned_json = ""
    var first = true
    for item in model.pinned:
        val sep = if first: "" else: ","
        first = false
        pinned_json = "{pinned_json}{sep}" +
            "{" +
            "\"app_id\":\"{_json_escape(item.app_id)}\"," +
            "\"display_name\":\"{_json_escape(item.display_name)}\"," +
            "\"icon\":\"{_json_escape(item.icon)}\"" +
            "}"
    var running_json = ""
    first = true
    for item in model.running:
        val sep = if first: "" else: ","
        first = false
        val minimized = if item.minimized: "true" else: "false"
        running_json = "{running_json}{sep}" +
            "{" +
            "\"window_id\":\"{_json_escape(item.window_id)}\"," +
            "\"app_id\":\"{_json_escape(item.app_id)}\"," +
            "\"title\":\"{_json_escape(item.title)}\"," +
            "\"minimized\":{minimized}" +
            "}"
    var tray_json = ""
    first = true
    for item in model.tray:
        val sep = if first: "" else: ","
        first = false
        tray_json = "{tray_json}{sep}" +
            "{" +
            "\"item_id\":\"{_json_escape(item.item_id)}\"," +
            "\"label\":\"{_json_escape(item.label)}\"," +
            "\"icon\":\"{_json_escape(item.icon)}\"" +
            "}"
    "{" +
    "\"pinned\":[{pinned_json}]," +
    "\"running\":[{running_json}]," +
    "\"tray\":[{tray_json}]" +
    "}"

fn _contains_text(items: [text], target: text) -> bool:
    for item in items:
        if item == target:
            return true
    false

fn _json_escape(s: text) -> text:
    var r = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\"":
            r = "{r}\\\""
        elif ch == "\\":
            r = "{r}\\\\"
        elif ch == "\n":
            r = "{r}\\n"
        elif ch == "\r":
            r = "{r}\\r"
        elif ch == "\t":
            r = "{r}\\t"
        else:
            r = "{r}{ch}"
        i = i + 1
    r
