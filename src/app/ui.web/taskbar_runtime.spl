# Host Taskbar Runtime — authoritative taskbar + launch/runtime state
#
# Supports three host shell modes:
#   * desktop_embedded: taskbar + in-shell SimpleWeb surfaces
#   * taskbar_only:     taskbar shell + native Electron BrowserWindows
#   * headless:         no local shell window; remote UI still gets taskbar state

use common.ui.session.{UISession}
use common.ui.taskbar_model.{AppRef, TrayItem}
use common.ui.builder.{column, label, button, build_tree_with_title, with_width, with_height, with_visible}
use app.ui.web.taskbar_shell.{build_taskbar_model_with_minimized, taskbar_model_to_json}
use examples.hello_taskbar.main.{hello_html, hello_title, hello_size_width, hello_size_height}
use examples.hello_taskbar.app_manifest.{APP_ID, DISPLAY_NAME, ICON, resolve_for_local_host}
use os.desktop.app_manifest.{AppManifest, UiBackendKind, default_manifests, host_caps_host, resolve_backend}

struct HostTaskbarApp:
    app_id: text
    display_name: text
    icon: text
    description: text
    title: text
    width: i32
    height: i32
    native_html: text

enum HostShellMode:
    DesktopEmbedded
    TaskbarOnly
    Headless

struct HostWindowCommand:
    action: text
    window_id: text
    surface_id: text
    app_id: text
    title: text
    url: text
    x: i32
    y: i32
    width: i32
    height: i32

class HostTaskbarRuntime:
    enabled: bool
    mode: HostShellMode
    electron_available: bool
    next_window_ordinal: i64
    next_process_id: u64
    pinned: [AppRef]
    tray: [TrayItem]
    minimized_surface_ids: [text]
    pending_commands: [HostWindowCommand]

    static fn new() -> HostTaskbarRuntime:
        HostTaskbarRuntime(
            enabled: false,
            mode: HostShellMode.DesktopEmbedded,
            electron_available: false,
            next_window_ordinal: 0,
            next_process_id: 1000u64,
            pinned: _default_pinned(),
            tray: _default_tray(),
            minimized_surface_ids: [],
            pending_commands: []
        )

var _host_taskbar_runtime: HostTaskbarRuntime? = nil

fn host_taskbar_runtime_reset():
    _host_taskbar_runtime = Some(HostTaskbarRuntime.new())

fn host_taskbar_runtime_enable(mode_name: text, electron_available: bool):
    val rt = _get_host_taskbar_runtime()
    rt.enabled = true
    rt.mode = _parse_mode(mode_name)
    rt.electron_available = electron_available
    rt.next_window_ordinal = 0
    rt.next_process_id = 1000u64
    rt.minimized_surface_ids = []
    rt.pending_commands = []

fn host_taskbar_runtime_is_enabled() -> bool:
    val rt = _get_host_taskbar_runtime()
    rt.enabled

fn host_taskbar_runtime_mode_name() -> text:
    val rt = _get_host_taskbar_runtime()
    _mode_name(rt.mode)

fn host_taskbar_runtime_taskbar_frame(session_id: text, session: UISession) -> text:
    val rt = _get_host_taskbar_runtime()
    val model = build_taskbar_model_with_minimized(
        session.window_surfaces,
        rt.pinned,
        rt.tray,
        rt.minimized_surface_ids
    )
    val payload = taskbar_model_to_json(model)
    _make_frame("taskbar_model", session_id, "null", payload)

fn host_taskbar_runtime_take_client_frames(session_id: text) -> [text]:
    val rt = _get_host_taskbar_runtime()
    var frames: [text] = []
    for cmd in rt.pending_commands:
        val payload = _command_to_json(cmd)
        frames = frames.push(_make_frame("host_window_command", session_id, "null", payload))
    rt.pending_commands = []
    frames

fn host_taskbar_runtime_native_window_html(app_id: text) -> text?:
    val app = _find_app(app_id)
    if app != nil:
        return app.native_html
    return nil

fn host_taskbar_runtime_catalog() -> [HostTaskbarApp]:
    var apps: [HostTaskbarApp] = [_hello_catalog_app()]
    for manifest in default_manifests():
        if _find_app_in(apps, manifest.binary) == nil:
            apps = apps.push(_manifest_catalog_app(manifest))
    apps

fn host_taskbar_runtime_launch(session: UISession, app_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    if not rt.enabled:
        return Err("host taskbar runtime not enabled")
    val app = _find_app(app_id)
    if app == nil:
        return Err("unknown pinned app: {app_id}")
    val title = app.title
    val width = app.width
    val height = app.height

    rt.next_window_ordinal = rt.next_window_ordinal + 1
    rt.next_process_id = rt.next_process_id + 1u64
    val ordinal = rt.next_window_ordinal
    val process_id = rt.next_process_id
    val surface_id = "host-surface-{ordinal}"
    val window_id = "host-window-{ordinal}"

    if _mode_is_headless(rt.mode):
        session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, "Headless")
        return Ok(())

    val resolved_backend = _resolve_app_backend(app_id, rt.electron_available)
    val backend = match resolved_backend:
        Err(e):
            return Err(e)
        Ok(kind):
            kind

    if _mode_is_taskbar_only(rt.mode) and backend != UiBackendKind.Electron:
        return Err("taskbar-only mode requires an Electron-resolved backend")

    if _mode_is_taskbar_only(rt.mode) and backend == UiBackendKind.Electron:
        session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, "Electron")
        session.set_active_surface(surface_id)
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "spawn_native_window",
            window_id: window_id,
            surface_id: surface_id,
            app_id: app_id,
            title: title,
            url: _native_window_url(app_id, surface_id, window_id),
            x: 0,
            y: 0,
            width: width,
            height: height
        ))
        return Ok(())

    val _ = session.open_surface(surface_id, _build_app_tree(surface_id, title, width, height, true))
    session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, "SimpleWeb")
    session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_focus(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    if binding.surface_kind == "Electron":
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "focus_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
    else:
        _set_surface_visible(session, surface_id, true)
        session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_sync_focus(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_minimize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not _contains_text(rt.minimized_surface_ids, surface_id):
        rt.minimized_surface_ids = rt.minimized_surface_ids.push(surface_id)
    if binding.surface_kind == "Electron":
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "minimize_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
    else:
        _set_surface_visible(session, surface_id, false)
    return Ok(())

fn host_taskbar_runtime_sync_minimize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not _contains_text(rt.minimized_surface_ids, surface_id):
        rt.minimized_surface_ids = rt.minimized_surface_ids.push(surface_id)
    return Ok(())

fn host_taskbar_runtime_restore(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    if binding.surface_kind == "Electron":
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "restore_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
    else:
        _set_surface_visible(session, surface_id, true)
        session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_sync_restore(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_close(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    if binding.surface_kind == "Electron":
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "close_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
        session.clear_window_surface_binding(surface_id)
        return Ok(())
    val handle = session.surface_handle(surface_id)
    if handle != nil:
        val _ = session.close_surface(handle)
    else:
        session.clear_window_surface_binding(surface_id)
    return Ok(())

fn host_taskbar_runtime_sync_close(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    val handle = session.surface_handle(surface_id)
    if handle != nil:
        val _ = session.close_surface(handle)
    else:
        session.clear_window_surface_binding(surface_id)
    return Ok(())

fn host_taskbar_runtime_move(session: UISession, surface_id: text, x: i32, y: i32) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if binding.surface_kind != "Electron":
        return Err("surface is not native")
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "move_native_window",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: binding.title,
        url: "",
        x: x,
        y: y,
        width: 0,
        height: 0
    ))
    return Ok(())

fn host_taskbar_runtime_sync_move(session: UISession, surface_id: text, x: i32, y: i32) -> Result<Unit, text>:
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    val tree = session.get_surface(surface_id)
    if tree != nil:
        val root_id = tree.root_node().id
        val _ = session.set_surface_widget_prop(surface_id, root_id, "x", "{x}")
        val _ = session.set_surface_widget_prop(surface_id, root_id, "y", "{y}")
    return Ok(())

