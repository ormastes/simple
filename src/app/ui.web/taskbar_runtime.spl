    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if binding.surface_kind != "Electron":
        return Err("surface is not native")
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "resize_native_window",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: binding.title,
        url: "",
        x: 0,
        y: 0,
        width: width,
        height: height
    ))
    return Ok(())

fn host_taskbar_runtime_sync_resize(session: UISession, surface_id: text, width: i32, height: i32) -> Result<Unit, text>:
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    val tree = session.get_surface(surface_id)
    if tree != nil:
        val root_id = tree.root_node().id
        val _ = session.set_surface_widget_prop(surface_id, root_id, "width", "{width}")
        val _ = session.set_surface_widget_prop(surface_id, root_id, "height", "{height}")
    return Ok(())

fn host_taskbar_runtime_maximize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if binding.surface_kind != "Electron":
        return Err("surface is not native")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "maximize_native_window",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: binding.title,
        url: "",
        x: 0,
        y: 0,
        width: 0,
        height: 0
    ))
    return Ok(())

fn host_taskbar_runtime_sync_maximize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    val tree = session.get_surface(surface_id)
    if tree != nil:
        val root_id = tree.root_node().id
        val _ = session.set_surface_widget_prop(surface_id, root_id, "maximized", "true")
    return Ok(())

fn host_taskbar_runtime_set_title(session: UISession, surface_id: text, title: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if binding.surface_kind != "Electron":
        return Err("surface is not native")
    val _ = session.update_window_surface_title(surface_id, title)
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "set_native_window_title",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: title,
        url: "",
        x: 0,
        y: 0,
        width: 0,
        height: 0
    ))
    return Ok(())

fn host_taskbar_runtime_sync_set_title(session: UISession, surface_id: text, title: text) -> Result<Unit, text>:
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    val _ = session.update_window_surface_title(surface_id, title)
    return Ok(())

fn _get_host_taskbar_runtime() -> HostTaskbarRuntime:
    if not _host_taskbar_runtime.?:
        _host_taskbar_runtime = Some(HostTaskbarRuntime.new())
    _host_taskbar_runtime.unwrap()

fn _default_pinned() -> [AppRef]:
    var pinned: [AppRef] = []
    for app in host_taskbar_runtime_catalog():
        pinned = pinned.push(AppRef(
            app_id: app.app_id,
            display_name: app.display_name,
            icon: app.icon
        ))
    pinned

fn _find_app(app_id: text) -> HostTaskbarApp?:
    _find_app_in(host_taskbar_runtime_catalog(), app_id)

fn _find_app_in(apps: [HostTaskbarApp], app_id: text) -> HostTaskbarApp?:
    for app in apps:
        if app.app_id == app_id:
            return app
    return nil

fn _hello_catalog_app() -> HostTaskbarApp:
    HostTaskbarApp(
        app_id: APP_ID,
        display_name: DISPLAY_NAME,
        icon: ICON,
        description: "Host taskbar runtime demo",
        title: hello_title(),
        width: hello_size_width(),
        height: hello_size_height(),
        native_html: hello_html()
    )

fn _manifest_catalog_app(manifest: AppManifest) -> HostTaskbarApp:
    val title = manifest.name
    HostTaskbarApp(
        app_id: manifest.binary,
        display_name: manifest.name,
        icon: manifest.icon,
        description: manifest.description,
        title: title,
        width: 640,
        height: 420,
        native_html: _generic_manifest_html(manifest)
    )

fn _resolve_app_backend(app_id: text, electron_available: bool) -> Result<UiBackendKind, text>:
    if app_id == APP_ID:
        return resolve_for_local_host(electron_available)
    val resolved = resolve_backend(UiBackendKind.Auto, host_caps_host(electron_available))
    match resolved:
        Ok(kind): Ok(kind)
        Err(_): Err("Electron not available on this host")

fn _generic_manifest_html(manifest: AppManifest) -> text:
    val title = _html_escape(manifest.name)
    val desc = _html_escape(manifest.description)
    val category = _html_escape(manifest.category)
    val binary = _html_escape(manifest.binary)
    "<!doctype html>" +
    "<html><head><meta charset='utf-8'>" +
    "<title>{title}</title>" +
    "<style>" +
    "body { margin: 0; min-height: 100vh; padding: 28px; background: linear-gradient(135deg, #10201b, #101724); color: #f3f0dc; font-family: Georgia, serif; }" +
    "h1 { margin: 0 0 10px 0; font-size: 28px; }" +
    "p { margin: 8px 0; font-size: 15px; line-height: 1.45; }" +
    ".tag { display: inline-block; margin-top: 14px; padding: 6px 10px; border: 1px solid rgba(243,240,220,.35); border-radius: 999px; }" +
    "</style></head><body>" +
    "<h1>{title}</h1>" +
    "<p>{desc}</p>" +
    "<p class='tag'>{category} - {binary}</p>" +
    "</body></html>"

fn _html_escape(s: text) -> text:
    var r = s.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r = r.replace("\"", "&quot;")
    r = r.replace("'", "&#39;")
    r

fn _default_tray() -> [TrayItem]:
    [TrayItem(item_id: "host-runtime", label: "host", icon: "host")]

fn _parse_mode(mode_name: text) -> HostShellMode:
    val m = mode_name.to_lower()
    if m == "taskbar_only" or m == "taskbar-only":
        return HostShellMode.TaskbarOnly
    if m == "headless":
        return HostShellMode.Headless
    return HostShellMode.DesktopEmbedded

fn _mode_name(mode: HostShellMode) -> text:
    match mode:
        HostShellMode.DesktopEmbedded: "desktop_embedded"
        HostShellMode.TaskbarOnly: "taskbar_only"
        HostShellMode.Headless: "headless"

fn _mode_is_taskbar_only(mode: HostShellMode) -> bool:
    match mode:
        HostShellMode.TaskbarOnly: true
        _: false

fn _mode_is_headless(mode: HostShellMode) -> bool:
    match mode:
        HostShellMode.Headless: true
        _: false

fn _build_app_tree(surface_id: text, title: text, width: i32, height: i32, visible: bool):
    val root = with_visible(
        with_height(
            with_width(
                column("{surface_id}_root", [
                    label("{surface_id}_title", title),
                    label("{surface_id}_body", "Host taskbar runtime demo surface"),
                    button("{surface_id}_dismiss", "Close", "close")
                ]),
                width
            ),
            height
        ),
        visible
    )
    build_tree_with_title(root, title, "glass_dark")

fn _set_surface_visible(session: UISession, surface_id: text, visible: bool):
    val tree = session.get_surface(surface_id)
    if tree == nil:
        return
    val updated = build_tree_with_title(
        with_visible(tree.root_node(), visible),
        tree.title_text(),
        tree.theme_name()
    )
    val handle = session.surface_handle(surface_id)
    if handle != nil:
        session.update_surface_tree(handle, updated)

fn _native_window_url(app_id: text, surface_id: text, window_id: text) -> text:
    "/wm/native_window?app_id={_url_encode(app_id)}&surface_id={_url_encode(surface_id)}&window_id={_url_encode(window_id)}"

fn _url_encode(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "/":
            out = "{out}%2F"
        elif ch == " ":
            out = "{out}%20"
        elif ch == "&":
            out = "{out}%26"
        elif ch == "=":
            out = "{out}%3D"
        elif ch == "?":
            out = "{out}%3F"
        else:
            out = "{out}{ch}"
        i = i + 1
    out

fn _contains_text(items: [text], target: text) -> bool:
    for item in items:
        if item == target:
            return true
    false

fn _remove_text(items: [text], target: text) -> [text]:
    var filtered: [text] = []
    for item in items:
        if item == target:
            pass_do_nothing
        else:
            filtered = filtered.push(item)
    filtered

fn _command_to_json(cmd: HostWindowCommand) -> text:
    "{" +
    "\"action\":\"{_json_escape(cmd.action)}\"," +
    "\"window_id\":\"{_json_escape(cmd.window_id)}\"," +
    "\"surface_id\":\"{_json_escape(cmd.surface_id)}\"," +
    "\"app_id\":\"{_json_escape(cmd.app_id)}\"," +
    "\"title\":\"{_json_escape(cmd.title)}\"," +
    "\"url\":\"{_json_escape(cmd.url)}\"," +
    "\"x\":{cmd.x}," +
    "\"y\":{cmd.y}," +
    "\"width\":{cmd.width}," +
    "\"height\":{cmd.height}" +
    "}"

fn _make_frame(msg_type: text, session_id: text, seq: text, payload: text) -> text:
    "{\"t\": \"{msg_type}\", \"v\": 1, \"s\": \"{session_id}\", \"seq\": {seq}, \"payload\": {payload}}"

fn _json_escape(s: text) -> text:
    var r = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\"":
            r = "{r}\\\""
        elif ch == "\\":
            r = "{r}\\\\"
        elif ch == "\n":
            r = "{r}\\n"
        elif ch == "\r":
            r = "{r}\\r"
        elif ch == "\t":
            r = "{r}\\t"
        else:
            r = "{r}{ch}"
        i = i + 1
    r
