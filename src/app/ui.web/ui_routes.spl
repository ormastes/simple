# UI Routes — /ui/* route dispatch for the Web UI server.
#
# Routes:
#   GET/WS /ui/ws   — WebSocket upgrade (bearer-gated via ws_handler), then
#                     construct WebRuntimeAdapter and run read/emit loop.
#   POST   /ui/resume — parse {session_id, snapshot_revision, last_sequence};
#                       send patch_batch or snapshot via adapter.
#
# /ui/login is handled by server.spl and must NOT be intercepted here.

use app.ui.web.tls_serve_loop.{ConnStream}
use nogc_sync_mut.ui.session.{UISession}
use app.ui.web.origin_guard.{OriginGuard, AuthError}
use app.ui.web.session_token.{verify, load_secret, random_hex}
use app.ui.web.auth_params.{UI_WEB_MAX_AUTH_JSON_BYTES, ui_web_extract_bearer, ui_web_query_param, ui_web_percent_decode_query_component, ui_web_ws_response_protocol, ui_web_auth_json_field, ui_web_ws_frame_payload_allowed, ui_web_json_security_headers}
use app.ui.web.ws_handler.{extract_ws_key, compute_ws_accept, send_ws_text}
use app.ui.web.async_ws.{extract_field}
use app.ui.web.web_runtime_adapter.{WebRuntimeAdapter}
use app.ui.web.wm_bridge.{WmBridge}
use app.ui.web.bounded_channel.{BoundedChannel}
use app.ui.web.wire.{make_wire_frame}
use app.ui.web.taskbar_runtime.{host_taskbar_runtime_is_enabled, host_taskbar_runtime_take_client_frames}

extern fn rt_time_ms() -> u64

fn ui_routes_time_ms() -> u64:
    rt_time_ms()

# =========================================================================
# Route dispatcher
# =========================================================================

fn dispatch_ui_route(path: text, method: text, headers: text, body: text, stream: ConnStream, session: UISession, guard: OriginGuard, secret: text) -> bool:
    """Returns true if request was handled; false if path is not /ui/*.
    /ui/login is intentionally excluded — handled by server.spl."""
    val route = _strip_query(path)
    if not route.starts_with("/ui/"):
        return false

    if route == "/ui/ws" and method == "GET":
        _handle_ws_route(stream, path, headers, session, guard, secret)
        return true

    if route == "/ui/ws":
        val resp = _ui_json_response(405, "{\"error\":\"method_not_allowed\"}")
        stream.write_all(resp)
        return true

    if route == "/ui/resume" and method == "POST":
        _handle_resume_route(stream, path, headers, body, session, guard, secret)
        return true

    # Unknown /ui/ path
    val resp = "HTTP/1.1 404 Not Found\r\nContent-Length: 9\r\nConnection: close\r\n\r\nNot Found"
    stream.write_all(resp)
    return true

fn ui_web_authorization_status(headers: text, path: text, guard: OriginGuard, secret: text, now_ms: u64) -> text:
    var origin = ""
    match guard.check(headers):
        Err(_): return "forbidden_origin"
        Ok(o): origin = o
    val bearer = _extract_bearer(headers, path)
    if bearer == "":
        return "missing_bearer"
    val tok_result = verify(bearer, origin, secret, now_ms)
    match tok_result:
        Err(_): return "invalid_bearer"
        Ok(_): return "ok"

fn ui_web_request_authorized(headers: text, path: text, guard: OriginGuard, secret: text, now_ms: u64) -> bool:
    return ui_web_authorization_status(headers, path, guard, secret, now_ms) == "ok"

fn ui_web_resume_body_status(body: text) -> text:
    if body.len() > UI_WEB_MAX_AUTH_JSON_BYTES:
        return "body_too_large"
    val session_id = ui_web_auth_json_field(body, "session_id")
    val rev_str = ui_web_auth_json_field(body, "snapshot_revision")
    val seq_str = ui_web_auth_json_field(body, "last_sequence")
    if session_id == "":
        return "missing_session_id"
    if not _is_u64_literal(rev_str):
        return "invalid_snapshot_revision"
    if not _is_i64_literal(seq_str):
        return "invalid_last_sequence"
    return "ok"

export ui_web_authorization_status
export ui_web_request_authorized
export ui_web_resume_body_status

# =========================================================================
# /ui/ws — WebSocket upgrade + adapter loop
# =========================================================================

fn _handle_ws_route(stream: ConnStream, path: text, headers: text, session: UISession, guard: OriginGuard, secret: text):
    """Gate origin + bearer, complete WS handshake, then run adapter read loop."""
    # Security gate: origin check
    var origin = ""
    match guard.check(headers):
        Err(_):
            stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(o): origin = o

    # Security gate: bearer token
    val bearer = _extract_bearer(headers, path)
    if bearer == "":
        stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
        return
    val now = ui_routes_time_ms()
    val tok_result = verify(bearer, origin, secret, now)
    var grant_id = ""
    match tok_result:
        Err(_):
            stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(tok): grant_id = tok.grant_id

    # Complete WebSocket handshake
    val key = extract_ws_key(headers)
    if key == "":
        stream.write_all("HTTP/1.1 400 Bad Request\r\nContent-Length: 0\r\n\r\n")
        return
    val accept = compute_ws_accept(key)
    var ws_response = "HTTP/1.1 101 Switching Protocols\r\n"
    ws_response = "{ws_response}Upgrade: websocket\r\n"
    ws_response = "{ws_response}Connection: Upgrade\r\n"
    ws_response = "{ws_response}Sec-WebSocket-Accept: {accept}\r\n"
    val protocol = ui_web_ws_response_protocol(headers)
    if protocol != "":
        ws_response = "{ws_response}Sec-WebSocket-Protocol: {protocol}\r\n"
    ws_response = "{ws_response}\r\n"
    stream.write_all(ws_response)

    # Build adapter
    val session_id = random_hex(16)
    var out_channel: BoundedChannel<text> = BoundedChannel.new(256)
    var adapter = WebRuntimeAdapter.new(session_id, session, grant_id, out_channel)

    # Send initial snapshot
    adapter.send_snapshot()
    _flush_out(stream, out_channel)

    # Read loop
    loop:
        val frame = _read_ws_frame_conn(stream)
        if frame == nil:
            break
        val msg_type = extract_field(frame, "t")
        match msg_type:
            "hello":
                val caps_payload = "{\"granted\": []}"
                val caps_frame = make_wire_frame("capabilities", session_id, "null", caps_payload)
                send_ws_text(stream, caps_frame)
            "open_session":
                adapter.send_snapshot()
            "resume_session":
                val rev_str = extract_field(frame, "snapshot_revision")
                val seq_str = extract_field(frame, "last_sequence")
                val rev: u64 = if rev_str == "": 0 else: _parse_u64(rev_str)
                val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
                adapter.on_resume(rev, seq)
            "ack":
                val seq_str = extract_field(frame, "last_applied_sequence")
                val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
                adapter.on_ack(seq)
            "input_event":
                _handle_input_event(frame, session, session_id, out_channel)
            "host_wm_pointer":
                _handle_host_wm_pointer(frame, session, session_id, out_channel)
            "window_cmd":
                _handle_window_cmd(frame, session, session_id, out_channel)
            "ping":
                val nonce = extract_field(frame, "nonce")
                val pong_payload = "{\"nonce\": \"{nonce}\"}"
                val pong_frame = make_wire_frame("pong", session_id, "null", pong_payload)
                send_ws_text(stream, pong_frame)
            _:
                pass_do_nothing("unknown client frame type is ignored")

        # Emit any pending patches
        adapter.emit_patches()
        _flush_out(stream, out_channel)

fn _flush_out(stream: ConnStream, ch: BoundedChannel<text>):
    """Drain the adapter's output channel and send all frames."""
    loop:
        val item = ch.try_recv()
        if item == nil:
            break
        send_ws_text(stream, item as text)

fn _handle_input_event(frame: text, session: UISession, session_id: text, out_ch: BoundedChannel<text>):
    val surface_id = extract_field(frame, "surface_id")
    val widget_id = extract_field(frame, "widget_id")
    if surface_id == "":
        _send_error(out_ch, session_id, "UNKNOWN_SURFACE", "surface_id required")
        return
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        _send_error(out_ch, session_id, "UNKNOWN_SURFACE", "surface not registered")
        return
    val bridge = WmBridge.new(session)
    # Build a minimal WmInputEvent from the JSON event sub-object
    val event_json = _extract_object(frame, "event")
    val wm_event = _parse_wm_input_event(event_json)
    val result = bridge.handle_input(surface_id, widget_id, event_json, wm_event)
    match result:
        Err(_):
            _send_error(out_ch, session_id, "CAP_DENIED", "InputInject capability denied")
        Ok(_):
            pass_do_nothing("input event dispatched; patches flush below")

fn _handle_window_cmd(frame: text, session: UISession, session_id: text, out_ch: BoundedChannel<text>):
    var cmd_kind = extract_field(frame, "cmd_type")
    if cmd_kind == "":
        cmd_kind = extract_field(frame, "kind")
    if cmd_kind == "":
        _send_error(out_ch, session_id, "BAD_REQUEST", "cmd_type required")
        return
    val payload = _extract_object(frame, "payload")
    val bridge = WmBridge.new(session)
    val result = bridge.handle_window_cmd(cmd_kind, payload)
    match result:
        Err(_):
            _send_error(out_ch, session_id, "CAP_DENIED", "window command capability denied")
        Ok(_):
            if host_taskbar_runtime_is_enabled():
                for client_frame in host_taskbar_runtime_take_client_frames(session_id):
                    out_ch.send(client_frame)

fn _handle_host_wm_pointer(frame: text, session: UISession, session_id: text, out_ch: BoundedChannel<text>):
    val payload = _extract_object(frame, "payload")
    val x = _json_field(payload, "x")
    val y = _json_field(payload, "y")
    val width = _json_field(payload, "width")
    val height = _json_field(payload, "height")
    val button = _json_field(payload, "button")
    val kind = _json_field(payload, "kind")
    val bridge = WmBridge.new(session)
    val result = bridge.handle_host_wm_pointer_loop_step(
        if x == "": 0 else: x.parse_i32(),
        if y == "": 0 else: y.parse_i32(),
        if button == "": "left" else: button,
        if kind == "": "down" else: kind,
        if width == "": 1280 else: width.parse_i32(),
        if height == "": 720 else: height.parse_i32()
    )
    match result:
        Err(_):
            _send_error(out_ch, session_id, "CAP_DENIED", "host WM pointer command denied")
        Ok(marker):
            out_ch.send(make_wire_frame("host_wm_loop_step", session_id, "null", "{\"marker\":\"{marker}\"}"))
            if host_taskbar_runtime_is_enabled():
                for client_frame in host_taskbar_runtime_take_client_frames(session_id):
                    out_ch.send(client_frame)

# =========================================================================
# /ui/resume — HTTP POST resume
# =========================================================================

fn _handle_resume_route(stream: ConnStream, path: text, headers: text, body: text, session: UISession, guard: OriginGuard, secret: text):
    var origin = ""
    match guard.check(headers):
        Err(_):
            stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(o): origin = o
    val bearer = _extract_bearer(headers, path)
    if bearer == "":
        stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
        return
    val tok_result = verify(bearer, origin, secret, ui_routes_time_ms())
    match tok_result:
        Err(_):
            stream.write_all("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(_):
            pass_do_nothing("resume bearer verified; request handling continues")
    val session_id = ui_web_auth_json_field(body, "session_id")
    val rev_str = ui_web_auth_json_field(body, "snapshot_revision")
    val seq_str = ui_web_auth_json_field(body, "last_sequence")
    val resume_status = ui_web_resume_body_status(body)
    if resume_status == "body_too_large":
        val too_large = "{\"error\": \"request_body_too_large\"}"
        stream.write_all(_ui_json_response(413, too_large))
        return
    if resume_status != "ok":
        val bad = "{\"error\": \"invalid_resume_body\"}"
        stream.write_all(_ui_json_response(400, bad))
        return
    val rev: u64 = if rev_str == "": 0 else: _parse_u64(rev_str)
    val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
    val resp_json = "{\"session_id\": \"{session_id}\", \"snapshot_revision\": {rev}, \"last_sequence\": {seq}}"
    stream.write_all(_ui_json_response(200, resp_json))

# =========================================================================
# Private helpers
# =========================================================================

fn _ui_json_response(status: i32, body: text) -> text:
    val status_text = match status:
        200: "OK"
        400: "Bad Request"
        405: "Method Not Allowed"
        413: "Payload Too Large"
        _: "OK"
    var resp = "HTTP/1.1 {status} {status_text}\r\n"
    resp = "{resp}Content-Type: application/json\r\n"
    resp = "{resp}{ui_web_json_security_headers(\"application/json\")}"
    resp = "{resp}Content-Length: {body.len()}\r\n"
    resp = "{resp}Connection: close\r\n"
    resp = "{resp}\r\n"
    return "{resp}{body}"

fn _read_ws_frame_conn(stream: ConnStream) -> text?:
    """Read a single WebSocket text frame from a ConnStream.

    Mirrors async_ws.read_ws_frame but uses ConnStream.read_bytes instead of
    TcpStream.read so it works over both TCP and TLS transports.
    Returns the decoded payload text, or nil on error/close.
    """
    match stream.read_bytes(2):
        Err(_):
            return nil
        Ok(header):
            var byte0: u8 = 0
            var byte1: u8 = 0
            var hdr_idx = 0
            for b in header:
                if hdr_idx == 0:
                    byte0 = b
                elif hdr_idx == 1:
                    byte1 = b
                hdr_idx = hdr_idx + 1
            if hdr_idx < 2:
                return nil

            val opcode = byte0 & 0x0F
            # 0x8 = connection close, 0x9 = ping, 0xA = pong
            if opcode == 0x8:
                return nil

            val masked = (byte1 & 0x80) != 0
            var payload_len: i64 = (byte1 & 0x7F) as i64

            if payload_len == 126:
                match stream.read_bytes(2):
                    Err(_):
                        return nil
                    Ok(ext):
                        var b0: u8 = 0
                        var b1: u8 = 0
                        var idx = 0
                        for b in ext:
                            if idx == 0: b0 = b
                            elif idx == 1: b1 = b
                            idx = idx + 1
                        payload_len = (b0 as i64) * 256 + (b1 as i64)
            elif payload_len == 127:
                match stream.read_bytes(8):
                    Err(_):
                        return nil
                    Ok(ext):
                        var acc: i64 = 0
                        for b in ext:
                            acc = acc * 256 + (b as i64)
                        payload_len = acc
            if not ui_web_ws_frame_payload_allowed(payload_len):
                return nil

            var mask_key: [u8] = []
            if masked:
                match stream.read_bytes(4):
                    Err(_):
                        return nil
                    Ok(mk):
                        mask_key = mk

            match stream.read_bytes(payload_len):
                Err(_):
                    return nil
                Ok(payload_bytes):
                    if not masked:
                        return payload_bytes.to_text()
                    val payload_count = payload_bytes.len()
                    if payload_count == 0:
                        return ""
                    var mask0: u8 = 0
                    var mask1: u8 = 0
                    var mask2: u8 = 0
                    var mask3: u8 = 0
                    var mi = 0
                    for mk in mask_key:
                        if mi == 0:
                            mask0 = mk
                        elif mi == 1:
                            mask1 = mk
                        elif mi == 2:
                            mask2 = mk
                        elif mi == 3:
                            mask3 = mk
                        mi = mi + 1
                    var decoded: [u8] = [0u8; payload_count]
                    var pi = 0
                    for pb in payload_bytes:
                        val mk_idx = pi % 4
                        val mk_byte = if mk_idx == 0: mask0 elif mk_idx == 1: mask1 elif mk_idx == 2: mask2 else: mask3
                        decoded[pi] = pb ^ mk_byte
                        pi = pi + 1
                    return decoded.to_text()

fn _send_error(out_ch: BoundedChannel<text>, session_id: text, code: text, message: text):
    val payload = "{\"code\": \"{code}\", \"message\": \"{message}\", \"retry_after_ms\": 0}"
    val frame = make_wire_frame("error", session_id, "null", payload)
    out_ch.send(frame)

fn _extract_bearer(headers: text, path: text) -> text:
    return ui_web_extract_bearer(headers, path)

fn _strip_query(path: text) -> text:
    val idx = path.find("?")
    if idx < 0:
        return path
    return path.slice(0, idx)

fn _query_param(path: text, key: text) -> text:
    return ui_web_query_param(path, key)

fn ui_web_query_percent_decode(value: text) -> text:
    return ui_web_percent_decode_query_component(value)

export ui_web_query_percent_decode

fn _json_field(json: text, field: text) -> text:
    val key = "\"{field}\":"
    val pos = json.find(key)
    if pos < 0:
        return ""
    val start = pos + key.len()
    val json_len = json.len()
    if start >= json_len:
        return ""
    val first_ch = json[start]
    if first_ch == "\"":
        val inner = start + 1
        var end = inner
        while end < json_len and json[end] != "\"":
            if json[end] == "\\":
                end = end + 1
            end = end + 1
        return json.slice(inner, end)
    var end = start
    while end < json_len:
        val ch = json[end]
        if ch == "," or ch == "}" or ch == "]":
            return json.slice(start, end).trim()
        end = end + 1
    return json.slice(start, json_len).trim()

fn _extract_object(json: text, field: text) -> text:
    """Extract a nested JSON object for the given field key."""
    val key = "\"{field}\":"
    val pos = json.find(key)
    if pos < 0:
        return "{}"
    val after = pos + key.len()
    val brace = _find_from(json, "{", after)
    if brace < 0:
        return "{}"
    var depth = 0
    var i = brace
    val json_len = json.len()
    while i < json_len:
        val ch = json[i]
        if ch == "{":
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0:
                return json.slice(brace, i + 1)
        i = i + 1
    return "{}"

fn _parse_u64(s: text) -> u64:
    if s == "":
        return 0 as u64
    var i = 0
    var acc: u64 = 0 as u64
    val s_len = s.len()
    while i < s_len:
        val digit = _digit(s.slice(i, i + 1))
        if digit < 0:
            break
        acc = (acc * (10 as u64)) + (digit as u64)
        i = i + 1
    return acc

fn _is_u64_literal(s: text) -> bool:
    if s == "":
        return false
    var i = 0
    val s_len = s.len()
    while i < s_len:
        if _digit(s.slice(i, i + 1)) < 0:
            return false
        i = i + 1
    return true

fn _is_i64_literal(s: text) -> bool:
    if s == "":
        return false
    var i = 0
    val s_len = s.len()
    if s.slice(0, 1) == "-":
        if s_len == 1:
            return false
        i = 1
    while i < s_len:
        if _digit(s.slice(i, i + 1)) < 0:
            return false
        i = i + 1
    return true

fn _digit(ch: text) -> i64:
    if ch == "0": return 0 as i64
    if ch == "1": return 1 as i64
    if ch == "2": return 2 as i64
    if ch == "3": return 3 as i64
    if ch == "4": return 4 as i64
    if ch == "5": return 5 as i64
    if ch == "6": return 6 as i64
    if ch == "7": return 7 as i64
    if ch == "8": return 8 as i64
    if ch == "9": return 9 as i64
    return -1 as i64

fn _find_from(haystack: text, needle: text, start: i64) -> i64:
    if needle == "":
        val haystack_len_empty = haystack.len()
        return if start < haystack_len_empty: start else: haystack_len_empty
    if start < 0:
        return -1
    val needle_len = needle.len()
    val limit = haystack.len() - needle_len
    if limit < start:
        return -1
    var i = start
    while i <= limit:
        if haystack.slice(i, i + needle_len) == needle:
            return i
        i = i + 1
    return -1

use common.window_protocol.window_protocol.{WmInputEvent}
use common.window_protocol.geometry.{WindowId, KeyCode, Modifiers, Point, WmEventType}

fn _parse_wm_input_event(event_json: text) -> WmInputEvent:
    val kind = _json_field(event_json, "kind")
    val key_code_str = _json_field(event_json, "key_code")
    val x_str = _json_field(event_json, "x")
    val y_str = _json_field(event_json, "y")
    val mods_str = _json_field(event_json, "modifiers")
    val key_code_val: i32 = if key_code_str == "": 0 else: key_code_str.parse_i32()
    val x_val: i32 = if x_str == "": 0 else: x_str.parse_i32()
    val y_val: i32 = if y_str == "": 0 else: y_str.parse_i32()
    val mods_val: i32 = if mods_str == "": 0 else: mods_str.parse_i32()
    val event_type = match kind:
        "KeyDown" | "key_down": WmEventType(value: 1)
        "KeyUp" | "key_up": WmEventType(value: 2)
        "MouseMove" | "pointer_move": WmEventType(value: 3)
        "MouseDown" | "pointer_down": WmEventType(value: 4)
        "MouseUp" | "pointer_up": WmEventType(value: 5)
        "wheel": WmEventType(value: 3)
        _: WmEventType(value: 1)
    return WmInputEvent(
        window_id: WindowId(value: 0u64),
        event_type: event_type,
        key_code: KeyCode(value: key_code_val),
        mouse_pos: Point.xy(x_val, y_val),
        modifiers: Modifiers(value: mods_val as u32)
    )
