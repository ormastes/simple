# Persistent shared web render cache helpers.

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

use std.crypto.sha256.{sha256_text}
use std.common.ui.web_render_api.{
    WebRenderArtifact,
    WebRenderOptimizationProfile,
    WebRenderRequest,
    web_render_cache_key,
    web_render_full_html,
    web_render_ipc_json_with_html,
    web_render_optimization_profile,
    web_render_to_artifact,
    WEB_RENDER_TARGET_ELECTRON,
    WEB_RENDER_TARGET_TAURI
}

class WebRenderCacheResult:
    artifact: WebRenderArtifact
    profile: WebRenderOptimizationProfile
    cache_hit: bool
    cache_stored: bool
    cache_path: text

class WebRenderStaticShellBinaryArtifact:
    schema: text
    cache_key: text
    cache_key_digest: text
    encoded: text
    encoded_bytes: i32
    html_bytes: i32
    css_bytes: i32
    js_bytes: i32
    command_count: i32
    cacheable: bool

class WebRenderStaticShellBinaryDecoded:
    valid: bool
    schema: text
    cache_key_digest: text
    viewport: text
    html_bytes: i32
    css_bytes: i32
    js_bytes: i32
    dynamic_region_count: i32
    command_count: i32
    render_plan: text

class WebRenderPreparedStaticShellArtifact:
    artifact: WebRenderArtifact
    profile: WebRenderOptimizationProfile
    decoded: WebRenderStaticShellBinaryDecoded
    valid: bool
    hits: i32

    static fn prepare(req: WebRenderRequest, encoded: text) -> WebRenderPreparedStaticShellArtifact:
        val profile = web_render_optimization_profile(req)
        val decoded = web_render_static_shell_binary_decode(encoded)
        val valid = web_render_static_shell_binary_decoded_matches_request(decoded, req)
        val artifact = if valid:
            _artifact_with_html(req, web_render_full_html(req))
        else:
            web_render_to_artifact(req)
        WebRenderPreparedStaticShellArtifact(
            artifact: artifact,
            profile: profile,
            decoded: decoded,
            valid: valid,
            hits: 0
        )

    me cached_result() -> WebRenderCacheResult:
        if self.valid:
            self.hits = self.hits + 1
            return WebRenderCacheResult(
                artifact: self.artifact,
                profile: self.profile,
                cache_hit: true,
                cache_stored: false,
                cache_path: "swbc:prepared"
            )
        WebRenderCacheResult(
            artifact: self.artifact,
            profile: self.profile,
            cache_hit: false,
            cache_stored: false,
            cache_path: "swbc-invalid"
        )

class WebRenderStaticArtifactCache:
    cache_dir: text
    memory_key: text
    memory_html: text
    memory_hits: i32
    disk_hits: i32
    stores: i32

    static fn create(cache_dir: text) -> WebRenderStaticArtifactCache:
        WebRenderStaticArtifactCache(
            cache_dir: cache_dir,
            memory_key: "",
            memory_html: "",
            memory_hits: 0,
            disk_hits: 0,
            stores: 0
        )

    me artifact(req: WebRenderRequest) -> WebRenderCacheResult:
        val profile = web_render_optimization_profile(req)
        val key = profile.cache_key

        if not profile.cacheable_static_shell:
            return WebRenderCacheResult(
                artifact: web_render_to_artifact(req),
                profile: profile,
                cache_hit: false,
                cache_stored: false,
                cache_path: ""
            )

        if self.memory_key == key and self.memory_html != "":
            self.memory_hits = self.memory_hits + 1
            return WebRenderCacheResult(
                artifact: _artifact_with_html(req, self.memory_html),
                profile: profile,
                cache_hit: true,
                cache_stored: false,
                cache_path: "memory"
            )

        val disk = web_render_cached_static_artifact(self.cache_dir, req)
        if disk.cache_hit:
            self.memory_key = key
            self.memory_html = disk.artifact.html
            self.disk_hits = self.disk_hits + 1
        elif disk.cache_stored:
            self.memory_key = key
            self.memory_html = disk.artifact.html
            self.stores = self.stores + 1
        disk

fn _web_render_cache_file(cache_dir: text, req: WebRenderRequest) -> text:
    val digest = sha256_text(web_render_cache_key(req))
    cache_dir + "/" + digest + ".html"

fn _web_render_binary_cache_file(cache_dir: text, req: WebRenderRequest) -> text:
    val digest = sha256_text(web_render_cache_key(req))
    cache_dir + "/" + digest + ".swbc"

fn web_render_cache_path(cache_dir: text, req: WebRenderRequest) -> text:
    _web_render_cache_file(cache_dir, req)

fn web_render_binary_cache_path(cache_dir: text, req: WebRenderRequest) -> text:
    _web_render_binary_cache_file(cache_dir, req)

fn _web_render_count_tag(html: text, tag: text) -> i32:
    var count = 0
    var offset = 0i64
    val marker = "<" + tag
    while offset < html.len():
        val tail = html.substring(offset, html.len())
        val found = tail.index_of(marker)
        if found < 0:
            return count
        count = count + 1
        offset = offset + found + marker.len()
    count

fn _web_render_static_shell_command_count(req: WebRenderRequest) -> i32:
    1 +
    _web_render_count_tag(req.body_html, "main") +
    _web_render_count_tag(req.body_html, "section") +
    _web_render_count_tag(req.body_html, "div") +
    _web_render_count_tag(req.body_html, "button") +
    _web_render_count_tag(req.body_html, "p") +
    _web_render_count_tag(req.body_html, "h1") +
    _web_render_count_tag(req.body_html, "h2") +
    _web_render_count_tag(req.body_html, "h3")

fn _swbc_field(encoded: text, name: text) -> text:
    val marker = name + "="
    for part in encoded.split("|"):
        if part.starts_with(marker):
            return part.substring(marker.len(), part.len())
    ""

fn _swbc_i32(encoded: text, name: text) -> i32:
    val value = _swbc_field(encoded, name)
    if value == "":
        return 0
    value.to_int() ?? 0

fn web_render_static_shell_binary_artifact(req: WebRenderRequest) -> WebRenderStaticShellBinaryArtifact:
    val profile = web_render_optimization_profile(req)
    val command_count = _web_render_static_shell_command_count(req)
    val digest = sha256_text(profile.cache_key)
    val encoded = "SWBC1|" +
        "key=" + digest +
        "|viewport=" + str(req.viewport_w) + "x" + str(req.viewport_h) +
        "|html=" + str(web_render_full_html(req).len()) +
        "|css=" + str(req.css.len()) +
        "|js=" + str(req.js.len()) +
        "|dyn=" + str(profile.dynamic_region_count) +
        "|cmd=" + str(command_count) +
        "|plan=" + profile.render_plan
    WebRenderStaticShellBinaryArtifact(
        schema: "SWBC1",
        cache_key: profile.cache_key,
        cache_key_digest: digest,
        encoded: encoded,
        encoded_bytes: encoded.len(),
        html_bytes: web_render_full_html(req).len(),
        css_bytes: req.css.len(),
        js_bytes: req.js.len(),
        command_count: command_count,
        cacheable: profile.cacheable_static_shell
    )

fn web_render_static_shell_binary_decode(encoded: text) -> WebRenderStaticShellBinaryDecoded:
    val valid = encoded.starts_with("SWBC1|")
    WebRenderStaticShellBinaryDecoded(
        valid: valid,
        schema: if valid: "SWBC1" else: "",
        cache_key_digest: _swbc_field(encoded, "key"),
        viewport: _swbc_field(encoded, "viewport"),
        html_bytes: _swbc_i32(encoded, "html"),
        css_bytes: _swbc_i32(encoded, "css"),
        js_bytes: _swbc_i32(encoded, "js"),
        dynamic_region_count: _swbc_i32(encoded, "dyn"),
        command_count: _swbc_i32(encoded, "cmd"),
        render_plan: _swbc_field(encoded, "plan")
    )

fn web_render_static_shell_binary_matches_request(encoded: text, req: WebRenderRequest) -> bool:
    val decoded = web_render_static_shell_binary_decode(encoded)
    web_render_static_shell_binary_decoded_matches_request(decoded, req)

fn web_render_static_shell_binary_decoded_matches_request(decoded: WebRenderStaticShellBinaryDecoded, req: WebRenderRequest) -> bool:
    if not decoded.valid:
        return false
    decoded.cache_key_digest == sha256_text(web_render_cache_key(req)) and
    decoded.viewport == str(req.viewport_w) + "x" + str(req.viewport_h) and
    decoded.dynamic_region_count == 0

fn web_render_static_shell_binary_to_artifact(req: WebRenderRequest, encoded: text) -> WebRenderCacheResult:
    val profile = web_render_optimization_profile(req)
    val decoded = web_render_static_shell_binary_decode(encoded)
    if not web_render_static_shell_binary_decoded_matches_request(decoded, req):
        return WebRenderCacheResult(
            artifact: web_render_to_artifact(req),
            profile: profile,
            cache_hit: false,
            cache_stored: false,
            cache_path: "swbc-miss"
        )
    WebRenderCacheResult(
        artifact: _artifact_with_html(req, web_render_full_html(req)),
        profile: profile,
        cache_hit: true,
        cache_stored: false,
        cache_path: "swbc:" + decoded.schema
    )

fn _artifact_with_html(req: WebRenderRequest, html: text) -> WebRenderArtifact:
    val ipc = if req.target == WEB_RENDER_TARGET_ELECTRON or req.target == WEB_RENDER_TARGET_TAURI:
        web_render_ipc_json_with_html(req, html)
    else:
        ""
    WebRenderArtifact(
        target: req.target,
        html: html,
        ipc_json: ipc,
        pixels: [],
        viewport_w: req.viewport_w,
        viewport_h: req.viewport_h,
        capability_summary: ""
    )

fn web_render_static_cache_lookup_html(cache_dir: text, req: WebRenderRequest) -> text:
    val profile = web_render_optimization_profile(req)
    if not profile.cacheable_static_shell:
        return ""
    val path = _web_render_cache_file(cache_dir, req)
    if not rt_file_exists(path):
        return ""
    rt_file_read_text(path) ?? ""

fn web_render_static_cache_store_html(cache_dir: text, req: WebRenderRequest, html: text) -> bool:
    val profile = web_render_optimization_profile(req)
    if not profile.cacheable_static_shell:
        return false
    if not rt_dir_create_all(cache_dir):
        return false
    val html_ok = rt_file_write_text(_web_render_cache_file(cache_dir, req), html)
    val binary = web_render_static_shell_binary_artifact(req)
    val binary_ok = rt_file_write_text(_web_render_binary_cache_file(cache_dir, req), binary.encoded)
    html_ok and binary_ok

fn web_render_cached_static_artifact(cache_dir: text, req: WebRenderRequest) -> WebRenderCacheResult:
    val profile = web_render_optimization_profile(req)
    val path = _web_render_cache_file(cache_dir, req)

    if not profile.cacheable_static_shell:
        return WebRenderCacheResult(
            artifact: web_render_to_artifact(req),
            profile: profile,
            cache_hit: false,
            cache_stored: false,
            cache_path: path
        )

    if rt_file_exists(path):
        val cached_html = rt_file_read_text(path) ?? ""
        if cached_html != "":
            return WebRenderCacheResult(
                artifact: _artifact_with_html(req, cached_html),
                profile: profile,
                cache_hit: true,
                cache_stored: false,
                cache_path: path
            )

    val html = web_render_full_html(req)
    val stored = web_render_static_cache_store_html(cache_dir, req, html)
    WebRenderCacheResult(
        artifact: _artifact_with_html(req, html),
        profile: profile,
        cache_hit: false,
        cache_stored: stored,
        cache_path: path
    )
