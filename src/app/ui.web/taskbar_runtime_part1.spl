fn host_taskbar_runtime_close(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    if ui_surface_kind_is_native_host(binding.surface_kind):
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "close_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
        session.clear_window_surface_binding(surface_id)
        return Ok(())
    val handle = session.surface_handle(surface_id)
    if handle != nil:
        val _ = session.close_surface(handle)
    else:
        session.clear_window_surface_binding(surface_id)
    return Ok(())

fn host_taskbar_runtime_sync_close(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    val handle = session.surface_handle(surface_id)
    if handle != nil:
        val _ = session.close_surface(handle)
    else:
        session.clear_window_surface_binding(surface_id)
    return Ok(())

fn host_taskbar_runtime_move(session: UISession, surface_id: text, x: i32, y: i32) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not ui_surface_kind_is_native_host(binding.surface_kind):
        return Err("surface is not native")
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "move_native_window",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: binding.title,
        url: "",
        x: x,
        y: y,
        width: 0,
        height: 0
    ))
    return Ok(())

fn host_taskbar_runtime_sync_move(session: UISession, surface_id: text, x: i32, y: i32) -> Result<Unit, text>:
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    val tree = session.get_surface(surface_id)
    if tree != nil:
        val root_id = tree.root_node().id
        val _ = session.set_surface_widget_prop(surface_id, root_id, "x", "{x}")
        val _ = session.set_surface_widget_prop(surface_id, root_id, "y", "{y}")
    return Ok(())

