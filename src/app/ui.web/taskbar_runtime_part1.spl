# Part 1 of src/app/ui.web/taskbar_runtime.spl
use app.ui.web.taskbar_runtime.*
# Host Taskbar Runtime — authoritative taskbar + launch/runtime state
#
# Supports host shell modes:
#   * embedded:        taskbar + in-shell SimpleWeb surfaces
#   * native:          taskbar shell + native Electron BrowserWindows
#   * hidden_taskbar:  native Electron BrowserWindows with Simple taskbar hidden
#   * headless:        no local shell window; remote UI still gets taskbar state
#
# Legacy names `desktop_embedded` and `taskbar_only` remain accepted.

use common.ui.session.{UISession}
use common.ui.window_surface_registry.{UiWindowSurfaceBinding, UI_SURFACE_KIND_SIMPLE_WEB, UI_SURFACE_KIND_ELECTRON, UI_SURFACE_KIND_HEADLESS, ui_surface_kind_is_native_host}
use common.ui.taskbar_model.{AppRef, TrayItem, TaskbarLaunchError}
use common.ui.builder.{column, label, button, build_tree_with_title, with_width, with_height, with_visible}
use app.ui.web.taskbar_shell.{build_taskbar_model_with_minimized, taskbar_model_to_json_with_launch_errors}
use app.ui.web.host_adapter_contract.{HostWindowCommand, host_window_command_to_json}
use app.ui.web.wire.{make_wire_frame}
use app.ui.web.taskbar_demo_app.{hello_html, hello_title, hello_size_width, hello_size_height}
use app.ui.web.taskbar_demo_app.{APP_ID, DISPLAY_NAME, ICON, resolve_for_local_host}
use os.desktop.app_manifest.{AppManifest, AppHostContent, UiBackendKind, default_manifests, host_caps_host, host_content_for_manifest, resolve_backend}

struct HostTaskbarApp:
    app_id: text
    display_name: text
    icon: text
    description: text
    title: text
    width: i32
    height: i32
    native_html: text

struct HostTaskbarAdapterCapabilities:
    supports_native_windows: bool
    supports_embedded_surfaces: bool
    supports_headless_session: bool
    requires_js_host_bridge: bool

enum HostShellMode:
    DesktopEmbedded
    TaskbarOnly
    Embedded
    Native
    HiddenTaskbar
    Headless

class HostTaskbarRuntime:
    enabled: bool
    mode: HostShellMode
    electron_available: bool
    next_window_ordinal: i64
    next_process_id: u64
    adapter_capabilities: HostTaskbarAdapterCapabilities
    pinned: [AppRef]
    tray: [TrayItem]
    minimized_surface_ids: [text]
    launch_errors: [TaskbarLaunchError]
    pending_commands: [HostWindowCommand]

    static fn new() -> HostTaskbarRuntime:
        HostTaskbarRuntime(
            enabled: false,
            mode: HostShellMode.Embedded,
            electron_available: false,
            next_window_ordinal: 0,
            next_process_id: 1000u64,
            adapter_capabilities: _adapter_capabilities_for(HostShellMode.Embedded, false),
            pinned: _default_pinned(),
            tray: _default_tray(),
            minimized_surface_ids: [],
            launch_errors: [],
            pending_commands: []
        )

var _host_taskbar_runtime: HostTaskbarRuntime? = nil
var _persisted_pinned: [AppRef]? = nil
var _persisted_tray: [TrayItem]? = nil
var _persisted_layout_corrupt: bool = false

fn host_taskbar_runtime_reset():
    _host_taskbar_runtime = Some(HostTaskbarRuntime.new())

fn host_taskbar_runtime_save_layout(pinned: [AppRef], tray: [TrayItem]) -> Result<Unit, text>:
    if _layout_has_duplicate_apps(pinned):
        return Err("persisted taskbar layout has duplicate app ids")
    if _layout_has_duplicate_tray_items(tray):
        return Err("persisted taskbar layout has duplicate tray item ids")
    _persisted_pinned = Some(pinned)
    _persisted_tray = Some(tray)
    _persisted_layout_corrupt = false
    Ok(())

fn host_taskbar_runtime_clear_persisted_layout():
    _persisted_pinned = nil
    _persisted_tray = nil
    _persisted_layout_corrupt = false

fn host_taskbar_runtime_mark_persisted_layout_corrupt_for_test():
    _persisted_layout_corrupt = true

fn host_taskbar_runtime_enable(mode_name: text, electron_available: bool):
    val rt = _get_host_taskbar_runtime()
    rt.enabled = true
    rt.mode = _parse_mode(mode_name)
    rt.electron_available = electron_available
    rt.adapter_capabilities = _adapter_capabilities_for(rt.mode, electron_available)
    rt.next_window_ordinal = 0
    rt.next_process_id = 1000u64
    rt.minimized_surface_ids = []
    rt.launch_errors = []
    rt.pending_commands = []

fn host_taskbar_runtime_is_enabled() -> bool:
    val rt = _get_host_taskbar_runtime()
    rt.enabled

fn host_taskbar_runtime_mode_name() -> text:
    val rt = _get_host_taskbar_runtime()
    _mode_name(rt.mode)

fn host_taskbar_runtime_hides_desktop() -> bool:
    val rt = _get_host_taskbar_runtime()
    _mode_hides_embedded_desktop(rt.mode)

fn host_taskbar_runtime_hides_taskbar() -> bool:
    val rt = _get_host_taskbar_runtime()
    _mode_hides_taskbar(rt.mode)

fn host_taskbar_runtime_adapter_capabilities() -> HostTaskbarAdapterCapabilities:
    val rt = _get_host_taskbar_runtime()
    rt.adapter_capabilities

fn host_taskbar_runtime_taskbar_frame(session_id: text, session: UISession) -> text:
    val rt = _get_host_taskbar_runtime()
    val model = build_taskbar_model_with_minimized(
        session.window_surfaces,
        rt.pinned,
        rt.tray,
        rt.minimized_surface_ids
    )
    val payload = taskbar_model_to_json_with_launch_errors(model, rt.launch_errors)
    make_wire_frame("taskbar_model", session_id, "null", payload)

fn host_taskbar_runtime_take_client_frames(session_id: text) -> [text]:
    val rt = _get_host_taskbar_runtime()
    var frames: [text] = []
    for cmd in rt.pending_commands:
        val payload = host_window_command_to_json(cmd)
        frames = frames.push(make_wire_frame("host_window_command", session_id, "null", payload))
    rt.pending_commands = []
    frames

fn host_taskbar_runtime_native_window_html(app_id: text) -> text?:
    val app = _find_app(app_id)
    if app != nil:
        return app.native_html
    return nil

fn host_taskbar_runtime_catalog() -> [HostTaskbarApp]:
    var apps: [HostTaskbarApp] = [_hello_catalog_app()]
    for manifest in default_manifests():
        if _find_app_in(apps, manifest.binary) == nil:
            apps = apps.push(_manifest_catalog_app(manifest))
    apps

fn host_taskbar_runtime_launch(session: UISession, app_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    if not rt.enabled:
        return _record_launch_error(rt, app_id, "host taskbar runtime not enabled")
    val app = _find_app(app_id)
    if app == nil:
        return _record_launch_error(rt, app_id, "unknown pinned app: {app_id}")
    val title = app.title
    val width = app.width
    val height = app.height

    rt.next_window_ordinal = rt.next_window_ordinal + 1
    rt.next_process_id = rt.next_process_id + 1u64
    val ordinal = rt.next_window_ordinal
    val process_id = rt.next_process_id
    val surface_id = "host-surface-{ordinal}"
    val window_id = "host-window-{ordinal}"

    if rt.adapter_capabilities.supports_headless_session:
        _clear_launch_errors(rt)
        session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_HEADLESS)
        return Ok(())

    val resolved_backend = _resolve_app_backend(app_id, rt.electron_available)
    val backend = match resolved_backend:
        Err(e):
            return _record_launch_error(rt, app_id, e)
        Ok(kind):
            kind

    if _mode_is_taskbar_only(rt.mode) and not rt.adapter_capabilities.supports_native_windows:
        return _record_launch_error(rt, app_id, "taskbar-only mode requires a native-window capable host adapter")

    if _mode_is_taskbar_only(rt.mode) and _backend_is_native_host(backend):
        _clear_launch_errors(rt)
        session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_ELECTRON)
        session.set_active_surface(surface_id)
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "spawn_native_window",
            window_id: window_id,
            surface_id: surface_id,
            app_id: app_id,
            title: title,
            url: _native_window_url(app_id, surface_id, window_id),
            x: 0,
            y: 0,
            width: width,
            height: height
        ))
        return Ok(())

    _clear_launch_errors(rt)
    val _ = session.open_surface(surface_id, _build_app_tree(surface_id, title, width, height, true))
    session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_SIMPLE_WEB)
    session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_focus(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    if ui_surface_kind_is_native_host(binding.surface_kind):
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "focus_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
    else:
        _set_surface_visible(session, surface_id, true)
        session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_sync_focus(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
    session.set_active_surface(surface_id)
    return Ok(())

fn host_taskbar_runtime_minimize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not _contains_text(rt.minimized_surface_ids, surface_id):
        rt.minimized_surface_ids = rt.minimized_surface_ids.push(surface_id)
    if ui_surface_kind_is_native_host(binding.surface_kind):
        rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
            action: "minimize_native_window",
            window_id: binding.window_id,
            surface_id: surface_id,
            app_id: binding.app_id,
            title: binding.title,
            url: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        ))
    else:
        _set_surface_visible(session, surface_id, false)
    return Ok(())

fn host_taskbar_runtime_sync_minimize(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not _contains_text(rt.minimized_surface_ids, surface_id):
        rt.minimized_surface_ids = rt.minimized_surface_ids.push(surface_id)
    return Ok(())

