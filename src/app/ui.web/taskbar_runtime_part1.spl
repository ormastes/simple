fn host_taskbar_runtime_sync_restore(session: UISession, surface_id: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    rt.minimized_surface_ids = _remove_text(rt.minimized_surface_ids, surface_id)
