fn host_taskbar_runtime_set_title(session: UISession, surface_id: text, title: text) -> Result<Unit, text>:
    val rt = _get_host_taskbar_runtime()
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    if not ui_surface_kind_is_native_host(binding.surface_kind):
        return Err("surface is not native")
    val _ = session.update_window_surface_title(surface_id, title)
    rt.pending_commands = rt.pending_commands.push(HostWindowCommand(
        action: "set_native_window_title",
        window_id: binding.window_id,
        surface_id: surface_id,
        app_id: binding.app_id,
        title: title,
        url: "",
        x: 0,
        y: 0,
        width: 0,
        height: 0
    ))
    return Ok(())

fn host_taskbar_runtime_sync_set_title(session: UISession, surface_id: text, title: text) -> Result<Unit, text>:
    val binding: UiWindowSurfaceBinding? = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        return Err("unknown surface")
    val _ = session.update_window_surface_title(surface_id, title)
    return Ok(())

fn _get_host_taskbar_runtime() -> HostTaskbarRuntime:
    if not _host_taskbar_runtime.?:
        _host_taskbar_runtime = Some(HostTaskbarRuntime.new())
    _host_taskbar_runtime.unwrap()

fn _default_pinned() -> [AppRef]:
    val persisted = _load_persisted_pinned()
    if persisted != nil:
        return persisted.unwrap()
    var pinned: [AppRef] = []
    for app in host_taskbar_runtime_catalog():
        pinned = pinned.push(AppRef(
            app_id: app.app_id,
            display_name: app.display_name,
            icon: app.icon
        ))
    pinned

fn _load_persisted_pinned() -> [AppRef]?:
    if _persisted_layout_corrupt:
        return nil
    if _persisted_pinned != nil:
        return _persisted_pinned
    return nil

fn _load_persisted_tray() -> [TrayItem]?:
    if _persisted_layout_corrupt:
        return nil
    if _persisted_tray != nil:
        return _persisted_tray
    return nil

fn _find_app(app_id: text) -> HostTaskbarApp?:
    _find_app_in(host_taskbar_runtime_catalog(), app_id)

fn _find_app_in(apps: [HostTaskbarApp], app_id: text) -> HostTaskbarApp?:
    for app in apps:
        if app.app_id == app_id:
            return app
    return nil

fn _hello_catalog_app() -> HostTaskbarApp:
    HostTaskbarApp(
        app_id: APP_ID,
        display_name: DISPLAY_NAME,
        icon: ICON,
        description: "Host taskbar runtime demo",
        title: hello_title(),
        width: hello_size_width(),
        height: hello_size_height(),
        native_html: hello_html()
    )

fn _manifest_catalog_app(manifest: AppManifest) -> HostTaskbarApp:
    val title = manifest.name
    HostTaskbarApp(
        app_id: manifest.binary,
        display_name: manifest.name,
        icon: manifest.icon,
        description: manifest.description,
        title: title,
        width: 640,
        height: 420,
        native_html: _manifest_host_html(manifest)
    )

fn _resolve_app_backend(app_id: text, electron_available: bool) -> Result<UiBackendKind, text>:
    if app_id == APP_ID:
        return resolve_for_local_host(electron_available)
    val resolved = resolve_backend(UiBackendKind.Auto, host_caps_host(electron_available))
    match resolved:
        Ok(kind): Ok(kind)
        Err(_): Err("Electron not available on this host")

fn _backend_is_native_host(kind: UiBackendKind) -> bool:
    match kind:
        UiBackendKind.Electron: true
        _: false

fn _adapter_capabilities_for(mode: HostShellMode, electron_available: bool) -> HostTaskbarAdapterCapabilities:
    HostTaskbarAdapterCapabilities(
        supports_native_windows: electron_available and _mode_uses_native_windows(mode),
        supports_embedded_surfaces: _mode_uses_embedded_surfaces(mode),
        supports_headless_session: _mode_is_headless(mode),
        requires_js_host_bridge: not _mode_is_headless(mode)
    )

fn _record_launch_error(rt: HostTaskbarRuntime, app_id: text, message: text) -> Result<Unit, text>:
    rt.launch_errors = [TaskbarLaunchError(app_id: app_id, message: message)]
    Err(message)

fn _clear_launch_errors(rt: HostTaskbarRuntime):
    rt.launch_errors = []

fn _manifest_host_html(manifest: AppManifest) -> text:
    val content = host_content_for_manifest(manifest)
    if content != nil:
        return _manifest_host_content_html(manifest, content.unwrap())
    return _unsupported_manifest_html(manifest)

fn _manifest_host_content_html(manifest: AppManifest, content: AppHostContent) -> text:
    val title = _html_escape(content.title)
    val body = _html_escape(content.body)
    val status = _html_escape(content.status)
    val category = _html_escape(manifest.category)
    "<!doctype html>" +
    "<html><head><meta charset='utf-8'>" +
    "<title>{title}</title>" +
    "<style>" +
    "body { margin: 0; min-height: 100vh; padding: 28px; background: #101724; color: #f3f0dc; font-family: system-ui, sans-serif; }" +
    "h1 { margin: 0 0 10px 0; font-size: 28px; }" +
    "p { margin: 8px 0; font-size: 15px; line-height: 1.45; }" +
    ".status { margin-top: 14px; color: #9fc5ff; }" +
    "</style></head><body>" +
    "<h1>{title}</h1>" +
    "<p>{body}</p>" +
    "<p class='status'>{category} - {status}</p>" +
    "</body></html>"
