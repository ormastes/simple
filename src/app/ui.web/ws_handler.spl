# WebSocket Handler
#
# Handles WebSocket upgrade handshake and message processing
# for the web UI renderer.

use std.nogc_sync_mut.io.tcp.{TcpStream}
use common.ui.widget.{UIState, UIEvent}
use common.string_core.{char_from_code}
use app.ui.render.widgets.{render_html_tree}
use app.ui.ipc.protocol.{build_ipc_open_window}
# Use runtime SHA-1/base64 directly to avoid as_bytes() interpreter limitation
extern fn rt_sha1_new() -> i64
extern fn rt_sha1_write(handle: i64, data: text) -> i64
extern fn rt_sha1_finish_base64(handle: i64) -> text
extern fn rt_sha1_free(handle: i64)

# =========================================================================
# WebSocket Upgrade
# =========================================================================

val WS_MAGIC: text = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"

fn is_ws_upgrade_request(headers: text) -> bool:
    return headers.contains("Upgrade: websocket")

fn handle_ws_upgrade(stream: TcpStream, headers: text, state: UIState):
    """Handle WebSocket upgrade handshake and enter message loop."""
    # Extract Sec-WebSocket-Key from headers
    val key = extract_ws_key(headers)
    if key == "":
        return

    # Compute accept hash
    val accept = compute_ws_accept(key)

    # Send upgrade response
    var response = "HTTP/1.1 101 Switching Protocols\r\n"
    response = "{response}Upgrade: websocket\r\n"
    response = "{response}Connection: Upgrade\r\n"
    response = "{response}Sec-WebSocket-Accept: {accept}\r\n"
    response = "{response}\r\n"
    stream.write_text(response)

    # Send initial render
    val html = render_html_tree(state.tree.root_node(), state)
    val msg = "{\"type\": \"render\", \"html\": \"{escape_json_string(html)}\"}"
    send_ws_text(stream, msg)

fn extract_ws_key(headers: text) -> text:
    """Extract the Sec-WebSocket-Key from headers."""
    val lines = headers.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("Sec-WebSocket-Key:"):
            val key = trimmed[18:]
            return key.trim()
    return ""

fn compute_ws_accept(key: text) -> text:
    """Compute the Sec-WebSocket-Accept value.
    WebSocket spec requires: base64(SHA-1(key + magic)).
    Uses runtime functions directly to avoid as_bytes() interpreter limitation."""
    val combined = key + WS_MAGIC
    val handle = rt_sha1_new()
    rt_sha1_write(handle, combined)
    val result = rt_sha1_finish_base64(handle)
    rt_sha1_free(handle)
    return result

# =========================================================================
# WebSocket Frame Operations
# =========================================================================

fn send_ws_text(stream: TcpStream, message: text):
    """Send a text frame over WebSocket."""
    val len = message.len()

    # Build frame header
    var header = ""
    # Opcode 0x81 = final frame + text
    header = "{header}\u{0081}"

    if len < 126:
        header = "{header}{chr(len)}"
    elif len < 65536:
        header = "{header}\u{007e}"
        header = "{header}{chr(len / 256)}"
        header = "{header}{chr(len - ((len / 256) * 256))}"

    stream.write_text("{header}{message}")

fn escape_json_string(s: text) -> text:
    """Escape a string for JSON embedding."""
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        match ch:
            "\"":
                result = "{result}\\\""
            "\\":
                result = "{result}\\\\"
            "\n":
                result = "{result}\\n"
            "\r":
                result = "{result}\\r"
            "\t":
                result = "{result}\\t"
            _:
                result = "{result}{ch}"
        i = i + 1
    return result

fn chr(code: i32) -> text:
    """Convert integer byte code to single character for WebSocket framing."""
    return char_from_code(code as i64)

# =========================================================================
# Window Manager WebSocket Handler
# =========================================================================

fn _build_wm_app_html(title: text, content: text) -> text:
    """Build HTML for a WM app window using glass-theme CSS classes.
    Class definitions live in html.spl::generate_css() (.wm-app-container,
    .wm-app-titlebar, .wm-app-content) so the Web WM uses the centralized
    glass token palette instead of inline hex literals."""
    var h = "<div class=\"wm-app-container\">"
    h = h + "<div class=\"wm-app-titlebar\">"
    h = h + title + "</div>"
    h = h + "<div class=\"wm-app-content\">"
    h = h + content + "</div></div>"
    return h

fn handle_ws_wm_upgrade(stream: TcpStream, headers: text, state: UIState):
    """Handle WebSocket upgrade and send multiple openWindow messages for the WM desktop."""
    val key = extract_ws_key(headers)
    if key == "":
        return

    val accept = compute_ws_accept(key)

    var response = "HTTP/1.1 101 Switching Protocols\r\n"
    response = response + "Upgrade: websocket\r\n"
    response = response + "Connection: Upgrade\r\n"
    response = response + "Sec-WebSocket-Accept: " + accept + "\r\n"
    response = response + "\r\n"
    stream.write_text(response)

    # Send openWindow messages for each app window
    val t1 = _build_wm_app_html("TERMINAL", "$ simple --version\nSimple Language v0.9.5\n\n$ _")
    send_ws_text(stream, build_ipc_open_window("terminal", "Terminal", t1, 50, 60, 600, 400))

    val t2 = _build_wm_app_html("EDITOR", "# hello.spl\n\nfn main() -> i64:\n    print \"Hello, World!\"\n    return 0")
    send_ws_text(stream, build_ipc_open_window("editor", "Editor", t2, 300, 120, 700, 500))

    val t3 = _build_wm_app_html("BROWSER", "Simple Language Documentation\n\nA modern systems programming language\nwith a focus on simplicity and safety.")
    send_ws_text(stream, build_ipc_open_window("browser", "Browser", t3, 500, 80, 650, 450))

    val t4 = _build_wm_app_html("FILE MANAGER", "src/\n  compiler/\n  lib/\n  app/\nexamples/\n  ui/\n  simple_os/")
    send_ws_text(stream, build_ipc_open_window("files", "File Manager", t4, 150, 200, 550, 350))
