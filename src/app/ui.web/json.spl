# Web UI JSON serialization helpers.

use common.ui.widget.{UIState}
use common.text_advanced.{escape_json}

fn state_to_json(state: UIState) -> text:
    var json = "{"
    json = "{json}\"mode\": \"{state.mode_name()}\","
    json = "{json}\"focused_id\": \"{state.focused_id}\","
    json = "{json}\"title\": \"{state.tree.title_text()}\","
    json = "{json}\"theme\": \"{state.tree.theme_name()}\""
    json = "{json}}"
    return json

fn widgets_to_json(state: UIState) -> text:
    val ids = state.tree.all_widget_ids()
    var items = ""
    var first = true
    for id in ids:
        val widget = state.tree.find_widget(id)
        if widget != nil:
            val sep = if first: "" else: ","
            first = false
            val summary = escape_json(widget.widget_summary())
            val eid = escape_json(id)
            items = "{items}{sep}{\"id\": \"{eid}\", \"summary\": \"{summary}\"}"
    return "[{items}]"
