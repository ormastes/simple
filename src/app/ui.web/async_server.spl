# Async Web Server
#
# Concurrent HTTP server with WebSocket push updates.
# Uses threads + channels to accept multiple connections,
# process UI events, watch file changes, and broadcast renders.

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.nogc_async_mut.concurrent.channel.{Channel, channel_new}
use std.nogc_async_mut.concurrent.thread.{thread_spawn, thread_spawn2, thread_sleep, ThreadHandle}
use common.ui.widget.{UIState, UITree, UIEvent}
use common.ui.parse.sdn.{parse_ui_file}
use common.ui.state.{init_state, update_state, update_tree}
use common.ui.session.{UISession}
use common.ui.event.{process_event}
use app.ui.web.html.{generate_html_page}
use app.ui.web.async_ws.{start_ws_reader, ws_send_render}
use app.ui.web.ws_handler.{extract_ws_key, compute_ws_accept, send_ws_text, escape_json_string}
use app.ui.render.widgets.{render_html_tree}
use app.ui.test_api.handler.{handle_test_request}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# Internal message types sent over the render channel
# =========================================================================

val MSG_TYPE_RENDER: text = "render"

# =========================================================================
# Async Web Server
# =========================================================================

class AsyncWebServer:
    file_path: text
    port: i32
    session: UISession
    event_channel: Channel
    render_channel: Channel
    ws_clients: [TcpStream]
    last_file_content: text
    running: bool

    static fn new(file_path: text, port: i32) -> Result<AsyncWebServer, text>:
        """Create a new async web server by parsing the UI file."""
        val tree_result = parse_ui_file(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                var session = UISession.new(tree)
                session.set_active_backend("web")
                val content = if rt_file_exists(file_path):
                    rt_file_read_text(file_path)
                else:
                    ""
                return Ok(AsyncWebServer(
                    file_path: file_path,
                    port: port,
                    session: session,
                    event_channel: channel_new(),
                    render_channel: channel_new(),
                    ws_clients: [],
                    last_file_content: content,
                    running: true
                ))

    fn start():
        """Start the async web server with concurrent tasks.

        Task 1 (main thread): Accept loop -- spawn handler per connection
        Task 2 (thread): File watcher -- check for file changes periodically
        Task 3 (main thread after accept_timeout): Process events + broadcast
        """
        print "Starting Async UI Web Server on port {self.port}..."
        print "Open http://localhost:{self.port} in your browser"
        print "Supports multiple concurrent connections with live push"
        print "Press Ctrl+C to stop"
        print ""

        match TcpListener.bind("0.0.0.0:{self.port}"):
            Err(e):
                print "Error: Failed to bind to port {self.port}: {e}"
                return
            Ok(listener):
                # Spawn file watcher thread
                val file_path_copy = self.file_path
                val event_ch = self.event_channel
                val watcher = thread_spawn2(file_path_copy, event_ch, \file_path_arg, ch_arg:
                    file_watcher_loop(file_path_arg, ch_arg)
                )

                # Main accept + event processing loop
                self.accept_loop(listener)

                # Cleanup
                self.running = false
                self.event_channel.close()
                self.render_channel.close()
                watcher.free()

    fn accept_loop(listener: TcpListener):
        """Accept connections and process events in interleaved fashion."""
        while self.running:
            # Try to accept a connection with short timeout so we can
            # also process events and broadcast renders between accepts
            match listener.accept_timeout(100):
                Ok(stream):
                    self.handle_connection(stream)
                Err(_):
                    pass_do_nothing

            # Process any pending events from WebSocket clients
            self.process_events()

            # Broadcast render if there are updates pending
            self.flush_render_queue()

    me handle_connection(stream: TcpStream):
        """Handle a single incoming HTTP connection.

        HTTP requests get an HTML page response.
        WebSocket upgrades get added to ws_clients for push updates.
        """
        match stream.read_line():
            Err(e):
                print "Error reading request: {e}"
            Ok(request_line):
                val parts = request_line.split(" ")
                if parts.len() < 2:
                    return

                val path = parts[1]

                # Read remaining headers
                var headers = ""
                var is_ws = false
                loop:
                    match stream.read_line():
                        Ok(header_line):
                            if header_line.trim() == "":
                                break
                            headers = "{headers}{header_line}\n"
                            if header_line.contains("Upgrade: websocket"):
                                is_ws = true
                        Err(_):
                            break

                if is_ws:
                    self.handle_ws_upgrade(stream, headers)
                    return

                # Route test API requests (before normal routing)
                if path.starts_with("/api/test/"):
                    val method = parts[0]
                    var body = ""
                    if method == "POST":
                        body = _read_request_body(stream, headers)
                    val event_ch = self.event_channel
                    val inject_event_fn = \event:
                        event_ch.send(event)
                    val result = handle_test_request(path, method, body, self.session.current_state(), inject_event_fn)
                    val test_response = http_response(result.0, result.1, result.2)
                    stream.write_all(test_response)
                    return

                # Route HTTP requests
                val response = match path:
                    "/":
                        val html = generate_html_page(self.session.current_state(), self.port)
                        http_response(200, "text/html", html)
                    "/api/state":
                        val state_json = async_state_to_json(self.session.current_state())
                        http_response(200, "application/json", state_json)
                    "/api/clients":
                        val clients_json = "{\"connected\": {self.ws_clients.len()}}"
                        http_response(200, "application/json", clients_json)
                    _:
                        http_response(404, "text/plain", "Not Found")

                stream.write_all(response)

    me handle_ws_upgrade(stream: TcpStream, headers: text):
        """Upgrade HTTP connection to WebSocket and register client."""
        val key = extract_ws_key(headers)
        if key == "":
            return

        val accept = compute_ws_accept(key)

        var response = "HTTP/1.1 101 Switching Protocols\r\n"
        response = "{response}Upgrade: websocket\r\n"
        response = "{response}Connection: Upgrade\r\n"
        response = "{response}Sec-WebSocket-Accept: {accept}\r\n"
        response = "{response}\r\n"
        stream.write_all(response)

        # Send initial render to this new client
        val ws_state = self.session.current_state()
        val html = render_html_tree(ws_state.tree.root_node(), ws_state)
        val msg = "{\"type\": \"render\", \"html\": \"{escape_json_string(html)}\"}"
        send_ws_text(stream, msg)

        # Register as a WebSocket client
        self.ws_clients = self.ws_clients + [stream]
        print "WebSocket client connected (total: {self.ws_clients.len()})"

        # Spawn a reader thread for this WebSocket client
        val event_ch = self.event_channel
        val reader = thread_spawn2(stream, event_ch, \ws_stream, ch:
            start_ws_reader(ws_stream, ch)
        )
        reader.free()

    me process_events():
        """Process all pending events from the event channel."""
        var changed = false
        loop:
            val msg = self.event_channel.try_recv()
            if msg == nil:
                break

            # Dispatch events
            val event = msg as UIEvent
            if event != nil:
                match event:
                    UIEvent.FileChanged:
                        self.reload_file()
                        changed = true
                    _:
                        self.session.dispatch(event)
                        changed = true

        if changed:
            self.broadcast_render()

    me reload_file():
        """Reload the UI file from disk."""
        if not rt_file_exists(self.file_path):
            return

        val current_content = rt_file_read_text(self.file_path)
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_file(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.session.update_tree(new_tree)
                Err(e):
                    print "Warning: UI parse error: {e}"

    me broadcast_render():
        """Send current render HTML to all connected WebSocket clients."""
        val bc_state = self.session.current_state()
        val html = render_html_tree(bc_state.tree.root_node(), bc_state)
        val msg = "{\"type\": \"render\", \"html\": \"{escape_json_string(html)}\"}"

        var alive_clients: [TcpStream] = []
        for client in self.ws_clients:
            val ok = ws_send_render(client, msg)
            if ok:
                alive_clients = alive_clients.push(client)

        # Prune disconnected clients
        if alive_clients.len() != self.ws_clients.len():
            print "Pruned {self.ws_clients.len() - alive_clients.len()} disconnected client(s)"
            self.ws_clients = alive_clients

    fn flush_render_queue():
        """Drain render channel messages (from file watcher thread)."""
        loop:
            val msg = self.render_channel.try_recv()
            if msg == nil:
                break
            # File watcher signaled a change; reload handled in process_events

    fn client_count() -> i32:
        """Return current number of connected WebSocket clients."""
        return self.ws_clients.len()

    fn is_running() -> bool:
        """Check if server is running."""
        return self.running

    me stop():
        """Signal the server to stop."""
        self.running = false
        self.event_channel.close()
        self.render_channel.close()

# =========================================================================
# File Watcher (runs in separate thread)
# =========================================================================

fn file_watcher_loop(file_path: Any, event_channel: Any):
    """Periodically check file for changes and push FileChanged events."""
    var last_content = ""
    if rt_file_exists(file_path as text):
        last_content = rt_file_read_text(file_path as text)

    loop:
        thread_sleep(500)

        val path = file_path as text
        if not rt_file_exists(path):
            continue

        val current = rt_file_read_text(path)
        if current != last_content:
            last_content = current
            val ch = event_channel as Channel
            ch.send(UIEvent.FileChanged)

# =========================================================================
# Request Body Helper
# =========================================================================

fn _read_request_body(stream: TcpStream, headers: text) -> text:
    """Read the request body based on Content-Length header."""
    var content_length = 0
    val header_lines = headers.split("\n")
    for line in header_lines:
        val trimmed = line.trim()
        if trimmed.starts_with("Content-Length:"):
            val len_str = trimmed.slice(15, trimmed.len())
            val len_trimmed = len_str.trim()
            content_length = len_trimmed.to_int()
    if content_length <= 0:
        return ""
    match stream.read_exact(content_length):
        Ok(body_data):
            return body_data
        Err(_):
            return ""

# =========================================================================
# HTTP Response Helper
# =========================================================================

fn http_response(status: i32, content_type: text, body: text) -> text:
    val status_text = match status:
        200: "OK"
        404: "Not Found"
        500: "Internal Server Error"
        _: "OK"
    var response = "HTTP/1.1 {status} {status_text}\r\n"
    response = "{response}Content-Type: {content_type}\r\n"
    response = "{response}Content-Length: {body.len()}\r\n"
    response = "{response}Access-Control-Allow-Origin: *\r\n"
    response = "{response}Connection: close\r\n"
    response = "{response}\r\n"
    response = "{response}{body}"
    return response

# =========================================================================
# JSON Serialization
# =========================================================================

fn async_state_to_json(state: UIState) -> text:
    var json = "{"
    json = "{json}\"mode\": \"{state.mode_name()}\","
    json = "{json}\"focused_id\": \"{state.focused_id}\","
    json = "{json}\"title\": \"{state.tree.title_text()}\","
    json = "{json}\"theme\": \"{state.tree.theme_name()}\""
    json = "{json}}"
    return json

# =========================================================================
# Entry Point
# =========================================================================

fn run_async_web(file_path: text, port: i32) -> i64:
    """Start async web server mode for a .ui.sdn file."""
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val server_result = AsyncWebServer.new(file_path, port)
    match server_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(server):
            server.start()
            return 0
