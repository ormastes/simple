# Wire envelope builder for the Web UI protocol.
#
# Shared by taskbar_runtime, ui_routes, and web_runtime_adapter to construct
# the top-level JSON envelope: { t, v, s, seq, payload }.

fn make_wire_frame(msg_type: text, session_id: text, seq: text, payload: text) -> text:
    """Build the top-level wire envelope: { t, v, s, seq, payload }."""
    "{\"t\": \"{msg_type}\", \"v\": 1, \"s\": \"{session_id}\", \"seq\": {seq}, \"payload\": {payload}}"
