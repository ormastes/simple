fn wm_theme_quality_report(theme: text) -> WmThemeQualityReport:
    val css = build_modern_theme_css(theme)
    val js = _read_wm_js_source()
    val html_source = _read_wm_html_source()
    val bg = _css_var(css, "--ui-bg")
    val text_color = _css_var(css, "--ui-text")
    val contrast_delta = _brightness_delta(bg, text_color)
    val contrast_ratio_x100 = _contrast_ratio_x100(bg, text_color)
    val color_checked = bg.starts_with("#") and text_color.starts_with("#") and contrast_delta >= 96 and contrast_ratio_x100 >= 450
    val contrast_preference_media_ready = _has_all(css, ["@media (prefers-contrast: more), (forced-colors: active)", ":root[data-wm-contrast=comfortable]", ":root[data-wm-contrast=high]", "--ui-contrast-policy: os-high", "--ui-glass-opacity-floor-x100: 88", "--ui-window-alpha-x100: 94", "--ui-command-alpha-x100: 94", "--ui-taskbar-alpha-x100: 94", "--ui-widget-alpha-x100: 94"])
    val semantic_tokens = _has_all(css, ["--ui-accent:", "--ui-accent-rgb:", "--ui-bg:", "--ui-panel:", "--ui-border:", "--ui-text:", "--ui-dim:", "--ui-wm-window-radius:", "--ui-corner-window-radius:", "--ui-window-radius: var(--ui-corner-window-radius)", "--ui-widget-radius: var(--ui-corner-widget-radius)", "--ui-taskbar-radius: var(--ui-corner-taskbar-radius)"]) and _has_all(html_source, ["fn build_modern_theme_css", "fn _wm_css", "build_modern_theme_css(theme)"])
    val titlebar_height_px = _first_int_after(css, ".wm-titlebar {", "height:")
    val window_min_width_px = _first_int_after(css, ".wm-window {", "min-width:")
    val window_min_height_px = _first_int_after(css, ".wm-window {", "min-height:")
    val title_input_min_width_px = _first_int_after(css, ".wm-title-input", "min-width:")
    val taskbar_icon_size_px = _first_int_after(css, ".wm-taskbar-icon {", "width:")
    val taskbar_preview_max_width_px = _first_int_after(css, ".wm-taskbar-preview {", "width: min(")
    val top_menu_bar_height_px = _first_int_after(css, ".wm-top-menu-bar {", "min-height:")
    val system_hud_max_width_px = _first_int_after(css, ".wm-system-hud {", "width: min(")
    val privacy_indicator_max_width_px = _first_int_after(css, ".wm-privacy-indicator {", "width: min(")
    val workspace_switcher_max_width_px = _first_int_after(css, ".wm-workspace-switcher {", "width: min(")
    val clipboard_history_max_width_px = _first_int_after(css, ".wm-clipboard-history {", "width: min(")
    val screen_capture_max_width_px = _first_int_after(css, ".wm-screen-capture-overlay {", "width: min(")
    val quick_settings_max_width_px = _first_int_after(css, ".wm-quick-settings {", "width: min(")
    val notification_center_max_width_px = _first_int_after(css, ".wm-notification-center {", "width: min(")
    val live_activity_max_width_px = _first_int_after(css, ".wm-live-activity {", "width: min(")
    val hot_corner_max_size_px = _first_int_after(css, ".wm-hot-corner-zone {", "width:")
    val resize_hud_max_width_px = _first_int_after(css, ".wm-resize-hud {", "width: min(")
    val gesture_hints_max_width_px = _first_int_after(css, ".wm-gesture-hints {", "width: min(")
    val command_palette_max_width_px = _first_int_after(css, ".wm-command-palette {", "width: min(")
    val context_menu_max_width_px = _first_int_after(css, ".wm-window-context-menu {", "width: min(")
    val quality_inspector_max_width_px = _first_int_after(css, ".wm-quality-inspector { position: fixed", "width: min(")
    val control_center_max_width_px = _first_int_after(css, ".wm-control-center {", "width: min(")
    val desktop_widget_max_width_px = _first_int_after(css, ".wm-desktop-widgets {", "width: min(")
    val widget_gallery_max_width_px = _first_int_after(css, ".wm-widget-gallery {", "width: min(")
    val app_launcher_max_width_px = _first_int_after(css, ".wm-app-launcher-grid {", "width: min(")
    val wallpaper_picker_max_width_px = _first_int_after(css, ".wm-wallpaper-picker {", "width: min(")
    val accent_palette_max_width_px = _first_int_after(css, ".wm-accent-palette {", "width: min(")
    val dock_stack_max_width_px = _first_int_after(css, ".wm-dock-stack {", "width: min(")
    val stage_rail_max_width_px = _first_int_after(css, ".wm-stage-rail {", "width: min(")
    val window_switcher_max_width_px = _first_int_after(css, ".wm-window-switcher {", "width: min(")
    val overview_card_min_width_px = _first_int_after(css, ".wm-overview-grid", "minmax(")
    val touch_target_min_height_px = _first_int_after(css, ".wm-command-item {", "min-height:")
    val size_layout_configured = titlebar_height_px >= 38 and window_min_width_px >= 200 and window_min_height_px >= 120 and title_input_min_width_px >= 140 and taskbar_icon_size_px >= 26
    val stable_layout = _has_all(css, ["grid-template-columns: auto auto minmax(96px, 0.7fr) minmax(140px, 1fr) auto", "min-width: 200px", "min-height: 120px", "text-overflow: ellipsis", "max-width: 220px"])
    val rounded_shapes = _has_all(css, ["border-radius: var(--ui-wm-window-radius)", "#wm-taskbar", "border-radius: 999px", ".widget-button", ".widget-input", "--ui-corner-window-radius", "--ui-window-radius", "--ui-corner-taskbar-radius", "--ui-taskbar-radius", "--ui-corner-widget-radius", "--ui-widget-radius"])
    val round_icon_masking = _has_all(css, [".wm-titlebar-icon", ".wm-taskbar-icon", "object-fit: cover", "border-radius: inherit"])
    val round_icon_converter = _has_all(css, [".wm-round-icon", ".wm-icon-normalized-square", ".wm-icon-image", ".wm-icon-glyph", "clip-path: circle(50% at 50% 50%)", "data-wm-icon-mask=rounded", "data-wm-icon-mask=square", "--ui-icon-mask-shape: 18px", "--ui-icon-image-fit: contain"]) and _has_all(js, ["_normalizeIconSource", "dataset.iconKind", "kind: 'image'", "kind: 'glyph'", "glyph-to-round", "square-to-round"])
    val round_scrollbars = _has_all(css, ["::-webkit-scrollbar-thumb", "background-clip: padding-box", "scrollbar-width: thin", "border-radius: 999px"])
    val translucent_shell = _has_all(css, ["backdrop-filter: blur", "-webkit-backdrop-filter: blur", "rgba(", "linear-gradient"])
    val material_policy_ready = _has_all(css, ["--ui-material-policy: glass-vibrancy", "--ui-glass-blur-px: 24", "--ui-glass-opacity-floor-x100: 6", "--ui-solid-surface-opacity-x100: 96", "--ui-window-alpha-x100: 86", "--ui-window-alpha: 0.86", "--ui-command-alpha-x100: 82", "--ui-taskbar-alpha-x100: 84", "--ui-widget-alpha-x100: 86", "color-mix(in srgb,", "calc(var(--ui-window-alpha-x100) * 1%), transparent)"])
    val transparency_verbosity_control = _has_all(css, ["data-wm-transparency=reduced", "data-wm-transparency=off", "prefers-reduced-transparency: reduce", "backdrop-filter: none !important"])
    val reduced_transparency = _has_all(css, ["--ui-material-policy: reduced-vibrancy", "--ui-glass-blur-px: 10", "--ui-glass-opacity-floor-x100: 72", "--ui-window-alpha-x100: 92", "--ui-window-alpha: 0.92", "blur(10px) saturate(125%)"])
    val solid_material_fallback = _has_all(css, ["--ui-material-policy: solid", "--ui-glass-blur-px: 0", "--ui-glass-opacity-floor-x100: 96", "--ui-window-alpha-x100: 96", "--ui-window-alpha: 0.96", "background-color: rgba(10,10,15,0.96)"])
    val glass_blur_px = _first_int_after(css, ":root {", "--ui-glass-blur-px:")
    val reduced_glass_blur_px = _first_int_after(css, ":root[data-wm-transparency=reduced]", "--ui-glass-blur-px:")
    val glass_opacity_floor_x100 = _first_int_after(css, ":root {", "--ui-glass-opacity-floor-x100:")
    val solid_surface_opacity_x100 = _first_int_after(css, ":root {", "--ui-solid-surface-opacity-x100:")
    val lifecycle_motion = _has_all(css, ["@keyframes wm-window-open", "@keyframes wm-window-close", "@keyframes wm-window-minimize", "@keyframes wm-bg-drift"])
    val lifecycle_motion_profile_ready = _has_all(css, ["--ui-motion-open-ms: 260", "--ui-motion-close-ms: 180", "--ui-motion-minimize-ms: 210", "--ui-motion-spring: cubic-bezier(0.18, 0.89, 0.28, 1.12)", "--ui-motion-exit: cubic-bezier(0.4, 0, 1, 1)", "calc(var(--ui-motion-open-ms) * 1ms)", "calc(var(--ui-motion-close-ms) * 1ms)", "calc(var(--ui-motion-minimize-ms) * 1ms)", ":root[data-wm-motion=reduced] { --ui-motion-open-ms: 120", ":root[data-wm-motion=off] { --ui-motion-open-ms: 0", "scale(1.012)", "--wm-minimize-target-x: 0px", "--wm-minimize-target-y: 42px", "translate3d(var(--wm-minimize-target-x), var(--wm-minimize-target-y), 0) scale(0.18)", ".wm-window.wm-window-opening", ".wm-window.wm-window-closing", ".wm-window.wm-window-restore", ".wm-window.wm-window-minimize", ".wm-window.focus-acquired", ".wm-window.focus-acquired::after", "@keyframes wm-focus-acquired", "@keyframes wm-focus-ring-sweep", ":root[data-wm-motion=off] .wm-window.focus-acquired"])
    val widget_motion = _has_all(css, ["@keyframes widget-pop-in", ".widget-panel:hover", ".widget-dialog", "transform: translateY(-3px) scale(1.04)"])
    val reduced_motion = _has_all(css, ["prefers-reduced-motion: reduce", ":root[data-wm-motion=standard]", ":root[data-wm-backdrop-motion=ambient]", "--ui-motion-open-ms: 0", "--ui-motion-close-ms: 0", "--ui-motion-minimize-ms: 0", "--ui-wallpaper-motion-ms: 0", "--ui-backdrop-duration-ms: 0", "--ui-wallpaper-state: wallpaper_static"])
    val motion_verbosity_control = _has_all(css, ["data-wm-motion=reduced", "data-wm-motion=off", "data-wm-quiet-mode=on", "--ui-quiet-mode: on", "data-wm-energy=low", "data-wm-energy=critical", "--ui-energy-policy: critical-saver", "--ui-energy-motion-scale-x100: 0", "--ui-backdrop-duration-ms: 0", "--ui-titlebar-context-opacity-x100: 0", "data-wm-backdrop-intensity=quiet", "--ui-backdrop-intensity: quiet", "--ui-backdrop-saturation-x100: 70", "--ui-backdrop-drift-scale-x100", "--ui-backdrop-pointer-x: 50%", "--ui-backdrop-pointer-y: 50%", "#wm-desktop::after", "radial-gradient(ellipse 420px 320px at var(--ui-backdrop-pointer-x", "scale(calc(var(--ui-backdrop-drift-scale-x100", ":root[data-wm-quiet-mode=on] #wm-desktop::before", ":root[data-wm-quiet-mode=on] #wm-desktop::after", ":root[data-wm-quiet-mode=on] #wm-taskbar", ":root[data-wm-energy=critical] #wm-desktop::before", ":root[data-wm-energy=critical] #wm-desktop::after", ":root[data-wm-backdrop-motion=static] #wm-desktop::before", ":root[data-wm-backdrop-motion=static] #wm-desktop::after", ":root[data-wm-backdrop-intensity=quiet] #wm-desktop::before", ":root[data-wm-backdrop-intensity=quiet] #wm-desktop::after", "transition-duration: 80ms", "transition: none !important", ".wm-effect-controls", ".wm-effect-control-group", ".wm-effect-control", "data-effect-control", "@keyframes wm-effect-controls-in", ":root[data-wm-feedback=off] .wm-effect-controls.action-feedback", ":root[data-wm-transparency=off] .wm-effect-controls"])
    val preview = generate_wm_modern_preview_html(theme)
    val browser_audit_command = wm_modern_preview_browser_audit_command("build/simple_wm_modern_preview.html", "build/simple_wm_modern_preview_argb.json", 1360, 840)
    val preview_fixture_ready = _has_all(preview, ["data-preview=\"modern-wm\"", "wm-window focused opening wm-window-opening focus-acquired", "wm-window restoring wm-window-restore", "data-focus-transition=\"acquired\"", "wm-title-input wm-command-bar command-submitted", "data-command-feedback=\"submitted\"", "data-command-kind=\"path\"", "widget-panel focused", "wm-taskbar-item active", "wm-icon-normalized-square", "wm-command-palette", "wm-effect-controls action-feedback", "aria-label=\"Effect controls\"", "aria-label=\"Motion control\"", "data-effect-control=\"motion\"", "data-effect-value=\"off\"", "aria-label=\"Transparency control\"", "data-effect-control=\"transparency\"", "aria-label=\"Feedback control\"", "data-effect-control=\"feedback\""])
    val command_context_ready = _has_all(css, [".wm-title-context", ".wm-titlebar", ".wm-title", ".wm-title-text", ".wm-title-icon", ".wm-body", ".wm-command-bar"])
    val command_palette_ready = _has_all(css, [".wm-command-palette", ".wm-command-palette-input", ".wm-command-palette-input.query-feedback", ".wm-command-palette.query-feedback .wm-command-palette-input", ".wm-command-query-status", ".wm-command-query-status.action-feedback", ".wm-command-palette-list", ".wm-command-empty", ".wm-command-item", ".wm-command-label", ".wm-command-match", ".wm-command-meta", ".wm-command-category-badge", ".wm-command-item.active", ".wm-command-shortcut", ".wm-command-item.selection-feedback", ".wm-command-palette[data-command-selection-feedback='keyboard'] .wm-command-item[data-command-selection-feedback='select']", ".wm-command-item .wm-taskbar-icon.selection-feedback", ".wm-command-shortcut.selection-feedback", ".wm-command-item.action-feedback", ".wm-command-palette[data-command-item-feedback='activate'] .wm-command-item[data-command-feedback='activate']", ".wm-command-item .wm-taskbar-icon.action-feedback", ".wm-command-shortcut.action-feedback", ":root[data-wm-motion=off] .wm-command-palette.query-feedback .wm-command-palette-input", ":root[data-wm-motion=off] .wm-command-query-status.action-feedback", ":root[data-wm-motion=off] .wm-command-match", ":root[data-wm-motion=off] .wm-command-item.selection-feedback", ":root[data-wm-motion=off] .wm-command-item.action-feedback", "@keyframes wm-command-query-feedback", "@keyframes wm-command-query-status-feedback", "@keyframes wm-command-match-feedback", "@keyframes wm-command-selection-feedback", "@keyframes wm-command-selection-part-feedback", "@keyframes wm-command-item-feedback", "@keyframes wm-command-item-part-feedback"]) and _has_all(preview, ["aria-controls=\"wm-command-palette-list\"", "aria-activedescendant=\"wm-command-item-0\"", "id=\"wm-command-palette-list\"", "role=\"listbox\" aria-label=\"Available commands\"", "id=\"wm-command-item-0\"", "data-command-index=\"0\"", "tabindex=\"0\"", "aria-selected=\"true\"", "query-feedback", "data-command-query-state=\"filtered\"", "da