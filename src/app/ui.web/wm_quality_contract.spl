# Quality contract for the Simple Web WM generated HTML/CSS shell.
#
# This is intentionally static and deterministic: it checks the generated theme
# contract before browser/screenshot evidence is added on top.

use app.ui.web.html.{generate_css, generate_wm_modern_preview_html}

struct WmThemeQualityReport:
    theme: text
    passed: bool
    contrast_delta: i64
    contrast_ratio_x100: i64
    color_checked: bool
    semantic_tokens: bool
    stable_layout: bool
    size_layout_configured: bool
    titlebar_height_px: i64
    window_min_width_px: i64
    window_min_height_px: i64
    title_input_min_width_px: i64
    taskbar_icon_size_px: i64
    rounded_shapes: bool
    round_icon_masking: bool
    round_icon_converter: bool
    round_scrollbars: bool
    translucent_shell: bool
    lifecycle_motion: bool
    widget_motion: bool
    reduced_motion: bool
    motion_verbosity_control: bool
    preview_fixture_ready: bool
    command_context_ready: bool
    command_palette_ready: bool
    title_input_ready: bool
    visual_layering_ready: bool
    accessible_controls_ready: bool
    notes: [text]

fn wm_theme_quality_report(theme: text) -> WmThemeQualityReport:
    val css = generate_css(theme)
    val bg = _css_var(css, "--ui-bg")
    val text_color = _css_var(css, "--ui-text")
    val contrast_delta = _brightness_delta(bg, text_color)
    val contrast_ratio_x100 = _contrast_ratio_x100(bg, text_color)
    val color_checked = bg.starts_with("#") and text_color.starts_with("#") and contrast_delta >= 96 and contrast_ratio_x100 >= 450
    val semantic_tokens = _has_all(css, ["--ui-accent:", "--ui-accent-rgb:", "--ui-bg:", "--ui-panel:", "--ui-border:", "--ui-text:", "--ui-dim:", "--ui-wm-window-radius:"])
    val titlebar_height_px = _first_int_after(css, ".wm-titlebar {", "height:")
    val window_min_width_px = _first_int_after(css, ".wm-window {", "min-width:")
    val window_min_height_px = _first_int_after(css, ".wm-window {", "min-height:")
    val title_input_min_width_px = _first_int_after(css, ".wm-title-input", "min-width:")
    val taskbar_icon_size_px = _first_int_after(css, ".wm-taskbar-icon {", "width:")
    val size_layout_configured = titlebar_height_px >= 38 and window_min_width_px >= 200 and window_min_height_px >= 120 and title_input_min_width_px >= 140 and taskbar_icon_size_px >= 26
    val stable_layout = _has_all(css, ["grid-template-columns: auto auto minmax(96px, 0.7fr) minmax(140px, 1fr) auto", "min-width: 200px", "min-height: 120px", "text-overflow: ellipsis", "max-width: 220px"])
    val rounded_shapes = _has_all(css, ["border-radius: var(--ui-wm-window-radius)", "#wm-taskbar", "border-radius: 999px", ".widget-button", ".widget-input"])
    val round_icon_masking = _has_all(css, [".wm-titlebar-icon", ".wm-taskbar-icon", "object-fit: cover", "border-radius: inherit"])
    val round_icon_converter = _has_all(css, [".wm-round-icon", ".wm-icon-normalized-square", ".wm-icon-image", ".wm-icon-glyph", "clip-path: circle(50% at 50% 50%)"])
    val round_scrollbars = _has_all(css, ["::-webkit-scrollbar-thumb", "background-clip: padding-box", "scrollbar-width: thin", "border-radius: 999px"])
    val translucent_shell = _has_all(css, ["backdrop-filter: blur", "-webkit-backdrop-filter: blur", "rgba(", "linear-gradient"])
    val lifecycle_motion = _has_all(css, ["@keyframes wm-window-open", "@keyframes wm-window-close", "@keyframes wm-window-minimize", "@keyframes wm-bg-drift"])
    val widget_motion = _has_all(css, ["@keyframes widget-pop-in", ".widget-panel:hover", ".widget-dialog", "transform: translateY(-3px) scale(1.04)"])
    val reduced_motion = css.contains("prefers-reduced-motion: reduce")
    val motion_verbosity_control = _has_all(css, ["data-wm-motion=reduced", "data-wm-motion=off", "transition-duration: 80ms", "transition: none !important"])
    val preview = generate_wm_modern_preview_html(theme)
    val preview_fixture_ready = _has_all(preview, ["data-preview=\"modern-wm\"", "wm-window focused opening", "wm-title-input wm-command-bar", "widget-panel focused", "wm-taskbar-item active", "wm-icon-normalized-square", "wm-command-palette"])
    val command_context_ready = _has_all(css, [".wm-title-context", ".wm-titlebar", ".wm-title", ".wm-body", ".wm-command-bar"])
    val command_palette_ready = _has_all(css, [".wm-command-palette", ".wm-command-palette-input", ".wm-command-palette-list", ".wm-command-item", ".wm-command-shortcut"])
    val title_input_ready = _has_all(css, [".wm-title-input", ".wm-command-bar", "minmax(140px, 1fr)", "cursor: text"])
    val visual_layering_ready = _has_all(css, ["#wm-desktop { position: fixed; inset: 0; overflow: hidden; isolation: isolate; }", "#wm-desktop::before", "z-index: 0", ".wm-window { position: absolute; z-index: 20", "#wm-taskbar", "z-index: 10000", ".wm-command-palette", "z-index: 12000"])
    val accessible_controls_ready = _has_all(css, [":focus-visible", "outline-offset: 3px", "inset: -8px", ".wm-command-palette-input { width: 100%; height: 44px", ".wm-command-item { display: grid", "min-height: 44px"]) and _has_all(preview, ["aria-label=\"Close window\"", "aria-label=\"Minimize window\"", "aria-label=\"Maximize window\"", "role=\"navigation\" aria-label=\"Window taskbar\"", "role=\"listbox\"", "role=\"option\"", "aria-label=\"Focus Simple IDE\""])
    val passed = color_checked and semantic_tokens and stable_layout and size_layout_configured and rounded_shapes and round_icon_masking and round_icon_converter and round_scrollbars and translucent_shell and lifecycle_motion and widget_motion and reduced_motion and motion_verbosity_control and preview_fixture_ready and command_context_ready and command_palette_ready and title_input_ready and visual_layering_ready and accessible_controls_ready
    WmThemeQualityReport(
        theme: theme,
        passed: passed,
        contrast_delta: contrast_delta,
        contrast_ratio_x100: contrast_ratio_x100,
        color_checked: color_checked,
        semantic_tokens: semantic_tokens,
        stable_layout: stable_layout,
        size_layout_configured: size_layout_configured,
        titlebar_height_px: titlebar_height_px,
        window_min_width_px: window_min_width_px,
        window_min_height_px: window_min_height_px,
        title_input_min_width_px: title_input_min_width_px,
        taskbar_icon_size_px: taskbar_icon_size_px,
        rounded_shapes: rounded_shapes,
        round_icon_masking: round_icon_masking,
        round_icon_converter: round_icon_converter,
        round_scrollbars: round_scrollbars,
        translucent_shell: translucent_shell,
        lifecycle_motion: lifecycle_motion,
        widget_motion: widget_motion,
        reduced_motion: reduced_motion,
        motion_verbosity_control: motion_verbosity_control,
        preview_fixture_ready: preview_fixture_ready,
        command_context_ready: command_context_ready,
        command_palette_ready: command_palette_ready,
        title_input_ready: title_input_ready,
        visual_layering_ready: visual_layering_ready,
        accessible_controls_ready: accessible_controls_ready,
        notes: _quality_notes(passed, contrast_delta)
    )

fn wm_theme_quality_summary(theme: text) -> text:
    val r = wm_theme_quality_report(theme)
    val status = if r.passed: "pass" else: "fail"
    "wm_theme_quality theme={r.theme} status={status} contrast_ratio_x100={r.contrast_ratio_x100} contrast_delta={r.contrast_delta} color_checked={r.color_checked} titlebar_height_px={r.titlebar_height_px} window_min_width_px={r.window_min_width_px} window_min_height_px={r.window_min_height_px} taskbar_icon_size_px={r.taskbar_icon_size_px} stable_layout={r.stable_layout} visual_layering_ready={r.visual_layering_ready} accessible_controls_ready={r.accessible_controls_ready} lifecycle_motion={r.lifecycle_motion} reduced_motion={r.reduced_motion}"

fn _quality_notes(passed: bool, contrast_delta: i64) -> [text]:
    var notes: [text] = []
    if passed:
        notes = notes.push("quality contract passed")
    else:
        notes = notes.push("quality contract failed")
    notes = notes.push("contrast_delta={contrast_delta}")
    notes

fn _contrast_ratio_x100(a: text, b: text) -> i64:
    val la = _relative_luminance_x1000(a)
    val lb = _relative_luminance_x1000(b)
    if la > lb:
        ((la + 50) * 100) / (lb + 50)
    else:
        ((lb + 50) * 100) / (la + 50)

fn _relative_luminance_x1000(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _linear_channel_x1000(_hex_pair(v, 1))
    val g = _linear_channel_x1000(_hex_pair(v, 3))
    val b = _linear_channel_x1000(_hex_pair(v, 5))
    ((r * 2126) + (g * 7152) + (b * 722)) / 10000

fn _linear_channel_x1000(channel: i64) -> i64:
    if channel <= 10:
        (channel * 1000) / 3294
    else:
        val srgb_x1000 = (channel * 1000) / 255
        val c = ((srgb_x1000 + 55) * 1000) / 1055
        (c * c) / 1000

fn _hex_pair(hex: text, start: i64) -> i64:
    _hex_digit(hex.substring(start, start + 1)) * 16 + _hex_digit(hex.substring(start + 1, start + 2))

fn _first_int_after(css: text, scope_marker: text, value_marker: text) -> i64:
    val scope_idx = css.index_of(scope_marker) ?? -1
    if scope_idx < 0:
        return 0
    val scoped = css.substring(scope_idx)
    val value_idx = scoped.index_of(value_marker) ?? -1
    if value_idx < 0:
        return 0
    val tail = scoped.substring(value_idx + value_marker.len())
    var started = false
    var value: i64 = 0
    for ch in tail:
        if ch >= "0" and ch <= "9":
            started = true
            value = value * 10 + (ch.to_i64() - "0".to_i64())
        else:
            if started:
                return value
    value

fn _has_all(css: text, needles: [text]) -> bool:
    for needle in needles:
        if not css.contains(needle):
            return false
    true

fn _css_var(css: text, name: text) -> text:
    val marker = "{name}:"
    val idx = css.index_of(marker) ?? -1
    if idx < 0:
        return ""
    val after = css.substring(idx + marker.len())
    val end = after.index_of(";") ?? after.len()
    after.substring(0, end).trim()

fn _brightness_delta(a: text, b: text) -> i64:
    val ba = _hex_brightness(a)
    val bb = _hex_brightness(b)
    if ba > bb:
        ba - bb
    else:
        bb - ba

fn _hex_brightness(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _hex_digit(v.substring(1, 2)) * 16 + _hex_digit(v.substring(2, 3))
    val g = _hex_digit(v.substring(3, 4)) * 16 + _hex_digit(v.substring(4, 5))
    val b = _hex_digit(v.substring(5, 6)) * 16 + _hex_digit(v.substring(6, 7))
    ((r * 299) + (g * 587) + (b * 114)) / 1000

fn _hex_digit(ch: text) -> i64:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    if ch == "a" or ch == "A":
        return 10
    if ch == "b" or ch == "B":
        return 11
    if ch == "c" or ch == "C":
        return 12
    if ch == "d" or ch == "D":
        return 13
    if ch == "e" or ch == "E":
        return 14
    if ch == "f" or ch == "F":
        return 15
    0
