# Quality contract for the Simple Web WM generated HTML/CSS shell.
#
# This is intentionally static and deterministic: it checks the generated theme
# contract before browser/screenshot evidence is added on top.

use app.ui.web.html.{generate_css, generate_wm_modern_preview_html}

extern fn rt_file_read_text(path: text) -> text

struct WmThemeQualityReport:
    theme: text
    passed: bool
    contrast_delta: i64
    contrast_ratio_x100: i64
    color_checked: bool
    semantic_tokens: bool
    stable_layout: bool
    size_layout_configured: bool
    titlebar_height_px: i64
    window_min_width_px: i64
    window_min_height_px: i64
    title_input_min_width_px: i64
    taskbar_icon_size_px: i64
    taskbar_preview_max_width_px: i64
    command_palette_max_width_px: i64
    context_menu_max_width_px: i64
    control_center_max_width_px: i64
    desktop_widget_max_width_px: i64
    widget_gallery_max_width_px: i64
    overview_card_min_width_px: i64
    touch_target_min_height_px: i64
    rounded_shapes: bool
    round_icon_masking: bool
    round_icon_converter: bool
    round_scrollbars: bool
    translucent_shell: bool
    material_policy_ready: bool
    transparency_verbosity_control: bool
    reduced_transparency: bool
    solid_material_fallback: bool
    glass_blur_px: i64
    reduced_glass_blur_px: i64
    glass_opacity_floor_x100: i64
    solid_surface_opacity_x100: i64
    lifecycle_motion: bool
    widget_motion: bool
    reduced_motion: bool
    motion_verbosity_control: bool
    preview_fixture_ready: bool
    command_context_ready: bool
    command_palette_ready: bool
    context_menu_ready: bool
    title_input_ready: bool
    title_command_runtime_ready: bool
    title_command_suggestions_ready: bool
    visual_layering_ready: bool
    accessible_controls_ready: bool
    snap_assist_ready: bool
    taskbar_preview_ready: bool
    desktop_widgets_ready: bool
    wallpaper_picker_ready: bool
    app_launcher_ready: bool
    shortcut_overlay_ready: bool
    widget_gallery_ready: bool
    window_overview_ready: bool
    control_center_ready: bool
    responsive_layout_ready: bool
    notes: [text]

fn wm_theme_quality_report(theme: text) -> WmThemeQualityReport:
    val css = generate_css(theme)
    val bg = _css_var(css, "--ui-bg")
    val text_color = _css_var(css, "--ui-text")
    val contrast_delta = _brightness_delta(bg, text_color)
    val contrast_ratio_x100 = _contrast_ratio_x100(bg, text_color)
    val color_checked = bg.starts_with("#") and text_color.starts_with("#") and contrast_delta >= 96 and contrast_ratio_x100 >= 450
    val semantic_tokens = _has_all(css, ["--ui-accent:", "--ui-accent-rgb:", "--ui-bg:", "--ui-panel:", "--ui-border:", "--ui-text:", "--ui-dim:", "--ui-wm-window-radius:"])
    val titlebar_height_px = _first_int_after(css, ".wm-titlebar {", "height:")
    val window_min_width_px = _first_int_after(css, ".wm-window {", "min-width:")
    val window_min_height_px = _first_int_after(css, ".wm-window {", "min-height:")
    val title_input_min_width_px = _first_int_after(css, ".wm-title-input", "min-width:")
    val taskbar_icon_size_px = _first_int_after(css, ".wm-taskbar-icon {", "width:")
    val taskbar_preview_max_width_px = _first_int_after(css, ".wm-taskbar-preview {", "width: min(")
    val command_palette_max_width_px = _first_int_after(css, ".wm-command-palette {", "width: min(")
    val context_menu_max_width_px = _first_int_after(css, ".wm-window-context-menu {", "width: min(")
    val control_center_max_width_px = _first_int_after(css, ".wm-control-center {", "width: min(")
    val desktop_widget_max_width_px = _first_int_after(css, ".wm-desktop-widgets {", "width: min(")
    val widget_gallery_max_width_px = _first_int_after(css, ".wm-widget-gallery {", "width: min(")
    val overview_card_min_width_px = _first_int_after(css, ".wm-overview-grid", "minmax(")
    val touch_target_min_height_px = _first_int_after(css, ".wm-command-item {", "min-height:")
    val size_layout_configured = titlebar_height_px >= 38 and window_min_width_px >= 200 and window_min_height_px >= 120 and title_input_min_width_px >= 140 and taskbar_icon_size_px >= 26
    val stable_layout = _has_all(css, ["grid-template-columns: auto auto minmax(96px, 0.7fr) minmax(140px, 1fr) auto", "min-width: 200px", "min-height: 120px", "text-overflow: ellipsis", "max-width: 220px"])
    val rounded_shapes = _has_all(css, ["border-radius: var(--ui-wm-window-radius)", "#wm-taskbar", "border-radius: 999px", ".widget-button", ".widget-input"])
    val round_icon_masking = _has_all(css, [".wm-titlebar-icon", ".wm-taskbar-icon", "object-fit: cover", "border-radius: inherit"])
    val round_icon_converter = _has_all(css, [".wm-round-icon", ".wm-icon-normalized-square", ".wm-icon-image", ".wm-icon-glyph", "clip-path: circle(50% at 50% 50%)"])
    val round_scrollbars = _has_all(css, ["::-webkit-scrollbar-thumb", "background-clip: padding-box", "scrollbar-width: thin", "border-radius: 999px"])
    val translucent_shell = _has_all(css, ["backdrop-filter: blur", "-webkit-backdrop-filter: blur", "rgba(", "linear-gradient"])
    val material_policy_ready = _has_all(css, ["--ui-material-policy: glass-vibrancy", "--ui-glass-blur-px: 24", "--ui-glass-opacity-floor-x100: 6", "--ui-solid-surface-opacity-x100: 96"])
    val transparency_verbosity_control = _has_all(css, ["data-wm-transparency=reduced", "data-wm-transparency=off", "prefers-reduced-transparency: reduce", "backdrop-filter: none !important"])
    val reduced_transparency = _has_all(css, ["--ui-material-policy: reduced-vibrancy", "--ui-glass-blur-px: 10", "--ui-glass-opacity-floor-x100: 72", "blur(10px) saturate(125%)"])
    val solid_material_fallback = _has_all(css, ["--ui-material-policy: solid", "--ui-glass-blur-px: 0", "--ui-glass-opacity-floor-x100: 96", "background-color: rgba(10,10,15,0.96)"])
    val glass_blur_px = _first_int_after(css, ":root {", "--ui-glass-blur-px:")
    val reduced_glass_blur_px = _first_int_after(css, ":root[data-wm-transparency=reduced]", "--ui-glass-blur-px:")
    val glass_opacity_floor_x100 = _first_int_after(css, ":root {", "--ui-glass-opacity-floor-x100:")
    val solid_surface_opacity_x100 = _first_int_after(css, ":root {", "--ui-solid-surface-opacity-x100:")
    val lifecycle_motion = _has_all(css, ["@keyframes wm-window-open", "@keyframes wm-window-close", "@keyframes wm-window-minimize", "@keyframes wm-bg-drift"])
    val widget_motion = _has_all(css, ["@keyframes widget-pop-in", ".widget-panel:hover", ".widget-dialog", "transform: translateY(-3px) scale(1.04)"])
    val reduced_motion = css.contains("prefers-reduced-motion: reduce")
    val motion_verbosity_control = _has_all(css, ["data-wm-motion=reduced", "data-wm-motion=off", "transition-duration: 80ms", "transition: none !important"])
    val preview = generate_wm_modern_preview_html(theme)
    val js = rt_file_read_text("src/app/ui.web/wm.js")
    val preview_fixture_ready = _has_all(preview, ["data-preview=\"modern-wm\"", "wm-window focused opening", "wm-title-input wm-command-bar", "widget-panel focused", "wm-taskbar-item active", "wm-icon-normalized-square", "wm-command-palette"])
    val command_context_ready = _has_all(css, [".wm-title-context", ".wm-titlebar", ".wm-title", ".wm-body", ".wm-command-bar"])
    val command_palette_ready = _has_all(css, [".wm-command-palette", ".wm-command-palette-input", ".wm-command-palette-list", ".wm-command-item", ".wm-command-shortcut"])
    val context_menu_ready = context_menu_max_width_px <= 280 and _has_all(css, [".wm-window-context-menu", ".wm-window-context-menu[hidden]", ".wm-window-context-title", ".wm-window-context-item", ".wm-window-context-shortcut", "@keyframes wm-context-menu-in"]) and _has_all(preview, ["role=\"menu\" aria-label=\"Window context menu\"", "wm-window-context-item active", "data-context-action=\"focus\"", "data-context-action=\"snap_left\"", "data-context-action=\"snap_right\"", "data-context-action=\"close\""])
    val title_input_ready = _has_all(css, [".wm-title-input", ".wm-command-bar", "minmax(140px, 1fr)", "cursor: text"])
    val title_command_runtime_ready = _has_all(js, ["_submitTitleCommandInput", "_titleCommandKind", "_focusActiveTitleInput", "title_command", "command_text", "command_kind", "command_context", "e.key.toLowerCase() === 'l'", "dataset.lastSubmittedValue", "_showTitleCommandSuggestions", "_applyTitleCommandSuggestion"])
    val title_command_suggestions_ready = _has_all(css, [".wm-title-suggestions", ".wm-title-suggestions[hidden]", ".wm-title-suggestion-item", ".wm-title-suggestion-label", ".wm-title-suggestion-meta", "@keyframes wm-title-suggest-in"]) and _has_all(preview, ["role=\"listbox\" aria-label=\"Window command suggestions\"", "wm-title-suggestion-item active", "wm-title-suggestion-label", "wm-title-suggestion-meta", "workspace search"])
    val visual_layering_ready = _has_all(css, ["#wm-desktop { position: fixed; inset: 0; overflow: hidden; isolation: isolate; }", "#wm-desktop::before", "z-index: 0", ".wm-window { position: absolute; z-index: 20", "#wm-taskbar", "z-index: 10000", ".wm-command-palette", "z-index: 12000"])
    val accessible_controls_ready = _has_all(css, [":focus-visible", "outline-offset: 3px", "inset: -8px", ".wm-command-palette-input { width: 100%; height: 44px", ".wm-command-item { display: grid", "min-height: 44px"]) and _has_all(preview, ["aria-label=\"Close window\"", "aria-label=\"Minimize window\"", "aria-label=\"Maximize window\"", "role=\"navigation\" aria-label=\"Window taskbar\"", "role=\"listbox\"", "role=\"option\"", "aria-label=\"Focus Simple IDE\""])
    val snap_assist_ready = _has_all(css, [".wm-snap-preview", ".wm-snap-preview.active", "data-snap-zone=left", "data-snap-zone=right", "data-snap-zone=full", "@keyframes wm-snap-pulse"]) and _has_all(preview, ["wm-snap-preview active", "data-snap-zone=\"right\"", "aria-hidden=\"true\""])
    val taskbar_preview_ready = taskbar_preview_max_width_px <= 320 and _has_all(css, [".wm-taskbar-preview", ".wm-taskbar-preview[hidden]", ".wm-taskbar-preview-icon", ".wm-taskbar-preview-title", ".wm-taskbar-preview-meta", ".wm-taskbar-preview-status", "@keyframes wm-taskbar-preview-in"]) and _has_all(preview, ["aria-label=\"Taskbar window preview\"", "wm-taskbar-preview-title", "wm-taskbar-preview-meta", "data-preview-title=\"Simple IDE\"", "data-preview-status=\"Active\""])
    val desktop_widgets_ready = _has_all(css, [".wm-desktop-widgets", ".wm-desktop-widgets.collapsed", ".wm-desktop-widget", ".wm-desktop-widget-label", ".wm-desktop-widget-value", ".wm-desktop-widget-meta", "@keyframes wm-widget-float"]) and _has_all(preview, ["aria-label=\"Desktop widgets\"", "wm-desktop-widget wm-widget-clock", "wm-desktop-widget wm-widget-system", "wm-desktop-widget wm-widget-workspace"])
    val wallpaper_picker_ready = _has_all(css, ["data-wm-wallpaper=aurora", "data-wm-wallpaper=mesh", "data-wm-wallpaper=solid"]) and _has_all(preview, ["data-wm-wallpaper=\"aurora\"", "aria-label=\"Animated wallpaper\"", "Aurora", "Mesh", "Solid", "Set wallpaper: aurora"])
    val app_launcher_ready = _has_all(css, [".wm-app-launcher", ".wm-app-launcher[hidden]", ".wm-app-launcher-input", ".wm-app-launcher-grid", ".wm-app-launcher-tile", ".wm-app-launcher-tile:hover", "@keyframes wm-launcher-in"]) and _has_all(preview, ["role=\"dialog\" aria-label=\"App launcher\"", "wm-app-launcher-tile active", "data-app-id=\"simple.ide\"", "wm-app-launcher-name", "Simple IDE"]) and _has_all(js, ["_ensureAppLauncher", "_toggleAppLauncher", "_renderAppLauncher", "_executeAppLauncherSelection", "Cmd Space", "e.key === ' '"])
    val shortcut_overlay_ready = _has_all(css, [".wm-shortcut-overlay", ".wm-shortcut-overlay[hidden]", ".wm-shortcut-grid", ".wm-shortcut-row", ".wm-shortcut-key", "@keyframes wm-shortcuts-in"]) and _has_all(preview, ["role=\"dialog\" aria-label=\"Keyboard shortcuts\"", "wm-shortcut-title", "wm-shortcut-row", "Cmd K", "Cmd Space", "Cmd L", "Esc"]) and _has_all(js, ["_ensureShortcutOverlay", "_toggleShortcutOverlay", "Show keyboard shortcuts", "Cmd /", "e.key === '/'"])
    val widget_gallery_ready = widget_gallery_max_width_px <= 440 and _has_all(css, [".wm-widget-gallery", ".wm-widget-gallery[hidden]", ".wm-widget-gallery-grid", ".wm-widget-gallery-card", ".wm-widget-gallery-card:hover", "@keyframes wm-widget-gallery-in"]) and _has_all(preview, ["aria-label=\"Widget gallery\"", "wm-widget-gallery-card", "Add Clock widget", "Add Motion widget", "Add Workspace widget", "Open widget gallery"])
    val window_overview_ready = _has_all(css, [".wm-window-overview", ".wm-overview-grid", ".wm-overview-card", ".wm-overview-card.active", ".wm-overview-icon", "@keyframes wm-overview-in"]) and _has_all(preview, ["aria-label=\"Window overview\"", "wm-overview-card active", "wm-overview-card-title", "wm-overview-card-meta", "Show window overview"])
    val control_center_ready = _has_all(css, [".wm-control-center", ".wm-control-center[hidden]", ".wm-control-group", ".wm-control-button", ".wm-control-button:hover", "@keyframes wm-control-in"]) and _has_all(preview, ["aria-label=\"WM control center\"", "Open control center", "Standard motion", "Reduced motion", "Motion off", "Desktop widgets", "Window overview"])
    val responsive_layout_ready = command_palette_max_width_px <= 680 and context_menu_max_width_px <= 280 and control_center_max_width_px <= 320 and desktop_widget_max_width_px <= 260 and widget_gallery_max_width_px <= 440 and taskbar_preview_max_width_px <= 320 and overview_card_min_width_px >= 180 and touch_target_min_height_px >= 44 and _has_all(css, ["calc(100vw - 32px)", "calc(100vw - 36px)", "repeat(auto-fit", "env(safe-area-inset-top)", "env(safe-area-inset-bottom)"])
    val passed = color_checked and semantic_tokens and stable_layout and size_layout_configured and rounded_shapes and round_icon_masking and round_icon_converter and round_scrollbars and translucent_shell and material_policy_ready and transparency_verbosity_control and reduced_transparency and solid_material_fallback and glass_blur_px == 24 and reduced_glass_blur_px == 10 and glass_opacity_floor_x100 == 6 and solid_surface_opacity_x100 == 96 and lifecycle_motion and widget_motion and reduced_motion and motion_verbosity_control and preview_fixture_ready and command_context_ready and command_palette_ready and context_menu_ready and title_input_ready and title_command_runtime_ready and title_command_suggestions_ready and visual_layering_ready and accessible_controls_ready and snap_assist_ready and taskbar_preview_ready and desktop_widgets_ready and wallpaper_picker_ready and app_launcher_ready and shortcut_overlay_ready and widget_gallery_ready and window_overview_ready and control_center_ready and responsive_layout_ready
    WmThemeQualityReport(
        theme: theme,
        passed: passed,
        contrast_delta: contrast_delta,
        contrast_ratio_x100: contrast_ratio_x100,
        color_checked: color_checked,
        semantic_tokens: semantic_tokens,
        stable_layout: stable_layout,
        size_layout_configured: size_layout_configured,
        titlebar_height_px: titlebar_height_px,
        window_min_width_px: window_min_width_px,
        window_min_height_px: window_min_height_px,
        title_input_min_width_px: title_input_min_width_px,
        taskbar_icon_size_px: taskbar_icon_size_px,
        taskbar_preview_max_width_px: taskbar_preview_max_width_px,
        command_palette_max_width_px: command_palette_max_width_px,
        context_menu_max_width_px: context_menu_max_width_px,
        control_center_max_width_px: control_center_max_width_px,
        desktop_widget_max_width_px: desktop_widget_max_width_px,
        widget_gallery_max_width_px: widget_gallery_max_width_px,
        overview_card_min_width_px: overview_card_min_width_px,
        touch_target_min_height_px: touch_target_min_height_px,
        rounded_shapes: rounded_shapes,
        round_icon_masking: round_icon_masking,
        round_icon_converter: round_icon_converter,
        round_scrollbars: round_scrollbars,
        translucent_shell: translucent_shell,
        material_policy_ready: material_policy_ready,
        transparency_verbosity_control: transparency_verbosity_control,
        reduced_transparency: reduced_transparency,
        solid_material_fallback: solid_material_fallback,
        glass_blur_px: glass_blur_px,
        reduced_glass_blur_px: reduced_glass_blur_px,
        glass_opacity_floor_x100: glass_opacity_floor_x100,
        solid_surface_opacity_x100: solid_surface_opacity_x100,
        lifecycle_motion: lifecycle_motion,
        widget_motion: widget_motion,
        reduced_motion: reduced_motion,
        motion_verbosity_control: motion_verbosity_control,
        preview_fixture_ready: preview_fixture_ready,
        command_context_ready: command_context_ready,
        command_palette_ready: command_palette_ready,
        context_menu_ready: context_menu_ready,
        title_input_ready: title_input_ready,
        title_command_runtime_ready: title_command_runtime_ready,
        title_command_suggestions_ready: title_command_suggestions_ready,
        visual_layering_ready: visual_layering_ready,
        accessible_controls_ready: accessible_controls_ready,
        snap_assist_ready: snap_assist_ready,
        taskbar_preview_ready: taskbar_preview_ready,
        desktop_widgets_ready: desktop_widgets_ready,
        wallpaper_picker_ready: wallpaper_picker_ready,
        app_launcher_ready: app_launcher_ready,
        shortcut_overlay_ready: shortcut_overlay_ready,
        widget_gallery_ready: widget_gallery_ready,
        window_overview_ready: window_overview_ready,
        control_center_ready: control_center_ready,
        responsive_layout_ready: responsive_layout_ready,
        notes: _quality_notes(passed, contrast_delta)
    )

fn wm_theme_quality_summary(theme: text) -> text:
    val r = wm_theme_quality_report(theme)
    val status = if r.passed: "pass" else: "fail"
    "wm_theme_quality theme={r.theme} status={status} contrast_ratio_x100={r.contrast_ratio_x100} contrast_delta={r.contrast_delta} color_checked={r.color_checked} titlebar_height_px={r.titlebar_height_px} window_min_width_px={r.window_min_width_px} window_min_height_px={r.window_min_height_px} taskbar_icon_size_px={r.taskbar_icon_size_px} taskbar_preview_max_width_px={r.taskbar_preview_max_width_px} command_palette_max_width_px={r.command_palette_max_width_px} context_menu_max_width_px={r.context_menu_max_width_px} control_center_max_width_px={r.control_center_max_width_px} desktop_widget_max_width_px={r.desktop_widget_max_width_px} widget_gallery_max_width_px={r.widget_gallery_max_width_px} overview_card_min_width_px={r.overview_card_min_width_px} touch_target_min_height_px={r.touch_target_min_height_px} stable_layout={r.stable_layout} responsive_layout_ready={r.responsive_layout_ready} visual_layering_ready={r.visual_layering_ready} accessible_controls_ready={r.accessible_controls_ready} snap_assist_ready={r.snap_assist_ready} taskbar_preview_ready={r.taskbar_preview_ready} desktop_widgets_ready={r.desktop_widgets_ready} wallpaper_picker_ready={r.wallpaper_picker_ready} app_launcher_ready={r.app_launcher_ready} shortcut_overlay_ready={r.shortcut_overlay_ready} widget_gallery_ready={r.widget_gallery_ready} window_overview_ready={r.window_overview_ready} control_center_ready={r.control_center_ready} command_palette_ready={r.command_palette_ready} context_menu_ready={r.context_menu_ready} title_command_runtime_ready={r.title_command_runtime_ready} title_command_suggestions_ready={r.title_command_suggestions_ready} material_policy={r.material_policy_ready} transparency_control={r.transparency_verbosity_control} reduced_transparency={r.reduced_transparency} solid_material_fallback={r.solid_material_fallback} glass_blur_px={r.glass_blur_px} reduced_glass_blur_px={r.reduced_glass_blur_px} glass_opacity_floor_x100={r.glass_opacity_floor_x100} solid_surface_opacity_x100={r.solid_surface_opacity_x100} lifecycle_motion={r.lifecycle_motion} reduced_motion={r.reduced_motion}"

fn _quality_notes(passed: bool, contrast_delta: i64) -> [text]:
    var notes: [text] = []
    if passed:
        notes = notes.push("quality contract passed")
    else:
        notes = notes.push("quality contract failed")
    notes = notes.push("contrast_delta={contrast_delta}")
    notes

fn _contrast_ratio_x100(a: text, b: text) -> i64:
    val la = _relative_luminance_x1000(a)
    val lb = _relative_luminance_x1000(b)
    if la > lb:
        ((la + 50) * 100) / (lb + 50)
    else:
        ((lb + 50) * 100) / (la + 50)

fn _relative_luminance_x1000(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _linear_channel_x1000(_hex_pair(v, 1))
    val g = _linear_channel_x1000(_hex_pair(v, 3))
    val b = _linear_channel_x1000(_hex_pair(v, 5))
    ((r * 2126) + (g * 7152) + (b * 722)) / 10000

fn _linear_channel_x1000(channel: i64) -> i64:
    if channel <= 10:
        (channel * 1000) / 3294
    else:
        val srgb_x1000 = (channel * 1000) / 255
        val c = ((srgb_x1000 + 55) * 1000) / 1055
        (c * c) / 1000

fn _hex_pair(hex: text, start: i64) -> i64:
    _hex_digit(hex.substring(start, start + 1)) * 16 + _hex_digit(hex.substring(start + 1, start + 2))

fn _first_int_after(css: text, scope_marker: text, value_marker: text) -> i64:
    val scope_idx = css.index_of(scope_marker) ?? -1
    if scope_idx < 0:
        return 0
    val scoped = css.substring(scope_idx)
    val value_idx = scoped.index_of(value_marker) ?? -1
    if value_idx < 0:
        return 0
    val tail = scoped.substring(value_idx + value_marker.len())
    var started = false
    var value: i64 = 0
    for ch in tail:
        if ch >= "0" and ch <= "9":
            started = true
            value = value * 10 + (ch.to_i64() - "0".to_i64())
        else:
            if started:
                return value
    value

fn _has_all(css: text, needles: [text]) -> bool:
    for needle in needles:
        if not css.contains(needle):
            return false
    true

fn _css_var(css: text, name: text) -> text:
    val marker = "{name}:"
    val idx = css.index_of(marker) ?? -1
    if idx < 0:
        return ""
    val after = css.substring(idx + marker.len())
    val end = after.index_of(";") ?? after.len()
    after.substring(0, end).trim()

fn _brightness_delta(a: text, b: text) -> i64:
    val ba = _hex_brightness(a)
    val bb = _hex_brightness(b)
    if ba > bb:
        ba - bb
    else:
        bb - ba

fn _hex_brightness(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _hex_digit(v.substring(1, 2)) * 16 + _hex_digit(v.substring(2, 3))
    val g = _hex_digit(v.substring(3, 4)) * 16 + _hex_digit(v.substring(4, 5))
    val b = _hex_digit(v.substring(5, 6)) * 16 + _hex_digit(v.substring(6, 7))
    ((r * 299) + (g * 587) + (b * 114)) / 1000

fn _hex_digit(ch: text) -> i64:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    val lower = ch.to_lower()
    if lower == "a":
        return 10
    if lower == "b":
        return 11
    if lower == "c":
        return 12
    if lower == "d":
        return 13
    if lower == "e":
        return 14
    if lower == "f":
        return 15
    0
