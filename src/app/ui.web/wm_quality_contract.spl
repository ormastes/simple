    translucent_shell: bool
    material_policy_ready: bool
    transparency_verbosity_control: bool
    reduced_transparency: bool
    solid_material_fallback: bool
    glass_blur_px: i64
    reduced_glass_blur_px: i64
    glass_opacity_floor_x100: i64
    solid_surface_opacity_x100: i64
    lifecycle_motion: bool
    lifecycle_motion_profile_ready: bool
