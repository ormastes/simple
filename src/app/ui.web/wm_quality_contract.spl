fn wm_theme_quality_report(theme: text) -> WmThemeQualityReport:
    val css = generate_css(theme)
    val bg = _css_var(css, "--ui-bg")
    val text_color = _css_var(css, "--ui-text")
    val contrast_delta = _brightness_delta(bg, text_color)
    val contrast_ratio_x100 = _contrast_ratio_x100(bg, text_color)
    val color_checked = bg.starts_with("#") and text_color.starts_with("#") and contrast_delta >= 96 and contrast_ratio_x100 >= 450
    val semantic_tokens = _has_all(css, ["--ui-accent:", "--ui-accent-rgb:", "--ui-bg:", "--ui-panel:", "--ui-border:", "--ui-text:", "--ui-dim:", "--ui-wm-window-radius:"])
    val titlebar_height_px = _first_int_after(css, ".wm-titlebar {", "height:")
    val window_min_width_px = _first_int_after(css, ".wm-window {", "min-width:")
    val window_min_height_px = _first_int_after(css, ".wm-window {", "min-height:")
    val title_input_min_width_px = _first_int_after(css, ".wm-title-input", "min-width:")
    val taskbar_icon_size_px = _first_int_after(css, ".wm-taskbar-icon {", "width:")
    val taskbar_preview_max_width_px = _first_int_after(css, ".wm-taskbar-preview {", "width: min(")
    val top_menu_bar_height_px = _first_int_after(css, ".wm-top-menu-bar {", "min-height:")
    val system_hud_max_width_px = _first_int_after(css, ".wm-system-hud {", "width: min(")
    val privacy_indicator_max_width_px = _first_int_after(css, ".wm-privacy-indicator {", "width: min(")
    val workspace_switcher_max_width_px = _first_int_after(css, ".wm-workspace-switcher {", "width: min(")
    val clipboard_history_max_width_px = _first_int_after(css, ".wm-clipboard-history {", "width: min(")
    val screen_capture_max_width_px = _first_int_after(css, ".wm-screen-capture-overlay {", "width: min(")
    val quick_settings_max_width_px = _first_int_after(css, ".wm-quick-settings {", "width: min(")
    val notification_center_max_width_px = _first_int_after(css, ".wm-notification-center {", "width: min(")
    val live_activity_max_width_px = _first_int_after(css, ".wm-live-activity {", "width: min(")
    val hot_corner_max_size_px = _first_int_after(css, ".wm-hot-corner-zone {", "width:")
    val resize_hud_max_width_px = _first_int_after(css, ".wm-resize-hud {", "width: min(")
    val gesture_hints_max_width_px = _first_int_after(css, ".wm-gesture-hints {", "width: min(")
    val command_palette_max_width_px = _first_int_after(css, ".wm-command-palette {", "width: min(")
    val context_menu_max_width_px = _first_int_after(css, ".wm-window-context-menu {", "width: min(")
    val quality_inspector_max_width_px = _first_int_after(css, ".wm-quality-inspector {", "width: min(")
    val control_center_max_width_px = _first_int_after(css, ".wm-control-center {", "width: min(")
    val desktop_widget_max_width_px = _first_int_after(css, ".wm-desktop-widgets {", "width: min(")
    val widget_gallery_max_width_px = _first_int_after(css, ".wm-widget-gallery {", "width: min(")
    val app_launcher_max_width_px = _first_int_after(css, ".wm-app-launcher-grid {", "width: min(")
    val wallpaper_picker_max_width_px = _first_int_after(css, ".wm-wallpaper-picker {", "width: min(")
    val accent_palette_max_width_px = _first_int_after(css, ".wm-accent-palette {", "width: min(")
    val dock_stack_max_width_px = _first_int_after(css, ".wm-dock-stack {", "width: min(")
    val stage_rail_max_width_px = _first_int_after(css, ".wm-stage-rail {", "width: min(")
    val window_switcher_max_width_px = _first_int_after(css, ".wm-window-switcher {", "width: min(")
    val overview_card_min_width_px = _first_int_after(css, ".wm-overview-grid", "minmax(")
    val touch_target_min_height_px = _first_int_after(css, ".wm-command-item {", "min-height:")
    val size_layout_configured = titlebar_height_px >= 38 and window_min_width_px >= 200 and window_min_height_px >= 120 and title_input_min_width_px >= 140 and taskbar_icon_size_px >= 26
    val stable_layout = _has_all(css, ["grid-template-columns: auto auto minmax(96px, 0.7fr) minmax(140px, 1fr) auto", "min-width: 200px", "min-height: 120px", "text-overflow: ellipsis", "max-width: 220px"])
    val rounded_shapes = _has_all(css, ["border-radius: var(--ui-wm-window-radius)", "#wm-taskbar", "border-radius: 999px", ".widget-button", ".widget-input"])
    val round_icon_masking = _has_all(css, [".wm-titlebar-icon", ".wm-taskbar-icon", "object-fit: cover", "border-radius: inherit"])
    val round_icon_converter = _has_all(css, [".wm-round-icon", ".wm-icon-normalized-square", ".wm-icon-image", ".wm-icon-glyph", "clip-path: circle(50% at 50% 50%)"])
    val round_scrollbars = _has_all(css, ["::-webkit-scrollbar-thumb", "background-clip: padding-box", "scrollbar-width: thin", "border-radius: 999px"])
    val translucent_shell = _has_all(css, ["backdrop-filter: blur", "-webkit-backdrop-filter: blur", "rgba(", "linear-gradient"])
    val material_policy_ready = _has_all(css, ["--ui-material-policy: glass-vibrancy", "--ui-glass-blur-px: 24", "--ui-glass-opacity-floor-x100: 6", "--ui-solid-surface-opacity-x100: 96"])
    val transparency_verbosity_control = _has_all(css, ["data-wm-transparency=reduced", "data-wm-transparency=off", "prefers-reduced-transparency: reduce", "backdrop-filter: none !important"])
    val reduced_transparency = _has_all(css, ["--ui-material-policy: reduced-vibrancy", "--ui-glass-blur-px: 10", "--ui-glass-opacity-floor-x100: 72", "blur(10px) saturate(125%)"])
    val solid_material_fallback = _has_all(css, ["--ui-material-policy: solid", "--ui-glass-blur-px: 0", "--ui-glass-opacity-floor-x100: 96", "background-color: rgba(10,10,15,0.96)"])
    val glass_blur_px = _first_int_after(css, ":root {", "--ui-glass-blur-px:")
    val reduced_glass_blur_px = _first_int_after(css, ":root[data-wm-transparency=reduced]", "--ui-glass-blur-px:")
    val glass_opacity_floor_x100 = _first_int_after(css, ":root {", "--ui-glass-opacity-floor-x100:")
    val solid_surface_opacity_x100 = _first_int_after(css, ":root {", "--ui-solid-surface-opacity-x100:")
    val lifecycle_motion = _has_all(css, ["@keyframes wm-window-open", "@keyframes wm-window-close", "@keyframes wm-window-minimize", "@keyframes wm-bg-drift"])
    val lifecycle_motion_profile_ready = _has_all(css, ["--ui-motion-open-ms: 260", "--ui-motion-close-ms: 180", "--ui-motion-minimize-ms: 210", "--ui-motion-spring: cubic-bezier(0.18, 0.89, 0.28, 1.12)", "--ui-motion-exit: cubic-bezier(0.4, 0, 1, 1)", "calc(var(--ui-motion-open-ms) * 1ms)", "calc(var(--ui-motion-close-ms) * 1ms)", "calc(var(--ui-motion-minimize-ms) * 1ms)", ":root[data-wm-motion=reduced] { --ui-motion-open-ms: 120", ":root[data-wm-motion=off] { --ui-motion-open-ms: 0", "scale(1.012)", "translate3d(0,42px,0) scale(0.72)"])
    val widget_motion = _has_all(css, ["@keyframes widget-pop-in", ".widget-panel:hover", ".widget-dialog", "transform: translateY(-3px) scale(1.04)"])
    val reduced_motion = css.contains("prefers-reduced-motion: reduce")
    val motion_verbosity_control = _has_all(css, ["data-wm-motion=reduced", "data-wm-motion=off", "data-wm-quiet-mode=on", "--ui-quiet-mode: on", "data-wm-energy=low", "data-wm-energy=critical", "--ui-energy-policy: critical-saver", "--ui-energy-motion-scale-x100: 0", "--ui-backdrop-duration-ms: 0", "--ui-titlebar-context-opacity-x100: 0", "data-wm-backdrop-intensity=quiet", "--ui-backdrop-intensity: quiet", "--ui-backdrop-saturation-x100: 70", "--ui-backdrop-drift-scale-x100", "scale(calc(var(--ui-backdrop-drift-scale-x100", ":root[data-wm-quiet-mode=on] #wm-desktop::before", ":root[data-wm-quiet-mode=on] #wm-taskbar", ":root[data-wm-energy=critical] #wm-desktop::before", ":root[data-wm-backdrop-motion=static] #wm-desktop::before", ":root[data-wm-backdrop-intensity=quiet] #wm-desktop::before", "transition-duration: 80ms", "transition: none !important"])
    val preview = generate_wm_modern_preview_html(theme)
    val js = _read_wm_js_source()
    val preview_fixture_ready = _has_all(preview, ["data-preview=\"modern-wm\"", "wm-window focused opening", "wm-title-input wm-command-bar", "widget-panel focused", "wm-taskbar-item active", "wm-icon-normalized-square", "wm-command-palette"])
    val command_context_ready = _has_all(css, [".wm-title-context", ".wm-titlebar", ".wm-title", ".wm-body", ".wm-command-bar"])
    val command_palette_ready = _has_all(css, [".wm-command-palette", ".wm-command-palette-input", ".wm-command-palette-list", ".wm-command-item", ".wm-command-shortcut"])
    val command_palette_grouping_ready = _has_all(css, [".wm-command-recents", ".wm-command-recent", ".wm-command-recent:hover", ".wm-command-recent-icon", ".wm-command-section"]) and _has_all(preview, ["aria-label=\"Recent commands\"", "wm-command-recent", "wm-command-section", "data-command-category=\"Apps\"", "data-command-category=\"System\"", "Open quality inspector"]) and _has_all(js, ["category: 'Apps'", "category: 'System'", "category: 'Appearance'", "category: 'Quality'", "_renderCommandPaletteRecents", "wm-command-section", "wm-command-recents", "wm-command-recent", "dataset.commandCategory"])
    val context_menu_ready = context_menu_max_width_px <= 280 and _has_all(css, [".wm-window-context-menu", ".wm-window-context-menu[hidden]", ".wm-window-context-title", ".wm-window-context-item", ".wm-window-context-shortcut", "@keyframes wm-context-menu-in"]) and _has_all(preview, ["role=\"menu\" aria-label=\"Window context menu\"", "wm-window-context-item active", "data-context-action=\"focus\"", "data-context-action=\"snap_left\"", "data-context-action=\"snap_right\"", "data-context-action=\"close\""])
    val context_menu_actions_ready = _has_all(css, [".wm-window-context-group", ".wm-window-context-group:first-of-type", ".wm-window-context-item:hover"]) and _has_all(preview, ["role=\"group\" aria-label=\"Window actions\"", "role=\"group\" aria-label=\"Layout actions\"", "role=\"group\" aria-label=\"Utility actions\"", "data-context-action=\"minimize\"", "data-context-action=\"pin_stage\"", "data-context-action=\"snap_full\"", "data-context-action=\"move_workspace\"", "data-context-action=\"copy_title\"", "Pin to Stage", "Move to workspace", "Copy title"]) and _has_all(js, ["_ensureWindowContextMenu", "_showWindowContextMenu", "_renderWindowContextMenu", "_windowContextMenuGroups", "_makeWindowContextItem", "_activateWindowContextAction", "contextmenu", "stage_pin", "window_move_workspace", "window_copy_title"])
    val context_menu_keyboard_ready = _has_all(css, [".wm-window-context-item:focus-visible", "outline-offset: 2px"]) and _has_all(js, ["_handleWindowContextMenuKeydown", "_moveWindowContextMenuSelection", "_focusWindowContextMenuItem", "ArrowDown", "ArrowUp", "Home", "End", "event.key === 'Enter'", "event.key === ' '"])
    val context_menu_workspace_targets_ready = _has_all(css, [".wm-window-context-item[data-context-workspace-id]", "padding-left: 18px"]) and _has_all(preview, ["role=\"group\" aria-label=\"Move to workspace\"", "data-context-workspace-id=\"main\"", "data-context-workspace-id=\"focus\"", "data-context-workspace-id=\"review\"", "Move to Main", "Move to Focus", "Move to Review"]) and _has_all(js, ["workspaceId: workspace.id", "button.dataset.contextWorkspaceId", "item.dataset.contextWorkspaceId", "const targetWorkspace = workspaceId || this._activeWorkspaceId", "workspace_id: targetWorkspace"])
    val context_menu_visuals_ready = _has_all(css, [".wm-window-context-header", ".wm-window-context-icon", ".wm-window-context-heading", ".wm-window-context-status", ".wm-window-context-glyph", ".wm-window-context-label", "grid-template-columns: 24px minmax(0, 1fr) auto"]) and _has_all(preview, ["wm-window-context-header", "wm-window-context-icon wm-round-icon", "wm-window-context-status", "Active window", "wm-window-context-glyph wm-round-icon", "wm-window-context-label"]) and _has_all(js, ["_makeWindowContextHeader", "_makeRoundIcon('wm-window-context-icon'", "wm-window-context-status", "wm-window-context-glyph wm-round-icon", "wm-window-context-label"])
    val quality_inspector_ready = quality_inspector_max_width_px <= 420 and _has_all(css, [".wm-quality-inspector", ".wm-quality-inspector[hidden]", ".wm-quality-grid", ".wm-quality-row", ".wm-quality-row.good", ".wm-quality-row.warn", ".wm-quality-label", ".wm-quality-value", "@keyframes wm-quality-inspector-in"]) and _has_all(preview, ["role=\"dialog\" aria-label=\"GUI quality inspector\"", "data-quality-check=\"color\"", "data-quality-check=\"touch\"", "data-quality-check=\"titlebar\"", "data-quality-check=\"input\"", "data-quality-check=\"bounds\"", "data-quality-check=\"motion\"", "data-quality-check=\"material\"", "Color contrast", "Touch target"]) and _has_all(js, ["_ensureQualityInspector", "_toggleQualityInspector", "_renderQualityInspector", "_qualityInspectorItems", "_makeQualityInspectorRow", "_qualityContrastRatio", "_qualityLuminance", "Open quality inspector", "Cmd Shift I", "wantsQualityInspector"])
    val quality_inspector_summary_ready = _has_all(css, [".wm-quality-summary", ".wm-quality-summary-metric", ".wm-quality-summary-label", ".wm-quality-summary-value", "grid-template-columns: repeat(3, minmax(0, 1fr))"]) and _has_all(preview, ["wm-quality-summary", "data-quality-score=\"100\"", "wm-quality-summary-metric", "wm-quality-summary-label", "wm-quality-summary-value", "Score", "Checks", "Contrast"]) and _has_all(js, ["_makeQualitySummary", "_makeQualitySummaryMetric", "dataset.qualityScore", "const score = Math.round", "passed + '/' + total"])
    val quality_inspector_details_ready = _has_all(css, [".wm-quality-details", ".wm-quality-swatches", ".wm-quality-swatch", ".wm-quality-swatch-chip", ".wm-quality-metrics", ".wm-quality-metric", ".wm-quality-metric-value"]) and _has_all(preview, ["wm-quality-details", "data-quality-swatch=\"background\"", "data-quality-swatch=\"text\"", "data-quality-swatch=\"accent\"", "data-quality-metric=\"safe_area\"", "data-quality-metric=\"panel_gap\"", "data-quality-metric=\"min_touch\"", "Safe area", "Panel gap", "Min touch"]) and _has_all(js, ["_makeQualityDetailPanel", "_makeQualitySwatches", "_makeQualityMetric", "_qualityCssPx", "--ui-layout-safe-area-px", "--ui-layout-panel-gap-px", "--ui-layout-min-touch-target-px"])
    val quality_inspector_policy_ready = _has_all(css, [".wm-quality-audit-policy", ".wm-quality-policy-item", ".wm-quality-policy-label", ".wm-quality-policy-value", "grid-template-columns: repeat(2, minmax(0, 1fr))"]) and _has_all(preview, ["wm-quality-audit-policy", "data-quality-policy=\"contrast\"", "data-quality-policy=\"layout\"", "data-quality-policy=\"touch\"", "data-quality-policy=\"bounds\"", "WCAG contrast", "&gt;= 4.5:1", "Layout tokens", "safe 16px / gap 12px", "Touch target", "&gt;= 44px", "Panel bounds", "&lt;= 680px"]) and _has_all(js, ["_makeQualityAuditPolicy", "WCAG contrast", "Layout tokens", "Touch target", "Panel bounds"])
    val quality_inspector_actions_ready = _has_all(css, [".wm-quality-actions", ".wm-quality-action", ".wm-quality-action:hover", ".wm-quality-action:focus-visible"]) and _has_all(preview, ["role=\"group\" aria-label=\"Quality inspector actions\"", "data-quality-action=\"motion\"", "data-quality-action=\"material\"", "data-quality-action=\"energy_low\"", "data-quality-action=\"energy_critical\"", "data-quality-action=\"layout\"", "data-quality-action=\"contrast\"", "Reduce motion", "Reduce glass", "Low power", "Critical saver", "Open layout tools", "Accent palette"]) and _has_all(js, ["_makeQualityActions", "_activateQualityInspectorAction", "data-quality-action", "quality_action", "setMotionPreference('reduced')", "setTransparencyPreference('reduced')", "setEnergyPreference('low')", "setEnergyPreference('critical')", "_toggleWindowArrangePalette(true)", "_toggleAccentPalette(true)"])
    val quality_inspector_filters_ready = _has_all(css, [".wm-quality-filters", ".wm-quality-filter", ".wm-quality-filter:hover", ".wm-quality-filter.active", "grid-template-columns: repeat(5, minmax(0, 1fr))"]) and _has_all(preview, ["role=\"group\" aria-label=\"Quality filters\"", "data-quality-filter=\"all\"", "data-quality-filter=\"layout\"", "data-quality-filter=\"visual\"", "data-quality-filter=\"motion\"", "data-quality-filter=\"material\"", "All", "Layout", "Visual", "Motion", "Material"]) and _has_all(js, ["_qualityFilterItems", "_makeQualityFilters", "_setQualityFilter", "_filteredQualityItems", "dataset.qualityFilter", "quality_filter", "category: 'layout'", "category: 'visual'"])
