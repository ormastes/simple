fn _quality_notes(passed: bool, contrast_delta: i64) -> [text]:
    var notes: [text] = []
    if passed:
        notes = notes.push("quality contract passed")
    else:
        notes = notes.push("quality contract failed")
    notes = notes.push("contrast_delta={contrast_delta}")
    notes

fn _read_wm_js_source() -> text:
    val current_dir = cwd()
    val from_cwd = file_read("{current_dir}/src/app/ui.web/wm.js")
    if from_cwd.len() > 0:
        return from_cwd
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib.len() > 0:
        val from_lib = file_read("{lib}/app/ui.web/wm.js")
        if from_lib.len() > 0:
            return from_lib
        val from_cwd_lib = file_read("{current_dir}/{lib}/app/ui.web/wm.js")
        if from_cwd_lib.len() > 0:
            return from_cwd_lib
    val repo_root = file_read("src/app/ui.web/wm.js")
    if repo_root.len() > 0:
        return repo_root
    val build_tmp = file_read("../../src/app/ui.web/wm.js")
    if build_tmp.len() > 0:
        return build_tmp
    val nested_test = file_read("../../../../src/app/ui.web/wm.js")
    if nested_test.len() > 0:
        return nested_test
    ""

fn _read_wm_html_source() -> text:
    val current_dir = cwd()
    val from_cwd = file_read("{current_dir}/src/app/ui.web/html.spl")
    if from_cwd.len() > 0:
        return from_cwd
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib.len() > 0:
        val from_lib = file_read("{lib}/app/ui.web/html.spl")
        if from_lib.len() > 0:
            return from_lib
        val from_cwd_lib = file_read("{current_dir}/{lib}/app/ui.web/html.spl")
        if from_cwd_lib.len() > 0:
            return from_cwd_lib
    val repo_root = file_read("src/app/ui.web/html.spl")
    if repo_root.len() > 0:
        return repo_root
    val build_tmp = file_read("../../src/app/ui.web/html.spl")
    if build_tmp.len() > 0:
        return build_tmp
    val nested_test = file_read("../../../../src/app/ui.web/html.spl")
    if nested_test.len() > 0:
        return nested_test
    ""

fn _contrast_ratio_x100(a: text, b: text) -> i64:
    val la = _relative_luminance_x1000(a)
    val lb = _relative_luminance_x1000(b)
    if la > lb:
        ((la + 50) * 100) / (lb + 50)
    else:
        ((lb + 50) * 100) / (la + 50)

fn _relative_luminance_x1000(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _linear_channel_x1000(_hex_pair(v, 1))
    val g = _linear_channel_x1000(_hex_pair(v, 3))
    val b = _linear_channel_x1000(_hex_pair(v, 5))
    ((r * 2126) + (g * 7152) + (b * 722)) / 10000

fn _linear_channel_x1000(channel: i64) -> i64:
    if channel <= 10:
        (channel * 1000) / 3294
    else:
        val srgb_x1000 = (channel * 1000) / 255
        val c = ((srgb_x1000 + 55) * 1000) / 1055
        (c * c) / 1000

fn _hex_pair(hex: text, start: i64) -> i64:
    _hex_digit(hex.substring(start, start + 1)) * 16 + _hex_digit(hex.substring(start + 1, start + 2))

fn _first_int_after(css: text, scope_marker: text, value_marker: text) -> i64:
    val scope_idx = css.index_of(scope_marker) ?? -1
    if scope_idx < 0:
        return 0
    val scoped = css.substring(scope_idx)
    val value_idx = scoped.index_of(value_marker) ?? -1
    if value_idx < 0:
        return 0
    val tail = scoped.substring(value_idx + value_marker.len())
    var started = false
    var value: i64 = 0
    for ch in tail:
        if ch >= "0" and ch <= "9":
            started = true
            value = value * 10 + (ch.to_i64() - "0".to_i64())
        else:
            if started:
                return value
    value

fn _has_all(css: text, needles: [text]) -> bool:
    for needle in needles:
        if not css.contains(needle):
            return false
    true

fn _css_var(css: text, name: text) -> text:
    val marker = "{name}:"
    val idx = css.index_of(marker) ?? -1
    if idx < 0:
        return ""
    val after = css.substring(idx + marker.len())
    val end = after.index_of(";") ?? after.len()
    after.substring(0, end).trim()

fn _brightness_delta(a: text, b: text) -> i64:
    val ba = _hex_brightness(a)
    val bb = _hex_brightness(b)
    if ba > bb:
        ba - bb
    else:
        bb - ba

fn _hex_brightness(hex: text) -> i64:
    val v = hex.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0
    val r = _hex_digit(v.substring(1, 2)) * 16 + _hex_digit(v.substring(2, 3))
    val g = _hex_digit(v.substring(3, 4)) * 16 + _hex_digit(v.substring(4, 5))
    val b = _hex_digit(v.substring(5, 6)) * 16 + _hex_digit(v.substring(6, 7))
    ((r * 299) + (g * 587) + (b * 114)) / 1000

fn _hex_digit(ch: text) -> i64:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    val lower = ch.to_lower()
    if lower == "a":
        return 10
    if lower == "b":
        return 11
    if lower == "c":
        return 12
    if lower == "d":
        return 13
    if lower == "e":
        return 14
    if lower == "f":
        return 15
    0
