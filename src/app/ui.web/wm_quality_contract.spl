    dock_stack_max_width_px: i64
    stage_rail_max_width_px: i64
    window_switcher_max_width_px: i64
    overview_card_min_width_px: i64
    touch_target_min_height_px: i64
    rounded_shapes: bool
    round_icon_masking: bool
    round_icon_converter: bool
    round_scrollbars: bool
    translucent_shell: bool
    material_policy_ready: bool
    transparency_verbosity_control: bool
    reduced_transparency: bool
    solid_material_fallback: bool
    glass_blur_px: i64
    reduced_glass_blur_px: i64
    glass_opacity_floor_x100: i64
    solid_surface_opacity_x100: i64
