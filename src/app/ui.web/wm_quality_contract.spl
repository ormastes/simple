    context_menu_keyboard_ready: bool
    context_menu_workspace_targets_ready: bool
    context_menu_visuals_ready: bool
    quality_inspector_ready: bool
    quality_inspector_summary_ready: bool
    quality_inspector_details_ready: bool
    quality_inspector_policy_ready: bool
    quality_inspector_actions_ready: bool
    quality_inspector_filters_ready: bool
    quality_inspector_check_detail_ready: bool
    quality_inspector_audit_mode_ready: bool
    quality_inspector_guidance_ready: bool
    quality_inspector_fix_action_ready: bool
    quality_inspector_motion_preview_ready: bool
    quality_inspector_motion_samples_ready: bool
    quality_inspector_motion_policy_ready: bool
