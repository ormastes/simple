    parts = parts.push(":root[data-wm-transparency=reduced] .wm-top-menu-bar, :root[data-wm-transparency=reduced] .wm-window, :root[data-wm-transparency=reduced] .widget-panel, :root[data-wm-transparency=reduced] .widget-dialog, :root[data-wm-transparency=reduced] .wm-command-palette, :root[data-wm-transparency=reduced] .wm-window-arrange-palette, :root[data-wm-transparency=reduced] .wm-control-center, :root[data-wm-transparency=reduced] .wm-window-overview, :root[data-wm-transparency=reduced] .wm-stage-rail, :root[data-wm-transparency=reduced] .wm-window-switcher, :root[data-wm-transparency=reduced] .wm-workspace-switcher, :root[data-wm-transparency=reduced] .wm-clipboard-history, :root[data-wm-transparency=reduced] .wm-screen-capture-overlay, :root[data-wm-transparency=reduced] .wm-quick-settings, :root[data-wm-transparency=reduced] .wm-notification-center, :root[data-wm-transparency=reduced] .wm-live-activity, :root[data-wm-transparency=reduced] .wm-hot-corner-hint, :root[data-wm-transparency=reduced] .wm-resize-hud, :root[data-wm-transparency=reduced] .wm-gesture-hints, :root[data-wm-transparency=reduced] .wm-system-hud, :root[data-wm-transparency=reduced] .wm-privacy-indicator, :root[data-wm-transparency=reduced] .wm-app-launcher, :root[data-wm-transparency=reduced] .wm-dock-stack, :root[data-wm-transparency=reduced] .wm-accent-palette, :root[data-wm-transparency=reduced] .wm-wallpaper-picker, :root[data-wm-transparency=reduced] .wm-shortcut-overlay, :root[data-wm-transparency=reduced] .wm-window-context-menu, :root[data-wm-transparency=reduced] .wm-title-suggestions, :root[data-wm-transparency=reduced] .wm-widget-gallery, :root[data-wm-transparency=reduced] .wm-taskbar-preview, :root[data-wm-transparency=reduced] #wm-taskbar { backdrop-filter: blur(10px) saturate(125%); -webkit-backdrop-filter: blur(10px) saturate(125%); }\n")
    parts = parts.push(":root[data-wm-transparency=off] .wm-top-menu-bar, :root[data-wm-transparency=off] .wm-window, :root[data-wm-transparency=off] .widget-panel, :root[data-wm-transparency=off] .widget-dialog, :root[data-wm-transparency=off] .wm-command-palette, :root[data-wm-transparency=off] .wm-window-arrange-palette, :root[data-wm-transparency=off] .wm-control-center, :root[data-wm-transparency=off] .wm-window-overview, :root[data-wm-transparency=off] .wm-stage-rail, :root[data-wm-transparency=off] .wm-window-switcher, :root[data-wm-transparency=off] .wm-workspace-switcher, :root[data-wm-transparency=off] .wm-clipboard-history, :root[data-wm-transparency=off] .wm-screen-capture-overlay, :root[data-wm-transparency=off] .wm-quick-settings, :root[data-wm-transparency=off] .wm-notification-center, :root[data-wm-transparency=off] .wm-live-activity, :root[data-wm-transparency=off] .wm-hot-corner-hint, :root[data-wm-transparency=off] .wm-resize-hud, :root[data-wm-transparency=off] .wm-gesture-hints, :root[data-wm-transparency=off] .wm-system-hud, :root[data-wm-transparency=off] .wm-privacy-indicator, :root[data-wm-transparency=off] .wm-app-launcher, :root[data-wm-transparency=off] .wm-dock-stack, :root[data-wm-transparency=off] .wm-accent-palette, :root[data-wm-transparency=off] .wm-wallpaper-picker, :root[data-wm-transparency=off] .wm-shortcut-overlay, :root[data-wm-transparency=off] .wm-window-context-menu, :root[data-wm-transparency=off] .wm-title-suggestions, :root[data-wm-transparency=off] .wm-widget-gallery, :root[data-wm-transparency=off] .wm-taskbar-preview, :root[data-wm-transparency=off] #wm-taskbar { background-color: rgba(10,10,15,0.96); background: rgba(10,10,15,0.96); backdrop-filter: none !important; -webkit-backdrop-filter: none !important; }\n")
    parts = parts.push("@media (prefers-reduced-motion: reduce) { #wm-desktop::before, .wm-top-menu-bar, .wm-top-menu-item, .wm-window, .wm-window.opening, .wm-window.restoring, .wm-window.closing, .wm-window.minimizing, .wm-taskbar-item, .wm-taskbar-badge, .wm-taskbar-preview, .wm-system-hud, .wm-system-hud-meter, .wm-privacy-indicator, .wm-privacy-dot, .widget-panel, .widget-dialog, .wm-title-input, .wm-command-bar, .wm-command-palette, .wm-snap-preview, .wm-ghost, .wm-snap-layout-palette, .wm-snap-layout-choice, .wm-window-arrange-palette, .wm-arrange-mode, .wm-desktop-widget, .wm-desktop-item, .wm-desktop-drop-target, .wm-control-center, .wm-control-button, .wm-window-overview, .wm-overview-card, .wm-stage-rail, .wm-stage-rail-item, .wm-window-switcher, .wm-window-switcher-card, .wm-workspace-switcher, .wm-workspace-card, .wm-clipboard-history, .wm-clipboard-item, .wm-screen-capture-overlay, .wm-capture-mode, .wm-capture-action, .wm-quick-settings, .wm-quick-setting, .wm-notification-center, .wm-notification-card, .wm-live-activity, .wm-live-activity-bar, .wm-app-launcher, .wm-dock-stack, .wm-quality-inspector, .wm-accent-palette, .wm-wallpaper-picker, .wm-wallpaper-swatch, .wm-shortcut-overlay, .wm-window-context-menu, .wm-title-suggestions, .wm-widget-gallery { animation: none !important; transition: none !important; transform: none !important; filter: none !important; } }\n")
    parts = parts.push("@media (prefers-reduced-transparency: reduce) { .wm-top-menu-bar, .wm-window, .widget-panel, .widget-dialog, .wm-command-palette, .wm-window-arrange-palette, .wm-control-center, .wm-window-overview, .wm-stage-rail, .wm-window-switcher, .wm-workspace-switcher, .wm-clipboard-history, .wm-screen-capture-overlay, .wm-quick-settings, .wm-notification-center, .wm-live-activity, .wm-hot-corner-hint, .wm-resize-hud, .wm-gesture-hints, .wm-system-hud, .wm-privacy-indicator, .wm-app-launcher, .wm-dock-stack, .wm-quality-inspector, .wm-accent-palette, .wm-wallpaper-picker, .wm-shortcut-overlay, .wm-window-context-menu, .wm-title-suggestions, .wm-widget-gallery, .wm-taskbar-preview, #wm-taskbar { backdrop-filter: none; -webkit-backdrop-filter: none; } }\n")

    var result = parts.join("")

    # Append iOS overrides when using an iOS theme
    val ios_css = generate_ios_css(theme)
    if ios_css != "":
        result = "{result}{ios_css}"

    # Append Glass overrides when using a glass theme
    val glass_css = generate_glass_css(theme)
    if glass_css != "":
        result = "{result}{glass_css}"

    # Folder-based theme package CSS is temporarily disabled: theme_package.spl
    # depends on UITheme/UIThemeColors/BorderStyle/FontStyle from common.ui.style,
    # which the 2cca0bc style.spl rewrite removed (subsystem orphaned). The
    # generated defaults + glass CSS above already provide full widget styling.
    # TODO(theme): restore UITheme types in common.ui.style and re-enable
    # resolved_theme_css(theme) here.

    # Apply theme colors — interpolation doesn't work inside .push() calls,
    # so we replace template placeholders with actual color values here.
    val p_bg = "{" + "bg" + "}"
    val p_fg = "{" + "fg" + "}"
    val p_border = "{" + "border_color" + "}"
    val p_accent = "{" + "accent" + "}"
    val p_accent_rgb = "{" + "accent_rgb" + "}"
    val p_panel = "{" + "panel_bg" + "}"
    val p_hover = "{" + "hover_bg" + "}"
    val p_success = "{" + "success" + "}"
    val p_error = "{" + "error" + "}"
    val p_warning = "{" + "warning" + "}"
    val p_dim = "{" + "dim_fg" + "}"
    val p_surface = "{" + "surface_bg" + "}"
    val p_body_background = "{" + "body_background" + "}"
    val p_font_sans = "{" + "ui_font_sans" + "}"
    val p_font_display = "{" + "ui_font_display" + "}"
    val p_font_body = "{" + "ui_font_body" + "}"
    val p_font_label = "{" + "ui_font_label" + "}"
    val p_wm_window_radius = "{" + "wm_window_radius" + "}"
    result = result.replace(p_bg, bg)
    result = result.replace(p_fg, fg)
    result = result.replace(p_border, border_color)
    result = result.replace(p_accent, accent)
    result = result.replace(p_accent_rgb, accent_rgb)
    result = result.replace(p_panel, panel_bg)
    result = result.replace(p_hover, hover_bg)
    result = result.replace(p_success, success)
    result = result.replace(p_error, error)
    result = result.replace(p_warning, warning)
    result = result.replace(p_dim, dim_fg)
    result = result.replace(p_surface, surface_bg)
    result = result.replace(p_body_background, body_background)
    result = result.replace(p_bg, bg)
    result = result.replace(p_surface, surface_bg)
    result = result.replace(p_accent_rgb, accent_rgb)
    result = result.replace(p_font_sans, ui_font_sans)
    result = result.replace(p_font_display, ui_font_display)
    result = result.replace(p_font_body, ui_font_body)
    result = result.replace(p_font_label, ui_font_label)
    result = result.replace(p_wm_window_radius, wm_window_radius)
    if is_glass:
        result = "{result}\n/* Glass theme touch-up */\n"
        result = "{result}.widget-panel, .widget-menubar, .widget-statusbar, .widget-dialog, .widget-list, .widget-tabs { backdrop-filter: blur(28px) saturate(175%); -webkit-backdrop-filter: blur(28px) saturate(175%); }\n"
        result = "{result}.widget-button { background-image: linear-gradient(180deg, rgba(255,255,255,0.20), rgba(255,255,255,0.08)); }\n"
        result = "{result}.widget-input, .widget-textfield, .widget-textarea, .widget-dropdown { box-shadow: inset 0 1px 0 rgba(255,255,255,0.08); }\n"
        result = "{result}#app { padding-top: calc(16px + env(safe-area-inset-top)); }\n"
        result = "{result}.widget-menubar { position: sticky; top: calc(6px + env(safe-area-inset-top)); z-index: 120; padding-left: 56px; }\n"
        result = "{result}.widget-menubar { position: relative; padding-left: 70px; }\n"
        result = "{result}.widget-menubar::before { content: ''; position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 44px; height: 12px; pointer-events: none; background: radial-gradient(circle at 6px 6px, {wm_close} 5px, transparent 5px), radial-gradient(circle at 22px 6px, {wm_min} 5px, transparent 5px), radial-gradient(circle at 38px 6px, {wm_max} 5px, transparent 5px); }\n"
        result = "{result}@keyframes glass-appear { 0% { opacity: 1; transform: translateY(10px) scale(0.985); } 100% { opacity: 1; transform: translateY(0) scale(1); } }\n"
        result = "{result}.widget-panel { animation: glass-appear 420ms cubic-bezier(0.22, 0.8, 0.2, 1) both; transform-origin: 50% 12%; }\n"
        result = "{result}.widget-panel:nth-of-type(2) { animation-delay: 40ms; }\n"
        result = "{result}.widget-panel:nth-of-type(3) { animation-delay: 80ms; }\n"
        result = "{result}.widget-panel:hover { box-shadow: 0 26px 66px rgba(0,0,0,0.26), 0 0 0 1px rgba(255,255,255,0.12), inset 0 1px 0 rgba(255,255,255,0.14); }\n"
        result = "{result}@media (prefers-reduced-motion: reduce) { .widget-panel { animation: none; } }\n"

    # Responsive / multi-profile layout. Breakpoints mirror the planned
    # LayoutProfile in common/ui/profile.spl (compact <= 600, regular <= 1200,
    # expanded > 1200). The webview knows its real device width, so CSS @media
    # selects the size class client-side — combined with the device-width
    # viewport meta this makes the phone (compact) layout readable instead of a
    # shrunk-down desktop page.
    result = "{result}{responsive_css()}"

    result = result.replace("{" + "wm_close" + "}", WM_TRAFFIC_CLOSE)
    result = result.replace("{" + "wm_min" + "}", WM_TRAFFIC_MIN)
    result = result.replace("{" + "wm_max" + "}", WM_TRAFFIC_MAX)
    result = result.replace("{" + "wm_close_hover" + "}", WM_TRAFFIC_CLOSE_HOVER)
    result = result.replace("{" + "wm_min_hover" + "}", WM_TRAFFIC_MIN_HOVER)
    result = result.replace("{" + "wm_max_hover" + "}", WM_TRAFFIC_MAX_HOVER)

    return result

fn responsive_css() -> text:
    """Responsive layout rules keyed off the planned LayoutProfile breakpoints
    (common/ui/profile.spl: compact <= 600px, regular <= 1200px, expanded > 1200).

    Compact (phone): single column, full-bleed panels, 16px base font (also
    stops iOS from zooming on input focus), 44px minimum touch targets, stacked
    rows. Regular (tablet) keeps a roomier single/again-flowing layout. Expanded
    (desktop) keeps the default multi-column layout."""
    var r = ""
    # --- Compact: phones (<= 600px) ---
    r = "{r}@media (max-width: 600px) { "
    r = "{r}html { font-size: 16px; } "
    r = "{r}#app { padding: 14px 12px; gap: 12px; } "
    r = "{r}.layout-hbox { flex-direction: column; align-items: stretch; } "
    r = "{r}.layout-grid { grid-template-columns: 1fr; } "
    r = "{r}.widget-panel, .widget-card { width: 100%; border-radius: 16px; } "
    r = "{r}.widget-navigation-bar { font-size: 17px; padding: 10px 14px; } "
    r = "{r}.widget-heading, h1, h2 { font-size: 22px; line-height: 1.25; } "
    r = "{r}.widget-button, .widget-checkbox, .widget-radio, .widget-radio-option, .widget-switch, .widget-dropdown, .widget-tab, input, select, textarea { min-height: 44px; font-size: 16px; } "
    r = "{r}.widget-button { padding: 12px 16px; width: 100%; } "
    r = "{r}.widget-input, .widget-textfield, input[type=\"text\"], input[type=\"search\"] { width: 100%; font-size: 16px; } "
    r = "{r}.widget-list .list-item, .widget-table td { padding: 12px 10px; } "
    r = "{r}.widget-statusbar { font-size: 13px; } "
    r = "{r}.widget-sidebar { display: none; } "
    r = "{r}}\n"
    # --- Regular: small tablets / split view (601-1200px) ---
    r = "{r}@media (min-width: 601px) and (max-width: 1200px) { "
    r = "{r}.layout-grid { grid-template-columns: repeat(2, 1fr); } "
    r = "{r}.widget-button, input, select, textarea { min-height: 40px; } "
    r = "{r}}\n"
    return r

# =========================================================================
# JavaScript (WebSocket client)
# =========================================================================

fn generate_js(ws_port: i32) -> text:
    """Generate JavaScript for WebSocket communication and interactive widget events.
    Handles keyboard, mouse clicks, focus, and widget-specific interactions
    consistently across Web, Electron, and Tauri backends."""
    # Use lb/rb for JS object literal braces to avoid Simple interpolation
    val lb = "\u{007b}"
    val rb = "\u{007d}"
    var js = "const wsProto = location.protocol === 'https:' ? 'wss' : 'ws';\n"
    js = "{js}const wsHost = location.host ? location.host : ('localhost:' + {ws_port} + '');\n"
    js = "{js}const wsUrl = wsProto + '://' + wsHost + '/ws';\n"
    js = "{js}let ws = null;\n"
    js = "{js}let currentFocusId = '';\n"

    # WebSocket connection with auto-reconnect
    js = "{js}function connect() {lb}\n"
    js = "{js}  ws = new WebSocket(wsUrl);\n"
    js = "{js}  ws.onmessage = function(e) {lb}\n"
    js = "{js}    const data = JSON.parse(e.data);\n"
    js = "{js}    if (data.type === 'render') {lb}\n"
    js = "{js}      document.getElementById('app').innerHTML = data.html;\n"
    js = "{js}      restoreFocus();\n"
    js = "{js}    {rb}\n"
    js = "{js}  {rb};\n"
    js = "{js}  ws.onclose = function() {lb}\n"
    js = "{js}    setTimeout(connect, 2000);\n"
    js = "{js}  {rb};\n"
    js = "{js}{rb}\n"
    js = "{js}connect();\n"

    # Helper: send event to backend
    js = "{js}function sendEvent(evt) {lb}\n"
    js = "{js}  if (ws && ws.readyState === WebSocket.OPEN) {lb}\n"
    js = "{js}    ws.send(JSON.stringify(evt));\n"
    js = "{js}  {rb}\n"
    js = "{js}{rb}\n"

    # Restore focus after re-render
    js = "{js}function restoreFocus() {lb}\n"
    js = "{js}  if (currentFocusId) {lb}\n"
    js = "{js}    var el = document.getElementById(currentFocusId);\n"
    js = "{js}    if (el) el.setAttribute('data-focused', 'true');\n"
    js = "{js}  {rb}\n"
    js = "{js}{rb}\n"

    # Keyboard event forwarding (unchanged behavior, handles TUI-like navigation)
    js = "{js}document.addEventListener('keydown', function(e) {lb}\n"
    js = "{js}  var tag = e.target.tagName.toLowerCase();\n"
    js = "{js}  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;\n"
    js = "{js}  sendEvent({lb}type: 'key', key: e.key{rb});\n"
    js = "{js}  if (['j','k','Tab','Escape',':','i'].indexOf(e.key) >= 0) e.preventDefault();\n"
    js = "{js}{rb});\n"

    # Click event delegation for interactive widgets
    js = "{js}document.addEventListener('click', function(e) {lb}\n"
    js = "{js}  var el = e.target;\n"
    # Button clicks
    js = "{js}  var btn = el.closest('.widget-button');\n"
    js = "{js}  if (btn) {lb}\n"
    js = "{js}    var action = btn.getAttribute('data-action');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action{rb});\n"
    js = "{js}    currentFocusId = btn.id;\n"
    js = "{js}    sendEvent({lb}type: 'focus', id: btn.id{rb});\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Checkbox toggle (div-based custom checkbox)
    js = "{js}  var cb = el.closest('.widget-checkbox');\n"
    js = "{js}  if (cb) {lb}\n"
    js = "{js}    var action = cb.getAttribute('data-action');\n"
    js = "{js}    var isChecked = cb.classList.contains('checked');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action, value: isChecked ? 'false' : 'true'{rb});\n"
    js = "{js}    currentFocusId = cb.id;\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # List item selection
    js = "{js}  var li = el.closest('.list-item');\n"
    js = "{js}  if (li) {lb}\n"
    js = "{js}    var list = li.closest('.widget-list');\n"
    js = "{js}    if (list) {lb}\n"
    js = "{js}      var items = list.querySelectorAll('.list-item');\n"
    js = "{js}      for (var i = 0; i < items.length; i++) {lb}\n"
    js = "{js}        if (items[i] === li) {lb}\n"
    js = "{js}          sendEvent({lb}type: 'action', name: 'select_' + list.id + '_' + i{rb});\n"
    js = "{js}          break;\n"
    js = "{js}        {rb}\n"
    js = "{js}      {rb}\n"
    js = "{js}      currentFocusId = list.id;\n"
    js = "{js}    {rb}\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Tab switching
    js = "{js}  var tab = el.closest('.tab-item');\n"
    js = "{js}  if (tab) {lb}\n"
    js = "{js}    var tabs = tab.parentElement;\n"
    js = "{js}    if (tabs) {lb}\n"
    js = "{js}      var items = tabs.querySelectorAll('.tab-item');\n"
    js = "{js}      for (var i = 0; i < items.length; i++) {lb}\n"
    js = "{js}        items[i].classList.remove('active');\n"
    js = "{js}        if (items[i] === tab) {lb}\n"
    js = "{js}          tab.classList.add('active');\n"
    js = "{js}          sendEvent({lb}type: 'action', name: 'tab_' + tabs.id + '_' + i{rb});\n"
    js = "{js}        {rb}\n"
    js = "{js}      {rb}\n"
    js = "{js}      currentFocusId = tabs.id;\n"
    js = "{js}    {rb}\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Tree node toggle
    js = "{js}  var toggle = el.closest('.tree-toggle');\n"
    js = "{js}  if (toggle) {lb}\n"
    js = "{js}    var action = toggle.getAttribute('data-action');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action{rb});\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Table header sort
    js = "{js}  var th = el.closest('th[data-action]');\n"
    js = "{js}  if (th) {lb}\n"
    js = "{js}    var action = th.getAttribute('data-action');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action{rb});\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Submenu item clicks
    js = "{js}  var sub = el.closest('.submenu-item');\n"
    js = "{js}  if (sub) {lb}\n"
    js = "{js}    var action = sub.getAttribute('data-action');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action{rb});\n"
    js = "{js}    return;\n"
    js = "{js}  {rb}\n"
    # Generic widget focus on click
    js = "{js}  var widget = el.closest('[id]');\n"
    js = "{js}  if (widget && widget.id) {lb}\n"
    js = "{js}    currentFocusId = widget.id;\n"
    js = "{js}    sendEvent({lb}type: 'focus', id: widget.id{rb});\n"
    js = "{js}  {rb}\n"
    js = "{js}{rb});\n"

    # Table filter input handler
    js = "{js}document.addEventListener('input', function(e) {lb}\n"
    js = "{js}  if (e.target.classList.contains('table-filter')) {lb}\n"
    js = "{js}    var action = e.target.getAttribute('data-action');\n"
    js = "{js}    if (action) sendEvent({lb}type: 'action', name: action, value: e.target.value{rb});\n"
    js = "{js}  {rb}\n"
    js = "{js}{rb});\n"

    # Dropdown change handler
    js = "{js}document.addEventListener('change', function(e) {lb}\n"
    js = "{js}  var dd = e.target.closest('.widget-dropdown');\n"
    js = "{js}  if (dd) {lb}\n"
    js = "{js}    sendEvent({lb}type: 'action', name: 'select_' + dd.id + '_' + e.target.selectedIndex{rb});\n"
    js = "{js}  {rb}\n"
    js = "{js}{rb});\n"

    # Input, textfield, textarea value change handlers
    js = "{js}document.addEventListener('change', function(e) {lb}\n"
    js = "{js}  var inp = e.target.closest('.widget-input, .widget-textfield');\n"
    js = "{js}  if (inp && inp.id) sendEvent({lb}type: 'action', name: 'change_' + inp.id, value: e.target.value{rb});\n"
    js = "{js}  var ta = e.target.closest('.widget-textarea');\n"
    js = "{js}  if (ta && ta.id) sendEvent({lb}type: 'action', name: 'change_' + ta.id, value: e.target.value{rb});\n"
    js = "{js}{rb});\n"

    return js
