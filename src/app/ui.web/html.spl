    parts = parts.push(".wm-privacy-actions { display: grid; grid-template-columns: 1fr; gap: 8px; }\n")
    parts = parts.push(".wm-privacy-action { min-height: 36px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.14); color: {fg}; background: rgba(255,255,255,0.08); font-size: 12px; font-weight: 750; }\n")
