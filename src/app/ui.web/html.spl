# HTML Page Generation
#
# Generates complete HTML pages for the web UI renderer,
# including CSS styles and JavaScript for WebSocket communication.

use common.ui.widget.{UIState, UITree}
use app.ui.render.widgets.{render_html_tree}

# =========================================================================
# Full HTML Page
# =========================================================================

fn generate_html_page(state: UIState, ws_port: i32) -> text:
    """Generate a complete HTML page for the UI."""
    val body_html = render_html_tree(state.tree.root, state)
    val css = generate_css(state.tree.theme)
    val js = generate_js(ws_port)
    val title = state.tree.title

    var html = "<!DOCTYPE html>\n"
    html = "{html}<html lang=\"en\">\n"
    html = "{html}<head>\n"
    html = "{html}  <meta charset=\"UTF-8\">\n"
    html = "{html}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html = "{html}  <title>{title}</title>\n"
    html = "{html}  <style>{css}</style>\n"
    html = "{html}</head>\n"
    html = "{html}<body>\n"
    html = "{html}  <div id=\"app\">{body_html}</div>\n"
    html = "{html}  <script>{js}</script>\n"
    html = "{html}</body>\n"
    html = "{html}</html>"
    return html

# =========================================================================
# CSS Styles
# =========================================================================

fn generate_css(theme: text) -> text:
    val bg = if theme == "dark": "#1e1e2e" else: "#ffffff"
    val fg = if theme == "dark": "#cdd6f4" else: "#333333"
    val border_color = if theme == "dark": "#45475a" else: "#cccccc"
    val accent = if theme == "dark": "#89b4fa" else: "#0066cc"
    val panel_bg = if theme == "dark": "#313244" else: "#f5f5f5"
    val hover_bg = if theme == "dark": "#45475a" else: "#e0e0e0"

    var css = "* { margin: 0; padding: 0; box-sizing: border-box; }\n"
    css = "{css}body { background: {bg}; color: {fg}; font-family: 'Fira Code', 'Cascadia Code', monospace; font-size: 14px; height: 100vh; overflow: hidden; }\n"
    css = "{css}#app { display: flex; flex-direction: column; height: 100vh; }\n"

    # Layout classes
    css = "{css}.layout-vbox { display: flex; flex-direction: column; }\n"
    css = "{css}.layout-hbox { display: flex; flex-direction: row; }\n"

    # Widget: Panel
    css = "{css}.widget-panel { border: 1px solid {border_color}; border-radius: 4px; background: {panel_bg}; overflow: hidden; display: flex; flex-direction: column; }\n"
    css = "{css}.widget-panel.focused { border-color: {accent}; box-shadow: 0 0 0 1px {accent}; }\n"
    css = "{css}.panel-title { padding: 4px 8px; font-weight: bold; border-bottom: 1px solid {border_color}; background: {bg}; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: {accent}; }\n"
    css = "{css}.panel-content { padding: 8px; flex: 1; overflow: auto; }\n"

    # Widget: Text
    css = "{css}.widget-text { padding: 4px 8px; }\n"

    # Widget: List
    css = "{css}.widget-list { list-style: none; padding: 4px 0; }\n"
    css = "{css}.widget-list li { padding: 4px 12px; cursor: pointer; }\n"
    css = "{css}.widget-list li:hover { background: {hover_bg}; }\n"

    # Widget: Table
    css = "{css}.widget-table { width: 100%; border-collapse: collapse; }\n"
    css = "{css}.widget-table td, .widget-table th { padding: 6px 12px; border-bottom: 1px solid {border_color}; text-align: left; }\n"

    # Widget: Progress
    css = "{css}.widget-progress { padding: 8px; display: flex; align-items: center; gap: 8px; }\n"
    css = "{css}.progress-bar { height: 8px; background: {accent}; border-radius: 4px; transition: width 0.3s; }\n"

    # Widget: MenuBar
    css = "{css}.widget-menubar { display: flex; padding: 4px 8px; background: {bg}; border-bottom: 1px solid {border_color}; gap: 4px; }\n"
    css = "{css}.menu-item { padding: 4px 12px; cursor: pointer; border-radius: 4px; }\n"
    css = "{css}.menu-item:hover { background: {hover_bg}; }\n"

    # Widget: StatusBar
    css = "{css}.widget-statusbar { display: flex; justify-content: space-between; padding: 4px 12px; background: {accent}; color: {bg}; font-weight: bold; font-size: 12px; }\n"

    # Widget: Input
    css = "{css}.widget-input { padding: 6px 12px; background: {bg}; border: 1px solid {border_color}; color: {fg}; font-family: inherit; font-size: inherit; border-radius: 4px; width: 100%; }\n"
    css = "{css}.widget-input:focus { outline: none; border-color: {accent}; }\n"

    # Widget: Tabs
    css = "{css}.widget-tabs { display: flex; gap: 0; border-bottom: 1px solid {border_color}; }\n"
    css = "{css}.tab-item { padding: 6px 16px; cursor: pointer; border-bottom: 2px solid transparent; }\n"
    css = "{css}.tab-item.active { border-bottom-color: {accent}; color: {accent}; }\n"
    css = "{css}.tab-item:hover { background: {hover_bg}; }\n"

    return css

# =========================================================================
# JavaScript (WebSocket client)
# =========================================================================

fn generate_js(ws_port: i32) -> text:
    var js = "const wsUrl = 'ws://localhost:' + {ws_port} + '/ws';\n"
    js = "{js}let ws = null;\n"
    js = "{js}function connect() {\n"
    js = "{js}  ws = new WebSocket(wsUrl);\n"
    js = "{js}  ws.onmessage = function(e) {\n"
    js = "{js}    const data = JSON.parse(e.data);\n"
    js = "{js}    if (data.type === 'render') {\n"
    js = "{js}      document.getElementById('app').innerHTML = data.html;\n"
    js = "{js}    }\n"
    js = "{js}  };\n"
    js = "{js}  ws.onclose = function() {\n"
    js = "{js}    setTimeout(connect, 2000);\n"
    js = "{js}  };\n"
    js = "{js}}\n"
    js = "{js}connect();\n"

    # Keyboard event forwarding
    js = "{js}document.addEventListener('keydown', function(e) {\n"
    js = "{js}  if (ws && ws.readyState === WebSocket.OPEN) {\n"
    js = "{js}    ws.send(JSON.stringify({type: 'key', key: e.key}));\n"
    js = "{js}  }\n"
    js = "{js}});\n"

    return js
