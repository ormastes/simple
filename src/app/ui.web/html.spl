    parts = parts.push("#wm-desktop[data-wm-snap-target='left'] .wm-snap-preview, #wm-desktop[data-wm-snap-target='right'] .wm-snap-preview, #wm-desktop[data-wm-snap-target='full'] .wm-snap-preview { box-shadow: 0 28px 90px rgba(0,0,0,0.34), 0 0 0 1px rgba({accent_rgb},0.46) inset; }\n")
    parts = parts.push(".wm-ghost { position: absolute; pointer-events: none; box-sizing: border-box; border-radius: var(--ui-wm-window-radius); border: 1px solid rgba({accent_rgb},0.66); background: linear-gradient(180deg, rgba({accent_rgb},0.16), rgba(255,255,255,0.08)); box-shadow: 0 34px 90px rgba(0,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.22); backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%); opacity: 0.78; transform: translate3d(0,-6px,0) scale(1.018); transition: left 90ms ease-out, top 90ms ease-out, width 90ms ease-out, height 90ms ease-out, transform 140ms cubic-bezier(0.22,0.8,0.2,1), opacity 120ms ease; }\n")
    parts = parts.push(".wm-ghost.drag-lifted { animation: wm-drag-lift 180ms cubic-bezier(0.22,0.8,0.2,1) both; }\n")
