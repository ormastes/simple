    parts = parts.push(".wm-snap-layout-choice:hover, .wm-snap-layout-choice:focus-visible, .wm-snap-layout-choice.active { transform: translateY(-2px); border-color: rgba({accent_rgb},0.62); background: rgba({accent_rgb},0.16); outline: none; }\n")
    parts = parts.push(".wm-snap-layout-preview { width: 54px; height: 34px; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; padding: 3px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.08); }\n")
    parts = parts.push(".wm-snap-layout-preview[data-snap-preview=full] { grid-template-columns: 1fr; }\n")
    parts = parts.push(".wm-snap-layout-cell { border-radius: 6px; background: rgba(255,255,255,0.15); }\n")
    parts = parts.push(".wm-snap-layout-preview[data-snap-preview=left] .wm-snap-layout-cell.a, .wm-snap-layout-preview[data-snap-preview=right] .wm-snap-layout-cell.b, .wm-snap-layout-preview[data-snap-preview=full] .wm-snap-layout-cell.a { background: rgba({accent_rgb},0.72); }\n")
