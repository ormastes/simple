    parts = parts.push(".wm-system-hud-icon { width: 42px; height: 42px; display: inline-grid; place-items: center; }\n")
    parts = parts.push(".wm-system-hud-body { min-width: 0; display: grid; gap: 3px; }\n")
    parts = parts.push(".wm-system-hud-title { color: {dim_fg}; font-size: 11px; font-weight: 750; text-transform: uppercase; }\n")
    parts = parts.push(".wm-system-hud-value { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: {fg}; font: 800 18px var(--ui-font-display); }\n")
    parts = parts.push(".wm-system-hud-meter { grid-column: 1 / -1; height: 4px; border-radius: 999px; background: linear-gradient(90deg, rgba({accent_rgb},0.90), rgba(255,255,255,0.20)); transform-origin: left center; animation: wm-system-hud-meter 1800ms linear both; }\n")
    parts = parts.push(".wm-privacy-indicator { position: fixed; top: max(82px, env(safe-area-inset-top)); right: max(18px, env(safe-area-inset-right)); z-index: 11650; width: min(300px, calc(100vw - 36px)); display: grid; gap: 10px; padding: 12px; border-radius: 22px; border: 1px solid rgba(255,255,255,0.18); color: {fg}; background: linear-gradient(180deg, rgba(255,255,255,0.17), rgba(255,255,255,0.07)), {panel_bg}; box-shadow: 0 24px 72px rgba(0,0,0,0.38), inset 0 1px 0 rgba(255,255,255,0.18); backdrop-filter: blur(30px) saturate(180%); -webkit-backdrop-filter: blur(30px) saturate(180%); animation: wm-privacy-in 150ms cubic-bezier(0.22, 0.8, 0.2, 1) both; }\n")
    parts = parts.push(".wm-privacy-indicator[hidden] { display: none; }\n")
    parts = parts.push(".wm-privacy-header { display: flex; align-items: center; gap: 8px; font: 800 13px var(--ui-font-display); }\n")
