    parts = parts.push(".wm-taskbar-preview-actions { grid-column: 1 / -1; display: flex; justify-content: flex-end; gap: 8px; }\n")
    parts = parts.push(".wm-taskbar-preview-action { width: 30px; height: 30px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.08); color: {fg}; font-size: 11px; font-weight: 850; display: inline-grid; place-items: center; cursor: pointer; transition: transform 140ms ease, background 140ms ease, border-color 140ms ease; }\n")
    parts = parts.push(".wm-taskbar-preview-action:hover { transform: translateY(-2px) scale(1.05); background: rgba({accent_rgb},0.18); border-color: rgba({accent_rgb},0.46); }\n")
    parts = parts.push(".wm-tooltip { position: fixed; z-index: 13000; max-width: min(280px, calc(100vw - 24px)); transform: translate(-50%, -100%); padding: 7px 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.18); color: {fg}; background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08)), {panel_bg}; box-shadow: 0 16px 44px rgba(0,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.18); backdrop-filter: blur(22px) saturate(170%); -webkit-backdrop-filter: blur(22px) saturate(170%); font-size: 11px; font-weight: 760; pointer-events: none; white-space: nowrap; animation: wm-tooltip-in 110ms cubic-bezier(0.22,0.8,0.2,1) both; }\n")
    parts = parts.push(".wm-tooltip[hidden] { display: none; }\n")
    parts = parts.push(":root[data-wm-motion=reduced] .wm-tooltip { animation: none !important; transition-duration: 80ms !important; filter: none !important; }\n")
    parts = parts.push(":root[data-wm-motion=off] .wm-tooltip { animation: none !important; transition: none !important; transform: translate(-50%, -100%) !important; filter: none !important; }\n")
    parts = parts.push("@media (prefers-reduced-motion: reduce) { .wm-tooltip { animation: none !important; transition: none !important; filter: none !important; } }\n")
    parts = parts.push("@keyframes wm-window-open { 0% { opacity: 0; transform: translate3d(0,18px,0) scale(0.94); filter: blur(5px) saturate(0.86); box-shadow: 0 4px 20px rgba(0,0,0,0.20); } 62% { opacity: 1; transform: translate3d(0,-2px,0) scale(1.012); filter: blur(0) saturate(1.02); } 100% { opacity: 1; transform: translate3d(0,0,0) scale(1); filter: blur(0) saturate(1); } }\n")
