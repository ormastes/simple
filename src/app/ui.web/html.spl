    var html = "<!DOCTYPE html>\n"
    html = html + "<html lang=\"en\" data-wm-motion=\"standard\" data-wm-animation-style=\"spring\" data-wm-transparency=\"standard\" data-wm-energy=\"standard\" data-wm-feedback=\"standard\" data-wm-contrast=\"comfortable\" data-wm-density=\"comfortable\" data-wm-wallpaper=\"aurora\" data-wm-backdrop-motion=\"ambient\" data-wm-backdrop-intensity=\"balanced\" data-wm-dock-magnification=\"standard\" data-wm-dock-visibility=\"shown\" data-wm-surface-depth=\"layered\" data-wm-traffic-side=\"left\" data-wm-chrome-verbosity=\"full\" data-wm-window-transition=\"mac\" data-wm-accent=\"blue\" data-wm-focus-mode=\"off\" data-wm-quiet-mode=\"off\">\n"
    html = html + "<head>\n"
    html = html + "  <meta charset=\"UTF-8\">\n"
    html = html + "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html = html + "  <title>Simple WM Modern Preview</title>\n"
    html = html + "  <style>" + css + "</style>\n"
    html = html + "</head>\n"
    html = html + "<body>\n"
    html = html + "  <header class=\"wm-top-menu-bar\" role=\"menubar\" aria-label=\"Simple desktop menu bar\"><nav class=\"wm-top-menu-left\" aria-label=\"Application menu\"><button class=\"wm-top-menu-item primary\" role=\"menuitem\" data-menu-action=\"launcher\">Simple</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"command_palette\">Simple IDE</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"widgets\">Widgets</button></nav><nav class=\"wm-top-menu-right\" aria-label=\"System menu\"><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"quick_settings\">Wi-Fi</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"quick_settings\">Battery 96%</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"focus_mode\">Focus off</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"notifications\">Notifications</button><button class=\"wm-top-menu-item\" role=\"menuitem\" data-menu-action=\"control_center\">09:41</button></nav></header>\n"
    html = html + "  <div id=\"wm-desktop\" data-preview=\"modern-wm\" data-desktop-peek=\"false\" data-wm-drag-state=\"active\" data-wm-snap-target=\"right\">\n"
