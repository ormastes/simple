    parts = parts.push(".wm-resize-s { left: 0; bottom: 0; right: 0; height: 4px; cursor: s-resize; }\n")
    parts = parts.push(".wm-resize-sw { left: 0; bottom: 0; width: 12px; height: 12px; cursor: sw-resize; }\n")
    parts = parts.push(".wm-resize-w { left: 0; top: 32px; width: 4px; bottom: 0; cursor: w-resize; }\n")
    parts = parts.push(".wm-resize-n { left: 0; top: 0; right: 0; height: 4px; cursor: n-resize; }\n")
    parts = parts.push(".wm-resize-nw { left: 0; top: 0; width: 12px; height: 12px; cursor: nw-resize; }\n")
    parts = parts.push(".wm-resize-ne { right: 0; top: 0; width: 12px; height: 12px; cursor: ne-resize; }\n")
    parts = parts.push("#wm-taskbar { position: fixed; bottom: max(10px, env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 8px; padding: 7px 12px; background: linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.06)), {panel_bg}; border: 1px solid rgba(255,255,255,0.18); border-radius: 999px; backdrop-filter: blur(28px) saturate(175%); -webkit-backdrop-filter: blur(28px) saturate(175%); box-shadow: 0 18px 48px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.16); z-index: 10000; transition: transform 180ms var(--ui-motion-spring), opacity 160ms ease, filter 160ms ease; }\n")
    parts = parts.push(":root[data-wm-dock-visibility=auto] #wm-taskbar { transform: translateX(-50%) translateY(calc(var(--ui-dock-offset-y-px) * 1px)); opacity: 0.42; filter: saturate(0.82); }\n")
    parts = parts.push(":root[data-wm-dock-visibility=auto] #wm-taskbar:hover, :root[data-wm-dock-visibility=auto] #wm-taskbar:focus-within { transform: translateX(-50%) translateY(0); opacity: 1; filter: saturate(1); }\n")
    parts = parts.push(":root[data-wm-dock-visibility=hidden] #wm-taskbar { transform: translateX(-50%) translateY(calc(var(--ui-dock-offset-y-px) * 1px)); opacity: 0.18; filter: saturate(0.7); }\n")
    parts = parts.push(":root[data-wm-dock-visibility=hidden] #wm-taskbar:hover, :root[data-wm-dock-visibility=hidden] #wm-taskbar:focus-within { transform: translateX(-50%) translateY(0); opacity: 1; filter: saturate(1); }\n")
    parts = parts.push(".wm-taskbar-section { display: flex; align-items: center; gap: 6px; }\n")
    parts = parts.push(".wm-taskbar-item { position: relative; overflow: visible; min-width: 34px; height: 34px; padding: 4px 10px 4px 5px; border-radius: 999px; cursor: pointer; display: inline-flex; align-items: center; gap: 7px; font-size: 11px; font-weight: 550; color: {dim_fg}; white-space: nowrap; border: 1px solid transparent; transition: background 150ms ease, color 150ms ease, transform 150ms ease, border-color 150ms ease; }\n")
    parts = parts.push(".wm-taskbar-item:hover { background: {hover_bg}; transform: translateY(-3px) scale(1.04); }\n")
    parts = parts.push(".wm-taskbar-item.active { background: rgba({accent_rgb},0.15); color: {accent}; font-weight: 600; }\n")
    parts = parts.push(".wm-taskbar-item.attention { border-color: rgba({accent_rgb},0.54); animation: wm-taskbar-attention 900ms cubic-bezier(0.22,0.8,0.2,1) both; }\n")
    parts = parts.push(".wm-taskbar-item.minimized { opacity: 0.5; }\n")
