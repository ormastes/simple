# HTML Page Generation
#
# Generates complete HTML pages for the web UI renderer,
# including CSS styles and JavaScript for WebSocket communication.

use common.ui.widget.{UIState, UITree}
use app.ui.render.html_widgets.{render_html_tree}
use common.ui.ios_css.{generate_ios_css}
use common.ui.glass_css.{generate_glass_css}
use common.ui.glass.theme.{is_glass_theme, glass_dark, glass_light, glass_obsidian_dark, glass_obsidian_light}
use common.ui.glass.tokens.{GlassColorTokens}

# =========================================================================
# WM Traffic-Light Constants
# =========================================================================
# Source: doc/05_design/stitch_design_system.md (macOS-style window controls).
# The glass token palette intentionally doesn't define close/minimize/maximize
# colors because they're chrome controls, not surface tokens. Defined once
# here so the literal hex values appear in exactly one place.
val WM_TRAFFIC_CLOSE = "#FF5F57"
val WM_TRAFFIC_MIN = "#FFBD2E"
val WM_TRAFFIC_MAX = "#28CA41"
val WM_TRAFFIC_CLOSE_HOVER = "#FF3B30"
val WM_TRAFFIC_MIN_HOVER = "#FF9500"
val WM_TRAFFIC_MAX_HOVER = "#30D158"

# =========================================================================
# Full HTML Page
# =========================================================================

fn generate_html_page(state: UIState, ws_port: i32) -> text:
    """Generate a complete HTML page for the UI."""
    val body_html = render_html_tree(state.tree.root_node(), state)
    val css = generate_css(state.tree.theme_name())
    val js = generate_js(ws_port)
    val title = state.tree.title_text()

    var html = "<!DOCTYPE html>\n"
    html = "{html}<html lang=\"en\">\n"
    html = "{html}<head>\n"
    html = "{html}  <meta charset=\"UTF-8\">\n"
    html = "{html}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html = "{html}  <title>{title}</title>\n"
    html = "{html}  <style>{css}</style>\n"
    html = "{html}</head>\n"
    html = "{html}<body>\n"
    html = "{html}  <div id=\"app\">{body_html}</div>\n"
    html = "{html}  <script>{js}</script>\n"
    html = "{html}</body>\n"
    html = "{html}</html>"
    return html

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

fn generate_wm_html_page(theme: text, title: text, ws_port: i32) -> text:
    """Generate a WM desktop HTML page with wm.js embedded inline.
    Windows are created dynamically via WebSocket openWindow messages."""
    val css = generate_css(theme)
    val boot_js = generate_wm_js(ws_port)
    # Embed wm.js inline to avoid extra HTTP request
    var wm_js = ""
    if rt_file_exists("src/app/ui.web/wm.js"):
        wm_js = rt_file_read_text("src/app/ui.web/wm.js")

    var html = "<!DOCTYPE html>\n"
    html = html + "<html lang=\"en\">\n"
    html = html + "<head>\n"
    html = html + "  <meta charset=\"UTF-8\">\n"
    html = html + "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html = html + "  <title>" + title + "</title>\n"
    html = html + "  <style>" + css + "</style>\n"
    html = html + "</head>\n"
    html = html + "<body>\n"
    html = html + "  <div id=\"wm-desktop\"></div>\n"
    html = html + "  <div id=\"wm-taskbar\"></div>\n"
    html = html + "  <script>" + wm_js + "</script>\n"
    html = html + "  <script>" + boot_js + "</script>\n"
    html = html + "</body>\n"
    html = html + "</html>"
    return html

fn generate_wm_modern_preview_html(theme: text) -> text:
    """Generate a standalone WM visual preview fixture for GUI quality review.
    The preview is static on purpose: it exercises the same generated CSS
    contracts without depending on WebSocket state."""
