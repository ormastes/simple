    parts = parts.push(".wm-gesture-name { font-size: 12px; }\n")
    parts = parts.push(".wm-gesture-action-label { color: {dim_fg}; font-size: 11px; }\n")
    parts = parts.push(".wm-gesture-action { min-height: 36px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.14); color: {fg}; background: rgba(255,255,255,0.08); font-size: 12px; font-weight: 750; }\n")
    parts = parts.push(".wm-gesture-action:hover, .wm-gesture-action.active { background: rgba({accent_rgb},0.18); border-color: rgba({accent_rgb},0.62); }\n")
    parts = parts.push(".wm-system-hud { position: fixed; left: 50%; top: max(84px, env(safe-area-inset-top)); z-index: 12100; width: min(280px, calc(100vw - 32px)); min-height: 82px; transform: translateX(-50%); display: grid; grid-template-columns: 42px minmax(0, 1fr); align-items: center; gap: 12px; padding: 14px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.18); color: {fg}; background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08)), {panel_bg}; box-shadow: 0 26px 78px rgba(0,0,0,0.40), inset 0 1px 0 rgba(255,255,255,0.18); backdrop-filter: blur(32px) saturate(180%); -webkit-backdrop-filter: blur(32px) saturate(180%); pointer-events: none; animation: wm-system-hud-in 170ms cubic-bezier(0.22, 0.8, 0.2, 1) both; }\n")
