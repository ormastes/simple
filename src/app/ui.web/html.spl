    parts = parts.push(".wm-gesture-list { display: grid; gap: 7px; }\n")
    parts = parts.push(".wm-gesture-row { min-height: 44px; display: grid; grid-template-columns: 32px minmax(0, 1fr); align-items: center; gap: 9px; padding: 7px 8px; border-radius: 16px; background: rgba(255,255,255,0.07); }\n")
