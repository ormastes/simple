    parts = parts.push(".wm-overview-search { width: min(420px, calc(100vw - 36px)); justify-self: center; height: 42px; border-radius: 18px; border: 1px solid rgba(255,255,255,0.16); padding: 0 14px; color: {fg}; background: linear-gradient(180deg, rgba(255,255,255,0.15), rgba(255,255,255,0.07)), {panel_bg}; outline: none; }\n")
    parts = parts.push(".wm-overview-search:focus { border-color: rgba({accent_rgb},0.58); box-shadow: 0 0 0 3px rgba({accent_rgb},0.16); }\n")
    parts = parts.push(".wm-overview-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 260px)); justify-content: center; gap: 14px; }\n")
    parts = parts.push(".wm-overview-card { min-height: 138px; display: grid; grid-template-columns: 38px minmax(0, 1fr); grid-template-areas: 'icon title' 'icon meta'; align-content: center; gap: 4px 12px; padding: 18px; border-radius: 22px; border: 1px solid rgba(255,255,255,0.18); color: {fg}; background: linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.07)), {panel_bg}; box-shadow: 0 24px 70px rgba(0,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.16); backdrop-filter: blur(26px) saturate(170%); -webkit-backdrop-filter: blur(26px) saturate(170%); text-align: left; transition: transform 150ms ease, border-color 150ms ease, background 150ms ease; }\n")
    parts = parts.push(".wm-overview-card:hover, .wm-overview-card.active { transform: translateY(-4px) scale(1.025); border-color: rgba({accent_rgb},0.68); background: linear-gradient(180deg, rgba({accent_rgb},0.18), rgba(255,255,255,0.08)), {panel_bg}; }\n")
    parts = parts.push(".wm-overview-card.minimized { opacity: 0.62; }\n")
    parts = parts.push(".wm-overview-icon { grid-area: icon; width: 38px; height: 38px; display: inline-grid; place-items: center; }\n")
    parts = parts.push(".wm-overview-card-title { grid-area: title; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 700; }\n")
    parts = parts.push(".wm-overview-card-meta { grid-area: meta; color: {dim_fg}; font-size: 12px; }\n")
    parts = parts.push(".wm-overview-empty { min-height: 96px; display: grid; place-items: center; color: {dim_fg}; border-radius: 18px; border: 1px dashed rgba(255,255,255,0.18); }\n")
    parts = parts.push(".wm-title-context { justify-self: end; min-width: 80px; max-width: 220px; height: 22px; border-radius: 999px; padding: 0 10px; display: flex; align-items: center; color: {dim_fg}; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.10); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n")
    parts = parts.push(".wm-traffic-lights { display: flex; gap: 6px; }\n")
    parts = parts.push(".wm-traffic-lights button { position: relative; width: 12px; height: 12px; border-radius: 50%; border: none; cursor: pointer; padding: 0; color: transparent; box-shadow: inset 0 0 0 1px rgba(0,0,0,0.16), 0 1px 4px rgba(0,0,0,0.22); transition: transform 120ms ease, filter 120ms ease; }\n")
    parts = parts.push(".wm-traffic-lights button::before { content: ''; position: absolute; inset: -8px; border-radius: 999px; }\n")
    parts = parts.push(".wm-traffic-lights button:focus-visible, .wm-taskbar-item:focus-visible, .wm-command-item:focus-visible, .wm-title-input:focus-visible, .wm-command-palette-input:focus-visible { outline: 2px solid rgba({accent_rgb},0.82); outline-offset: 3px; }\n")
    parts = parts.push(".wm-traffic-lights button:hover { transform: scale(1.08); filter: brightness(1.06); }\n")
