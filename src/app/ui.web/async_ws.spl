# Async WebSocket Handler
#
# WebSocket frame reader and sender for the async web server.
# The reader runs in a dedicated thread per client and pushes
# parsed UI events into the shared event channel.

use std.nogc_sync_mut.io.tcp.{TcpStream}
use std.nogc_async_mut.concurrent.channel.{Channel}
use common.ui.widget.{UIEvent}
use app.ui.web.ws_handler.{send_ws_text}

# =========================================================================
# WebSocket Reader (runs in client thread)
# =========================================================================

fn start_ws_reader(stream: Any, event_channel: Any):
    """Read WebSocket frames from a client and push events to channel.

    Runs in a dedicated thread. Exits when the connection closes
    or an unrecoverable read error occurs.
    """
    val tcp = stream as TcpStream
    val ch = event_channel as Channel

    loop:
        val frame = read_ws_frame(tcp)
        if frame == nil:
            # Connection closed or error
            break

        val event = parse_ws_event(frame)
        if event != nil:
            ch.send(event)

fn read_ws_frame(stream: TcpStream) -> text?:
    """Read a single WebSocket text frame.

    Returns the decoded payload text, or nil on error/close.
    Handles masking as required by RFC 6455 for client-to-server frames.
    """
    # Read first 2 bytes: FIN+opcode and mask+length
    match stream.read(2):
        Err(_):
            return nil
        Ok(header):
            # Extract bytes via iteration to avoid .len() + [index] interpreter bug
            var byte0: u8 = 0
            var byte1: u8 = 0
            var hdr_idx = 0
            for b in header:
                if hdr_idx == 0:
                    byte0 = b
                elif hdr_idx == 1:
                    byte1 = b
                hdr_idx = hdr_idx + 1
            if hdr_idx < 2:
                return nil

            val opcode = byte0 & 0x0F
            # Close frame
            if opcode == 0x08:
                return nil

            # Only handle text frames (opcode 1)
            if opcode != 0x01:
                return nil

            val masked = (byte1 & 0x80) != 0
            var payload_len = (byte1 & 0x7F) as i64

            # Extended payload length
            if payload_len == 126:
                match stream.read(2):
                    Ok(ext):
                        var e0: i64 = 0
                        var e1: i64 = 0
                        var ei = 0
                        for b in ext:
                            if ei == 0:
                                e0 = b as i64
                            elif ei == 1:
                                e1 = b as i64
                            ei = ei + 1
                        if ei < 2:
                            return nil
                        payload_len = e0 * 256 + e1
                    Err(_):
                        return nil
            elif payload_len == 127:
                match stream.read(8):
                    Ok(ext):
                        var e4: i64 = 0
                        var e5: i64 = 0
                        var e6: i64 = 0
                        var e7: i64 = 0
                        var ei = 0
                        for b in ext:
                            if ei == 4:
                                e4 = b as i64
                            elif ei == 5:
                                e5 = b as i64
                            elif ei == 6:
                                e6 = b as i64
                            elif ei == 7:
                                e7 = b as i64
                            ei = ei + 1
                        if ei < 8:
                            return nil
                        # Simplified: only use lower 4 bytes
                        payload_len = e4 * 16777216 + e5 * 65536 + e6 * 256 + e7
                    Err(_):
                        return nil

            # Read mask key (4 bytes) if masked
            var mask_key: [u8] = []
            if masked:
                match stream.read(4):
                    Ok(mk):
                        var mk_count = 0
                        for b in mk:
                            mk_count = mk_count + 1
                        if mk_count < 4:
                            return nil
                        mask_key = mk
                    Err(_):
                        return nil

            # Read payload
            if payload_len == 0:
                return ""

            match stream.read_exact(payload_len):
                Err(_):
                    return nil
                Ok(payload):
                    # Unmask payload
                    var decoded: [u8] = []
                    var i = 0
                    while i < payload.len():
                        if masked:
                            val unmasked = payload[i] ^ mask_key[i % 4]
                            decoded = decoded + [unmasked]
                        else:
                            decoded = decoded + [payload[i]]
                        i = i + 1

                    # Convert bytes to text
                    return bytes_to_text_simple(decoded)

fn bytes_to_text_simple(data: [u8]) -> text:
    """Convert byte array to text (ASCII subset)."""
    var result = ""
    for b in data:
        result = "{result}{b as text}"
    return result

# =========================================================================
# Event Parsing
# =========================================================================

fn parse_ws_event(message: text) -> UIEvent?:
    """Parse a JSON WebSocket message into a UIEvent.

    Expected formats:
        {"type": "key", "key": "q"}
        {"type": "action", "name": "save"}
        {"type": "resize", "width": "120", "height": "40"}
        {"type": "quit"}
    """
    val msg_type = extract_field(message, "type")

    match msg_type:
        "key":
            val key = extract_field(message, "key")
            if key != "":
                return UIEvent.KeyPress(key: key)
            return nil
        "keypress":
            val key = extract_field(message, "key")
            if key != "":
                return UIEvent.KeyPress(key: key)
            return nil
        "action":
            val name = extract_field(message, "name")
            if name != "":
                return UIEvent.Action(name: name)
            return nil
        "focus":
            # Focus events from mouse clicks: set focus to clicked widget
            val id = extract_field(message, "id")
            if id != "":
                return UIEvent.Action(name: "focus_{id}")
            return nil
        "resize":
            # Resize events not yet supported in async WebSocket handler
            return nil
        "quit":
            return UIEvent.Quit
        _:
            return nil

fn extract_field(json: text, field: text) -> text:
    """Extract a simple JSON string field value.

    Handles formats like:
        "field": "value"
        "field":"value"
    """
    val search = "\"{field}\""
    val idx = json.find(search)
    if idx < 0:
        return ""

    # Find the colon after the field name
    var pos = idx + search.len()
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1
    if pos >= json.len() or json[pos] != ":":
        return ""
    pos = pos + 1

    # Skip whitespace after colon
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1

    # Expect opening quote
    if pos >= json.len() or json[pos] != "\"":
        return ""
    pos = pos + 1

    # Read until closing quote
    var value = ""
    while pos < json.len() and json[pos] != "\"":
        value = "{value}{json[pos]}"
        pos = pos + 1

    return value

# =========================================================================
# WebSocket Send
# =========================================================================

fn ws_send_render(stream: TcpStream, message: text) -> bool:
    """Send a render message to a WebSocket client.

    Returns true if send succeeded, false if connection is broken.
    """
    if not stream.is_open():
        return false

    send_ws_text(stream, message)
    return true
