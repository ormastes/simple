#![allow(unnamed_duplicate_typed_args)]
# Async WebSocket Handler
#
# WebSocket frame reader and sender for the async web server.
# The reader runs in a dedicated thread per client and pushes
# parsed UI events into the shared event channel.

use std.nogc_sync_mut.io.tcp.{TcpStream}
use std.nogc_async_mut.concurrent.channel.{Channel}
use common.ui.widget.{UIEvent}
use app.ui.web.ws_handler.{send_ws_text}

extern fn rt_ws_mask_bytes(data: [u8], mask_key: [u8]) -> [u8]

# =========================================================================
# WebSocket Reader (runs in client thread)
# =========================================================================

fn start_ws_reader(stream: Any, event_channel: Any):
    """Read WebSocket frames from a client and push events to channel.

    Runs in a dedicated thread. Exits when the connection closes
    or an unrecoverable read error occurs.
    """
    val tcp = stream as TcpStream
    val ch = event_channel as Channel

    loop:
        val frame = read_ws_frame(tcp)
        if frame == nil:
            # Connection closed or error
            break

        val event = parse_ws_event(frame)
        if event != nil:
            ch.send(event)

fn read_ws_frame(stream: TcpStream) -> text?:
    """Read a single WebSocket text frame.

    Returns the decoded payload text, or nil on error/close.
    Handles masking, ping/pong, and close per RFC 6455.
    Uses a loop for control frames to avoid stack overflow from recursive calls.
    """
    loop:
        val frame = _read_single_frame(stream)
        if frame == nil:
            return nil
        val opcode = frame.opcode
        if opcode == 0x08:
            _send_close_response(stream, frame.payload)
            return nil
        if opcode == 0x09:
            _send_pong_with_payload(stream, frame.payload)
            pass_do_nothing
        elif opcode == 0x0A:
            pass_do_nothing
        elif opcode == 0x01:
            return bytes_to_text_simple(frame.payload)
        else:
            return nil

class _WsFrame:
    opcode: i64
    payload: [u8]

fn _read_single_frame(stream: TcpStream) -> _WsFrame?:
    """Read and decode one complete WebSocket frame from the stream."""
    match stream.read(2):
        Err(_):
            return nil
        Ok(header):
            var byte0: u8 = 0
            var byte1: u8 = 0
            var hdr_idx = 0
            for b in header:
                if hdr_idx == 0:
                    byte0 = b
                elif hdr_idx == 1:
                    byte1 = b
                hdr_idx = hdr_idx + 1
            if hdr_idx < 2:
                return nil

            val opcode = (byte0 & 0x0F) as i64
            val masked = (byte1 & 0x80) != 0
            var payload_len = (byte1 & 0x7F) as i64

            if payload_len == 126:
                match stream.read(2):
                    Ok(ext):
                        var e0: i64 = 0
                        var e1: i64 = 0
                        var ei = 0
                        for b in ext:
                            if ei == 0:
                                e0 = b as i64
                            elif ei == 1:
                                e1 = b as i64
                            ei = ei + 1
                        if ei < 2:
                            return nil
                        payload_len = e0 * 256 + e1
                    Err(_):
                        return nil
            elif payload_len == 127:
                match stream.read(8):
                    Ok(ext):
                        var e4: i64 = 0
                        var e5: i64 = 0
                        var e6: i64 = 0
                        var e7: i64 = 0
                        var ei = 0
                        for b in ext:
                            if ei == 4:
                                e4 = b as i64
                            elif ei == 5:
                                e5 = b as i64
                            elif ei == 6:
                                e6 = b as i64
                            elif ei == 7:
                                e7 = b as i64
                            ei = ei + 1
                        if ei < 8:
                            return nil
                        payload_len = e4 * 16777216 + e5 * 65536 + e6 * 256 + e7
                    Err(_):
                        return nil

            var mask_key: [u8] = []
            if masked:
                match stream.read(4):
                    Ok(mk):
                        var mk_count = 0
                        for b in mk:
                            mk_count = mk_count + 1
                        if mk_count < 4:
                            return nil
                        mask_key = mk
                    Err(_):
                        return nil

            if payload_len == 0:
                return _WsFrame(opcode: opcode, payload: [])

            match stream.read_exact(payload_len):
                Err(_):
                    return nil
                Ok(payload):
                    var decoded: [u8] = payload
                    if masked:
                        decoded = rt_ws_mask_bytes(payload, mask_key)
                    return _WsFrame(opcode: opcode, payload: decoded)

fn bytes_to_text_simple(data: [u8]) -> text:
    """Convert byte array to text (ASCII subset)."""
    var parts: [text] = []
    for b in data:
        parts = parts.push(b as text)
    return parts.join("")

# =========================================================================
# Event Parsing
# =========================================================================

fn parse_ws_event(message: text) -> UIEvent?:
    """Parse a JSON WebSocket message into a UIEvent.

    Expected formats:
        {"type": "key", "key": "q"}
        {"type": "action", "name": "save"}
        {"type": "resize", "width": "120", "height": "40"}
        {"type": "quit"}
    """
    val msg_type = extract_field(message, "type")

    match msg_type:
        "key":
            val key = extract_field(message, "key")
            if key != "":
                return UIEvent.KeyPress(key: key)
            return nil
        "keypress":
            val key = extract_field(message, "key")
            if key != "":
                return UIEvent.KeyPress(key: key)
            return nil
        "action":
            val name = extract_field(message, "name")
            if name != "":
                return UIEvent.Action(name: name)
            return nil
        "focus":
            # Focus events from mouse clicks: set focus to clicked widget
            val id = extract_field(message, "id")
            if id != "":
                return UIEvent.Action(name: "focus_{id}")
            return nil
        "resize":
            val width_str = extract_field(message, "width")
            val height_str = extract_field(message, "height")
            if width_str != "" and height_str != "":
                val w: i32 = width_str.to_int()
                val h: i32 = height_str.to_int()
                return UIEvent.Resize(width: w, height: h)
            return nil
        "quit":
            return UIEvent.Quit
        _:
            return nil

fn extract_field(json: text, field: text) -> text:
    """Extract a simple JSON string field value.

    Handles formats like:
        "field": "value"
        "field":"value"
    """
    val search = "\"{field}\""
    val idx = json.find(search)
    if idx < 0:
        return ""

    # Find the colon after the field name
    var pos = idx + search.len()
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1
    if pos >= json.len() or json[pos] != ":":
        return ""
    pos = pos + 1

    # Skip whitespace after colon
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1

    # Expect opening quote
    if pos >= json.len() or json[pos] != "\"":
        return ""
    pos = pos + 1

    # Read until closing quote
    var value = ""
    while pos < json.len() and json[pos] != "\"":
        value = "{value}{json[pos]}"
        pos = pos + 1

    return value

fn _send_close_response(stream: TcpStream, payload: [u8]):
    """Send a close frame echoing the received close payload (status + reason)."""
    val len = payload.len()
    if len == 0:
        stream.write_all([0x88u8, 0x00u8])
    else:
        var frame: [u8] = [0x88u8, len.to_u8()]
        frame = frame + payload
        stream.write_all(frame)

fn _send_pong_with_payload(stream: TcpStream, payload: [u8]):
    """Send a pong frame echoing the ping payload (RFC 6455 section 5.5.3)."""
    val len = payload.len()
    var frame: [u8] = [0x8Au8, len.to_u8()]
    if len > 0:
        frame = frame + payload
    stream.write_all(frame)

# =========================================================================
# WebSocket Send
# =========================================================================

fn ws_send_render(stream: TcpStream, message: text) -> bool:
    """Send a render message to a WebSocket client.

    Returns true if send succeeded, false if connection is broken.
    """
    if not stream.is_open():
        return false

    send_ws_text(stream, message)
    return true
