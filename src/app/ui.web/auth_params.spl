# Shared auth-path parameter helpers for Simple Web.

use std.io_runtime.{env_get}

val UI_WEB_MAX_UNAUTH_BODY_BYTES: i64 = 8192
val UI_WEB_MAX_AUTH_JSON_BYTES: i64 = 8192
val UI_WEB_MAX_WS_FRAME_BYTES: i64 = 65536
val UI_WEB_MAX_REQUEST_ID_BYTES: i64 = 64
val UI_WEB_MAX_REQUEST_HEAD_BYTES: i64 = 32768
val UI_WEB_MAX_REQUEST_LINE_BYTES: i64 = 8192
val UI_WEB_MAX_HEADER_LINE_BYTES: i64 = 8192
val UI_WEB_LOGIN_RATE_WINDOW_MS: u64 = 60000u64
val UI_WEB_LOGIN_RATE_MAX_ATTEMPTS: i64 = 20

fn ui_web_extract_bearer(headers: text, path: text) -> text:
    val allow_query = ui_web_query_token_allowed_from_env_value(env_get("SIMPLE_UI_WEB_ALLOW_QUERY_TOKEN") ?? "")
    return ui_web_extract_bearer_with_query_policy(headers, path, allow_query)

fn ui_web_extract_bearer_with_query_policy(headers: text, path: text, allow_query_token: bool) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("authorization:"):
            val value = trimmed[14:].trim()
            if value.lower().starts_with("bearer "):
                return value[7:].trim()
        if trimmed.lower().starts_with("sec-websocket-protocol:"):
            val value = trimmed[23:].trim()
            val bearer = ui_web_bearer_from_ws_protocols(value)
            if bearer != "":
                return bearer
    if not allow_query_token:
        return ""
    return ui_web_query_param(path, "token")

fn ui_web_query_token_allowed_from_env_value(raw: text) -> bool:
    return false

fn ui_web_bearer_from_ws_protocols(protocols: text) -> text:
    for part in protocols.split(","):
        val protocol = part.trim()
        if protocol.starts_with("bearer."):
            return ui_web_percent_decode_query_component(protocol.slice(7, protocol.len()))
    return ""

fn ui_web_ws_response_protocol(headers: text) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("sec-websocket-protocol:"):
            val value = trimmed[23:].trim()
            for part in value.split(","):
                val protocol = part.trim()
                if protocol == "simple-ui":
                    return "simple-ui"
    return ""

fn ui_web_query_param(path: text, key: text) -> text:
    val idx = path.find("?")
    if idx < 0:
        return ""
    val query = path.slice(idx + 1, path.len())
    for part in query.split("&"):
        val eq = part.find("=")
        if eq >= 0:
            val k = part.slice(0, eq)
            if k == key:
                return ui_web_percent_decode_query_component(part.slice(eq + 1, part.len()))
    return ""

fn ui_web_content_length(headers: text) -> i64:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("content-length:"):
            val raw = trimmed[15:].trim()
            if raw == "":
                return -1
            if not _ui_web_decimal_i64(raw):
                return -1
            return raw.parse_i64()
    return 0

fn _ui_web_decimal_i64(raw: text) -> bool:
    if raw == "":
        return false
    var rest = raw
    rest = rest.replace("0", "")
    rest = rest.replace("1", "")
    rest = rest.replace("2", "")
    rest = rest.replace("3", "")
    rest = rest.replace("4", "")
    rest = rest.replace("5", "")
    rest = rest.replace("6", "")
    rest = rest.replace("7", "")
    rest = rest.replace("8", "")
    rest = rest.replace("9", "")
    return rest == ""

fn ui_web_request_body_status(headers: text) -> text:
    if _ui_web_request_body_framing_problem(headers):
        return "invalid_request_framing"
    val content_length = ui_web_content_length(headers)
    if content_length < 0:
        return "invalid_request_framing"
    if content_length > UI_WEB_MAX_UNAUTH_BODY_BYTES:
        return "request_body_too_large"
    return "ok"

fn _ui_web_request_body_framing_problem(headers: text) -> bool:
    var saw_content_length = false
    for line in headers.split("\n"):
        val trimmed = line.trim()
        val lower = trimmed.lower()
        if lower.starts_with("transfer-encoding:"):
            return true
        if lower.starts_with("content-length:"):
            if saw_content_length:
                return true
            saw_content_length = true
            val raw = trimmed[15:].trim()
            if raw == "" or not _ui_web_decimal_i64(raw):
                return true
    return false

fn ui_web_body_exceeds_unauth_limit(headers: text) -> bool:
    return ui_web_request_body_status(headers) == "request_body_too_large"

fn ui_web_request_body_framing_valid(headers: text) -> bool:
    return ui_web_request_body_status(headers) != "invalid_request_framing"

fn ui_web_ws_frame_payload_allowed(payload_len: i64) -> bool:
    return payload_len >= 0 and payload_len <= UI_WEB_MAX_WS_FRAME_BYTES

fn ui_web_request_head_allowed(head_len: i64) -> bool:
    return head_len >= 0 and head_len <= UI_WEB_MAX_REQUEST_HEAD_BYTES

fn ui_web_request_line_allowed(line_len: i64) -> bool:
    return line_len >= 0 and line_len <= UI_WEB_MAX_REQUEST_LINE_BYTES

fn ui_web_header_line_allowed(line_len: i64) -> bool:
    return line_len >= 0 and line_len <= UI_WEB_MAX_HEADER_LINE_BYTES

fn ui_web_request_head_status(request_line: text, headers: text) -> text:
    if not ui_web_request_line_allowed(request_line.len()):
        return "request_head_too_large"
    var head_len = request_line.len()
    if not ui_web_request_head_allowed(head_len):
        return "request_head_too_large"
    for line in headers.split("\n"):
        if line == "":
            continue
        head_len = head_len + line.len()
        if not ui_web_header_line_allowed(line.len()) or not ui_web_request_head_allowed(head_len):
            return "request_head_too_large"
    return "ok"

fn ui_web_json_security_headers(content_type: text) -> text:
    if content_type != "application/json":
        return ""
    return "Cache-Control: no-store\r\nPragma: no-cache\r\nX-Content-Type-Options: nosniff\r\n"

fn ui_web_static_script_security_headers(content_type: text) -> text:
    if content_type != "application/javascript":
        return ""
    return "Cache-Control: no-store\r\nPragma: no-cache\r\nX-Content-Type-Options: nosniff\r\n"

fn ui_web_html_security_headers(content_type: text) -> text:
    if content_type != "text/html":
        return ""
    var html_headers = "Cache-Control: no-store\r\n"
    html_headers = "{html_headers}Pragma: no-cache\r\n"
    html_headers = "{html_headers}Expires: 0\r\n"
    html_headers = "{html_headers}X-Content-Type-Options: nosniff\r\n"
    html_headers = "{html_headers}X-Frame-Options: DENY\r\n"
    html_headers = "{html_headers}X-DNS-Prefetch-Control: off\r\n"
    html_headers = "{html_headers}X-Permitted-Cross-Domain-Policies: none\r\n"
    html_headers = "{html_headers}Referrer-Policy: no-referrer\r\n"
    html_headers = "{html_headers}Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()\r\n"
    html_headers = "{html_headers}Permissions-Policy: usb=(), serial=(), bluetooth=()\r\n"
    html_headers = "{html_headers}Permissions-Policy: clipboard-read=(), clipboard-write=()\r\n"
    html_headers = "{html_headers}Permissions-Policy: display-capture=(), screen-wake-lock=(), xr-spatial-tracking=()\r\n"
    html_headers = "{html_headers}Origin-Agent-Cluster: ?1\r\n"
    html_headers = "{html_headers}Cross-Origin-Embedder-Policy: require-corp\r\n"
    html_headers = "{html_headers}Content-Security-Policy: default-src 'self'; connect-src 'self' ws: wss:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'\r\n"
    return html_headers

fn ui_web_request_id(headers: text, fallback: text) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("x-request-id:"):
            val candidate = ui_web_sanitize_request_id(trimmed[13:].trim())
            if candidate != "":
                return candidate
    return ui_web_sanitize_request_id(fallback)

fn ui_web_sanitize_request_id(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "" or trimmed.len() > UI_WEB_MAX_REQUEST_ID_BYTES:
        return ""
    var out = ""
    var pos = 0
    while pos < trimmed.len():
        val ch = trimmed.slice(pos, pos + 1)
        if _ui_web_request_id_char_allowed(ch):
            out = "{out}{ch}"
        else:
            return ""
        pos = pos + 1
    return out

fn _ui_web_request_id_char_allowed(ch: text) -> bool:
    return (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "-" or ch == "_" or ch == "."

fn ui_web_login_rate_decision(window_start_ms: u64, attempt_count: i64, now_ms: u64) -> (bool, u64, i64):
    if window_start_ms == 0u64 or now_ms >= window_start_ms + UI_WEB_LOGIN_RATE_WINDOW_MS:
        return (true, now_ms, 1)
    if attempt_count >= UI_WEB_LOGIN_RATE_MAX_ATTEMPTS:
        return (false, window_start_ms, attempt_count)
    return (true, window_start_ms, attempt_count + 1)

fn ui_web_auth_json_field(json: text, field: text) -> text:
    """Bounded JSON field extraction for unauth/login and resume auth paths.
    Supports simple string, number, boolean, and null scalar values. Nested
    objects/arrays remain handled by route-specific non-auth parsers."""
    if json.len() > UI_WEB_MAX_AUTH_JSON_BYTES:
        return ""
    val key = "\"{field}\""
    val key_pos = json.find(key)
    if key_pos < 0:
        return ""
    var pos = key_pos + key.len()
    val json_len = json.len()
    while pos < json_len and _ui_web_is_json_space(json.slice(pos, pos + 1)):
        pos = pos + 1
    if pos >= json_len or json.slice(pos, pos + 1) != ":":
        return ""
    pos = pos + 1
    while pos < json_len and _ui_web_is_json_space(json.slice(pos, pos + 1)):
        pos = pos + 1
    if pos >= json_len:
        return ""
    if json.slice(pos, pos + 1) == "\"":
        return _ui_web_json_string_value(json, pos + 1)
    val start = pos
    while pos < json_len:
        val ch = json.slice(pos, pos + 1)
        if ch == "," or ch == "}" or ch == "]" or _ui_web_is_json_space(ch):
            return json.slice(start, pos).trim()
        pos = pos + 1
    return json.slice(start, json_len).trim()

fn _ui_web_json_string_value(json: text, start: i64) -> text:
    var out = ""
    var pos = start
    val json_len = json.len()
    while pos < json_len:
        val ch = json.slice(pos, pos + 1)
        if ch == "\"":
            return out
        if ch == "\\":
            if pos + 1 >= json_len:
                return ""
            val escaped = json.slice(pos + 1, pos + 2)
            if escaped == "\"" or escaped == "\\" or escaped == "/":
                out = "{out}{escaped}"
            elif escaped == "n":
                out = "{out}\n"
            elif escaped == "r":
                out = "{out}\r"
            elif escaped == "t":
                out = "{out}\t"
            else:
                out = "{out}{escaped}"
            pos = pos + 2
        else:
            out = "{out}{ch}"
            pos = pos + 1
    return ""

fn _ui_web_is_json_space(ch: text) -> bool:
    return ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn ui_web_percent_decode_query_component(value: text) -> text:
    var out = value
    out = out.replace("%2E", ".")
    out = out.replace("%2e", ".")
    out = out.replace("%2F", "/")
    out = out.replace("%2f", "/")
    out = out.replace("%3A", ":")
    out = out.replace("%3a", ":")
    out = out.replace("%20", " ")
    out = out.replace("+", " ")
    out = out.replace("%2B", "+")
    out = out.replace("%2b", "+")
    out = out.replace("%26", "&")
    out = out.replace("%3D", "=")
    out = out.replace("%3d", "=")
    out = out.replace("%3F", "?")
    out = out.replace("%3f", "?")
    out = out.replace("%25", "%")
    return out

export ui_web_extract_bearer
export ui_web_extract_bearer_with_query_policy
export ui_web_bearer_from_ws_protocols
export ui_web_query_token_allowed_from_env_value
export ui_web_ws_response_protocol
export ui_web_query_param
export ui_web_content_length
export ui_web_body_exceeds_unauth_limit
export ui_web_request_body_status
export ui_web_request_body_framing_valid
export ui_web_ws_frame_payload_allowed
export ui_web_request_head_allowed
export ui_web_request_line_allowed
export ui_web_header_line_allowed
export ui_web_request_head_status
export ui_web_json_security_headers
export ui_web_html_security_headers
export ui_web_request_id
export ui_web_sanitize_request_id
export ui_web_login_rate_decision
export ui_web_auth_json_field
export ui_web_percent_decode_query_component
export UI_WEB_MAX_UNAUTH_BODY_BYTES
export UI_WEB_MAX_AUTH_JSON_BYTES
export UI_WEB_MAX_WS_FRAME_BYTES
export UI_WEB_MAX_REQUEST_ID_BYTES
export UI_WEB_MAX_REQUEST_HEAD_BYTES
export UI_WEB_MAX_REQUEST_LINE_BYTES
export UI_WEB_MAX_HEADER_LINE_BYTES
export UI_WEB_LOGIN_RATE_WINDOW_MS
export UI_WEB_LOGIN_RATE_MAX_ATTEMPTS
