# Shared auth-path parameter helpers for Simple Web.

extern fn rt_env_get(key: text) -> text

val UI_WEB_MAX_UNAUTH_BODY_BYTES: i64 = 8192
val UI_WEB_MAX_AUTH_JSON_BYTES: i64 = 8192
val UI_WEB_MAX_WS_FRAME_BYTES: i64 = 65536
val UI_WEB_MAX_REQUEST_ID_BYTES: i64 = 64
val UI_WEB_MAX_CAPABILITY_GRANT_ID_BYTES: i64 = 64
val UI_WEB_MAX_SESSION_ID_BYTES: i64 = 64
val UI_WEB_MAX_REQUEST_HEAD_BYTES: i64 = 32768
val UI_WEB_MAX_REQUEST_LINE_BYTES: i64 = 8192
val UI_WEB_MAX_HEADER_LINE_BYTES: i64 = 8192
val UI_WEB_LOGIN_RATE_WINDOW_MS: u64 = 60000u64
val UI_WEB_LOGIN_RATE_MAX_ATTEMPTS: i64 = 20
val UI_WEB_PRINCIPAL_RATE_WINDOW_MS: u64 = 60000u64
val UI_WEB_PRINCIPAL_RATE_MAX_REQUESTS: i64 = 600

fn ui_web_extract_bearer(headers: text, path: text) -> text:
    val allow_query = ui_web_query_token_allowed_from_env_value(rt_env_get("SIMPLE_UI_WEB_ALLOW_QUERY_TOKEN") ?? "")
    return ui_web_extract_bearer_with_query_policy(headers, path, allow_query)

fn ui_web_extract_bearer_with_query_policy(headers: text, path: text, allow_query_token: bool) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("authorization:"):
            val value = trimmed[14:].trim()
            if value.lower().starts_with("bearer "):
                return value[7:].trim()
        if trimmed.lower().starts_with("sec-websocket-protocol:"):
            val value = trimmed[23:].trim()
            val bearer = ui_web_bearer_from_ws_protocols(value)
            if bearer != "":
                return bearer
    if not allow_query_token:
        return ""
    return ui_web_query_param(path, "token")

fn ui_web_query_token_allowed_from_env_value(raw: text) -> bool:
    return false

fn ui_web_bearer_from_ws_protocols(protocols: text) -> text:
    for part in protocols.split(","):
        val protocol = part.trim()
        if protocol.starts_with("bearer."):
            return ui_web_percent_decode_query_component(protocol.slice(7, protocol.len()))
    return ""

fn ui_web_ws_response_protocol(headers: text) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("sec-websocket-protocol:"):
            val value = trimmed[23:].trim()
            for part in value.split(","):
                val protocol = part.trim()
                if protocol == "simple-ui":
                    return "simple-ui"
    return ""

fn ui_web_query_param(path: text, key: text) -> text:
    val idx = path.find("?")
    if idx < 0:
        return ""
    val query = path.slice(idx + 1, path.len())
    for part in query.split("&"):
        val eq = part.find("=")
        if eq >= 0:
            val k = part.slice(0, eq)
            if k == key:
                return ui_web_percent_decode_query_component(part.slice(eq + 1, part.len()))
    return ""

fn ui_web_content_length(headers: text) -> i64:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("content-length:"):
            val raw = trimmed[15:].trim()
            if raw == "":
                return -1
            if not _ui_web_decimal_i64(raw):
                return -1
            return raw.parse_i64()
    return 0

fn _ui_web_decimal_i64(raw: text) -> bool:
    if raw == "":
        return false
    var rest = raw
    rest = rest.replace("0", "")
    rest = rest.replace("1", "")
    rest = rest.replace("2", "")
    rest = rest.replace("3", "")
    rest = rest.replace("4", "")
    rest = rest.replace("5", "")
    rest = rest.replace("6", "")
    rest = rest.replace("7", "")
    rest = rest.replace("8", "")
    rest = rest.replace("9", "")
    return rest == ""

fn ui_web_request_body_status(headers: text) -> text:
    if _ui_web_request_body_framing_problem(headers):
        return "invalid_request_framing"
    val content_length = ui_web_content_length(headers)
    if content_length < 0:
        return "invalid_request_framing"
    if content_length > UI_WEB_MAX_UNAUTH_BODY_BYTES:
        return "request_body_too_large"
    return "ok"

fn _ui_web_request_body_framing_problem(headers: text) -> bool:
    var saw_content_length = false
    for line in headers.split("\n"):
        val trimmed = line.trim()
        val lower = trimmed.lower()
        if lower.starts_with("transfer-encoding:"):
            return true
        if lower.starts_with("content-length:"):
            if saw_content_length:
                return true
            saw_content_length = true
            val raw = trimmed[15:].trim()
            if raw == "" or not _ui_web_decimal_i64(raw):
                return true
    return false

fn ui_web_body_exceeds_unauth_limit(headers: text) -> bool:
    return ui_web_request_body_status(headers) == "request_body_too_large"

fn ui_web_request_body_framing_valid(headers: text) -> bool:
    return ui_web_request_body_status(headers) != "invalid_request_framing"

fn ui_web_json_content_type_status(headers: text) -> text:
    var count = 0
    var value = ""
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("content-type:"):
            count = count + 1
            value = trimmed[13:].trim().lower()
    if count == 0:
        return "missing_content_type"
    if count > 1:
        return "duplicate_content_type"
    val semi = value.find(";")
    if semi >= 0:
        value = value.slice(0, semi).trim()
    if value != "application/json":
        return "unsupported_content_type"
    return "ok"

fn ui_web_json_content_type_allowed(headers: text) -> bool:
    return ui_web_json_content_type_status(headers) == "ok"

fn ui_web_fetch_site_status(headers: text) -> text:
    var count = 0
    var value = ""
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("sec-fetch-site:"):
            count = count + 1
            value = trimmed[15:].trim().lower()
    if count == 0:
        return "ok"
    if count > 1:
        return "duplicate_fetch_site"
    if value == "same-origin" or value == "same-site":
        return "ok"
    if value == "cross-site":
        return "cross_site_request"
    return "invalid_fetch_site"

fn ui_web_fetch_site_allowed(headers: text) -> bool:
    return ui_web_fetch_site_status(headers) == "ok"

fn ui_web_host_header_status(headers: text) -> text:
    var count = 0
    var host = ""
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("host:"):
            count = count + 1
            host = trimmed[5:].trim()
    if count == 0:
        return "missing_host"
    if count > 1:
        return "duplicate_host"
    if not ui_web_host_value_allowed(host):
        return "invalid_host"
    return "ok"

fn ui_web_host_value_allowed(host: text) -> bool:
    if host == "":
        return false
    if host.contains(" ") or host.contains("\t"):
        return false
    if host.contains("/") or host.contains("?") or host.contains("#"):
        return false
    if host.contains("@") or host.contains(","):
        return false
    if host.starts_with("http:") or host.starts_with("https:"):
        return false
    return true

fn ui_web_host_header_allowed(headers: text) -> bool:
    return ui_web_host_header_status(headers) == "ok"

fn ui_web_host_header_value(headers: text) -> text:
    if ui_web_host_header_status(headers) != "ok":
        return ""
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("host:"):
            return trimmed[5:].trim().lower()
    return ""

fn ui_web_origin_authority(origin: text) -> text:
    val scheme_pos = origin.find("://")
    if scheme_pos < 0:
        return ""
    val authority_start = scheme_pos + 3
    if authority_start >= origin.len():
        return ""
    val authority = origin.slice(authority_start, origin.len())
    if authority.contains("/") or authority.contains("?") or authority.contains("#"):
        return ""
    return authority.lower()

fn ui_web_host_origin_authority_status(headers: text, origin: text) -> text:
    val host = ui_web_host_header_value(headers)
    if host == "":
        return "bad_host"
    val authority = ui_web_origin_authority(origin)
    if authority == "":
        return "invalid_origin"
    if host != authority:
        return "origin_host_mismatch"
    return "ok"

fn ui_web_host_origin_authority_allowed(headers: text, origin: text) -> bool:
    return ui_web_host_origin_authority_status(headers, origin) == "ok"

fn ui_web_ws_frame_payload_allowed(payload_len: i64) -> bool:
    return payload_len >= 0 and payload_len <= UI_WEB_MAX_WS_FRAME_BYTES

fn ui_web_ws_frame_metadata_status(first_byte: i64, masked: bool, payload_len: i64) -> text:
    if not masked:
        return "client_frame_unmasked"
    if (first_byte & 0x70) != 0:
        return "reserved_bits_set"
    val fin_set = (first_byte & 0x80) != 0
    if not fin_set:
        return "fragmented_frame_unsupported"
    val opcode = first_byte & 0x0F
    if opcode != 0x01 and opcode != 0x08 and opcode != 0x09 and opcode != 0x0A:
        return "unsupported_opcode"
    if not ui_web_ws_frame_payload_allowed(payload_len):
        return "frame_payload_too_large"
    if opcode >= 0x08 and payload_len > 125:
        return "control_frame_too_large"
    return "ok"

fn ui_web_request_head_allowed(head_len: i64) -> bool:
    return head_len >= 0 and head_len <= UI_WEB_MAX_REQUEST_HEAD_BYTES

fn ui_web_request_line_allowed(line_len: i64) -> bool:
    return line_len >= 0 and line_len <= UI_WEB_MAX_REQUEST_LINE_BYTES

fn ui_web_header_line_allowed(line_len: i64) -> bool:
    return line_len >= 0 and line_len <= UI_WEB_MAX_HEADER_LINE_BYTES

fn ui_web_request_head_status(request_line: text, headers: text) -> text:
    if not ui_web_request_line_allowed(request_line.len()):
        return "request_head_too_large"
    var head_len = request_line.len()
    if not ui_web_request_head_allowed(head_len):
        return "request_head_too_large"
    for line in headers.split("\n"):
        if line == "":
            continue
        head_len = head_len + line.len()
        if not ui_web_header_line_allowed(line.len()) or not ui_web_request_head_allowed(head_len):
            return "request_head_too_large"
    return "ok"

fn ui_web_sensitive_route_method_status(path: text, method: text) -> text:
    var route = path
    val query_idx = path.find("?")
    if query_idx >= 0:
        route = path.slice(0, query_idx)
    if route == "/ui/login" or route == "/ui/resume":
        if method == "POST":
            return "ok"
        return "method_not_allowed"
    if route == "/ui/ws":
        if method == "GET":
            return "ok"
        return "method_not_allowed"
    if route == "/api/state" or route == "/api/widgets" or route == "/api/clients":
        if method == "GET":
            return "ok"
        return "method_not_allowed"
    return "not_sensitive_route"

fn ui_web_sensitive_route_method_allowed(path: text, method: text) -> bool:
    val status = ui_web_sensitive_route_method_status(path, method)
    return status == "ok" or status == "not_sensitive_route"

fn ui_web_session_id_status(session_id: text) -> text:
    val trimmed = session_id.trim()
    if trimmed == "":
        return "missing_session_id"
    if trimmed.len() > UI_WEB_MAX_SESSION_ID_BYTES:
        return "session_id_too_large"
    for ch in trimmed:
        if not _ui_web_session_id_char_allowed(ch):
            return "invalid_session_id"
    return "ok"

fn ui_web_session_id_allowed(session_id: text) -> bool:
    return ui_web_session_id_status(session_id) == "ok"

fn _ui_web_session_id_char_allowed(ch: text) -> bool:
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    return ch == "-" or ch == "_"

fn ui_web_allow_public_bind_from_env_value(raw: text) -> bool:
    val v = raw.trim().lower()
    return v == "1" or v == "true" or v == "yes"

fn ui_web_bind_host_from_env_value(raw_host: text, raw_allow_public: text) -> text:
    val host = raw_host.trim()
    if host == "":
        return "127.0.0.1"
    if _ui_web_bind_host_is_public(host) and not ui_web_allow_public_bind_from_env_value(raw_allow_public):
        return "127.0.0.1"
    if not _ui_web_bind_host_shape_allowed(host):
        return "127.0.0.1"
    return host

fn _ui_web_bind_host_is_public(host: text) -> bool:
    val h = host.trim().lower()
    return h == "0.0.0.0" or h == "::" or h == "[::]"

fn _ui_web_bind_host_shape_allowed(host: text) -> bool:
    if host == "":
        return false
    if host.contains(" ") or host.contains("\t"):
        return false
    if host.contains("/") or host.contains("?") or host.contains("#"):
        return false
    if host.contains("@") or host.contains(","):
        return false
    if host.starts_with("http:") or host.starts_with("https:"):
        return false
    return true

fn ui_web_json_security_headers(content_type: text) -> text:
    if content_type != "application/json":
        return ""
    var headers = "Cache-Control: no-store\r\nPragma: no-cache\r\nX-Content-Type-Options: nosniff\r\n"
    headers = "{headers}Cross-Origin-Resource-Policy: same-origin\r\n"
    return headers

fn ui_web_script_security_headers(content_type: text) -> text:
    if content_type != "application/javascript":
        return ""
    var headers = "Cache-Control: no-store\r\nPragma: no-cache\r\nX-Content-Type-Options: nosniff\r\n"
    headers = "{headers}Cross-Origin-Resource-Policy: same-origin\r\n"
    return headers

fn ui_web_html_security_headers(content_type: text) -> text:
    if content_type != "text/html":
        return ""
    var html_headers = "Cache-Control: no-store\r\nPragma: no-cache\r\nExpires: 0\r\nX-Content-Type-Options: nosniff\r\n"
    html_headers = "{html_headers}X-Frame-Options: DENY\r\n"
    html_headers = "{html_headers}X-DNS-Prefetch-Control: off\r\n"
    html_headers = "{html_headers}X-Permitted-Cross-Domain-Policies: none\r\n"
    html_headers = "{html_headers}Cross-Origin-Opener-Policy: same-origin\r\n"
    html_headers = "{html_headers}Cross-Origin-Embedder-Policy: require-corp\r\n"
    html_headers = "{html_headers}Cross-Origin-Resource-Policy: same-origin\r\n"
    html_headers = "{html_headers}Origin-Agent-Cluster: ?1\r\n"
    html_headers = "{html_headers}Referrer-Policy: no-referrer\r\n"
    html_headers = "{html_headers}Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), bluetooth=(), clipboard-read=(), clipboard-write=(), display-capture=(), screen-wake-lock=(), xr-spatial-tracking=(), accelerometer=(), gyroscope=(), magnetometer=(), midi=(), autoplay=(), encrypted-media=(), fullscreen=()\r\n"
    html_headers = "{html_headers}Content-Security-Policy: default-src 'self'; connect-src 'self' ws: wss:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; object-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'\r\n"
    return html_headers

fn ui_web_tls_transport_security_headers() -> text:
    return "Strict-Transport-Security: max-age=31536000; includeSubDomains\r\n"

fn ui_web_request_id(headers: text, fallback: text) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.lower().starts_with("x-request-id:"):
            val candidate = ui_web_sanitize_request_id(trimmed[13:].trim())
            if candidate != "":
                return candidate
    return ui_web_sanitize_request_id(fallback)

fn ui_web_sanitize_request_id(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "" or trimmed.len() > UI_WEB_MAX_REQUEST_ID_BYTES:
        return ""
    var out = ""
    var pos = 0
    while pos < trimmed.len():
        val ch = trimmed.slice(pos, pos + 1)
        if _ui_web_request_id_char_allowed(ch):
            out = "{out}{ch}"
        else:
            return ""
        pos = pos + 1
    return out

fn _ui_web_request_id_char_allowed(ch: text) -> bool:
    return (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "-" or ch == "_" or ch == "."

fn ui_web_capability_grant_id_status(grant_id: text) -> text:
    val trimmed = grant_id.trim()
    if trimmed == "":
        return "missing_capability_grant"
    if trimmed.len() > UI_WEB_MAX_CAPABILITY_GRANT_ID_BYTES:
        return "capability_grant_too_large"
    var pos = 0
    while pos < trimmed.len():
        val ch = trimmed.slice(pos, pos + 1)
        if not _ui_web_capability_grant_id_char_allowed(ch):
            return "invalid_capability_grant"
        pos = pos + 1
    return "ok"

fn ui_web_capability_grant_id_allowed(grant_id: text) -> bool:
    return ui_web_capability_grant_id_status(grant_id) == "ok"

fn _ui_web_capability_grant_id_char_allowed(ch: text) -> bool:
    return (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "-" or ch == "_"

fn ui_web_capability_grant_id_authorized(grant_id: text) -> bool:
    val raw = rt_env_get("SIMPLE_UI_WEB_ALLOWED_CAPABILITY_GRANTS") ?? ""
    return ui_web_capability_grant_id_authorized_from_value(grant_id, raw)

fn ui_web_capability_grant_id_authorized_from_value(grant_id: text, raw: text) -> bool:
    val trimmed_grant = grant_id.trim()
    if not ui_web_capability_grant_id_allowed(trimmed_grant):
        return false
    if raw.trim() == "":
        return trimmed_grant == "legacy" or trimmed_grant == "wm" or trimmed_grant == "dev" or trimmed_grant == "wm-default"
    for part in raw.split(","):
        val allowed = part.trim()
        if ui_web_capability_grant_id_allowed(allowed) and allowed == trimmed_grant:
            return true
    return false

fn ui_web_redact_sensitive_header_line(line: text) -> text:
    val trimmed = line.trim()
    val lower = trimmed.lower()
    if lower.starts_with("authorization:"):
        return "Authorization: <redacted>"
    if lower.starts_with("cookie:"):
        return "Cookie: <redacted>"
    if lower.starts_with("set-cookie:"):
        return "Set-Cookie: <redacted>"
    if lower.starts_with("sec-websocket-protocol:"):
        val value = trimmed[23:].trim()
        var out = ""
        for part in value.split(","):
            val protocol = part.trim()
            var safe = protocol
            if protocol.lower().starts_with("bearer."):
                safe = "bearer.<redacted>"
            if out == "":
                out = safe
            else:
                out = "{out}, {safe}"
        return "Sec-WebSocket-Protocol: {out}"
    return trimmed

fn ui_web_redact_sensitive_headers(headers: text) -> text:
    var out = ""
    for line in headers.split("\n"):
        if line == "":
            continue
        val safe = ui_web_redact_sensitive_header_line(line)
        if out == "":
            out = safe
        else:
            out = "{out}\n{safe}"
    return out

fn ui_web_redact_sensitive_path(path: text) -> text:
    val idx = path.find("?")
    if idx < 0:
        return path
    val prefix = path.slice(0, idx)
    val query = path.slice(idx + 1, path.len())
    var out = ""
    for part in query.split("&"):
        val eq = part.find("=")
        var safe = part
        if eq >= 0:
            val key = part.slice(0, eq)
            if key.lower() == "token" or key.lower() == "access_token":
                safe = "{key}=<redacted>"
        if out == "":
            out = safe
        else:
            out = "{out}&{safe}"
    return "{prefix}?{out}"

fn ui_web_login_rate_decision(window_start_ms: u64, attempt_count: i64, now_ms: u64) -> (bool, u64, i64):
    if window_start_ms == 0u64 or now_ms >= window_start_ms + UI_WEB_LOGIN_RATE_WINDOW_MS:
        return (true, now_ms, 1)
    if attempt_count >= UI_WEB_LOGIN_RATE_MAX_ATTEMPTS:
        return (false, window_start_ms, attempt_count)
    return (true, window_start_ms, attempt_count + 1)

fn ui_web_principal_rate_decision(window_start_ms: u64, request_count: i64, now_ms: u64) -> (bool, u64, i64):
    if window_start_ms == 0u64 or now_ms >= window_start_ms + UI_WEB_PRINCIPAL_RATE_WINDOW_MS:
        return (true, now_ms, 1)
    if request_count >= UI_WEB_PRINCIPAL_RATE_MAX_REQUESTS:
        return (false, window_start_ms, request_count)
    return (true, window_start_ms, request_count + 1)

fn ui_web_auth_json_field(json: text, field: text) -> text:
    """Bounded JSON field extraction for unauth/login and resume auth paths.
    Supports simple string, number, boolean, and null scalar values. Nested
    objects/arrays remain handled by route-specific non-auth parsers."""
    if json.len() > UI_WEB_MAX_AUTH_JSON_BYTES:
        return ""
    val key = "\"{field}\""
    val key_pos = json.find(key)
    if key_pos < 0:
        return ""
    var pos = key_pos + key.len()
    val json_len = json.len()
    while pos < json_len and _ui_web_is_json_space(json.slice(pos, pos + 1)):
        pos = pos + 1
    if pos >= json_len or json.slice(pos, pos + 1) != ":":
        return ""
    pos = pos + 1
    while pos < json_len and _ui_web_is_json_space(json.slice(pos, pos + 1)):
        pos = pos + 1
    if pos >= json_len:
        return ""
    if json.slice(pos, pos + 1) == "\"":
        return _ui_web_json_string_value(json, pos + 1)
    val start = pos
    while pos < json_len:
        val ch = json.slice(pos, pos + 1)
        if ch == "," or ch == "}" or ch == "]" or _ui_web_is_json_space(ch):
            return json.slice(start, pos).trim()
        pos = pos + 1
    return json.slice(start, json_len).trim()

fn _ui_web_json_string_value(json: text, start: i64) -> text:
    var out = ""
    var pos = start
    val json_len = json.len()
    while pos < json_len:
        val ch = json.slice(pos, pos + 1)
        if ch == "\"":
            return out
        if ch == "\\":
            if pos + 1 >= json_len:
                return ""
            val escaped = json.slice(pos + 1, pos + 2)
            if escaped == "\"" or escaped == "\\" or escaped == "/":
                out = "{out}{escaped}"
            elif escaped == "n":
                out = "{out}\n"
            elif escaped == "r":
                out = "{out}\r"
            elif escaped == "t":
                out = "{out}\t"
            else:
                out = "{out}{escaped}"
            pos = pos + 2
        else:
            out = "{out}{ch}"
            pos = pos + 1
    return ""

fn _ui_web_is_json_space(ch: text) -> bool:
    return ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn ui_web_percent_decode_query_component(value: text) -> text:
    var out = value
    out = out.replace("%2E", ".")
    out = out.replace("%2e", ".")
    out = out.replace("%2F", "/")
    out = out.replace("%2f", "/")
    out = out.replace("%3A", ":")
    out = out.replace("%3a", ":")
    out = out.replace("%20", " ")
    out = out.replace("+", " ")
    out = out.replace("%2B", "+")
    out = out.replace("%2b", "+")
    out = out.replace("%26", "&")
    out = out.replace("%3D", "=")
    out = out.replace("%3d", "=")
    out = out.replace("%3F", "?")
    out = out.replace("%3f", "?")
    out = out.replace("%25", "%")
    return out

