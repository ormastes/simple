# Host web WM runtime bridge.
#
# Thin host-facing adapter over the shared WM scene/runtime contracts. Web
# socket and host-shell code can use this to turn pointer coordinates into the
# same runtime commands used by SimpleOS WM tests.

use common.ui.taskbar_model.{TaskbarModel}
use common.ui.window_scene.{SharedWmScene, shared_wm_dispatch_pointer}
use common.ui.wm_runtime_dispatch.{WmRuntimeDispatchCommand, WmRuntimeShellState, wm_runtime_apply_command, wm_runtime_command_from_shared_dispatch}

fn host_wm_pointer_runtime_command(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmRuntimeDispatchCommand:
    val dispatch = shared_wm_dispatch_pointer(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    wm_runtime_command_from_shared_dispatch(dispatch)

fn host_wm_pointer_runtime_wire(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    val command = host_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    "kind={command.kind};target={command.target_id};app={command.app_id};window={command.window_id};handled={command.handled};payload={command.payload}"

fn host_wm_apply_pointer(state: WmRuntimeShellState, scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmRuntimeShellState:
    val command = host_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    wm_runtime_apply_command(state, command)

fn host_wm_event_loop_marker(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    val command = host_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    "[host-wm] loop-step command={command.kind} target={command.target_id} app={command.app_id} window={command.window_id} handled={command.handled}"
