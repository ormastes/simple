# Host Adapter Contract — shared Simple-owned wire types for host shells.
#
# SimpleWeb and ElectronWeb adapters consume the same command shape. Simple
# remains authoritative for session/taskbar state; adapters execute only the
# host-local rendering or native-window side effects represented here.

use std.common.text_advanced.{escape_json}
use common.ui.web_render_api.{WebRenderHostWindowCommand, web_render_host_window_command_to_json}

val HOST_NATIVE_EVENT_SOURCE: text = "native_event"

struct HostWindowCommand:
    action: text
    window_id: text
    surface_id: text
    app_id: text
    title: text
    url: text
    x: i32
    y: i32
    width: i32
    height: i32

fn host_window_command_to_json(cmd: HostWindowCommand) -> text:
    web_render_host_window_command_to_json(WebRenderHostWindowCommand(
        action: cmd.action,
        window_id: cmd.window_id,
        surface_id: cmd.surface_id,
        app_id: cmd.app_id,
        title: cmd.title,
        url: cmd.url,
        x: cmd.x,
        y: cmd.y,
        width: cmd.width,
        height: cmd.height
    ))

fn host_window_command_contract_fixture() -> HostWindowCommand:
    HostWindowCommand(
        action: "spawn_native_window",
        window_id: "host-window-1",
        surface_id: "host-surface-1",
        app_id: "/sys/apps/terminal",
        title: "Terminal \"One\"",
        url: "/wm/native_window?app_id=%2Fsys%2Fapps%2Fterminal&title=Line\nBreak",
        x: 10,
        y: 20,
        width: 640,
        height: 420
    )

fn host_window_command_contract_golden_json() -> text:
    "{\"action\":\"spawn_native_window\",\"window_id\":\"host-window-1\",\"surface_id\":\"host-surface-1\",\"app_id\":\"/sys/apps/terminal\",\"title\":\"Terminal \\\"One\\\"\",\"url\":\"/wm/native_window?app_id=%2Fsys%2Fapps%2Fterminal&title=Line\\nBreak\",\"x\":10,\"y\":20,\"width\":640,\"height\":420}"

fn native_feedback_window_cmd_payload_to_json(
    cmd_type: text,
    window_id_hint: text,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32
) -> text:
    val base = "\"cmd_type\":\"{escape_json(cmd_type)}\",\"kind\":\"{escape_json(cmd_type)}\",\"window_id_hint\":\"{escape_json(window_id_hint)}\",\"source\":\"{HOST_NATIVE_EVENT_SOURCE}\""
    if cmd_type == "move":
        return "{" + base + ",\"x\":{x},\"y\":{y}}"
    if cmd_type == "resize":
        return "{" + base + ",\"w\":{width},\"h\":{height}}"
    if cmd_type == "set_title":
        return "{" + base + ",\"title\":\"{escape_json(title)}\"}"
    return "{" + base + "}"

fn native_feedback_window_cmd_frame_to_json(
    session_id: text,
    cmd_type: text,
    window_id_hint: text,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32
) -> text:
    val payload = native_feedback_window_cmd_payload_to_json(cmd_type, window_id_hint, title, x, y, width, height)
    "{\"t\":\"window_cmd\",\"v\":1,\"s\":\"{escape_json(session_id)}\",\"seq\":null,\"payload\":{payload}}"
