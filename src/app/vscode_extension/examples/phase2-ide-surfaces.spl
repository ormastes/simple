# Phase 2 IDE surfaces sample

use math.render

fn helper(value: i32) -> i32:
    value + 1

fn compute_total(items: [i32]) -> i32:
    var total = 0
    for item in items:
        total = total + item
    total

class Invoice:
    total: i32

describe "invoice math":
    context "with helper":
        it "computes a rich total":
            val eq = m{frac(1, 1 + exp(-x))}
            expect(helper(1)).to_equal(2)

        it "keeps malformed math visible":
            val broken = m{frac(1, sqrt(x)}
            expect(true).to_equal(true)
