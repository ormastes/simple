@allow(unnamed_duplicate_typed_args)
# Simple-native math core entrypoint for the VSCode extension.
#
# This module keeps the actual math rendering logic in std.math_repr and
# exposes a small public surface that can be exported from a standalone
# WebAssembly build.

use std.math_repr.{render_latex_raw, to_debug, to_pretty, to_text}

pub fn math_core_render_latex(source: text) -> text:
    render_latex_raw(source)

pub fn math_core_render_text(source: text) -> text:
    to_text(source)

pub fn math_core_render_debug(source: text) -> text:
    to_debug(source)

pub fn math_core_render_pretty(source: text) -> text:
    to_pretty(source)

fn main() -> i64:
    return 0
