@allow(unnamed_duplicate_typed_args)
# Simple-native math core entrypoint for the VSCode extension.
#
# This module keeps the actual math rendering logic in std.math_repr and
# exposes a small public surface that can be exported from a standalone
# WebAssembly build.

use std.math_repr.{render_latex_raw, to_debug, to_pretty, to_text}

extern fn rt_alloc(size: i64) -> i64
extern fn rt_string_new(ptr: i64, len: i64) -> text
extern fn rt_string_data(value: text) -> i64
extern fn rt_string_len(value: text) -> i64
extern fn rt_mem_write_i64(ptr: i64, value: i64)

pub fn math_core_render_latex(source: text) -> text:
    render_latex_raw(source)

pub fn math_core_render_text(source: text) -> text:
    to_text(source)

pub fn math_core_render_debug(source: text) -> text:
    to_debug(source)

pub fn math_core_render_pretty(source: text) -> text:
    to_pretty(source)

fn _char_at(source: text, index: i64) -> text:
    source[index]

fn _json_escape(value: text) -> text:
    var parts: [text] = []
    for i in 0..value.len():
        val ch = _char_at(value, i)
        if ch == "\\":
            parts.push("\\\\")
        elif ch == "\"":
            parts.push("\\\"")
        elif ch == "\n":
            parts.push("\\n")
        elif ch == "\r":
            parts.push("\\r")
        elif ch == "\t":
            parts.push("\\t")
        else:
            parts.push(ch)
    parts.join("")

fn _build_render_json(source: text) -> text:
    val latex = math_core_render_latex(source)
    val pretty = math_core_render_pretty(source)
    val text_val = math_core_render_text(source)
    val debug = math_core_render_debug(source)
    val json = (
        "{" +
        "\"latex\":\"" + _json_escape(latex) + "\"," +
        "\"pretty\":\"" + _json_escape(pretty) + "\"," +
        "\"text\":\"" + _json_escape(text_val) + "\"," +
        "\"debug\":\"" + _json_escape(debug) + "\"" +
        "}"
    )
    json

pub fn malloc(size: i64) -> i64:
    rt_alloc(size)

pub fn render_math_core_json(input_ptr: i64, input_len: i64, out_len_ptr: i64) -> i64:
    val source = rt_string_new(input_ptr, input_len)
    val json = _build_render_json(source)
    rt_mem_write_i64(out_len_ptr, rt_string_len(json))
    rt_string_data(json)

fn main() -> i64:
    return 0
