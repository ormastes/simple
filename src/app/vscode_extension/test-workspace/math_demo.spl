# Math Block Rendering Demo
# Move cursor ON a math line to see raw source
# Move cursor OFF to see rendered Unicode preview

# 1. Basic math expression
val energy = m{ E = m * c^2 }

# 2. Greek letters and square root
val distance = m{ d = sqrt(x^2 + y^2) }

# 3. Fraction
val half = m{ frac(1, 2) * pi }

# 4. Summation with subscript
val total = m{ sum(x[i], i=1..n) }

# 5. Loss function block
val cross_entropy = loss{ -sum(y[i] * log(p[i])) }

# 6. No-gradient block
val frozen = nograd{ theta * x + beta }

# 7. Matrix operations
val result = m{ A @ B' + alpha * I }

# 8. Neural network layer
val output = m{ sigma(W @ x + b) }

# 9. Gradient descent
val update = m{ theta - alpha * frac(partial L, partial theta) }

# 10. Complex expression
val bayes = m{ frac(P(A) * P(B), P(B)) }
