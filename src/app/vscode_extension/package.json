{
  "name": "simple-language",
  "displayName": "Simple Language",
  "description": "Language support for Simple programming language with LSP-powered features",
  "version": "0.1.0",
  "publisher": "simple-lang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/simple-lang/simple"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Machine Learning"
  ],
  "keywords": [
    "simple",
    "spl",
    "language-server",
    "lsp",
    "semantic-highlighting"
  ],
  "activationEvents": [
    "onLanguage:simple"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "simple",
        "extensions": [
          ".spl"
        ],
        "aliases": [
          "Simple",
          "simple"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/simple-light.svg",
          "dark": "./icons/simple-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "simple",
        "scopeName": "source.simple",
        "path": "./syntaxes/simple.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "simple.mathSourceEditor",
        "displayName": "Simple Math Source Editor",
        "selector": [
          {
            "filenamePattern": "*.spl"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "simple.richSourceEditor",
        "displayName": "Simple Rich Source Editor",
        "selector": [
          {
            "filenamePattern": "*.spl"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Simple",
      "properties": {
        "simple.lsp.mode": {
          "type": "string",
          "enum": [
            "auto",
            "native",
            "wasm"
          ],
          "default": "auto",
          "description": "LSP server mode. 'auto' uses native on desktop and WASM on web. 'native' forces subprocess. 'wasm' forces in-process WebAssembly."
        },
        "simple.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to Simple LSP server binary. Leave empty to auto-detect from extension location. Set to 'simple' to use PATH, or provide an absolute path."
        },
        "simple.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication between VSCode and server for debugging"
        },
        "simple.lsp.enableSemanticTokens": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic syntax highlighting (requires LSP server)"
        },
        "simple.lsp.debounceDelay": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay in milliseconds before sending didChange notifications (default: 300ms)"
        },
        "simple.ai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered features (requires GitHub Copilot or compatible language model extension)"
        },
        "simple.ai.inlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered inline code completions (ghost text suggestions)"
        },
        "simple.ai.chatPanel": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI chat panel for interactive coding assistance"
        },
        "simple.math.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable math block rendering and preview"
        },
        "simple.math.renderInline": {
          "type": "boolean",
          "default": true,
          "description": "Render math blocks inline using decorations"
        },
        "simple.math.previewOnHover": {
          "type": "boolean",
          "default": true,
          "description": "Show math preview on hover"
        },
        "simple.math.syncPanel.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the synced math panel when the caret enters a math block"
        },
        "simple.math.alignment": {
          "type": "string",
          "enum": [
            "center",
            "bottom"
          ],
          "default": "center",
          "description": "Vertical alignment of inline math relative to surrounding code. 'center' centers the rendered equation in the line box, 'bottom' keeps the equation near the text baseline."
        },
        "simple.math.debugLayout": {
          "type": "boolean",
          "default": false,
          "description": "Log inline SVG fit metrics to the extension host console for debugging decoration sizing"
        },
        "simple.lsp.enableInlayHints": {
          "type": "boolean",
          "default": true,
          "description": "Enable inlay hints for parameter names and inferred types (requires LSP server)"
        },
        "simple.lsp.enableCodeActions": {
          "type": "boolean",
          "default": true,
          "description": "Enable code actions and quick fixes (requires LSP server)"
        },
        "simple.lsp.enablePullDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable pull-based diagnostics for on-demand workspace checking (requires LSP server)"
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "keyword",
        "description": "Language keywords"
      },
      {
        "id": "function",
        "description": "Function names"
      },
      {
        "id": "type",
        "description": "Type names"
      },
      {
        "id": "variable",
        "description": "Variable names"
      },
      {
        "id": "parameter",
        "description": "Function parameters"
      },
      {
        "id": "property",
        "description": "Object properties"
      },
      {
        "id": "number",
        "description": "Numeric literals"
      },
      {
        "id": "string",
        "description": "String literals"
      },
      {
        "id": "comment",
        "description": "Comments"
      },
      {
        "id": "operator",
        "description": "Operators"
      },
      {
        "id": "namespace",
        "description": "Module/namespace names"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "declaration",
        "description": "Symbol declaration"
      },
      {
        "id": "definition",
        "description": "Symbol definition"
      },
      {
        "id": "readonly",
        "description": "Read-only variable"
      },
      {
        "id": "static",
        "description": "Static member"
      },
      {
        "id": "deprecated",
        "description": "Deprecated symbol"
      },
      {
        "id": "abstract",
        "description": "Abstract member"
      },
      {
        "id": "async",
        "description": "Async function"
      },
      {
        "id": "modification",
        "description": "Modifying operation"
      },
      {
        "id": "documentation",
        "description": "Documentation comment"
      }
    ],
    "commands": [
      {
        "command": "simple.richEditor.open",
        "title": "Open Rich Source Editor",
        "category": "Simple Rich"
      },
      {
        "command": "simple.lsp.restart",
        "title": "Restart LSP Server",
        "category": "Simple"
      },
      {
        "command": "simple.lsp.showOutputChannel",
        "title": "Show LSP Server Output",
        "category": "Simple"
      },
      {
        "command": "simple.ai.openChat",
        "title": "Open AI Chat Panel",
        "category": "Simple AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "simple.ai.toggleInlineCompletions",
        "title": "Toggle AI Inline Completions",
        "category": "Simple AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "simple.ai.explainCode",
        "title": "Explain Selected Code",
        "category": "Simple AI",
        "icon": "$(question)"
      },
      {
        "command": "simple.ai.reviewCode",
        "title": "Review Selected Code",
        "category": "Simple AI",
        "icon": "$(checklist)"
      },
      {
        "command": "simple.ai.generateCode",
        "title": "Generate Code from Description",
        "category": "Simple AI",
        "icon": "$(wand)"
      },
      {
        "command": "simple.math.togglePreview",
        "title": "Toggle Math Preview Panel",
        "category": "Simple Math"
      },
      {
        "command": "simple.math.toggleSyncPanel",
        "title": "Toggle Synced Math Panel",
        "category": "Simple Math"
      },
      {
        "command": "simple.math.openCustomEditor",
        "title": "Open Math Source Editor",
        "category": "Simple Math"
      },
      {
        "command": "simple.math.toggleInlineRender",
        "title": "Toggle Inline Math Rendering",
        "category": "Simple Math"
      },
      {
        "command": "simple.test.runFile",
        "title": "Run Test File",
        "category": "Simple Test",
        "icon": "$(play)"
      },
      {
        "command": "simple.test.runAtCursor",
        "title": "Run Test at Cursor",
        "category": "Simple Test",
        "icon": "$(play)"
      },
      {
        "command": "simple.test.runSdoctest",
        "title": "Run SDoctest",
        "category": "Simple Test",
        "icon": "$(play)"
      },
      {
        "command": "simple.test.openWorkspace",
        "title": "Open Test Workspace",
        "category": "Simple Test",
        "icon": "$(workspace-trusted)"
      },
      {
        "command": "simple.test.refreshWorkspace",
        "title": "Refresh Test Workspace",
        "category": "Simple Test",
        "icon": "$(refresh)"
      },
      {
        "command": "simple.test.openLatestArtifacts",
        "title": "Open Latest Test Artifacts",
        "category": "Simple Test",
        "icon": "$(folder-opened)"
      },
      {
        "command": "simple.editor.toggleBreakpoint",
        "title": "Toggle Simple Breakpoint",
        "category": "Simple Editor",
        "icon": "$(debug-breakpoint)"
      },
      {
        "command": "simple.editor.toggleBookmark",
        "title": "Toggle Simple Bookmark",
        "category": "Simple Editor",
        "icon": "$(book)"
      },
      {
        "command": "simple.editor.togglePointer",
        "title": "Toggle Simple Execution Pointer",
        "category": "Simple Editor",
        "icon": "$(debug-line-arrow)"
      },
      {
        "command": "simple.editor.clearPointer",
        "title": "Clear Simple Execution Pointer",
        "category": "Simple Editor",
        "icon": "$(close)"
      },
      {
        "command": "simple.editor.nextBookmark",
        "title": "Next Simple Bookmark",
        "category": "Simple Editor",
        "icon": "$(chevron-down)"
      },
      {
        "command": "simple.editor.prevBookmark",
        "title": "Previous Simple Bookmark",
        "category": "Simple Editor",
        "icon": "$(chevron-up)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "simple.ai.explainCode",
          "when": "editorHasSelection && editorLangId == simple",
          "group": "simple-ai@1"
        },
        {
          "command": "simple.ai.reviewCode",
          "when": "editorHasSelection && editorLangId == simple",
          "group": "simple-ai@2"
        },
        {
          "command": "simple.math.toggleSyncPanel",
          "when": "editorLangId == simple",
          "group": "simple-math@1"
        },
        {
          "command": "simple.math.openCustomEditor",
          "when": "editorLangId == simple",
          "group": "simple-math@2"
        },
        {
          "command": "simple.test.openWorkspace",
          "when": "editorLangId == simple",
          "group": "simple-test@1"
        },
        {
          "command": "simple.test.openLatestArtifacts",
          "when": "editorLangId == simple",
          "group": "simple-test@2"
        },
        {
          "command": "simple.editor.toggleBreakpoint",
          "when": "editorLangId == simple",
          "group": "simple-editor@1"
        },
        {
          "command": "simple.editor.toggleBookmark",
          "when": "editorLangId == simple",
          "group": "simple-editor@2"
        },
        {
          "command": "simple.editor.togglePointer",
          "when": "editorLangId == simple",
          "group": "simple-editor@3"
        },
        {
          "command": "simple.editor.nextBookmark",
          "when": "editorLangId == simple",
          "group": "simple-editor@4"
        },
        {
          "command": "simple.editor.prevBookmark",
          "when": "editorLangId == simple",
          "group": "simple-editor@5"
        }
      ],
      "commandPalette": [
        {
          "command": "simple.ai.explainCode",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.ai.reviewCode",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.ai.generateCode",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.runFile",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.runAtCursor",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.runSdoctest",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.math.togglePreview",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.math.toggleSyncPanel",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.math.openCustomEditor",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.math.toggleInlineRender",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.openWorkspace",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.refreshWorkspace",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.test.openLatestArtifacts",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.toggleBreakpoint",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.toggleBookmark",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.togglePointer",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.clearPointer",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.nextBookmark",
          "when": "editorLangId == simple"
        },
        {
          "command": "simple.editor.prevBookmark",
          "when": "editorLangId == simple"
        }
      ],
      "editor/title": [
        {
          "command": "simple.math.openCustomEditor",
          "when": "resourceExtname == .spl",
          "group": "navigation@20"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:math-core-wasm && tsc -b . && npm run build:webview && npm run stage:wasm",
    "build:webview": "node ./scripts/build-webview.mjs",
    "stage:wasm": "node ./scripts/stage-wasm.mjs",
    "build:math-core-wasm": "node ./scripts/stage-wasm.mjs --build-math-core-simple",
    "watch": "tsc -b . --watch",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "test:lsp": "vscode-test --label=lsp-e2e",
    "test:ai": "vscode-test --label=ai-e2e",
    "test:gui": "vscode-test --label=gui",
    "test:integration": "vscode-test --label=integration",
    "test:all": "npm run test",
    "test:watch": "tsc -watch -p ./ & vscode-test --watch",
    "lint": "eslint src --ext ts",
    "package": "npm run compile && vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "mocha": "^10.8.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@vscode/wasm-wasi": "^1.0.2",
    "@vscode/wasm-wasi-lsp": "^0.1.0-pre.9",
    "katex": "^0.16.45",
    "mathjax-full": "^3.2.1",
    "vscode-languageclient": "^10.0.0-next.21"
  }
}
