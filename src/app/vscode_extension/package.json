{
  "name": "simple-rich-editor",
  "displayName": "Simple Rich Editor",
  "description": "Rich custom editor for Simple language files with variable line heights, math rendering, and image embedding",
  "version": "0.1.0",
  "publisher": "simple-lang",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:simple",
    "onCustomEditor:simple.richSourceEditor",
    "onCommand:simple.richEditor.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "simple",
        "extensions": [".spl"],
        "aliases": ["Simple", "simple"]
      }
    ],
    "customEditors": [
      {
        "viewType": "simple.richSourceEditor",
        "displayName": "Simple Rich Source Editor",
        "selector": [
          {
            "filenamePattern": "*.spl"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "simple.richEditor.open",
        "title": "Open Rich Source Editor",
        "category": "Simple Rich"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview",
    "build:webview": "node ./scripts/build-webview.mjs",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node ./scripts/build-webview.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.82.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "katex": "^0.16.45"
  }
}
