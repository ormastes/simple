{
  "name": "simple-rich-editor",
  "displayName": "Simple Rich Editor",
  "description": "Rich custom editor for Simple language files with variable line heights, math rendering, and image embedding",
  "version": "0.1.0",
  "publisher": "simple-lang",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Testing"
  ],
  "activationEvents": [
    "onLanguage:simple",
    "onCustomEditor:simple.richSourceEditor",
    "onCommand:simple.richEditor.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "simple",
        "extensions": [".spl"],
        "aliases": ["Simple", "simple"]
      }
    ],
    "customEditors": [
      {
        "viewType": "simple.richSourceEditor",
        "displayName": "Simple Rich Source Editor",
        "selector": [
          {
            "filenamePattern": "*.spl"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "simple.richEditor.open",
        "title": "Open Rich Source Editor",
        "category": "Simple Rich"
      },
      {
        "command": "simple.richEditor.showOutputChannel",
        "title": "Show Rich Editor Output",
        "category": "Simple Rich"
      },
      {
        "command": "simple.test.runFile",
        "title": "Run Simple Test File",
        "category": "Simple Test"
      },
      {
        "command": "simple.test.runSdoctest",
        "title": "Run Simple Doctest",
        "category": "Simple Test"
      },
      {
        "command": "simple.test.openWorkspace",
        "title": "Open Simple Test Workspace",
        "category": "Simple Test"
      },
      {
        "command": "simple.test.refreshWorkspace",
        "title": "Refresh Simple Test Workspace",
        "category": "Simple Test"
      },
      {
        "command": "simple.test.openLatestArtifacts",
        "title": "Open Latest Test Artifacts",
        "category": "Simple Test"
      },
      {
        "command": "simple.outline.revealSymbol",
        "title": "Reveal Simple Symbol",
        "category": "Simple Rich"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "simpleOutline",
          "name": "Simple Outline"
        }
      ]
    },
    "semanticTokenTypes": [
      {
        "id": "keyword",
        "description": "Language keywords"
      },
      {
        "id": "function",
        "description": "Function names"
      },
      {
        "id": "type",
        "description": "Type names"
      },
      {
        "id": "variable",
        "description": "Variable names"
      },
      {
        "id": "parameter",
        "description": "Function parameters"
      },
      {
        "id": "property",
        "description": "Object properties"
      },
      {
        "id": "number",
        "description": "Numeric literals"
      },
      {
        "id": "string",
        "description": "String literals"
      },
      {
        "id": "comment",
        "description": "Comments"
      },
      {
        "id": "operator",
        "description": "Operators"
      },
      {
        "id": "namespace",
        "description": "Module and suite names"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "declaration",
        "description": "Symbol declaration"
      },
      {
        "id": "definition",
        "description": "Symbol definition"
      },
      {
        "id": "readonly",
        "description": "Read-only variable"
      },
      {
        "id": "static",
        "description": "Static member"
      },
      {
        "id": "deprecated",
        "description": "Deprecated symbol"
      },
      {
        "id": "abstract",
        "description": "Abstract member"
      },
      {
        "id": "async",
        "description": "Async function"
      },
      {
        "id": "modification",
        "description": "Modifying operation"
      },
      {
        "id": "documentation",
        "description": "Documentation comment"
      }
    ],
    "configuration": {
      "title": "Simple Rich Editor",
      "properties": {
        "simple.cli.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Simple CLI binary used for native test runs. Leave empty to use PATH or workspace bin/simple."
        },
        "simple.richEditor.showBlockBorders": {
          "type": "boolean",
          "default": false,
          "description": "Show borders around rendered rich-editor blocks such as math and image widgets."
        },
        "simple.richEditor.centerLineNumbers": {
          "type": "boolean",
          "default": true,
          "description": "Experimental line-number alignment option for the rich editor. Current migration work does not depend on it."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview",
    "build:webview": "node ./scripts/build-webview.mjs",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node ./scripts/build-webview.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.82.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "katex": "^0.16.45"
  }
}
