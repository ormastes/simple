# Simple CLI - check-skip command
# Scans test files for skip/pending markers and reports status.
#
# Usage:
#   bin/simple check-skip                    # Terminal report
#   bin/simple check-skip --format=md        # Markdown output
#   bin/simple check-skip --by-category      # Group by test category
#   bin/simple check-skip --summary          # Summary only

use std.nogc_sync_mut.io.dir_ops.{dir_walk, is_dir}
use std.nogc_sync_mut.io.file_ops.{file_read}
use std.nogc_sync_mut.io.env_ops.{cwd}
use std.nogc_sync_mut.io.sysinfo_ops.{path_basename}
use std.nogc_sync_mut.io_runtime.{get_args}

# ============================================================================
# Data Types
# ============================================================================

struct SkipEntry:
    file_path: text
    category: text
    status: text
    reason: text

struct CategoryStats:
    name: text
    total: i64
    skipped: i64
    pending: i64
    active: i64

struct CheckSkipReport:
    total_files: i64
    skipped_count: i64
    pending_count: i64
    active_count: i64
    skip_percentage: i64
    entries: [SkipEntry]
    categories: [CategoryStats]

# ============================================================================
# Help
# ============================================================================

fn print_help():
    print "Usage: simple check-skip [options]"
    print ""
    print "Scan test files for skip/pending markers and report status."
    print ""
    print "Options:"
    print "  --format=md      Output as markdown (default: terminal)"
    print "  --by-category    Group results by directory category"
    print "  --summary        Show only summary, no file listing"
    print "  -h, --help       Show this help"

# ============================================================================
# File Discovery
# ============================================================================

fn is_test_file(path: text) -> bool:
    if not path.ends_with(".spl"):
        return false
    val name = path_basename(path)
    name.contains("_spec.") or name.contains("_test.")

fn collect_test_files(root: text) -> [text]:
    var files: [text] = []
    val test_path = "{root}/test"
    if not is_dir(test_path):
        return files
    val walked = dir_walk(test_path)
    for f in walked:
        if is_test_file(f):
            files.push(f)
    files

# ============================================================================
# Category Detection
# ============================================================================

fn categorize_file(path: text) -> text:
    if path.contains("/unit/"):
        return "unit"
    if path.contains("/integration/") or path.contains("/integration_e2e/") or path.contains("/core_integration/"):
        return "integration"
    if path.contains("/system/") or path.contains("/core_system/"):
        return "system"
    if path.contains("/feature/") or path.contains("/feature_new/"):
        return "feature"
    if path.contains("/compiler/") or path.contains("/compiler_complete/") or path.contains("/compiler_deep/"):
        return "compiler"
    if path.contains("/lib/") or path.contains("/lib_complete/") or path.contains("/lib_extended/"):
        return "lib"
    if path.contains("/std/") or path.contains("/stdlib_complete/") or path.contains("/stdlib_deep/") or path.contains("/stdlib_improved/"):
        return "stdlib"
    if path.contains("/app/") or path.contains("/app_complete/") or path.contains("/app_extended/"):
        return "app"
    "other"

# ============================================================================
# Skip/Pending Detection
# ============================================================================

fn extract_reason(content: text, marker: text) -> text:
    val lines = content.split("\n")
    var i = 0
    for line in lines:
        val trimmed = line.trim()
        if trimmed.contains(marker):
            if i > 0:
                val prev = lines[i - 1].trim()
                if prev.starts_with("# ") and not prev.starts_with("# @"):
                    return prev.slice(2, prev.len())
            return ""
        i = i + 1
    ""

fn scan_test_file(file_path: text, root_prefix: text) -> [SkipEntry]:
    var results: [SkipEntry] = []
    val content = file_read(file_path) ?? ""
    if content == "":
        return results

    val has_skip = (content.contains("tag: \"skip\"") or
        content.contains("tag: 'skip'") or
        content.contains("# @skip"))
    val has_pending = (content.contains("# @pending") or
        content.contains("tag: \"pending\"") or
        content.contains("tag: 'pending'"))

    if not has_skip and not has_pending:
        return results

    var rel_path = file_path
    if rel_path.starts_with(root_prefix):
        rel_path = rel_path.slice(root_prefix.len(), rel_path.len())

    val category = categorize_file(file_path)

    if has_skip:
        val reason = extract_reason(content, "skip")
        results.push(SkipEntry(
            file_path: rel_path,
            category: category,
            status: "skip",
            reason: reason
        ))

    if has_pending:
        val reason = extract_reason(content, "pending")
        results.push(SkipEntry(
            file_path: rel_path,
            category: category,
            status: "pending",
            reason: reason
        ))

    results

# ============================================================================
# Report Building
# ============================================================================

fn build_report(files: [text], root: text) -> CheckSkipReport:
    val root_prefix = "{root}/"
    var entries: [SkipEntry] = []
    var skipped_count = 0
    var pending_count = 0

    for f in files:
        val file_entries = scan_test_file(f, root_prefix)
        for entry in file_entries:
            if entry.status == "skip":
                skipped_count = skipped_count + 1
            else:
                pending_count = pending_count + 1
            entries.push(entry)

    val total = files.len()
    val active = total - skipped_count - pending_count
    val skip_pct = if total > 0: ((skipped_count + pending_count) * 100) / total else: 0

    val categories = build_category_stats(files, entries)

    CheckSkipReport(
        total_files: total,
        skipped_count: skipped_count,
        pending_count: pending_count,
        active_count: active,
        skip_percentage: skip_pct,
        entries: entries,
        categories: categories
    )

fn build_category_stats(all_files: [text], entries: [SkipEntry]) -> [CategoryStats]:
    val cat_names = ["unit", "integration", "system", "feature", "compiler", "lib", "stdlib", "app", "other"]
    var stats: [CategoryStats] = []

    for cat in cat_names:
        var total = 0
        var skipped = 0
        var pending = 0
        for f in all_files:
            if categorize_file(f) == cat:
                total = total + 1
        for e in entries:
            if e.category == cat:
                if e.status == "skip":
                    skipped = skipped + 1
                else:
                    pending = pending + 1
        if total > 0:
            stats.push(CategoryStats(
                name: cat,
                total: total,
                skipped: skipped,
                pending: pending,
                active: total - skipped - pending
            ))

    stats

# ============================================================================
# Terminal Output
# ============================================================================

fn render_terminal(report: CheckSkipReport, by_category: bool, summary_only: bool):
    print ""
    print "Skip/Pending Test Report"
    print "========================"
    print ""
    print "Total test files:  {report.total_files}"
    print "Active:            {report.active_count}"
    print "Skipped:           {report.skipped_count}"
    print "Pending:           {report.pending_count}"
    print "Skip percentage:   {report.skip_percentage}%"
    print ""

    if by_category:
        print "By Category:"
        print ""
        for cat in report.categories:
            val cat_pct = if cat.total > 0: ((cat.skipped + cat.pending) * 100) / cat.total else: 0
            print "  {cat.name}: {cat.total} total, {cat.skipped} skip, {cat.pending} pending ({cat_pct}%)"
        print ""

    if not summary_only:
        if report.entries.len() > 0:
            print "Skipped/Pending Files:"
            print ""
            for entry in report.entries:
                if entry.reason != "":
                    print "  [{entry.status}] {entry.file_path}  -- {entry.reason}"
                else:
                    print "  [{entry.status}] {entry.file_path}"
            print ""

# ============================================================================
# Markdown Output
# ============================================================================

fn render_markdown(report: CheckSkipReport, by_category: bool, summary_only: bool):
    print "# Skip/Pending Test Report"
    print ""
    print "| Metric | Count |"
    print "|--------|-------|"
    print "| Total files | {report.total_files} |"
    print "| Active | {report.active_count} |"
    print "| Skipped | {report.skipped_count} |"
    print "| Pending | {report.pending_count} |"
    print "| Skip % | {report.skip_percentage}% |"
    print ""

    if by_category:
        print "## By Category"
        print ""
        print "| Category | Total | Skipped | Pending | Active | Skip % |"
        print "|----------|-------|---------|---------|--------|--------|"
        for cat in report.categories:
            val cat_pct = if cat.total > 0: ((cat.skipped + cat.pending) * 100) / cat.total else: 0
            print "| {cat.name} | {cat.total} | {cat.skipped} | {cat.pending} | {cat.active} | {cat_pct}% |"
        print ""

    if not summary_only and report.entries.len() > 0:
        print "## File Details"
        print ""
        print "| Status | File | Reason |"
        print "|--------|------|--------|"
        for entry in report.entries:
            print "| {entry.status} | `{entry.file_path}` | {entry.reason} |"

# ============================================================================
# Main
# ============================================================================

fn main() -> i64:
    val args = get_args()

    var format = "text"
    var by_category = false
    var summary_only = false

    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        if arg == "--format=md" or arg == "--format=markdown":
            format = "md"
        if arg == "--by-category":
            by_category = true
        if arg == "--summary":
            summary_only = true

    val root = cwd()

    val files = collect_test_files(root)
    print "Found {files.len()} test files"

    val report = build_report(files, root)

    if format == "md":
        render_markdown(report, by_category, summary_only)
    else:
        render_terminal(report, by_category, summary_only)

    0
