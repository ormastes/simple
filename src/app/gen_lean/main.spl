# Simple CLI - gen-lean command
# Startup-light wrapper that delegates real work to the pure-Simple verifier.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.io.process_ops.{process_run_timeout}

fn print_help():
    print "Usage: simple gen-lean [options]"
    print "Generates Lean 4 verification files"
    print ""
    print "Commands:"
    print "  generate       Generate all Lean verification files"
    print "  compare        Compare generated with existing Lean files"
    print "  write          Write generated files"
    print "  verify         Run the Lean proof checker"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("gen-lean", log_opts.error)
        return 1

    val args = gen_lean_clean_log_args(raw_args)
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"gen-lean\",\"status\":\"usage\"}"
            return 0
        print_help()
        return 0
    if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
        print_help_with_progress(log_opts.progress)
        return 0
    if args[0].starts_with("-"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"gen-lean\",\"status\":\"error\",\"error\":\"unknown option\"}"
            return 1
        print "error: unknown option: {args[0]}"
        print_help()
        return 1
    delegate_gen_lean(args)

fn delegate_gen_lean(args: [text]) -> i64:
    val subcommand = args[0]
    var worker_command = subcommand
    if subcommand == "write":
        worker_command = "regenerate"
    elif subcommand == "verify":
        worker_command = "check"

    var forwarded: [text] = ["run", "src/compiler/90.tools/verify/main.spl", worker_command]
    for arg in args[1:]:
        forwarded.push(arg)
    # Dispatch to a distinct worker command with a hard deadline. Re-entering
    # `gen-lean` here caused an unbounded self-recursion chain.
    val (stdout, stderr, code) = process_run_timeout("./bin/simple", forwarded, 30000)
    if stdout != "":
        print stdout
    if stderr != "":
        print stderr
    if code == -1:
        error("gen-lean", "verification worker timed out")
        return 124
    code as i64

fn gen_lean_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn gen_lean_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if gen_lean_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
