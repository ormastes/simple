# DEEP analysis reporters for the dependency tool.
#
# Exports:
#   fn deps_deep_report(files: [text], entry: text) -> text
#   fn deps_deep_report_lines(files: [text], entry: text) -> [text]
#
# Three sections per report:
#   1. SCRIPT  — exported interface + line counts per file
#   2. SMF     — sibling .smf artifact existence + size
#   3. NATIVE  — bytes attributable per module via SmfReaderMemory (or estimate)

use std.io_runtime.{file_exists, file_read, file_size}
use app.stats.line_counter (count_lines)
use compiler.tools.stats.types (LineCount)

# ---------------------------------------------------------------------------
# Section 1 helpers — SCRIPT perspective
# ---------------------------------------------------------------------------

fn is_exported_symbol_line(ln: text) -> bool:
    val t = ln.trim()
    if t.starts_with("fn ") and not t.starts_with("fn _"):
        return true
    if t.starts_with("class ") and not t.starts_with("class _"):
        return true
    if t.starts_with("struct ") and not t.starts_with("struct _"):
        return true
    if t.starts_with("enum ") and not t.starts_with("enum _"):
        return true
    if t.starts_with("trait ") and not t.starts_with("trait _"):
        return true
    false

fn extract_symbol_name(ln: text) -> text:
    val t = ln.trim()
    # Strip keyword prefix (fn /class /struct /enum /trait )
    var rest = t
    if t.starts_with("fn "):
        rest = t[3..]
    elif t.starts_with("class "):
        rest = t[6..]
    elif t.starts_with("struct "):
        rest = t[7..]
    elif t.starts_with("enum "):
        rest = t[5..]
    elif t.starts_with("trait "):
        rest = t[6..]
    # Take the word up to first non-ident character
    var name = ""
    var i = 0
    while i < rest.len():
        val ch = rest[i]
        if ch == "(" or ch == ":" or ch == "<" or ch == " " or ch == "{":
            return name
        name = name + ch
        i = i + 1
    name

fn collect_script_lines_for_file(path: text) -> [text]:
    var out: [text] = []
    val lc = count_lines(path)
    val total_code = lc.code

    val content = file_read(path)
    val lines = content.split("\n")
    var symbols: [text] = []
    for ln in lines:
        if is_exported_symbol_line(ln):
            val nm = extract_symbol_name(ln)
            if nm.len() > 0:
                symbols = symbols.push(nm)

    out = out.push("  file: " + path)
    out = out.push("    code_lines: " + total_code.to_string())
    out = out.push("    blank_lines: " + lc.blank.to_string())
    out = out.push("    comment_lines: " + lc.comment.to_string())
    out = out.push("    exported_symbols: " + symbols.len().to_string())
    for s in symbols:
        out = out.push("      - " + s)
    out

# ---------------------------------------------------------------------------
# Section 2 helpers — SMF perspective
# ---------------------------------------------------------------------------

fn stem_of(path: text) -> text:
    # Return path without the last extension (e.g. foo.spl -> foo)
    var last_dot = -1
    var i = path.len() - 1
    while i >= 0:
        val ch = path[i]
        if ch == ".":
            last_dot = i
            return path[0..last_dot]
        if ch == "/" or ch == "\\":
            return path
        i = i - 1
    path

fn sibling_smf_path(spl_path: text) -> text:
    stem_of(spl_path) + ".smf"

fn smf_artifact_paths(spl_path: text) -> [text]:
    var paths: [text] = []
    # 1. Sibling .smf (most common)
    paths = paths.push(sibling_smf_path(spl_path))
    paths

fn collect_smf_lines_for_file(path: text) -> [text]:
    var out: [text] = []
    out = out.push("  file: " + path)
    val candidates = smf_artifact_paths(path)
    var found_path = ""
    var found_size: i64 = 0
    for cp in candidates:
        if file_exists(cp):
            found_path = cp
            found_size = file_size(cp)
    if found_path.len() > 0:
        out = out.push("    smf_artifact: " + found_path)
        out = out.push("    smf_exists: yes")
        out = out.push("    smf_size_bytes: " + found_size.to_string())
    else:
        val sibling = sibling_smf_path(path)
        out = out.push("    smf_artifact: " + sibling)
        out = out.push("    smf_exists: no")
        out = out.push("    smf_size_bytes: 0")
    out

# ---------------------------------------------------------------------------
# Section 3 helpers — NATIVE perspective
# ---------------------------------------------------------------------------

# Estimate constant: bytes per code line when no .smf can be read.
# Derived from observed .smf artifact sizes vs. code line counts.
val NATIVE_BYTES_PER_CODE_LINE: i64 = 48

fn collect_native_lines_for_file(path: text) -> [text]:
    # Native bytes: use sibling .smf file size when present (real artifact size).
    # Falls back to code_lines * NATIVE_BYTES_PER_CODE_LINE estimate.
    # SmfReaderMemory symbol table parsing is skipped in interpreter mode
    # because nested match on cross-module Result causes type confusion;
    # artifact file size is a reliable proxy (same data, different granularity).
    var out: [text] = []
    out = out.push("  file: " + path)

    val lc = count_lines(path)
    val smf_path = sibling_smf_path(path)

    if file_exists(smf_path):
        val art_size = file_size(smf_path)
        out = out.push("    native_method: smf_artifact_size")
        out = out.push("    native_bytes: " + art_size.to_string())
    else:
        val est = lc.code * NATIVE_BYTES_PER_CODE_LINE
        out = out.push("    native_method: estimate_from_code_lines")
        out = out.push("    native_bytes: ~" + est.to_string())
    out

# ---------------------------------------------------------------------------
# Aggregation helpers (return-based to avoid value-type mutation loss)
# ---------------------------------------------------------------------------

fn append_lines(base: [text], extra: [text]) -> [text]:
    var result = base
    for ln in extra:
        result = result.push(ln)
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn deps_deep_report_lines(files: [text], entry: text) -> [text]:
    var out: [text] = []

    # --- Header ---
    out = out.push("=== DEEP DEPENDENCY REPORT ===")
    out = out.push("entry: " + entry)
    out = out.push("total_files: " + files.len().to_string())
    out = out.push("native_estimate_constant: " + NATIVE_BYTES_PER_CODE_LINE.to_string() + " bytes/code_line (used when no .smf is readable)")
    out = out.push("")

    # -------------------------------------------------------------------
    # Section 1: SCRIPT perspective
    # -------------------------------------------------------------------
    out = out.push("--- SECTION 1: SCRIPT (interfaces and line counts) ---")
    var total_code: i64 = 0
    var total_symbols: i64 = 0
    for fp in files:
        val file_lines = collect_script_lines_for_file(fp)
        out = append_lines(out, file_lines)
        # Accumulate totals (re-scan since we don't carry state out of the helper)
        val lc = count_lines(fp)
        total_code = total_code + lc.code
        # Count symbol lines from the source (quick rescan)
        val content = file_read(fp)
        val src_lines = content.split("\n")
        for ln in src_lines:
            if is_exported_symbol_line(ln):
                val nm = extract_symbol_name(ln)
                if nm.len() > 0:
                    total_symbols = total_symbols + 1
    out = out.push("")
    out = out.push("SCRIPT TOTALS:")
    out = out.push("  total_files: " + files.len().to_string())
    out = out.push("  total_code_lines: " + total_code.to_string())
    out = out.push("  total_interface_symbols: " + total_symbols.to_string())
    out = out.push("")

    # -------------------------------------------------------------------
    # Section 2: SMF perspective
    # -------------------------------------------------------------------
    out = out.push("--- SECTION 2: SMF (artifact presence and size) ---")
    var smf_present: i64 = 0
    var smf_total_bytes: i64 = 0
    for fp in files:
        val file_lines = collect_smf_lines_for_file(fp)
        out = append_lines(out, file_lines)
        val smf_path = sibling_smf_path(fp)
        if file_exists(smf_path):
            smf_present = smf_present + 1
            smf_total_bytes = smf_total_bytes + file_size(smf_path)
    out = out.push("")
    out = out.push("SMF TOTALS:")
    out = out.push("  artifacts_present: " + smf_present.to_string() + " of " + files.len().to_string())
    out = out.push("  total_artifact_bytes: " + smf_total_bytes.to_string())
    out = out.push("")

    # -------------------------------------------------------------------
    # Section 3: NATIVE perspective
    # -------------------------------------------------------------------
    out = out.push("--- SECTION 3: NATIVE (bytes per module) ---")
    var total_native_bytes: i64 = 0
    for fp in files:
        val file_lines = collect_native_lines_for_file(fp)
        out = append_lines(out, file_lines)
        # Extract native bytes from last computed value for totals
        val lc = count_lines(fp)
        val smf_path = sibling_smf_path(fp)
        if file_exists(smf_path):
            val artifact_size = file_size(smf_path)
            total_native_bytes = total_native_bytes + artifact_size
        else:
            total_native_bytes = total_native_bytes + lc.code * NATIVE_BYTES_PER_CODE_LINE
    out = out.push("")
    out = out.push("NATIVE TOTALS:")
    out = out.push("  total_native_bytes: " + total_native_bytes.to_string())
    out = out.push("")

    out

fn deps_deep_report(files: [text], entry: text) -> text:
    val lines = deps_deep_report_lines(files, entry)
    var result = ""
    var first = true
    for ln in lines:
        if first:
            result = ln
            first = false
        else:
            result = result + "\n" + ln
    result
