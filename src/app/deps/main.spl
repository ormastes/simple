# Dependency Analysis Tool — src/app/deps/main.spl
#
# CLI entry point for `bin/simple deps`. All analysis logic lives in scanner.spl.
# Called via: bin/simple src/app/deps/main.spl <subcmd> <file>
# argv[0] = this file path, argv[1] = subcmd, argv[2] = entry file

use std.cli.cli_util.{get_cli_args}
use app.deps.scanner.{_run_fast, _run_normal}

fn run_deps(args: [text]) -> i64:
    if args.len() == 0:
        print "Usage: bin/simple deps <fast|normal|deep> <file.spl>"
        return 1
    val subcmd = args[0]
    if subcmd == "deep":
        print "deep mode: not yet implemented"
        return 1
    if args.len() < 2:
        print "Usage: bin/simple deps <fast|normal> <file.spl>"
        return 1
    val entry_file = args[1]
    if subcmd == "fast":
        return _run_fast(entry_file)
    elif subcmd == "normal":
        return _run_normal(entry_file)
    else:
        print "Unknown deps subcommand: {subcmd}"
        print "Usage: bin/simple deps <fast|normal|deep> <file.spl>"
        return 1

fn main() -> i64:
    val all_args = get_cli_args()
    # When invoked via command table, args[0] is "deps" — skip it
    val args = if all_args.len() > 0 and all_args[0] == "deps": all_args[1:] else: all_args
    return run_deps(args)
