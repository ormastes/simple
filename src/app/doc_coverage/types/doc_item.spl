# Documentation coverage item types.

enum DocKind:
    Function
    Struct
    Class
    Enum
    Module

struct DocItem:
    name: text
    kind: DocKind
    file_path: text
    line: i64
    col: i64
    visibility: text
    signature: text
    has_inline_comment: bool
    has_docstring: bool
    has_sdoctest: bool
    is_public: bool
    is_exported: bool
    sdoctest_tags: [text]

    static fn create_function(name: text, path: text, line: i64, col: i64, vis: text, sig: text) -> DocItem:
        DocItem(
            name: name,
            kind: DocKind.Function,
            file_path: path,
            line: line,
            col: col,
            visibility: vis,
            signature: sig,
            has_inline_comment: false,
            has_docstring: false,
            has_sdoctest: false,
            is_public: vis == "pub",
            is_exported: false,
            sdoctest_tags: []
        )

    static fn create_struct(name: text, path: text, line: i64, col: i64, vis: text) -> DocItem:
        DocItem(
            name: name,
            kind: DocKind.Struct,
            file_path: path,
            line: line,
            col: col,
            visibility: vis,
            signature: "struct {name}",
            has_inline_comment: false,
            has_docstring: false,
            has_sdoctest: false,
            is_public: vis == "pub",
            is_exported: false,
            sdoctest_tags: []
        )
