# Documentation coverage aggregate types.

use app.doc_coverage.types.doc_item.{DocItem}

struct FileCoverage:
    path: text
    total_items: i64
    documented_items: i64
    missing_docs: i64
    has_sdoctest: i64
    missing_sdoctest: i64
    items: [DocItem]

    static fn create(path: text) -> FileCoverage:
        FileCoverage(
            path: path,
            total_items: 0,
            documented_items: 0,
            missing_docs: 0,
            has_sdoctest: 0,
            missing_sdoctest: 0,
            items: []
        )

struct CoverageReport:
    total_items: i64
    documented_items: i64
    missing_docs: i64
    sdoctest_coverage: i64
    missing_sdoctest: i64
    timestamp: i64
    files: [FileCoverage]

    static fn create() -> CoverageReport:
        CoverageReport(
            total_items: 0,
            documented_items: 0,
            missing_docs: 0,
            sdoctest_coverage: 0,
            missing_sdoctest: 0,
            timestamp: 0,
            files: []
        )
