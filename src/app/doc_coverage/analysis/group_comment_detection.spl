# Variable group comment detection helpers.

struct VariableGroup:
    file_path: text
    start_line: i64
    end_line: i64
    var_names: [text]
    var_count: i64
    has_group_comment: bool
    suggested_comment: text

fn _is_var_decl(line: text) -> bool:
    val trimmed = line.trim()
    trimmed.starts_with("var ") or trimmed.starts_with("val ")

fn _var_name(line: text) -> text:
    var rest = line.trim()
    if rest.starts_with("var "):
        rest = rest[4:]
    elif rest.starts_with("val "):
        rest = rest[4:]
    val colon = rest.index_of(":") ?? -1
    val eq = rest.index_of("=") ?? -1
    var end = rest.len()
    if colon >= 0 and colon < end:
        end = colon
    if eq >= 0 and eq < end:
        end = eq
    rest[0:end].trim()

fn _has_comment_before(lines: [text], start_index: i64) -> bool:
    var blanks = 0
    var i = start_index - 1
    while i >= 0:
        val trimmed = lines[i].trim()
        if trimmed == "":
            blanks = blanks + 1
            if blanks > 1:
                return false
        elif trimmed.starts_with("#"):
            return true
        else:
            return false
        i = i - 1
    false

fn _make_group(path: text, start_index: i64, end_index: i64, names: [text], lines: [text]) -> VariableGroup:
    val count = names.len() as i64
    val has_comment = _has_comment_before(lines, start_index)
    val base = VariableGroup(
        file_path: path,
        start_line: start_index + 1,
        end_line: end_index + 1,
        var_names: names,
        var_count: count,
        has_group_comment: has_comment,
        suggested_comment: ""
    )
    VariableGroup(
        file_path: base.file_path,
        start_line: base.start_line,
        end_line: base.end_line,
        var_names: base.var_names,
        var_count: base.var_count,
        has_group_comment: base.has_group_comment,
        suggested_comment: suggest_group_comment(base)
    )

fn detect_variable_groups(path: text, source: text) -> [VariableGroup]:
    val lines = source.split("\n")
    var groups: [VariableGroup] = []
    var names: [text] = []
    var start_index = 0
    var end_index = 0
    var in_group = false
    var idx = 0
    for line in lines:
        val trimmed = line.trim()
        if _is_var_decl(line):
            if not in_group:
                start_index = idx
                names = []
                in_group = true
            names.push(_var_name(line))
            end_index = idx
        elif trimmed == "" or trimmed.starts_with("#"):
            pass
        else:
            if in_group and names.len() >= 2:
                groups.push(_make_group(path, start_index, end_index, names, lines))
            names = []
            in_group = false
        idx = idx + 1
    if in_group and names.len() >= 2:
        groups.push(_make_group(path, start_index, end_index, names, lines))
    groups

fn _all_upper(names: [text]) -> bool:
    if names.len() == 0:
        return false
    for name in names:
        if name != name.to_uppercase():
            return false
    true

fn _common_prefix(names: [text]) -> text:
    if names.len() == 0:
        return ""
    val parts = names[0].split("_")
    if parts.len() == 0:
        return ""
    val prefix = parts[0]
    for name in names:
        if not name.starts_with("{prefix}_"):
            return ""
    prefix

fn _common_suffix(names: [text]) -> text:
    if names.len() == 0:
        return ""
    val parts = names[0].split("_")
    if parts.len() == 0:
        return ""
    val suffix = parts[-1]
    for name in names:
        if not name.ends_with("_{suffix}"):
            return ""
    suffix

fn suggest_group_comment(group: VariableGroup) -> text:
    val names = group.var_names
    if _all_upper(names):
        return "# Constants"
    val prefix = _common_prefix(names)
    if prefix == "config":
        return "# {prefix}_* variables"
    val suffix = _common_suffix(names)
    if suffix == "count" and names.len() >= 3:
        return "# *_{suffix} variables"
    for name in names:
        if name.contains("config"):
            return "# Configuration variables"
    for name in names:
        if name.contains("state"):
            return "# State variables"
    for name in names:
        if name.contains("count"):
            return "# Counter variables"
    for name in names:
        if name.starts_with("is_") or name.starts_with("has_"):
            return "# Flag variables"
    "# Group of {group.var_count} related variables"

fn emit_group_comment_warnings(groups: [VariableGroup]) -> [text]:
    var warnings: [text] = []
    for group in groups:
        if not group.has_group_comment:
            warnings.push("{group.file_path}:{group.start_line}: Group of {group.var_count} variables ({group.var_names.join(\", \")}) needs a group comment")
            warnings.push("Suggestion: {group.suggested_comment}")
    warnings

fn classify_variable_group(group: VariableGroup) -> [text]:
    var tags: [text] = []
    if group.has_group_comment:
        tags.push("group_comment:present")
    else:
        tags.push("group_comment:missing")
    val suggestion = group.suggested_comment
    if suggestion.contains("Configuration"):
        tags.push("var_group:config")
    elif suggestion.contains("State"):
        tags.push("var_group:state")
    elif suggestion.contains("Constants"):
        tags.push("var_group:constants")
    elif suggestion.contains("Counter"):
        tags.push("var_group:counter")
    elif suggestion.contains("Flag"):
        tags.push("var_group:flag")
    else:
        tags.push("var_group:general")
    tags
