use app.verify.tooling_gate.{list_changed_files, split_csv_files}
use app.verify.tooling_gate.{
    build_default_tooling_verify_report,
    render_verify_report,
    write_verify_report,
    default_report_dir
}
use app.verify.test_quality_gate.{
    build_test_quality_verify_report,
    render_test_quality_verify_report,
    write_test_quality_verify_report
}
use common.ui.theme_package.{validate_default_theme_package, render_theme_validation_report}

fn collect_scope_files(args: [text]) -> [text]:
    var explicit_files: [text] = []
    for arg in args:
        if arg.starts_with("--files="):
            for path in split_csv_files(arg.substring(8)):
                explicit_files.push(path)
        elif not arg.starts_with("-"):
            explicit_files.push(arg)
    if explicit_files.len() > 0:
        return explicit_files
    list_changed_files()

fn run_full_verify(args: [text]) -> i64:
    val files = collect_scope_files(args)
    val scope = if args.contains("--all"):
        "full project"
    else:
        "current changes"

    val report = build_default_tooling_verify_report(files, scope)
    print render_verify_report(report)

    val theme_issues = validate_default_theme_package()
    print ""
    print render_theme_validation_report(theme_issues)

    val quality_report = build_test_quality_verify_report(scope, files, args.contains("--all"))
    print ""
    print render_test_quality_verify_report(quality_report)

    if not args.contains("--no-write-report"):
        val report_path = write_verify_report(report, default_report_dir())
        if report_path != "":
            print ""
            print "Report: {report_path}"
        val quality_report_path = write_test_quality_verify_report(quality_report, default_report_dir())
        if quality_report_path != "":
            print "Quality report: {quality_report_path}"

    if report.status == "FAIL" or quality_report.status == "FAIL" or theme_issues.len() > 0:
        1
    elif report.status == "WARN" or quality_report.status == "WARN":
        0
    else:
        0

export run_full_verify
