# Simple CLI - verify command
#
# Production-readiness verification focused on current changes. For MCP/LSP and
# tool-server changes, this command requires wrapper audit, request-path audit,
# and performance evidence artifacts before returning PASS.

use std.cli.cli_util.{get_cli_args}
use app.verify.tooling_gate.{
    list_changed_files,
    split_csv_files,
    build_default_tooling_verify_report,
    render_verify_report,
    write_verify_report,
    default_report_dir
}

fn print_help():
    print "Usage: simple verify [options] [file ...]"
    print ""
    print "Verifies current changes for production-readiness."
    print ""
    print "Options:"
    print "  --all                 Run the tooling gate for the full project scope"
    print "  --files=a,b,c         Override changed-file discovery with an explicit file list"
    print "  --no-write-report     Do not write doc/09_report/verify output"
    print "  -h, --help            Show this help"

fn collect_scope_files(args: [text]) -> [text]:
    var explicit_files: [text] = []
    for arg in args:
        if arg.starts_with("--files="):
            for path in split_csv_files(arg.substring(8)):
                explicit_files.push(path)
        elif not arg.starts_with("-"):
            explicit_files.push(arg)
    if explicit_files.len() > 0:
        return explicit_files
    list_changed_files()

fn main() -> i64:
    val args = get_cli_args()

    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0

    val files = collect_scope_files(args)
    val scope = if args.contains("--all"):
        "full project"
    else:
        "current changes"

    val report = build_default_tooling_verify_report(files, scope)
    print render_verify_report(report)

    if not args.contains("--no-write-report"):
        val report_path = write_verify_report(report, default_report_dir())
        if report_path != "":
            print ""
            print "Report: {report_path}"

    if report.status == "FAIL":
        1
    else:
        0
