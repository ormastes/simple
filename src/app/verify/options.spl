# Fail-closed CLI grammar for `simple verify`.

fn verify_files_value_error(value: text) -> text:
    if value.trim() == "":
        return "--files requires a non-empty comma-separated file list"
    for path in value.split(","):
        if path.trim() == "":
            return "--files requires a non-empty comma-separated file list"
    ""

fn verify_scope_option_error(args: [text]) -> text:
    var has_all = false
    var has_files = false
    var has_positionals = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--all":
            if has_all:
                return "--all may be specified only once"
            has_all = true
        elif arg.starts_with("--files="):
            if has_files:
                return "--files may be specified only once"
            val value_error = verify_files_value_error(arg.substring(8))
            if value_error != "":
                return value_error
            has_files = true
        elif arg == "--files":
            return "--files requires a non-empty comma-separated file list; use --files=a,b"
        elif arg == "--no-write-report":
            val _ = 0
        elif arg.starts_with("-"):
            return "unknown option: {arg}"
        else:
            if arg.trim() == "":
                return "file path must not be empty"
            has_positionals = true
        i = i + 1

    if has_all and (has_files or has_positionals):
        return "--all cannot be combined with explicit files"
    if has_files and has_positionals:
        return "--files cannot be combined with positional files"
    ""

pub fn verify_option_error(args: [text]) -> text:
    if args.len() == 0:
        return ""

    for arg in args:
        if arg == "-h" or arg == "--help":
            if args.len() == 1:
                return ""
            return "help cannot be combined with other arguments"

    val command = args[0]
    if command == "status" or command == "list" or command == "check" or command == "regenerate":
        if args.len() > 1:
            return "{command} does not accept arguments"
        return ""
    if command == "--lean-status":
        if args.len() > 1:
            return "--lean-status cannot be combined with other arguments"
        return ""
    if command == "quality":
        return verify_scope_option_error(args[1:])
    verify_scope_option_error(args)
