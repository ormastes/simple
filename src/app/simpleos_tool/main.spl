# Focused Simple compiler/interpreter/loader entrypoint for SimpleOS.
#
# This deliberately exposes only the language operations required on the guest;
# desktop and host-service commands belong to the full CLI, not this target.

use app.simpleos_tool.focused_pipeline.{simpleos_compile_native_file, simpleos_interpret_file}
use app.io.args_ops.{get_args}
use app.io.env_ops.{env_set}

fn configure_guest_toolchain() -> bool:
    if (not env_set("SIMPLE_NATIVE_BUILD_TARGET", "x86_64-unknown-simpleos") or
        not env_set("SIMPLE_TARGET", "x86_64-unknown-simpleos") or
        not env_set("SIMPLE_SYSROOT", "/usr") or
        not env_set("SIMPLE_SIMPLE_CORE_PATH", "/usr/lib/SIMPRT.A") or
        not env_set("SIMPLE_CRT0_PATH", "/usr/lib/CRT0.O") or
        not env_set("SIMPLE_LIBC_PATH", "/usr/lib/SOSLIB.A") or
        not env_set("SIMPLE_LINKER_SCRIPT", "/SYSRT/SIMPLEOS.LD") or
        not env_set("SIMPLEOS_FOCUSED_HIR_DIAG", "1") or
        not env_set("SIMPLE_CC", "/usr/bin/clang")):
        return false
    true

fn compile_native(args: [text]) -> i64:
    var source = ""
    var output = ""
    var emit_object = false
    var emit_llvm = false
    var i = 2
    while i < args.len():
        if args[i] == "--native":
            i = i + 1
            continue
        elif args[i] == "--emit-object":
            emit_object = true
        elif args[i] == "--emit-llvm":
            emit_llvm = true
        elif args[i] == "-o" and i + 1 < args.len():
            i = i + 1
            output = args[i]
        elif args[i].starts_with("-"):
            print "error: unsupported compile option: {args[i]}"
            return 2
        elif source == "":
            source = args[i]
        else:
            print "error: compile accepts one source file"
            return 2
        i = i + 1

    if source == "" or output == "":
        print "usage: simple compile [--native|--emit-object|--emit-llvm] <source.spl> -o <output>"
        return 2
    if emit_object and emit_llvm:
        print "error: choose one emit mode"
        return 2

    if not configure_guest_toolchain():
        print "error: failed to configure the SimpleOS native toolchain"
        return 1
    simpleos_compile_native_file(source, output, emit_object, emit_llvm)

fn main() -> i64:
    val args = get_args()
    if args.len() < 2:
        print "usage: simple [--version|compile [--native|--emit-object|--emit-llvm] <source> -o <output>|<file.spl>]"
        return 2

    val command = args[1]
    if command == "--version":
        print "Simple v1.0.0-beta"
        return 0
    if command == "compile":
        return compile_native(args)
    simpleos_interpret_file(command)
