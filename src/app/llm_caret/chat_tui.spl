# LLM Caret - Interactive Chat TUI
#
# An interactive, full-screen chat shell for llm_caret built on the stdlib TUI
# framework (std.tui). It replaces the headless raw-print experience with a
# scrollable transcript panel (BoxWidget) + a prompt input line (InputWidget)
# + a status/hint line.
#
# Design:
#   - Pure formatting helpers (format_turn_line, format_tool_line,
#     tui_role_style, select_renderer_mode, ...) hold NO terminal state, so they
#     are unit-testable without a live terminal.
#   - The mutable transcript lives in module-level state (TUI_TRANSCRIPT), the
#     same idiom chat.spl uses for history. render_turn / render_tool_call
#     append styled lines to it.
#   - tui_tool_renderer is the renderer seam handed to
#     chat.run_agent_loop_rendered: when a TUI session is active, tool results
#     are drawn as styled transcript lines instead of raw prints.
#
# ponytail: assistant replies render after completion (non-streaming). std.tui
# has no incremental/streaming re-render primitive; token-by-token streaming is
# the upgrade path (would need a partial-line redraw during responder()).
#
# Session hooks + slash commands: run_chat_tui/run_chat_plain accept a
# SessionHooks bundle so provider/model switching, session listing, and
# session resume/persistence (owned by app.llm_caret.session + main.spl's
# runtime state) can be triggered from the chat input without chat_tui.spl
# depending on main.spl (that would be circular - main.spl imports this
# module). dispatch_slash/parse_slash_command/SlashResult are pure and
# unit-testable with a fake SessionHooks.

use std.tui.terminal.*
use std.tui.style.*
use std.tui.widget.{Rect, make_rect, pad_or_truncate}
use std.tui.widgets.box_widget.{BoxWidget, make_box_widget_with_content, box_render}
use std.tui.widgets.input.{
    InputWidget, make_input_widget, input_clear, input_render
}

use app.llm_caret.types.{Message, new_user_message}
use app.llm_caret.interface_text.{caret_role_label, caret_turn_line}
use app.llm_caret.tools.{ToolCall, ToolResult, ModelResponse, PermissionPolicy}
use app.llm_caret.chat.{AgentResult, run_agent_loop, run_agent_loop_rendered,
                        tool_call_status, tool_call_summary}
use app.llm_caret.claude_full.commands.{findRootCommand, admitRootCommand}
use app.llm_caret.tui_input.{
    select_renderer_mode, caret_is_tty, make_raw_line_state,
    step_raw_line_byte, RAW_LINE_SUBMIT, RAW_LINE_EXIT,
    RAW_LINE_PAGE_UP, RAW_LINE_PAGE_DOWN
}

extern fn rt_stdin_read_line() -> text

# ============================================================================
# Module-level session state
# ============================================================================

# Accumulated styled conversation lines (transcript panel contents). The
# conversation history itself (threaded back into the model each turn) is a
# local var owned by run_chat_tui/run_chat_plain, not module state - each
# call is one session and the history is passed in/out via SessionHooks +
# AgentResult.final_transcript instead.
var TUI_TRANSCRIPT: [StyledLine] = []

# Scroll state: -1 = auto-follow (always show the tail, the default); >= 0 =
# the absolute transcript-line index currently at the top of the viewport (a
# fixed point, so appending new messages while scrolled does NOT move the
# view - the guide's "new message while scrolled does not yank view").
var SCROLL_TOP: i64 = -1

# Status-bar state: turn count (shown next to provider/model/session) and a
# transient "waiting for response" flag toggled around the responder call.
var TURN_COUNT: i64 = 0
var AWAITING_RESPONSE: bool = false

# ============================================================================
# ChatTui - owns the session's widgets (transcript panel title, prompt input,
# hint line). Turn/tool styling is applied by the free tui_role_style /
# tui_tool_style functions at render time, not stored on the struct.
# ============================================================================

struct ChatTui:
    title: text
    hint: text
    input: InputWidget
    status: text     # e.g. "provider=claude_cli model=claude-sonnet-4-20250514" - set once by main.spl

fn make_chat_tui(title: text) -> ChatTui:
    make_chat_tui_with_status(title, "")

fn make_chat_tui_with_status(title: text, status: text) -> ChatTui:
    ChatTui(
        title: title,
        hint: " Enter=send   /exit,Ctrl-C,Ctrl-D=quit   Ctrl-P/Ctrl-N=scroll ",
        input: make_input_widget("> ", fg_style(COLOR_WHITE)),
        status: status
    )

fn _ui_set_input(ui: ChatTui, inp: InputWidget) -> ChatTui:
    ChatTui(
        title: ui.title,
        hint: ui.hint,
        input: inp,
        status: ui.status
    )

# ============================================================================
# Pure formatting helpers (no terminal state - unit-testable)
# ============================================================================

fn tui_role_label(role: text) -> text:
    caret_role_label(role)

fn format_turn_line(role: text, content: text) -> text:
    caret_turn_line(role, content)

fn tui_role_style(role: text) -> Style:
    if role == "user":
        return make_style(COLOR_CYAN, COLOR_NONE, true, false, false, false)
    if role == "assistant":
        return fg_style(COLOR_GREEN)
    tui_default_style()

fn format_tool_line(name: text, status: text, summary: text) -> text:
    "  -> tool " + name + " [" + status + "]: " + summary

fn tui_tool_style(status: text) -> Style:
    if status == "error":
        return fg_style(COLOR_RED)
    fg_style(COLOR_YELLOW)

# ============================================================================
# Markdown-lite line rendering (no full markdown parser - line-based only):
#   - fenced ``` blocks render dim, indentation preserved verbatim
#   - `inline code` spans render in a distinct color within a normal line
#   - "- "/"* " bullet lines get an extra indent
# ============================================================================

fn _dim_style() -> Style:
    make_style(COLOR_NONE, COLOR_NONE, false, false, false, true)

fn _code_span_style() -> Style:
    fg_style(COLOR_MAGENTA)

fn is_fence_line(line: text) -> bool:
    line.trim().starts_with("```")

fn bullet_indent(line: text) -> text:
    if line.starts_with("- ") or line.starts_with("* "):
        return "  " + line
    line

# Splits `line` into styled segments, rendering `inline code` spans in
# _code_span_style() and everything else in `base_style`. Unmatched/odd
# backtick counts just render the remainder as plain text (best-effort, no
# parser errors surface to the user).
fn inline_code_segments(line: text, base_style: Style) -> [StyledSegment]:
    var segs: [StyledSegment] = []
    var buf = ""
    var in_code = false
    var i = 0
    while i < line.len():
        val ch = line[i]
        if ch == "`":
            if buf != "":
                if in_code:
                    segs = segs + [make_segment(buf, _code_span_style())]
                else:
                    segs = segs + [make_segment(buf, base_style)]
                buf = ""
            in_code = not in_code
        else:
            buf = buf + ch
        i = i + 1
    if buf != "":
        if in_code:
            segs = segs + [make_segment(buf, _code_span_style())]
        else:
            segs = segs + [make_segment(buf, base_style)]
    if segs.len() == 0:
        segs = [make_segment("", base_style)]
    segs

# Renders one turn's (possibly multi-line) content as multiple StyledLines:
# the role label prefixes the first line only, fenced code blocks render dim
# with indentation preserved, bullet lines get an extra indent, and inline
# `code` spans within normal lines render in a distinct color.
fn markdown_turn_lines(role: text, content: text) -> [StyledLine]:
    val base_style = tui_role_style(role)
    var lines: [StyledLine] = []
    var in_fence = false
    var first = true
    for raw_line in content.split("\n"):
        # Fence detection must run on the UNPREFIXED line - a role label
        # ("Assistant: ") glued onto the first line would otherwise hide a
        # fence marker that happens to open on turn 1 (`msg = "```\ncode\n```"`).
        val fence = is_fence_line(raw_line)
        var line = raw_line
        if first:
            line = tui_role_label(role) + ": " + line
            first = false
        if fence:
            in_fence = not in_fence
            lines = lines + [make_styled_line(line, _dim_style())]
        elif in_fence:
            lines = lines + [make_styled_line(line, _dim_style())]
        else:
            lines = lines + [make_line(inline_code_segments(bullet_indent(line), base_style))]
    lines

# ============================================================================
# Session hooks (DI seam into main.spl's runtime state + session.spl)
# ============================================================================

struct ProviderSwitchResult:
    accepted: bool
    message: text
    provider: text
    model: text

struct SessionResumeResult:
    found: bool
    message: text
    messages: [Message]
    session_id: text
    provider: text
    model: text

struct SessionHooks:
    session_id: text
    hidden_commands_enabled: bool
    on_model: fn(text) -> text
    on_provider: fn(text) -> ProviderSwitchResult
    on_sessions: fn() -> text
    on_new: fn() -> text
    on_resume: fn(text) -> SessionResumeResult
    on_hidden_command: fn(text, text) -> text
    on_persist: fn(text, [Message])

# ============================================================================
# Slash commands (pure parse + dispatch - unit-testable without a terminal)
# ============================================================================

fn is_slash_command(line: text) -> bool:
    line.starts_with("/")

fn _split_first_space(s: text) -> (text, text):
    var i = 0
    while i < s.len():
        if s[i] == " ":
            return (s.substring(0, i), s.substring(i + 1).trim())
        i = i + 1
    (s, "")

# Splits "/model foo" into ("model", "foo"); "/help" into ("help", "").
fn parse_slash_command(line: text) -> (text, text):
    _split_first_space(line.substring(1))

fn slash_help_text() -> text:
    "Commands:\n" +
    "  /help              show this help\n" +
    "  /exit, /quit       end the session\n" +
    "  /new               start a new conversation (clears history)\n" +
    "  /model <name>      switch model\n" +
    "  /provider <name>   switch provider\n" +
    "  /sessions          list saved sessions\n" +
    "  /resume <id>       resume a saved session"

struct SlashResult:
    message: text
    exit: bool
    new_conv: bool
    replace_conv: bool
    loaded_messages: [Message]
    new_session_id: text
    status_provider: text
    status_model: text
    status_session: text

fn _slash_msg(message: text) -> SlashResult:
    SlashResult(
        message: message, exit: false, new_conv: false,
        replace_conv: false, loaded_messages: [], new_session_id: "",
        status_provider: "", status_model: "", status_session: ""
    )

fn _slash_status(message: text, provider: text, model: text, session: text) -> SlashResult:
    SlashResult(
        message: message, exit: false, new_conv: false,
        replace_conv: false, loaded_messages: [], new_session_id: "",
        status_provider: provider, status_model: model, status_session: session
    )

# Every /command's effect is expressed purely in the returned SlashResult;
# the caller (run_chat_tui/run_chat_plain) applies it. Unknown /commands are
# reported back instead of being sent to the model (never silently forwarded).
fn dispatch_slash(cmd: text, arg: text, hooks: SessionHooks) -> SlashResult:
    if cmd == "help" or cmd == "?":
        return _slash_msg(slash_help_text())
    if cmd == "exit" or cmd == "quit":
        return SlashResult(
            message: "", exit: true, new_conv: false,
            replace_conv: false, loaded_messages: [], new_session_id: "",
            status_provider: "", status_model: "", status_session: ""
        )
    if cmd == "new" or cmd == "clear" or cmd == "reset":
        val new_id = hooks.on_new()
        return SlashResult(
            message: "started a new conversation", exit: false, new_conv: true,
            replace_conv: false, loaded_messages: [],
            new_session_id: new_id,
            status_provider: "", status_model: "", status_session: new_id
        )
    if cmd == "model":
        if arg == "":
            return _slash_msg("Usage: /model <name>")
        return _slash_status(hooks.on_model(arg), "", arg, "")
    if cmd == "provider":
        if arg == "":
            return _slash_msg("Usage: /provider <name>")
        val changed = hooks.on_provider(arg)
        if changed.accepted:
            return _slash_status(
                changed.message, changed.provider, changed.model, ""
            )
        return _slash_msg(changed.message)
    if cmd == "sessions":
        return _slash_msg(hooks.on_sessions())
    if cmd == "resume":
        if arg == "":
            return _slash_msg("Usage: /resume <session_id>")
        val resumed = hooks.on_resume(arg)
        return SlashResult(
            message: resumed.message, exit: false, new_conv: false,
            replace_conv: resumed.found, loaded_messages: resumed.messages,
            new_session_id: resumed.session_id,
            status_provider: if resumed.found: resumed.provider else: "",
            status_model: if resumed.found: resumed.model else: "",
            status_session: if resumed.found: resumed.session_id else: ""
        )
    val root = findRootCommand(cmd)
    if root.found and root.command.hidden:
        val admitted = admitRootCommand(cmd, hooks.hidden_commands_enabled)
        if admitted.found:
            return _slash_msg(
                hooks.on_hidden_command(admitted.command.name, arg)
            )
        # Do not disclose hidden registry membership while its gate is off.
        return _slash_msg("Unknown command: /" + cmd + " (try /help)")
    if root.found and not root.command.enabled:
        return _slash_msg("Command disabled: /" + cmd)
    if root.found:
        return _slash_msg(
            "Command not implemented in Caret: /" + root.command.name
        )
    _slash_msg("Unknown command: /" + cmd + " (try /help)")

fn _replace_status_field(status: text, key: text, value: text) -> text:
    val prefix = key + "="
    val fields = status.split(" ")
    var updated: [text] = []
    var replaced = false
    for field in fields:
        if field.starts_with(prefix):
            updated.push(prefix + value)
            replaced = true
        elif field != "":
            updated.push(field)
    if not replaced:
        updated.push(prefix + value)
    updated.join(" ")

fn apply_slash_status(ui: ChatTui, result: SlashResult) -> ChatTui:
    if result.status_provider == "" and result.status_model == "" and
       result.status_session == "":
        return ui
    var title = ui.title
    var status = ui.status
    if result.status_provider != "":
        if title.starts_with("llm_caret - "):
            title = "llm_caret - " + result.status_provider
        status = _replace_status_field(
            status, "provider", result.status_provider
        )
    if result.status_model != "":
        status = _replace_status_field(status, "model", result.status_model)
    if result.status_session != "":
        status = _replace_status_field(
            status, "session", result.status_session
        )
    ChatTui(
        title: title,
        hint: ui.hint,
        input: ui.input,
        status: status
    )

# ============================================================================
# Transcript state ops
# ============================================================================

fn tui_transcript_reset():
    TUI_TRANSCRIPT = []
    SCROLL_TOP = -1
    TURN_COUNT = 0
    AWAITING_RESPONSE = false

fn tui_transcript_len() -> i64:
    TUI_TRANSCRIPT.len()

fn _line_plain_text(line: StyledLine) -> text:
    var out = ""
    var i = 0
    while i < line.segments.len():
        out = out + line.segments[i].content
        i = i + 1
    out

# Plain (ANSI-stripped) text of a transcript line - used by tests to assert on
# content without decoding escape codes.
fn tui_transcript_line_text(idx: i64) -> text:
    if idx < 0 or idx >= TUI_TRANSCRIPT.len():
        return ""
    _line_plain_text(TUI_TRANSCRIPT[idx])

# Append a styled conversation turn (user vs assistant visually distinct).
# Multi-line content (markdown-lite: fenced code / bullets / inline code) is
# split into one StyledLine per source line - see markdown_turn_lines.
fn render_turn(role: text, content: text):
    for line in markdown_turn_lines(role, content):
        TUI_TRANSCRIPT = TUI_TRANSCRIPT + [line]

# Append a styled tool-call line. This is what replaces the raw print that was
# at chat.spl:172 when a TUI session is active.
fn render_tool_call(name: text, status: text, summary: text):
    val line = make_styled_line(format_tool_line(name, status, summary), tui_tool_style(status))
    TUI_TRANSCRIPT = TUI_TRANSCRIPT + [line]

# The renderer seam handed to run_agent_loop_rendered. Signature matches the
# `on_tool: fn(ToolCall, ToolResult)` parameter.
fn tui_tool_renderer(call: ToolCall, result: ToolResult):
    render_tool_call(call.name, tool_call_status(result), tool_call_summary(result))

# ============================================================================
# Frame rendering + scrollback
# ============================================================================

# Pure window computation - the only part of scrolling worth unit-testing
# without a live terminal. Returns (start, end) [end exclusive] into a
# transcript of `len` lines for a viewport `inner_h` tall.
#   scroll_top < 0  -> auto-follow: always the last inner_h lines
#   scroll_top >= 0 -> a fixed absolute start index, clamped to valid range
fn visible_window(len: i64, inner_h: i64, scroll_top: i64) -> (i64, i64):
    if scroll_top < 0:
        var start = len - inner_h
        if start < 0:
            start = 0
        return (start, len)
    var max_start = len - inner_h
    if max_start < 0:
        max_start = 0
    var start = scroll_top
    if start > max_start:
        start = max_start
    if start < 0:
        start = 0
    (start, start + inner_h)

fn is_scrolled() -> bool:
    SCROLL_TOP >= 0

# Ctrl-P: page toward older lines (PageUp-equivalent - see caret_is_tty's
# comment for why real PageUp/Home/End ANSI sequences aren't wired: parsing
# them needs a bounded-wait byte read to disambiguate a bare ESC from a
# sequence prefix, and terminal_read_byte() has no timeout variant).
fn scroll_page_up(len: i64, inner_h: i64):
    var start = SCROLL_TOP
    if start < 0:
        val w = visible_window(len, inner_h, -1)
        start = w.0
    start = start - inner_h
    if start < 0:
        start = 0
    SCROLL_TOP = start

# Ctrl-N: page toward newer lines (PageDown-equivalent); resumes auto-follow
# once the window reaches the tail.
fn scroll_page_down(len: i64, inner_h: i64):
    if SCROLL_TOP < 0:
        return
    var max_start = len - inner_h
    if max_start < 0:
        max_start = 0
    val start = SCROLL_TOP + inner_h
    if start >= max_start:
        SCROLL_TOP = -1
    else:
        SCROLL_TOP = start

fn _visible_content(inner_h: i64) -> [StyledLine]:
    val len = TUI_TRANSCRIPT.len()
    val window = visible_window(len, inner_h, SCROLL_TOP)
    val start = window.0
    val end = window.1
    var lines: [StyledLine] = []
    var i = start
    while i < end and i < len:
        lines = lines + [TUI_TRANSCRIPT[i]]
        i = i + 1
    lines

fn _inner_height() -> i64:
    val rows = terminal_get_size().rows
    var box_h = rows - 3
    if box_h < 3:
        box_h = 3
    box_h - 2

fn _status_line(ui: ChatTui, turn: i64, awaiting: bool) -> text:
    var line = ui.status
    if line != "":
        line = line + "  "
    line = line + "turn " + turn.to_text()
    if awaiting:
        line = line + "  (waiting for response...)"
    line

fn _hint_line(ui: ChatTui) -> text:
    if is_scrolled():
        return ui.hint + " [scrolled - Ctrl-N to follow]"
    ui.hint

fn _draw_frame(ui: ChatTui):
    terminal_clear_screen()
    val size = terminal_get_size()
    val cols = size.cols
    val inner_h = _inner_height()
    val box_h = inner_h + 2
    val content = _visible_content(inner_h)
    val box = make_box_widget_with_content(ui.title, fg_style(COLOR_CYAN), content)
    val box_area = make_rect(0, 0, cols, box_h)
    val box_lines = box_render(box, box_area)
    var i = 0
    while i < box_lines.len():
        terminal_draw_at(i, 0, render_line(box_lines[i]))
        i = i + 1
    val input_area = make_rect(0, box_h, cols, 1)
    val input_lines = input_render(ui.input, input_area)
    if input_lines.len() > 0:
        terminal_draw_at(box_h, 0, render_line(input_lines[0]))
    val hint_style = make_style(COLOR_NONE, COLOR_NONE, false, false, false, true)
    terminal_draw_at(box_h + 1, 0, styled(pad_or_truncate(_hint_line(ui), cols), hint_style))
    terminal_draw_at(box_h + 2, 0, styled(pad_or_truncate(_status_line(ui, TURN_COUNT, AWAITING_RESPONSE), cols), hint_style))
    terminal_flush()

# ============================================================================
# Interactive line reader (raw mode, byte-at-a-time)
# ============================================================================

# Reads one prompt line, redrawing the frame on each keystroke. Returns the
# (updated ui, submitted text, status) where status: 0 = line submitted,
# 1 = exit requested (Ctrl-C / Ctrl-D / EOF).
fn _read_line(ui0: ChatTui) -> (ChatTui, text, i64):
    var ui = ui0
    var done = false
    var result_text = ""
    var status = 1
    var raw_line = make_raw_line_state(ui.input)
    while not done:
        _draw_frame(ui)
        val b = terminal_read_byte()
        val next = step_raw_line_byte(raw_line, b)
        raw_line = next.state
        ui = _ui_set_input(ui, raw_line.input)
        if next.action == RAW_LINE_EXIT:
            status = 1
            done = true
        elif next.action == RAW_LINE_SUBMIT:
            result_text = next.submitted
            status = 0
            done = true
        elif next.action == RAW_LINE_PAGE_UP:
            scroll_page_up(tui_transcript_len(), _inner_height())
        elif next.action == RAW_LINE_PAGE_DOWN:
            scroll_page_down(tui_transcript_len(), _inner_height())
    (ui, result_text, status)

# ============================================================================
# Interactive loop
# ============================================================================

# Re-renders a fully loaded/replaced conversation (resume, /new) into the
# transcript panel so the user sees the restored history, not a blank screen.
fn _render_history(conv: [Message]):
    for m in conv:
        render_turn(m.role, m.content)

# Applies a dispatched SlashResult's new_conv/replace_conv effect to the
# running (conv, session_id) state (exit/message are handled by the caller).
# Shared by the TUI loop; run_chat_plain inlines the same two branches since
# it has no transcript panel to reset.
fn _apply_slash(result: SlashResult, conv: [Message], session_id: text) -> ([Message], text):
    if result.new_conv:
        tui_transcript_reset()
        return ([], result.new_session_id)
    if result.replace_conv:
        tui_transcript_reset()
        _render_history(result.loaded_messages)
        return (result.loaded_messages, result.new_session_id)
    (conv, session_id)

struct ChatSubmissionResult:
    ui: ChatTui
    conversation: [Message]
    session_id: text
    running: bool
    submitted_to_model: bool

# Deterministic production state transition for one submitted TUI line. The
# terminal loop owns key reading/frame timing; this function owns the actual
# command/model/history/persistence behavior and is directly system-testable.
fn run_chat_tui_submission(
    ui0: ChatTui,
    conv0: [Message],
    session_id0: text,
    submitted: text,
    policy: PermissionPolicy,
    responder: fn([Message]) -> ModelResponse,
    hooks: SessionHooks
) -> ChatSubmissionResult:
    var ui = ui0
    var conv = conv0
    var session_id = session_id0
    var running = true
    var submitted_to_model = false
    val trimmed = submitted.trim()
    if trimmed == "/exit" or trimmed == "/quit":
        running = false
    elif trimmed == "":
        ui = _ui_set_input(ui, input_clear(ui.input))
    elif is_slash_command(trimmed):
        val (cmd, arg) = parse_slash_command(trimmed)
        val result = dispatch_slash(cmd, arg, hooks)
        ui = apply_slash_status(ui, result)
        if result.exit:
            running = false
        else:
            val applied = _apply_slash(result, conv, session_id)
            conv = applied.0
            session_id = applied.1
            # Render after a /new reset or /resume history restore so the
            # visible confirmation is not immediately erased.
            if result.message != "":
                render_turn("system", result.message)
        ui = _ui_set_input(ui, input_clear(ui.input))
    else:
        SCROLL_TOP = -1
        render_turn("user", trimmed)
        conv = conv + [new_user_message(trimmed)]
        TURN_COUNT = TURN_COUNT + 1
        val result = run_agent_loop_rendered(
            policy, conv, responder, 25, tui_tool_renderer
        )
        conv = result.final_transcript
        render_turn("assistant", result.final_text)
        hooks.on_persist(session_id, conv)
        ui = _ui_set_input(ui, input_clear(ui.input))
        submitted_to_model = true
    ChatSubmissionResult(
        ui: ui,
        conversation: conv,
        session_id: session_id,
        running: running,
        submitted_to_model: submitted_to_model
    )

# The full-screen interactive chat loop. Sets up the alt screen + raw mode per
# editor/tui_shell.spl, reads a prompt, runs one agent turn (threading the
# whole conversation - including tool_result turns, via AgentResult's
# final_transcript - for real multi-turn memory), renders the reply + any
# tool-call lines, persists the session after every turn, and loops until
# /exit or Ctrl-C/Ctrl-D. Restores the terminal at the end of the loop.
#
# ponytail: no guard restores the terminal on a hard runtime panic mid-loop.
# Checked for an existing repo idiom first: editor/tui_shell.spl (the pattern
# this module already mirrors) has the identical gap - enter_raw_mode/
# enter_alt_screen with teardown only at the function's natural end, no
# panic guard anywhere. Simple's error model is Result<T,E> + `?` only (no
# try/catch/throw by design - .claude/rules/language.md), which covers
# explicit Err returns but not interpreter-level panics (e.g. an out-of-bounds
# index), so there is no in-language way to intercept those and restore the
# terminal. A real fix needs either a runtime atexit/signal-handler extern
# (Rust-seed + bootstrap change) or restructuring every fallible call in this
# loop through Result/`?` (moot today - none of them return Result). Filing
# as a bug rather than adding a no-op wrapper that wouldn't actually catch a
# panic: "chat_tui/editor raw-mode not restored on interpreter panic - needs
# atexit-style runtime hook, no in-language guard is possible today".
fn run_chat_tui(ui0: ChatTui, policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse, hooks: SessionHooks, initial_conv: [Message]):
    tui_transcript_reset()
    var conv = initial_conv
    var session_id = hooks.session_id
    _render_history(conv)
    terminal_enter_alt_screen()
    terminal_enter_raw_mode()
    terminal_hide_cursor()
    var ui = ui0
    var running = true
    while running:
        val rl = _read_line(ui)
        ui = rl.0
        val submitted = rl.1
        val status = rl.2
        if status == 1:
            running = false
        else:
            val trimmed = submitted.trim()
            val model_turn = trimmed != "" and
                trimmed != "/exit" and trimmed != "/quit" and
                not is_slash_command(trimmed)
            if model_turn:
                AWAITING_RESPONSE = true
                _draw_frame(ui)
            val transition = run_chat_tui_submission(
                ui, conv, session_id, submitted, policy, responder, hooks
            )
            if model_turn:
                AWAITING_RESPONSE = false
            ui = transition.ui
            conv = transition.conversation
            session_id = transition.session_id
            running = transition.running
    terminal_show_cursor()
    terminal_exit_raw_mode()
    terminal_exit_alt_screen()
    print "chat session ended"

# ============================================================================
# Plain fallback loop (non-tty: piped / CI / server)
# ============================================================================

fn run_chat_plain(policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse, hooks: SessionHooks, initial_conv: [Message]):
    var conv: [Message] = initial_conv
    var session_id = hooks.session_id
    var running = true
    while running:
        print "> "
        val line = rt_stdin_read_line() ?? ""
        val trimmed = line.trim()
        # Empty line == EOF on a drained pipe -> exit. Explicit /exit too.
        if trimmed == "" or trimmed == "/exit" or trimmed == "/quit":
            running = false
        elif is_slash_command(trimmed):
            val (cmd, arg) = parse_slash_command(trimmed)
            val result = dispatch_slash(cmd, arg, hooks)
            if result.message != "":
                print result.message
            if result.exit:
                running = false
            elif result.new_conv:
                conv = []
                session_id = result.new_session_id
            elif result.replace_conv:
                conv = result.loaded_messages
                session_id = result.new_session_id
        else:
            conv = conv + [new_user_message(trimmed)]
            val result = run_agent_loop(policy, conv, responder, 25)
            conv = result.final_transcript
            print "Assistant: " + result.final_text
            hooks.on_persist(session_id, conv)

# ============================================================================
# Top-level entry: pick TUI vs plain per flag/tty
# ============================================================================

# Interactive chat entry point. `ui_mode` is "auto" (default), "tui", or
# "plain". TUI is the default for interactive TTY use; non-tty falls back to the
# plain print path so piped/CI/server output is not ANSI-corrupted. `hooks`
# wires slash-command effects (model/provider switch, session list/resume,
# persistence) into main.spl's runtime state; `initial_conv` seeds the
# transcript (e.g. a --resume'd session's messages, or [] for a fresh chat).
fn caret_chat(ui: ChatTui, policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse, ui_mode: text, hooks: SessionHooks, initial_conv: [Message]):
    val mode = select_renderer_mode(ui_mode, caret_is_tty())
    if mode == "tui":
        run_chat_tui(ui, policy, responder, hooks, initial_conv)
    else:
        run_chat_plain(policy, responder, hooks, initial_conv)
