# LLM Caret - Chat Session Management
#
# Maintains conversation history in module-level state.
# Provides add, clear, truncate operations, plus the tool-using agent loop.

use app.llm_caret.types.{Message}
use app.llm_caret.tools.{PermissionPolicy, ToolCall, ToolResult, ModelResponse, run_tool}
use app.llm_caret.redact.{redact, wrap_untrusted}

# ============================================================================
# JSON helpers (inlined)
# ============================================================================

fn _LB() -> text:
    (123 as char).to_text()

fn _RB() -> text:
    (125 as char).to_text()

fn _Q() -> text:
    "\""

fn _escape_json(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\":
            result = result + "\\\\"
        elif ch == "\"":
            result = result + "\\\""
        elif ch == "\n":
            result = result + "\\n"
        elif ch == "\r":
            result = result + "\\r"
        elif ch == "\t":
            result = result + "\\t"
        else:
            result = result + ch
        i = i + 1
    result

# ============================================================================
# Module-level state
# ============================================================================

var CHAT_ROLES: [text] = []
var CHAT_CONTENTS: [text] = []
var CHAT_SYSTEM_PROMPT = ""
var CHAT_MAX_HISTORY = 100

# ============================================================================
# History management
# ============================================================================

fn chat_clear():
    CHAT_ROLES = []
    CHAT_CONTENTS = []

fn chat_set_system_prompt(prompt: text):
    CHAT_SYSTEM_PROMPT = prompt

fn chat_get_system_prompt() -> text:
    CHAT_SYSTEM_PROMPT

fn chat_set_max_history(max_items: i64):
    CHAT_MAX_HISTORY = max_items

fn chat_add_message(role: text, content: text):
    CHAT_ROLES = CHAT_ROLES + [role]
    CHAT_CONTENTS = CHAT_CONTENTS + [content]
    # Truncate if over limit
    if CHAT_ROLES.len() > CHAT_MAX_HISTORY:
        chat_truncate(CHAT_MAX_HISTORY)

fn chat_add_user(content: text):
    chat_add_message("user", content)

fn chat_add_assistant(content: text):
    chat_add_message("assistant", content)

fn chat_history_len() -> i64:
    CHAT_ROLES.len()

fn chat_get_role(idx: i64) -> text:
    if idx >= 0 and idx < CHAT_ROLES.len():
        return CHAT_ROLES[idx]
    ""

fn chat_get_content(idx: i64) -> text:
    if idx >= 0 and idx < CHAT_CONTENTS.len():
        return CHAT_CONTENTS[idx]
    ""

fn chat_truncate(keep_last: i64):
    if CHAT_ROLES.len() <= keep_last:
        return
    val start = CHAT_ROLES.len() - keep_last
    var new_roles: [text] = []
    var new_contents: [text] = []
    var i = start
    while i < CHAT_ROLES.len():
        new_roles = new_roles + [CHAT_ROLES[i]]
        new_contents = new_contents + [CHAT_CONTENTS[i]]
        i = i + 1
    CHAT_ROLES = new_roles
    CHAT_CONTENTS = new_contents

# ============================================================================
# Build messages JSON from history
# ============================================================================

fn chat_build_messages_json() -> text:
    var items: [text] = []
    var i = 0
    while i < CHAT_ROLES.len():
        var msg = _LB()
        msg = msg + _Q() + "role" + _Q() + ":" + _Q() + CHAT_ROLES[i] + _Q() + ","
        msg = msg + _Q() + "content" + _Q() + ":" + _Q() + _escape_json(CHAT_CONTENTS[i]) + _Q()
        msg = msg + _RB()
        items = items + [msg]
        i = i + 1
    var result = "["
    var j = 0
    for item in items:
        if j > 0:
            result = result + ","
        result = result + item
        j = j + 1
    result = result + "]"
    result

# Get last message content (useful for getting the latest assistant reply)
fn chat_last_content() -> text:
    if CHAT_CONTENTS.len() == 0:
        return ""
    CHAT_CONTENTS[CHAT_CONTENTS.len() - 1]

fn chat_last_role() -> text:
    if CHAT_ROLES.len() == 0:
        return ""
    CHAT_ROLES[CHAT_ROLES.len() - 1]

# ============================================================================
# Agent loop (tool_use -> gate -> execute -> tool_result -> re-call model)
# ============================================================================

val AGENT_MAX_ITERATIONS = 25

struct AgentResult:
    final_text: text
    iterations: i64
    stopped_reason: text     # "end_turn" | "max_iterations"
    tool_calls_made: i64
    # Full transcript including every tool_result / re-prompt turn made during
    # this call (not just the initial messages + final reply). Callers that
    # need real multi-turn memory across top-level calls (e.g. the TUI/plain
    # chat shells) should carry this forward as the next call's `initial`
    # instead of manually re-appending just `final_text` - that was the
    # gap that silently dropped tool_result history between turns.
    final_transcript: [Message]

# Format a tool_result the way it re-enters the transcript for the model.
fn _tool_result_message(call: ToolCall, result: ToolResult) -> text:
    var prefix = "[tool_result " + call.name + " id=" + result.tool_use_id
    if result.is_error:
        prefix = prefix + " error"
    prefix = prefix + "]\n"
    prefix + wrap_untrusted("tool:" + call.name, redact(result.content))

# Tool status/summary derivation, shared by the plain print path and the TUI
# renderer seam so both surface identical text for the same tool result.
fn tool_call_status(result: ToolResult) -> text:
    if result.is_error:
        return "error"
    "ok"

fn tool_call_summary(result: ToolResult) -> text:
    var summary = redact(result.content)
    if summary.len() > 200:
        summary = summary.substring(0, 200) + "..."
    summary

# Surface each tool call + a short result summary to the user. This is the
# PLAIN (raw print) renderer, used headless / when stdout is not a tty. The
# TUI passes its own renderer (chat_tui.tui_tool_renderer) into
# run_agent_loop_rendered instead.
fn _emit_tool(call: ToolCall, result: ToolResult):
    print "  -> tool " + call.name + " [" + tool_call_status(result) + "]: " + tool_call_summary(result)

# Run the agent loop. The `responder` is the model seam: given the running
# transcript it returns a ModelResponse (assistant text + any tool_use calls).
# Providers parse their wire format into ModelResponse; tests inject a fake.
# Every tool call traverses run_tool (the permission gate) - nothing executes
# ungated. The loop is hard-capped so a model that never stops asking for tools
# cannot run forever.
fn run_agent_loop(policy: PermissionPolicy, initial: [Message], responder: fn([Message]) -> ModelResponse, max_iterations: i64) -> AgentResult:
    # Backward-compatible entry: uses the plain print renderer. Existing callers
    # (tools_spec.spl, headless CLI) keep working unchanged.
    run_agent_loop_rendered(policy, initial, responder, max_iterations, _emit_tool)

# Renderer-seam variant. `on_tool` is called for every gated tool result; the
# headless path passes `_emit_tool` (print), the TUI passes a renderer that
# appends a styled line to the transcript. Everything else is identical - every
# tool call still traverses run_tool (the permission gate).
fn run_agent_loop_rendered(policy: PermissionPolicy, initial: [Message], responder: fn([Message]) -> ModelResponse, max_iterations: i64, on_tool: fn(ToolCall, ToolResult)) -> AgentResult:
    var cap = max_iterations
    if cap <= 0:
        cap = AGENT_MAX_ITERATIONS
    var transcript = initial
    var iters = 0
    var tool_count = 0
    var final_text = ""
    while iters < cap:
        iters = iters + 1
        val resp = responder(transcript)
        final_text = resp.text
        if resp.text != "":
            transcript = transcript + [Message(role: "assistant", content: resp.text)]
        if resp.tool_calls.len() == 0:
            return AgentResult(final_text: final_text, iterations: iters, stopped_reason: "end_turn", tool_calls_made: tool_count, final_transcript: transcript)
        for call in resp.tool_calls:
            val result = run_tool(policy, call)
            tool_count = tool_count + 1
            on_tool(call, result)
            transcript = transcript + [Message(role: "user", content: _tool_result_message(call, result))]
    AgentResult(final_text: final_text, iterations: iters, stopped_reason: "max_iterations", tool_calls_made: tool_count, final_transcript: transcript)
