# LLM Caret - Public API Module
#
# Unified LLM access layer providing Claude-CLI-like chat API.
# Wraps multiple backends: Claude CLI, Claude API, OpenAI API,
# OpenAI-compatible endpoints, and local torch models.
#
# Usage:
#   use app.llm_caret.mod.{llm_init_defaults, llm_chat, llm_clear}
#   llm_init_defaults()
#   val response = llm_chat("Hello!")
#   print response

use app.io.mod.{env_get}
use app.llm_caret.claude_cli.{claude_cli_send}
use app.llm_caret.opencode_cli.{opencode_cli_send}
use app.llm_caret.json_helpers.{json_find, json_parse_int}
use std.nogc_sync_mut.io.http_sffi.{http_request_raw}

# Re-export the retry/backoff/timeout policy so callers of the unified
# module don't need a separate `use app.llm_caret.retry.{...}`.
export use app.llm_caret.retry.{
    RetryPolicy, RetryOutcome,
    default_retry_policy, retry_policy_from_env,
    is_retryable_status, should_retry, backoff_delay_ms, effective_delay_ms,
    with_retry
}

# Re-export real tool execution + permission gating (Phase 1.1).
export use app.llm_caret.tools.{
    PermissionPolicy, ToolCall, ToolResult, ModelResponse,
    run_tool, permission_decision, guard_path, parse_tool_use_blocks,
    default_policy, allow_all_policy, policy_with_allow
}
export use app.llm_caret.chat.{AgentResult, run_agent_loop, run_agent_loop_rendered, tool_call_status, tool_call_summary}

# Interactive chat UI (std.tui) + its renderer seam.
export use app.llm_caret.chat_tui.{
    ChatTui, make_chat_tui, caret_chat, run_chat_tui, run_chat_plain,
    render_turn, render_tool_call, tui_tool_renderer,
    select_renderer_mode, caret_is_tty
}

# ============================================================================
# JSON helpers (inlined)
# ============================================================================

fn _LB() -> text:
    (123 as char).to_text()

fn _RB() -> text:
    (125 as char).to_text()

fn _Q() -> text:
    "\""

fn _escape_json(s: text) -> text:
    var parts = []
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\":
            parts.append("\\\\")
        elif ch == "\"":
            parts.append("\\\"")
        elif ch == "\n":
            parts.append("\\n")
        elif ch == "\r":
            parts.append("\\r")
        elif ch == "\t":
            parts.append("\\t")
        else:
            parts.append(ch)
        i = i + 1
    parts.join("")

fn _extract_json_string(json: text, key: text) -> text:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx = json_find(json, search)
    if idx < 0:
        return ""
    val slen = search.len()
    val start = idx + slen
    val after = json.substring(start)
    val trimmed = after.trim()
    if trimmed.starts_with(quote):
        val rest = trimmed.substring(1)
        var end = 0
        var escaped = false
        while end < rest.len():
            val ch = rest[end]
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                return rest.substring(0, end)
            end = end + 1
    ""

fn _extract_json_value(json: text, key: text) -> text:
    val search = _Q() + key + _Q() + ":"
    val idx = json_find(json, search)
    if idx < 0:
        return "null"
    val slen = search.len()
    val start = idx + slen
    val after = json.substring(start)
    val trimmed = after.trim()
    var end = 0
    while end < trimmed.len():
        val ch = trimmed[end]
        if ch == "," or ch == _RB() or ch == "]":
            break
        end = end + 1
    trimmed.substring(0, end).trim()

fn _extract_json_bool(json: text, key: text) -> bool:
    val raw = _extract_json_value(json, key)
    raw == "true"

fn _extract_json_int(json: text, key: text) -> i64:
    val raw = _extract_json_value(json, key)
    if raw == "null" or raw == "":
        return 0
    json_parse_int(raw)

# ============================================================================
# Module-level state
# ============================================================================

var LLM_INITIALIZED = false
var LLM_PROVIDER = "claude_cli"
var LLM_MODEL = ""
var LLM_CLI_PATH = "claude"
var LLM_API_KEY = ""
var LLM_BASE_URL = ""
var LLM_SYSTEM_PROMPT = ""
var LLM_SESSION_ID = ""
var LLM_MAX_TURNS = 0

# History
var LLM_ROLES: [text] = []
var LLM_CONTENTS: [text] = []

# ============================================================================
# Initialization
# ============================================================================

fn llm_init_defaults():
    LLM_INITIALIZED = true
    LLM_PROVIDER = "claude_cli"
    LLM_MODEL = ""
    LLM_CLI_PATH = "claude"
    LLM_SYSTEM_PROMPT = ""
    LLM_SESSION_ID = ""
    LLM_MAX_TURNS = 0
    LLM_ROLES = []
    LLM_CONTENTS = []

fn llm_init(provider: text, model: text):
    LLM_INITIALIZED = true
    LLM_PROVIDER = provider
    LLM_MODEL = model
    # A new public client initialization is a new logical conversation.
    # Never carry backend session or system-prompt state across providers.
    LLM_SYSTEM_PROMPT = ""
    LLM_SESSION_ID = ""
    LLM_ROLES = []
    LLM_CONTENTS = []

fn llm_set_api_key(key: text):
    LLM_API_KEY = key

fn llm_set_base_url(url: text):
    LLM_BASE_URL = url

fn llm_set_cli_path(path: text):
    LLM_CLI_PATH = path

fn llm_system(prompt: text):
    LLM_SYSTEM_PROMPT = prompt

fn llm_provider() -> text:
    LLM_PROVIDER

fn llm_model() -> text:
    LLM_MODEL

fn llm_clear():
    LLM_ROLES = []
    LLM_CONTENTS = []
    LLM_SESSION_ID = ""

# ============================================================================
# History
# ============================================================================

fn llm_history_len() -> i64:
    LLM_ROLES.len()

fn llm_history_role(idx: i64) -> text:
    if idx >= 0 and idx < LLM_ROLES.len():
        return LLM_ROLES[idx]
    ""

fn llm_history_content(idx: i64) -> text:
    if idx >= 0 and idx < LLM_CONTENTS.len():
        return LLM_CONTENTS[idx]
    ""

# ============================================================================
# Build messages JSON from history
# ============================================================================

fn _build_messages_json() -> text:
    var items: [text] = []
    var i = 0
    while i < LLM_ROLES.len():
        var msg_parts = []
        msg_parts.append(_LB())
        msg_parts.append(_Q() + "role" + _Q() + ":" + _Q() + LLM_ROLES[i] + _Q() + ",")
        msg_parts.append(_Q() + "content" + _Q() + ":" + _Q() + _escape_json(LLM_CONTENTS[i]) + _Q())
        msg_parts.append(_RB())
        items = items + [msg_parts.join("")]
        i = i + 1
    var parts = []
    parts.append("[")
    var j = 0
    for item in items:
        if j > 0:
            parts.append(",")
        parts.append(item)
        j = j + 1
    parts.append("]")
    parts.join("")

# ============================================================================
# Chat (main entry point)
# ============================================================================

fn llm_chat(user_msg: text) -> text:
    if not LLM_INITIALIZED:
        return "ERROR: call llm_init_defaults() or llm_init() first"
    # Add user message to history
    LLM_ROLES = LLM_ROLES + ["user"]
    LLM_CONTENTS = LLM_CONTENTS + [user_msg]
    # Dispatch based on provider
    var result_content = ""
    var result_error = ""
    if LLM_PROVIDER == "claude_cli":
        val r = _send_claude_cli(user_msg)
        result_content = r.0
        result_error = r.1
    elif LLM_PROVIDER == "opencode_cli":
        val r = _send_opencode_cli(user_msg)
        result_content = r.0
        result_error = r.1
    elif LLM_PROVIDER == "claude_api":
        val r = _send_claude_api()
        result_content = r.0
        result_error = r.1
    elif LLM_PROVIDER == "openai":
        val r = _send_openai()
        result_content = r.0
        result_error = r.1
    else:
        result_error = "unsupported provider: " + LLM_PROVIDER
    if result_error != "":
        return "ERROR: " + result_error
    # Add assistant response to history
    LLM_ROLES = LLM_ROLES + ["assistant"]
    LLM_CONTENTS = LLM_CONTENTS + [result_content]
    result_content

# ============================================================================
# Send via Claude CLI
# ============================================================================

fn _send_claude_cli(prompt: text) -> (text, text):
    val resp = claude_cli_send(
        LLM_CLI_PATH, prompt, LLM_MODEL, LLM_SYSTEM_PROMPT, LLM_SESSION_ID,
        LLM_MAX_TURNS, 0, "", [], []
    )
    if resp.is_error:
        return ("", resp.error)
    if resp.session_id != "":
        LLM_SESSION_ID = resp.session_id
    (resp.content, "")

fn _send_opencode_cli(prompt: text) -> (text, text):
    val resp = opencode_cli_send(LLM_CLI_PATH, prompt, LLM_MODEL, LLM_SESSION_ID, "", [])
    if resp.is_error:
        return ("", resp.error)
    if resp.session_id != "":
        LLM_SESSION_ID = resp.session_id
    (resp.content, "")

# ============================================================================
# Send via Claude API
# ============================================================================

fn _send_claude_api() -> (text, text):
    var key = LLM_API_KEY
    if key == "":
        key = env_get("ANTHROPIC_API_KEY") ?? ""
    if key == "":
        return ("", "ANTHROPIC_API_KEY not set")
    var url = LLM_BASE_URL
    if url == "":
        url = "https://api.anthropic.com"
    url = url + "/v1/messages"
    var model_val = LLM_MODEL
    if model_val == "":
        model_val = "claude-sonnet-4-20250514"
    val messages = _build_messages_json()
    # Build body
    var parts: [text] = []
    parts = parts + [_Q() + "model" + _Q() + ":" + _Q() + model_val + _Q()]
    parts = parts + [_Q() + "max_tokens" + _Q() + ":4096"]
    if LLM_SYSTEM_PROMPT != "":
        parts = parts + [_Q() + "system" + _Q() + ":" + _Q() + _escape_json(LLM_SYSTEM_PROMPT) + _Q()]
    parts = parts + [_Q() + "messages" + _Q() + ":" + messages]
    var body_parts = []
    body_parts.append(_LB())
    var i = 0
    for part in parts:
        if i > 0:
            body_parts.append(",")
        body_parts.append(part)
        i = i + 1
    body_parts.append(_RB())
    val body = body_parts.join("")
    var hdr_parts = []
    hdr_parts.append("x-api-key: " + key)
    hdr_parts.append("anthropic-version: 2023-06-01")
    hdr_parts.append("content-type: application/json")
    val headers = hdr_parts.join("\n")
    val result = http_request_raw("POST", url, headers, body)
    val resp_body = result.1 ?? ""
    val http_error = result.2 ?? ""
    if http_error != "":
        return ("", "HTTP error: " + http_error)
    val content = _extract_json_string(resp_body, "text")
    (content, "")

# ============================================================================
# Send via OpenAI API
# ============================================================================

fn _send_openai() -> (text, text):
    var key = LLM_API_KEY
    if key == "":
        key = env_get("OPENAI_API_KEY") ?? ""
    if key == "":
        return ("", "OPENAI_API_KEY not set")
    var url = LLM_BASE_URL
    if url == "":
        url = "https://api.openai.com"
    url = url + "/v1/chat/completions"
    var model_val = LLM_MODEL
    if model_val == "":
        model_val = "gpt-4o"
    val messages = _build_messages_json()
    var parts: [text] = []
    parts = parts + [_Q() + "model" + _Q() + ":" + _Q() + model_val + _Q()]
    parts = parts + [_Q() + "messages" + _Q() + ":" + messages]
    var body_parts = []
    body_parts.append(_LB())
    var i = 0
    for part in parts:
        if i > 0:
            body_parts.append(",")
        body_parts.append(part)
        i = i + 1
    body_parts.append(_RB())
    val body = body_parts.join("")
    var hdr_parts = []
    hdr_parts.append("Authorization: Bearer " + key)
    hdr_parts.append("Content-Type: application/json")
    val headers = hdr_parts.join("\n")
    val result = http_request_raw("POST", url, headers, body)
    val resp_body = result.1 ?? ""
    val http_error = result.2 ?? ""
    if http_error != "":
        return ("", "HTTP error: " + http_error)
    val content = _extract_json_string(resp_body, "content")
    (content, "")

# ============================================================================
# Direct send (without history management)
# ============================================================================

fn llm_send(prompt: text) -> text:
    if not LLM_INITIALIZED:
        return "ERROR: call llm_init_defaults() or llm_init() first"
    if LLM_PROVIDER == "claude_cli":
        val r = _send_claude_cli(prompt)
        if r.1 != "":
            return "ERROR: " + r.1
        return r.0
    if LLM_PROVIDER == "opencode_cli":
        val r = _send_opencode_cli(prompt)
        if r.1 != "":
            return "ERROR: " + r.1
        return r.0
    "ERROR: llm_send only supports claude_cli and opencode_cli providers"
