# LLM Caret - OpenCode CLI Wrapper

use app.io.mod.{process_run, process_spawn_async, process_is_running, process_kill}

struct OpencodeCliResponse:
    content: text
    model: text
    session_id: text
    stop_reason: text
    input_tokens: i64
    output_tokens: i64
    error: text
    is_error: bool
    raw: text

struct OpencodeProcessResult:
    status: text
    reason: text
    pid: i64

fn _Q() -> text:
    "\""

fn _unwrap_idx(opt) -> i64:
    match opt:
        Some(i): return i
        nil: return -1

fn _extract_json_string(json: text, key: text) -> text:
    val parts = json.split(_Q() + key + _Q())
    var part_index = 1
    while part_index < parts.len():
        val parsed = _json_string_value_after_key(parts[part_index])
        if parsed != "":
            return parsed
        part_index = part_index + 1
    ""

fn _json_string_value_after_key(after_key: text) -> text:
    var seen_colon = false
    var in_string = false
    var escaped = false
    var value = ""
    for ch in after_key:
        if not seen_colon:
            if ch == ":":
                seen_colon = true
            elif ch == " " or ch == "\t" or ch == "\r" or ch == "\n":
                pass
            else:
                return ""
            continue
        if not in_string:
            if ch == " " or ch == "\t" or ch == "\r" or ch == "\n":
                continue
            if ch == _Q():
                in_string = true
                continue
            return ""
        if escaped:
            if ch == "n":
                value = value + "\n"
            elif ch == "r":
                value = value + "\r"
            elif ch == "t":
                value = value + "\t"
            else:
                value = value + ch
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == _Q():
            return value
        else:
            value = value + ch
    ""

pub fn build_opencode_args(prompt: text, model: text, session_id: text, output_format: text, attach_url: text, auto_approve: bool, extra_args: [text]) -> [text]:
    var args = ["run"]
    if output_format != "":
        args = args + ["--format", output_format]
    else:
        args = args + ["--format", "json"]
    if model != "":
        args = args + ["--model", model]
    if session_id != "":
        args = args + ["--session", session_id]
    if attach_url != "":
        args = args + ["--attach", attach_url]
    if auto_approve:
        args = args + ["--auto"]
    for arg in extra_args:
        if arg != "":
            args = args + [arg]
    args + [prompt]

pub fn parse_opencode_response(raw: text, model: text) -> OpencodeCliResponse:
    if raw.trim() == "":
        return OpencodeCliResponse(content: "", model: model, session_id: "", stop_reason: "error", input_tokens: 0, output_tokens: 0, error: "empty response", is_error: true, raw: "")
    val content = _first_non_empty([_extract_json_string(raw, "content"), _extract_json_string(raw, "message"), _extract_json_string(raw, "text"), raw.trim()])
    val session = _extract_json_string(raw, "sessionID")
    OpencodeCliResponse(content: content, model: model, session_id: session, stop_reason: "stop", input_tokens: 0, output_tokens: 0, error: "", is_error: false, raw: raw)

fn _first_non_empty(values: [text]) -> text:
    for value in values:
        if value != "":
            return value
    ""

pub fn opencode_cli_send(cli_path: text, prompt: text, model: text, session_id: text, attach_url: text, extra_args: [text]) -> OpencodeCliResponse:
    var path = cli_path
    if path == "":
        path = "opencode"
    val result = process_run(path, build_opencode_args(prompt, model, session_id, "json", attach_url, false, extra_args))
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2
    if exit_code != 0:
        var err = "opencode CLI exited with code " + exit_code.to_text()
        if stderr != "":
            err = err + ": " + stderr
        return OpencodeCliResponse(content: "", model: model, session_id: session_id, stop_reason: "error", input_tokens: 0, output_tokens: 0, error: err, is_error: true, raw: stdout)
    parse_opencode_response(stdout, model)

pub fn opencode_cli_spawn(cli_path: text, prompt: text, model: text, session_id: text, attach_url: text, extra_args: [text]) -> OpencodeProcessResult:
    var path = cli_path
    if path == "":
        path = "opencode"
    val pid = process_spawn_async(path, build_opencode_args(prompt, model, session_id, "json", attach_url, false, extra_args))
    if pid <= 0:
        return OpencodeProcessResult(status: "error", reason: "spawn_failed", pid: pid)
    OpencodeProcessResult(status: "started", reason: "process_spawned", pid: pid)

pub fn opencode_cli_running_status(pid: i64) -> text:
    if pid <= 0:
        return "not_running"
    if process_is_running(pid):
        return "running"
    "not_running"

pub fn opencode_cli_kill(pid: i64) -> OpencodeProcessResult:
    if pid <= 0:
        return OpencodeProcessResult(status: "not_stopped", reason: "invalid_pid", pid: pid)
    if process_kill(pid):
        return OpencodeProcessResult(status: "stopped", reason: "process_killed", pid: pid)
    OpencodeProcessResult(status: "error", reason: "process_kill_failed", pid: pid)

export OpencodeCliResponse, OpencodeProcessResult
export build_opencode_args, parse_opencode_response, opencode_cli_send, opencode_cli_spawn, opencode_cli_running_status, opencode_cli_kill
