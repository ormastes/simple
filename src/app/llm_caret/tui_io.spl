# LLM Caret terminal I/O seam.
#
# The production adapter is deliberately the only place where the chat loop
# reaches terminal and stdin owners. Tests can provide a CaretIo made from
# deterministic functions without declaring app-leaf runtime externs.

use std.tui.terminal.{
    TerminalSize, terminal_get_size,
    terminal_enter_raw_mode, terminal_exit_raw_mode,
    terminal_enter_alt_screen, terminal_exit_alt_screen,
    terminal_hide_cursor, terminal_show_cursor,
    terminal_clear_screen, terminal_draw_at, terminal_flush,
    terminal_read_byte
}
use std.nogc_sync_mut.io.pipe.{Stdin}
use app.llm_caret.tui_input.{caret_is_tty}

struct CaretIo:
    is_tty: fn() -> bool
    terminal_size: fn() -> TerminalSize
    enter_raw: fn() -> bool
    exit_raw: fn() -> bool
    enter_alt: fn()
    exit_alt: fn()
    hide_cursor: fn()
    show_cursor: fn()
    clear_screen: fn()
    draw_at: fn(i64, i64, text)
    flush: fn()
    read_byte: fn() -> i64
    read_line: fn() -> text?
    emit: fn(text)

struct CaretLoopResult:
    mode: text
    ok: bool
    exit_reason: text
    error: text

fn _production_is_tty() -> bool:
    caret_is_tty()

fn _production_terminal_size() -> TerminalSize:
    terminal_get_size()

fn _production_enter_raw() -> bool:
    terminal_enter_raw_mode()

fn _production_exit_raw() -> bool:
    terminal_exit_raw_mode()

fn _production_enter_alt():
    terminal_enter_alt_screen()

fn _production_exit_alt():
    terminal_exit_alt_screen()

fn _production_hide_cursor():
    terminal_hide_cursor()

fn _production_show_cursor():
    terminal_show_cursor()

fn _production_clear_screen():
    terminal_clear_screen()

fn _production_draw_at(row: i64, col: i64, content: text):
    terminal_draw_at(row, col, content)

fn _production_flush():
    terminal_flush()

fn _production_read_byte() -> i64:
    terminal_read_byte()

fn _production_read_line() -> text?:
    val input = Stdin.new()
    match input.read_line():
        case Ok(line): line
        case Err(_): nil

fn _production_emit(content: text):
    print_raw(content)

fn production_caret_io() -> CaretIo:
    CaretIo(
        is_tty: _production_is_tty,
        terminal_size: _production_terminal_size,
        enter_raw: _production_enter_raw,
        exit_raw: _production_exit_raw,
        enter_alt: _production_enter_alt,
        exit_alt: _production_exit_alt,
        hide_cursor: _production_hide_cursor,
        show_cursor: _production_show_cursor,
        clear_screen: _production_clear_screen,
        draw_at: _production_draw_at,
        flush: _production_flush,
        read_byte: _production_read_byte,
        read_line: _production_read_line,
        emit: _production_emit
    )
