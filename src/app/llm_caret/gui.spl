# LLM Caret browser GUI.
# Pure page, request, and response helpers are shared by the live HTTP adapter
# and system tests. Provider dispatch stays in main.spl so the self-hosted JIT
# never has to carry a function-valued callback across this module boundary.

use app.llm_caret.json_helpers.{extract_json_string, escape_json_text}

fn _caret_gui_html_escape(value: text) -> text:
    var escaped = value.replace("&", "&amp;")
    escaped = escaped.replace("<", "&lt;")
    escaped = escaped.replace(">", "&gt;")
    escaped = escaped.replace("\"", "&quot;")
    escaped

fn caret_gui_html() -> text:
    """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>LLM Caret</title>
<style>
:root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, sans-serif; }
body { margin: 0; min-height: 100vh; background: #0b1020; color: #eef2ff; display: grid; place-items: center; }
main { width: min(720px, calc(100vw - 32px)); background: #151b2e; border: 1px solid #334155; border-radius: 18px; box-shadow: 0 24px 70px #0008; overflow: hidden; }
header { padding: 22px 24px; border-bottom: 1px solid #334155; }
h1 { margin: 0; font-size: 1.25rem; }
#status { color: #86efac; font-size: .85rem; margin-top: 6px; }
#messages { min-height: 260px; max-height: 55vh; overflow: auto; padding: 24px; display: flex; flex-direction: column; gap: 12px; }
.message { padding: 12px 14px; border-radius: 12px; white-space: pre-wrap; }
.user { align-self: flex-end; background: #2563eb; }
.assistant { align-self: flex-start; background: #273449; }
form { display: grid; grid-template-columns: 1fr auto; gap: 10px; padding: 18px 24px 24px; }
input, button { min-height: 44px; border-radius: 10px; border: 1px solid #475569; font: inherit; }
input { padding: 0 12px; color: #f8fafc; background: #0f172a; }
button { padding: 0 20px; color: white; background: #2563eb; cursor: pointer; }
button:disabled { opacity: .6; cursor: wait; }
</style>
</head>
<body>
<main aria-label="LLM Caret chat">
<header><h1>LLM Caret</h1><div id="status" role="status">Connected</div></header>
<section id="messages" aria-live="polite" aria-label="Conversation"></section>
<form id="chat-form">
<label for="prompt" hidden>Message</label>
<input id="prompt" name="prompt" autocomplete="off" placeholder="Message LLM Caret" autofocus required>
<button id="send" type="submit">Send</button>
</form>
</main>
<script>
const form = document.getElementById('chat-form');
const prompt = document.getElementById('prompt');
const messages = document.getElementById('messages');
const send = document.getElementById('send');
function add(role, text) {
  const node = document.createElement('div');
  node.className = 'message ' + role;
  node.dataset.role = role;
  node.textContent = text;
  messages.appendChild(node);
  messages.scrollTop = messages.scrollHeight;
}
form.addEventListener('submit', async function(event) {
  event.preventDefault();
  const text = prompt.value.trim();
  if (!text) return;
  add('user', text);
  prompt.value = '';
  send.disabled = true;
  try {
    const response = await fetch('/api/chat', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({content: text})});
    const data = await response.json();
    add('assistant', data.content || data.error || 'No response');
  } catch (error) {
    add('assistant', 'Connection error');
  } finally {
    send.disabled = false;
    prompt.focus();
  }
});
</script>
</body>
</html>"""

fn caret_gui_json_content(content: text) -> text:
    "{\"content\":\"{escape_json_text(content)}\"}"

fn caret_gui_json_error(error: text) -> text:
    "{\"error\":\"{escape_json_text(error)}\"}"

fn caret_gui_prompt(body: text) -> text:
    extract_json_string(body, "content").trim()

fn caret_gui_native_html(prompt: text, user: text, assistant: text, backend: text, status: text) -> text:
    val safe_prompt = _caret_gui_html_escape(prompt)
    val safe_user = _caret_gui_html_escape(user)
    val safe_assistant = _caret_gui_html_escape(assistant)
    val safe_backend = _caret_gui_html_escape(backend)
    val safe_status = _caret_gui_html_escape(status)
    var messages = "<div class='empty'>Type a message and press Enter</div>"
    if safe_user != "" or safe_assistant != "":
        messages = ""
        if safe_user != "":
            messages = messages + "<div class='message user'>You: " + safe_user + "</div>"
        if safe_assistant != "":
            messages = messages + "<div class='message assistant'>Assistant: " + safe_assistant + "</div>"
    "<!DOCTYPE html><html lang='en'><head><meta charset='utf-8'><title>LLM Caret</title>" +
    "<style>" +
    "html,body{margin:0;width:480px;height:320px;background-color:#0b1020;color:#eef2ff;font-family:sans-serif;}" +
    "main{margin:12px;width:454px;height:294px;background-color:#151b2e;border:1px solid #334155;}" +
    "header{height:44px;padding:8px;background-color:#111827;border-bottom:1px solid #334155;}" +
    "h1{margin:0;font-size:18px;color:#eef2ff;}" +
    ".status{font-size:11px;color:#86efac;}" +
    ".messages{height:166px;padding:12px;background-color:#151b2e;}" +
    ".message{padding:8px;margin-bottom:8px;color:#ffffff;}" +
    ".user{background-color:#2563eb;text-align:right;}" +
    ".assistant{background-color:#273449;}" +
    ".empty{color:#94a3b8;padding:8px;}" +
    ".composer{height:42px;padding:10px;background-color:#111827;border-top:1px solid #334155;}" +
    ".prompt{display:inline-block;width:330px;height:24px;padding:7px;background-color:#0f172a;border:1px solid #60a5fa;color:#f8fafc;}" +
    ".send{display:inline-block;width:68px;height:24px;padding:7px;margin-left:8px;background-color:#2563eb;color:#ffffff;text-align:center;}" +
    "</style></head><body>" +
    "<main aria-label=\"LLM Caret native chat\" data-backend=\"" + safe_backend + "\">" +
    "<header><h1>LLM Caret</h1><div class='status'>" + safe_backend + " / " + safe_status + "</div></header>" +
    "<section class='messages' aria-label='Conversation'>" + messages + "</section>" +
    "<section class='composer' aria-label='Message composer'>" +
    "<span class='prompt'>Message LLM Caret: " + safe_prompt + "</span>" +
    "<span class='send'>Send</span></section></main></body></html>"
