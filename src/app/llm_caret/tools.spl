# LLM Caret - Real Tool Execution + Permission Gating
#
# This is a TRUST BOUNDARY. Every tool call MUST traverse `run_tool`, which
# applies the PermissionPolicy gate before any real side effect (process spawn,
# file read/write, directory listing). No executor is reachable except through
# the gate.
#
# Tools:
#   bash        - run a shell command (timeout, capture stdout/stderr/exit)
#   read_file   - real FS read, line-numbered, offset/limit
#   write_file  - real FS write, refused outside workspace root
#   list_dir    - real directory listing
#   glob        - simple `*` glob within the workspace
#
# Permission model:
#   read-only tools (read_file / list_dir / glob) are auto-allowed
#   mutating tools (bash / write_file) require explicit allow (allow_list or
#   allow_all). With no grant the policy default is "ask"; in non-interactive
#   mode "ask" resolves to DENY and the model gets a permission-error tool_result
#   instead of any execution.
#
# All file tools are additionally path-guarded: the target must resolve under
# the workspace root and must not contain a `..` traversal component.

# ============================================================================
# Runtime externs
# ============================================================================

use app.io.mod.{process_run}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

# ============================================================================
# JSON helpers (inlined - self contained)
# ============================================================================

fn _LB() -> text:
    (123 as char).to_text()

fn _RB() -> text:
    (125 as char).to_text()

fn _Q() -> text:
    "\""

fn _idx(s: text, needle: text) -> i64:
    # NOTE: in the self-hosted interpreter, text.index_of returns a bare i64
    # (-1 sentinel), not an Option. `?? -1` handles both shapes safely.
    s.index_of(needle) ?? -1

fn _json_wire(s: text) -> text:
    # Safe pass-through for real JSON: any JSON object/array contains real `"`,
    # so this returns the input unchanged. It MUST NOT unconditionally strip
    # \" -> " - a prior version did and TRUNCATED any quoted value (write_file
    # content, bash commands with quotes, nested tool_use input). Escapes are
    # handled by the escaped-flag scanners plus _json_unescape. Guarded by
    # tools_spec's JSON round-trip and escaped-input parse tests.
    if s.contains("\""):
        return s
    s.replace("\\\"", "\"")

fn _json_unescape(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\" and i + 1 < s.len():
            val nx = s[i + 1]
            if nx == "n":
                out = out + "\n"
            elif nx == "t":
                out = out + "\t"
            elif nx == "r":
                out = out + "\r"
            elif nx == "\"":
                out = out + "\""
            elif nx == "\\":
                out = out + "\\"
            elif nx == "/":
                out = out + "/"
            else:
                out = out + nx
            i = i + 2
        else:
            out = out + ch
            i = i + 1
    out

fn _json_get_str(json: text, key: text) -> text:
    # Do NOT pre-unescape here: the escaped-flag scanner below plus
    # _json_unescape handle JSON escapes correctly. A prior pre-pass that
    # rewrote \" -> " truncated any quoted value (regression, see
    # tools_spec "preserves escaped quotes ... JSON round-trip").
    val search = _Q() + key + _Q() + ":"
    val idx = _idx(json, search)
    if idx < 0:
        return ""
    val after = json.substring(idx + search.len()).trim()
    if not after.starts_with(_Q()):
        return ""
    val rest = after.substring(1)
    var end = 0
    var escaped = false
    while end < rest.len():
        val ch = rest[end]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return _json_unescape(rest.substring(0, end))
        end = end + 1
    ""

fn _json_get_int(json: text, key: text, dflt: i64) -> i64:
    val search = _Q() + key + _Q() + ":"
    val idx = _idx(json, search)
    if idx < 0:
        return dflt
    val after = json.substring(idx + search.len()).trim()
    var end = 0
    while end < after.len():
        val ch = after.substring(end, end + 1)
        val is_digit = ch >= "0" and ch <= "9"
        val is_neg = ch == "-" and end == 0
        if not (is_digit or is_neg):
            break
        end = end + 1
    if end == 0:
        return dflt
    int(after.substring(0, end))

# ============================================================================
# Tool data types
# ============================================================================

struct ToolCall:
    id: text
    name: text
    input: text

fn new_tool_call(id: text, name: text, input: text) -> ToolCall:
    ToolCall(id: id, name: name, input: input)

struct ToolResult:
    tool_use_id: text
    content: text
    is_error: bool

fn new_tool_result(tool_use_id: text, content: text) -> ToolResult:
    ToolResult(tool_use_id: tool_use_id, content: content, is_error: false)

fn new_tool_error(tool_use_id: text, content: text) -> ToolResult:
    ToolResult(tool_use_id: tool_use_id, content: content, is_error: true)

# A model turn: assistant text plus zero or more tool_use requests.
# Providers (claude_api.spl etc.) parse their wire format into this shape;
# the agent loop consumes it. `parse_tool_use_blocks` below builds the
# tool_calls list directly from an Anthropic-style content array.
struct ModelResponse:
    text: text
    tool_calls: [ToolCall]
    stop_reason: text

fn new_model_text(content: text) -> ModelResponse:
    ModelResponse(text: content, tool_calls: [], stop_reason: "end_turn")

fn new_model_tools(content: text, calls: [ToolCall]) -> ModelResponse:
    ModelResponse(text: content, tool_calls: calls, stop_reason: "tool_use")

# ============================================================================
# Permission policy
# ============================================================================

struct PermissionPolicy:
    workspace_root: text
    default_mode: text      # "ask" | "allow" | "deny" for un-listed mutating tools
    allow_list: [text]      # tool names explicitly allowed (e.g. from config tools.allow)
    allow_all: bool         # --dangerously-allow-all
    interactive: bool       # if false, "ask" resolves to deny

fn _normalize_root(root: text) -> text:
    var r = root
    while r.len() > 1 and r.ends_with("/"):
        r = r.substring(0, r.len() - 1)
    r

fn default_policy(workspace_root: text) -> PermissionPolicy:
    PermissionPolicy(
        workspace_root: _normalize_root(workspace_root),
        default_mode: "ask",
        allow_list: [],
        allow_all: false,
        interactive: false
    )

fn allow_all_policy(workspace_root: text) -> PermissionPolicy:
    PermissionPolicy(
        workspace_root: _normalize_root(workspace_root),
        default_mode: "allow",
        allow_list: [],
        allow_all: true,
        interactive: false
    )

fn policy_with_allow(workspace_root: text, allow_list: [text]) -> PermissionPolicy:
    PermissionPolicy(
        workspace_root: _normalize_root(workspace_root),
        default_mode: "ask",
        allow_list: allow_list,
        allow_all: false,
        interactive: false
    )

fn _list_contains(items: [text], target: text) -> bool:
    for it in items:
        if it == target:
            return true
    false

fn is_read_only_tool(name: text) -> bool:
    name == "read_file" or name == "list_dir" or name == "glob"

fn is_known_tool(name: text) -> bool:
    is_read_only_tool(name) or name == "bash" or name == "write_file"

# Returns "allow" | "deny" | "ask".
fn permission_decision(policy: PermissionPolicy, name: text) -> text:
    if is_read_only_tool(name):
        return "allow"
    if policy.allow_all:
        return "allow"
    if _list_contains(policy.allow_list, name):
        return "allow"
    policy.default_mode

# ============================================================================
# Path guard
# ============================================================================

fn _has_dotdot(path: text) -> bool:
    for part in path.split("/"):
        if part == "..":
            return true
    false

# Returns (resolved_path, error). error == "" means the path is safe to use.
fn guard_path(policy: PermissionPolicy, path: text) -> (text, text):
    if path == "":
        return ("", "path is empty")
    if _has_dotdot(path):
        return ("", "path traversal ('..') is not allowed: " + path)
    var full = path
    if not path.starts_with("/"):
        full = policy.workspace_root + "/" + path
    val root = policy.workspace_root
    if full == root or full.starts_with(root + "/"):
        return (full, "")
    ("", "path escapes workspace root: " + path)

# ============================================================================
# Output helpers
# ============================================================================

val MAX_TOOL_OUTPUT = 30000

fn _truncate(s: text, max_len: i64) -> text:
    if s.len() <= max_len:
        return s
    s.substring(0, max_len) + "\n[output truncated: " + s.len().to_text() + " bytes total]"

fn _pad_left(s: text, width: i64) -> text:
    var r = s
    while r.len() < width:
        r = " " + r
    r

fn _sq(s: text) -> text:
    "'" + s.replace("'", "'\\''") + "'"

# ============================================================================
# Executors (only reachable through run_tool)
# ============================================================================

fn exec_bash(input: text) -> ToolResult:
    val command = _json_get_str(input, "command")
    if command == "":
        return new_tool_error("", "bash: missing required 'command'")
    var timeout_ms = _json_get_int(input, "timeout_ms", 120000)
    if timeout_ms <= 0:
        timeout_ms = 120000
    var secs = timeout_ms / 1000
    if secs < 1:
        secs = 1
    val wrapped = "timeout " + secs.to_text() + " /bin/sh -c " + _sq(command)
    val (out, errout, code) = process_run("/bin/sh", ["-c", wrapped])
    val stdout = out ?? ""
    val stderr = errout ?? ""
    var content = stdout
    if stderr != "":
        if content != "":
            content = content + "\n"
        content = content + "[stderr]\n" + stderr
    if code != 0:
        if content != "":
            content = content + "\n"
        content = content + "[exit code: " + code.to_text() + "]"
    new_tool_result("", _truncate(content, MAX_TOOL_OUTPUT))

fn exec_read_file(policy: PermissionPolicy, input: text) -> ToolResult:
    val path = _json_get_str(input, "path")
    val (full, err) = guard_path(policy, path)
    if err != "":
        return new_tool_error("", "read_file: " + err)
    if not rt_file_exists(full):
        return new_tool_error("", "read_file: file not found: " + path)
    val raw = rt_file_read_text(full) ?? ""
    var offset = _json_get_int(input, "offset", 1)
    if offset < 1:
        offset = 1
    var limit = _json_get_int(input, "limit", 2000)
    if limit < 1:
        limit = 2000
    val lines = raw.split("\n")
    var out_parts: [text] = []
    var i = offset - 1
    var shown = 0
    while i < lines.len() and shown < limit:
        val numbered = _pad_left((i + 1).to_text(), 6) + "\t" + lines[i]
        out_parts = out_parts + [numbered]
        i = i + 1
        shown = shown + 1
    new_tool_result("", _truncate(out_parts.join("\n"), MAX_TOOL_OUTPUT))

fn exec_write_file(policy: PermissionPolicy, input: text) -> ToolResult:
    val path = _json_get_str(input, "path")
    val (full, err) = guard_path(policy, path)
    if err != "":
        return new_tool_error("", "write_file: " + err)
    val content = _json_get_str(input, "content")
    val ok = rt_file_write_text(full, content)
    if not ok:
        return new_tool_error("", "write_file: failed to write " + path)
    new_tool_result("", "wrote " + content.len().to_text() + " bytes to " + path)

fn exec_list_dir(policy: PermissionPolicy, input: text) -> ToolResult:
    var path = _json_get_str(input, "path")
    if path == "":
        path = "."
    val (full, err) = guard_path(policy, path)
    if err != "":
        return new_tool_error("", "list_dir: " + err)
    if not rt_dir_exists(full):
        return new_tool_error("", "list_dir: directory not found: " + path)
    val entries = rt_dir_list(full) ?? []
    new_tool_result("", _truncate(entries.join("\n"), MAX_TOOL_OUTPUT))

# Minimal `*` glob matcher on a single name.
fn _glob_match(pattern: text, name: text) -> bool:
    if _idx(pattern, "*") < 0:
        return pattern == name
    val parts = pattern.split("*")
    var pos = 0
    var first = true
    var idx = 0
    for part in parts:
        if part == "":
            first = false
            idx = idx + 1
            continue
        val rel = _idx(name.substring(pos), part)
        if rel < 0:
            return false
        if first and rel != 0:
            return false
        pos = pos + rel + part.len()
        first = false
        idx = idx + 1
    # if pattern does not end with '*', require we consumed to the end
    if not pattern.ends_with("*"):
        return pos == name.len()
    true

fn exec_glob(policy: PermissionPolicy, input: text) -> ToolResult:
    val pattern = _json_get_str(input, "pattern")
    if pattern == "":
        return new_tool_error("", "glob: missing required 'pattern'")
    var path = _json_get_str(input, "path")
    if path == "":
        path = "."
    val (full, err) = guard_path(policy, path)
    if err != "":
        return new_tool_error("", "glob: " + err)
    if not rt_dir_exists(full):
        return new_tool_error("", "glob: directory not found: " + path)
    val entries = rt_dir_list(full) ?? []
    var matches: [text] = []
    for e in entries:
        if _glob_match(pattern, e):
            matches = matches + [e]
    new_tool_result("", matches.join("\n"))

# ============================================================================
# The gate - every tool call MUST traverse this function
# ============================================================================

fn run_tool(policy: PermissionPolicy, call: ToolCall) -> ToolResult:
    if not is_known_tool(call.name):
        return new_tool_error(call.id, "unknown tool: " + call.name)
    val decision = permission_decision(policy, call.name)
    if decision == "deny":
        return new_tool_error(call.id, "permission denied: tool '" + call.name + "' is denied by policy")
    if decision == "ask":
        if not policy.interactive:
            return new_tool_error(call.id, "permission denied: tool '" + call.name + "' requires approval (non-interactive mode; no grant configured)")
        # Interactive approval seam: not wired in Phase 1. Fail safe = deny.
        return new_tool_error(call.id, "permission denied: interactive approval not available for '" + call.name + "'")
    # decision == "allow": dispatch to the real executor
    var res = new_tool_error(call.id, "unknown tool: " + call.name)
    if call.name == "bash":
        res = exec_bash(call.input)
    elif call.name == "read_file":
        res = exec_read_file(policy, call.input)
    elif call.name == "write_file":
        res = exec_write_file(policy, call.input)
    elif call.name == "list_dir":
        res = exec_list_dir(policy, call.input)
    elif call.name == "glob":
        res = exec_glob(policy, call.input)
    ToolResult(tool_use_id: call.id, content: res.content, is_error: res.is_error)

# ============================================================================
# Anthropic content-array parse (real wire-format tool_use blocks)
# ============================================================================

fn _extract_object_at(json: text, start: i64) -> text:
    var depth = 0
    var i = start
    var in_str = false
    var escaped = false
    while i < json.len():
        val ch = json.substring(i, i + 1)
        if in_str:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == "{":
                depth = depth + 1
            elif ch == "}":
                depth = depth - 1
                if depth == 0:
                    return json.substring(start, i + 1)
        i = i + 1
    json.substring(start)

fn _rfind_brace(json: text, pos: i64) -> i64:
    var i = pos
    while i >= 0:
        if json.substring(i, i + 1) == "{":
            return i
        i = i - 1
    -1

fn _extract_input_object(obj: text) -> text:
    val src = _json_wire(obj)
    val key = _Q() + "input" + _Q() + ":"
    val idx = _idx(src, key)
    if idx < 0:
        return _LB() + _RB()
    var j = idx + key.len()
    while j < src.len() and src.substring(j, j + 1) != "{":
        j = j + 1
    if j >= src.len():
        return _LB() + _RB()
    _extract_object_at(src, j)

# Parse all tool_use blocks out of an Anthropic-style content array / message.
fn parse_tool_use_blocks(json: text) -> [ToolCall]:
    val src = _json_wire(json)
    var calls: [ToolCall] = []
    val marker = _Q() + "type" + _Q() + ":" + _Q() + "tool_use" + _Q()
    var search_from = 0
    while search_from < src.len():
        val rest = src.substring(search_from)
        val rel = _idx(rest, marker)
        if rel < 0:
            break
        val abs_marker = search_from + rel
        val obj_start = _rfind_brace(src, abs_marker)
        if obj_start < 0:
            break
        val obj = _extract_object_at(src, obj_start)
        val id = _json_get_str(obj, "id")
        val name = _json_get_str(obj, "name")
        val input = _extract_input_object(obj)
        calls = calls + [ToolCall(id: id, name: name, input: input)]
        search_from = abs_marker + marker.len()
    calls
