"""
Claude full top-level slash command registry parity model.
"""

class RootCommandRecord:
    name: text
    slashName: text
    summary: text
    category: text
    aliases: [text]
    enabled: bool
    hidden: bool
    sourceFile: text
    sourceLine: i64

impl RootCommandRecord:
    static fn command(name: text, summary: text, category: text, aliases: [text], sourceFile: text, sourceLine: i64) -> RootCommandRecord:
        RootCommandRecord(name: name, slashName: "/" + name, summary: summary, category: category, aliases: aliases, enabled: true, hidden: false, sourceFile: sourceFile, sourceLine: sourceLine)

    static fn hiddenCommand(name: text, summary: text, category: text, aliases: [text], sourceFile: text, sourceLine: i64) -> RootCommandRecord:
        RootCommandRecord(name: name, slashName: "/" + name, summary: summary, category: category, aliases: aliases, enabled: true, hidden: true, sourceFile: sourceFile, sourceLine: sourceLine)

    static fn disabledCommand(name: text, summary: text, category: text, aliases: [text], sourceFile: text, sourceLine: i64) -> RootCommandRecord:
        RootCommandRecord(name: name, slashName: "/" + name, summary: summary, category: category, aliases: aliases, enabled: false, hidden: false, sourceFile: sourceFile, sourceLine: sourceLine)

class RootCommandLookup:
    found: bool
    command: RootCommandRecord
    matchedAlias: text

impl RootCommandLookup:
    static fn missing() -> RootCommandLookup:
        RootCommandLookup(found: false, command: RootCommandRecord.disabledCommand("", "", "", [], "", 0), matchedAlias: "")

    static fn found(command: RootCommandRecord, matchedAlias: text) -> RootCommandLookup:
        RootCommandLookup(found: true, command: command, matchedAlias: matchedAlias)

fn canonicalCommandToken(token: text) -> text:
    if token.starts_with("/"):
        token.substring(1, token.len())
    else:
        token

fn rootCommandRegistry() -> [RootCommandRecord]:
    [
        RootCommandRecord.command("help", "Show available slash commands", "core", ["?"], "commands/help/index.ts", 1),
        RootCommandRecord.command("clear", "Clear conversation history and free up context", "core", ["reset", "new"], "commands/clear/index.ts", 1),
        RootCommandRecord.command("compact", "Compact the current conversation", "core", ["summarize"], "commands/compact/index.ts", 1),
        RootCommandRecord.command("config", "Open configuration controls", "settings", ["settings"], "commands/config/index.ts", 1),
        RootCommandRecord.command("mcp", "Manage MCP servers and authentication", "integrations", ["servers"], "commands/mcp/index.ts", 1),
        RootCommandRecord.command("memory", "Edit project memory files", "context", ["mem"], "commands/memory/index.ts", 1),
        RootCommandRecord.command("add-dir", "Add a workspace directory", "context", ["add_dir"], "commands/add-dir/index.ts", 1),
        RootCommandRecord.command("agents", "Manage agent definitions", "automation", ["agent"], "commands/agents/index.ts", 1),
        RootCommandRecord.command("status", "Show session status", "session", ["session-status"], "commands/status/index.ts", 1),
        RootCommandRecord.command("cost", "Show token and cost totals", "session", ["usage"], "commands/cost/index.ts", 1),
        RootCommandRecord.command("doctor", "Run local diagnostics", "maintenance", ["checkup"], "commands/doctor/index.ts", 1),
        RootCommandRecord.command("diff", "Show working tree diff", "workflow", ["changes"], "commands/diff/index.ts", 1),
        RootCommandRecord.command("commit", "Create a commit prompt", "workflow", ["commit-message"], "commands/commit.ts", 1),
        RootCommandRecord.command("copy", "Copy conversation content", "workflow", ["clipboard"], "commands/copy/index.ts", 1),
        RootCommandRecord.command("export", "Export the conversation", "workflow", ["save"], "commands/export/index.ts", 1),
        RootCommandRecord.command("login", "Sign in to Claude", "auth", ["signin"], "commands/login/index.ts", 1),
        RootCommandRecord.command("logout", "Sign out of Claude", "auth", ["signout"], "commands/logout/index.ts", 1),
        RootCommandRecord.command("ide", "Connect an IDE", "integrations", ["editor"], "commands/ide/index.ts", 1),
        RootCommandRecord.command("hooks", "Configure command hooks", "settings", ["hook"], "commands/hooks/index.ts", 1),
        RootCommandRecord.command("init", "Initialize project guidance", "setup", ["bootstrap"], "commands/init.ts", 1),
        RootCommandRecord.hiddenCommand("debug-tool-call", "Inspect a tool call envelope", "debug", ["debug_tool_call"], "commands/debug-tool-call/index.ts", 1),
        RootCommandRecord.disabledCommand("remote-setup", "Set up remote session support", "remote", ["remote_setup"], "commands/remote-setup/index.ts", 1)
    ]

fn findRootCommand(token: text) -> RootCommandLookup:
    val wanted = canonicalCommandToken(token)
    for command in rootCommandRegistry():
        if command.name == wanted:
            return RootCommandLookup.found(command, "")
        for alias in command.aliases:
            if alias == wanted:
                return RootCommandLookup.found(command, alias)
    RootCommandLookup.missing()

fn visibleRootCommands() -> [RootCommandRecord]:
    var out: [RootCommandRecord] = []
    for command in rootCommandRegistry():
        if command.enabled and not command.hidden:
            out.push(command)
    out

fn rootCommandsByCategory(category: text) -> [RootCommandRecord]:
    var out: [RootCommandRecord] = []
    for command in rootCommandRegistry():
        if command.category == category:
            out.push(command)
    out

fn rootCommandNames() -> [text]:
    var out: [text] = []
    for command in rootCommandRegistry():
        out.push(command.name)
    out

fn visibleRootCommandSummary() -> text:
    "/help core - Show available slash commands\n/clear core - Clear conversation history and free up context\n/config settings - Open configuration controls\n/mcp integrations - Manage MCP servers and authentication"

fn rootCommandSourceLine(name: text) -> i64:
    val lookup = findRootCommand(name)
    if lookup.found:
        lookup.command.sourceLine
    else:
        0

fn rootCommandsSourceLinesModeled() -> i64:
    754
