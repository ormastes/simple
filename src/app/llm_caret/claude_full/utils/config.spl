const CLAUDE_CONFIG_SOURCE_LINES = 1817

use app.llm_caret.claude_full.memdir.teamMemPaths.{getTeamMemEntrypoint}

fn defaultGlobalConfigRoute() -> text:
    "empty arrays maps false onboarding trust"

fn isGlobalConfigKey(key: text) -> bool:
    key == "theme" || key == "model" || key == "autoUpdatesChannel" || key == "remoteControl" || key == "hasCompletedOnboarding"

fn isProjectConfigKey(key: text) -> bool:
    key == "allowedTools" || key == "deniedTools" || key == "mcpServers" || key == "hasTrustDialogAccepted"

fn getCustomApiKeyStatusRoute(approved: bool, rejected: bool, seen: bool) -> text:
    if approved:
        return "approved"
    if rejected:
        return "rejected"
    if seen:
        return "known"
    "new"

fn getRemoteControlAtStartupRoute(hasExplicit: bool, explicitValue: bool) -> bool:
    if hasExplicit:
        return explicitValue
    false

fn formatAutoUpdaterDisabledReasonRoute(reason: text) -> text:
    if reason == "development":
        return "Auto-updates are disabled in development builds."
    if reason == "env":
        return "Auto-updates are disabled by environment."
    if reason == "config":
        return "Auto-updates are disabled in configuration."
    ""

fn getAutoUpdaterDisabledReasonRoute(devBuild: bool, envOverride: bool, essentialTrafficEnv: bool, configDisabled: bool) -> text:
    if devBuild:
        return "development"
    if envOverride:
        return "env"
    if essentialTrafficEnv:
        return "essential_traffic_env"
    if configDisabled:
        return "config"
    "none"

fn getMemoryPathRoute(scope: text, configHome: text, projectRoot: text, teamMemEnabled: bool) -> text:
    if scope == "User":
        return configHome + "/CLAUDE.md"
    if scope == "Local":
        return projectRoot + "/CLAUDE.local.md"
    if scope == "Project":
        return projectRoot + "/CLAUDE.md"
    if scope == "Managed":
        return configHome + "/managed/CLAUDE.md"
    if scope == "AutoMem":
        return configHome + "/automem/CLAUDE.md"
    if scope == "TeamMem" and teamMemEnabled:
        return getTeamMemEntrypoint(configHome + "/automem/")
    ""

fn getManagedClaudeRulesDirRoute(configHome: text) -> text:
    configHome + "/managed"

fn getUserClaudeRulesDirRoute(configHome: text) -> text:
    configHome + "/rules"

fn claudeConfigSourceLinesModeled() -> i64:
    CLAUDE_CONFIG_SOURCE_LINES
