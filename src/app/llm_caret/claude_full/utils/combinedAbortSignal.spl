class CombinedAbortSignal:
    aborted: bool
    listenerCount: i64
    timerActive: bool
    cleanupNeeded: bool

impl CombinedAbortSignal:
    static fn new(aborted: bool, listenerCount: i64, timerActive: bool, cleanupNeeded: bool) -> CombinedAbortSignal:
        CombinedAbortSignal(aborted: aborted, listenerCount: listenerCount, timerActive: timerActive, cleanupNeeded: cleanupNeeded)

    fn cleanup() -> CombinedAbortSignal:
        CombinedAbortSignal.new(self.aborted, 0, false, false)

    fn abortFromInput() -> CombinedAbortSignal:
        CombinedAbortSignal.new(true, self.listenerCount, false, self.listenerCount > 0)

    fn abortFromTimeout() -> CombinedAbortSignal:
        CombinedAbortSignal.new(true, self.listenerCount, false, self.listenerCount > 0)

fn createCombinedAbortSignal(hasSignalA: bool, signalAAborted: bool, hasSignalB: bool, signalBAborted: bool, timeoutMs: i64) -> CombinedAbortSignal:
    if (hasSignalA and signalAAborted) or (hasSignalB and signalBAborted):
        return CombinedAbortSignal.new(true, 0, false, false)
    var listenerCount = 0
    if hasSignalA:
        listenerCount = listenerCount + 1
    if hasSignalB:
        listenerCount = listenerCount + 1
    val timerActive = timeoutMs >= 0
    CombinedAbortSignal.new(false, listenerCount, timerActive, listenerCount > 0 or timerActive)
