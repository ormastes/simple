class ControlMessageResponseCompat:
    request_id: text
    requestId: text
    hasRequestId: bool

class ControlMessageCompat:
    request_id: text
    requestId: text
    hasRequestId: bool
    response: ControlMessageResponseCompat
    hasResponse: bool

fn controlMessageResponse(request_id: text, requestId: text, hasRequestId: bool) -> ControlMessageResponseCompat:
    ControlMessageResponseCompat(request_id: request_id, requestId: requestId, hasRequestId: hasRequestId)

fn controlMessage(request_id: text, requestId: text, hasRequestId: bool, response: ControlMessageResponseCompat, hasResponse: bool) -> ControlMessageCompat:
    ControlMessageCompat(request_id: request_id, requestId: requestId, hasRequestId: hasRequestId, response: response, hasResponse: hasResponse)

fn emptyControlMessageResponse() -> ControlMessageResponseCompat:
    controlMessageResponse("", "", false)

fn normalizeControlMessageKeys(message: ControlMessageCompat) -> ControlMessageCompat:
    var request_id = message.request_id
    var requestId = message.requestId
    var hasRequestId = message.hasRequestId
    if request_id == "" and hasRequestId:
        request_id = requestId
        requestId = ""
        hasRequestId = false

    var response = message.response
    if message.hasResponse:
        response = normalizeControlMessageResponseKeys(response)

    controlMessage(request_id, requestId, hasRequestId, response, message.hasResponse)

fn normalizeControlMessageResponseKeys(response: ControlMessageResponseCompat) -> ControlMessageResponseCompat:
    if response.request_id == "" and response.hasRequestId:
        return controlMessageResponse(response.requestId, "", false)
    response
