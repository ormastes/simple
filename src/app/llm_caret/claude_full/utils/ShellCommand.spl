"""
Claude full shell command utility parity surface.
"""

use app.llm_caret.claude_full.utils.stream.{Stream}

class ExecResult:
    code: i64
    signal: text
    stdout: text
    stderr: text
    interrupted: bool
    errorName: text
    errorMessage: text

impl ExecResult:
    static fn new(code: i64, signal: text, stdout: text, stderr: text, interrupted: bool, errorName: text, errorMessage: text) -> ExecResult:
        ExecResult(code: code, signal: signal, stdout: stdout, stderr: stderr, interrupted: interrupted, errorName: errorName, errorMessage: errorMessage)

    fn ok() -> bool:
        self.code == 0 and self.signal == "" and self.errorName == "" and not self.interrupted

    fn failed() -> bool:
        not self.ok()

class ShellCommand:
    command: text
    args: [text]
    cwd: text
    stdin: text

impl ShellCommand:
    static fn new(command: text, args: [text], cwd: text, stdin: text) -> ShellCommand:
        ShellCommand(command: command, args: args, cwd: cwd, stdin: stdin)

    fn displayCommand() -> text:
        var result = self.command
        var i = 0
        while i < self.args.len():
            result = result + " " + self.args[i]
            i = i + 1
        result

fn prependStderr(stderr: text, prefix: text) -> text:
    if stderr == "":
        return ""
    val lines = stderr.split("\n")
    var result = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            result = result + "\n"
        if lines[i] == "":
            result = result + lines[i]
        else:
            result = result + prefix + lines[i]
        i = i + 1
    result

class StreamWrapper:
    stdout: Stream
    stderr: Stream
    closed: bool
    capturedStdout: [text]
    capturedStderr: [text]

impl StreamWrapper:
    static fn new() -> StreamWrapper:
        StreamWrapper(stdout: Stream.new(), stderr: Stream.new(), closed: false, capturedStdout: [], capturedStderr: [])

    fn writeStdout(chunk: text) -> StreamWrapper:
        if self.closed:
            return self
        var captured = self.capturedStdout
        captured.push(chunk)
        StreamWrapper(stdout: self.stdout.append(chunk), stderr: self.stderr, closed: self.closed, capturedStdout: captured, capturedStderr: self.capturedStderr)

    fn writeStderr(chunk: text) -> StreamWrapper:
        if self.closed:
            return self
        var captured = self.capturedStderr
        captured.push(chunk)
        StreamWrapper(stdout: self.stdout, stderr: self.stderr.append(chunk), closed: self.closed, capturedStdout: self.capturedStdout, capturedStderr: captured)

    fn close() -> StreamWrapper:
        StreamWrapper(stdout: self.stdout.closeStream(), stderr: self.stderr.closeStream(), closed: true, capturedStdout: self.capturedStdout, capturedStderr: self.capturedStderr)

    fn stdoutText() -> text:
        self.stdout.text()

    fn stderrText() -> text:
        self.stderr.text()

    fn combinedText() -> text:
        self.stdoutText() + self.stderrText()

class ShellCommandImpl:
    command: ShellCommand
    streams: StreamWrapper
    started: bool
    completed: bool
    killed: bool
    timedOut: bool
    aborted: bool
    exitCode: i64
    signal: text
    errorName: text
    errorMessage: text

impl ShellCommandImpl:
    static fn new(command: text, args: [text], cwd: text) -> ShellCommandImpl:
        ShellCommandImpl(command: ShellCommand.new(command, args, cwd, ""), streams: StreamWrapper.new(), started: false, completed: false, killed: false, timedOut: false, aborted: false, exitCode: 0, signal: "", errorName: "", errorMessage: "")

    fn start() -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams, started: true, completed: self.completed, killed: self.killed, timedOut: self.timedOut, aborted: self.aborted, exitCode: self.exitCode, signal: self.signal, errorName: self.errorName, errorMessage: self.errorMessage)

    fn writeStdout(chunk: text) -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.writeStdout(chunk), started: self.started, completed: self.completed, killed: self.killed, timedOut: self.timedOut, aborted: self.aborted, exitCode: self.exitCode, signal: self.signal, errorName: self.errorName, errorMessage: self.errorMessage)

    fn writeStderr(chunk: text) -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.writeStderr(chunk), started: self.started, completed: self.completed, killed: self.killed, timedOut: self.timedOut, aborted: self.aborted, exitCode: self.exitCode, signal: self.signal, errorName: self.errorName, errorMessage: self.errorMessage)

    fn complete(code: i64) -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.close(), started: true, completed: true, killed: self.killed, timedOut: self.timedOut, aborted: self.aborted, exitCode: code, signal: self.signal, errorName: self.errorName, errorMessage: self.errorMessage)

    fn fail(message: text) -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.writeStderr(message).close(), started: true, completed: true, killed: self.killed, timedOut: self.timedOut, aborted: self.aborted, exitCode: 1, signal: self.signal, errorName: "Error", errorMessage: message)

    fn abort() -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.close(), started: true, completed: true, killed: true, timedOut: self.timedOut, aborted: true, exitCode: 1, signal: "SIGTERM", errorName: "AbortError", errorMessage: "Command was aborted")

    fn timeout() -> ShellCommandImpl:
        ShellCommandImpl(command: self.command, streams: self.streams.close(), started: true, completed: true, killed: true, timedOut: true, aborted: true, exitCode: 1, signal: "SIGTERM", errorName: "AbortError", errorMessage: "Command timed out")

    fn isRunning() -> bool:
        self.started and not self.completed

    fn result() -> ExecResult:
        ExecResult.new(self.exitCode, self.signal, self.streams.stdoutText(), self.streams.stderrText(), self.aborted or self.killed or self.timedOut, self.errorName, self.errorMessage)

    fn summary() -> text:
        if self.completed:
            return "completed:{self.exitCode}"
        if self.started:
            return "running"
        "pending"

fn exitPromise(command: ShellCommandImpl) -> ExecResult:
    command.result()

fn wrapSpawn(command: text, args: [text], cwd: text) -> ShellCommandImpl:
    ShellCommandImpl.new(command, args, cwd).start()

class AbortedShellCommand:
    command: ShellCommand
    reason: text
    signal: text

impl AbortedShellCommand:
    static fn new(command: text, reason: text) -> AbortedShellCommand:
        AbortedShellCommand(command: ShellCommand.new(command, [], "", ""), reason: reason, signal: "SIGTERM")

    fn result() -> ExecResult:
        ExecResult.new(1, self.signal, "", self.reason, true, "AbortError", self.reason)

    fn displayCommand() -> text:
        self.command.displayCommand()

fn createAbortedCommand(command: text, reason: text) -> AbortedShellCommand:
    AbortedShellCommand.new(command, reason)

fn createFailedCommand(command: text, message: text) -> ShellCommandImpl:
    ShellCommandImpl.new(command, [], "").fail(message)

