fn formatFileSize(sizeInBytes: i64) -> text:
    val kbTenths = (sizeInBytes * 10) / 1024
    if kbTenths < 10:
        return sizeInBytes.to_text() + " bytes"
    if kbTenths < 10240:
        return formatTenths(kbTenths) + "KB"
    val mbTenths = kbTenths / 1024
    if mbTenths < 10240:
        return formatTenths(mbTenths) + "MB"
    val gbTenths = mbTenths / 1024
    formatTenths(gbTenths) + "GB"

fn formatSecondsShort(ms: i64) -> text:
    formatTenths(ms / 100) + "s"

fn formatDuration(ms: i64) -> text:
    if ms < 60000:
        if ms == 0:
            return "0s"
        if ms < 1000:
            return formatTenths(ms / 100) + "s"
        return (ms / 1000).to_text() + "s"

    var days = ms / 86400000
    var hours = (ms % 86400000) / 3600000
    var minutes = (ms % 3600000) / 60000
    var seconds = ((ms % 60000) + 500) / 1000

    if seconds == 60:
        seconds = 0
        minutes = minutes + 1
    if minutes == 60:
        minutes = 0
        hours = hours + 1
    if hours == 24:
        hours = 0
        days = days + 1

    if days > 0:
        return days.to_text() + "d " + hours.to_text() + "h " + minutes.to_text() + "m"
    if hours > 0:
        return hours.to_text() + "h " + minutes.to_text() + "m " + seconds.to_text() + "s"
    if minutes > 0:
        return minutes.to_text() + "m " + seconds.to_text() + "s"
    seconds.to_text() + "s"

fn formatTenths(tenths: i64) -> text:
    val whole = tenths / 10
    val frac = tenths - whole * 10
    if frac == 0: whole.to_text() else: whole.to_text() + "." + frac.to_text()
