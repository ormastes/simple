fn modelAliases() -> [text]:
    ["sonnet", "opus", "haiku", "best", "sonnet[1m]", "opus[1m]", "opusplan"]

fn modelFamilyAliases() -> [text]:
    ["sonnet", "opus", "haiku"]

fn isModelAlias(modelInput: text) -> bool:
    containsText(modelAliases(), modelInput)

fn isModelFamilyAlias(model: text) -> bool:
    containsText(modelFamilyAliases(), model)

fn containsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false
