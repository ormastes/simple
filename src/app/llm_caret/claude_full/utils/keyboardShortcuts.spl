fn macosOptionSpecialCharBinding(sourceKey: text) -> text:
    if sourceKey == "dagger":
        return "alt+t"
    if sourceKey == "pi":
        return "alt+p"
    if sourceKey == "o-slash":
        return "alt+o"
    ""

fn macosOptionSpecialCharBindingByCodepoint(codepoint: i64) -> text:
    if codepoint == 0x2020:
        return "alt+t"
    if codepoint == 0x03c0:
        return "alt+p"
    if codepoint == 0x00f8:
        return "alt+o"
    ""

fn isMacosOptionChar(sourceKey: text) -> bool:
    macosOptionSpecialCharBinding(sourceKey) != ""

fn isMacosOptionCodepoint(codepoint: i64) -> bool:
    macosOptionSpecialCharBindingByCodepoint(codepoint) != ""

fn macosOptionSpecialCharCount() -> i64:
    3

fn macosOptionSpecialCharSourceKeys() -> [text]:
    ["dagger", "pi", "o-slash"]
