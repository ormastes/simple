"""
Claude full errors parity surface.
"""

class ClaudeError:
    name: text
    message: text

impl ClaudeError:
    static fn new(message: text) -> ClaudeError:
        ClaudeError(name: "ClaudeError", message: message)

class MalformedCommandError:
    name: text
    message: text

impl MalformedCommandError:
    static fn new(message: text) -> MalformedCommandError:
        MalformedCommandError(name: "MalformedCommandError", message: message)

class AbortError:
    name: text
    message: text

impl AbortError:
    static fn new(message: text) -> AbortError:
        AbortError(name: "AbortError", message: message)

class ConfigParseError:
    name: text
    message: text
    filePath: text
    defaultConfig: text

impl ConfigParseError:
    static fn new(message: text, filePath: text, defaultConfig: text) -> ConfigParseError:
        ConfigParseError(name: "ConfigParseError", message: message, filePath: filePath, defaultConfig: defaultConfig)

class ShellError:
    name: text
    message: text
    stdout: text
    stderr: text
    code: i64
    interrupted: bool

impl ShellError:
    static fn new(stdout: text, stderr: text, code: i64, interrupted: bool) -> ShellError:
        ShellError(name: "ShellError", message: "Shell command failed", stdout: stdout, stderr: stderr, code: code, interrupted: interrupted)

class TeleportOperationError:
    name: text
    message: text
    formattedMessage: text

impl TeleportOperationError:
    static fn new(message: text, formattedMessage: text) -> TeleportOperationError:
        TeleportOperationError(name: "TeleportOperationError", message: message, formattedMessage: formattedMessage)

class TelemetrySafeError_I_VERIFIED_THIS_IS_NOT_CODE_OR_FILEPATHS:
    name: text
    message: text
    telemetryMessage: text

impl TelemetrySafeError_I_VERIFIED_THIS_IS_NOT_CODE_OR_FILEPATHS:
    static fn new(message: text, telemetryMessage: text) -> TelemetrySafeError_I_VERIFIED_THIS_IS_NOT_CODE_OR_FILEPATHS:
        var safe = telemetryMessage
        if safe == "":
            safe = message
        TelemetrySafeError_I_VERIFIED_THIS_IS_NOT_CODE_OR_FILEPATHS(name: "TelemetrySafeError", message: message, telemetryMessage: safe)

fn isAbortErrorName(name: text) -> bool:
    name == "AbortError" or name == "APIUserAbortError"

fn hasExactErrorMessage(errorMessage: text, message: text) -> bool:
    errorMessage == message

fn toErrorMessage(value: text) -> text:
    value

fn errorMessage(value: text) -> text:
    value

fn isEnoent(code: text) -> bool:
    code == "ENOENT"

fn isEacces(code: text) -> bool:
    code == "EACCES"

fn errorsSourceLinesModeled() -> i64: 238
