"""
Claude full image validation parity surface.
"""

class OversizedImage:
    index: i64
    size: i64

impl OversizedImage:
    static fn new(index: i64, size: i64) -> OversizedImage:
        OversizedImage(index: index, size: size)

class ImageSizeError:
    name: text
    message: text
    oversizedImages: [OversizedImage]
    maxSize: i64

impl ImageSizeError:
    static fn new(oversizedImages: [OversizedImage], maxSize: i64) -> ImageSizeError:
        var message = ""
        if oversizedImages.len() == 1:
            message = "Image base64 size (" + oversizedImages[0].size.to_text() + ") exceeds API limit (" + maxSize.to_text() + "). Please resize the image before sending."
        else:
            message = oversizedImages.len().to_text() + " images exceed the API limit (" + maxSize.to_text() + "). Please resize these images before sending."
        ImageSizeError(name: "ImageSizeError", message: message, oversizedImages: oversizedImages, maxSize: maxSize)

fn validateImageSizes(sizes: [i64], maxSize: i64) -> ImageSizeError:
    var oversized: [OversizedImage] = []
    var i = 0
    while i < sizes.len():
        if sizes[i] > maxSize:
            oversized.push(OversizedImage.new(i, sizes[i]))
        i = i + 1
    if oversized.len() == 0:
        return ImageSizeError.new([], maxSize)
    ImageSizeError.new(oversized, maxSize)

fn imageValidationSourceLinesModeled() -> i64: 104
