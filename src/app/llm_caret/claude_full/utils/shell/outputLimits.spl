class EnvVarValidationResult:
    effective: i64
    status: text
    message: text

fn bashMaxOutputUpperLimit() -> i64:
    150000

fn bashMaxOutputDefault() -> i64:
    30000

fn bashMaxOutputEnvName() -> text:
    "BASH_MAX_OUTPUT_LENGTH"

fn validateBoundedIntEnvVar(name: text, value: text, defaultValue: i64, upperLimit: i64) -> EnvVarValidationResult:
    if value == "":
        return EnvVarValidationResult(effective: defaultValue, status: "valid", message: "")
    if val parsed = value.to_i64():
        if parsed <= 0:
            return EnvVarValidationResult(effective: defaultValue, status: "invalid", message: invalidEnvValueMessage(value, defaultValue))
        if parsed > upperLimit:
            return EnvVarValidationResult(effective: upperLimit, status: "capped", message: cappedEnvValueMessage(parsed, upperLimit))
        return EnvVarValidationResult(effective: parsed, status: "valid", message: "")
    EnvVarValidationResult(effective: defaultValue, status: "invalid", message: invalidEnvValueMessage(value, defaultValue))

fn getMaxOutputLengthFromEnvValue(value: text) -> i64:
    validateBoundedIntEnvVar(bashMaxOutputEnvName(), value, bashMaxOutputDefault(), bashMaxOutputUpperLimit()).effective

fn invalidEnvValueMessage(value: text, defaultValue: i64) -> text:
    "Invalid value \"" + value + "\" (using default: " + defaultValue.to_text() + ")"

fn cappedEnvValueMessage(parsed: i64, upperLimit: i64) -> text:
    "Capped from " + parsed.to_text() + " to " + upperLimit.to_text()
