const SHELL_READ_ONLY_COMMAND_VALIDATION_SOURCE_LINES = 1893

fn validateFlagArgumentRoute(value: text, argType: text) -> bool:
    if argType == "number":
        return value == "0" || value == "1" || value == "2" || value == "3" || value == "10"
    if argType == "char":
        return value.len() == 1
    if argType == "{}":
        return value == "{}"
    value != ""

fn containsVulnerableUncPathRoute(value: text, isWindows: bool) -> bool:
    if !isWindows:
        return false
    if value.starts_with("https://") || value.starts_with("http://"):
        return false
    value.starts_with("\\\\") || value.starts_with("//")

fn ghIsDangerousCallbackRoute(arg: text) -> bool:
    arg.starts_with("--repo=evil.com/") || arg.starts_with("https://evil.com/") || arg.starts_with("ssh://evil.com/")

fn validateFlagsRoute(command: text, respectsDoubleDash: bool) -> text:
    if command.contains("-E="):
        return "reject empty inline arg"
    if command.contains("-rI"):
        return "reject bundled arg flag"
    if command.contains(" -- ") && respectsDoubleDash:
        return "stop at double dash"
    if command.contains(" -- ") && !respectsDoubleDash:
        return "scan past double dash"
    if command.contains(" -3"):
        return "accept git numeric shorthand"
    "flags accepted"

fn gitTagRoute(command: text) -> text:
    if command == "git tag -l foo":
        return "git tag list safe"
    if command.starts_with("git tag "):
        return "git tag creation blocked"
    "not git tag"

fn shellReadOnlyCommandValidationSourceLinesModeled() -> i64:
    SHELL_READ_ONLY_COMMAND_VALIDATION_SOURCE_LINES
