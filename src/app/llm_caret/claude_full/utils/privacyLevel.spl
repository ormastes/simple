use app.io.mod.{env_get}

fn getPrivacyLevel() -> text:
    if (env_get("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC") ?? "") != "":
        return "essential-traffic"
    if (env_get("DISABLE_TELEMETRY") ?? "") != "":
        return "no-telemetry"
    "default"

fn isEssentialTrafficOnly() -> bool:
    getPrivacyLevel() == "essential-traffic"

fn isTelemetryDisabled() -> bool:
    getPrivacyLevel() != "default"

fn getEssentialTrafficOnlyReason() -> Option<text>:
    if (env_get("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC") ?? "") != "":
        return Some("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC")
    nil

export getPrivacyLevel, isEssentialTrafficOnly
export isTelemetryDisabled, getEssentialTrafficOnlyReason
