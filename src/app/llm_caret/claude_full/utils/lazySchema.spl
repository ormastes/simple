"""
Claude full lazy schema parity.
"""

class LazySchemaText:
    cached: Option<text>
    factory: fn() -> text
    factoryCalls: i64

impl LazySchemaText:
    fn read() -> LazySchemaTextRead:
        if val Some(value) = self.cached:
            return LazySchemaTextRead(state: self, value: value)
        val value = self.factory()
        val next = LazySchemaText(cached: Some(value), factory: self.factory, factoryCalls: self.factoryCalls + 1)
        LazySchemaTextRead(state: next, value: value)

class LazySchemaTextRead:
    state: LazySchemaText
    value: text

fn lazySchemaText(factory: fn() -> text) -> LazySchemaText:
    LazySchemaText(cached: nil, factory: factory, factoryCalls: 0)
