class SemanticValue:
    kind: text
    textValue: text
    numberValue: f64
    boolValue: bool

impl SemanticValue:
    static fn textValue(value: text) -> SemanticValue:
        SemanticValue(kind: "text", textValue: value, numberValue: 0.0, boolValue: false)

    static fn numberValue(value: f64) -> SemanticValue:
        SemanticValue(kind: "number", textValue: "", numberValue: value, boolValue: false)

    static fn boolValue(value: bool) -> SemanticValue:
        SemanticValue(kind: "bool", textValue: "", numberValue: 0.0, boolValue: value)

    static fn nilValue() -> SemanticValue:
        SemanticValue(kind: "nil", textValue: "", numberValue: 0.0, boolValue: false)

fn semanticBoolean(value: SemanticValue) -> SemanticValue:
    if value.kind == "text" and (value.textValue == "true" or value.textValue == "false"):
        return SemanticValue.boolValue(value.textValue == "true")
    value

fn semanticNumber(value: SemanticValue) -> SemanticValue:
    if value.kind != "text":
        return value
    if not isSemanticDecimalLiteral(value.textValue):
        return value
    if not isSemanticFiniteDecimalLiteral(value.textValue):
        return value
    SemanticValue.numberValue(value.textValue.to_f64())

fn isSemanticDecimalLiteral(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    if value.slice(0, 1) == "-":
        if value.len() == 1:
            return false
        i = 1
    var digitsBeforeDot = 0
    while i < value.len() and isSemanticDigit(value.slice(i, i + 1)):
        digitsBeforeDot = digitsBeforeDot + 1
        i = i + 1
    if digitsBeforeDot == 0:
        return false
    if i == value.len():
        return true
    if value.slice(i, i + 1) != ".":
        return false
    i = i + 1
    var digitsAfterDot = 0
    while i < value.len() and isSemanticDigit(value.slice(i, i + 1)):
        digitsAfterDot = digitsAfterDot + 1
        i = i + 1
    digitsAfterDot > 0 and i == value.len()

fn isSemanticDigit(ch: text) -> bool:
    ch >= "0" and ch <= "9"

fn isSemanticFiniteDecimalLiteral(value: text) -> bool:
    val maxFiniteInteger = ""
    var start = 0
    if value.slice(0, 1) == "-":
        start = 1
    var end = start
    while end < value.len() and isSemanticDigit(value.slice(end, end + 1)):
        end = end + 1
    var firstNonZero = start
    while firstNonZero < end and value.slice(firstNonZero, firstNonZero + 1) == "0":
        firstNonZero = firstNonZero + 1
    val digits = value.slice(firstNonZero, end)
    if digits == "":
        return true
    if digits.len() < maxFiniteInteger.len():
        return true
    if digits.len() > maxFiniteInteger.len():
        return false
    digits <= maxFiniteInteger
