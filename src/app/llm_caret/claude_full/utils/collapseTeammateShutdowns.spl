class TeammateShutdownMessage:
    typeName: text
    uuid: text
    timestamp: text
    attachmentType: text
    taskType: text
    status: text
    count: i64

impl TeammateShutdownMessage:
    static fn taskStatus(uuid: text, timestamp: text, taskType: text, status: text) -> TeammateShutdownMessage:
        TeammateShutdownMessage(typeName: "attachment", uuid: uuid, timestamp: timestamp, attachmentType: "task_status", taskType: taskType, status: status, count: 0)

    static fn user(uuid: text, timestamp: text) -> TeammateShutdownMessage:
        TeammateShutdownMessage(typeName: "user", uuid: uuid, timestamp: timestamp, attachmentType: "", taskType: "", status: "", count: 0)

    static fn batch(uuid: text, timestamp: text, count: i64) -> TeammateShutdownMessage:
        TeammateShutdownMessage(typeName: "attachment", uuid: uuid, timestamp: timestamp, attachmentType: "teammate_shutdown_batch", taskType: "", status: "", count: count)

fn isTeammateShutdownAttachment(msg: TeammateShutdownMessage) -> bool:
    msg.typeName == "attachment" and msg.attachmentType == "task_status" and msg.taskType == "in_process_teammate" and msg.status == "completed"

fn collapseTeammateShutdowns(messages: [TeammateShutdownMessage]) -> [TeammateShutdownMessage]:
    var result: [TeammateShutdownMessage] = []
    var i = 0

    while i < messages.len():
        val msg = messages[i]
        if isTeammateShutdownAttachment(msg):
            var count = 0
            while i < messages.len():
                val next = messages[i]
                if not isTeammateShutdownAttachment(next):
                    break
                count = count + 1
                i = i + 1
            if count == 1:
                result.push(msg)
            else:
                result.push(TeammateShutdownMessage.batch(msg.uuid, msg.timestamp, count))
        else:
            result.push(msg)
            i = i + 1

    result
