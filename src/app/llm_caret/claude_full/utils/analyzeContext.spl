use app.llm_caret.claude_full.components.ContextVisualization.*

const ANALYZE_CONTEXT_SOURCE_LINES = 1382
const MANUAL_COMPACT_BUFFER_TOKENS = 3000

fn trimHeadingMarker(line: text) -> text:
    var i = 0
    while i < line.len() && line.substring(i, i + 1) == "#":
        i = i + 1
    line.substring(i, line.len()).trim()

fn truncateSectionPreview(value: text) -> text:
    if value.len() > 40:
        return value.substring(0, 40) + "..."
    value

fn extractSectionNameRoute(content: text) -> text:
    val lines = content.split("\n")
    var fallback = ""
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line != "" && fallback == "":
            fallback = line
        if line.starts_with("#"):
            val heading = trimHeadingMarker(line)
            if heading != "":
                return heading
        i = i + 1
    truncateSectionPreview(fallback)

fn reserveCategoryNameRoute(isAutoCompact: bool) -> text: if isAutoCompact: "Autocompact buffer" else: "Compact buffer"

fn reserveTokensRoute(contextWindow: i64, autoCompactThreshold: i64, isAutoCompact: bool, skipReservedBuffer: bool) -> i64:
    if skipReservedBuffer:
        return 0
    if isAutoCompact && autoCompactThreshold > 0:
        return contextWindow - autoCompactThreshold
    if not isAutoCompact:
        return MANUAL_COMPACT_BUFFER_TOKENS
    0

fn actualUsageTokensRoute(categories: [ContextCategory]) -> i64:
    var total = 0
    var i = 0
    while i < categories.len():
        val cat = categories[i]
        if not cat.isDeferred:
            total = total + cat.tokens
        i = i + 1
    total

fn freeSpaceTokensRoute(contextWindow: i64, actualUsage: i64, reservedTokens: i64) -> i64:
    val free = contextWindow - actualUsage - reservedTokens
    if free < 0:
        return 0
    free

fn finalTotalTokensRoute(hasApiUsage: bool, apiInputTokens: i64, apiCacheCreationTokens: i64, apiCacheReadTokens: i64, estimatedTotalTokens: i64) -> i64:
    if hasApiUsage:
        return apiInputTokens + apiCacheCreationTokens + apiCacheReadTokens
    estimatedTotalTokens

fn gridWidthRoute(contextWindow: i64, terminalWidth: i64) -> i64:
    val narrow = terminalWidth > 0 && terminalWidth < 80
    if contextWindow >= 1000000:
        if narrow:
            return 5
        return 20
    if narrow:
        return 5
    10

fn gridHeightRoute(contextWindow: i64, terminalWidth: i64) -> i64:
    val narrow = terminalWidth > 0 && terminalWidth < 80
    if contextWindow >= 1000000:
        return 10
    if narrow:
        return 5
    10

fn roundedGridSquaresRoute(tokens: i64, contextWindow: i64, totalSquares: i64, isFreeSpace: bool) -> i64:
    if contextWindow <= 0 || totalSquares <= 0 || tokens <= 0:
        return 0
    val rounded = (tokens * totalSquares + (contextWindow / 2)) / contextWindow
    if isFreeSpace:
        return rounded
    if rounded < 1:
        return 1
    rounded

fn analyzeContextSourceLinesModeled() -> i64:
    ANALYZE_CONTEXT_SOURCE_LINES
