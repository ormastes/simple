class CachedToolSchema:
    sessionId: text
    name: text
    schema: text
    strict: Option<bool>
    eagerInputStreaming: Option<bool>

    static fn new(sessionId: text, name: text, schema: text, strict: Option<bool>, eagerInputStreaming: Option<bool>) -> CachedToolSchema:
        CachedToolSchema(sessionId: sessionId, name: name, schema: schema, strict: strict, eagerInputStreaming: eagerInputStreaming)

var TOOL_SCHEMA_CACHE: [CachedToolSchema] = []

fn putToolSchemaCache(sessionId: text, name: text, schema: text, strict: Option<bool>, eagerInputStreaming: Option<bool>):
    var next: [CachedToolSchema] = []
    var replaced = false
    for entry in TOOL_SCHEMA_CACHE:
        if entry.sessionId == sessionId and entry.name == name:
            next.push(CachedToolSchema.new(sessionId, name, schema, strict, eagerInputStreaming))
            replaced = true
        else:
            next.push(entry)
    if not replaced:
        next.push(CachedToolSchema.new(sessionId, name, schema, strict, eagerInputStreaming))
    TOOL_SCHEMA_CACHE = next

fn getToolSchemaCache(sessionId: text, name: text) -> Option<CachedToolSchema>:
    for entry in TOOL_SCHEMA_CACHE:
        if entry.sessionId == sessionId and entry.name == name:
            return Some(entry)
    nil

fn toolSchemaCacheSize(sessionId: text) -> i64:
    var count = 0
    for entry in TOOL_SCHEMA_CACHE:
        if entry.sessionId == sessionId:
            count = count + 1
    count

fn clearToolSchemaCache(sessionId: text):
    var next: [CachedToolSchema] = []
    for entry in TOOL_SCHEMA_CACHE:
        if entry.sessionId != sessionId:
            next.push(entry)
    TOOL_SCHEMA_CACHE = next
