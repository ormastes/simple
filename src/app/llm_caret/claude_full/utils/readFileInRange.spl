"""
Claude full readFileInRange parity surface.
"""

use common.encoding.text_ops.{strip_utf8_bom}

const FAST_PATH_MAX_SIZE = 10485760

class FileTooLargeError:
    name: text
    sizeInBytes: i64
    maxSizeBytes: i64
    message: text

impl FileTooLargeError:
    static fn new(sizeInBytes: i64, maxSizeBytes: i64) -> FileTooLargeError:
        FileTooLargeError(
            name: "FileTooLargeError",
            sizeInBytes: sizeInBytes,
            maxSizeBytes: maxSizeBytes,
            message: "File content (" + formatBytes(sizeInBytes) + ") exceeds maximum allowed size (" + formatBytes(maxSizeBytes) + "). Use offset and limit parameters to read specific portions of the file, or search for specific content instead of reading the whole file.",
        )

class ReadFileRangeResult:
    content: text
    lineCount: i64
    totalLines: i64
    totalBytes: i64
    readBytes: i64
    mtimeMs: i64
    truncatedByBytes: bool
    error: FileTooLargeError

impl ReadFileRangeResult:
    static fn ok(content: text, lineCount: i64, totalLines: i64, totalBytes: i64, readBytes: i64, truncatedByBytes: bool) -> ReadFileRangeResult:
        ReadFileRangeResult(content: content, lineCount: lineCount, totalLines: totalLines, totalBytes: totalBytes, readBytes: readBytes, mtimeMs: 0, truncatedByBytes: truncatedByBytes, error: FileTooLargeError.new(0, 0))

    static fn tooLarge(sizeInBytes: i64, maxSizeBytes: i64) -> ReadFileRangeResult:
        ReadFileRangeResult(content: "", lineCount: 0, totalLines: 0, totalBytes: sizeInBytes, readBytes: 0, mtimeMs: 0, truncatedByBytes: false, error: FileTooLargeError.new(sizeInBytes, maxSizeBytes))

fn readFileInRangeFastModel(textValue: text, fileSize: i64, offset: i64, maxLines: i64, maxBytes: i64, truncateOnByteLimit: bool) -> ReadFileRangeResult:
    if not truncateOnByteLimit and maxBytes > 0 and fileSize > maxBytes:
        return ReadFileRangeResult.tooLarge(fileSize, maxBytes)
    val normalized = stripBomAndCr(textValue)
    val lines = splitLinesSimple(normalized)
    var selected: [text] = []
    var i = offset
    while i < lines.len() and (maxLines <= 0 or selected.len() < maxLines):
        selected.push(lines[i])
        i = i + 1
    val joined = joinLines(selected)
    if truncateOnByteLimit and maxBytes > 0 and joined.len() > maxBytes:
        return ReadFileRangeResult.ok(joined.slice(0, maxBytes), selected.len(), lines.len(), fileSize, maxBytes, true)
    ReadFileRangeResult.ok(joined, selected.len(), lines.len(), fileSize, joined.len(), false)

fn chooseReadPath(isRegularFile: bool, fileSize: i64) -> text:
    if isRegularFile and fileSize < FAST_PATH_MAX_SIZE:
        return "fast"
    "streaming"

fn stripBomAndCr(value: text) -> text:
    var out = strip_utf8_bom(value)
    out.replace("\r", "")

fn splitLinesSimple(value: text) -> [text]:
    value.split("\n")

fn joinLines(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + "\n"
        out = out + values[i]
        i = i + 1
    out

fn formatBytes(value: i64) -> text:
    value.to_text() + " B"

fn readFileInRangeSourceLinesModeled() -> i64:
    383
