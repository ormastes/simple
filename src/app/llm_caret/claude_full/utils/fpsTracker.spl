"""
Claude full FPS tracker parity surface.
"""

class FpsMetrics:
    averageFpsHundredths: i64
    low1PctFpsHundredths: i64

impl FpsMetrics:
    static fn new(averageFpsHundredths: i64, low1PctFpsHundredths: i64) -> FpsMetrics:
        FpsMetrics(averageFpsHundredths: averageFpsHundredths, low1PctFpsHundredths: low1PctFpsHundredths)

class FpsTracker:
    frameDurations: [i64]
    firstRenderTime: i64
    lastRenderTime: i64

impl FpsTracker:
    static fn new() -> FpsTracker:
        FpsTracker(frameDurations: [], firstRenderTime: 0, lastRenderTime: 0)

    fn record(durationMs: i64, nowMs: i64) -> FpsTracker:
        var durations = copyI64FpsTracker(self.frameDurations)
        durations.push(durationMs)
        var first = self.firstRenderTime
        if first == 0:
            first = nowMs
        FpsTracker(frameDurations: durations, firstRenderTime: first, lastRenderTime: nowMs)

    fn getMetrics() -> FpsMetrics:
        if self.frameDurations.len() == 0 or self.firstRenderTime == 0 or self.lastRenderTime <= self.firstRenderTime:
            return FpsMetrics.new(0, 0)
        val totalFrames = self.frameDurations.len()
        val totalTime = self.lastRenderTime - self.firstRenderTime
        val avgHundredths = (totalFrames * 100000) / totalTime
        val worst = maxFrameDurationFpsTracker(self.frameDurations)
        var lowHundredths = 0
        if worst > 0:
            lowHundredths = 100000 / worst
        FpsMetrics.new(avgHundredths, lowHundredths)

fn copyI64FpsTracker(values: [i64]) -> [i64]:
    var out: [i64] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn maxFrameDurationFpsTracker(values: [i64]) -> i64:
    var max = 0
    var i = 0
    while i < values.len():
        if values[i] > max:
            max = values[i]
        i = i + 1
    max

fn fpsTrackerSourceLinesModeled() -> i64: 47
