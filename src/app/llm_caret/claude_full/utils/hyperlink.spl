const OSC8_START = "\u001B]8;;"
const OSC8_END = "\u0007"
const ANSI_BLUE = "\u001B[34m"
const ANSI_BLUE_END = "\u001B[39m"

fn createHyperlink(url: text, content: Option<text>, supportsHyperlinks: bool) -> text:
    if not supportsHyperlinks:
        return url
    val displayText = content ?? url
    OSC8_START + url + OSC8_END + chalkBlueHyperlinkText(displayText) + OSC8_START + OSC8_END

fn chalkBlueHyperlinkText(value: text) -> text:
    if value == "":
        return ""
    var styled = value.replace(ANSI_BLUE_END, ANSI_BLUE)
    styled = styled.replace("\n", ANSI_BLUE_END + "\n" + ANSI_BLUE)
    ANSI_BLUE + styled + ANSI_BLUE_END
