const AGENT_DESCRIPTIONS_THRESHOLD = 15000

class StatusNoticeAgentDefinition:
    agentType: text
    whenToUse: text
    source: text

class AgentDefinitionsResult:
    activeAgents: [StatusNoticeAgentDefinition]

fn getAgentDescriptionsTotalTokens(agentDefinitions: Option<AgentDefinitionsResult>) -> i64:
    if val Some(definitions) = agentDefinitions:
        var total = 0
        for agent in definitions.activeAgents:
            if agent.source != "built-in":
                total = total + roughTokenCountEstimation(agent.agentType + ": " + agent.whenToUse)
        return total
    0

fn roughTokenCountEstimation(content: text) -> i64:
    (jsCodeUnitLength(content) + 2) / 4

fn jsCodeUnitLength(content: text) -> i64:
    var total = 0
    for ch in content.chars():
        if ch.len() == 4:
            total = total + 2
        else:
            total = total + 1
    total
