"""
Claude full file state cache parity surface.
"""

class FileState:
    content: text
    timestamp: i64
    offset: i64
    limit: i64
    isPartialView: bool

impl FileState:
    static fn new(content: text, timestamp: i64, offset: i64, limit: i64, isPartialView: bool) -> FileState:
        FileState(content: content, timestamp: timestamp, offset: offset, limit: limit, isPartialView: isPartialView)

class FileStateCache:
    keysList: [text]
    values: [FileState]
    maxEntries: i64
    maxSizeBytes: i64

impl FileStateCache:
    static fn new(maxEntries: i64, maxSizeBytes: i64) -> FileStateCache:
        FileStateCache(keysList: [], values: [], maxEntries: maxEntries, maxSizeBytes: maxSizeBytes)

    fn get(key: text) -> FileState:
        val idx = findFileStateCacheKey(self.keysList, normalizeFileStatePath(key))
        if idx < 0:
            return FileState.new("", 0, 0, 0, false)
        self.values[idx]

    fn set(key: text, value: FileState) -> FileStateCache:
        var keys = copyTextFileStateCache(self.keysList)
        var values = copyFileStateCacheValues(self.values)
        val normalized = normalizeFileStatePath(key)
        val idx = findFileStateCacheKey(keys, normalized)
        if idx >= 0:
            values[idx] = value
        else:
            keys.push(normalized)
            values.push(value)
        while keys.len() > self.maxEntries:
            keys = dropFirstTextFileStateCache(keys)
            values = dropFirstFileStateCacheValues(values)
        FileStateCache(keysList: keys, values: values, maxEntries: self.maxEntries, maxSizeBytes: self.maxSizeBytes)

    fn has(key: text) -> bool:
        findFileStateCacheKey(self.keysList, normalizeFileStatePath(key)) >= 0

    fn delete(key: text) -> FileStateCache:
        var keys: [text] = []
        var values: [FileState] = []
        val normalized = normalizeFileStatePath(key)
        var i = 0
        while i < self.keysList.len():
            if self.keysList[i] != normalized:
                keys.push(self.keysList[i])
                values.push(self.values[i])
            i = i + 1
        FileStateCache(keysList: keys, values: values, maxEntries: self.maxEntries, maxSizeBytes: self.maxSizeBytes)

    fn clear() -> FileStateCache:
        FileStateCache.new(self.maxEntries, self.maxSizeBytes)

    fn size() -> i64:
        self.keysList.len()

    fn max() -> i64:
        self.maxEntries

    fn maxSize() -> i64:
        self.maxSizeBytes

    fn calculatedSize() -> i64:
        var total = 0
        var i = 0
        while i < self.values.len():
            total = total + maxI64FileStateCache(1, self.values[i].content.len())
            i = i + 1
        total

    fn keys() -> [text]:
        copyTextFileStateCache(self.keysList)

    fn entries() -> [text]:
        copyTextFileStateCache(self.keysList)

fn createFileStateCacheWithSizeLimit(maxEntries: i64, maxSizeBytes: i64) -> FileStateCache:
    FileStateCache.new(maxEntries, maxSizeBytes)

fn cacheKeys(cache: FileStateCache) -> [text]:
    cache.keys()

fn cloneFileStateCache(cache: FileStateCache) -> FileStateCache:
    FileStateCache(keysList: copyTextFileStateCache(cache.keysList), values: copyFileStateCacheValues(cache.values), maxEntries: cache.maxEntries, maxSizeBytes: cache.maxSizeBytes)

fn mergeFileStateCaches(first: FileStateCache, second: FileStateCache) -> FileStateCache:
    var merged = cloneFileStateCache(first)
    var i = 0
    while i < second.keysList.len():
        val existing = merged.get(second.keysList[i])
        if existing.timestamp == 0 or second.values[i].timestamp > existing.timestamp:
            merged = merged.set(second.keysList[i], second.values[i])
        i = i + 1
    merged

fn normalizeFileStatePath(path: text) -> text:
    var out = path.replace("\\", "/")
    while out.contains("//"):
        out = out.replace("//", "/")
    out.replace("/./", "/")

fn findFileStateCacheKey(keys: [text], key: text) -> i64:
    var i = 0
    while i < keys.len():
        if keys[i] == key:
            return i
        i = i + 1
    -1

fn copyTextFileStateCache(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyFileStateCacheValues(values: [FileState]) -> [FileState]:
    var out: [FileState] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn dropFirstTextFileStateCache(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn dropFirstFileStateCacheValues(values: [FileState]) -> [FileState]:
    var out: [FileState] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn maxI64FileStateCache(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn readFileStateCacheSize() -> i64: 100

fn defaultMaxCacheSizeBytes() -> i64:
    25 * 1024 * 1024

fn fileStateCacheSourceLinesModeled() -> i64: 142
