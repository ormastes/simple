fn hasNodeOption(nodeOptions: text, flag: text) -> bool:
    val noTabs = nodeOptions.replace("\t", " ")
    val noNewlines = noTabs.replace("\n", " ")
    val normalized = noNewlines.replace("\r", " ")
    for option in normalized.split(" "):
        if option == flag:
            return true
    false

fn isEnvTruthy(envVar: Option<text>) -> bool:
    if val value = envVar:
        val normalized = value.trim().lower()
        return normalized == "1" or normalized == "true" or normalized == "yes" or normalized == "on"
    false

fn isEnvDefinedFalsy(envVar: Option<text>) -> bool:
    if val value = envVar:
        val normalized = value.trim().lower()
        if normalized == "":
            return false
        return normalized == "0" or normalized == "false" or normalized == "no" or normalized == "off"
    false
