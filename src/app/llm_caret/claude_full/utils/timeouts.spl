class EnvLike:
    defaultTimeoutMs: text
    maxTimeoutMs: text

impl EnvLike:
    static fn new(defaultTimeoutMs: text, maxTimeoutMs: text) -> EnvLike:
        EnvLike(defaultTimeoutMs: defaultTimeoutMs, maxTimeoutMs: maxTimeoutMs)

fn defaultBashTimeoutMs() -> i64:
    120000

fn maxBashTimeoutMs() -> i64:
    600000

fn getDefaultBashTimeoutMs(env: EnvLike) -> i64:
    parsePositiveTimeoutMs(env.defaultTimeoutMs) ?? defaultBashTimeoutMs()

fn getMaxBashTimeoutMs(env: EnvLike) -> i64:
    val defaultValue = getDefaultBashTimeoutMs(env)
    maxI64(parsePositiveTimeoutMs(env.maxTimeoutMs) ?? maxBashTimeoutMs(), defaultValue)

fn parsePositiveTimeoutMs(value: text) -> Option<i64>:
    val trimmed = value.trim()
    if trimmed == "":
        return nil
    var digits = ""
    var i = 0
    var sign = 1
    if trimmed.slice(0, 1) == "-":
        sign = -1
        i = 1
    else if trimmed.slice(0, 1) == "+":
        i = 1
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if ch < "0" or ch > "9":
            if digits == "":
                return nil
            if val parsedDigits = digits.to_i64():
                val parsed = parsedDigits * sign
                if parsed > 0:
                    return parsed
            return nil
        digits = digits + ch
        i = i + 1
    if val parsedDigits = digits.to_i64():
        val parsed = parsedDigits * sign
        if parsed > 0:
            return parsed
    nil

fn maxI64(a: i64, b: i64) -> i64: if a > b: a else: b
