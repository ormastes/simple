class ParsedAgentId:
    valid: bool
    agentName: text
    teamName: text

class ParsedRequestId:
    valid: bool
    requestType: text
    timestamp: i64
    agentId: text

fn formatAgentId(agentName: text, teamName: text) -> text:
    agentName + "@" + teamName

fn parseAgentId(agentId: text) -> ParsedAgentId:
    val at = agentId.index_of("@")
    if at == -1:
        return ParsedAgentId(valid: false, agentName: "", teamName: "")
    ParsedAgentId(valid: true, agentName: agentId.slice(0, at), teamName: agentId.slice(at + 1, agentId.len()))

fn generateRequestId(requestType: text, timestamp: i64, agentId: text) -> text:
    requestType + "-" + timestamp.to_text() + "@" + agentId

fn parseRequestId(requestId: text) -> ParsedRequestId:
    val at = requestId.index_of("@")
    if at == -1:
        return invalidRequestId()
    val prefix = requestId.slice(0, at)
    val agentId = requestId.slice(at + 1, requestId.len())
    val dash = lastDashIndex(prefix)
    if dash == -1:
        return invalidRequestId()
    val timestampText = prefix.slice(dash + 1, prefix.len())
    val timestamp = parseLeadingI64(timestampText) ?? -1
    if timestamp >= 0:
        return ParsedRequestId(valid: true, requestType: prefix.slice(0, dash), timestamp: timestamp, agentId: agentId)
    invalidRequestId()

fn invalidRequestId() -> ParsedRequestId:
    ParsedRequestId(valid: false, requestType: "", timestamp: 0, agentId: "")

fn lastDashIndex(value: text) -> i64:
    var last = -1
    var i = 0
    while i < value.len():
        if value.slice(i, i + 1) == "-":
            last = i
        i = i + 1
    last

fn parseLeadingI64(value: text) -> Option<i64>:
    var digits = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch < "0" or ch > "9":
            if digits == "":
                return nil
            return digits.to_i64()
        digits = digits + ch
        i = i + 1
    if digits == "":
        return nil
    digits.to_i64()
