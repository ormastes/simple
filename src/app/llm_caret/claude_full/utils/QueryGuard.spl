"""
Claude full QueryGuard parity surface.
"""

class QueryGuard:
    status: text
    generationValue: i64
    notifications: i64

impl QueryGuard:
    static fn new() -> QueryGuard:
        QueryGuard(status: "idle", generationValue: 0, notifications: 0)

    fn reserve() -> QueryGuardReserveResult:
        if self.status != "idle":
            return QueryGuardReserveResult.new(false, self)
        QueryGuardReserveResult.new(true, QueryGuard(status: "dispatching", generationValue: self.generationValue, notifications: self.notifications + 1))

    fn cancelReservation() -> QueryGuard:
        if self.status != "dispatching":
            return self
        QueryGuard(status: "idle", generationValue: self.generationValue, notifications: self.notifications + 1)

    fn tryStart() -> QueryGuardStartResult:
        if self.status == "running":
            return QueryGuardStartResult.new(false, self.generationValue, self)
        val nextGeneration = self.generationValue + 1
        QueryGuardStartResult.new(true, nextGeneration, QueryGuard(status: "running", generationValue: nextGeneration, notifications: self.notifications + 1))

    fn end(generation: i64) -> QueryGuardEndResult:
        if self.generationValue != generation:
            return QueryGuardEndResult.new(false, self)
        if self.status != "running":
            return QueryGuardEndResult.new(false, self)
        QueryGuardEndResult.new(true, QueryGuard(status: "idle", generationValue: self.generationValue, notifications: self.notifications + 1))

    fn forceEnd() -> QueryGuard:
        if self.status == "idle":
            return self
        QueryGuard(status: "idle", generationValue: self.generationValue + 1, notifications: self.notifications + 1)

    fn isActive() -> bool:
        self.status != "idle"

    fn generation() -> i64:
        self.generationValue

    fn getSnapshot() -> bool:
        self.isActive()

class QueryGuardReserveResult:
    ok: bool
    guard: QueryGuard

impl QueryGuardReserveResult:
    static fn new(ok: bool, guard: QueryGuard) -> QueryGuardReserveResult:
        QueryGuardReserveResult(ok: ok, guard: guard)

class QueryGuardStartResult:
    ok: bool
    generation: i64
    guard: QueryGuard

impl QueryGuardStartResult:
    static fn new(ok: bool, generation: i64, guard: QueryGuard) -> QueryGuardStartResult:
        QueryGuardStartResult(ok: ok, generation: generation, guard: guard)

class QueryGuardEndResult:
    ok: bool
    guard: QueryGuard

impl QueryGuardEndResult:
    static fn new(ok: bool, guard: QueryGuard) -> QueryGuardEndResult:
        QueryGuardEndResult(ok: ok, guard: guard)

fn queryGuardSourceLinesModeled() -> i64:
    121
