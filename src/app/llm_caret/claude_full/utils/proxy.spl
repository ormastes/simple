class ProxyEnv:
    httpsProxyLower: text
    httpsProxyUpper: text
    httpProxyLower: text
    httpProxyUpper: text
    noProxyLower: text
    noProxyUpper: text

impl ProxyEnv:
    static fn new(httpsProxyLower: text, httpsProxyUpper: text, httpProxyLower: text, httpProxyUpper: text, noProxyLower: text, noProxyUpper: text) -> ProxyEnv:
        ProxyEnv(httpsProxyLower: httpsProxyLower, httpsProxyUpper: httpsProxyUpper, httpProxyLower: httpProxyLower, httpProxyUpper: httpProxyUpper, noProxyLower: noProxyLower, noProxyUpper: noProxyUpper)

fn getProxyUrl(env: ProxyEnv) -> Option<text>:
    if env.httpsProxyLower != "":
        return Some(env.httpsProxyLower)
    if env.httpsProxyUpper != "":
        return Some(env.httpsProxyUpper)
    if env.httpProxyLower != "":
        return Some(env.httpProxyLower)
    if env.httpProxyUpper != "":
        return Some(env.httpProxyUpper)
    nil

fn getNoProxy(env: ProxyEnv) -> Option<text>:
    if env.noProxyLower != "":
        return Some(env.noProxyLower)
    if env.noProxyUpper != "":
        return Some(env.noProxyUpper)
    nil
