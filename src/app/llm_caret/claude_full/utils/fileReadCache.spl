"""
Claude full file read cache parity surface.
"""

class CachedFileData:
    content: text
    encoding: text
    mtime: i64

impl CachedFileData:
    static fn new(content: text, encoding: text, mtime: i64) -> CachedFileData:
        CachedFileData(content: content, encoding: encoding, mtime: mtime)

class FileReadResult:
    content: text
    encoding: text

impl FileReadResult:
    static fn new(content: text, encoding: text) -> FileReadResult:
        FileReadResult(content: content, encoding: encoding)

class FileReadCacheStats:
    size: i64
    entries: [text]

impl FileReadCacheStats:
    static fn new(size: i64, entries: [text]) -> FileReadCacheStats:
        FileReadCacheStats(size: size, entries: entries)

class FileReadCache:
    keys: [text]
    values: [CachedFileData]
    maxCacheSize: i64

impl FileReadCache:
    static fn new() -> FileReadCache:
        FileReadCache(keys: [], values: [], maxCacheSize: 1000)

    fn readFile(filePath: text, content: text, encoding: text, mtime: i64) -> FileReadResult:
        val idx = findFileReadCacheKey(self.keys, filePath)
        if idx >= 0 and self.values[idx].mtime == mtime:
            return FileReadResult.new(self.values[idx].content, self.values[idx].encoding)
        FileReadResult.new(normalizeNewlinesFileReadCache(content), encoding)

    fn put(filePath: text, content: text, encoding: text, mtime: i64) -> FileReadCache:
        var keys = copyTextFileReadCache(self.keys)
        var values = copyCachedFileDataFileReadCache(self.values)
        val idx = findFileReadCacheKey(keys, filePath)
        val data = CachedFileData.new(normalizeNewlinesFileReadCache(content), encoding, mtime)
        if idx >= 0:
            values[idx] = data
        else:
            keys.push(filePath)
            values.push(data)
        while keys.len() > self.maxCacheSize:
            keys = dropFirstTextFileReadCache(keys)
            values = dropFirstCachedFileDataFileReadCache(values)
        FileReadCache(keys: keys, values: values, maxCacheSize: self.maxCacheSize)

    fn clear() -> FileReadCache:
        FileReadCache.new()

    fn invalidate(filePath: text) -> FileReadCache:
        var keys: [text] = []
        var values: [CachedFileData] = []
        var i = 0
        while i < self.keys.len():
            if self.keys[i] != filePath:
                keys.push(self.keys[i])
                values.push(self.values[i])
            i = i + 1
        FileReadCache(keys: keys, values: values, maxCacheSize: self.maxCacheSize)

    fn getStats() -> FileReadCacheStats:
        FileReadCacheStats.new(self.keys.len(), copyTextFileReadCache(self.keys))

fn normalizeNewlinesFileReadCache(content: text) -> text:
    content.replace("\r\n", "\n")

fn findFileReadCacheKey(keys: [text], key: text) -> i64:
    var i = 0
    while i < keys.len():
        if keys[i] == key:
            return i
        i = i + 1
    -1

fn copyTextFileReadCache(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyCachedFileDataFileReadCache(values: [CachedFileData]) -> [CachedFileData]:
    var out: [CachedFileData] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn dropFirstTextFileReadCache(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn dropFirstCachedFileDataFileReadCache(values: [CachedFileData]) -> [CachedFileData]:
    var out: [CachedFileData] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn fileReadCacheSourceLinesModeled() -> i64:
    96
