"""
Claude full string utility parity surface.
"""

const MAX_STRING_LENGTH = 33554432

class EndTruncatingAccumulator:
    content: text
    truncatedValue: bool
    totalBytesReceived: i64
    maxSize: i64

impl EndTruncatingAccumulator:
    static fn new(maxSize: i64) -> EndTruncatingAccumulator:
        EndTruncatingAccumulator(content: "", truncatedValue: false, totalBytesReceived: 0, maxSize: maxSize)

    fn append(data: text) -> EndTruncatingAccumulator:
        var next = self.copy()
        next.totalBytesReceived = next.totalBytesReceived + data.len()
        if next.truncatedValue and next.content.len() >= next.maxSize:
            return next
        if next.content.len() + data.len() > next.maxSize:
            val remaining = next.maxSize - next.content.len()
            if remaining > 0:
                next.content = next.content + data.slice(0, remaining)
            next.truncatedValue = true
        else:
            next.content = next.content + data
        next

    fn toString() -> text:
        if not self.truncatedValue:
            return self.content
        val truncatedBytes = self.totalBytesReceived - self.maxSize
        self.content + "\n... [output truncated - " + ((truncatedBytes + 512) / 1024).to_text() + "KB removed]"

    fn clear() -> EndTruncatingAccumulator:
        EndTruncatingAccumulator.new(self.maxSize)

    fn length() -> i64:
        self.content.len()

    fn truncated() -> bool:
        self.truncatedValue

    fn totalBytes() -> i64:
        self.totalBytesReceived

    fn copy() -> EndTruncatingAccumulator:
        EndTruncatingAccumulator(content: self.content, truncatedValue: self.truncatedValue, totalBytesReceived: self.totalBytesReceived, maxSize: self.maxSize)

fn escapeRegExp(str: text) -> text:
    var out = str
    out = out.replace("\\", "\\\\")
    out = out.replace(".", "\\.")
    out = out.replace("*", "\\*")
    out = out.replace("+", "\\+")
    out = out.replace("?", "\\?")
    out = out.replace("^", "\\^")
    out = out.replace("$", "\\$")
    out = out.replace("{", "\\{")
    out = out.replace("}", "\\}")
    out = out.replace("(", "\\(")
    out = out.replace(")", "\\)")
    out = out.replace("|", "\\|")
    out = out.replace("[", "\\[")
    out = out.replace("]", "\\]")
    out

fn capitalize(str: text) -> text:
    if str.len() == 0:
        return str
    str.slice(0, 1).to_upper() + str.slice(1, str.len())

fn plural(n: i64, word: text, pluralWord: text) -> text:
    if n == 1:
        return word
    if pluralWord != "":
        return pluralWord
    word + "s"

fn firstLineOf(s: text) -> text:
    val lines = s.split("\n")
    if lines.len() == 0:
        return ""
    lines[0]

fn countCharInString(str: text, char: text, start: i64) -> i64:
    var count = 0
    var i = start
    while i < str.len():
        if str.slice(i, i + 1) == char:
            count = count + 1
        i = i + 1
    count

fn normalizeFullWidthDigits(input: text) -> text:
    var out = input
    out = out.replace("０", "0")
    out = out.replace("１", "1")
    out = out.replace("２", "2")
    out = out.replace("３", "3")
    out = out.replace("４", "4")
    out = out.replace("５", "5")
    out = out.replace("６", "6")
    out = out.replace("７", "7")
    out = out.replace("８", "8")
    out = out.replace("９", "9")
    out

fn normalizeFullWidthSpace(input: text) -> text:
    input.replace("　", " ")

fn safeJoinLines(lines: [text], delimiter: text, maxSize: i64) -> text:
    val truncationMarker = "...[truncated]"
    var result = ""
    var i = 0
    while i < lines.len():
        var delimiterToAdd = ""
        if result != "":
            delimiterToAdd = delimiter
        val fullAddition = delimiterToAdd + lines[i]
        if result.len() + fullAddition.len() <= maxSize:
            result = result + fullAddition
        else:
            val remainingSpace = maxSize - result.len() - delimiterToAdd.len() - truncationMarker.len()
            if remainingSpace > 0:
                result = result + delimiterToAdd + lines[i].slice(0, remainingSpace) + truncationMarker
            else:
                result = result + truncationMarker
            return result
        i = i + 1
    result

fn truncateToLines(textValue: text, maxLines: i64) -> text:
    val lines = textValue.split("\n")
    if lines.len() <= maxLines:
        return textValue
    var selected: [text] = []
    var i = 0
    while i < maxLines and i < lines.len():
        selected.push(lines[i])
        i = i + 1
    joinStringLines(selected) + "..."

fn joinStringLines(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + "\n"
        out = out + values[i]
        i = i + 1
    out

fn stringUtilsSourceLinesModeled() -> i64:
    235
