"""
Claude full AWS/cloud auth status manager parity surface.
"""

class AwsAuthStatus:
    isAuthenticating: bool
    output: [text]
    error: text

impl AwsAuthStatus:
    static fn idle() -> AwsAuthStatus:
        AwsAuthStatus(isAuthenticating: false, output: [], error: "")

class AwsAuthStatusManager:
    status: AwsAuthStatus
    changeCount: i64

impl AwsAuthStatusManager:
    static fn new() -> AwsAuthStatusManager:
        AwsAuthStatusManager(status: AwsAuthStatus.idle(), changeCount: 0)

    fn getStatus() -> AwsAuthStatus:
        AwsAuthStatus(isAuthenticating: self.status.isAuthenticating, output: copyTextAwsAuthStatus(self.status.output), error: self.status.error)

    fn startAuthentication() -> AwsAuthStatusManager:
        AwsAuthStatusManager(status: AwsAuthStatus(isAuthenticating: true, output: [], error: ""), changeCount: self.changeCount + 1)

    fn addOutput(line: text) -> AwsAuthStatusManager:
        var output = copyTextAwsAuthStatus(self.status.output)
        output.push(line)
        AwsAuthStatusManager(status: AwsAuthStatus(isAuthenticating: self.status.isAuthenticating, output: output, error: self.status.error), changeCount: self.changeCount + 1)

    fn setError(error: text) -> AwsAuthStatusManager:
        AwsAuthStatusManager(status: AwsAuthStatus(isAuthenticating: self.status.isAuthenticating, output: copyTextAwsAuthStatus(self.status.output), error: error), changeCount: self.changeCount + 1)

    fn endAuthentication(success: bool) -> AwsAuthStatusManager:
        if success:
            return AwsAuthStatusManager(status: AwsAuthStatus.idle(), changeCount: self.changeCount + 1)
        AwsAuthStatusManager(status: AwsAuthStatus(isAuthenticating: false, output: copyTextAwsAuthStatus(self.status.output), error: self.status.error), changeCount: self.changeCount + 1)

    static fn reset() -> AwsAuthStatusManager:
        AwsAuthStatusManager.new()

fn copyTextAwsAuthStatus(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn awsAuthStatusManagerSourceLinesModeled() -> i64:
    81
