const PLUGIN_SCHEMAS_SOURCE_LINES = 1681
const OFFICIAL_MARKETPLACE_ORG = "anthropics"

fn isReservedMarketplaceNameRoute(name: text) -> bool:
    name == "claude-code-marketplace" || name == "claude-code" || name == "official"

fn marketplaceAutoUpdateDefaultRoute(name: text, explicitSet: bool, explicitValue: bool) -> bool:
    if explicitSet:
        return explicitValue
    isReservedMarketplaceNameRoute(name)

fn isBlockedMarketplaceNameRoute(name: text) -> bool:
    if name == "claude-code-marketplace":
        return false
    name == "claude-official" || name == "official-claude" || name == "anthropic-plugins"

fn hasOnlyAsciiMarketplaceNameRoute(name: text) -> bool:
    true

fn validateReservedMarketplaceSourceRoute(name: text, sourceKind: text, source: text) -> text:
    if !isReservedMarketplaceNameRoute(name):
        return "source validation skipped"
    if sourceKind == "github" && source.starts_with(OFFICIAL_MARKETPLACE_ORG + "/"):
        return "source valid"
    if sourceKind == "git" && (source.starts_with("https://github.com/" + OFFICIAL_MARKETPLACE_ORG + "/") || source.starts_with("git@github.com:" + OFFICIAL_MARKETPLACE_ORG + "/")):
        return "source valid"
    "reserved marketplace source must be anthropics"

fn validateMarketplaceNameRoute(name: text) -> text:
    if name == "." || name == "inline" || name == "builtin":
        return "invalid marketplace name"
    if name.contains(" ") || name.contains("/") || name.contains(".."):
        return "invalid marketplace name"
    if !hasOnlyAsciiMarketplaceNameRoute(name):
        return "invalid marketplace name"
    if isBlockedMarketplaceNameRoute(name):
        return "blocked marketplace name"
    "valid marketplace name"

fn validateMarketplaceNameWithAsciiRoute(name: text, isAscii: bool) -> text:
    if !isAscii:
        return "invalid marketplace name"
    validateMarketplaceNameRoute(name)

fn pluginSchemasSourceLinesModeled() -> i64:
    PLUGIN_SCHEMAS_SOURCE_LINES
