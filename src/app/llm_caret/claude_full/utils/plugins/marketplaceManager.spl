const MARKETPLACE_MANAGER_SOURCE_LINES = 2643

fn getMarketplacesCacheDirRoute(root: text) -> text:
    root + "/plugins/marketplaces"

fn getKnownMarketplacesFileRoute(root: text) -> text:
    root + "/plugins/known_marketplaces.json"

fn loadKnownMarketplacesConfigSafeRoute(fileState: text) -> text:
    if fileState == "missing" || fileState == "malformed":
        return "empty config"
    if fileState == "valid":
        return "known marketplaces config"
    "empty config"

fn loadKnownMarketplacesConfigRoute(fileState: text) -> text:
    if fileState == "valid":
        return "known marketplaces config"
    if fileState == "invalid_shape":
        return "schema error"
    "empty config"

fn clearMarketplacesCacheRoute(wasMemoized: bool) -> text:
    if wasMemoized:
        return "marketplace cache reset"
    "marketplace cache already clear"

fn getDeclaredMarketplacesRoute(officialEnabled: bool, hasConfigured: bool) -> text:
    if officialEnabled && hasConfigured:
        return "declared official and configured"
    if officialEnabled:
        return "declared official marketplace"
    if hasConfigured:
        return "declared configured marketplaces"
    "no declared marketplaces"

fn getMarketplaceDeclaringSourceRoute(hasLocal: bool, hasProject: bool, hasUser: bool) -> text:
    if hasLocal:
        return "local"
    if hasProject:
        return "project"
    if hasUser:
        return "user"
    "none"

fn saveMarketplaceToSettingsRoute(source: text, preserveExisting: bool) -> text:
    if preserveExisting:
        return "save marketplace to " + source + " preserving entries"
    "save marketplace to " + source

fn getMarketplaceCacheOnlyRoute(cacheState: text) -> text:
    if cacheState == "valid":
        return "marketplace cache object"
    if cacheState == "absent":
        return "marketplace cache null"
    "marketplace cache invalid"

fn getPluginByIdRoute(hasMarket: bool, pluginFound: bool) -> text:
    if hasMarket && pluginFound:
        return "plugin from marketplace cache"
    "plugin null"

fn marketplaceManagerSourceLinesModeled() -> i64:
    MARKETPLACE_MANAGER_SOURCE_LINES
