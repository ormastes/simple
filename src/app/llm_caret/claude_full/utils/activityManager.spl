class ActivityRecord:
    seconds: f64
    typeName: text

impl ActivityRecord:
    static fn new(seconds: f64, typeName: text) -> ActivityRecord:
        ActivityRecord(seconds: seconds, typeName: typeName)

class ActiveTimeCounter:
    records: [ActivityRecord]

impl ActiveTimeCounter:
    static fn new() -> ActiveTimeCounter:
        ActiveTimeCounter(records: [])

    me add(seconds: f64, labels: text) -> ():
        me.records = me.records + [ActivityRecord.new(seconds, labels)]

    me count() -> i64:
        me.records.len()

    me totalFor(typeName: text) -> f64:
        var total = 0.0
        for record in me.records:
            if record.typeName == typeName:
                total = total + record.seconds
        total

    me lastType() -> text:
        if me.records.len() == 0:
            return ""
        me.records[me.records.len() - 1].typeName

    me lastSeconds() -> f64:
        if me.records.len() == 0:
            return 0.0
        me.records[me.records.len() - 1].seconds

class ActivityStates:
    isUserActive: bool
    isCLIActive: bool
    activeOperationCount: i64

impl ActivityStates:
    static fn new(isUserActive: bool, isCLIActive: bool, activeOperationCount: i64) -> ActivityStates:
        ActivityStates(isUserActive: isUserActive, isCLIActive: isCLIActive, activeOperationCount: activeOperationCount)

class ActivityManager:
    activeOperations: [text]
    lastUserActivityTime: i64
    lastCLIRecordedTime: i64
    isCLIActive: bool
    userActivityTimeoutMs: i64
    nowMs: i64
    counter: ActiveTimeCounter

impl ActivityManager:
    static fn new(nowMs: i64) -> ActivityManager:
        ActivityManager(activeOperations: [], lastUserActivityTime: 0, lastCLIRecordedTime: nowMs, isCLIActive: false, userActivityTimeoutMs: 5000, nowMs: nowMs, counter: ActiveTimeCounter.new())

    static fn createInstance(nowMs: i64) -> ActivityManager:
        _activity_manager_singleton = ActivityManager.new(nowMs)
        _activity_manager_singleton

    static fn getInstance() -> ActivityManager:
        if not _activity_manager_singleton_ready:
            _activity_manager_singleton = ActivityManager.new(0)
            _activity_manager_singleton_ready = true
        _activity_manager_singleton

    static fn resetInstance() -> ():
        _activity_manager_singleton = ActivityManager.new(0)
        _activity_manager_singleton_ready = false

    me setNow(nowMs: i64) -> ():
        me.nowMs = nowMs

    me getNow() -> i64:
        me.nowMs

    me getActiveTimeCounter() -> ActiveTimeCounter:
        me.counter

    me recordUserActivity() -> ():
        if not me.isCLIActive and me.lastUserActivityTime != 0:
            val timeSinceLastActivity = (me.nowMs - me.lastUserActivityTime).to_f64() / 1000.0
            if timeSinceLastActivity > 0.0:
                val timeoutSeconds = me.userActivityTimeoutMs.to_f64() / 1000.0
                if timeSinceLastActivity < timeoutSeconds:
                    me.counter.add(timeSinceLastActivity, "user")
        me.lastUserActivityTime = me.nowMs

    me startCLIActivity(operationId: text) -> ():
        if me.hasOperation(operationId):
            me.endCLIActivity(operationId)
        val wasEmpty = me.activeOperations.len() == 0
        me.activeOperations = me.activeOperations + [operationId]
        if wasEmpty:
            me.isCLIActive = true
            me.lastCLIRecordedTime = me.nowMs

    me endCLIActivity(operationId: text) -> ():
        me.removeOperation(operationId)
        if me.activeOperations.len() == 0:
            val timeSinceLastRecord = (me.nowMs - me.lastCLIRecordedTime).to_f64() / 1000.0
            if timeSinceLastRecord > 0.0:
                me.counter.add(timeSinceLastRecord, "cli")
            me.lastCLIRecordedTime = me.nowMs
            me.isCLIActive = false

    me trackOperation(operationId: text, elapsedMs: i64) -> text:
        me.startCLIActivity(operationId)
        me.setNow(me.nowMs + elapsedMs)
        me.endCLIActivity(operationId)
        "resolved"

    me getActivityStates() -> ActivityStates:
        val timeSinceUserActivity = (me.nowMs - me.lastUserActivityTime).to_f64() / 1000.0
        val isUserActive = timeSinceUserActivity < (me.userActivityTimeoutMs.to_f64() / 1000.0)
        ActivityStates.new(isUserActive, me.isCLIActive, me.activeOperations.len())

    me activeOperationCount() -> i64:
        me.activeOperations.len()

    me hasOperation(operationId: text) -> bool:
        for activeOperation in me.activeOperations:
            if activeOperation == operationId:
                return true
        false

    me removeOperation(operationId: text) -> ():
        var remaining: [text] = []
        for activeOperation in me.activeOperations:
            if activeOperation != operationId:
                remaining = remaining + [activeOperation]
        me.activeOperations = remaining

var _activity_manager_singleton_ready: bool = false
var _activity_manager_singleton: ActivityManager = ActivityManager.new(0)

fn activityManagerNew(nowMs: i64) -> ActivityManager:
    ActivityManager.new(nowMs)

fn activityManagerGetInstance() -> ActivityManager:
    ActivityManager.getInstance()

fn activityManagerCreateInstance(nowMs: i64) -> ActivityManager:
    ActivityManager.createInstance(nowMs)

fn activityManagerResetInstance() -> ():
    ActivityManager.resetInstance()

fn activityManagerDefaultTimeoutMs() -> i64:
    5000

fn activityManagerSourceLinesModeled() -> i64:
    164

# Source parity ledger: imports getActiveTimeCounter from bootstrap state.
# Source parity ledger: ActivityManagerOptions allows custom getNow.
# Source parity ledger: ActivityManagerOptions allows custom active counter.
# Source parity ledger: activeOperations is a JavaScript Set<string>.
# Source parity ledger: lastUserActivityTime starts at zero.
# Source parity ledger: lastCLIRecordedTime starts at constructor now.
# Source parity ledger: isCLIActive starts false.
# Source parity ledger: USER_ACTIVITY_TIMEOUT_MS is 5000.
# Source parity ledger: singleton instance starts null in TypeScript.
# Source parity ledger: getInstance lazily creates the singleton.
# Source parity ledger: resetInstance clears the singleton for tests.
# Source parity ledger: createInstance replaces singleton for tests.
# Source parity ledger: recordUserActivity skips first activity delta.
# Source parity ledger: CLI activity takes precedence over user time.
# Source parity ledger: user elapsed milliseconds are converted to seconds.
# Source parity ledger: user elapsed must be positive.
# Source parity ledger: missing counter means no metric add in TypeScript.
# Source parity ledger: user elapsed is capped by timeout window.
# Source parity ledger: timeout comparison is strictly less than five seconds.
# Source parity ledger: recordUserActivity always updates last user timestamp.
# Source parity ledger: startCLIActivity deduplicates repeated operation ids.
# Source parity ledger: duplicate operation ids force cleanup before restart.
# Source parity ledger: first active CLI operation flips isCLIActive true.
# Source parity ledger: first active CLI operation resets CLI record timestamp.
# Source parity ledger: overlapping CLI operations share one active interval.
# Source parity ledger: endCLIActivity deletes operation id from active set.
# Source parity ledger: only the last CLI operation records elapsed CLI time.
# Source parity ledger: CLI elapsed milliseconds are converted to seconds.
# Source parity ledger: CLI elapsed must be positive.
# Source parity ledger: CLI metric label type is cli.
# Source parity ledger: after final end, lastCLIRecordedTime becomes now.
# Source parity ledger: after final end, isCLIActive becomes false.
# Source parity ledger: trackOperation starts before executing callback.
# Source parity ledger: trackOperation always ends in finally.
# Source parity ledger: getActivityStates computes user activity from now.
# Source parity ledger: getActivityStates reports isUserActive.
# Source parity ledger: getActivityStates reports isCLIActive.
# Source parity ledger: getActivityStates reports activeOperationCount.
# Source parity ledger: exported singleton is ActivityManager.getInstance().
