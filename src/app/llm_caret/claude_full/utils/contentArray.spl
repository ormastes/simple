class ContentArrayBlock:
    typeName: text
    text: text

fn contentBlock(typeName: text, textValue: text) -> ContentArrayBlock:
    ContentArrayBlock(typeName: typeName, text: textValue)

fn insertBlockAfterToolResults(content: [ContentArrayBlock], block: ContentArrayBlock) -> [ContentArrayBlock]:
    val lastToolResultIndex = findLastToolResultIndex(content)
    if lastToolResultIndex >= 0:
        return insertContentBlockAt(content, block, lastToolResultIndex + 1, true)
    val insertIndex = maxI64(0, content.len() - 1)
    insertContentBlockAt(content, block, insertIndex, false)

fn findLastToolResultIndex(content: [ContentArrayBlock]) -> i64:
    var last = -1
    var i = 0
    while i < content.len():
        if content[i].typeName == "tool_result":
            last = i
        i = i + 1
    last

fn insertContentBlockAt(content: [ContentArrayBlock], block: ContentArrayBlock, insertIndex: i64, appendTextIfFinal: bool) -> [ContentArrayBlock]:
    var out: [ContentArrayBlock] = []
    var i = 0
    while i < content.len():
        if i == insertIndex:
            out.push(block)
        out.push(content[i])
        i = i + 1
    if insertIndex >= content.len():
        out.push(block)
    if appendTextIfFinal and insertIndex == content.len():
        out.push(contentBlock("text", "."))
    out

fn maxI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b
