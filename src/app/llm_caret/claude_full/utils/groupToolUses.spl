class ToolUseRenderMessage:
    typeName: text
    uuid: text
    timestamp: i64
    messageId: text
    toolUseId: text
    toolName: text
    toolResultIds: [text]

class GroupedToolUseRenderMessage:
    typeName: text
    toolName: text
    messageIds: [text]
    resultIds: [text]
    displayUuid: text
    uuid: text
    timestamp: i64
    messageId: text

class ToolUseGroupingResult:
    renderTypes: [text]
    renderUuids: [text]
    groups: [GroupedToolUseRenderMessage]

fn applyToolUseGrouping(messages: [ToolUseRenderMessage], groupedToolNames: [text], verbose: bool) -> ToolUseGroupingResult:
    if verbose:
        return ToolUseGroupingResult(renderTypes: messageTypeNames(messages), renderUuids: messageUuids(messages), groups: [])
    val groupedIds = groupedToolUseIds(messages, groupedToolNames)
    var renderTypes: [text] = []
    var renderUuids: [text] = []
    var groups: [GroupedToolUseRenderMessage] = []
    var emittedKeys: [text] = []
    for msg in messages:
        if msg.typeName == "assistant_tool_use" and containsTextGroupTool(groupedIds, msg.toolUseId):
            val key = msg.messageId + ":" + msg.toolName
            if not containsTextGroupTool(emittedKeys, key):
                emittedKeys.push(key)
                val group = buildGroupedToolUseMessage(messages, key, msg)
                groups.push(group)
                renderTypes.push("grouped_tool_use")
                renderUuids.push(group.uuid)
            continue
        if msg.typeName == "user_tool_result" and allToolResultsGrouped(msg.toolResultIds, groupedIds):
            continue
        renderTypes.push(msg.typeName)
        renderUuids.push(msg.uuid)
    ToolUseGroupingResult(renderTypes: renderTypes, renderUuids: renderUuids, groups: groups)

fn groupedToolUseIds(messages: [ToolUseRenderMessage], groupedToolNames: [text]) -> [text]:
    var ids: [text] = []
    for msg in messages:
        if msg.typeName == "assistant_tool_use" and containsTextGroupTool(groupedToolNames, msg.toolName):
            val count = countToolGroup(messages, msg.messageId, msg.toolName)
            if count >= 2 and not containsTextGroupTool(ids, msg.toolUseId):
                ids.push(msg.toolUseId)
    ids

fn countToolGroup(messages: [ToolUseRenderMessage], messageId: text, toolName: text) -> i64:
    var count = 0
    for msg in messages:
        if msg.typeName == "assistant_tool_use" and msg.messageId == messageId and msg.toolName == toolName:
            count = count + 1
    count

fn buildGroupedToolUseMessage(messages: [ToolUseRenderMessage], key: text, first: ToolUseRenderMessage) -> GroupedToolUseRenderMessage:
    var messageIds: [text] = []
    var resultIds: [text] = []
    for msg in messages:
        if msg.typeName == "assistant_tool_use" and msg.messageId + ":" + msg.toolName == key:
            messageIds.push(msg.uuid)
            resultIds = appendMatchingToolResults(messages, resultIds, msg.toolUseId)
    GroupedToolUseRenderMessage(typeName: "grouped_tool_use", toolName: first.toolName, messageIds: messageIds, resultIds: resultIds, displayUuid: first.uuid, uuid: "grouped-" + first.uuid, timestamp: first.timestamp, messageId: first.messageId)

fn appendMatchingToolResults(messages: [ToolUseRenderMessage], resultIds: [text], toolUseId: text) -> [text]:
    var out = resultIds
    for msg in messages:
        if msg.typeName == "user_tool_result" and containsTextGroupTool(msg.toolResultIds, toolUseId):
            out.push(msg.uuid)
    out

fn allToolResultsGrouped(resultIds: [text], groupedIds: [text]) -> bool:
    if resultIds.len() == 0:
        return false
    for id in resultIds:
        if not containsTextGroupTool(groupedIds, id):
            return false
    true

fn messageUuids(messages: [ToolUseRenderMessage]) -> [text]:
    var out: [text] = []
    for msg in messages:
        out.push(msg.uuid)
    out

fn messageTypeNames(messages: [ToolUseRenderMessage]) -> [text]:
    var out: [text] = []
    for msg in messages:
        out.push(msg.typeName)
    out

fn containsTextGroupTool(values: [text], value: text) -> bool:
    for item in values:
        if item == value:
            return true
    false
