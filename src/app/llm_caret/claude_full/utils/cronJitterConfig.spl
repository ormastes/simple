class CronJitterConfig:
    recurringFrac: f64
    recurringCapMs: i64
    oneShotMaxMs: i64
    oneShotFloorMs: i64
    oneShotMinuteMod: i64
    recurringMaxAgeMs: i64

class CronJitterConfigCandidate:
    recurringFrac: f64
    recurringCapMs: i64
    oneShotMaxMs: i64
    oneShotFloorMs: i64
    oneShotMinuteMod: i64
    recurringMaxAgeMs: Option<i64>

fn defaultCronJitterConfig() -> CronJitterConfig:
    CronJitterConfig(recurringFrac: 0.1, recurringCapMs: 900000, oneShotMaxMs: 90000, oneShotFloorMs: 0, oneShotMinuteMod: 30, recurringMaxAgeMs: 604800000)

fn parseCronJitterConfig(candidate: Option<CronJitterConfigCandidate>) -> CronJitterConfig:
    if val Some(config) = candidate:
        if isCronJitterConfigValid(config):
            return CronJitterConfig(
                recurringFrac: config.recurringFrac,
                recurringCapMs: config.recurringCapMs,
                oneShotMaxMs: config.oneShotMaxMs,
                oneShotFloorMs: config.oneShotFloorMs,
                oneShotMinuteMod: config.oneShotMinuteMod,
                recurringMaxAgeMs: config.recurringMaxAgeMs ?? defaultCronJitterConfig().recurringMaxAgeMs,
            )
    defaultCronJitterConfig()

fn isCronJitterConfigValid(config: CronJitterConfigCandidate) -> bool:
    if config.recurringFrac < 0.0 or config.recurringFrac > 1.0:
        return false
    if config.recurringCapMs < 0 or config.recurringCapMs > 1800000:
        return false
    if config.oneShotMaxMs < 0 or config.oneShotMaxMs > 1800000:
        return false
    if config.oneShotFloorMs < 0 or config.oneShotFloorMs > 1800000:
        return false
    if config.oneShotMinuteMod < 1 or config.oneShotMinuteMod > 60:
        return false
    if config.oneShotFloorMs > config.oneShotMaxMs:
        return false
    if val Some(maxAgeMs) = config.recurringMaxAgeMs:
        return maxAgeMs >= 0 and maxAgeMs <= 2592000000
    true
