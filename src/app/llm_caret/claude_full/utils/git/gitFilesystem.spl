"""
Claude full git filesystem watcher parity surface.
"""

class GitCacheEntry:
    key: text
    dirty: bool

impl GitCacheEntry:
    static fn new(key: text, dirty: bool) -> GitCacheEntry:
        GitCacheEntry(key: key, dirty: dirty)

class GitFileWatcher:
    gitDir: text
    commonDir: text
    initialized: bool
    watchedPaths: [text]
    branchRefPath: text
    cache: [GitCacheEntry]

impl GitFileWatcher:
    static fn new() -> GitFileWatcher:
        GitFileWatcher(gitDir: "", commonDir: "", initialized: false, watchedPaths: [], branchRefPath: "", cache: [])

    fn ensureStarted(gitDir: text, commonDir: text) -> GitFileWatcher:
        if self.initialized:
            return self
        var out = GitFileWatcher(gitDir: gitDir, commonDir: commonDir, initialized: true, watchedPaths: [], branchRefPath: "", cache: self.cache)
        out = out.watchPath(gitDir + "/HEAD")
        out.watchPath(commonDir + "/config")

    fn watchPath(path: text) -> GitFileWatcher:
        var paths = copyTextGitFileWatcher(self.watchedPaths)
        if not containsTextGitFileWatcher(paths, path):
            paths.push(path)
        GitFileWatcher(gitDir: self.gitDir, commonDir: self.commonDir, initialized: self.initialized, watchedPaths: paths, branchRefPath: self.branchRefPath, cache: self.cache)

    fn onHeadChanged(branchRefPath: text) -> GitFileWatcher:
        var out = GitFileWatcher(gitDir: self.gitDir, commonDir: self.commonDir, initialized: self.initialized, watchedPaths: self.watchedPaths, branchRefPath: branchRefPath, cache: markAllDirtyGitFileWatcher(self.cache))
        out.watchPath(branchRefPath)

    fn setCache(key: text) -> GitFileWatcher:
        var cache = copyGitCacheEntries(self.cache)
        cache.push(GitCacheEntry.new(key, false))
        GitFileWatcher(gitDir: self.gitDir, commonDir: self.commonDir, initialized: self.initialized, watchedPaths: self.watchedPaths, branchRefPath: self.branchRefPath, cache: cache)

    fn markDirty(key: text) -> GitFileWatcher:
        var cache: [GitCacheEntry] = []
        var i = 0
        while i < self.cache.len():
            var entry = self.cache[i]
            if entry.key == key:
                entry.dirty = true
            cache.push(entry)
            i = i + 1
        GitFileWatcher(gitDir: self.gitDir, commonDir: self.commonDir, initialized: self.initialized, watchedPaths: self.watchedPaths, branchRefPath: self.branchRefPath, cache: cache)

fn markAllDirtyGitFileWatcher(values: [GitCacheEntry]) -> [GitCacheEntry]:
    var out: [GitCacheEntry] = []
    var i = 0
    while i < values.len():
        out.push(GitCacheEntry.new(values[i].key, true))
        i = i + 1
    out

fn copyGitCacheEntries(values: [GitCacheEntry]) -> [GitCacheEntry]:
    var out: [GitCacheEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyTextGitFileWatcher(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn containsTextGitFileWatcher(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn watchIntervalMs(testMode: bool) -> i64:
    if testMode:
        return 10
    1000

fn gitFilesystemSourceLinesModeled() -> i64: 699
