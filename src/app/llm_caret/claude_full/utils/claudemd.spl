const CLAUDEMD_SOURCE_LINES = 1479
const LARGE_MEMORY_FILE_THRESHOLD = 40000

fn isMemoryFilePathRoute(path: text) -> bool:
    path.ends_with("CLAUDE.md") || path.ends_with("CLAUDE.local.md") || (path.contains("/.claude/rules/") && path.ends_with(".md"))

fn getLargeMemoryFilesRoute(contentLength: i64) -> bool:
    contentLength > LARGE_MEMORY_FILE_THRESHOLD

fn getExternalClaudeMdIncludesRoute(scope: text, hasParent: bool, pathInsideCwd: bool) -> bool:
    if scope == "User":
        return false
    hasParent && !pathInsideCwd

fn hasExternalClaudeMdIncludesRoute(count: i64) -> bool:
    count > 0

fn memoryFileInfoRoute(path: text, scope: text) -> text:
    scope + ":" + path

fn externalClaudeMdIncludeRoute(path: text, parent: text) -> text:
    parent + " -> " + path

fn claudemdSourceLinesModeled() -> i64:
    CLAUDEMD_SOURCE_LINES
