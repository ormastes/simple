class BtwTriggerPosition:
    word: text
    start: i64
    end: i64

impl BtwTriggerPosition:
    static fn new(word: text, start: i64, end: i64) -> BtwTriggerPosition:
        BtwTriggerPosition(word: word, start: start, end: end)

fn findBtwTriggerPositions(textValue: text) -> [BtwTriggerPosition]:
    val trigger = "/btw"
    if textValue.len() < trigger.len():
        return []
    val end = trigger.len()
    if textValue.slice(0, end).lower() != trigger:
        return []
    if textValue.len() > end and isBtwWordChar(textValue.slice(end, end + 1)):
        return []
    [BtwTriggerPosition.new(textValue.slice(0, end), 0, end)]

fn isBtwWordChar(ch: text) -> bool:
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    ch == "_"
