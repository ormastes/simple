"""
Claude full stream utility parity surface.
"""

class Stream:
    chunks: [text]
    closed: bool
    cancelled: bool
    errorMessage: text
    pipedChunks: [text]

impl Stream:
    static fn new() -> Stream:
        Stream(chunks: [], closed: false, cancelled: false, errorMessage: "", pipedChunks: [])

    static fn fromChunks(chunks: [text]) -> Stream:
        Stream(chunks: chunks, closed: false, cancelled: false, errorMessage: "", pipedChunks: [])

    fn append(chunk: text) -> Stream:
        if self.closed or self.cancelled:
            return self
        var chunks = self.chunks
        chunks.push(chunk)
        Stream(chunks: chunks, closed: self.closed, cancelled: self.cancelled, errorMessage: self.errorMessage, pipedChunks: self.pipedChunks)

    fn closeStream() -> Stream:
        Stream(chunks: self.chunks, closed: true, cancelled: self.cancelled, errorMessage: self.errorMessage, pipedChunks: self.pipedChunks)

    fn cancel(reason: text) -> Stream:
        Stream(chunks: self.chunks, closed: true, cancelled: true, errorMessage: reason, pipedChunks: self.pipedChunks)

    fn pipeTo(other: Stream) -> Stream:
        var target = other
        var i = 0
        while i < self.chunks.len():
            target = target.append(self.chunks[i])
            i = i + 1
        target

    fn text() -> text:
        var result = ""
        var i = 0
        while i < self.chunks.len():
            result = result + self.chunks[i]
            i = i + 1
        result

    fn lineCount() -> i64:
        val value = self.text()
        if value == "":
            return 0
        value.split("\n").len()

    fn byteLength() -> i64:
        self.text().len()

    fn isReadable() -> bool:
        not self.closed and not self.cancelled

    fn status() -> text:
        if self.cancelled:
            return "cancelled"
        if self.closed:
            return "closed"
        "open"

fn streamSourceLinesModeled() -> i64: 76
