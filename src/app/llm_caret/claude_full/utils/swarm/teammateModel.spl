fn getHardcodedTeammateModelFallback(apiProvider: text) -> text:
    val provider = apiProvider.trim().lower()
    if provider == "bedrock":
        return "us.anthropic.claude-opus-4-6-v1"
    if provider == "vertex":
        return "claude-opus-4-6"
    if provider == "foundry":
        return "claude-opus-4-6"
    "claude-opus-4-6"
