const IN_PROCESS_RUNNER_SOURCE_LINES = 1553

fn formatAsTeammateMessageRoute(teammateId: text, color: text, summary: text, content: text) -> text:
    var attrs = "teammate_id=\"" + teammateId + "\""
    if color != "":
        attrs = attrs + " color=\"" + color + "\""
    if summary != "":
        attrs = attrs + " summary=\"" + summary + "\""
    "<teammate-message " + attrs + ">\n" + content + "\n</teammate-message>"

fn findAvailableTaskRoute(status: text, owner: text, unresolvedBlockers: i64) -> bool:
    status == "pending" && owner == "" && unresolvedBlockers == 0

fn findAvailableTaskIndexRoute(firstAvailableIndex: i64) -> i64:
    firstAvailableIndex

fn formatTaskAsPromptRoute(taskId: text, description: text) -> text:
    val prefix = "Complete all open tasks. Start with task #" + taskId + "."
    if description == "":
        return prefix
    prefix + "\n\n" + description

fn inProcessRunnerSourceLinesModeled() -> i64:
    IN_PROCESS_RUNNER_SOURCE_LINES
