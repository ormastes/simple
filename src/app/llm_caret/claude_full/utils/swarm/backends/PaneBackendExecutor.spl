class PaneSpawnConfig:
    name: text
    teamName: text
    prompt: text
    color: text
    cwd: text
    model: text
    planModeRequired: bool

impl PaneSpawnConfig:
    static fn new(name: text, teamName: text, prompt: text, color: text, cwd: text, model: text, planModeRequired: bool) -> PaneSpawnConfig:
        PaneSpawnConfig(name: name, teamName: teamName, prompt: prompt, color: color, cwd: cwd, model: model, planModeRequired: planModeRequired)

class PaneSpawnResult:
    success: bool
    agentId: text
    paneId: text
    error: text

class PaneBackendExecutor:
    type: text
    contextSet: bool
    spawnedAgentIds: [text]
    spawnedPaneIds: [text]
    mailboxAgents: [text]
    mailboxTexts: [text]
    commands: [text]
    lastError: text

impl PaneBackendExecutor:
    static fn new(backendType: text) -> PaneBackendExecutor:
        PaneBackendExecutor(type: backendType, contextSet: false, spawnedAgentIds: [], spawnedPaneIds: [], mailboxAgents: [], mailboxTexts: [], commands: [], lastError: "")

    me setContext(contextName: text) -> ():
        me.contextSet = contextName.len() > 0

    me isAvailable() -> bool:
        me.type == "tmux" or me.type == "iterm2"

    me spawn(config: PaneSpawnConfig) -> PaneSpawnResult:
        val agentId = config.name + "@" + config.teamName
        if not me.contextSet:
            me.lastError = "PaneBackendExecutor not initialized. Call setContext() before spawn()."
            return PaneSpawnResult(success: false, agentId: agentId, paneId: "", error: me.lastError)
        val paneId = me.type + ":" + agentId
        val command = buildPaneSpawnCommand(agentId, config)
        me.spawnedAgentIds = appendPaneText(me.spawnedAgentIds, agentId)
        me.spawnedPaneIds = appendPaneText(me.spawnedPaneIds, paneId)
        me.commands = appendPaneText(me.commands, command)
        me.mailboxAgents = appendPaneText(me.mailboxAgents, agentId)
        me.mailboxTexts = appendPaneText(me.mailboxTexts, config.prompt)
        PaneSpawnResult(success: true, agentId: agentId, paneId: paneId, error: "")

    me sendMessage(agentId: text, messageText: text) -> bool:
        if parsePaneAgentId(agentId) == "":
            me.lastError = "Invalid agentId format: " + agentId
            return false
        me.mailboxAgents = appendPaneText(me.mailboxAgents, agentId)
        me.mailboxTexts = appendPaneText(me.mailboxTexts, messageText)
        true

    me terminate(agentId: text, reason: text) -> bool:
        if not containsPaneText(me.spawnedAgentIds, agentId):
            me.lastError = "No pane for " + agentId
            return false
        me.mailboxAgents = appendPaneText(me.mailboxAgents, agentId)
        me.mailboxTexts = appendPaneText(me.mailboxTexts, "shutdown:" + reason)
        true

    me kill(agentId: text) -> bool:
        val idx = indexOfPaneText(me.spawnedAgentIds, agentId)
        if idx < 0:
            return false
        me.commands = appendPaneText(me.commands, "kill-pane " + me.spawnedPaneIds[idx])
        true

    me isActive(agentId: text) -> bool:
        containsPaneText(me.spawnedAgentIds, agentId)

fn createPaneBackendExecutor(backendType: text) -> PaneBackendExecutor:
    PaneBackendExecutor.new(backendType)

fn buildPaneSpawnCommand(agentId: text, config: PaneSpawnConfig) -> text:
    var flags = "--agent-id " + agentId + " --agent-name " + config.name + " --team-name " + config.teamName + " --agent-color " + config.color
    if config.planModeRequired:
        flags = flags + " --plan-mode-required"
    if config.model != "":
        flags = flags + " --model " + config.model
    "cd " + config.cwd + " && env claude " + flags

fn parsePaneAgentId(agentId: text) -> text:
    val at = agentId.index_of("@")
    if at <= 0:
        return ""
    if at >= agentId.len() - 1:
        return ""
    agentId

fn appendPaneText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn containsPaneText(values: [text], value: text) -> bool:
    indexOfPaneText(values, value) >= 0

fn indexOfPaneText(values: [text], value: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return i
        i = i + 1
    -1

fn paneBackendExecutorSourceLinesModeled() -> i64:
    354

