class TmuxPaneResult:
    paneId: text
    isFirstTeammate: bool
    useExternalSession: bool

class TmuxBackend:
    type: text
    displayName: text
    supportsHideShow: bool
    tmuxAvailable: bool
    insideTmux: bool
    firstPaneUsedForExternal: bool
    panes: [text]
    commands: [text]
    hiddenPanes: [text]
    cachedLeaderWindowTarget: text
    lastError: text

impl TmuxBackend:
    static fn new() -> TmuxBackend:
        TmuxBackend(type: "tmux", displayName: "tmux", supportsHideShow: true, tmuxAvailable: false, insideTmux: false, firstPaneUsedForExternal: false, panes: [], commands: [], hiddenPanes: [], cachedLeaderWindowTarget: "", lastError: "")

    me setDetection(tmuxAvailable: bool, insideTmux: bool) -> ():
        me.tmuxAvailable = tmuxAvailable
        me.insideTmux = insideTmux

    me isAvailable() -> bool:
        me.tmuxAvailable

    me isRunningInside() -> bool:
        me.insideTmux

    me createTeammatePaneInSwarmView(name: text, color: text) -> TmuxPaneResult:
        if me.insideTmux:
            return me.createTeammatePaneWithLeader(name, color)
        me.createTeammatePaneExternal(name, color)

    me createTeammatePaneWithLeader(name: text, color: text) -> TmuxPaneResult:
        val isFirst = me.panes.len() == 0
        val paneId = "%leader-" + (me.panes.len() + 1).to_text()
        me.panes = appendTmuxText(me.panes, paneId)
        me.commands = appendTmuxText(me.commands, "split-pane -h " + name + " " + getTmuxColorName(color))
        TmuxPaneResult(paneId: paneId, isFirstTeammate: isFirst, useExternalSession: false)

    me createTeammatePaneExternal(name: text, color: text) -> TmuxPaneResult:
        val isFirst = not me.firstPaneUsedForExternal
        val paneId = "%swarm-" + (me.panes.len() + 1).to_text()
        me.firstPaneUsedForExternal = true
        me.panes = appendTmuxText(me.panes, paneId)
        me.commands = appendTmuxText(me.commands, "new-session claude-swarm; split-window " + name + " " + getTmuxColorName(color))
        TmuxPaneResult(paneId: paneId, isFirstTeammate: isFirst, useExternalSession: true)

    me sendCommandToPane(paneId: text, command: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "send-keys -t " + paneId + " " + command + " Enter")
        true

    me setPaneBorderColor(paneId: text, color: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "select-pane -t " + paneId + " -P fg=" + getTmuxColorName(color))
        true

    me setPaneTitle(paneId: text, name: text, color: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "select-pane -t " + paneId + " -T " + name)
        true

    me enablePaneBorderStatus(windowTarget: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "set-option -w -t " + windowTarget + " pane-border-status top")
        true

    me rebalancePanes(windowTarget: text, hasLeader: bool) -> bool:
        var layout = "even-horizontal"
        if hasLeader:
            layout = "main-vertical"
        me.commands = appendTmuxText(me.commands, "select-layout -t " + windowTarget + " " + layout)
        true

    me hidePane(paneId: text, useExternalSession: bool) -> bool:
        if not containsTmuxText(me.hiddenPanes, paneId):
            me.hiddenPanes = appendTmuxText(me.hiddenPanes, paneId)
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "break-pane -d -s " + paneId)
        true

    me showPane(paneId: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "join-pane -s " + paneId)
        true

    me killPane(paneId: text, useExternalSession: bool) -> bool:
        me.commands = appendTmuxText(me.commands, tmuxPrefix(useExternalSession) + "kill-pane -t " + paneId)
        true

    me getCurrentWindowTarget() -> text:
        if me.cachedLeaderWindowTarget != "":
            return me.cachedLeaderWindowTarget
        me.cachedLeaderWindowTarget = "leader:swarm-view"
        me.cachedLeaderWindowTarget

fn waitForPaneShellReady() -> i64:
    200

fn acquirePaneCreationLock() -> text:
    "release"

fn newLock() -> text:
    "locked"

fn getTmuxColorName(color: text) -> text:
    if color == "purple":
        return "magenta"
    if color == "orange":
        return "colour208"
    if color == "pink":
        return "colour205"
    color

fn runTmuxInUserSession(args: [text]) -> text:
    "tmux " + joinTmuxText(args, " ")

fn runTmuxInSwarm(args: [text]) -> text:
    "tmux -L claude-swarm " + joinTmuxText(args, " ")

fn tmuxPrefix(useExternalSession: bool) -> text:
    if useExternalSession:
        return "tmux -L claude-swarm "
    "tmux "

fn appendTmuxText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn containsTmuxText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn joinTmuxText(values: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + sep
        out = out + values[i]
        i = i + 1
    out

fn tmuxBackendSourceLinesModeled() -> i64:
    764

