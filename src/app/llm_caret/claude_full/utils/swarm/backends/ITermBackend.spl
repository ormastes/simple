class ITermSplitResult:
    paneId: text
    isFirstTeammate: bool
    splitArgs: [text]

class ITermBackend:
    type: text
    displayName: text
    supportsHideShow: bool
    inITerm2: bool
    it2Available: bool
    firstPaneUsed: bool
    teammateSessionIds: [text]
    commands: [text]
    lastError: text

impl ITermBackend:
    static fn new() -> ITermBackend:
        ITermBackend(type: "iterm2", displayName: "iTerm2", supportsHideShow: false, inITerm2: false, it2Available: false, firstPaneUsed: false, teammateSessionIds: [], commands: [], lastError: "")

    me setDetection(inITerm2: bool, it2Available: bool) -> ():
        me.inITerm2 = inITerm2
        me.it2Available = it2Available

    me isAvailable() -> bool:
        me.inITerm2 and me.it2Available

    me isRunningInside() -> bool:
        me.inITerm2

    me createTeammatePaneInSwarmView(name: text, color: text) -> ITermSplitResult:
        val isFirst = not me.firstPaneUsed
        var args: [text] = []
        if isFirst:
            args = ["session", "split", "-v"]
        else:
            val last = me.teammateSessionIds[me.teammateSessionIds.len() - 1]
            args = ["session", "split", "-s", last]
        val paneId = "iterm:" + name + ":" + (me.teammateSessionIds.len() + 1).to_text()
        me.firstPaneUsed = true
        me.teammateSessionIds = appendITermText(me.teammateSessionIds, paneId)
        ITermSplitResult(paneId: paneId, isFirstTeammate: isFirst, splitArgs: args)

    me sendCommandToPane(paneId: text, command: text, useExternalSession: bool) -> bool:
        me.commands = appendITermText(me.commands, "send-text|" + paneId + "|" + command)
        true

    me killPane(paneId: text, useExternalSession: bool) -> bool:
        me.commands = appendITermText(me.commands, "close|" + paneId)
        true

    me hidePane(paneId: text, useExternalSession: bool) -> bool:
        me.lastError = "iTerm2 backend does not support hidePane"
        false

    me showPane(paneId: text, useExternalSession: bool) -> bool:
        me.lastError = "iTerm2 backend does not support showPane"
        false

fn acquirePaneCreationLock() -> text:
    "release"

fn newLock() -> text:
    "locked"

fn runIt2(args: [text]) -> text:
    joinITermText(args, " ")

fn parseSplitOutput(output: text) -> text:
    val marker = "Created new pane:"
    val pos = output.index_of(marker)
    if pos < 0:
        return ""
    output.slice(pos + marker.len(), output.len()).trim()

fn getLeaderSessionId(itermSessionId: text) -> text:
    val pos = itermSessionId.index_of(":")
    if pos < 0:
        return ""
    itermSessionId.slice(pos + 1, itermSessionId.len())

fn appendITermText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn joinITermText(values: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + sep
        out = out + values[i]
        i = i + 1
    out

fn iTermBackendSourceLinesModeled() -> i64:
    370

