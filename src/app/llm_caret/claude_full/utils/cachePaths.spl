fn maxSanitizedCachePathLength() -> i64:
    200

fn sanitizeCachePath(name: text, hashSuffix: text) -> text:
    val sanitized = sanitizeCachePathChars(name)
    if sanitized.len() <= maxSanitizedCachePathLength():
        return sanitized
    sanitized.slice(0, maxSanitizedCachePathLength()) + "-" + hashSuffix

fn getProjectDir(cwd: text, hashSuffix: text) -> text:
    sanitizeCachePath(cwd, hashSuffix)

fn cacheBaseLogsPath(cacheBase: text, cwd: text, hashSuffix: text) -> text:
    joinCachePath(cacheBase, getProjectDir(cwd, hashSuffix))

fn cacheErrorsPath(cacheBase: text, cwd: text, hashSuffix: text) -> text:
    joinCachePath(cacheBaseLogsPath(cacheBase, cwd, hashSuffix), "errors")

fn cacheMessagesPath(cacheBase: text, cwd: text, hashSuffix: text) -> text:
    joinCachePath(cacheBaseLogsPath(cacheBase, cwd, hashSuffix), "messages")

fn cacheMcpLogsPath(cacheBase: text, cwd: text, serverName: text, projectHashSuffix: text, serverHashSuffix: text) -> text:
    joinCachePath(cacheBaseLogsPath(cacheBase, cwd, projectHashSuffix), "mcp-logs-" + sanitizeCachePath(serverName, serverHashSuffix))

fn sanitizeCachePathChars(name: text) -> text:
    var out = ""
    var i = 0
    while i < name.len():
        val ch = name.slice(i, i + 1)
        if isCachePathAlphaNumeric(ch):
            out = out + ch
        else:
            out = out + "-"
        i = i + 1
    out

fn isCachePathAlphaNumeric(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9")

fn joinCachePath(left: text, right: text) -> text:
    if left == "":
        return right
    if right == "":
        return left
    if left.slice(left.len() - 1, left.len()) == "/":
        return left + right
    left + "/" + right
