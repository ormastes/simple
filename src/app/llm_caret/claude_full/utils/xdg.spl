class XDGOptions:
    stateHome: Option<text>
    cacheHome: Option<text>
    dataHome: Option<text>
    home: text

fn getXDGStateHome(options: XDGOptions) -> text:
    options.stateHome ?? joinXDGPath(options.home, ".local/state")

fn getXDGCacheHome(options: XDGOptions) -> text:
    if val Some(cacheHome) = options.cacheHome:
        return cacheHome
    joinXDGPath(options.home, ".cache")

fn getXDGDataHome(options: XDGOptions) -> text:
    if val Some(dataHome) = options.dataHome:
        return dataHome
    joinXDGPath(options.home, ".local/share")

fn getUserBinDir(options: XDGOptions) -> text:
    joinXDGPath(options.home, ".local/bin")

fn joinXDGPath(left: text, right: text) -> text:
    if left == "":
        return right
    if left.ends_with("/"):
        return left + right
    left + "/" + right
