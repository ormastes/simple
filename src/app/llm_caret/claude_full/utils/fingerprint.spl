use std.common.crypto.sha256.{sha256_bytes}
use std.common.crypto.types.{bytes_to_hex}
use std.common.encoding.utf8.{utf8_encode_one}

const FINGERPRINT_SALT = "59cf53e54c78"

class FingerprintMessage:
    messageType: text
    stringContent: Option<text>
    textBlocks: [text]

fn extractFirstMessageText(messages: [FingerprintMessage]) -> text:
    for message in messages:
        if message.messageType == "user":
            if message.stringContent.?:
                return message.stringContent ?? ""
            if message.textBlocks.len() > 0:
                return message.textBlocks[0]
            return ""
    ""

fn computeFingerprint(messageText: text, version: text) -> text:
    val bytes = textUtf8Bytes(FINGERPRINT_SALT) + fingerprintUtf8BytesAt(messageText, 4) + fingerprintUtf8BytesAt(messageText, 7) + fingerprintUtf8BytesAt(messageText, 20) + textUtf8Bytes(version)
    bytes_to_hex(sha256_bytes(bytes)).slice(0, 3)

fn computeFingerprintFromMessages(messages: [FingerprintMessage], version: text) -> text:
    computeFingerprint(extractFirstMessageText(messages), version)

fn fingerprintCharAt(value: text, index: i64) -> text:
    var utf16Index = 0
    for ch in value.chars():
        val units = if ch.len() == 4: 2 else: 1
        if index >= utf16Index and index < utf16Index + units:
            if units == 2:
                return "�"
            return ch
        utf16Index = utf16Index + units
    "0"

fn fingerprintUtf8BytesAt(value: text, index: i64) -> [i64]:
    var utf16Index = 0
    for ch in value.chars():
        val units = if ch.len() == 4: 2 else: 1
        if index >= utf16Index and index < utf16Index + units:
            if units == 2:
                return [0xEF, 0xBF, 0xBD]
            return utf8_encode_one(ch.ord())
        utf16Index = utf16Index + units
    [48]

fn textUtf8Bytes(value: text) -> [i64]:
    var bytes: [i64] = []
    for ch in value.chars():
        bytes = bytes + utf8_encode_one(ch.ord())
    bytes
