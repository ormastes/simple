const IDE_UTILS_SOURCE_LINES = 1494

fn isVSCodeIdeRoute(ideType: text) -> bool:
    ideType == "vscode" || ideType == "code" || ideType == "cursor" || ideType == "windsurf"

fn isJetBrainsIdeRoute(ideType: text) -> bool:
    ideType == "intellij" || ideType == "pycharm" || ideType == "webstorm" || ideType == "goland"

fn basenameIdeRoute(value: text) -> text:
    val slash = value.rfind("/")
    if slash >= 0: value.substring(slash + 1) else: value

fn toIDEDisplayNameRoute(value: text) -> text:
    if value == "":
        return "IDE"
    val base = basenameIdeRoute(value)
    if base.starts_with("code"):
        return "VS Code"
    if base == "vscode":
        return "VS Code"
    if base == "cursor":
        return "Cursor"
    if base == "intellij":
        return "IntelliJ IDEA"
    if base == "pycharm":
        return "PyCharm"
    capitalizeIdeNameRoute(base)

fn capitalizeIdeNameRoute(value: text) -> text:
    if value == "":
        return value
    value.substring(0, 1).to_upper() + value.substring(1)

fn connectedIdeNameRoute(clientConfigName: text, terminalSupported: bool, terminalName: text) -> text:
    if clientConfigName != "":
        return toIDEDisplayNameRoute(clientConfigName)
    if terminalSupported:
        return toIDEDisplayNameRoute(terminalName)
    "null"

fn hasAccessToIDEExtensionDiffFeatureRoute(connectedMcpName: text) -> bool:
    connectedMcpName == "ide"

fn ideUtilsSourceLinesModeled() -> i64:
    IDE_UTILS_SOURCE_LINES
