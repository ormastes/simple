"""
Claude full MCP websocket transport parity surface.
"""

const WS_CONNECTING = 0
const WS_OPEN = 1
const WS_CLOSED = 3

class JsonRpcMessage:
    id: text
    method: text
    params: text

impl JsonRpcMessage:
    static fn new(id: text, method: text, params: text) -> JsonRpcMessage:
        JsonRpcMessage(id: id, method: method, params: params)

    fn encode() -> text:
        "{\"id\":\"" + self.id + "\",\"method\":\"" + self.method + "\",\"params\":\"" + self.params + "\"}"

class WebSocketTransport:
    readyState: i64
    started: bool
    isBun: bool
    sentMessages: [text]
    receivedMethods: [text]
    errorCodes: [text]
    closeCount: i64
    listenersAttached: bool

impl WebSocketTransport:
    static fn new(readyState: i64, isBun: bool) -> WebSocketTransport:
        WebSocketTransport(
            readyState: readyState,
            started: false,
            isBun: isBun,
            sentMessages: [],
            receivedMethods: [],
            errorCodes: [],
            closeCount: 0,
            listenersAttached: true,
        )

    fn start() -> WebSocketTransportStartResult:
        if self.started:
            return WebSocketTransportStartResult.err("Start can only be called once per transport.")
        if self.readyState != WS_OPEN:
            return WebSocketTransportStartResult.err("WebSocket is not open. Cannot start transport.")
        var next = self.copy()
        next.started = true
        WebSocketTransportStartResult.ok(next)

    fn send(message: JsonRpcMessage) -> WebSocketTransportSendResult:
        if self.readyState != WS_OPEN:
            var failed = self.copy()
            failed.errorCodes.push("mcp_websocket_send_not_opened")
            return WebSocketTransportSendResult.err("WebSocket is not open. Cannot send message.", failed)
        var next = self.copy()
        next.sentMessages.push(message.encode())
        WebSocketTransportSendResult.ok(next)

    fn receiveText(data: text) -> WebSocketTransport:
        var next = self.copy()
        val method = parseJsonRpcMethod(data)
        if method == "":
            next.errorCodes.push("mcp_websocket_message_fail")
        else:
            next.receivedMethods.push(method)
        next

    fn handleError(code: text) -> WebSocketTransport:
        var next = self.copy()
        if code == "":
            next.errorCodes.push("mcp_websocket_message_fail")
        else:
            next.errorCodes.push(code)
        next

    fn close() -> WebSocketTransport:
        var next = self.copy()
        if next.readyState == WS_OPEN or next.readyState == WS_CONNECTING:
            next.readyState = WS_CLOSED
        next.closeCount = next.closeCount + 1
        next.listenersAttached = false
        next

    fn copy() -> WebSocketTransport:
        WebSocketTransport(
            readyState: self.readyState,
            started: self.started,
            isBun: self.isBun,
            sentMessages: copyTextList(self.sentMessages),
            receivedMethods: copyTextList(self.receivedMethods),
            errorCodes: copyTextList(self.errorCodes),
            closeCount: self.closeCount,
            listenersAttached: self.listenersAttached,
        )

class WebSocketTransportStartResult:
    ok: bool
    transport: WebSocketTransport
    error: text

impl WebSocketTransportStartResult:
    static fn ok(transport: WebSocketTransport) -> WebSocketTransportStartResult:
        WebSocketTransportStartResult(ok: true, transport: transport, error: "")

    static fn err(error: text) -> WebSocketTransportStartResult:
        WebSocketTransportStartResult(ok: false, transport: WebSocketTransport.new(WS_CLOSED, false), error: error)

class WebSocketTransportSendResult:
    ok: bool
    transport: WebSocketTransport
    error: text

impl WebSocketTransportSendResult:
    static fn ok(transport: WebSocketTransport) -> WebSocketTransportSendResult:
        WebSocketTransportSendResult(ok: true, transport: transport, error: "")

    static fn err(error: text, transport: WebSocketTransport) -> WebSocketTransportSendResult:
        WebSocketTransportSendResult(ok: false, transport: transport, error: error)

fn parseJsonRpcMethod(data: text) -> text:
    if data.contains("\"method\":\"initialize\""):
        return "initialize"
    if data.contains("\"method\":\"tools/list\""):
        return "tools/list"
    if data.contains("\"method\":\"ping\""):
        return "ping"
    ""

fn copyTextList(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn mcpWebSocketTransportSourceLinesModeled() -> i64:
    200
