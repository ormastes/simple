fn splitPathInFrontmatter(input: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var braceDepth = 0
    var i = 0
    while i < input.len():
        val ch = input.slice(i, i + 1)
        if ch == "{":
            braceDepth = braceDepth + 1
            current = current + ch
        else if ch == "}":
            braceDepth = braceDepth - 1
            current = current + ch
        else if ch == "," and braceDepth == 0:
            val trimmed = current.trim()
            if trimmed != "":
                parts = parts + [trimmed]
            current = ""
        else:
            current = current + ch
        i = i + 1
    val trimmed = current.trim()
    if trimmed != "":
        parts = parts + [trimmed]
    var expanded: [text] = []
    for part in parts:
        expanded = expanded + expandFrontmatterBraces(part)
    expanded

fn splitPathListInFrontmatter(inputs: [text]) -> [text]:
    var out: [text] = []
    for input in inputs:
        out = out + splitPathInFrontmatter(input)
    out

fn expandFrontmatterBraces(pattern: text) -> [text]:
    val open = pattern.index_of("{")
    if open == -1:
        return [pattern]
    val close = findFrontmatterChar(pattern, "}", open + 1)
    if close == -1:
        return [pattern]
    val prefix = pattern.slice(0, open)
    val suffix = pattern.slice(close + 1, pattern.len())
    val alternatives = splitFrontmatterAlternatives(pattern.slice(open + 1, close))
    var out: [text] = []
    for alternative in alternatives:
        val combined = prefix + alternative.trim() + suffix
        out = out + expandFrontmatterBraces(combined)
    out

class FrontmatterValue:
    kind: text
    textValue: text
    intValue: i64
    boolValue: bool

impl FrontmatterValue:
    static fn textValue(value: text) -> FrontmatterValue:
        FrontmatterValue(kind: "text", textValue: value, intValue: 0, boolValue: false)

    static fn intValue(value: i64) -> FrontmatterValue:
        FrontmatterValue(kind: "int", textValue: "", intValue: value, boolValue: false)

    static fn boolValue(value: bool) -> FrontmatterValue:
        FrontmatterValue(kind: "bool", textValue: "", intValue: 0, boolValue: value)

    static fn nilValue() -> FrontmatterValue:
        FrontmatterValue(kind: "nil", textValue: "", intValue: 0, boolValue: false)

fn parsePositiveIntFromFrontmatter(value: FrontmatterValue) -> Option<i64>:
    if value.kind == "nil":
        return nil
    if value.kind == "int":
        if value.intValue > 0:
            return value.intValue
        return nil
    val trimmed = frontmatterValueToText(value).trim()
    if trimmed == "":
        return nil
    var sign = 1
    var i = 0
    if trimmed.slice(0, 1) == "-":
        sign = -1
        i = 1
    else if trimmed.slice(0, 1) == "+":
        i = 1
    var digits = ""
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if ch < "0" or ch > "9":
            if digits == "":
                return nil
            val parsed = digits.to_i64() * sign
            if parsed > 0:
                return parsed
            return nil
        digits = digits + ch
        i = i + 1
    if digits == "":
        return nil
    if val parsedDigits = digits.to_i64():
        val parsed = parsedDigits * sign
        if parsed > 0:
            return parsed
    nil

fn parseBooleanFrontmatter(value: FrontmatterValue) -> bool:
    if value.kind == "bool":
        return value.boolValue
    value.kind == "text" and value.textValue == "true"

fn parseShellFrontmatter(value: FrontmatterValue) -> Option<text>:
    if value.kind == "nil":
        return nil
    val normalized = frontmatterValueToText(value).trim().lower()
    if normalized == "":
        return nil
    if normalized == "bash" or normalized == "powershell":
        return normalized
    nil

fn frontmatterValueToText(value: FrontmatterValue) -> text:
    if value.kind == "text":
        return value.textValue
    if value.kind == "int":
        return value.intValue.to_text()
    if value.kind == "bool":
        if value.boolValue:
            return "true"
        return "false"
    ""

fn splitFrontmatterAlternatives(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == ",":
            out = out + [current]
            current = ""
        else:
            current = current + ch
        i = i + 1
    out + [current]

fn findFrontmatterChar(value: text, needle: text, start: i64) -> i64:
    var i = start
    while i < value.len():
        if value.slice(i, i + 1) == needle:
            return i
        i = i + 1
    -1
