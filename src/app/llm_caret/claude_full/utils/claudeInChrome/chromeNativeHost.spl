"""
Claude in Chrome native host parity surface.
"""

class McpClientModel:
    id: i64
    buffer: [text]

impl McpClientModel:
    static fn new(id: i64) -> McpClientModel:
        McpClientModel(id: id, buffer: [])

class ChromeNativeHost:
    mcpClients: [McpClientModel]
    nextClientId: i64
    running: bool
    socketPath: text
    sentChromeMessages: [text]

impl ChromeNativeHost:
    static fn new() -> ChromeNativeHost:
        ChromeNativeHost(mcpClients: [], nextClientId: 1, running: false, socketPath: "", sentChromeMessages: [])

    fn start(socketPath: text) -> ChromeNativeHost:
        if self.running:
            return self
        ChromeNativeHost(mcpClients: self.mcpClients, nextClientId: self.nextClientId, running: true, socketPath: socketPath, sentChromeMessages: self.sentChromeMessages)

    fn stop() -> ChromeNativeHost:
        ChromeNativeHost(mcpClients: [], nextClientId: self.nextClientId, running: false, socketPath: "", sentChromeMessages: self.sentChromeMessages)

    fn isRunning() -> bool:
        self.running

    fn getClientCount() -> i64:
        self.mcpClients.len()

    fn handleMessage(messageType: text) -> ChromeNativeHost:
        if messageType == "ping":
            return self.sendChromeMessage("pong")
        if messageType == "get_status":
            return self.sendChromeMessage("status_response")
        if messageType == "tool_response":
            return self.sendChromeMessage("forward_tool_response:" + self.mcpClients.len().to_text())
        if messageType == "notification":
            return self.sendChromeMessage("forward_notification:" + self.mcpClients.len().to_text())
        self.sendChromeMessage("error:Unknown message type: " + messageType)

    fn connectMcpClient() -> ChromeNativeHost:
        var clients = copyClientsChromeNativeHost(self.mcpClients)
        clients.push(McpClientModel.new(self.nextClientId))
        var out = ChromeNativeHost(mcpClients: clients, nextClientId: self.nextClientId + 1, running: self.running, socketPath: self.socketPath, sentChromeMessages: self.sentChromeMessages)
        out.sendChromeMessage("mcp_connected")

    fn disconnectMcpClient(id: i64) -> ChromeNativeHost:
        var clients: [McpClientModel] = []
        var i = 0
        while i < self.mcpClients.len():
            if self.mcpClients[i].id != id:
                clients.push(self.mcpClients[i])
            i = i + 1
        var out = ChromeNativeHost(mcpClients: clients, nextClientId: self.nextClientId, running: self.running, socketPath: self.socketPath, sentChromeMessages: self.sentChromeMessages)
        out.sendChromeMessage("mcp_disconnected")

    fn forwardToolRequest(clientId: i64, method: text) -> ChromeNativeHost:
        self.sendChromeMessage("tool_request:" + clientId.to_text() + ":" + method)

    fn sendChromeMessage(message: text) -> ChromeNativeHost:
        var sent = copyTextChromeNativeHost(self.sentChromeMessages)
        sent.push(message)
        ChromeNativeHost(mcpClients: self.mcpClients, nextClientId: self.nextClientId, running: self.running, socketPath: self.socketPath, sentChromeMessages: sent)

class ChromeMessageReader:
    buffer: [text]
    pending: bool
    closed: bool
    maxMessageSize: i64

impl ChromeMessageReader:
    static fn new(maxMessageSize: i64) -> ChromeMessageReader:
        ChromeMessageReader(buffer: [], pending: false, closed: false, maxMessageSize: maxMessageSize)

    fn pushFrame(length: i64, message: text) -> ChromeMessageReader:
        var buffer = copyTextChromeNativeHost(self.buffer)
        if length <= 0 or length > self.maxMessageSize:
            buffer.push("INVALID")
        else:
            buffer.push(length.to_text() + ":" + message)
        ChromeMessageReader(buffer: buffer, pending: self.pending, closed: self.closed, maxMessageSize: self.maxMessageSize)

    fn read() -> ChromeReadResult:
        if self.closed:
            return ChromeReadResult.new("", true, ChromeMessageReader(buffer: self.buffer, pending: false, closed: true, maxMessageSize: self.maxMessageSize))
        if self.buffer.len() == 0:
            return ChromeReadResult.new("", false, ChromeMessageReader(buffer: self.buffer, pending: true, closed: self.closed, maxMessageSize: self.maxMessageSize))
        if self.buffer[0] == "INVALID":
            return ChromeReadResult.new("", true, ChromeMessageReader(buffer: [], pending: false, closed: true, maxMessageSize: self.maxMessageSize))
        val frame = self.buffer[0]
        val colon = frame.index_of(":") ?? -1
        var message = frame
        if colon >= 0:
            message = frame.slice(colon + 1, frame.len())
        ChromeReadResult.new(message, false, ChromeMessageReader(buffer: dropFirstChromeNativeHost(self.buffer), pending: false, closed: self.closed, maxMessageSize: self.maxMessageSize))

    fn close() -> ChromeMessageReader:
        ChromeMessageReader(buffer: self.buffer, pending: false, closed: true, maxMessageSize: self.maxMessageSize)

class ChromeReadResult:
    message: text
    isNull: bool
    reader: ChromeMessageReader

impl ChromeReadResult:
    static fn new(message: text, isNull: bool, reader: ChromeMessageReader) -> ChromeReadResult:
        ChromeReadResult(message: message, isNull: isNull, reader: reader)

fn copyClientsChromeNativeHost(values: [McpClientModel]) -> [McpClientModel]:
    var out: [McpClientModel] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyTextChromeNativeHost(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn dropFirstChromeNativeHost(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn maxChromeMessageSize() -> i64:
    1024 * 1024

fn chromeNativeHostSourceLinesModeled() -> i64:
    527
