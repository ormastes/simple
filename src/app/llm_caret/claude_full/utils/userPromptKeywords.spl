fn matchesNegativeKeyword(input: text) -> bool:
    val lowerInput = input.lower()
    keywordContainsWord(lowerInput, "wtf") or keywordContainsWord(lowerInput, "wth") or keywordContainsWord(lowerInput, "ffs") or keywordContainsWord(lowerInput, "omfg") or keywordContainsWord(lowerInput, "dumbass") or keywordContainsWord(lowerInput, "horrible") or keywordContainsWord(lowerInput, "awful") or keywordContainsWord(lowerInput, "fuck you") or keywordContainsWord(lowerInput, "screw this") or keywordContainsWord(lowerInput, "screw you") or keywordContainsWord(lowerInput, "so frustrating") or keywordContainsWord(lowerInput, "this sucks") or keywordContainsWord(lowerInput, "damn it") or keywordContainsWord(lowerInput, "what the hell") or keywordContainsWord(lowerInput, "what the fuck") or keywordContainsWord(lowerInput, "piss off") or keywordContainsWord(lowerInput, "pissed off") or keywordContainsWord(lowerInput, "pissing off") or keywordContainsWord(lowerInput, "piece of crap") or keywordContainsWord(lowerInput, "piece of junk") or keywordContainsWord(lowerInput, "piece of shit") or keywordContainsWord(lowerInput, "shit") or keywordContainsWord(lowerInput, "shitty") or keywordContainsWord(lowerInput, "shittiest") or keywordContainsWord(lowerInput, "fucking broken") or keywordContainsWord(lowerInput, "fucking useless") or keywordContainsWord(lowerInput, "fucking terrible") or keywordContainsWord(lowerInput, "fucking awful") or keywordContainsWord(lowerInput, "fucking horrible") or keywordContainsWord(lowerInput, "fuckin broken") or keywordContainsWord(lowerInput, "fuckin useless") or keywordContainsWord(lowerInput, "fuckin terrible") or keywordContainsWord(lowerInput, "fuckin awful") or keywordContainsWord(lowerInput, "fuckin horrible")

fn matchesKeepGoingKeyword(input: text) -> bool:
    val lowerInput = input.lower().trim()
    lowerInput == "continue" or keywordContainsWord(lowerInput, "keep going") or keywordContainsWord(lowerInput, "go on")

fn keywordContainsWord(input: text, keyword: text) -> bool:
    var start = 0
    while start <= input.len() - keyword.len():
        val index = keywordFindFrom(input, keyword, start)
        if index < 0:
            return false
        val beforeOk = index == 0 or not keywordWordChar(input.slice(index - 1, index))
        val afterIndex = index + keyword.len()
        val afterOk = afterIndex >= input.len() or not keywordWordChar(input.slice(afterIndex, afterIndex + 1))
        if beforeOk and afterOk:
            return true
        start = index + 1
    false

fn keywordFindFrom(input: text, keyword: text, start: i64) -> i64:
    var i = start
    while i + keyword.len() <= input.len():
        if input.slice(i, i + keyword.len()) == keyword:
            return i
        i = i + 1
    -1

fn keywordWordChar(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "0" and ch <= "9") or ch == "_"
