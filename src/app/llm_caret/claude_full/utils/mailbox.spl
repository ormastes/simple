"""
Claude full mailbox parity surface.
"""

class MailboxMessage:
    id: text
    source: text
    content: text
    from: text
    color: text
    timestamp: text

impl MailboxMessage:
    static fn new(id: text, source: text, content: text) -> MailboxMessage:
        MailboxMessage(id: id, source: source, content: content, from: "", color: "", timestamp: "")

class Mailbox:
    queue: [MailboxMessage]
    waiters: i64
    revisionValue: i64

impl Mailbox:
    static fn new() -> Mailbox:
        Mailbox(queue: [], waiters: 0, revisionValue: 0)

    fn length() -> i64:
        self.queue.len()

    fn revision() -> i64:
        self.revisionValue

    fn send(msg: MailboxMessage) -> Mailbox:
        var queue = copyMailboxMessages(self.queue)
        var waiters = self.waiters
        if waiters > 0:
            waiters = waiters - 1
        else:
            queue.push(msg)
        Mailbox(queue: queue, waiters: waiters, revisionValue: self.revisionValue + 1)

    fn poll(source: text) -> MailboxPollResult:
        var queue: [MailboxMessage] = []
        var found = MailboxMessage.new("", "", "")
        var hit = false
        var i = 0
        while i < self.queue.len():
            if not hit and (source == "" or self.queue[i].source == source):
                found = self.queue[i]
                hit = true
            else:
                queue.push(self.queue[i])
            i = i + 1
        MailboxPollResult.new(found, hit, Mailbox(queue: queue, waiters: self.waiters, revisionValue: self.revisionValue))

    fn receive(source: text) -> Mailbox:
        val polled = self.poll(source)
        if polled.found:
            return polled.mailbox
        Mailbox(queue: self.queue, waiters: self.waiters + 1, revisionValue: self.revisionValue)

class MailboxPollResult:
    message: MailboxMessage
    found: bool
    mailbox: Mailbox

impl MailboxPollResult:
    static fn new(message: MailboxMessage, found: bool, mailbox: Mailbox) -> MailboxPollResult:
        MailboxPollResult(message: message, found: found, mailbox: mailbox)

fn copyMailboxMessages(values: [MailboxMessage]) -> [MailboxMessage]:
    var out: [MailboxMessage] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn mailboxSourceLinesModeled() -> i64: 73
