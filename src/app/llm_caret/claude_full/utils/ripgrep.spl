"""
Claude full ripgrep utility parity surface.
"""

class RipgrepConfig:
    mode: text
    command: text
    args: [text]
    argv0: text

impl RipgrepConfig:
    static fn new(mode: text, command: text, args: [text], argv0: text) -> RipgrepConfig:
        RipgrepConfig(mode: mode, command: command, args: args, argv0: argv0)

class RipgrepCommand:
    rgPath: text
    rgArgs: [text]
    argv0: text

impl RipgrepCommand:
    static fn new(rgPath: text, rgArgs: [text], argv0: text) -> RipgrepCommand:
        RipgrepCommand(rgPath: rgPath, rgArgs: rgArgs, argv0: argv0)

class RipgrepTimeoutError:
    name: text
    message: text
    partialResults: [text]

impl RipgrepTimeoutError:
    static fn new(message: text, partialResults: [text]) -> RipgrepTimeoutError:
        RipgrepTimeoutError(name: "RipgrepTimeoutError", message: message, partialResults: partialResults)

fn getRipgrepConfig() -> RipgrepConfig:
    RipgrepConfig.new("builtin", "rg", [], "")

fn ripgrepCommand() -> RipgrepCommand:
    val config = getRipgrepConfig()
    RipgrepCommand.new(config.command, config.args, config.argv0)

fn isEagainError(stderr: text) -> bool:
    stderr.contains("os error 11") or stderr.contains("Resource temporarily unavailable")

fn stripCR(value: text) -> text:
    value.replace("\r", "")

fn ripgrepTimeout(message: text, partialResults: [text]) -> RipgrepTimeoutError:
    RipgrepTimeoutError.new(message, partialResults)

fn ripgrepSourceLinesModeled() -> i64:
    679
