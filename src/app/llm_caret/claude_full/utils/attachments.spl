const CLAUDE_ATTACHMENTS_SOURCE_LINES = 3997

class FileAttachment:
    path: text
    kind: text

impl FileAttachment:
    static fn new(path: text, kind: text) -> FileAttachment:
        FileAttachment(path: path, kind: kind)

class Attachment:
    kind: text
    visible: bool

impl Attachment:
    static fn new(kind: text, visible: bool) -> Attachment:
        Attachment(kind: kind, visible: visible)

fn getAttachmentsRoute(hasPrompt: bool, hasFiles: bool, hasContext: bool) -> text:
    if hasPrompt && hasFiles && hasContext:
        return "prompt file and context attachments"
    if hasFiles:
        return "file attachments"
    if hasContext:
        return "context attachments"
    "no attachments"

fn getQueuedCommandAttachmentsRoute(hasCommand: bool, hasOutput: bool) -> text:
    if hasCommand && hasOutput:
        return "queued command with output attachments"
    if hasCommand:
        return "queued command attachment"
    "no queued command attachments"

fn getAgentPendingMessageAttachmentsRoute(hasAgent: bool, hasPending: bool) -> text:
    if hasAgent && hasPending:
        return "agent pending message attachments"
    "no agent pending attachments"

fn buildImageContentBlocksRoute(imageCount: i64, valid: bool) -> text:
    if imageCount <= 0:
        return "no image blocks"
    if !valid:
        return "invalid image skipped"
    "image content blocks"

fn modeAttachmentRoute(mode: text, sinceExitCount: i64, exiting: bool) -> text:
    if exiting:
        return mode + " mode exit attachment"
    if sinceExitCount > 0:
        return mode + " mode reminder attachment"
    "no mode attachment"

fn deltaAttachmentRoute(kind: text, addedCount: i64) -> text:
    if addedCount <= 0:
        return "no " + kind + " delta"
    kind + " delta attachment"

fn ideAttachmentRoute(hasSelectedLines: bool, hasOpenedFile: bool) -> text:
    if hasSelectedLines:
        return "selected ide lines attachment"
    if hasOpenedFile:
        return "opened ide file attachment"
    "no ide attachment"

fn atMentionRoute(kind: text, found: bool, denied: bool) -> text:
    if denied:
        return "file read denied attachment"
    if !found:
        return "missing mention skipped"
    if kind == "agent":
        return "agent mention attachment"
    if kind == "mcp":
        return "mcp resource attachment"
    "file mention attachment"

fn extractMentionRoute(kind: text, quoted: bool, duplicate: bool, invalidTrailing: bool) -> text:
    if invalidTrailing:
        return "invalid mention ignored"
    if duplicate:
        return "dedupe mention"
    if kind == "agent" && quoted:
        return "quoted agent mention"
    if kind == "agent":
        return "agent mention"
    if kind == "mcp":
        return "mcp server uri mention"
    if quoted:
        return "quoted file mention"
    "file mention"

fn memoryAttachmentRoute(nested: bool, relevant: bool, duplicate: bool) -> text:
    if duplicate:
        return "duplicate memory filtered"
    if nested:
        return "nested memory attachments"
    if relevant:
        return "relevant memory attachments"
    "no memory attachments"

fn skillAttachmentRoute(dynamic: bool, suppressed: bool, newSkills: bool) -> text:
    if suppressed:
        return "skill listing suppressed"
    if dynamic:
        return "dynamic skill attachments"
    if newSkills:
        return "new skill listing attachments"
    "no skill attachments"

fn diagnosticAttachmentRoute(hasLsp: bool, hasDiagnostics: bool) -> text:
    if !hasDiagnostics:
        return "no diagnostic attachments"
    if hasLsp && hasDiagnostics:
        return "lsp diagnostic attachments"
    "diagnostic attachments"

fn diagnosticAvailabilityRoute(hasBashTool: bool, hasDiagnostics: bool) -> text:
    if !hasBashTool:
        return "skip diagnostics without bash tool"
    if hasDiagnostics:
        return "diagnostics available"
    "no diagnostics available"

fn fileAttachmentRoute(kind: text, truncated: bool, pdf: bool, denied: bool) -> text:
    if denied:
        return "file read denied attachment"
    if kind == "compact":
        return "compact file reference attachment"
    if pdf:
        return "pdf reference attachment"
    if truncated:
        return "truncated file attachment"
    if kind == "alreadyRead":
        return "already read file attachment"
    "file attachment"

fn fileReadRoute(existingState: bool, maxTokensExceeded: bool, validInput: bool) -> text:
    if existingState:
        return "already read file attachment"
    if maxTokensExceeded:
        return "truncated file attachment"
    if !validInput:
        return "file validation error attachment"
    "read file attachment"

fn reminderAttachmentRoute(kind: text, due: bool) -> text:
    if !due:
        return "no " + kind + " reminder"
    kind + " reminder attachment"

fn reminderAvailabilityRoute(kind: text, toolAvailable: bool, briefMode: bool, due: bool) -> text:
    if !toolAvailable:
        return "skip " + kind + " reminder unavailable tool"
    if briefMode:
        return "skip " + kind + " reminder in brief"
    if due:
        return kind + " reminder attachment"
    "no " + kind + " reminder"

fn teamAttachmentRoute(mailbox: bool, context: bool, pendingIds: bool) -> text:
    if mailbox:
        return "teammate mailbox attachments"
    if context:
        return "team context attachment"
    if pendingIds:
        return "pending teammate ids"
    "no team attachments"

fn teammateMailboxRoute(hasMessages: bool, pendingIds: bool) -> text:
    if pendingIds:
        return "pending teammate mailbox ids"
    if hasMessages:
        return "teammate mailbox attachments"
    "no teammate mailbox attachments"

fn usageAttachmentRoute(kind: text, thresholdHit: bool) -> text:
    if !thresholdHit:
        return "no " + kind + " attachment"
    kind + " attachment"

fn contextEfficiencyAttachmentRoute(hasEfficiency: bool, compactDue: bool) -> text:
    if compactDue:
        return "compaction reminder attachment"
    if hasEfficiency:
        return "context efficiency attachment"
    "no context efficiency attachment"

fn isFileReadDeniedRoute(errorKind: text) -> bool:
    errorKind == "permission" || errorKind == "denied"

fn attachmentsSourceLinesModeled() -> i64:
    CLAUDE_ATTACHMENTS_SOURCE_LINES
