use app.llm_caret.claude_full.utils.envUtils.{isEnvTruthy}

fn hasEmbeddedSearchTools(embeddedSearchTools: Option<text>, entrypoint: Option<text>) -> bool:
    if not isEnvTruthy(embeddedSearchTools):
        return false
    val e = entrypoint ?? ""
    e == "" or (e != "sdk-ts" and e != "sdk-py" and e != "sdk-cli" and e != "local-agent")

fn embeddedSearchToolsBinaryPath(execPath: text) -> text:
    execPath
