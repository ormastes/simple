class StandaloneAgentContext:
    name: text
    color: text

fn getStandaloneAgentName(teamName: Option<text>, context: Option<StandaloneAgentContext>) -> Option<text>:
    if val Some(team) = teamName:
        if team != "":
            return nil
    if val Some(agent) = context:
        return Some(agent.name)
    nil
