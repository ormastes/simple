use app.llm_caret.claude_full.utils.envUtils.{isEnvDefinedFalsy, isEnvTruthy}

fn shouldIncludeGitInstructions(disableEnv: Option<text>, includeSetting: Option<bool>) -> bool:
    if isEnvTruthy(disableEnv):
        return false
    if isEnvDefinedFalsy(disableEnv):
        return true
    includeSetting ?? true
