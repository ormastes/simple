"""
Claude full IDE path conversion parity surface.
"""

class WindowsToWSLConverter:
    wslDistroName: text

impl WindowsToWSLConverter:
    static fn new(wslDistroName: text) -> WindowsToWSLConverter:
        WindowsToWSLConverter(wslDistroName: wslDistroName)

    fn toLocalPath(windowsPath: text) -> text:
        if windowsPath == "":
            return windowsPath
        if self.wslDistroName != "" and windowsPath.starts_with("\\\\wsl") and not windowsPath.contains("\\" + self.wslDistroName + "\\"):
            return windowsPath
        manualWindowsToWslPath(windowsPath)

    fn toIDEPath(wslPath: text) -> text:
        wslPath

fn checkWSLDistroMatch(windowsPath: text, wslDistroName: text) -> bool:
    if not windowsPath.starts_with("\\\\wsl"):
        return true
    windowsPath.contains("\\" + wslDistroName + "\\")

fn manualWindowsToWslPath(windowsPath: text) -> text:
    var path = windowsPath.replace("\\", "/")
    if path.len() >= 2 and path.slice(1, 2) == ":":
        val drive = path.slice(0, 1).lower()
        return "/mnt/" + drive + path.slice(2, path.len())
    path

