const SANDBOX_VIOLATIONS_OPEN = "<sandbox_violations>"
const SANDBOX_VIOLATIONS_CLOSE = "</sandbox_violations>"

fn removeSandboxViolationTags(textValue: text) -> text:
    var out = ""
    var rest = textValue
    var start = rest.find(SANDBOX_VIOLATIONS_OPEN)
    while start >= 0:
        out = out + rest.substring(0, start)
        val afterOpen = start + SANDBOX_VIOLATIONS_OPEN.len()
        val tail = rest.substring(afterOpen, rest.len())
        val end = tail.find(SANDBOX_VIOLATIONS_CLOSE)
        if end < 0:
            return out + rest.substring(start, rest.len())
        rest = tail.substring(end + SANDBOX_VIOLATIONS_CLOSE.len(), tail.len())
        start = rest.find(SANDBOX_VIOLATIONS_OPEN)
    out + rest
