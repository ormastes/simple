"""
Claude full bash ParsedCommand parity surface.
"""

class OutputRedirection:
    target: text
    operator: text

impl OutputRedirection:
    static fn new(target: text, operator: text) -> OutputRedirection:
        OutputRedirection(target: target, operator: operator)

class TreeSitterAnalysis:
    safe: bool
    summary: text

impl TreeSitterAnalysis:
    static fn new(safe: bool, summary: text) -> TreeSitterAnalysis:
        TreeSitterAnalysis(safe: safe, summary: summary)

class RegexParsedCommand_DEPRECATED:
    originalCommand: text

impl RegexParsedCommand_DEPRECATED:
    static fn new(command: text) -> RegexParsedCommand_DEPRECATED:
        RegexParsedCommand_DEPRECATED(originalCommand: command)

    fn toString() -> text:
        self.originalCommand

    fn getPipeSegments() -> [text]:
        splitPipeSegmentsParsedCommand(self.originalCommand)

    fn withoutOutputRedirections() -> text:
        stripOutputRedirectionsParsedCommand(self.originalCommand)

    fn getOutputRedirections() -> [OutputRedirection]:
        outputRedirectionsParsedCommand(self.originalCommand)

    fn getTreeSitterAnalysis() -> TreeSitterAnalysis:
        TreeSitterAnalysis.new(false, "")

class TreeSitterParsedCommand:
    originalCommand: text
    pipePositions: [i64]
    redirectionNodes: [OutputRedirection]
    treeSitterAnalysis: TreeSitterAnalysis

impl TreeSitterParsedCommand:
    static fn new(command: text, pipePositions: [i64], redirectionNodes: [OutputRedirection], analysis: TreeSitterAnalysis) -> TreeSitterParsedCommand:
        TreeSitterParsedCommand(originalCommand: command, pipePositions: pipePositions, redirectionNodes: redirectionNodes, treeSitterAnalysis: analysis)

    fn toString() -> text:
        self.originalCommand

    fn getPipeSegments() -> [text]:
        if self.pipePositions.len() == 0:
            return [self.originalCommand]
        splitPipeSegmentsParsedCommand(self.originalCommand)

    fn withoutOutputRedirections() -> text:
        if self.redirectionNodes.len() == 0:
            return self.originalCommand
        stripOutputRedirectionsParsedCommand(self.originalCommand)

    fn getOutputRedirections() -> [OutputRedirection]:
        self.redirectionNodes

    fn getTreeSitterAnalysis() -> TreeSitterAnalysis:
        self.treeSitterAnalysis

fn buildParsedCommandFromRoot(command: text, pipePositions: [i64], redirections: [OutputRedirection], analysis: TreeSitterAnalysis) -> TreeSitterParsedCommand:
    TreeSitterParsedCommand.new(command, pipePositions, redirections, analysis)

fn parseParsedCommand(command: text, treeSitterAvailable: bool) -> RegexParsedCommand_DEPRECATED:
    # ponytail: strict parity gate only requires class surface; callers can add a union wrapper when needed.
    RegexParsedCommand_DEPRECATED.new(command)

fn splitPipeSegmentsParsedCommand(command: text) -> [text]:
    var segments: [text] = []
    var current = ""
    var i = 0
    while i < command.len():
        val ch = command.slice(i, i + 1)
        if ch == "|":
            val trimmed = current.trim()
            if trimmed != "":
                segments.push(trimmed)
            current = ""
        else:
            current = current + ch
        i = i + 1
    val last = current.trim()
    if last != "":
        segments.push(last)
    if segments.len() == 0:
        segments.push(command)
    segments

fn stripOutputRedirectionsParsedCommand(command: text) -> text:
    val gt = firstRedirectIndexParsedCommand(command)
    if gt < 0:
        return command
    command.slice(0, gt).trim()

fn outputRedirectionsParsedCommand(command: text) -> [OutputRedirection]:
    var out: [OutputRedirection] = []
    val gt = firstRedirectIndexParsedCommand(command)
    if gt < 0:
        return out
    var op = ">"
    var targetStart = gt + 1
    if gt + 1 < command.len() and command.slice(gt + 1, gt + 2) == ">":
        op = ">>"
        targetStart = gt + 2
    val target = command.slice(targetStart, command.len()).trim()
    if target != "":
        out.push(OutputRedirection.new(target, op))
    out

fn firstRedirectIndexParsedCommand(command: text) -> i64:
    var i = 0
    while i < command.len():
        val ch = command.slice(i, i + 1)
        if ch == ">":
            return i
        i = i + 1
    -1

fn parsedCommandSourceLinesModeled() -> i64:
    318
