fn stripMatchedQuotes(value: text) -> text:
    if value.starts_with("\"") && value.ends_with("\"") && value.len() >= 2:
        return value.slice(1, value.len() - 1)
    if value.starts_with("'") && value.ends_with("'") && value.len() >= 2:
        return value.slice(1, value.len() - 1)
    value

fn isSimpleCommandName(value: text) -> bool:
    if value == "":
        return false
    for ch in value.chars():
        if not ((ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") || (ch >= "0" && ch <= "9") || ch == "_" || ch == "-" || ch == "." || ch == "/"):
            return false
    true

fn isHelpCommandRoute(command: text) -> bool:
    val trimmed = command.trim()
    val parts = trimmed.split(" ")
    if parts.len() != 2:
        return false
    val name = stripMatchedQuotes(parts[0].trim())
    val flag = parts[1].trim()
    isSimpleCommandName(name) && (flag == "--help" || flag == "-h")

fn filterControlOperatorsRoute(command: text) -> text:
    var out = command.replace("&&", " ")
    out = out.replace("||", " ")
    out = out.replace(";", " ")
    out = out.replace("|", " ")
    out.trim()
