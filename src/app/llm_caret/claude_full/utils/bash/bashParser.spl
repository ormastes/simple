const CLAUDE_BASH_PARSER_SOURCE_LINES = 4436

class TsNode:
    kind: text
    startByte: i64
    endByte: i64

impl TsNode:
    static fn new(kind: text, startByte: i64, endByte: i64) -> TsNode:
        TsNode(kind: kind, startByte: startByte, endByte: endByte)

class Token:
    kind: text
    textValue: text

impl Token:
    static fn new(kind: text, textValue: text) -> Token:
        Token(kind: kind, textValue: textValue)

fn nextTokenModeRoute(input: text, commandMode: bool) -> text:
    if commandMode && input.starts_with("[["):
        return "cmd mode test operator"
    if input.starts_with("[["):
        return "arg mode word token"
    if input.starts_with("<<"):
        return "heredoc redirect token"
    if input.starts_with("$("):
        return "command substitution token"
    "word token"

fn scannerWhitespaceRoute(kind: text) -> text:
    if kind == "crlf":
        return "newline token from crlf"
    if kind == "lineContinuation":
        return "skip escaped newline"
    if kind == "blank":
        return "skip blanks"
    "no whitespace"

fn checkBudgetRoute(budget: i64) -> text:
    if budget <= 0:
        return "parse budget exhausted"
    "parse budget ok"

fn parseStatementsRoute(stopToken: text) -> text:
    if stopToken == ")" || stopToken == "}" || stopToken == ";;" || stopToken == "]]" || stopToken == "]" || stopToken == "))":
        return "stop statements at closer"
    if stopToken == "#":
        return "emit comment"
    "continue statements"

fn parsePipelineRoute(op: text, rhsRedirect: bool) -> text:
    if op == "|&" && rhsRedirect:
        return "pipe stderr stdout with rhs redirect hoist"
    if op == "|&":
        return "pipe stderr stdout"
    if op == "|" && rhsRedirect:
        return "pipe with rhs redirect hoist"
    "parse command"

fn parseSimpleCommandRoute(hasAssignment: bool, hasRedirect: bool, hasFunctionPrecheck: bool) -> text:
    if hasFunctionPrecheck:
        return "function definition precheck"
    if hasAssignment && hasRedirect:
        return "simple command assignment redirect"
    if hasAssignment:
        return "simple command assignment"
    if hasRedirect:
        return "simple command redirect"
    "simple command words"

fn assignmentRoute(validName: bool, op: text, hasSubscript: bool) -> text:
    if !validName:
        return "not assignment"
    if op == "+=" && hasSubscript:
        return "append array assignment"
    if hasSubscript:
        return "array assignment"
    "scalar assignment"

fn redirectRoute(fdPrefix: bool, op: text, hasTarget: bool) -> text:
    if !hasTarget:
        return "redirect missing target"
    if fdPrefix:
        return "fd redirect greedy target"
    if op == "<>":
        return "read write redirect"
    if op == "<<-" || op == "<<":
        return "heredoc redirect pending"
    "redirect file"

fn heredocRoute(op: text, quoted: bool) -> text:
    if op == "<<-" && quoted:
        return "quoted tab stripping heredoc start"
    if op == "<<-":
        return "tab stripping heredoc start"
    if quoted:
        return "quoted heredoc start"
    "interpolated heredoc start"

fn parseWordRoute(quoted: bool, hasExpansion: bool, hasBacktick: bool, braceLike: bool) -> text:
    if quoted && hasExpansion:
        return "quoted word with expansion"
    if hasBacktick:
        return "word with backtick"
    if braceLike:
        return "word with brace boundary"
    if hasExpansion:
        return "word with expansion"
    "bare word"

fn expansionRoute(kind: text, segmented: bool) -> text:
    if kind == "arith":
        return "parse arithmetic expansion"
    if kind == "brace":
        return "parse parameter expansion"
    if kind == "regex" && segmented:
        return "parse segmented regex expansion"
    if kind == "array":
        return "parse array expansion"
    if kind == "concat":
        return "parse concatenated expansion"
    "parse expansion body"

fn controlRoute(kind: text) -> text:
    if kind == "if":
        return "parse if command"
    if kind == "while":
        return "parse while command"
    if kind == "for":
        return "parse for command"
    if kind == "case":
        return "parse case command"
    if kind == "function":
        return "parse function command"
    "parse command"

fn testExprRoute(kind: text) -> text:
    if kind == "regex":
        return "test regex rhs"
    if kind == "extglob":
        return "test extglob rhs"
    if kind == "or":
        return "test or expression"
    if kind == "and":
        return "test and expression"
    "test primary"

fn arithmeticRoute(mode: text, assign: bool, stop: text) -> text:
    if stop == "))" || stop == "]" || stop == "}":
        return "arithmetic stop boundary"
    if assign:
        return "arithmetic right associative assignment"
    if mode == "var":
        return "arithmetic variable mode"
    if mode == "word":
        return "arithmetic word mode"
    "arithmetic expression mode"

fn bashParserSourceLinesModeled() -> i64:
    CLAUDE_BASH_PARSER_SOURCE_LINES
