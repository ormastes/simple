const BASH_AST_SOURCE_LINES = 2679

fn nodeTypeIdRoute(nodeType: text) -> i64:
    if nodeType == "":
        return -2
    if nodeType == "ERROR":
        return -1
    if nodeType == "command_substitution" || nodeType == "process_substitution" || nodeType == "heredoc_redirect":
        return 1
    0

fn parseForSecurityRoute(cmd: text, parserAvailable: bool) -> text:
    if cmd.trim() == "":
        return "simple"
    if !parserAvailable:
        return "parse unavailable"
    "parse ast"

fn parseForSecurityFromAstRoute(cmd: text, rootState: text) -> text:
    if rootState == "PARSE_ABORTED":
        return "too complex parse aborted"
    if rootState == "CONTROL_CHAR":
        return "too complex control char"
    if rootState == "UNICODE_WHITESPACE":
        return "too complex unicode whitespace"
    if cmd.contains("\\ "):
        return "too complex escaped whitespace"
    if rootState == "ZSH_EXPANSION":
        return "too complex zsh expansion"
    if cmd.contains("{\"") || cmd.contains("{'"):
        return "too complex brace quote"
    "simple"

fn checkSemanticsRoute(command: text) -> text:
    val trimmed = command.trim()
    if trimmed == "":
        return "ok"
    if trimmed == "timeout 5" || trimmed == "env" || trimmed == "nice" || trimmed == "stdbuf":
        return "ok"
    if trimmed.starts_with("timeout 5 eval") || trimmed.starts_with("env eval") || trimmed.starts_with("nice eval") || trimmed.starts_with("stdbuf eval"):
        return "reject wrapper command"
    if trimmed.starts_with("eval "):
        return "reject dangerous command"
    if trimmed.starts_with("[[ -v "):
        return "reject unsafe test"
    if trimmed.starts_with("jq ") && trimmed.contains("system("):
        return "reject jq system"
    if trimmed == "if" || trimmed == "then" || trimmed == "fi" || trimmed == "for":
        return "reject shell keyword"
    "ok"

fn bashAstSourceLinesModeled() -> i64:
    BASH_AST_SOURCE_LINES
