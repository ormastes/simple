class BashCommandArgSpec:
    name: text
    description: text
    isOptional: bool
    isVariadic: bool
    isCommand: bool

    static fn new(name: text, description: text, isOptional: bool, isVariadic: bool, isCommand: bool) -> BashCommandArgSpec:
        BashCommandArgSpec(name: name, description: description, isOptional: isOptional, isVariadic: isVariadic, isCommand: isCommand)

class BashCommandSpec:
    name: text
    description: text
    args: Option<BashCommandArgSpec>

    static fn new(name: text, description: text, args: Option<BashCommandArgSpec>) -> BashCommandSpec:
        BashCommandSpec(name: name, description: description, args: args)
