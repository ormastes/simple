class BashCommandArgSpec:
    name: text
    description: text
    isOptional: bool
    isVariadic: bool

    static fn new(name: text, description: text, isOptional: bool, isVariadic: bool) -> BashCommandArgSpec:
        BashCommandArgSpec(name: name, description: description, isOptional: isOptional, isVariadic: isVariadic)

class BashCommandSpec:
    name: text
    description: text
    args: Option<BashCommandArgSpec>

    static fn new(name: text, description: text, args: Option<BashCommandArgSpec>) -> BashCommandSpec:
        BashCommandSpec(name: name, description: description, args: args)

fn aliasCommandSpec() -> BashCommandSpec:
    BashCommandSpec.new(
        "alias",
        "Create or list command aliases",
        Some(BashCommandArgSpec.new("definition", "Alias definition in the form name=value", true, true))
    )
