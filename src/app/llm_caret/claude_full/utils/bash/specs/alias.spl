use app.llm_caret.claude_full.utils.bash.specs.types.{BashCommandArgSpec, BashCommandSpec}

fn aliasCommandSpec() -> BashCommandSpec:
    BashCommandSpec.new(
        "alias",
        "Create or list command aliases",
        Some(BashCommandArgSpec.new("definition", "Alias definition in the form name=value", Some(true), Some(true), nil))
    )
