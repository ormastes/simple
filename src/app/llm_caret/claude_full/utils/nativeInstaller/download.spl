"""
Claude full native installer download parity surface.
"""

const DEFAULT_STALL_TIMEOUT_MS = 60000
const MAX_DOWNLOAD_RETRIES = 3

class StallTimeoutError:
    name: text
    message: text

impl StallTimeoutError:
    static fn new() -> StallTimeoutError:
        StallTimeoutError(name: "StallTimeoutError", message: "Download stalled: no data received for 60 seconds")

class DownloadAttempt:
    bytesReceived: i64
    checksum: text
    canceled: bool
    networkError: text

impl DownloadAttempt:
    static fn ok(bytesReceived: i64, checksum: text) -> DownloadAttempt:
        DownloadAttempt(bytesReceived: bytesReceived, checksum: checksum, canceled: false, networkError: "")

    static fn stalled() -> DownloadAttempt:
        DownloadAttempt(bytesReceived: 0, checksum: "", canceled: true, networkError: "")

    static fn failed(message: text) -> DownloadAttempt:
        DownloadAttempt(bytesReceived: 0, checksum: "", canceled: false, networkError: message)

class DownloadVerifyResult:
    ok: bool
    attempts: i64
    writtenBytes: i64
    executableMode: bool
    errorName: text
    message: text

impl DownloadVerifyResult:
    static fn success(attempts: i64, writtenBytes: i64) -> DownloadVerifyResult:
        DownloadVerifyResult(ok: true, attempts: attempts, writtenBytes: writtenBytes, executableMode: true, errorName: "", message: "")

    static fn failure(attempts: i64, errorName: text, message: text) -> DownloadVerifyResult:
        DownloadVerifyResult(ok: false, attempts: attempts, writtenBytes: 0, executableMode: false, errorName: errorName, message: message)

fn getStallTimeoutMs(envValue: i64) -> i64:
    if envValue > 0:
        return envValue
    DEFAULT_STALL_TIMEOUT_MS

fn verifyDownloadAttempt(attempt: DownloadAttempt, expectedChecksum: text) -> DownloadVerifyResult:
    if attempt.canceled:
        val err = StallTimeoutError.new()
        return DownloadVerifyResult.failure(1, err.name, err.message)
    if attempt.networkError != "":
        return DownloadVerifyResult.failure(1, "Error", attempt.networkError)
    if attempt.checksum != expectedChecksum:
        return DownloadVerifyResult.failure(1, "Error", "Checksum mismatch: expected " + expectedChecksum + ", got " + attempt.checksum)
    DownloadVerifyResult.success(1, attempt.bytesReceived)

fn downloadAndVerifyBinaryPlan(attempts: [DownloadAttempt], expectedChecksum: text) -> DownloadVerifyResult:
    var last = DownloadVerifyResult.failure(0, "Error", "No download attempts")
    var i = 0
    while i < attempts.len() and i < MAX_DOWNLOAD_RETRIES:
        val current = verifyDownloadAttempt(attempts[i], expectedChecksum)
        if current.ok:
            return DownloadVerifyResult.success(i + 1, current.writtenBytes)
        last = DownloadVerifyResult.failure(i + 1, current.errorName, current.message)
        i = i + 1
    last

fn nativeDownloadSourceLinesModeled() -> i64:
    523
