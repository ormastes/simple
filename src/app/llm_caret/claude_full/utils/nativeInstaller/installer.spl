const NATIVE_INSTALLER_SOURCE_LINES = 1708
const VERSION_RETENTION_COUNT = 3

fn getPlatformRoute(os: text, arch: text, musl: bool) -> text:
    if os == "linux" && arch == "x64":
        return "linux-x64"
    if os == "linux" && arch == "arm64" && musl:
        return "linux-arm64-musl"
    if os == "linux" && arch == "arm64":
        return "linux-arm64"
    if os == "darwin" && arch == "arm64":
        return "darwin-arm64"
    if os == "win32" && arch == "x64":
        return "win32-x64"
    "unsupported platform"

fn getBinaryNameRoute(platform: text) -> text:
    if platform.starts_with("win32"):
        return "claude.exe"
    "claude"

fn getBaseDirectoriesRoute(xdgDataHome: text, userBinDir: text) -> text:
    xdgDataHome + "/claude/versions|" + xdgDataHome + "/claude/staging|" + xdgDataHome + "/claude/locks|" + userBinDir + "/claude"

fn isPossibleClaudeBinaryRoute(filePresent: bool, byteSize: i64, executable: bool) -> bool:
    filePresent && byteSize > 0 && executable

fn getVersionPathsRoute(baseDir: text, version: text, versionFileMissing: bool) -> text:
    if versionFileMissing:
        return baseDir + "/versions/" + version + "|created-version-file|" + baseDir + "/staging/" + version
    baseDir + "/versions/" + version + "|version-file|" + baseDir + "/staging/" + version

fn removeDirectoryIfEmptyRoute(errorCode: text, empty: bool) -> text:
    if errorCode == "ENOENT" || errorCode == "ENOTDIR" || errorCode == "ENOTEMPTY":
        return "ignored"
    if empty:
        return "removed"
    "kept"

fn nativeInstallerSourceLinesModeled() -> i64:
    NATIVE_INSTALLER_SOURCE_LINES
