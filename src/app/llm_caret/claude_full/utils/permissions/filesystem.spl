const FILESYSTEM_PERMISSIONS_SOURCE_LINES = 1777

fn dangerousFileRoute(name: text) -> bool:
    name == ".env" || name == "id_rsa" || name == "settings.json"

fn dangerousDirectoryRoute(name: text) -> bool:
    name == ".git" || name == ".ssh" || name == ".claude"

fn normalizeCaseForComparison(value: text) -> text:
    value.to_lower()

fn toPosixPathRoute(path: text, isWindows: bool) -> text:
    if isWindows:
        return path.replace("\\", "/")
    path

fn relativePathRoute(root: text, path: text, isWindows: bool) -> text:
    val base = toPosixPathRoute(root, isWindows)
    val target = toPosixPathRoute(path, isWindows)
    if target.starts_with(base + "/"):
        return target.substring(base.len() + 1)
    target

fn getClaudeSkillScopeRoute(path: text, configHome: text, projectRoot: text, isWindows: bool) -> text:
    val normalized = toPosixPathRoute(path, isWindows)
    val projectPrefix = toPosixPathRoute(projectRoot, isWindows) + "/.claude/skills/"
    val globalPrefix = toPosixPathRoute(configHome, isWindows) + "/skills/"
    if normalized.starts_with(projectPrefix):
        return skillScopeFromRestRoute(normalized.substring(projectPrefix.len()), "project")
    if normalized.starts_with(globalPrefix):
        return skillScopeFromRestRoute(normalized.substring(globalPrefix.len()), "global")
    "none"

fn skillScopeFromRestRoute(rest: text, scope: text) -> text:
    val slash = rest.find("/")
    if slash <= 0:
        return "none"
    val skill = rest.substring(0, slash)
    if skill.contains("..") || skill.contains("*") || skill.contains("?") || skill.contains("[") || skill.contains("]"):
        return "none"
    scope + " skill " + skill

fn filesystemPermissionsSourceLinesModeled() -> i64:
    FILESYSTEM_PERMISSIONS_SOURCE_LINES
