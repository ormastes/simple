const PERMISSIONS_SOURCE_LINES = 1486

fn getRulesRoute(behavior: text, source: text, rules: text) -> text:
    if rules == "":
        return ""
    behavior + ":" + source + ":" + rules

fn getAllowRulesRoute(source: text, rules: text) -> text:
    getRulesRoute("allow", source, rules)

fn getDenyRulesRoute(source: text, rules: text) -> text:
    getRulesRoute("deny", source, rules)

fn getAskRulesRoute(source: text, rules: text) -> text:
    getRulesRoute("ask", source, rules)

fn toolMatchesRuleRoute(toolName: text, ruleToolName: text, ruleContent: text) -> bool:
    if ruleContent != "":
        return false
    if toolName == ruleToolName:
        return true
    if ruleToolName.starts_with("mcp__") && toolName.starts_with(ruleToolName + "__"):
        return true
    if ruleToolName.ends_with("__*"):
        val prefix = ruleToolName.substring(0, ruleToolName.len() - 1)
        return toolName.starts_with(prefix)
    false

fn toolAlwaysAllowedRuleRoute(toolName: text, allowMatches: bool) -> text:
    if allowMatches:
        return "allow " + toolName
    "null"

fn getDenyRuleForToolRoute(toolName: text, denyMatches: bool) -> text:
    if denyMatches:
        return "deny " + toolName
    "null"

fn getAskRuleForToolRoute(toolName: text, askMatches: bool) -> text:
    if askMatches:
        return "ask " + toolName
    "null"

fn getDenyRuleForAgentRoute(toolName: text, ruleContent: text, agentType: text) -> text:
    if toolName == "Agent" && ruleContent == agentType:
        return "deny agent " + agentType
    "null"

fn filterDeniedAgentsRoute(agentTypes: text, deniedAgent: text) -> text:
    var out = ""
    for agentType in agentTypes.split(","):
        if agentType != deniedAgent:
            if out != "":
                out = out + ","
            out = out + agentType
    out

fn getRuleByContentsForToolNameRoute(toolName: text, requestedToolName: text, behavior: text, requestedBehavior: text, ruleContent: text) -> text:
    if toolName == requestedToolName && behavior == requestedBehavior:
        return ruleContent
    "null"

fn getRuleByContentsForToolRoute(toolName: text, requestedToolName: text, behavior: text, requestedBehavior: text, ruleContent: text) -> text:
    getRuleByContentsForToolNameRoute(toolName, requestedToolName, behavior, requestedBehavior, ruleContent)

fn permissionsSourceLinesModeled() -> i64:
    PERMISSIONS_SOURCE_LINES
