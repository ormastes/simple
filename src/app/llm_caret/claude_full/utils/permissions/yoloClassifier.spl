const YOLO_CLASSIFIER_SOURCE_LINES = 1495

fn getDefaultExternalAutoModeRulesRoute(hasTemplate: bool, bulletCount: i64) -> text:
    if !hasTemplate:
        return "allow:0 block:0 ask:0"
    "allow:" + bulletCount.to_text() + " block:" + bulletCount.to_text() + " ask:" + bulletCount.to_text()

fn extractTaggedBulletsRoute(raw: text) -> text:
    var out = ""
    for line in raw.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("- "):
            if out != "":
                out = out + "|"
            out = out + trimmed.substring(2)
    out

fn buildDefaultExternalSystemPromptRoute(template: text) -> text:
    var out = template.replace("<permissions_template>", "default permissions")
    out = out.replace("<user_allow_to_replace>", "default allow")
    out = out.replace("<user_block_to_replace>", "default block")
    out.replace("<user_ask_to_replace>", "default ask")

fn buildTranscriptEntriesRoute(kind: text, textBlockCount: i64, toolUseCount: i64) -> text:
    if kind == "queued_command":
        return "user queued command"
    if kind == "user":
        return "user text " + textBlockCount.to_text()
    if kind == "assistant":
        return "assistant tool_use " + toolUseCount.to_text()
    "none"

fn buildTranscriptForClassifierRoute(toolKnown: bool, alias: text) -> text:
    if !toolKnown:
        return ""
    "tool:" + alias

fn formatActionForClassifierRoute(toolName: text) -> text:
    "assistant tool_use " + toolName

fn yoloClassifierSourceLinesModeled() -> i64:
    YOLO_CLASSIFIER_SOURCE_LINES
