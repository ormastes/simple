fn defaultAgentThemeColor() -> text:
    "cyan_FOR_SUBAGENTS_ONLY"

fn agentColorToThemeColor(color: text) -> Option<text>:
    if color == "red":
        return Some("red_FOR_SUBAGENTS_ONLY")
    if color == "blue":
        return Some("blue_FOR_SUBAGENTS_ONLY")
    if color == "green":
        return Some("green_FOR_SUBAGENTS_ONLY")
    if color == "yellow":
        return Some("yellow_FOR_SUBAGENTS_ONLY")
    if color == "purple":
        return Some("purple_FOR_SUBAGENTS_ONLY")
    if color == "orange":
        return Some("orange_FOR_SUBAGENTS_ONLY")
    if color == "pink":
        return Some("pink_FOR_SUBAGENTS_ONLY")
    if color == "cyan":
        return Some("cyan_FOR_SUBAGENTS_ONLY")
    nil

fn toInkColor(color: Option<text>) -> text:
    if val value = color:
        if value == "":
            return defaultAgentThemeColor()
        if val themeColor = agentColorToThemeColor(value):
            return themeColor
        return "ansi:" + value
    defaultAgentThemeColor()
