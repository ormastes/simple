"""
Claude full telemetry diagnostic logger parity surface.
"""

class ClaudeCodeDiagLogger:
    errors: [text]
    warnings: [text]
    debugMessages: [text]

impl ClaudeCodeDiagLogger:
    static fn new() -> ClaudeCodeDiagLogger:
        ClaudeCodeDiagLogger(errors: [], warnings: [], debugMessages: [])

    fn error(message: text) -> ClaudeCodeDiagLogger:
        var next = self.copy()
        next.errors.push(message)
        next.debugMessages.push("[3P telemetry] OTEL diag error: " + message)
        next

    fn warn(message: text) -> ClaudeCodeDiagLogger:
        var next = self.copy()
        next.warnings.push(message)
        next.debugMessages.push("[3P telemetry] OTEL diag warn: " + message)
        next

    fn info(message: text) -> ClaudeCodeDiagLogger:
        self

    fn debug(message: text) -> ClaudeCodeDiagLogger:
        self

    fn verbose(message: text) -> ClaudeCodeDiagLogger:
        self

    fn copy() -> ClaudeCodeDiagLogger:
        ClaudeCodeDiagLogger(errors: copyLoggerText(self.errors), warnings: copyLoggerText(self.warnings), debugMessages: copyLoggerText(self.debugMessages))

fn copyLoggerText(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn telemetryLoggerSourceLinesModeled() -> i64: 26
