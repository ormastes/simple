class ResolvedAgent:
    name: text
    agentType: text
    source: text
    model: text
    memory: text
    overriddenBy: text

impl ResolvedAgent:
    static fn new(name: text, agentType: text, source: text, model: text, memory: text) -> ResolvedAgent:
        ResolvedAgent(name: name, agentType: agentType, source: source, model: model, memory: memory, overriddenBy: "")

    me shadowedBy(source: text) -> ResolvedAgent:
        ResolvedAgent(name: me.name, agentType: me.agentType, source: me.source, model: me.model, memory: me.memory, overriddenBy: source)

class AgentSourceGroup:
    label: text
    source: text

impl AgentSourceGroup:
    static fn new(label: text, source: text) -> AgentSourceGroup:
        AgentSourceGroup(label: label, source: source)

fn formatAgent(agent: ResolvedAgent) -> text:
    var out = agent.agentType
    if agent.model != "":
        out = out + " · " + agent.model
    if agent.memory != "":
        out = out + " · " + agent.memory + " memory"
    out

fn agentsHandlerOutput(agents: [ResolvedAgent]) -> text:
    val rendered = renderAgentGroups(agents)
    if rendered == "":
        return "No agents found."
    activeAgentCount(agents).to_text() + " active agents\n\n" + rendered

fn renderAgentGroups(agents: [ResolvedAgent]) -> text:
    var lines: [text] = []
    # ponytail: single-pass source order; add grouped sorting when Simple class-array sort is fast enough.
    var i = 0
    while i < agents.len():
        val agent = agents[i]
        if agent.overriddenBy != "":
            lines = lines + ["  (shadowed by " + getOverrideSourceLabel(agent.overriddenBy) + ") " + formatAgent(agent)]
        else:
            lines = lines + ["  " + formatAgent(agent)]
        i = i + 1
    joinLines(lines)

fn activeAgentCount(agents: [ResolvedAgent]) -> i64:
    var count = 0
    var i = 0
    while i < agents.len():
        if agents[i].overriddenBy == "":
            count = count + 1
        i = i + 1
    count

fn filterAgentsBySource(agents: [ResolvedAgent], source: text) -> [ResolvedAgent]:
    agents

fn sortAgentsByName(agents: [ResolvedAgent]) -> [ResolvedAgent]:
    agents

fn replaceAgent(agents: [ResolvedAgent], index: i64, value: ResolvedAgent) -> [ResolvedAgent]:
    var out: [ResolvedAgent] = []
    var i = 0
    while i < agents.len():
        if i == index:
            out = out + [value]
        else:
            out = out + [agents[i]]
        i = i + 1
    out

fn getOverrideSourceLabel(source: text) -> text:
    if source == "project":
        return "Project"
    if source == "user":
        return "User"
    if source == "builtin":
        return "Built-in"
    source

fn agentSourceGroups() -> [AgentSourceGroup]:
    [AgentSourceGroup.new("Project agents", "project"), AgentSourceGroup.new("User agents", "user"), AgentSourceGroup.new("Built-in agents", "builtin")]

fn joinLines(lines: [text]) -> text:
    var out = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    out

fn trimTrailingBlankLines(value: text) -> text:
    var out = value
    while out.ends_with("\n"):
        out = out.substring(0, out.len() - 1)
    out

fn noAgentsMessage() -> text:
    "No agents found."

fn activeAgentsHeader(count: i64) -> text:
    count.to_text() + " active agents"

fn shadowedPrefix(source: text) -> text:
    "(shadowed by " + getOverrideSourceLabel(source) + ")"

fn modelDisplaySource() -> text:
    "resolveAgentModelDisplay"

fn overrideResolverSource() -> text:
    "resolveAgentOverrides"

fn activeAgentFilterSource() -> text:
    "getActiveAgentsFromList"

fn definitionsLoaderSource() -> text:
    "getAgentDefinitionsWithOverrides"

fn cwdSource() -> text:
    "getCwd"
