    "claude mcp remove \"" + name + "\" -s " + scope

fn removeServerFooter(name: text, scope: text) -> text:
    "To remove this server, run: " + removeSpecificScopeHint(name, scope)

fn configSourceJson() -> text:
    "json"

fn configSourceDesktop() -> text:
    "desktop"

fn defaultConfigScope() -> text:
    "local"

fn dynamicImportOnlyWhenCommandRuns() -> bool:
    true

fn listUsesGracefulShutdown() -> bool:
    true

fn getUsesGracefulShutdown() -> bool:
    true

fn serveChecksCwdBeforeSetup() -> bool:
    true

fn removeCleansSecureStorageBeforeExit() -> bool:
    true

fn addJsonReadsSecretBeforeWritingConfig() -> bool:
    true

fn desktopImportUsesKeybindingSetup() -> bool:
    true

fn resetChoicesClearsEnabledServers() -> bool:
    true

fn resetChoicesClearsDisabledServers() -> bool:
    true

fn resetChoicesDisablesEnableAllFlag() -> bool:
    true

fn connectionBatchSizeUsedForList() -> bool:
    true

fn internalSseIdeExcludedFromList() -> bool:
    true

fn cliOkUsedForMutationSuccess() -> bool:
    true

fn cliErrorUsedForUserErrors() -> bool:
    true

# Source parity notes for small inline behaviors in mcp.tsx:
# serve imports setup lazily and passes setup mode "default".
# serve defaults absent debug to false.
# serve defaults absent verbose to false.
# add-json falls back to transport type stdio.
# list renders SSE with uppercase transport label.
# list renders HTTP with uppercase transport label.
# project scope reads from .mcp.json.
# desktop import renders with exitOnCtrlC enabled.
# get prints headers one per line.
# get prints environment entries one per line.
# remove reports all matching scopes before failing.
# reset persists empty enabled and disabled project choices.

fn mcpHandlerSourceLinesModeled() -> i64:
    361
