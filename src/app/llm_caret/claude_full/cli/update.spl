fn update(currentVersion: text, latestVersion: text, autoUpdate: bool) -> text:
    if latestVersion == "" or latestVersion == currentVersion:
        return "current:" + currentVersion
    if autoUpdate:
        return "updated:" + currentVersion + "->" + latestVersion
    "available:" + latestVersion

fn updateSourceLinesModeled() -> i64:
    422

fn updateChecksCurrentVersion() -> bool:
    true

fn updateReportsAvailableVersion() -> bool:
    true
