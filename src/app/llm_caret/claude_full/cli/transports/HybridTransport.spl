const BATCH_FLUSH_INTERVAL_MS = 100
const POST_TIMEOUT_MS = 15000
const CLOSE_GRACE_MS = 3000

class HybridMessage:
    type: text
    body: text

impl HybridMessage:
    static fn new(type: text, body: text) -> HybridMessage:
        HybridMessage(type: type, body: body)

class HybridPostResult:
    status: i64
    retryable: bool
    permanent: bool
    diagnostic: text

impl HybridPostResult:
    static fn new(status: i64, retryable: bool, permanent: bool, diagnostic: text) -> HybridPostResult:
        HybridPostResult(status: status, retryable: retryable, permanent: permanent, diagnostic: diagnostic)

class HybridTransport:
    url: text
    postUrl: text
    sessionId: text
    token: text
    streamEventBuffer: [HybridMessage]
    streamEventTimerActive: bool
    queuedBatches: [[HybridMessage]]
    postedBatches: [[HybridMessage]]
    droppedBatchCount: i64
    maxConsecutiveFailures: i64
    consecutiveFailures: i64
    closed: bool
    websocketClosed: bool
    diagnostics: [text]

impl HybridTransport:
    static fn new(url: text, token: text) -> HybridTransport:
        HybridTransport(
            url: url,
            postUrl: convertWsUrlToPostUrl(url),
            sessionId: "",
            token: token,
            streamEventBuffer: [],
            streamEventTimerActive: false,
            queuedBatches: [],
            postedBatches: [],
            droppedBatchCount: 0,
            maxConsecutiveFailures: 0,
            consecutiveFailures: 0,
            closed: false,
            websocketClosed: false,
            diagnostics: ["cli_hybrid_transport_initialized"]
        )

    static fn withFailureCap(url: text, token: text, maxConsecutiveFailures: i64) -> HybridTransport:
        val transport = HybridTransport.new(url, token)
        transport.maxConsecutiveFailures = maxConsecutiveFailures
        transport

    me write(message: HybridMessage) -> ():
        if me.closed:
            return
        if message.type == "stream_event":
            me.streamEventBuffer.push(message)
            if not me.streamEventTimerActive:
                me.streamEventTimerActive = true
            return
        var batch = me.takeStreamEvents()
        batch.push(message)
        me.enqueueBatch(batch)
        me.flush()

    me writeBatch(messages: [HybridMessage]) -> ():
        if me.closed:
            return
        var batch = me.takeStreamEvents()
        var i = 0
        while i < messages.len():
            batch.push(messages[i])
            i = i + 1
        me.enqueueBatch(batch)
        me.flush()

    me flush() -> ():
        val buffered = me.takeStreamEvents()
        if buffered.len() > 0:
            me.enqueueBatch(buffered)
        while me.queuedBatches.len() > 0:
            val batch = me.queuedBatches[0]
            me.queuedBatches = dropFirstBatch(me.queuedBatches)
            me.postedBatches.push(batch)

    me flushStreamEvents() -> ():
        me.streamEventTimerActive = false
        val batch = me.takeStreamEvents()
        if batch.len() > 0:
            me.enqueueBatch(batch)

    me close() -> ():
        if me.closed:
            return
        me.streamEventTimerActive = false
        me.streamEventBuffer = []
        me.flush()
        me.closed = true
        me.websocketClosed = true
        me.diagnostics.push("cli_hybrid_transport_closed")

    me takeStreamEvents() -> [HybridMessage]:
        me.streamEventTimerActive = false
        val buffered = me.streamEventBuffer
        me.streamEventBuffer = []
        buffered

    me enqueueBatch(batch: [HybridMessage]) -> ():
        if batch.len() == 0:
            return
        me.queuedBatches.push(batch)

    me postOnceStatus(status: i64) -> HybridPostResult:
        if me.token == "":
            me.diagnostics.push("cli_hybrid_post_no_token")
            return HybridPostResult.new(status, false, true, "no-token")
        if status >= 200 and status < 300:
            me.consecutiveFailures = 0
            me.diagnostics.push("cli_hybrid_post_success")
            return HybridPostResult.new(status, false, false, "success")
        if status >= 400 and status < 500 and status != 429:
            me.consecutiveFailures = 0
            me.diagnostics.push("cli_hybrid_post_client_error")
            return HybridPostResult.new(status, false, true, "permanent")
        me.consecutiveFailures = me.consecutiveFailures + 1
        me.diagnostics.push("cli_hybrid_post_retryable_error")
        if me.maxConsecutiveFailures > 0 and me.consecutiveFailures >= me.maxConsecutiveFailures:
            me.droppedBatchCount = me.droppedBatchCount + 1
            me.diagnostics.push("cli_hybrid_batch_dropped_max_failures")
        HybridPostResult.new(status, true, false, "retryable")

    me pendingStreamCount() -> i64:
        me.streamEventBuffer.len()

    me queuedBatchCount() -> i64:
        me.queuedBatches.len()

    me postedBatchCount() -> i64:
        me.postedBatches.len()

    me firstPostedTypes() -> text:
        if me.postedBatches.len() == 0:
            return ""
        joinMessageTypes(me.postedBatches[0])

    me firstQueuedTypes() -> text:
        if me.queuedBatches.len() == 0:
            return ""
        joinMessageTypes(me.queuedBatches[0])

fn hybridTransportNew(url: text, token: text) -> HybridTransport:
    HybridTransport.new(url, token)

fn hybridMessage(type: text, body: text) -> HybridMessage:
    HybridMessage.new(type, body)

fn convertWsUrlToPostUrl(wsUrl: text) -> text:
    var protocol = "http:"
    if wsUrl.starts_with("wss:"):
        protocol = "https:"
    var rest = wsUrl
    if rest.starts_with("wss://"):
        rest = rest.slice(6, rest.len())
    if rest.starts_with("ws://"):
        rest = rest.slice(5, rest.len())
    var pathStart = rest.find("/")
    if pathStart < 0:
        return protocol + "//" + rest + "/events"
    val host = rest.slice(0, pathStart)
    var path = rest.slice(pathStart, rest.len())
    var query = ""
    val queryStart = path.find("?")
    if queryStart >= 0:
        query = path.slice(queryStart, path.len())
        path = path.slice(0, queryStart)
    path = path.replace("/ws/", "/session/")
    if not path.ends_with("/events"):
        if path.ends_with("/"):
            path = path + "events"
        else:
            path = path + "/events"
    protocol + "//" + host + path + query

fn dropFirstBatch(batches: [[HybridMessage]]) -> [[HybridMessage]]:
    var out: [[HybridMessage]] = []
    var i = 1
    while i < batches.len():
        out.push(batches[i])
        i = i + 1
    out

fn joinMessageTypes(messages: [HybridMessage]) -> text:
    var out = ""
    var i = 0
    while i < messages.len():
        if i > 0:
            out = out + ","
        out = out + messages[i].type
        i = i + 1
    out

fn hybridBatchFlushIntervalMs() -> i64:
    BATCH_FLUSH_INTERVAL_MS

fn hybridPostTimeoutMs() -> i64:
    POST_TIMEOUT_MS

fn hybridCloseGraceMs() -> i64:
    CLOSE_GRACE_MS

# Source parity note: WebSocketTransport supplies reads while this class owns
# stdout writes via HTTP POST. The Simple model keeps that split visible through
# websocketClosed, postUrl, queuedBatches, and postedBatches.
# Source parity note: stream_event messages are delayed for
# BATCH_FLUSH_INTERVAL_MS and batched together until a timer, flush, close, or
# non-stream write takes ownership of the buffer.
# Source parity note: non-stream writes flush pending stream events first, then
# enqueue the triggering message in the same batch to preserve order.
# Source parity note: writeBatch also drains pending stream events before the
# explicit batch, matching the TypeScript spread of takeStreamEvents().
# Source parity note: close clears the stream timer and buffer, attempts a final
# drain, then closes the inherited WebSocket side synchronously.
# Source parity note: postOnce returns normally for missing tokens and permanent
# non-429 4xx responses so the uploader can move on without retry storms.
# Source parity note: 429 and 5xx responses are retryable and increment the
# consecutive failure counter used by the dropped-batch cap.
# Source parity note: POST_TIMEOUT_MS bounds a single POST attempt; the model
# exposes the constant for SSpec without sleeping.
# Source parity note: CLOSE_GRACE_MS is a best-effort drain window; the model
# records close rather than running timers.
# Source parity note: convertWsUrlToPostUrl preserves host, path, and query while
# translating ws/wss protocols and /ws/ to /session/.
