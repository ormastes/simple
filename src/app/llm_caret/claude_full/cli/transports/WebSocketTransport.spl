const KEEP_ALIVE_FRAME = "{\"type\":\"keep_alive\"}\n"
const DEFAULT_MAX_BUFFER_SIZE = 1000
const DEFAULT_BASE_RECONNECT_DELAY = 1000
const DEFAULT_MAX_RECONNECT_DELAY = 30000
const DEFAULT_RECONNECT_GIVE_UP_MS = 600000
const DEFAULT_PING_INTERVAL = 10000
const DEFAULT_KEEPALIVE_INTERVAL = 300000
const SLEEP_DETECTION_THRESHOLD_MS = DEFAULT_MAX_RECONNECT_DELAY * 2

class WebSocketMessage:
    type: text
    uuid: text
    subtype: text
    request_id: text
    tool_name: text

impl WebSocketMessage:
    static fn new(type: text, uuid: text) -> WebSocketMessage:
        WebSocketMessage(type: type, uuid: uuid, subtype: "", request_id: "", tool_name: "")

    static fn controlRequest(uuid: text, subtype: text, requestId: text, toolName: text) -> WebSocketMessage:
        WebSocketMessage(type: "control_request", uuid: uuid, subtype: subtype, request_id: requestId, tool_name: toolName)

class WebSocketTransport:
    url: text
    headers: [text]
    sessionId: text
    autoReconnect: bool
    isBridge: bool
    state: text
    lastSentId: text
    reconnectAttempts: i64
    reconnectStartTime: i64
    lastReconnectAttemptTime: i64
    lastActivityTime: i64
    reconnectTimerActive: bool
    pingIntervalActive: bool
    keepAliveIntervalActive: bool
    pongReceived: bool
    messageBuffer: [WebSocketMessage]
    sentLines: [text]
    closeCodes: [i64]
    dataMessages: [text]
    connectCount: i64
    closeCallbackCount: i64
    diagnostics: [text]

impl WebSocketTransport:
    static fn new(url: text, headers: [text], sessionId: text) -> WebSocketTransport:
        WebSocketTransport.withOptions(url, headers, sessionId, true, false)

    static fn withOptions(url: text, headers: [text], sessionId: text, autoReconnect: bool, isBridge: bool) -> WebSocketTransport:
        WebSocketTransport(
            url: url,
            headers: headers,
            sessionId: sessionId,
            autoReconnect: autoReconnect,
            isBridge: isBridge,
            state: "idle",
            lastSentId: "",
            reconnectAttempts: 0,
            reconnectStartTime: 0,
            lastReconnectAttemptTime: 0,
            lastActivityTime: 0,
            reconnectTimerActive: false,
            pingIntervalActive: false,
            keepAliveIntervalActive: false,
            pongReceived: true,
            messageBuffer: [],
            sentLines: [],
            closeCodes: [],
            dataMessages: [],
            connectCount: 0,
            closeCallbackCount: 0,
            diagnostics: []
        )

    me connect(nowMs: i64) -> nil:
        if me.state != "idle" and me.state != "reconnecting":
            me.diagnostics.push("cli_websocket_connect_failed")
            return
        me.state = "reconnecting"
        me.connectCount = me.connectCount + 1
        me.diagnostics.push("cli_websocket_connect_opening")

    me open(nowMs: i64, serverLastId: text) -> nil:
        me.diagnostics.push("cli_websocket_connect_connected")
        me.reconnectAttempts = 0
        me.reconnectStartTime = 0
        me.lastReconnectAttemptTime = 0
        me.lastActivityTime = nowMs
        me.state = "connected"
        me.startPingInterval()
        me.startKeepaliveInterval(false)
        if serverLastId != "" or me.lastSentId != "":
            me.replayBufferedMessages(serverLastId)

    me receive(message: text, nowMs: i64) -> nil:
        me.lastActivityTime = nowMs
        me.dataMessages.push(message)
        me.diagnostics.push("cli_websocket_message_received")

    me write(message: WebSocketMessage) -> nil:
        if message.uuid != "":
            me.addBuffered(message)
            me.lastSentId = message.uuid
        if me.state != "connected":
            return
        val line = serializeMessage(message)
        me.sendLine(line)

    me sendLine(line: text) -> bool:
        if me.state != "connected":
            me.diagnostics.push("cli_websocket_send_not_connected")
            return false
        me.sentLines.push(line)
        return true

    me handleConnectionError(closeCode: i64, nowMs: i64, refreshedAuthorization: text) -> nil:
        me.diagnostics.push("cli_websocket_disconnected")
        me.doDisconnect()
        if me.state == "closing" or me.state == "closed":
            return
        var headersRefreshed = false
        if closeCode == 4003 and refreshedAuthorization != "" and refreshedAuthorization != authorizationHeader(me.headers):
            me.headers = replaceAuthorization(me.headers, refreshedAuthorization)
            headersRefreshed = true
            me.diagnostics.push("cli_websocket_4003_token_refreshed")
        if isPermanentCloseCode(closeCode) and not headersRefreshed:
            me.state = "closed"
            me.closeCallbackCount = me.closeCallbackCount + 1
            me.closeCodes.push(closeCode)
            me.diagnostics.push("cli_websocket_permanent_close")
            return
        if not me.autoReconnect:
            me.state = "closed"
            me.closeCallbackCount = me.closeCallbackCount + 1
            me.closeCodes.push(closeCode)
            return
        if me.reconnectStartTime == 0:
            me.reconnectStartTime = nowMs
        if me.lastReconnectAttemptTime != 0 and nowMs - me.lastReconnectAttemptTime > SLEEP_DETECTION_THRESHOLD_MS:
            me.reconnectStartTime = nowMs
            me.reconnectAttempts = 0
            me.diagnostics.push("cli_websocket_sleep_detected")
        me.lastReconnectAttemptTime = nowMs
        val elapsed = nowMs - me.reconnectStartTime
        if elapsed < DEFAULT_RECONNECT_GIVE_UP_MS:
            me.state = "reconnecting"
            me.reconnectAttempts = me.reconnectAttempts + 1
            me.reconnectTimerActive = true
            me.diagnostics.push("cli_websocket_reconnect_attempt")
        else:
            me.state = "closed"
            me.closeCallbackCount = me.closeCallbackCount + 1
            me.closeCodes.push(closeCode)
            me.diagnostics.push("cli_websocket_reconnect_exhausted")

    me close() -> nil:
        me.reconnectTimerActive = false
        me.stopPingInterval()
        me.stopKeepaliveInterval()
        me.state = "closing"
        me.doDisconnect()

    me doDisconnect() -> nil:
        me.stopPingInterval()
        me.stopKeepaliveInterval()

    me replayBufferedMessages(lastId: text) -> nil:
        if me.messageBuffer.len() == 0:
            return
        var startIndex = 0
        if lastId != "":
            val confirmed = findMessageUuid(me.messageBuffer, lastId)
            if confirmed >= 0:
                startIndex = confirmed + 1
                me.messageBuffer = sliceMessages(me.messageBuffer, startIndex)
                if me.messageBuffer.len() == 0:
                    me.lastSentId = ""
                me.diagnostics.push("cli_websocket_evicted_confirmed_messages")
        val messagesToReplay = sliceMessagesFromOriginal(me.messageBuffer, 0)
        if messagesToReplay.len() == 0:
            me.diagnostics.push("cli_websocket_no_messages_to_replay")
            return
        me.diagnostics.push("cli_websocket_messages_to_replay")
        var i = 0
        while i < messagesToReplay.len():
            if not me.sendLine(serializeMessage(messagesToReplay[i])):
                me.handleConnectionError(0, me.lastActivityTime, "")
                return
            i = i + 1

    me tickPing(gapMs: i64) -> nil:
        if me.state != "connected":
            return
        if gapMs > SLEEP_DETECTION_THRESHOLD_MS:
            me.diagnostics.push("cli_websocket_sleep_detected_on_ping")
            me.handleConnectionError(0, me.lastActivityTime + gapMs, "")
            return
        if not me.pongReceived:
            me.diagnostics.push("cli_websocket_pong_timeout")
            me.handleConnectionError(0, me.lastActivityTime + gapMs, "")
            return
        me.pongReceived = false

    me pong() -> nil:
        me.pongReceived = true

    me startPingInterval() -> nil:
        me.pingIntervalActive = true
        me.pongReceived = true

    me stopPingInterval() -> nil:
        me.pingIntervalActive = false

    me startKeepaliveInterval(isRemote: bool) -> nil:
        if isRemote:
            me.keepAliveIntervalActive = false
        else:
            me.keepAliveIntervalActive = true

    me stopKeepaliveInterval() -> nil:
        me.keepAliveIntervalActive = false

    me addBuffered(message: WebSocketMessage) -> nil:
        me.messageBuffer.push(message)
        while me.messageBuffer.len() > DEFAULT_MAX_BUFFER_SIZE:
            me.messageBuffer = sliceMessages(me.messageBuffer, 1)

    me isConnectedStatus() -> bool:
        me.state == "connected"

    me isClosedStatus() -> bool:
        me.state == "closed"

    me getStateLabel() -> text:
        me.state

fn webSocketTransportNew(url: text, headers: [text], sessionId: text) -> WebSocketTransport:
    WebSocketTransport.new(url, headers, sessionId)

fn webSocketMessage(type: text, uuid: text) -> WebSocketMessage:
    WebSocketMessage.new(type, uuid)

fn isPermanentCloseCode(code: i64) -> bool:
    code == 1002 or code == 4001 or code == 4003

fn reconnectDelayMs(attempts: i64, jitterPct: i64) -> i64:
    val base = minI64(DEFAULT_BASE_RECONNECT_DELAY * pow2(attempts - 1), DEFAULT_MAX_RECONNECT_DELAY)
    base + (base * jitterPct / 100)

fn getControlMessageDetailLabel(message: WebSocketMessage) -> text:
    if message.type == "control_request":
        var tool = ""
        if message.subtype == "can_use_tool" and message.tool_name != "":
            tool = " tool=" + message.tool_name
        return " subtype=" + message.subtype + " request_id=" + message.request_id + tool
    if message.type == "control_response":
        return " subtype=" + message.subtype + " request_id=" + message.request_id
    ""

fn serializeMessage(message: WebSocketMessage) -> text:
    if message.uuid == "":
        return "{\"type\":\"" + message.type + "\"}\n"
    "{\"type\":\"" + message.type + "\",\"uuid\":\"" + message.uuid + "\"}\n"

fn findMessageUuid(messages: [WebSocketMessage], uuid: text) -> i64:
    var i = 0
    while i < messages.len():
        if messages[i].uuid == uuid:
            return i
        i = i + 1
    -1

fn sliceMessages(messages: [WebSocketMessage], start: i64) -> [WebSocketMessage]:
    var out: [WebSocketMessage] = []
    var i = start
    while i < messages.len():
        out.push(messages[i])
        i = i + 1
    out

fn sliceMessagesFromOriginal(messages: [WebSocketMessage], start: i64) -> [WebSocketMessage]:
    sliceMessages(messages, start)

fn authorizationHeader(headers: [text]) -> text:
    var i = 0
    while i < headers.len():
        if headers[i].starts_with("Authorization="):
            return headers[i]
        i = i + 1
    ""

fn replaceAuthorization(headers: [text], value: text) -> [text]:
    var out: [text] = []
    var replaced = false
    var i = 0
    while i < headers.len():
        if headers[i].starts_with("Authorization="):
            out.push(value)
            replaced = true
        else:
            out.push(headers[i])
        i = i + 1
    if not replaced:
        out.push(value)
    out

fn pow2(exp: i64) -> i64:
    var out = 1
    var i = 0
    while i < exp:
        out = out * 2
        i = i + 1
    out

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn keepAliveFrame() -> text:
    KEEP_ALIVE_FRAME

fn defaultMaxBufferSize() -> i64:
    DEFAULT_MAX_BUFFER_SIZE

fn defaultBaseReconnectDelayMs() -> i64:
    DEFAULT_BASE_RECONNECT_DELAY

fn defaultMaxReconnectDelayMs() -> i64:
    DEFAULT_MAX_RECONNECT_DELAY

fn defaultReconnectGiveUpMs() -> i64:
    DEFAULT_RECONNECT_GIVE_UP_MS

fn defaultPingIntervalMs() -> i64:
    DEFAULT_PING_INTERVAL

fn defaultKeepaliveIntervalMs() -> i64:
    DEFAULT_KEEPALIVE_INTERVAL

fn sleepDetectionThresholdMs() -> i64:
    SLEEP_DETECTION_THRESHOLD_MS

fn webSocketTransportSourceLinesModeled() -> i64:
    660

# Source parity note: constructor defaults autoReconnect true and isBridge false.
# Source parity note: connect only starts from idle or reconnecting.
# Source parity note: open resets reconnect counters and starts ping and keepalive.
# Source parity note: inbound messages update lastActivityTime and call onData.
# Source parity note: write buffers UUID messages and records lastSentId.
# Source parity note: disconnected writes are buffered but not sent.
# Source parity note: connected writes serialize JSON with a newline.
# Source parity note: send failure routes through handleConnectionError.
# Source parity note: doDisconnect stops ping and keepalive state.
# Source parity note: permanent close codes close without retry.
# Source parity note: 4003 may refresh authorization and reconnect.
# Source parity note: autoReconnect false closes immediately.
# Source parity note: reconnect attempts use an exponential capped delay.
# Source parity note: reconnect gives up after the time budget.
# Source parity note: sleep gaps reset the reconnect budget.
# Source parity note: close clears reconnect timer and moves to closing.
# Source parity note: replay evicts messages confirmed by x-last-request-id.
# Source parity note: replay keeps unconfirmed messages buffered.
# Source parity note: Bun reconnect replays all buffered messages.
# Source parity note: ping tick forces reconnect after sleep gap.
# Source parity note: missing pong forces reconnect.
# Source parity note: pong marks the connection healthy.
# Source parity note: keepalive is a data frame, not a ping frame.
# Source parity note: remote CCR sessions skip periodic keepalive.
# Source parity note: control request diagnostics include subtype and request id.
