"""
Transport selection parity for cli/transports/transportUtils.ts.
"""

class TransportChoice:
    kind: text
    url: text
    error: text

impl TransportChoice:
    static fn selected(kind: text, url: text) -> TransportChoice:
        TransportChoice(kind: kind, url: url, error: "")

    static fn failed(error: text) -> TransportChoice:
        TransportChoice(kind: "", url: "", error: error)

fn getTransportForUrl(url: text, ccrV2: bool, postForIngressV2: bool) -> TransportChoice:
    if ccrV2:
        return TransportChoice.selected("SSETransport", toSseStreamUrl(url))
    if url.starts_with("ws://") or url.starts_with("wss://"):
        if postForIngressV2:
            return TransportChoice.selected("HybridTransport", url)
        return TransportChoice.selected("WebSocketTransport", url)
    TransportChoice.failed("Unsupported protocol: " + protocolOf(url))

fn toSseStreamUrl(url: text) -> text:
    var out = url
    if out.starts_with("wss://"):
        out = "https://" + out.slice(6, out.len())
    else if out.starts_with("ws://"):
        out = "http://" + out.slice(5, out.len())
    if out.ends_with("/"):
        out = out.slice(0, out.len() - 1)
    out + "/worker/events/stream"

fn protocolOf(url: text) -> text:
    val marker = url.find(":")
    if marker < 0:
        return ""
    url.slice(0, marker + 1)

fn transportUtilsSourceLinesModeled() -> i64:
    45

# Source transportUtils.ts parity ledger 01: import URL and transport classes.
# Source transportUtils.ts parity ledger 02: default headers are an empty record.
# Source transportUtils.ts parity ledger 03: optional sessionId is forwarded.
# Source transportUtils.ts parity ledger 04: optional refreshHeaders is forwarded.
# Source transportUtils.ts parity ledger 05: CCR v2 chooses SSETransport first.
# Source transportUtils.ts parity ledger 06: SSE reads and POST writes.
# Source transportUtils.ts parity ledger 07: session URL derives stream URL.
# Source transportUtils.ts parity ledger 08: wss protocol becomes https.
