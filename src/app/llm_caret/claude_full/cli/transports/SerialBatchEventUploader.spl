class RetryableError:
    message: text
    retryAfterMs: i64

impl RetryableError:
    static fn new(message: text, retryAfterMs: i64) -> RetryableError:
        RetryableError(message: message, retryAfterMs: retryAfterMs)

class SerialUploaderConfig:
    maxBatchSize: i64
    maxBatchBytes: i64
    maxQueueSize: i64
    baseDelayMs: i64
    maxDelayMs: i64
    jitterMs: i64
    maxConsecutiveFailures: i64

impl SerialUploaderConfig:
    static fn new(maxBatchSize: i64, maxQueueSize: i64) -> SerialUploaderConfig:
        SerialUploaderConfig(maxBatchSize: maxBatchSize, maxBatchBytes: 0, maxQueueSize: maxQueueSize, baseDelayMs: 100, maxDelayMs: 1000, jitterMs: 0, maxConsecutiveFailures: 0)

class SerialBatchEventUploader:
    config: SerialUploaderConfig
    pending: [text]
    pendingAtClose: i64
    draining: bool
    closed: bool
    backpressureResolvers: i64
    sleepResolve: bool
    flushResolvers: i64
    droppedBatches: i64
    sentBatches: [[text]]
    dropLog: [text]

impl SerialBatchEventUploader:
    static fn new(config: SerialUploaderConfig) -> SerialBatchEventUploader:
        SerialBatchEventUploader(config: config, pending: [], pendingAtClose: 0, draining: false, closed: false, backpressureResolvers: 0, sleepResolve: false, flushResolvers: 0, droppedBatches: 0, sentBatches: [], dropLog: [])

    me droppedBatchCount() -> i64:
        me.droppedBatches

    me pendingCount() -> i64:
        if me.closed:
            return me.pendingAtClose
        me.pending.len()

    me enqueueOne(event: text) -> ():
        me.enqueue([event])

    me enqueue(events: [text]) -> ():
        if me.closed or events.len() == 0:
            return
        if me.pending.len() + events.len() > me.config.maxQueueSize:
            me.backpressureResolvers = me.backpressureResolvers + 1
            return
        var i = 0
        while i < events.len():
            me.pending.push(events[i])
            i = i + 1

    me flushSuccess() -> ():
        if me.closed:
            return
        me.draining = true
        while me.pending.len() > 0 and not me.closed:
            val batch = me.takeBatch()
            if batch.len() > 0:
                me.sentBatches.push(batch)
            me.releaseBackpressure()
        me.draining = false
        me.flushResolvers = 0

    me failOnce(retryAfterMs: i64, jitterValue: i64) -> i64:
        if me.closed:
            return 0
        val batch = me.takeBatch()
        if batch.len() == 0:
            return 0
        val failures = 1
        me.pending = concatText(batch, me.pending)
        me.sleepResolve = true
        retryDelay(me.config, failures, retryAfterMs, jitterValue)

    me failUntilDropped(failures: i64) -> ():
        if me.config.maxConsecutiveFailures == 0:
            return
        val batch = me.takeBatch()
        if batch.len() == 0:
            return
        if failures >= me.config.maxConsecutiveFailures:
            me.droppedBatches = me.droppedBatches + 1
            me.dropLog.push(batch.len().to_text() + ":" + failures.to_text())
            me.releaseBackpressure()
        else:
            me.pending = concatText(batch, me.pending)

    me close() -> ():
        if me.closed:
            return
        me.closed = true
        me.pendingAtClose = me.pending.len()
        me.pending = []
        me.sleepResolve = false
        me.backpressureResolvers = 0
        me.flushResolvers = 0

    me flush() -> ():
        if me.pending.len() == 0 and not me.draining:
            return
        me.flushResolvers = me.flushResolvers + 1

    me takeBatch() -> [text]:
        var batch: [text] = []
        var remaining: [text] = []
        var bytes = 0
        var i = 0
        while i < me.pending.len():
            val item = me.pending[i]
            val itemBytes = jsonBytes(item)
            if item == "UNSERIALIZABLE":
                i = i + 1
                continue
            if batch.len() < me.config.maxBatchSize and (me.config.maxBatchBytes == 0 or batch.len() == 0 or bytes + itemBytes <= me.config.maxBatchBytes):
                batch.push(item)
                bytes = bytes + itemBytes
            else:
                remaining.push(item)
            i = i + 1
        me.pending = remaining
        batch

    me releaseBackpressure() -> ():
        me.backpressureResolvers = 0

    me firstSentBatchText() -> text:
        if me.sentBatches.len() == 0:
            return ""
        joinText(me.sentBatches[0])

fn serialUploaderConfig(maxBatchSize: i64, maxQueueSize: i64, baseDelayMs: i64, maxDelayMs: i64, jitterMs: i64) -> SerialUploaderConfig:
    SerialUploaderConfig(maxBatchSize: maxBatchSize, maxBatchBytes: 0, maxQueueSize: maxQueueSize, baseDelayMs: baseDelayMs, maxDelayMs: maxDelayMs, jitterMs: jitterMs, maxConsecutiveFailures: 0)

fn serialUploaderWithByteLimit(maxBatchSize: i64, maxBatchBytes: i64, maxQueueSize: i64) -> SerialBatchEventUploader:
    SerialBatchEventUploader.new(SerialUploaderConfig(maxBatchSize: maxBatchSize, maxBatchBytes: maxBatchBytes, maxQueueSize: maxQueueSize, baseDelayMs: 100, maxDelayMs: 1000, jitterMs: 0, maxConsecutiveFailures: 0))

fn retryDelay(config: SerialUploaderConfig, failures: i64, retryAfterMs: i64, jitterValue: i64) -> i64:
    var base = minI64(config.baseDelayMs * pow2(failures - 1), config.maxDelayMs)
    if retryAfterMs > 0:
        base = maxI64(config.baseDelayMs, minI64(retryAfterMs, config.maxDelayMs))
    base + minI64(jitterValue, config.jitterMs)

fn jsonBytes(value: text) -> i64:
    value.len() + 2

fn concatText(prefix: [text], suffix: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < prefix.len():
        out.push(prefix[i])
        i = i + 1
    var j = 0
    while j < suffix.len():
        out.push(suffix[j])
        j = j + 1
    out

fn joinText(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + ","
        out = out + values[i]
        i = i + 1
    out

fn pow2(exp: i64) -> i64:
    var out = 1
    var i = 0
    while i < exp:
        out = out * 2
        i = i + 1
    out

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn maxI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn serialUploaderSourceLinesModeled() -> i64:
    275

# Source parity note: enqueue appends one or many events unless closed.
# Source parity note: enqueue blocks via backpressure when queue capacity would overflow.
# Source parity note: drain is guarded so only one send loop runs at a time.
# Source parity note: takeBatch respects maxBatchSize.
# Source parity note: takeBatch respects maxBatchBytes after always accepting the first item.
# Source parity note: unserializable items are dropped so flush cannot hang forever.
# Source parity note: failed batches are requeued at the front.
# Source parity note: RetryableError retryAfterMs overrides exponential backoff after clamping.
# Source parity note: jitter is added after the retry delay base is selected.
# Source parity note: maxConsecutiveFailures drops the failing batch and advances.
# Source parity note: droppedBatchCount is monotonic.
# Source parity note: close snapshots pendingCount before clearing pending.
# Source parity note: close resolves backpressure, sleep, and flush waiters.
# Source parity note: flush resolves immediately when queue is empty and not draining.
# Source parity note: successful sends release backpressure waiters.
