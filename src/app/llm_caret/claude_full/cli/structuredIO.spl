class StructuredIO:
    inputBlocks: [text]
    replayUserMessages: bool
    pendingRequestIds: [text]
    pendingRequestSubtypes: [text]
    pendingToolUseIds: [text]
    resolvedToolUseIds: [text]
    prependedLines: [text]
    outbound: [text]
    yieldedMessages: [text]
    rejectedRequests: [text]
    resolvedRequests: [text]
    lifecycleReports: [text]
    unexpectedResponses: [text]
    environmentUpdates: [text]
    inputClosed: bool
    unexpectedResponseCallbackSet: bool
    onControlRequestSentSet: bool
    onControlRequestResolvedSet: bool
    restoredWorkerState: text

impl StructuredIO:
    static fn new(inputBlocks: [text], replayUserMessages: bool) -> StructuredIO:
        StructuredIO(inputBlocks: inputBlocks, replayUserMessages: replayUserMessages, pendingRequestIds: [], pendingRequestSubtypes: [], pendingToolUseIds: [], resolvedToolUseIds: [], prependedLines: [], outbound: [], yieldedMessages: [], rejectedRequests: [], resolvedRequests: [], lifecycleReports: [], unexpectedResponses: [], environmentUpdates: [], inputClosed: false, unexpectedResponseCallbackSet: false, onControlRequestSentSet: false, onControlRequestResolvedSet: false, restoredWorkerState: "null")

    me prependUserMessage(content: text) -> nil:
        me.prependedLines.push("user|" + content)

    me readAll() -> [text]:
        var content = ""
        var emitted: [text] = []
        emitted = me.drainPrepended(content, emitted)
        content = ""
        var i = 0
        while i < me.inputBlocks.len():
            content = content + me.inputBlocks[i]
            val split = me.drainCompleteLines(content, emitted)
            content = split.remaining
            emitted = split.messages
            i = i + 1
        if content != "":
            val message = me.processLine(content)
            if message != "":
                emitted.push(message)
        me.inputClosed = true
        i = 0
        while i < me.pendingRequestIds.len():
            me.rejectedRequests.push(me.pendingRequestIds[i] + ":Tool permission stream closed before response received")
            i = i + 1
        me.yieldedMessages = emitted
        emitted

    me drainPrepended(content: text, emitted: [text]) -> [text]:
        var out = emitted
        var i = 0
        while i < me.prependedLines.len():
            val message = me.processLine(me.prependedLines[i])
            if message != "":
                out.push(message)
            i = i + 1
        me.prependedLines = []
        out

    me drainCompleteLines(content: text, emitted: [text]) -> LineDrain:
        var rest = content
        var out = emitted
        while rest.contains("\n"):
            val parts = splitOnce(rest, "\n")
            val message = me.processLine(parts.left)
            if message != "":
                out.push(message)
            rest = parts.right
            out = me.drainPrepended(rest, out)
        LineDrain(remaining: rest, messages: out)

    me processLine(line: text) -> text:
        if line == "":
            return ""
        if messageType(line) == "keep_alive":
            return ""
        if messageType(line) == "update_environment_variables":
            me.environmentUpdates.push(messagePayload(line))
            return ""
        if messageType(line) == "control_response":
            return me.processControlResponse(line)
        if messageType(line) == "control_request":
            if not line.contains("|"):
                return "exit:Error: Missing request on control_request"
            return line
        if messageType(line) == "assistant" or messageType(line) == "system":
            return line
        if messageType(line) == "user":
            return line
        ""

    me processControlResponse(line: text) -> text:
        val requestId = controlResponseRequestId(line)
        val uuid = controlResponseUuid(line)
        if uuid != "":
            me.lifecycleReports.push(uuid + ":completed")
        val index = indexOfText(me.pendingRequestIds, requestId)
        if index < 0:
            val toolUseId = controlResponseToolUseId(line)
            if toolUseId != "" and containsText(me.resolvedToolUseIds, toolUseId):
                return ""
            if me.unexpectedResponseCallbackSet:
                me.unexpectedResponses.push(line)
            return ""
        me.trackResolvedToolUseIdByIndex(index)
        removeAt(me.pendingRequestIds, index)
        removeAt(me.pendingRequestSubtypes, index)
        removeAt(me.pendingToolUseIds, index)
        if me.onControlRequestResolvedSet:
            me.resolvedRequests.push(requestId)
        if controlResponseSubtype(line) == "error":
            me.rejectedRequests.push(requestId + ":" + controlResponseError(line))
            return ""
        me.resolvedRequests.push(requestId + ":" + controlResponsePayload(line))
        if me.replayUserMessages:
            return line
        ""

    me setUnexpectedResponseCallback(enabled: bool) -> nil:
        me.unexpectedResponseCallbackSet = enabled

    me setOnControlRequestSent(enabled: bool) -> nil:
        me.onControlRequestSentSet = enabled

    me setOnControlRequestResolved(enabled: bool) -> nil:
        me.onControlRequestResolvedSet = enabled

    me getPendingPermissionRequests() -> [text]:
        var out: [text] = []
        var i = 0
        while i < me.pendingRequestIds.len():
            if me.pendingRequestSubtypes[i] == "can_use_tool":
                out.push(me.pendingRequestIds[i])
            i = i + 1
        out

    me injectControlResponse(line: text) -> nil:
        val requestId = controlResponseRequestId(line)
        val index = indexOfText(me.pendingRequestIds, requestId)
        if index < 0:
            return
        me.trackResolvedToolUseIdByIndex(index)
        removeAt(me.pendingRequestIds, index)
        removeAt(me.pendingRequestSubtypes, index)
        removeAt(me.pendingToolUseIds, index)
        me.outbound.push("control_cancel_request|" + requestId)
        if controlResponseSubtype(line) == "error":
            me.rejectedRequests.push(requestId + ":" + controlResponseError(line))
        else:
            me.resolvedRequests.push(requestId + ":" + controlResponsePayload(line))

    me sendRequest(subtype: text, requestId: text, toolUseId: text, aborted: bool) -> text:
        if me.inputClosed:
            return "error:Stream closed"
        if aborted:
            return "error:Request aborted"
        me.pendingRequestIds.push(requestId)
        me.pendingRequestSubtypes.push(subtype)
        me.pendingToolUseIds.push(toolUseId)
        me.outbound.push("control_request|" + requestId + "|" + subtype)
        if subtype == "can_use_tool" and me.onControlRequestSentSet:
            me.resolvedRequests.push("sent:" + requestId)
        "pending:" + requestId

    me abortRequest(requestId: text) -> nil:
        val index = indexOfText(me.pendingRequestIds, requestId)
        if index < 0:
            return
        me.outbound.push("control_cancel_request|" + requestId)
        me.trackResolvedToolUseIdByIndex(index)
        me.rejectedRequests.push(requestId + ":AbortError")

    me trackResolvedToolUseIdByIndex(index: i64) -> nil:
        if index < 0 or index >= me.pendingToolUseIds.len():
            return
        val toolUseId = me.pendingToolUseIds[index]
        if toolUseId == "":
            return
        me.resolvedToolUseIds.push(toolUseId)
        while me.resolvedToolUseIds.len() > MAX_RESOLVED_TOOL_USE_IDS:
            removeAt(me.resolvedToolUseIds, 0)

    me flushInternalEvents() -> text:
        "resolved"

    me internalEventsPending() -> i64:
        0

    me write(message: text) -> nil:
        me.outbound.push(ndjsonSafeStringifyText(message))

    me createCanUseTool(toolName: text, toolUseId: text, forceDecision: text, hookDecision: text, sdkDecision: text) -> text:
        if forceDecision == "allow" or forceDecision == "deny":
            return forceDecision
        if hookDecision == "allow" or hookDecision == "deny":
            return hookDecision
        if sdkDecision == "allow":
            return "allow"
        if sdkDecision == "deny":
            return "deny"
        "deny"

    me createHookCallback(callbackId: text, input: text, result: text, fails: bool) -> text:
        if fails:
            return "{}"
        callbackId + ":" + input + ":" + result

    me handleElicitation(serverName: text, message: text, action: text, fails: bool) -> text:
        if fails:
            return "cancel"
        serverName + ":" + message + ":" + action

    me createSandboxAskCallback(host: text, sdkDecision: text) -> bool:
        me.sendRequest("can_use_tool", "sandbox:" + host, host, false)
        sdkDecision == "allow"

    me sendMcpMessage(serverName: text, message: text, response: text) -> text:
        me.sendRequest("mcp_message", "mcp:" + serverName, "", false)
        response

class LineDrain:
    remaining: text
    messages: [text]

class SplitPair:
    left: text
    right: text

fn splitOnce(value: text, separator: text) -> SplitPair:
    val parts = value.split(separator)
    if parts.len() == 0:
        return SplitPair(left: value, right: "")
    var right = ""
    var i = 1
    while i < parts.len():
        if i > 1:
            right = right + separator
        right = right + parts[i]
        i = i + 1
    SplitPair(left: parts[0], right: right)

fn messageType(line: text) -> text:
    partOrEmpty(line.split("|"), 0)

fn messagePayload(line: text) -> text:
    partOrEmpty(line.split("|"), 1)

fn controlResponseRequestId(line: text) -> text:
    partOrEmpty(line.split("|"), 1)

fn controlResponseSubtype(line: text) -> text:
    partOrEmpty(line.split("|"), 2)

fn controlResponsePayload(line: text) -> text:
    partOrEmpty(line.split("|"), 3)

fn controlResponseToolUseId(line: text) -> text:
    partOrEmpty(line.split("|"), 4)

fn controlResponseUuid(line: text) -> text:
    partOrEmpty(line.split("|"), 5)

fn controlResponseError(line: text) -> text:
    partOrEmpty(line.split("|"), 3)

fn partOrEmpty(parts: [text], index: i64) -> text:
    if index < 0 or index >= parts.len():
        return ""
    parts[index]

fn indexOfText(values: [text], needle: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return i
        i = i + 1
    -1

fn containsText(values: [text], needle: text) -> bool:
    indexOfText(values, needle) >= 0

fn removeAt(values: [text], index: i64) -> nil:
    if index < 0 or index >= values.len():
        return
    var i = index
    while i + 1 < values.len():
        values[i] = values[i + 1]
        i = i + 1
    values.pop()

fn serializeDecisionReason(reasonType: text, reason: text, classifierFeatureEnabled: bool) -> text:
    if reasonType == "":
        return ""
    if classifierFeatureEnabled and reasonType == "classifier":
        return reason
    if reasonType == "hook" or reasonType == "asyncAgent" or reasonType == "sandboxOverride" or reasonType == "workingDir" or reasonType == "safetyCheck" or reasonType == "other":
        return reason
    ""

fn buildRequiresActionDetails(toolName: text, activityDescription: text, summary: text, userFacingName: text, toolUseId: text, requestId: text, input: text, descriptionThrows: bool) -> [text]:
    var description = toolName
    if not descriptionThrows:
        if activityDescription != "":
            description = activityDescription
        else:
            if summary != "":
                description = summary
            else:
                description = userFacingName
    [toolName, description, toolUseId, requestId, input]

fn executePermissionRequestHooksForSDK(toolName: text, toolUseId: text, input: text, hookBehavior: text, updatedInput: text, updateCount: i64) -> text:
    if hookBehavior == "allow":
        val finalInput = if updatedInput != "": updatedInput else: input
        return "allow|" + finalInput + "|updates:" + updateCount.to_text() + "|reason:hook"
    if hookBehavior == "deny":
        return "deny|Permission denied by PermissionRequest hook|reason:hook"
    ""

fn ndjsonSafeStringifyText(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == " ":
            out = out + "\\u2028"
        else:
            if ch == " ":
                out = out + "\\u2029"
            else:
                out = out + ch
        i = i + 1
    out

fn sandboxNetworkAccessToolName() -> text:
    SANDBOX_NETWORK_ACCESS_TOOL_NAME

fn maxResolvedToolUseIds() -> i64:
    MAX_RESOLVED_TOOL_USE_IDS

fn structuredIoSourceLinesModeled() -> i64:
    859

fn structuredIoClassSourceLine() -> i64:
    135

fn duplicateControlResponsesAreIgnored() -> bool:
    true

fn pendingRequestsRejectOnInputClose() -> bool:
    true

fn prependedLinesAreReadBeforeInput() -> bool:
    true

fn keepAliveMessagesAreIgnored() -> bool:
    true

fn environmentUpdatesAreApplied() -> bool:
    true

fn controlResponsesCanReplayWhenEnabled() -> bool:
    true

fn sdkPromptRacesPermissionHooks() -> bool:
    true

fn sandboxAskUsesCanUseToolProtocol() -> bool:
    true

fn hookCallbackFallsBackToEmptyObject() -> bool:
    true

fn elicitationFailureCancels() -> bool:
    true

fn mcpMessageReturnsNestedResponse() -> bool:
    true
