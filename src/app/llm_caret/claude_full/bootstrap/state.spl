"""
Claude full bootstrap state parity surface.
"""

class ChannelEntry:
    kind: text
    name: text
    marketplace: text
    dev: bool

impl ChannelEntry:
    static fn plugin(name: text, marketplace: text, dev: bool) -> ChannelEntry:
        ChannelEntry(kind: "plugin", name: name, marketplace: marketplace, dev: dev)

    static fn server(name: text, dev: bool) -> ChannelEntry:
        ChannelEntry(kind: "server", name: name, marketplace: "", dev: dev)

class SessionCronTask:
    id: text
    schedule: text
    command: text

impl SessionCronTask:
    static fn new(id: text, schedule: text, command: text) -> SessionCronTask:
        SessionCronTask(id: id, schedule: schedule, command: command)

class ModelUsage:
    inputTokens: i64
    outputTokens: i64
    cacheReadInputTokens: i64
    cacheCreationInputTokens: i64
    webSearchRequests: i64

impl ModelUsage:
    static fn new() -> ModelUsage:
        ModelUsage(inputTokens: 0, outputTokens: 0, cacheReadInputTokens: 0, cacheCreationInputTokens: 0, webSearchRequests: 0)

    fn add(inputTokens: i64, outputTokens: i64, cacheRead: i64, cacheCreate: i64, webSearch: i64) -> ModelUsage:
        ModelUsage(
            inputTokens: self.inputTokens + inputTokens,
            outputTokens: self.outputTokens + outputTokens,
            cacheReadInputTokens: self.cacheReadInputTokens + cacheRead,
            cacheCreationInputTokens: self.cacheCreationInputTokens + cacheCreate,
            webSearchRequests: self.webSearchRequests + webSearch,
        )

class ModelUsageEntry:
    model: text
    usage: ModelUsage

impl ModelUsageEntry:
    static fn new(model: text, usage: ModelUsage) -> ModelUsageEntry:
        ModelUsageEntry(model: model, usage: usage)

class InvokedSkill:
    key: text
    skillName: text
    skillPath: text
    content: text
    invokedAt: i64
    agentId: text

impl InvokedSkill:
    static fn new(key: text, skillName: text, skillPath: text, content: text, invokedAt: i64, agentId: text) -> InvokedSkill:
        InvokedSkill(key: key, skillName: skillName, skillPath: skillPath, content: content, invokedAt: invokedAt, agentId: agentId)

class ClaudeFullState:
    originalCwd: text
    projectRoot: text
    cwd: text
    sessionId: text
    parentSessionId: text
    sessionProjectDir: text
    totalCostUSD: i64
    totalAPIDuration: i64
    totalAPIDurationWithoutRetries: i64
    totalToolDuration: i64
    turnHookDurationMs: i64
    turnToolDurationMs: i64
    turnClassifierDurationMs: i64
    turnHookCount: i64
    turnToolCount: i64
    turnClassifierCount: i64
    totalLinesAdded: i64
    totalLinesRemoved: i64
    hasUnknownModelCostValue: bool
    modelUsage: [ModelUsageEntry]
    turnOutputTokenSnapshot: i64
    currentTurnTokenBudget: i64
    budgetContinuationCount: i64
    isInteractive: bool
    kairosActive: bool
    strictToolResultPairing: bool
    sdkAgentProgressSummariesEnabled: bool
    userMsgOptIn: bool
    clientType: text
    sessionSource: text
    questionPreviewFormat: text
    allowedSettingSources: [text]
    sessionIngressToken: text
    oauthTokenFromFd: text
    apiKeyFromFd: text
    meterSet: bool
    loggerProviderSet: bool
    eventLoggerSet: bool
    meterProviderSet: bool
    tracerProviderSet: bool
    statsStoreSet: bool
    agentColorMap: [AgentColorEntry]
    agentColorIndex: i64
    lastAPIRequestId: text
    lastApiCompletionTimestamp: i64
    postCompaction: bool
    cachedClaudeMdContent: text
    inMemoryErrorLog: [text]
    inlinePlugins: [text]
    chromeFlagOverride: text
    useCoworkPlugins: bool
    sessionBypassPermissionsMode: bool
    scheduledTasksEnabled: bool
    sessionCronTasks: [SessionCronTask]
    sessionCreatedTeams: [text]
    sessionTrustAccepted: bool
    sessionPersistenceDisabled: bool
    hasExitedPlanMode: bool
    needsPlanModeExitAttachmentValue: bool
    needsAutoModeExitAttachmentValue: bool
    lspRecommendationShownThisSession: bool
    initJsonSchemaSet: bool
    registeredHooks: [RegisteredHook]
    planSlugCache: [PlanSlugEntry]
    teleportedSessionId: text
    teleportedFirstMessageLogged: bool
    invokedSkills: [InvokedSkill]
    slowOperations: [SlowOperation]
    sdkBetas: [text]
    mainThreadAgentType: text
    isRemoteMode: bool
    directConnectServerUrl: text
    systemPromptSectionCache: [PlanSlugEntry]
    lastEmittedDate: text
    additionalDirectoriesForClaudeMd: [text]
    allowedChannels: [ChannelEntry]
    hasDevChannels: bool

impl ClaudeFullState:
    static fn new(originalCwd: text, sessionId: text) -> ClaudeFullState:
        ClaudeFullState(
            originalCwd: originalCwd,
            projectRoot: originalCwd,
            cwd: originalCwd,
            sessionId: sessionId,
            parentSessionId: "",
            sessionProjectDir: "",
            totalCostUSD: 0,
            totalAPIDuration: 0,
            totalAPIDurationWithoutRetries: 0,
            totalToolDuration: 0,
            turnHookDurationMs: 0,
            turnToolDurationMs: 0,
            turnClassifierDurationMs: 0,
            turnHookCount: 0,
            turnToolCount: 0,
            turnClassifierCount: 0,
            totalLinesAdded: 0,
            totalLinesRemoved: 0,
            hasUnknownModelCostValue: false,
            modelUsage: [],
            turnOutputTokenSnapshot: 0,
            currentTurnTokenBudget: -1,
            budgetContinuationCount: 0,
            isInteractive: true,
            kairosActive: false,
            strictToolResultPairing: false,
            sdkAgentProgressSummariesEnabled: false,
            userMsgOptIn: false,
            clientType: "cli",
            sessionSource: "",
            questionPreviewFormat: "",
            allowedSettingSources: [],
            sessionIngressToken: "",
            oauthTokenFromFd: "",
            apiKeyFromFd: "",
            meterSet: false,
            loggerProviderSet: false,
            eventLoggerSet: false,
            meterProviderSet: false,
            tracerProviderSet: false,
            statsStoreSet: false,
            agentColorMap: [],
            agentColorIndex: 0,
            lastAPIRequestId: "",
            lastApiCompletionTimestamp: -1,
            postCompaction: false,
            cachedClaudeMdContent: "",
            inMemoryErrorLog: [],
            inlinePlugins: [],
            chromeFlagOverride: "",
            useCoworkPlugins: false,
            sessionBypassPermissionsMode: false,
            scheduledTasksEnabled: false,
            sessionCronTasks: [],
            sessionCreatedTeams: [],
            sessionTrustAccepted: false,
            sessionPersistenceDisabled: false,
            hasExitedPlanMode: false,
            needsPlanModeExitAttachmentValue: false,
            needsAutoModeExitAttachmentValue: false,
            lspRecommendationShownThisSession: false,
            initJsonSchemaSet: false,
            registeredHooks: [],
            planSlugCache: [],
            teleportedSessionId: "",
            teleportedFirstMessageLogged: false,
            invokedSkills: [],
            slowOperations: [],
            sdkBetas: [],
            mainThreadAgentType: "",
            isRemoteMode: false,
            directConnectServerUrl: "",
            systemPromptSectionCache: [],
            lastEmittedDate: "",
            additionalDirectoriesForClaudeMd: [],
            allowedChannels: [],
            hasDevChannels: false,
        )

    fn switchSession(sessionId: text, parentSessionId: text, sessionProjectDir: text) -> ClaudeFullState:
        var next = self.copy()
        next.parentSessionId = parentSessionId
        next.sessionId = sessionId
        next.sessionProjectDir = sessionProjectDir
        next

    fn regenerateSessionId(sessionId: text) -> ClaudeFullState:
        var next = self.copy()
        next.parentSessionId = self.sessionId
        next.sessionId = sessionId
        next

    fn setOriginalCwd(value: text) -> ClaudeFullState:
        var next = self.copy()
        next.originalCwd = value
        next

    fn setProjectRoot(value: text) -> ClaudeFullState:
        var next = self.copy()
        next.projectRoot = value
        next

    fn setCwdState(value: text) -> ClaudeFullState:
        var next = self.copy()
        next.cwd = value
        next

    fn setDirectConnectServerUrl(url: text) -> ClaudeFullState:
        var next = self.copy()
        next.directConnectServerUrl = url
        next

    fn addToTotalDurationState(apiDuration: i64, apiDurationWithoutRetries: i64) -> ClaudeFullState:
        var next = self.copy()
        next.totalAPIDuration = next.totalAPIDuration + apiDuration
        next.totalAPIDurationWithoutRetries = next.totalAPIDurationWithoutRetries + apiDurationWithoutRetries
        next

    fn addToTotalCostState(costUsdCents: i64) -> ClaudeFullState:
        var next = self.copy()
        next.totalCostUSD = next.totalCostUSD + costUsdCents
        next

    fn addToToolDuration(duration: i64) -> ClaudeFullState:
        var next = self.copy()
        next.totalToolDuration = next.totalToolDuration + duration
        next.turnToolDurationMs = next.turnToolDurationMs + duration
        next.turnToolCount = next.turnToolCount + 1
        next

    fn addToTurnHookDuration(duration: i64) -> ClaudeFullState:
        var next = self.copy()
        next.turnHookDurationMs = next.turnHookDurationMs + duration
        next.turnHookCount = next.turnHookCount + 1
        next

    fn addToTurnClassifierDuration(duration: i64) -> ClaudeFullState:
        var next = self.copy()
        next.turnClassifierDurationMs = next.turnClassifierDurationMs + duration
        next.turnClassifierCount = next.turnClassifierCount + 1
        next

    fn resetTurnDurations() -> ClaudeFullState:
        var next = self.copy()
        next.turnHookDurationMs = 0
        next.turnToolDurationMs = 0
        next.turnClassifierDurationMs = 0
        next.turnHookCount = 0
        next.turnToolCount = 0
        next.turnClassifierCount = 0
        next

    fn addToTotalLinesChanged(added: i64, removed: i64) -> ClaudeFullState:
        var next = self.copy()
        next.totalLinesAdded = next.totalLinesAdded + added
        next.totalLinesRemoved = next.totalLinesRemoved + removed
        next

    fn addModelUsage(model: text, usage: ModelUsage) -> ClaudeFullState:
        var next = self.copy()
        var found = false
        var i = 0
        while i < next.modelUsage.len():
            if next.modelUsage[i].model == model:
                next.modelUsage[i] = ModelUsageEntry.new(model, next.modelUsage[i].usage.add(usage.inputTokens, usage.outputTokens, usage.cacheReadInputTokens, usage.cacheCreationInputTokens, usage.webSearchRequests))
                found = true
            i = i + 1
        if not found:
            next.modelUsage.push(ModelUsageEntry.new(model, usage))
        next

    fn getUsageForModel(model: text) -> ModelUsage:
        var i = 0
        while i < self.modelUsage.len():
            if self.modelUsage[i].model == model:
                return self.modelUsage[i].usage
            i = i + 1
        ModelUsage.new()

    fn getTotalInputTokens() -> i64:
        var total = 0
        var i = 0
        while i < self.modelUsage.len():
            total = total + self.modelUsage[i].usage.inputTokens
            i = i + 1
        total

    fn getTotalOutputTokens() -> i64:
        var total = 0
        var i = 0
        while i < self.modelUsage.len():
            total = total + self.modelUsage[i].usage.outputTokens
            i = i + 1
        total

    fn snapshotOutputTokensForTurn(budget: i64) -> ClaudeFullState:
        var next = self.copy()
        next.turnOutputTokenSnapshot = self.getTotalOutputTokens()
        next.currentTurnTokenBudget = budget
        next

    fn getTurnOutputTokens() -> i64:
        self.getTotalOutputTokens() - self.turnOutputTokenSnapshot

    fn incrementBudgetContinuationCount() -> ClaudeFullState:
        var next = self.copy()
        next.budgetContinuationCount = next.budgetContinuationCount + 1
        next

    fn setHasUnknownModelCost() -> ClaudeFullState:
        var next = self.copy()
        next.hasUnknownModelCostValue = true
        next

    fn resetCostState() -> ClaudeFullState:
        var next = self.copy()
        next.totalCostUSD = 0
        next.hasUnknownModelCostValue = false
        next.modelUsage = []
        next

    fn setTelemetryProviders(meter: bool, loggerProvider: bool, eventLogger: bool, meterProvider: bool, tracerProvider: bool) -> ClaudeFullState:
        var next = self.copy()
        next.meterSet = meter
        next.loggerProviderSet = loggerProvider
        next.eventLoggerSet = eventLogger
        next.meterProviderSet = meterProvider
        next.tracerProviderSet = tracerProvider
        next

    fn setInteractive(value: bool) -> ClaudeFullState:
        var next = self.copy()
        next.isInteractive = value
        next

    fn getIsNonInteractiveSession() -> bool:
        not self.isInteractive

    fn setClientType(value: text) -> ClaudeFullState:
        var next = self.copy()
        next.clientType = value
        next

    fn setSessionSource(value: text) -> ClaudeFullState:
        var next = self.copy()
        next.sessionSource = value
        next

    fn addAgentColor(agentId: text, color: text) -> ClaudeFullState:
        var next = self.copy()
        next.agentColorMap.push(AgentColorEntry.new(agentId, color))
        next.agentColorIndex = next.agentColorIndex + 1
        next

    fn addError(error: text, timestamp: text) -> ClaudeFullState:
        var next = self.copy()
        next.inMemoryErrorLog.push(timestamp + " " + error)
        while next.inMemoryErrorLog.len() > 20:
            next.inMemoryErrorLog = dropFirstText(next.inMemoryErrorLog)
        next

    fn setInlinePlugins(plugins: [text]) -> ClaudeFullState:
        var next = self.copy()
        next.inlinePlugins = copyTextListState(plugins)
        next

    fn setAllowedSettingSources(sources: [text]) -> ClaudeFullState:
        var next = self.copy()
        next.allowedSettingSources = copyTextListState(sources)
        next

    fn preferThirdPartyAuthentication() -> bool:
        containsTextState(self.allowedSettingSources, "project") and not containsTextState(self.allowedSettingSources, "user")

    fn setSessionFlags(bypass: bool, scheduled: bool, trust: bool, persistenceDisabled: bool) -> ClaudeFullState:
        var next = self.copy()
        next.sessionBypassPermissionsMode = bypass
        next.scheduledTasksEnabled = scheduled
        next.sessionTrustAccepted = trust
        next.sessionPersistenceDisabled = persistenceDisabled
        next

    fn addSessionCronTask(task: SessionCronTask) -> ClaudeFullState:
        var next = self.copy()
        next.sessionCronTasks.push(task)
        next

    fn removeSessionCronTasks(ids: [text]) -> ClaudeFullState:
        var next = self.copy()
        var remaining: [SessionCronTask] = []
        var i = 0
        while i < next.sessionCronTasks.len():
            if not containsTextState(ids, next.sessionCronTasks[i].id):
                remaining.push(next.sessionCronTasks[i])
            i = i + 1
        next.sessionCronTasks = remaining
        next

    fn addSessionCreatedTeam(team: text) -> ClaudeFullState:
        var next = self.copy()
        if not containsTextState(next.sessionCreatedTeams, team):
            next.sessionCreatedTeams.push(team)
        next

    fn removeSessionCreatedTeam(team: text) -> ClaudeFullState:
        var next = self.copy()
        var remaining: [text] = []
        var i = 0
        while i < next.sessionCreatedTeams.len():
            if next.sessionCreatedTeams[i] != team:
                remaining.push(next.sessionCreatedTeams[i])
            i = i + 1
        next.sessionCreatedTeams = remaining
        next

    fn handlePlanModeTransition(exited: bool) -> ClaudeFullState:
        var next = self.copy()
        next.hasExitedPlanMode = exited
        next.needsPlanModeExitAttachmentValue = exited
        next

    fn setRegisteredHooks(eventName: text, matchers: [text]) -> ClaudeFullState:
        var next = self.copy()
        next.registeredHooks.push(RegisteredHook.new(eventName, matchers))
        next

    fn cachePlanSlug(sessionId: text, slug: text) -> ClaudeFullState:
        var next = self.copy()
        next.planSlugCache.push(PlanSlugEntry.new(sessionId, slug))
        next

    fn setTeleportedSession(sessionId: text) -> ClaudeFullState:
        var next = self.copy()
        next.teleportedSessionId = sessionId
        next.teleportedFirstMessageLogged = false
        next

    fn logTeleportedFirstMessage() -> ClaudeFullState:
        var next = self.copy()
        next.teleportedFirstMessageLogged = true
        next

    fn addInvokedSkill(skillName: text, skillPath: text, content: text, invokedAt: i64, agentId: text) -> ClaudeFullState:
        var next = self.copy()
        val key = agentId + ":" + skillName
        next.invokedSkills.push(InvokedSkill.new(key, skillName, skillPath, content, invokedAt, agentId))
        next

    fn addSlowOperation(operation: text, durationMs: i64, timestamp: i64) -> ClaudeFullState:
        var next = self.copy()
        next.slowOperations.push(SlowOperation.new(operation, durationMs, timestamp))
        next

    fn setSdkBetas(betas: [text]) -> ClaudeFullState:
        var next = self.copy()
        next.sdkBetas = copyTextListState(betas)
        next

    fn setRemoteMode(value: bool) -> ClaudeFullState:
        var next = self.copy()
        next.isRemoteMode = value
        next

    fn setSystemPromptSection(key: text, value: text) -> ClaudeFullState:
        var next = self.copy()
        next.systemPromptSectionCache.push(PlanSlugEntry.new(key, value))
        next

    fn addAdditionalDirectoryForClaudeMd(path: text) -> ClaudeFullState:
        var next = self.copy()
        next.additionalDirectoriesForClaudeMd.push(path)
        next

    fn setAllowedChannels(entries: [ChannelEntry]) -> ClaudeFullState:
        var next = self.copy()
        next.allowedChannels = copyChannelEntries(entries)
        next.hasDevChannels = hasDevChannel(entries)
        next

    fn resetStateForTests() -> ClaudeFullState:
        ClaudeFullState.new(self.originalCwd, self.sessionId)

    fn copy() -> ClaudeFullState:
        ClaudeFullState(
            originalCwd: self.originalCwd,
            projectRoot: self.projectRoot,
            cwd: self.cwd,
            sessionId: self.sessionId,
            parentSessionId: self.parentSessionId,
            sessionProjectDir: self.sessionProjectDir,
            totalCostUSD: self.totalCostUSD,
            totalAPIDuration: self.totalAPIDuration,
            totalAPIDurationWithoutRetries: self.totalAPIDurationWithoutRetries,
            totalToolDuration: self.totalToolDuration,
            turnHookDurationMs: self.turnHookDurationMs,
            turnToolDurationMs: self.turnToolDurationMs,
            turnClassifierDurationMs: self.turnClassifierDurationMs,
            turnHookCount: self.turnHookCount,
            turnToolCount: self.turnToolCount,
            turnClassifierCount: self.turnClassifierCount,
            totalLinesAdded: self.totalLinesAdded,
            totalLinesRemoved: self.totalLinesRemoved,
            hasUnknownModelCostValue: self.hasUnknownModelCostValue,
            modelUsage: copyModelUsageEntries(self.modelUsage),
            turnOutputTokenSnapshot: self.turnOutputTokenSnapshot,
            currentTurnTokenBudget: self.currentTurnTokenBudget,
            budgetContinuationCount: self.budgetContinuationCount,
            isInteractive: self.isInteractive,
            kairosActive: self.kairosActive,
            strictToolResultPairing: self.strictToolResultPairing,
            sdkAgentProgressSummariesEnabled: self.sdkAgentProgressSummariesEnabled,
            userMsgOptIn: self.userMsgOptIn,
            clientType: self.clientType,
            sessionSource: self.sessionSource,
            questionPreviewFormat: self.questionPreviewFormat,
            allowedSettingSources: copyTextListState(self.allowedSettingSources),
            sessionIngressToken: self.sessionIngressToken,
            oauthTokenFromFd: self.oauthTokenFromFd,
            apiKeyFromFd: self.apiKeyFromFd,
            meterSet: self.meterSet,
            loggerProviderSet: self.loggerProviderSet,
            eventLoggerSet: self.eventLoggerSet,
            meterProviderSet: self.meterProviderSet,
            tracerProviderSet: self.tracerProviderSet,
            statsStoreSet: self.statsStoreSet,
            agentColorMap: copyAgentColorEntries(self.agentColorMap),
            agentColorIndex: self.agentColorIndex,
            lastAPIRequestId: self.lastAPIRequestId,
            lastApiCompletionTimestamp: self.lastApiCompletionTimestamp,
            postCompaction: self.postCompaction,
            cachedClaudeMdContent: self.cachedClaudeMdContent,
            inMemoryErrorLog: copyTextListState(self.inMemoryErrorLog),
            inlinePlugins: copyTextListState(self.inlinePlugins),
            chromeFlagOverride: self.chromeFlagOverride,
            useCoworkPlugins: self.useCoworkPlugins,
            sessionBypassPermissionsMode: self.sessionBypassPermissionsMode,
            scheduledTasksEnabled: self.scheduledTasksEnabled,
            sessionCronTasks: copySessionCronTasks(self.sessionCronTasks),
            sessionCreatedTeams: copyTextListState(self.sessionCreatedTeams),
            sessionTrustAccepted: self.sessionTrustAccepted,
            sessionPersistenceDisabled: self.sessionPersistenceDisabled,
            hasExitedPlanMode: self.hasExitedPlanMode,
            needsPlanModeExitAttachmentValue: self.needsPlanModeExitAttachmentValue,
            needsAutoModeExitAttachmentValue: self.needsAutoModeExitAttachmentValue,
            lspRecommendationShownThisSession: self.lspRecommendationShownThisSession,
            initJsonSchemaSet: self.initJsonSchemaSet,
            registeredHooks: copyRegisteredHooks(self.registeredHooks),
            planSlugCache: copyPlanSlugEntries(self.planSlugCache),
            teleportedSessionId: self.teleportedSessionId,
            teleportedFirstMessageLogged: self.teleportedFirstMessageLogged,
            invokedSkills: copyInvokedSkills(self.invokedSkills),
            slowOperations: copySlowOperations(self.slowOperations),
            sdkBetas: copyTextListState(self.sdkBetas),
            mainThreadAgentType: self.mainThreadAgentType,
            isRemoteMode: self.isRemoteMode,
            directConnectServerUrl: self.directConnectServerUrl,
            systemPromptSectionCache: copyPlanSlugEntries(self.systemPromptSectionCache),
            lastEmittedDate: self.lastEmittedDate,
            additionalDirectoriesForClaudeMd: copyTextListState(self.additionalDirectoriesForClaudeMd),
            allowedChannels: copyChannelEntries(self.allowedChannels),
            hasDevChannels: self.hasDevChannels,
        )

class AgentColorEntry:
    agentId: text
    color: text

impl AgentColorEntry:
    static fn new(agentId: text, color: text) -> AgentColorEntry:
        AgentColorEntry(agentId: agentId, color: color)

class RegisteredHook:
    eventName: text
    matchers: [text]

impl RegisteredHook:
    static fn new(eventName: text, matchers: [text]) -> RegisteredHook:
        RegisteredHook(eventName: eventName, matchers: copyTextListState(matchers))

class PlanSlugEntry:
    key: text
    value: text

impl PlanSlugEntry:
    static fn new(key: text, value: text) -> PlanSlugEntry:
        PlanSlugEntry(key: key, value: value)

class SlowOperation:
    operation: text
    durationMs: i64
    timestamp: i64

impl SlowOperation:
    static fn new(operation: text, durationMs: i64, timestamp: i64) -> SlowOperation:
        SlowOperation(operation: operation, durationMs: durationMs, timestamp: timestamp)

fn copyTextListState(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn containsTextState(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn dropFirstText(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyModelUsageEntries(values: [ModelUsageEntry]) -> [ModelUsageEntry]:
    var out: [ModelUsageEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyAgentColorEntries(values: [AgentColorEntry]) -> [AgentColorEntry]:
    var out: [AgentColorEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copySessionCronTasks(values: [SessionCronTask]) -> [SessionCronTask]:
    var out: [SessionCronTask] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyRegisteredHooks(values: [RegisteredHook]) -> [RegisteredHook]:
    var out: [RegisteredHook] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyPlanSlugEntries(values: [PlanSlugEntry]) -> [PlanSlugEntry]:
    var out: [PlanSlugEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyInvokedSkills(values: [InvokedSkill]) -> [InvokedSkill]:
    var out: [InvokedSkill] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copySlowOperations(values: [SlowOperation]) -> [SlowOperation]:
    var out: [SlowOperation] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyChannelEntries(values: [ChannelEntry]) -> [ChannelEntry]:
    var out: [ChannelEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn hasDevChannel(values: [ChannelEntry]) -> bool:
    var i = 0
    while i < values.len():
        if values[i].dev:
            return true
        i = i + 1
    false

