"""
Claude full code-session API parity model.
"""

const CODE_SESSION_API_SOURCE_LINES = 168
const ANTHROPIC_VERSION = "2023-06-01"

class CodeSessionHeaders:
    authorization: text
    content_type: text
    anthropic_version: text
    trusted_device_token: text

impl CodeSessionHeaders:
    static fn new(accessToken: text) -> CodeSessionHeaders:
        CodeSessionHeaders(authorization: "Bearer " + accessToken, content_type: "application/json", anthropic_version: ANTHROPIC_VERSION, trusted_device_token: "")

class CodeSessionCreateRequest:
    url: text
    title: text
    timeout_ms: i64
    bridge: bool
    tags: [text]

impl CodeSessionCreateRequest:
    static fn new(baseUrl: text, title: text, timeoutMs: i64, tags: [text]) -> CodeSessionCreateRequest:
        CodeSessionCreateRequest(url: baseUrl + "/v1/code/sessions", title: title, timeout_ms: timeoutMs, bridge: true, tags: tags)

class CodeSessionResponse:
    status: i64
    session_id: text
    detail: text

impl CodeSessionResponse:
    static fn new(status: i64, sessionId: text, detail: text) -> CodeSessionResponse:
        CodeSessionResponse(status: status, session_id: sessionId, detail: detail)

class RemoteCredentials:
    worker_jwt: text
    api_base_url: text
    expires_in: i64
    worker_epoch: i64
    valid: bool

impl RemoteCredentials:
    static fn new(workerJwt: text, apiBaseUrl: text, expiresIn: i64, workerEpoch: i64, valid: bool) -> RemoteCredentials:
        RemoteCredentials(worker_jwt: workerJwt, api_base_url: apiBaseUrl, expires_in: expiresIn, worker_epoch: workerEpoch, valid: valid)

fn oauthHeaders(accessToken: text) -> CodeSessionHeaders:
    CodeSessionHeaders.new(accessToken)

fn bridgeOauthHeaders(accessToken: text, trustedDeviceToken: text) -> CodeSessionHeaders:
    var headers = CodeSessionHeaders.new(accessToken)
    headers.trusted_device_token = trustedDeviceToken
    headers

fn createCodeSessionRequest(baseUrl: text, title: text, timeoutMs: i64, tags: [text]) -> CodeSessionCreateRequest:
    CodeSessionCreateRequest.new(baseUrl, title, timeoutMs, tags)

fn createCodeSessionFromResponse(response: CodeSessionResponse) -> text:
    if response.status != 200 and response.status != 201:
        return ""
    if not response.session_id.starts_with("cse_"):
        return ""
    response.session_id

fn codeSessionFailureLog(status: i64, detail: text) -> text:
    if detail == "":
        return "[code-session] Session create failed " + status.to_text()
    "[code-session] Session create failed " + status.to_text() + ": " + detail

fn remoteCredentialsUrl(baseUrl: text, sessionId: text) -> text:
    baseUrl + "/v1/code/sessions/" + sessionId + "/bridge"

fn parseRemoteCredentials(workerJwt: text, apiBaseUrl: text, expiresIn: i64, workerEpoch: i64) -> RemoteCredentials:
    if workerJwt == "":
        return RemoteCredentials.new("", "", 0, 0, false)
    if apiBaseUrl == "":
        return RemoteCredentials.new("", "", 0, 0, false)
    if expiresIn <= 0:
        return RemoteCredentials.new("", "", 0, 0, false)
    if workerEpoch < 0:
        return RemoteCredentials.new("", "", 0, 0, false)
    RemoteCredentials.new(workerJwt, apiBaseUrl, expiresIn, workerEpoch, true)

fn codeSessionApiSourceLinesModeled() -> i64:
    CODE_SESSION_API_SOURCE_LINES
