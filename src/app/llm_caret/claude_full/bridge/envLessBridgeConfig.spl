"""
Claude full env-less bridge config parity model.
"""

const ENV_LESS_BRIDGE_CONFIG_SOURCE_LINES = 165

class EnvLessBridgeConfig:
    init_retry_max_attempts: i64
    init_retry_base_delay_ms: i64
    init_retry_jitter_fraction: f64
    init_retry_max_delay_ms: i64
    http_timeout_ms: i64
    uuid_dedup_buffer_size: i64
    heartbeat_interval_ms: i64
    heartbeat_jitter_fraction: f64
    token_refresh_buffer_ms: i64
    teardown_archive_timeout_ms: i64
    connect_timeout_ms: i64
    min_version: text
    should_show_app_upgrade_message: bool

impl EnvLessBridgeConfig:
    static fn defaults() -> EnvLessBridgeConfig:
        EnvLessBridgeConfig(
            init_retry_max_attempts: 3,
            init_retry_base_delay_ms: 500,
            init_retry_jitter_fraction: 0.25,
            init_retry_max_delay_ms: 4000,
            http_timeout_ms: 10000,
            uuid_dedup_buffer_size: 2000,
            heartbeat_interval_ms: 20000,
            heartbeat_jitter_fraction: 0.1,
            token_refresh_buffer_ms: 300000,
            teardown_archive_timeout_ms: 1500,
            connect_timeout_ms: 15000,
            min_version: "0.0.0",
            should_show_app_upgrade_message: false,
        )

fn getEnvLessBridgeConfig(validRemoteConfig: bool, remote: EnvLessBridgeConfig) -> EnvLessBridgeConfig:
    if validRemoteConfig:
        return remote
    EnvLessBridgeConfig.defaults()

fn validateEnvLessBridgeConfig(cfg: EnvLessBridgeConfig) -> bool:
    if cfg.init_retry_max_attempts < 1 or cfg.init_retry_max_attempts > 10:
        return false
    if cfg.init_retry_base_delay_ms < 100:
        return false
    if cfg.init_retry_jitter_fraction < 0.0 or cfg.init_retry_jitter_fraction > 1.0:
        return false
    if cfg.init_retry_max_delay_ms < 500:
        return false
    if cfg.http_timeout_ms < 2000:
        return false
    if cfg.uuid_dedup_buffer_size < 100 or cfg.uuid_dedup_buffer_size > 50000:
        return false
    if cfg.heartbeat_interval_ms < 5000 or cfg.heartbeat_interval_ms > 30000:
        return false
    if cfg.heartbeat_jitter_fraction < 0.0 or cfg.heartbeat_jitter_fraction > 0.5:
        return false
    if cfg.token_refresh_buffer_ms < 30000 or cfg.token_refresh_buffer_ms > 1800000:
        return false
    if cfg.teardown_archive_timeout_ms < 500 or cfg.teardown_archive_timeout_ms > 2000:
        return false
    if cfg.connect_timeout_ms < 5000 or cfg.connect_timeout_ms > 60000:
        return false
    true

fn checkEnvLessBridgeMinVersion(currentVersion: text, cfg: EnvLessBridgeConfig) -> text:
    if cfg.min_version == "" or cfg.min_version == "0.0.0":
        return ""
    if currentVersion < cfg.min_version:
        return "Your version of Claude Code (" + currentVersion + ") is too old for Remote Control.\nVersion " + cfg.min_version + " or higher is required. Run `claude update` to update."
    ""

fn shouldShowAppUpgradeMessage(envLessBridgeEnabled: bool, cfg: EnvLessBridgeConfig) -> bool:
    if not envLessBridgeEnabled:
        return false
    cfg.should_show_app_upgrade_message

fn envLessBridgeConfigSourceLinesModeled() -> i64:
    ENV_LESS_BRIDGE_CONFIG_SOURCE_LINES
