const WORK_SECRET_VERSION: i64 = 1
const WORKER_REGISTER_TIMEOUT_MS: i64 = 10000
const ANTHROPIC_VERSION: text = "2023-06-01"

class DecodedWorkSecret:
    ok: bool
    version: i64
    sessionIngressToken: text
    apiBaseUrl: text
    useCodeSessions: bool
    error: text

impl DecodedWorkSecret:
    static fn ok(version: i64, token: text, apiBaseUrl: text, useCodeSessions: bool) -> DecodedWorkSecret:
        DecodedWorkSecret(ok: true, version: version, sessionIngressToken: token, apiBaseUrl: apiBaseUrl, useCodeSessions: useCodeSessions, error: "")

    static fn failed(error: text) -> DecodedWorkSecret:
        DecodedWorkSecret(ok: false, version: 0, sessionIngressToken: "", apiBaseUrl: "", useCodeSessions: false, error: error)

class WorkerRegisterRequest:
    url: text
    Authorization: text
    Content_Type: text
    anthropic_version: text
    timeoutMs: i64

impl WorkerRegisterRequest:
    static fn new(sessionUrl: text, accessToken: text) -> WorkerRegisterRequest:
        WorkerRegisterRequest(url: sessionUrl + "/worker/register", Authorization: "Bearer " + accessToken, Content_Type: "application/json", anthropic_version: ANTHROPIC_VERSION, timeoutMs: WORKER_REGISTER_TIMEOUT_MS)

class WorkerRegisterResponse:
    ok: bool
    workerEpoch: i64
    error: text

impl WorkerRegisterResponse:
    static fn ok(workerEpoch: i64) -> WorkerRegisterResponse:
        WorkerRegisterResponse(ok: true, workerEpoch: workerEpoch, error: "")

    static fn failed(error: text) -> WorkerRegisterResponse:
        WorkerRegisterResponse(ok: false, workerEpoch: 0, error: error)

fn decodeWorkSecret(version: i64, sessionIngressToken: text, apiBaseUrl: text, useCodeSessions: bool) -> DecodedWorkSecret:
    if version != WORK_SECRET_VERSION:
        return DecodedWorkSecret.failed("Unsupported work secret version: " + version.to_text())
    if sessionIngressToken == "":
        return DecodedWorkSecret.failed("Invalid work secret: missing or empty session_ingress_token")
    if apiBaseUrl == "":
        return DecodedWorkSecret.failed("Invalid work secret: missing api_base_url")
    DecodedWorkSecret.ok(version, sessionIngressToken, apiBaseUrl, useCodeSessions)

fn decodeWorkSecretUnknownVersion() -> DecodedWorkSecret:
    DecodedWorkSecret.failed("Unsupported work secret version: unknown")

fn buildSdkUrl(apiBaseUrl: text, sessionId: text) -> text:
    val host = stripHttpProtocol(trimTrailingSlashes(apiBaseUrl))
    val version = if isLocalhost(apiBaseUrl): "v2" else: "v1"
    val protocol = if isLocalhost(apiBaseUrl): "ws" else: "wss"
    protocol + "://" + host + "/" + version + "/session_ingress/ws/" + sessionId

fn buildCCRv2SdkUrl(apiBaseUrl: text, sessionId: text) -> text:
    trimTrailingSlashes(apiBaseUrl) + "/v1/code/sessions/" + sessionId

fn sameSessionId(a: text, b: text) -> bool:
    if a == b:
        return true
    val aBody = afterLastUnderscore(a)
    val bBody = afterLastUnderscore(b)
    aBody.len() >= 4 and aBody == bBody

fn registerWorkerRequest(sessionUrl: text, accessToken: text) -> WorkerRegisterRequest:
    WorkerRegisterRequest.new(sessionUrl, accessToken)

fn registerWorker(workerEpochRaw: text) -> WorkerRegisterResponse:
    val epoch = parseSafeInteger(workerEpochRaw)
    if epoch < 0:
        return WorkerRegisterResponse.failed("registerWorker: invalid worker_epoch in response: " + workerEpochRaw)
    WorkerRegisterResponse.ok(epoch)

fn registerWorkerNumber(workerEpoch: i64) -> WorkerRegisterResponse:
    if workerEpoch < 0 or workerEpoch > maxSafeInteger():
        return WorkerRegisterResponse.failed("registerWorker: invalid worker_epoch in response: " + workerEpoch.to_text())
    WorkerRegisterResponse.ok(workerEpoch)

fn stripHttpProtocol(url: text) -> text:
    if url.starts_with("https://"):
        return url.substring("https://".len(), url.len())
    if url.starts_with("http://"):
        return url.substring("http://".len(), url.len())
    url

fn trimTrailingSlashes(url: text) -> text:
    var end = url.len()
    while end > 0 and url.substring(end - 1, end) == "/":
        end = end - 1
    url.substring(0, end)

fn isLocalhost(url: text) -> bool:
    url.contains("localhost") or url.contains("127.0.0.1")

fn afterLastUnderscore(idText: text) -> text:
    var last = -1
    var i = 0
    while i < idText.len():
        if idText.substring(i, i + 1) == "_":
            last = i
        i = i + 1
    idText.substring(last + 1, idText.len())

fn parseSafeInteger(value: text) -> i64:
    if value == "":
        return -1
    var n = 0
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch < "0" or ch > "9":
            return -1
        n = n * 10 + digitValue(ch)
        if n > maxSafeInteger():
            return -1
        i = i + 1
    n

fn digitValue(ch: text) -> i64:
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn maxSafeInteger() -> i64:
    9007199254740991

fn workSecretVersion() -> i64:
    WORK_SECRET_VERSION

fn workerRegisterTimeoutMs() -> i64:
    WORKER_REGISTER_TIMEOUT_MS

fn anthropicVersion() -> text:
    ANTHROPIC_VERSION

fn workerRegisterPath(sessionUrl: text) -> text:
    sessionUrl + "/worker/register"

fn sdkIngressPath(sessionId: text) -> text:
    "/session_ingress/ws/" + sessionId

fn ccrV2SessionPath(sessionId: text) -> text:
    "/v1/code/sessions/" + sessionId
