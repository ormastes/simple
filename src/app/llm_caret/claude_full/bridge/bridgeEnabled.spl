"""
Claude full bridge enabled gate parity model.
"""

const BRIDGE_ENABLED_SOURCE_LINES = 202

class BridgeEntitlement:
    build_bridge_mode: bool
    claude_ai_subscriber: bool
    bridge_gate: bool
    profile_scope: bool
    organization_uuid: text

impl BridgeEntitlement:
    static fn new(buildBridgeMode: bool, subscriber: bool, bridgeGate: bool, profileScope: bool, organizationUuid: text) -> BridgeEntitlement:
        BridgeEntitlement(build_bridge_mode: buildBridgeMode, claude_ai_subscriber: subscriber, bridge_gate: bridgeGate, profile_scope: profileScope, organization_uuid: organizationUuid)

class BridgeFeatureFlags:
    bridge_mode: bool
    env_less_bridge: bool
    cse_shim: bool
    ccr_auto_connect: bool
    ccr_mirror_build: bool
    ccr_mirror_env: bool
    ccr_mirror_gate: bool

impl BridgeFeatureFlags:
    static fn new() -> BridgeFeatureFlags:
        BridgeFeatureFlags(bridge_mode: true, env_less_bridge: false, cse_shim: true, ccr_auto_connect: false, ccr_mirror_build: false, ccr_mirror_env: false, ccr_mirror_gate: false)

fn isBridgeEnabled(entitlement: BridgeEntitlement) -> bool:
    if not entitlement.build_bridge_mode:
        return false
    if not entitlement.claude_ai_subscriber:
        return false
    entitlement.bridge_gate

fn isBridgeEnabledBlocking(entitlement: BridgeEntitlement) -> bool:
    isBridgeEnabled(entitlement)

fn getBridgeDisabledReason(entitlement: BridgeEntitlement) -> text:
    if not entitlement.build_bridge_mode:
        return "Remote Control is not available in this build."
    if not entitlement.claude_ai_subscriber:
        return "Remote Control requires a claude.ai subscription. Run `claude auth login` to sign in with your claude.ai account."
    if not entitlement.profile_scope:
        return "Remote Control requires a full-scope login token. Long-lived tokens (from `claude setup-token` or CLAUDE_CODE_OAUTH_TOKEN) are limited to inference-only for security reasons. Run `claude auth login` to use Remote Control."
    if entitlement.organization_uuid == "":
        return "Unable to determine your organization for Remote Control eligibility. Run `claude auth login` to refresh your account information."
    if not entitlement.bridge_gate:
        return "Remote Control is not yet enabled for your account."
    ""

fn isEnvLessBridgeEnabled(flags: BridgeFeatureFlags) -> bool:
    if not flags.bridge_mode:
        return false
    flags.env_less_bridge

fn isCseShimEnabled(flags: BridgeFeatureFlags) -> bool:
    if not flags.bridge_mode:
        return true
    flags.cse_shim

fn checkBridgeMinVersion(currentVersion: text, minVersion: text, bridgeMode: bool) -> text:
    if not bridgeMode:
        return ""
    if minVersion == "" or minVersion == "0.0.0":
        return ""
    if currentVersion < minVersion:
        return "Your version of Claude Code (" + currentVersion + ") is too old for Remote Control.\nVersion " + minVersion + " or higher is required. Run `claude update` to update."
    ""

fn getCcrAutoConnectDefault(buildFlag: bool, gateEnabled: bool) -> bool:
    if not buildFlag:
        return false
    gateEnabled

fn isCcrMirrorEnabled(flags: BridgeFeatureFlags) -> bool:
    if not flags.ccr_mirror_build:
        return false
    if flags.ccr_mirror_env:
        return true
    flags.ccr_mirror_gate

fn bridgeEnabledSourceLinesModeled() -> i64:
    BRIDGE_ENABLED_SOURCE_LINES
