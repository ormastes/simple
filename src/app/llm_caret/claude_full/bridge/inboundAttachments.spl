"""
Claude full bridge inbound attachment parity model.
"""

const INBOUND_ATTACHMENTS_SOURCE_LINES = 175
const INBOUND_ATTACHMENT_DOWNLOAD_TIMEOUT_MS = 30000

class InboundAttachment:
    file_uuid: text
    file_name: text

impl InboundAttachment:
    static fn new(file_uuid: text, file_name: text) -> InboundAttachment:
        InboundAttachment(file_uuid: file_uuid, file_name: file_name)

    me valid() -> bool:
        me.file_uuid != "" and me.file_name != ""

class InboundAttachmentMessage:
    has_file_attachments: bool
    file_attachments_valid: bool
    file_attachments: [InboundAttachment]

impl InboundAttachmentMessage:
    static fn none() -> InboundAttachmentMessage:
        InboundAttachmentMessage(has_file_attachments: false, file_attachments_valid: false, file_attachments: [])

    static fn withAttachments(attachments: [InboundAttachment]) -> InboundAttachmentMessage:
        InboundAttachmentMessage(has_file_attachments: true, file_attachments_valid: true, file_attachments: attachments)

    static fn malformed() -> InboundAttachmentMessage:
        InboundAttachmentMessage(has_file_attachments: true, file_attachments_valid: false, file_attachments: [])

class InboundAttachmentContext:
    access_token: text
    base_url: text
    config_home: text
    session_id: text
    fallback_uuid: text
    fetch_status: i64
    fetch_threw: bool
    write_failed: bool
    downloaded_bytes: i64

impl InboundAttachmentContext:
    static fn ok(access_token: text, base_url: text, config_home: text, session_id: text) -> InboundAttachmentContext:
        InboundAttachmentContext(access_token: access_token, base_url: base_url, config_home: config_home, session_id: session_id, fallback_uuid: "00000000", fetch_status: 200, fetch_threw: false, write_failed: false, downloaded_bytes: 0)

class InboundAttachmentResolution:
    ok: bool
    path: text
    debug_message: text

impl InboundAttachmentResolution:
    static fn skipped(message: text) -> InboundAttachmentResolution:
        InboundAttachmentResolution(ok: false, path: "", debug_message: message)

    static fn resolved(path: text, message: text) -> InboundAttachmentResolution:
        InboundAttachmentResolution(ok: true, path: path, debug_message: message)

class InboundAttachmentContentBlock:
    type_name: text
    text_value: text

impl InboundAttachmentContentBlock:
    static fn textBlock(value: text) -> InboundAttachmentContentBlock:
        InboundAttachmentContentBlock(type_name: "text", text_value: value)

    static fn nonText(type_name: text) -> InboundAttachmentContentBlock:
        InboundAttachmentContentBlock(type_name: type_name, text_value: "")

fn extractInboundAttachments(msg: InboundAttachmentMessage) -> [InboundAttachment]:
    if not msg.has_file_attachments:
        return []
    if not msg.file_attachments_valid:
        return []
    var out: [InboundAttachment] = []
    var i = 0
    while i < msg.file_attachments.len():
        val att = msg.file_attachments[i]
        if att.valid():
            out.push(att)
        i = i + 1
    out

fn inboundAttachmentBasename(name: text) -> text:
    var start = 0
    var i = 0
    while i < name.len():
        val ch = name.slice(i, i + 1)
        if ch == "/" or ch == "\\":
            start = i + 1
        i = i + 1
    name.slice(start, name.len())

fn inboundAttachmentSafeChar(ch: text, allowDash: bool) -> bool:
    val code = ch.char_code_at(0)
    if code >= 65 and code <= 90:
        return true
    if code >= 97 and code <= 122:
        return true
    if code >= 48 and code <= 57:
        return true
    if ch == "_" or ch == ".":
        return true
    allowDash and ch == "-"

fn inboundAttachmentSanitizeWithDash(value: text, allowDash: bool) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if inboundAttachmentSafeChar(ch, allowDash):
            out = out + ch
        else:
            out = out + "_"
        i = i + 1
    out

fn sanitizeInboundAttachmentFileName(name: text) -> text:
    val safe = inboundAttachmentSanitizeWithDash(inboundAttachmentBasename(name), true)
    if safe == "":
        return "attachment"
    safe

fn inboundAttachmentPrefix(att: InboundAttachment, fallback_uuid: text) -> text:
    var raw = att.file_uuid
    if raw == "":
        raw = fallback_uuid
    if raw.len() > 8:
        raw = raw.slice(0, 8)
    inboundAttachmentSanitizeWithDash(raw, true)

fn inboundAttachmentUploadsDir(ctx: InboundAttachmentContext) -> text:
    ctx.config_home + "/uploads/" + ctx.session_id

fn inboundAttachmentContentUrl(ctx: InboundAttachmentContext, att: InboundAttachment) -> text:
    ctx.base_url + "/api/oauth/files/" + att.file_uuid + "/content"

fn resolveOneInboundAttachment(att: InboundAttachment, ctx: InboundAttachmentContext) -> InboundAttachmentResolution:
    if ctx.access_token == "":
        return InboundAttachmentResolution.skipped("skip: no oauth token")
    val _url = inboundAttachmentContentUrl(ctx, att)
    if ctx.fetch_threw:
        return InboundAttachmentResolution.skipped("fetch " + att.file_uuid + " threw")
    if ctx.fetch_status != 200:
        return InboundAttachmentResolution.skipped("fetch " + att.file_uuid + " failed: status=" + ctx.fetch_status.to_text())
    val dir = inboundAttachmentUploadsDir(ctx)
    val out_path = dir + "/" + inboundAttachmentPrefix(att, ctx.fallback_uuid) + "-" + sanitizeInboundAttachmentFileName(att.file_name)
    if ctx.write_failed:
        return InboundAttachmentResolution.skipped("write " + out_path + " failed")
    InboundAttachmentResolution.resolved(out_path, "resolved " + att.file_uuid + " -> " + out_path + " (" + ctx.downloaded_bytes.to_text() + " bytes)")

fn resolveInboundAttachments(attachments: [InboundAttachment], ctx: InboundAttachmentContext) -> text:
    if attachments.len() == 0:
        return ""
    var prefix = ""
    var i = 0
    while i < attachments.len():
        val resolved = resolveOneInboundAttachment(attachments[i], ctx)
        if resolved.ok:
            prefix = prefix + "@\"" + resolved.path + "\" "
        i = i + 1
    prefix

fn prependPathRefsToText(content: text, prefix: text) -> text:
    if prefix == "":
        return content
    prefix + content

fn prependPathRefsToBlocks(blocks: [InboundAttachmentContentBlock], prefix: text) -> [InboundAttachmentContentBlock]:
    if prefix == "":
        return blocks
    var out: [InboundAttachmentContentBlock] = []
    var last_text = -1
    var i = 0
    while i < blocks.len():
        if blocks[i].type_name == "text":
            last_text = i
        i = i + 1
    if last_text == -1:
        return blocks + [InboundAttachmentContentBlock.textBlock(prefix.trim())]
    i = 0
    while i < blocks.len():
        val block = blocks[i]
        if i == last_text:
            out.push(InboundAttachmentContentBlock.textBlock(prefix + block.text_value))
        else:
            out.push(block)
        i = i + 1
    out

fn resolveAndPrependInboundAttachmentText(msg: InboundAttachmentMessage, content: text, ctx: InboundAttachmentContext) -> text:
    val attachments = extractInboundAttachments(msg)
    if attachments.len() == 0:
        return content
    prependPathRefsToText(content, resolveInboundAttachments(attachments, ctx))

fn inboundAttachmentsSourceLinesModeled() -> i64:
    INBOUND_ATTACHMENTS_SOURCE_LINES
# parity ledger: upstream inboundAttachments lines 001-175 modeled by the focused attachment extraction, resolution, and prefix-prepend surface above.
