const BETA_HEADER: text = "environments-2025-11-01"
const ANTHROPIC_VERSION: text = "2023-06-01"
const BRIDGE_LOGIN_INSTRUCTION: text = "Remote Control is only available with claude.ai subscriptions. Please use `/login` to sign in with your claude.ai account."
const REGISTRATION_TIMEOUT_MS: i64 = 15000
const BRIDGE_REQUEST_TIMEOUT_MS: i64 = 10000
const EMPTY_POLL_LOG_INTERVAL: i64 = 100

class BridgeFatalError:
    message: text
    status: i64
    errorType: text

impl BridgeFatalError:
    static fn new(message: text, status: i64, errorType: text) -> BridgeFatalError:
        BridgeFatalError(message: message, status: status, errorType: errorType)

    me isAuth() -> bool:
        me.status == 401

    me isExpired() -> bool:
        isExpiredErrorType(me.errorType)

class BridgeErrorData:
    detail: text
    errorType: text

impl BridgeErrorData:
    static fn none() -> BridgeErrorData:
        BridgeErrorData(detail: "", errorType: "")

    static fn detail(detail: text) -> BridgeErrorData:
        BridgeErrorData(detail: detail, errorType: "")

    static fn typed(detail: text, errorType: text) -> BridgeErrorData:
        BridgeErrorData(detail: detail, errorType: errorType)

class BridgeApiResponse:
    status: i64
    data: text
    error: BridgeErrorData

impl BridgeApiResponse:
    static fn ok(status: i64, data: text) -> BridgeApiResponse:
        BridgeApiResponse(status: status, data: data, error: BridgeErrorData.none())

    static fn empty(status: i64) -> BridgeApiResponse:
        BridgeApiResponse(status: status, data: "", error: BridgeErrorData.none())

    static fn failed(status: i64, detail: text) -> BridgeApiResponse:
        BridgeApiResponse(status: status, data: "", error: BridgeErrorData.detail(detail))

    static fn typed(status: i64, detail: text, errorType: text) -> BridgeApiResponse:
        BridgeApiResponse(status: status, data: "", error: BridgeErrorData.typed(detail, errorType))

class BridgeHeaders:
    Authorization: text
    Content_Type: text
    anthropic_version: text
    anthropic_beta: text
    x_environment_runner_version: text
    X_Trusted_Device_Token: text

impl BridgeHeaders:
    static fn new(accessToken: text, runnerVersion: text, trustedDeviceToken: text) -> BridgeHeaders:
        BridgeHeaders(
            Authorization: "Bearer " + accessToken,
            Content_Type: "application/json",
            anthropic_version: ANTHROPIC_VERSION,
            anthropic_beta: BETA_HEADER,
            x_environment_runner_version: runnerVersion,
            X_Trusted_Device_Token: trustedDeviceToken
        )

    me hasTrustedDeviceToken() -> bool:
        me.X_Trusted_Device_Token != ""

class BridgeConfig:
    bridgeId: text
    machineName: text
    dir: text
    branch: text
    gitRepoUrl: text
    maxSessions: i64
    workerType: text
    reuseEnvironmentId: text

impl BridgeConfig:
    static fn new(bridgeId: text, machineName: text, dir: text, branch: text, gitRepoUrl: text, maxSessions: i64, workerType: text, reuseEnvironmentId: text) -> BridgeConfig:
        BridgeConfig(
            bridgeId: bridgeId,
            machineName: machineName,
            dir: dir,
            branch: branch,
            gitRepoUrl: gitRepoUrl,
            maxSessions: maxSessions,
            workerType: workerType,
            reuseEnvironmentId: reuseEnvironmentId
        )

class BridgeApiDeps:
    baseUrl: text
    accessToken: text
    refreshedAccessToken: text
    runnerVersion: text
    trustedDeviceToken: text
    authRefreshSucceeds: bool

impl BridgeApiDeps:
    static fn new(baseUrl: text, accessToken: text, runnerVersion: text) -> BridgeApiDeps:
        BridgeApiDeps(
            baseUrl: baseUrl,
            accessToken: accessToken,
            refreshedAccessToken: "",
            runnerVersion: runnerVersion,
            trustedDeviceToken: "",
            authRefreshSucceeds: false
        )

    me withTrustedDeviceToken(token: text) -> BridgeApiDeps:
        BridgeApiDeps(
            baseUrl: me.baseUrl,
            accessToken: me.accessToken,
            refreshedAccessToken: me.refreshedAccessToken,
            runnerVersion: me.runnerVersion,
            trustedDeviceToken: token,
            authRefreshSucceeds: me.authRefreshSucceeds
        )

    me withRefresh(refreshedAccessToken: text, succeeds: bool) -> BridgeApiDeps:
        BridgeApiDeps(
            baseUrl: me.baseUrl,
            accessToken: me.accessToken,
            refreshedAccessToken: refreshedAccessToken,
            runnerVersion: me.runnerVersion,
            trustedDeviceToken: me.trustedDeviceToken,
            authRefreshSucceeds: succeeds
        )

class BridgeApiRequest:
    method: text
    url: text
    body: text
    params: text
    timeoutMs: i64
    headers: BridgeHeaders

impl BridgeApiRequest:
    static fn new(method: text, url: text, body: text, params: text, timeoutMs: i64, headers: BridgeHeaders) -> BridgeApiRequest:
        BridgeApiRequest(method: method, url: url, body: body, params: params, timeoutMs: timeoutMs, headers: headers)

class BridgeApiCallResult:
    ok: bool
    data: text
    fatal: BridgeFatalError
    errorMessage: text
    requests: [BridgeApiRequest]

impl BridgeApiCallResult:
    static fn ok(data: text, requests: [BridgeApiRequest]) -> BridgeApiCallResult:
        BridgeApiCallResult(ok: true, data: data, fatal: BridgeFatalError.new("", 0, ""), errorMessage: "", requests: requests)

    static fn fatal(fatal: BridgeFatalError, requests: [BridgeApiRequest]) -> BridgeApiCallResult:
        BridgeApiCallResult(ok: false, data: "", fatal: fatal, errorMessage: fatal.message, requests: requests)

    static fn failed(message: text, requests: [BridgeApiRequest]) -> BridgeApiCallResult:
        BridgeApiCallResult(ok: false, data: "", fatal: BridgeFatalError.new("", 0, ""), errorMessage: message, requests: requests)

class WorkResponse:
    id: text
    dataType: text
    sessionId: text

impl WorkResponse:
    static fn new(id: text, dataType: text, sessionId: text) -> WorkResponse:
        WorkResponse(id: id, dataType: dataType, sessionId: sessionId)

    me encode() -> text:
        me.id + "|" + me.dataType + "|" + me.sessionId

class PollResult:
    hasWork: bool
    work: WorkResponse
    emptyPolls: i64
    call: BridgeApiCallResult

impl PollResult:
    static fn empty(emptyPolls: i64, call: BridgeApiCallResult) -> PollResult:
        PollResult(hasWork: false, work: WorkResponse.new("", "", ""), emptyPolls: emptyPolls, call: call)

    static fn work(work: WorkResponse, call: BridgeApiCallResult) -> PollResult:
        PollResult(hasWork: true, work: work, emptyPolls: 0, call: call)

class HeartbeatResult:
    leaseExtended: bool
    state: text
    call: BridgeApiCallResult

impl HeartbeatResult:
    static fn new(leaseExtended: bool, state: text, call: BridgeApiCallResult) -> HeartbeatResult:
        HeartbeatResult(leaseExtended: leaseExtended, state: state, call: call)

class BridgeApiClient:
    deps: BridgeApiDeps
    consecutiveEmptyPolls: i64
    logs: [text]

impl BridgeApiClient:
    static fn new(deps: BridgeApiDeps) -> BridgeApiClient:
        BridgeApiClient(deps: deps, consecutiveEmptyPolls: 0, logs: [])

    me headers(accessToken: text) -> BridgeHeaders:
        BridgeHeaders.new(accessToken, me.deps.runnerVersion, me.deps.trustedDeviceToken)

    me registerBridgeEnvironment(config: BridgeConfig, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        val body = registrationBody(config)
        val req = BridgeApiRequest.new("POST", registrationPath(me.deps.baseUrl), body, "", REGISTRATION_TIMEOUT_MS, me.headers(me.deps.accessToken))
        val call = me.withOAuthRetry("Registration", req, first, retry)
        if call.ok == false:
            return call
        BridgeApiCallResult.ok(first.data, call.requests)

    me pollForWork(environmentId: text, environmentSecret: text, reclaimOlderThanMs: i64, response: BridgeApiResponse) -> PollResult:
        val validation = validateBridgeIdError(environmentId, "environmentId")
        if validation != "":
            return PollResult.empty(me.consecutiveEmptyPolls, BridgeApiCallResult.failed(validation, []))
        val previous = me.consecutiveEmptyPolls
        me.consecutiveEmptyPolls = 0
        val params = if reclaimOlderThanMs >= 0: "reclaim_older_than_ms=" + reclaimOlderThanMs.to_text() else: ""
        val req = BridgeApiRequest.new("GET", pollPath(me.deps.baseUrl, environmentId), "", params, BRIDGE_REQUEST_TIMEOUT_MS, me.headers(environmentSecret))
        val handled = handleApiResponse("Poll", response, [req])
        if handled.ok == false:
            return PollResult.empty(previous, handled)
        if response.data == "":
            me.consecutiveEmptyPolls = previous + 1
            if me.consecutiveEmptyPolls == 1 or me.consecutiveEmptyPolls % EMPTY_POLL_LOG_INTERVAL == 0:
                me.logs = me.logs + ["[bridge:api] GET .../work/poll -> " + response.status.to_text() + " (no work, " + me.consecutiveEmptyPolls.to_text() + " consecutive empty polls)"]
            return PollResult.empty(me.consecutiveEmptyPolls, handled)
        PollResult.work(WorkResponse.new(response.data, "message", ""), handled)

    me acknowledgeWork(environmentId: text, workId: text, sessionToken: text, response: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateTwoBridgeIds(environmentId, "environmentId", workId, "workId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("POST", acknowledgePath(me.deps.baseUrl, environmentId, workId), "{}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(sessionToken))
        handleApiResponse("Acknowledge", response, [req])

    me stopWork(environmentId: text, workId: text, force: bool, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateTwoBridgeIds(environmentId, "environmentId", workId, "workId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("POST", stopPath(me.deps.baseUrl, environmentId, workId), "{\"force\":" + boolText(force) + "}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(me.deps.accessToken))
        me.withOAuthRetry("StopWork", req, first, retry)

    me deregisterEnvironment(environmentId: text, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateBridgeIdError(environmentId, "environmentId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("DELETE", deregisterPath(me.deps.baseUrl, environmentId), "", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(me.deps.accessToken))
        me.withOAuthRetry("Deregister", req, first, retry)

    me archiveSession(sessionId: text, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateBridgeIdError(sessionId, "sessionId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("POST", archivePath(me.deps.baseUrl, sessionId), "{}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(me.deps.accessToken))
        if first.status == 409:
            return BridgeApiCallResult.ok("", [req])
        me.withOAuthRetry("ArchiveSession", req, first, retry)

    me reconnectSession(environmentId: text, sessionId: text, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateTwoBridgeIds(environmentId, "environmentId", sessionId, "sessionId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("POST", reconnectPath(me.deps.baseUrl, environmentId), "{\"session_id\":\"" + sessionId + "\"}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(me.deps.accessToken))
        me.withOAuthRetry("ReconnectSession", req, first, retry)

    me heartbeatWork(environmentId: text, workId: text, sessionToken: text, response: BridgeApiResponse) -> HeartbeatResult:
        val err = validateTwoBridgeIds(environmentId, "environmentId", workId, "workId")
        if err != "":
            return HeartbeatResult.new(false, "", BridgeApiCallResult.failed(err, []))
        val req = BridgeApiRequest.new("POST", heartbeatPath(me.deps.baseUrl, environmentId, workId), "{}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(sessionToken))
        val call = handleApiResponse("Heartbeat", response, [req])
        if call.ok == false:
            return HeartbeatResult.new(false, "", call)
        HeartbeatResult.new(response.data == "extended", response.data, call)

    me sendPermissionResponseEvent(sessionId: text, permissionEvent: text, sessionToken: text, response: BridgeApiResponse) -> BridgeApiCallResult:
        val err = validateBridgeIdError(sessionId, "sessionId")
        if err != "":
            return BridgeApiCallResult.failed(err, [])
        val req = BridgeApiRequest.new("POST", sessionEventsPath(me.deps.baseUrl, sessionId), "{\"events\":[" + permissionEvent + "]}", "", BRIDGE_REQUEST_TIMEOUT_MS, me.headers(sessionToken))
        handleApiResponse("SendPermissionResponseEvent", response, [req])

    me withOAuthRetry(context: text, req: BridgeApiRequest, first: BridgeApiResponse, retry: BridgeApiResponse) -> BridgeApiCallResult:
        if me.deps.accessToken == "":
            return BridgeApiCallResult.failed(BRIDGE_LOGIN_INSTRUCTION, [])
        if first.status != 401:
            return handleApiResponse(context, first, [req])
        if not me.deps.authRefreshSucceeds:
            return handleApiResponse(context, first, [req])
        val retried = cloneRequestWithToken(req, me.deps.refreshedAccessToken, me.deps.runnerVersion, me.deps.trustedDeviceToken)
        val handled = handleApiResponse(context, retry, [req, retried])
        handled

fn createBridgeApiClient(deps: BridgeApiDeps) -> BridgeApiClient:
    BridgeApiClient.new(deps)

fn validateBridgeId(idText: text, label: text) -> text:
    val err = validateBridgeIdError(idText, label)
    if err != "":
        return ""
    idText

fn validateBridgeIdError(idText: text, label: text) -> text:
    if idText == "":
        return "Invalid " + label + ": contains unsafe characters"
    var i = 0
    while i < idText.len():
        if not isSafeBridgeIdChar(idText.substring(i, i + 1)):
            return "Invalid " + label + ": contains unsafe characters"
        i = i + 1
    ""

fn validateTwoBridgeIds(left: text, leftLabel: text, right: text, rightLabel: text) -> text:
    val leftErr = validateBridgeIdError(left, leftLabel)
    if leftErr != "":
        return leftErr
    validateBridgeIdError(right, rightLabel)

fn isSafeBridgeIdChar(ch: text) -> bool:
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    ch == "_" or ch == "-"

fn handleApiResponse(context: text, response: BridgeApiResponse, requests: [BridgeApiRequest]) -> BridgeApiCallResult:
    val fatal = handleErrorStatus(context, response.status, response.error)
    if fatal.message != "":
        return BridgeApiCallResult.fatal(fatal, requests)
    val err = nonFatalErrorMessage(context, response.status, response.error)
    if err != "":
        return BridgeApiCallResult.failed(err, requests)
    BridgeApiCallResult.ok(response.data, requests)

fn handleErrorStatus(context: text, status: i64, data: BridgeErrorData) -> BridgeFatalError:
    if status == 401:
        return BridgeFatalError.new(context + ": Authentication failed (401)" + detailSuffix(data.detail) + ". " + BRIDGE_LOGIN_INSTRUCTION, 401, data.errorType)
    if status == 403:
        if isExpiredErrorType(data.errorType):
            return BridgeFatalError.new(expiredMessage(), 403, data.errorType)
        return BridgeFatalError.new(context + ": Access denied (403)" + detailSuffix(data.detail) + ". Check your organization permissions.", 403, data.errorType)
    if status == 404:
        if data.detail != "":
            return BridgeFatalError.new(data.detail, 404, data.errorType)
        return BridgeFatalError.new(context + ": Not found (404). Remote Control may not be available for this organization.", 404, data.errorType)
    if status == 410:
        if data.detail != "":
            return BridgeFatalError.new(data.detail, 410, data.errorType)
        val errorType = if data.errorType != "": data.errorType else: "environment_expired"
        return BridgeFatalError.new(expiredMessage(), 410, errorType)
    BridgeFatalError.new("", 0, "")

fn nonFatalErrorMessage(context: text, status: i64, data: BridgeErrorData) -> text:
    if status == 200 or status == 204:
        return ""
    if status == 409:
        return ""
    if status == 429:
        return context + ": Rate limited (429). Polling too frequently."
    if status >= 500:
        return context + ": Failed with status " + status.to_text() + detailSuffix(data.detail)
    if status >= 400:
        return context + ": Failed with status " + status.to_text() + detailSuffix(data.detail)
    ""

fn isExpiredErrorType(errorType: text) -> bool:
    if errorType == "":
        return false
    errorType.contains("expired") or errorType.contains("lifetime")

fn isSuppressible403(err: BridgeFatalError) -> bool:
    if err.status != 403:
        return false
    err.message.contains("external_poll_sessions") or err.message.contains("environments:manage")

fn detailSuffix(detail: text) -> text:
    if detail == "":
        return ""
    ": " + detail

fn expiredMessage() -> text:
    "Remote Control session has expired. Please restart with `claude remote-control` or /remote-control."

fn registrationBody(config: BridgeConfig) -> text:
    var body = "{"
    body = body + "\"machine_name\":\"" + config.machineName + "\","
    body = body + "\"directory\":\"" + config.dir + "\","
    body = body + "\"branch\":\"" + config.branch + "\","
    body = body + "\"git_repo_url\":\"" + config.gitRepoUrl + "\","
    body = body + "\"max_sessions\":" + config.maxSessions.to_text() + ","
    body = body + "\"metadata\":{\"worker_type\":\"" + config.workerType + "\"}"
    if config.reuseEnvironmentId != "":
        body = body + ",\"environment_id\":\"" + config.reuseEnvironmentId + "\""
    body + "}"

fn cloneRequestWithToken(req: BridgeApiRequest, token: text, runnerVersion: text, trustedDeviceToken: text) -> BridgeApiRequest:
    BridgeApiRequest.new(req.method, req.url, req.body, req.params, req.timeoutMs, BridgeHeaders.new(token, runnerVersion, trustedDeviceToken))

fn registrationPath(baseUrl: text) -> text:
    baseUrl + "/v1/environments/bridge"

fn pollPath(baseUrl: text, environmentId: text) -> text:
    baseUrl + "/v1/environments/" + environmentId + "/work/poll"

fn acknowledgePath(baseUrl: text, environmentId: text, workId: text) -> text:
    baseUrl + "/v1/environments/" + environmentId + "/work/" + workId + "/ack"

fn stopPath(baseUrl: text, environmentId: text, workId: text) -> text:
    baseUrl + "/v1/environments/" + environmentId + "/work/" + workId + "/stop"

fn heartbeatPath(baseUrl: text, environmentId: text, workId: text) -> text:
    baseUrl + "/v1/environments/" + environmentId + "/work/" + workId + "/heartbeat"

fn deregisterPath(baseUrl: text, environmentId: text) -> text:
    baseUrl + "/v1/environments/bridge/" + environmentId

fn archivePath(baseUrl: text, sessionId: text) -> text:
    baseUrl + "/v1/sessions/" + sessionId + "/archive"

fn reconnectPath(baseUrl: text, environmentId: text) -> text:
    baseUrl + "/v1/environments/" + environmentId + "/bridge/reconnect"

fn sessionEventsPath(baseUrl: text, sessionId: text) -> text:
    baseUrl + "/v1/sessions/" + sessionId + "/events"

fn validateStatusForAxios(status: i64) -> bool:
    status < 500

fn bridgeSuccessStatus(status: i64) -> bool:
    status == 200 or status == 204

fn archiveAlreadyArchivedStatus(status: i64) -> bool:
    status == 409

fn trustedDeviceHeaderName() -> text:
    "X-Trusted-Device-Token"

fn betaHeaderName() -> text:
    "anthropic-beta"

fn runnerVersionHeaderName() -> text:
    "x-environment-runner-version"

fn contentTypeHeaderName() -> text:
    "Content-Type"

fn authorizationHeaderName() -> text:
    "Authorization"

fn registrationTimeoutMs() -> i64:
    REGISTRATION_TIMEOUT_MS

fn bridgeRequestTimeoutMs() -> i64:
    BRIDGE_REQUEST_TIMEOUT_MS

fn bridgeApiRetryLimit() -> i64:
    1

fn bridgeApiEmptyPollDebugInterval() -> i64:
    EMPTY_POLL_LOG_INTERVAL

fn betaHeader() -> text:
    BETA_HEADER

fn anthropicVersion() -> text:
    ANTHROPIC_VERSION

fn bridgeLoginInstruction() -> text:
    BRIDGE_LOGIN_INSTRUCTION

fn emptyPollLogInterval() -> i64:
    EMPTY_POLL_LOG_INTERVAL

fn boolText(value: bool) -> text:
    if value:
        return "true"
    "false"

fn bridgeApiDebugPrefix() -> text:
    "[bridge:api]"

fn registrationContext() -> text:
    "Registration"

fn pollContext() -> text:
    "Poll"

fn acknowledgeContext() -> text:
    "Acknowledge"

fn stopWorkContext() -> text:
    "StopWork"

fn deregisterContext() -> text:
    "Deregister"

fn archiveSessionContext() -> text:
    "ArchiveSession"

fn reconnectSessionContext() -> text:
    "ReconnectSession"

fn heartbeatContext() -> text:
    "Heartbeat"

fn sendPermissionResponseEventContext() -> text:
    "SendPermissionResponseEvent"

fn registrationDebugLine(bridgeId: text) -> text:
    bridgeApiDebugPrefix() + " POST /v1/environments/bridge bridgeId=" + bridgeId

fn registrationSuccessDebugLine(status: i64, environmentId: text) -> text:
    bridgeApiDebugPrefix() + " POST /v1/environments/bridge -> " + status.to_text() + " environment_id=" + environmentId

fn pollEmptyDebugLine(status: i64, emptyPolls: i64) -> text:
    bridgeApiDebugPrefix() + " GET .../work/poll -> " + status.to_text() + " (no work, " + emptyPolls.to_text() + " consecutive empty polls)"

fn pollWorkDebugLine(status: i64, workId: text, dataType: text, sessionId: text) -> text:
    var line = bridgeApiDebugPrefix() + " GET .../work/poll -> " + status.to_text() + " workId=" + workId + " type=" + dataType
    if sessionId != "":
        line = line + " sessionId=" + sessionId
    line

fn acknowledgeDebugLine(workId: text) -> text:
    bridgeApiDebugPrefix() + " POST .../work/" + workId + "/ack"

fn stopWorkDebugLine(workId: text, force: bool) -> text:
    bridgeApiDebugPrefix() + " POST .../work/" + workId + "/stop force=" + boolText(force)

fn deregisterDebugLine(environmentId: text) -> text:
    bridgeApiDebugPrefix() + " DELETE /v1/environments/bridge/" + environmentId

fn archiveDebugLine(sessionId: text) -> text:
    bridgeApiDebugPrefix() + " POST /v1/sessions/" + sessionId + "/archive"

fn reconnectDebugLine(environmentId: text, sessionId: text) -> text:
    bridgeApiDebugPrefix() + " POST /v1/environments/" + environmentId + "/bridge/reconnect session_id=" + sessionId

fn heartbeatDebugLine(workId: text) -> text:
    bridgeApiDebugPrefix() + " POST .../work/" + workId + "/heartbeat"

fn permissionEventDebugLine(sessionId: text, eventType: text) -> text:
    bridgeApiDebugPrefix() + " POST /v1/sessions/" + sessionId + "/events type=" + eventType

fn oauth401NoRefreshDebugLine(context: text) -> text:
    bridgeApiDebugPrefix() + " " + context + ": 401 received, no refresh handler"

fn oauth401RefreshDebugLine(context: text) -> text:
    bridgeApiDebugPrefix() + " " + context + ": 401 received, attempting token refresh"

fn oauthRetryDebugLine(context: text) -> text:
    bridgeApiDebugPrefix() + " " + context + ": Token refreshed, retrying request"

fn oauthRetryStill401DebugLine(context: text) -> text:
    bridgeApiDebugPrefix() + " " + context + ": Retry after refresh also got 401"

fn oauthRefreshFailedDebugLine(context: text) -> text:
    bridgeApiDebugPrefix() + " " + context + ": Token refresh failed"
