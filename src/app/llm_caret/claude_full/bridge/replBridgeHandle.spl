class ReplBridgeHandle:
    bridgeSessionId: text
    environmentId: text
    connected: bool

impl ReplBridgeHandle:
    static fn new(bridgeSessionId: text, environmentId: text) -> ReplBridgeHandle:
        ReplBridgeHandle(bridgeSessionId: bridgeSessionId, environmentId: environmentId, connected: true)

    static fn empty() -> ReplBridgeHandle:
        ReplBridgeHandle(bridgeSessionId: "", environmentId: "", connected: false)

    me hasSession() -> bool:
        me.connected and me.bridgeSessionId != ""

class ReplBridgeHandleSlot:
    handle: ReplBridgeHandle
    hasHandle: bool
    publishedCompatId: text
    updateAttempts: i64

impl ReplBridgeHandleSlot:
    static fn new() -> ReplBridgeHandleSlot:
        ReplBridgeHandleSlot(handle: ReplBridgeHandle.empty(), hasHandle: false, publishedCompatId: "", updateAttempts: 0)

    me setReplBridgeHandle(handle: ReplBridgeHandle):
        me.handle = handle
        me.hasHandle = handle.hasSession()
        me.publishSelfBridgeCompatId()

    me clearReplBridgeHandle():
        me.handle = ReplBridgeHandle.empty()
        me.hasHandle = false
        me.publishSelfBridgeCompatId()

    me getReplBridgeHandle() -> ReplBridgeHandle:
        if me.hasHandle:
            return me.handle
        ReplBridgeHandle.empty()

    me getSelfBridgeCompatId() -> text:
        if not me.hasHandle:
            return ""
        toCompatSessionId(me.handle.bridgeSessionId)

    me publishSelfBridgeCompatId():
        me.publishedCompatId = me.getSelfBridgeCompatId()
        me.updateAttempts = me.updateAttempts + 1

    me hasPublishedClear() -> bool:
        me.updateAttempts > 0 and me.publishedCompatId == ""

fn getReplBridgeHandle(slot: ReplBridgeHandleSlot) -> ReplBridgeHandle:
    slot.getReplBridgeHandle()

fn getSelfBridgeCompatId(slot: ReplBridgeHandleSlot) -> text:
    slot.getSelfBridgeCompatId()

fn toCompatSessionId(sessionValue: text) -> text:
    if sessionValue.starts_with("cse_"):
        return "session_" + sessionValue.substring(4, sessionValue.len())
    sessionValue

fn replBridgeHandlePurpose() -> text:
    "global active REPL bridge handle"

fn replBridgeHandlePublishReason() -> text:
    "dedupe local bridge sessions"
