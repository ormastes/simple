"""
Deterministic createSession.ts parity surface for bridge session lifecycle.
"""

const CREATE_SESSION_SOURCE_LINES: i64 = 384

class BridgeGitSource:
    branch: text
    repoUrl: text
    cwd: text

impl BridgeGitSource:
    static fn new(branch: text, repoUrl: text, cwd: text) -> BridgeGitSource:
        BridgeGitSource(branch: branch, repoUrl: repoUrl, cwd: cwd)

class BridgeGitOutcome:
    ok: bool
    source: BridgeGitSource
    error: text

impl BridgeGitOutcome:
    static fn ok(source: BridgeGitSource) -> BridgeGitOutcome:
        BridgeGitOutcome(ok: true, source: source, error: "")

    static fn failed(error: text) -> BridgeGitOutcome:
        BridgeGitOutcome(ok: false, source: BridgeGitSource.new("", "", ""), error: error)

class BridgeSessionEvent:
    kind: text
    sessionId: text
    title: text

impl BridgeSessionEvent:
    static fn new(kind: text, sessionId: text, title: text) -> BridgeSessionEvent:
        BridgeSessionEvent(kind: kind, sessionId: sessionId, title: title)

class BridgeSessionRecord:
    sessionId: text
    title: text
    archived: bool
    git: BridgeGitSource
    events: [BridgeSessionEvent]

impl BridgeSessionRecord:
    static fn new(sessionId: text, title: text, git: BridgeGitSource) -> BridgeSessionRecord:
        BridgeSessionRecord(sessionId: sessionId, title: title, archived: false, git: git, events: [BridgeSessionEvent.new("created", sessionId, title)])

fn createBridgeSession(sessionId: text, title: text, git: BridgeGitSource) -> BridgeSessionRecord:
    BridgeSessionRecord.new(sessionId, normalizedBridgeSessionTitle(title), git)

fn getBridgeSession(record: BridgeSessionRecord, sessionId: text) -> BridgeSessionRecord:
    if record.sessionId == sessionId and not record.archived:
        return record
    BridgeSessionRecord.new("", "", BridgeGitSource.new("", "", ""))

fn archiveBridgeSession(record: BridgeSessionRecord) -> BridgeSessionRecord:
    BridgeSessionRecord(sessionId: record.sessionId, title: record.title, archived: true, git: record.git, events: record.events + [BridgeSessionEvent.new("archived", record.sessionId, record.title)])

fn updateBridgeSessionTitle(record: BridgeSessionRecord, title: text) -> BridgeSessionRecord:
    val normalized = normalizedBridgeSessionTitle(title)
    BridgeSessionRecord(sessionId: record.sessionId, title: normalized, archived: record.archived, git: record.git, events: record.events + [BridgeSessionEvent.new("title", record.sessionId, normalized)])

fn normalizedBridgeSessionTitle(title: text) -> text:
    val trimmed = title.trim()
    if trimmed == "":
        return "Untitled session"
    if trimmed.len() > 80:
        return trimmed.substring(0, 80)
    trimmed

fn createSessionSourceLinesModeled() -> i64:
    CREATE_SESSION_SOURCE_LINES

