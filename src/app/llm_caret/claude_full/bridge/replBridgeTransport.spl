const V1_SEQUENCE_NUM: i64 = 0
const V2_DROPPED_BATCH_COUNT: i64 = 0
const EPOCH_MISMATCH_CLOSE_CODE: i64 = 4090
const INIT_FAILURE_CLOSE_CODE: i64 = 4091
const SSE_EXHAUSTED_CLOSE_CODE: i64 = 4092
const DEFAULT_HEARTBEAT_INTERVAL_MS: i64 = 20000

class ReplTransportEvent:
    kind: text
    payload: text

impl ReplTransportEvent:
    static fn new(kind: text, payload: text) -> ReplTransportEvent:
        ReplTransportEvent(kind: kind, payload: payload)

class ReplTransportOpts:
    sessionUrl: text
    ingressToken: text
    sessionId: text
    initialSequenceNum: i64
    epoch: i64
    heartbeatIntervalMs: i64
    heartbeatJitterFraction: i64
    outboundOnly: bool
    hasPerInstanceAuth: bool

impl ReplTransportOpts:
    static fn new(sessionUrl: text, ingressToken: text, sessionId: text) -> ReplTransportOpts:
        ReplTransportOpts(sessionUrl: sessionUrl, ingressToken: ingressToken, sessionId: sessionId, initialSequenceNum: 0, epoch: 0, heartbeatIntervalMs: DEFAULT_HEARTBEAT_INTERVAL_MS, heartbeatJitterFraction: 0, outboundOnly: false, hasPerInstanceAuth: false)

    me withEpoch(epoch: i64) -> ReplTransportOpts:
        ReplTransportOpts(sessionUrl: me.sessionUrl, ingressToken: me.ingressToken, sessionId: me.sessionId, initialSequenceNum: me.initialSequenceNum, epoch: epoch, heartbeatIntervalMs: me.heartbeatIntervalMs, heartbeatJitterFraction: me.heartbeatJitterFraction, outboundOnly: me.outboundOnly, hasPerInstanceAuth: me.hasPerInstanceAuth)

    me withInitialSequenceNum(seq: i64) -> ReplTransportOpts:
        ReplTransportOpts(sessionUrl: me.sessionUrl, ingressToken: me.ingressToken, sessionId: me.sessionId, initialSequenceNum: seq, epoch: me.epoch, heartbeatIntervalMs: me.heartbeatIntervalMs, heartbeatJitterFraction: me.heartbeatJitterFraction, outboundOnly: me.outboundOnly, hasPerInstanceAuth: me.hasPerInstanceAuth)

    me outbound() -> ReplTransportOpts:
        ReplTransportOpts(sessionUrl: me.sessionUrl, ingressToken: me.ingressToken, sessionId: me.sessionId, initialSequenceNum: me.initialSequenceNum, epoch: me.epoch, heartbeatIntervalMs: me.heartbeatIntervalMs, heartbeatJitterFraction: me.heartbeatJitterFraction, outboundOnly: true, hasPerInstanceAuth: me.hasPerInstanceAuth)

    me perInstanceAuth() -> ReplTransportOpts:
        ReplTransportOpts(sessionUrl: me.sessionUrl, ingressToken: me.ingressToken, sessionId: me.sessionId, initialSequenceNum: me.initialSequenceNum, epoch: me.epoch, heartbeatIntervalMs: me.heartbeatIntervalMs, heartbeatJitterFraction: me.heartbeatJitterFraction, outboundOnly: me.outboundOnly, hasPerInstanceAuth: true)

class ReplBridgeTransport:
    version: text
    connected: bool
    closed: bool
    ccrInitialized: bool
    outboundOnly: bool
    lastSequenceNum: i64
    droppedBatchCount: i64
    epoch: i64
    writes: [text]
    dataCallbacks: i64
    closeCallbacks: i64
    connectCallbacks: i64
    closeCodes: [i64]
    stateReports: [text]
    metadataReports: [text]
    deliveries: [text]
    flushed: bool
    logs: [text]

impl ReplBridgeTransport:
    static fn v1(lastSequenceNum: i64, droppedBatchCount: i64) -> ReplBridgeTransport:
        ReplBridgeTransport(version: "v1", connected: false, closed: false, ccrInitialized: true, outboundOnly: false, lastSequenceNum: V1_SEQUENCE_NUM, droppedBatchCount: droppedBatchCount, epoch: 0, writes: [], dataCallbacks: 0, closeCallbacks: 0, connectCallbacks: 0, closeCodes: [], stateReports: [], metadataReports: [], deliveries: [], flushed: false, logs: [])

    static fn v2(opts: ReplTransportOpts, registeredEpoch: i64) -> ReplBridgeTransport:
        val epoch = if opts.epoch > 0: opts.epoch else: registeredEpoch
        val source = if opts.epoch > 0: " (from /bridge)" else: " (via registerWorker)"
        ReplBridgeTransport(version: "v2", connected: false, closed: false, ccrInitialized: false, outboundOnly: opts.outboundOnly, lastSequenceNum: opts.initialSequenceNum, droppedBatchCount: V2_DROPPED_BATCH_COUNT, epoch: epoch, writes: [], dataCallbacks: 0, closeCallbacks: 0, connectCallbacks: 0, closeCodes: [], stateReports: [], metadataReports: [], deliveries: [], flushed: false, logs: ["[bridge:repl] CCR v2: worker sessionId=" + opts.sessionId + " epoch=" + epoch.to_text() + source])

    me write(message: text) -> ():
        if me.closed:
            return
        me.writes = me.writes + [message]

    me writeBatch(messages: [text]) -> ():
        var i = 0
        while i < messages.len():
            if me.closed:
                return
            me.write(messages[i])
            i = i + 1

    me close() -> ():
        me.closed = true
        me.connected = false

    me isConnectedStatus() -> bool:
        if me.version == "v2":
            return me.ccrInitialized and not me.closed
        me.connected and not me.closed

    me getStateLabel() -> text:
        if me.closed:
            return "closed"
        if me.version == "v2":
            if me.connected and me.ccrInitialized:
                return "connected"
            if me.connected:
                return "init"
            return "connecting"
        if me.connected:
            return "connected"
        "connecting"

    me setOnData() -> ():
        me.dataCallbacks = me.dataCallbacks + 1

    me setOnClose() -> ():
        me.closeCallbacks = me.closeCallbacks + 1

    me setOnConnect() -> ():
        me.connectCallbacks = me.connectCallbacks + 1

    me connect() -> ():
        if me.closed:
            return
        if me.version == "v2":
            if not me.outboundOnly:
                me.connected = true
            me.ccrInitialized = true
            me.logs = me.logs + ["[bridge:repl] v2 transport ready for writes (epoch=" + me.epoch.to_text() + ", sse=" + ifText(me.connected, "open", "opening") + ")"]
            return
        me.connected = true

    me getLastSequenceNum() -> i64:
        if me.version == "v1":
            return V1_SEQUENCE_NUM
        me.lastSequenceNum

    me reportState(state: text) -> ():
        if me.version == "v2":
            me.stateReports = me.stateReports + [state]

    me reportMetadata(metadata: text) -> ():
        if me.version == "v2":
            me.metadataReports = me.metadataReports + [metadata]

    me reportDelivery(eventId: text, status: text) -> ():
        if me.version == "v2":
            me.deliveries = me.deliveries + [eventId + ":" + status]

    me receiveEvent(eventId: text, payload: text) -> ReplTransportEvent:
        if me.version == "v2":
            me.reportDelivery(eventId, "received")
            me.reportDelivery(eventId, "processed")
            me.lastSequenceNum = me.lastSequenceNum + 1
        ReplTransportEvent.new(eventId, payload)

    me flush() -> ():
        if me.version == "v2":
            me.flushed = true

    me epochMismatch() -> ():
        me.logs = me.logs + ["[bridge:repl] CCR v2: epoch superseded (409) - closing for poll-loop recovery"]
        me.close()
        me.closeCodes = me.closeCodes + [EPOCH_MISMATCH_CLOSE_CODE]

    me initFailure(message: text) -> ():
        me.logs = me.logs + ["[bridge:repl] CCR v2 initialize failed: " + message]
        me.close()
        me.closeCodes = me.closeCodes + [INIT_FAILURE_CLOSE_CODE]

    me sseClose(code: i64) -> ():
        me.close()
        if code == 0:
            me.closeCodes = me.closeCodes + [SSE_EXHAUSTED_CLOSE_CODE]
        else:
            me.closeCodes = me.closeCodes + [code]

fn createV1ReplTransport(lastSequenceNum: i64, droppedBatchCount: i64) -> ReplBridgeTransport:
    ReplBridgeTransport.v1(lastSequenceNum, droppedBatchCount)

fn createV2ReplTransport(opts: ReplTransportOpts, registeredEpoch: i64) -> ReplBridgeTransport:
    ReplBridgeTransport.v2(opts, registeredEpoch)

fn deriveSseStreamUrl(sessionUrl: text) -> text:
    trimTrailingSlashes(sessionUrl) + "/worker/events/stream"

fn getAuthHeader(token: text) -> text:
    if token == "":
        return ""
    "Authorization: Bearer " + token

fn shouldUsePerInstanceAuth(opts: ReplTransportOpts) -> bool:
    opts.hasPerInstanceAuth

fn shouldUpdateProcessWideAuth(opts: ReplTransportOpts) -> bool:
    not opts.hasPerInstanceAuth

fn shouldRegisterWorker(opts: ReplTransportOpts) -> bool:
    opts.epoch <= 0

fn resolvedEpoch(opts: ReplTransportOpts, registeredEpoch: i64) -> i64:
    if opts.epoch > 0:
        return opts.epoch
    registeredEpoch

fn trimTrailingSlashes(url: text) -> text:
    var end = url.len()
    while end > 0 and url.substring(end - 1, end) == "/":
        end = end - 1
    url.substring(0, end)

fn ifText(condition: bool, yes: text, no: text) -> text:
    if condition:
        return yes
    no

fn v1LastSequenceNum() -> i64:
    V1_SEQUENCE_NUM

fn v2DroppedBatchCount() -> i64:
    V2_DROPPED_BATCH_COUNT

fn epochMismatchCloseCode() -> i64:
    EPOCH_MISMATCH_CLOSE_CODE

fn initFailureCloseCode() -> i64:
    INIT_FAILURE_CLOSE_CODE

fn sseExhaustedCloseCode() -> i64:
    SSE_EXHAUSTED_CLOSE_CODE

fn defaultHeartbeatIntervalMs() -> i64:
    DEFAULT_HEARTBEAT_INTERVAL_MS

fn v1ReadTransportName() -> text:
    "HybridTransport"

fn v2ReadTransportName() -> text:
    "SSETransport"

fn v2WriteTransportName() -> text:
    "CCRClient"

fn v2WritePathName() -> text:
    "CCRClient.writeEvent"

fn sseWritePathIsUsedForV2() -> bool:
    false

fn v2DeliveryStatusesOnReceive() -> [text]:
    ["received", "processed"]

fn v2CloseRecoveryOwner() -> text:
    "poll loop"

fn v2StateLabelClosed() -> text:
    "closed"

fn v2StateLabelConnected() -> text:
    "connected"

fn v2StateLabelInit() -> text:
    "init"

fn v2StateLabelConnecting() -> text:
    "connecting"

fn reportStateEndpointPurpose() -> text:
    "PUT /worker state"

fn reportMetadataEndpointPurpose() -> text:
    "PUT /worker external_metadata"

fn reportDeliveryEndpointPurpose() -> text:
    "POST /worker/events/<id>/delivery"

fn flushPurpose() -> text:
    "Drain the v2 write queue before close"

fn sequenceCarryoverPurpose() -> text:
    "resume from where the old stream left off"

fn outboundOnlyPurpose() -> text:
    "skip opening the SSE read stream"

fn epochMismatchMessage() -> text:
    "epoch superseded"

fn initFailureMessage() -> text:
    "initialize failed"

fn sseExhaustedMessage() -> text:
    "reconnect budget exhausted"

fn transportAbstractionPurpose() -> text:
    "confine v1/v2 choice to construction"

fn v1ReportMethodsAreNoop() -> bool:
    true

fn v1FlushIsImmediate() -> bool:
    true

fn v2WriteReadinessIsCcrInitialized() -> bool:
    true

fn v2SseOpenIsOrthogonalToWrites() -> bool:
    true

fn v2RegisterWorkerFailurePropagates() -> bool:
    true

fn v2AuthUsesJwtNotOauth() -> bool:
    true

fn v2MultiSessionUsesPerInstanceAuth() -> bool:
    true

fn v2LegacySingleSessionUsesEnvAuth() -> bool:
    true

fn v2OutboundOnlyStillWrites() -> bool:
    true

fn v2DroppedBatchesUnsupported() -> bool:
    true

fn v1ReplaySemanticsHandledServerSide() -> bool:
    true

fn closeCodeMeaning(code: i64) -> text:
    if code == EPOCH_MISMATCH_CLOSE_CODE:
        return "epoch mismatch"
    if code == INIT_FAILURE_CLOSE_CODE:
        return "init failure"
    if code == SSE_EXHAUSTED_CLOSE_CODE:
        return "sse exhausted"
    "transport close"

fn v1WritePathName() -> text:
    "HybridTransport.write"

fn v1BatchWritePathName() -> text:
    "HybridTransport.writeBatch"

fn v1StateLabelSource() -> text:
    "HybridTransport.getStateLabel"

fn v2InitializeMethodName() -> text:
    "CCRClient.initialize"

fn v2HeartbeatOwner() -> text:
    "CCRClient"

fn v2ReadLoopOwner() -> text:
    "SSETransport.connect"

fn v2EventHookMethod() -> text:
    "SSETransport.setOnEvent"

fn v2ReceivedDeliveryAutoFired() -> bool:
    true

fn v2ProcessedDeliveryImmediateAck() -> bool:
    true

fn v2WriteBatchPreservesOrder() -> bool:
    true

fn v2CloseStopsHeartbeat() -> bool:
    true

fn v2OnConnectAfterInitialize() -> bool:
    true

fn v2OnCloseSseUndefinedMapsTo4092() -> bool:
    true

fn v2InitFailureNotifiesReplBridge() -> bool:
    true

fn v2EpochMismatchThrowsToUnwindRequest() -> bool:
    true

fn v2ReadStreamConnectIsFireAndForget() -> bool:
    true

fn v2InitializeFailureRecovery() -> text:
    "close resources and notify replBridge via onClose"

fn v2EpochMismatchRecovery() -> text:
    "close for poll-loop recovery"

fn v2OutboundOnlySkipsDeliveryAck() -> bool:
    true

fn v2SessionUrlToSsePathSuffix() -> text:
    "/worker/events/stream"

fn v2WorkerRegisterPathSuffix() -> text:
    "/worker/register"

fn v2WorkerEventsPathSuffix() -> text:
    "/worker/events"

fn v2WorkerStatePathSuffix() -> text:
    "/worker/state"

fn v2WorkerMetadataPathSuffix() -> text:
    "/worker/external_metadata"

fn v2WorkerDeliveryStatusProcessing() -> text:
    "processing"

fn v2WorkerDeliveryStatusProcessed() -> text:
    "processed"

fn v2WorkerDeliveryStatusReceived() -> text:
    "received"

fn transportUsesSingleAdapterInterface() -> bool:
    true
