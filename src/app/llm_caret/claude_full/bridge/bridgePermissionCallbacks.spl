struct PermissionUpdate:
    rules: [text]
    behavior: text
    destination: text
    mode: text

struct BridgePermissionResponse:
    behavior: text
    updatedInput: text
    updatedPermissions: [PermissionUpdate]
    message: text

struct BridgePermissionRequest:
    requestId: text
    toolName: text
    input: text
    toolUseId: text
    description: text
    permissionSuggestions: [PermissionUpdate]
    blockedPath: text
    canceled: bool

struct BridgePermissionSubscription:
    id: i64
    requestId: text
    active: bool
    deliveredCount: i64
    lastBehavior: text
    lastMessage: text

class BridgePermissionUnsubscribe:
    subscriptionId: i64

class BridgePermissionCallbacks:
    requests: [BridgePermissionRequest]
    responses: [BridgePermissionResponse]
    subscriptions: [BridgePermissionSubscription]
    nextSubscriptionId: i64

impl BridgePermissionCallbacks:
    static fn new() -> BridgePermissionCallbacks:
        BridgePermissionCallbacks(requests: [], responses: [], subscriptions: [], nextSubscriptionId: 1)

    me sendRequest(requestId: text, toolName: text, input: text, toolUseId: text, description: text, permissionSuggestions: [PermissionUpdate], blockedPath: text) -> ():
        me.requests = me.requests + [BridgePermissionRequest(requestId: requestId, toolName: toolName, input: input, toolUseId: toolUseId, description: description, permissionSuggestions: permissionSuggestions, blockedPath: blockedPath, canceled: false)]

    me sendResponse(requestId: text, response: BridgePermissionResponse) -> bool:
        if not isBridgePermissionResponse(response):
            return false
        me.responses = me.responses + [response]
        var next: [BridgePermissionSubscription] = []
        for subscription in me.subscriptions:
            if subscription.active and subscription.requestId == requestId:
                next = next + [BridgePermissionSubscription(id: subscription.id, requestId: subscription.requestId, active: true, deliveredCount: subscription.deliveredCount + 1, lastBehavior: response.behavior, lastMessage: response.message)]
            else:
                next = next + [subscription]
        me.subscriptions = next
        true

    me cancelRequest(requestId: text) -> bool:
        var changed = false
        var next: [BridgePermissionRequest] = []
        for request in me.requests:
            if request.requestId == requestId:
                next = next + [BridgePermissionRequest(requestId: request.requestId, toolName: request.toolName, input: request.input, toolUseId: request.toolUseId, description: request.description, permissionSuggestions: request.permissionSuggestions, blockedPath: request.blockedPath, canceled: true)]
                changed = true
            else:
                next = next + [request]
        me.requests = next
        changed

    me onResponse(requestId: text) -> BridgePermissionUnsubscribe:
        val id = me.nextSubscriptionId
        me.nextSubscriptionId = me.nextSubscriptionId + 1
        me.subscriptions = me.subscriptions + [BridgePermissionSubscription(id: id, requestId: requestId, active: true, deliveredCount: 0, lastBehavior: "", lastMessage: "")]
        BridgePermissionUnsubscribe(subscriptionId: id)

    me unsubscribe(subscriptionId: i64) -> bool:
        var changed = false
        var next: [BridgePermissionSubscription] = []
        for subscription in me.subscriptions:
            if subscription.id == subscriptionId:
                next = next + [BridgePermissionSubscription(id: subscription.id, requestId: subscription.requestId, active: false, deliveredCount: subscription.deliveredCount, lastBehavior: subscription.lastBehavior, lastMessage: subscription.lastMessage)]
                changed = true
            else:
                next = next + [subscription]
        me.subscriptions = next
        changed

    me requestCount() -> i64:
        me.requests.len()

    me responseCount() -> i64:
        me.responses.len()

    me activeSubscriptionCount() -> i64:
        var count = 0
        for subscription in me.subscriptions:
            if subscription.active:
                count = count + 1
        count

    me deliveredCount(subscriptionId: i64) -> i64:
        for subscription in me.subscriptions:
            if subscription.id == subscriptionId:
                return subscription.deliveredCount
        0

    me lastDeliveredBehavior(subscriptionId: i64) -> text:
        for subscription in me.subscriptions:
            if subscription.id == subscriptionId:
                return subscription.lastBehavior
        ""

    me lastDeliveredMessage(subscriptionId: i64) -> text:
        for subscription in me.subscriptions:
            if subscription.id == subscriptionId:
                return subscription.lastMessage
        ""

fn bridgePermissionCallbacksNew() -> BridgePermissionCallbacks:
    BridgePermissionCallbacks.new()

fn bridgePermissionResponse(behavior: text, message: text) -> BridgePermissionResponse:
    BridgePermissionResponse(behavior: behavior, updatedInput: "", updatedPermissions: [], message: message)

fn permissionUpdate(rule: text, behavior: text, destination: text) -> PermissionUpdate:
    PermissionUpdate(rules: [rule], behavior: behavior, destination: destination, mode: "")

fn isBridgePermissionResponse(value: BridgePermissionResponse) -> bool:
    value.behavior == "allow" or value.behavior == "deny"
