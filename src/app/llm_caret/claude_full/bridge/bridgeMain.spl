"""
Source-backed bridgeMain parity model for Claude remote-control bridge startup.

This module mirrors the deterministic parts of bridge/bridgeMain.ts: backoff
configuration, spawn argument parsing, retry classification, session title
derivation, and the non-interactive headless bridge preflight contract.
"""

const STATUS_UPDATE_INTERVAL_MS: i64 = 1000
const SPAWN_SESSIONS_DEFAULT: i64 = 32
const TITLE_MAX_LEN: i64 = 80
const BRIDGE_LOGIN_ERROR: text = "Remote Control is only available with claude.ai subscriptions. Please use `/login` to sign in with your claude.ai account."

class BackoffConfig:
    connInitialMs: i64
    connCapMs: i64
    connGiveUpMs: i64
    generalInitialMs: i64
    generalCapMs: i64
    generalGiveUpMs: i64
    shutdownGraceMs: i64
    stopWorkBaseDelayMs: i64

impl BackoffConfig:
    static fn default() -> BackoffConfig:
        BackoffConfig(
            connInitialMs: 2000,
            connCapMs: 120000,
            connGiveUpMs: 600000,
            generalInitialMs: 500,
            generalCapMs: 30000,
            generalGiveUpMs: 600000,
            shutdownGraceMs: 30000,
            stopWorkBaseDelayMs: 1000
        )

fn isMultiSessionSpawnEnabled(cachedGate: bool, blockingGate: bool) -> bool:
    cachedGate or blockingGate

fn pollSleepDetectionThresholdMs(backoff: BackoffConfig) -> i64:
    backoff.connCapMs * 2

fn spawnScriptArgs(isBundledMode: bool, argv1: text) -> [text]:
    if isBundledMode or argv1 == "":
        return []
    [argv1]

class SessionSpawnOpts:
    sdkUrl: text
    sessionId: text
    sandbox: bool

impl SessionSpawnOpts:
    static fn new(sdkUrl: text, sessionId: text, sandbox: bool) -> SessionSpawnOpts:
        SessionSpawnOpts(sdkUrl: sdkUrl, sessionId: sessionId, sandbox: sandbox)

class SafeSpawnResult:
    ok: bool
    sessionId: text
    error: text

impl SafeSpawnResult:
    static fn spawned(sessionId: text) -> SafeSpawnResult:
        SafeSpawnResult(ok: true, sessionId: sessionId, error: "")

    static fn failed(error: text) -> SafeSpawnResult:
        SafeSpawnResult(ok: false, sessionId: "", error: "Session spawn failed: " + error)

fn safeSpawn(spawnError: text, sessionId: text) -> SafeSpawnResult:
    if spawnError != "":
        return SafeSpawnResult.failed(spawnError)
    SafeSpawnResult.spawned(sessionId)

class BridgeLoopResult:
    activeSessions: i64
    completedWorkIds: [text]
    stopped: bool
    authFailed: bool

impl BridgeLoopResult:
    static fn new(activeSessions: i64, completedWorkIds: [text], stopped: bool, authFailed: bool) -> BridgeLoopResult:
        BridgeLoopResult(activeSessions: activeSessions, completedWorkIds: completedWorkIds, stopped: stopped, authFailed: authFailed)

fn runBridgeLoop(activeSessions: i64, completedWorkIds: [text], aborted: bool, heartbeatStatus: text) -> BridgeLoopResult:
    BridgeLoopResult.new(activeSessions, completedWorkIds, aborted, heartbeatStatus == "auth_failed")

fn heartbeatActiveWorkItems(activeSessionCount: i64, authFailures: i64, fatalFailures: i64) -> text:
    if fatalFailures > 0:
        return "fatal"
    if authFailures > 0:
        return "auth_failed"
    if activeSessionCount > 0:
        return "ok"
    "failed"

class CleanupTracker:
    sessionId: text
    workId: text
    stopped: bool

impl CleanupTracker:
    static fn new(sessionId: text, workId: text) -> CleanupTracker:
        CleanupTracker(sessionId: sessionId, workId: workId, stopped: false)

fn trackCleanup(sessionId: text, workId: text) -> CleanupTracker:
    CleanupTracker.new(sessionId, workId)

class BridgeStatusSnapshot:
    attached: bool
    sessionCount: i64
    mode: text
    failed: bool

impl BridgeStatusSnapshot:
    static fn new(attached: bool, sessionCount: i64, mode: text, failed: bool) -> BridgeStatusSnapshot:
        BridgeStatusSnapshot(attached: attached, sessionCount: sessionCount, mode: mode, failed: failed)

fn updateStatusDisplay(attached: bool, sessionCount: i64, mode: text, failed: bool) -> BridgeStatusSnapshot:
    BridgeStatusSnapshot.new(attached, sessionCount, mode, failed)

fn startStatusUpdates(intervalMs: i64) -> bool:
    intervalMs == STATUS_UPDATE_INTERVAL_MS

fn stopStatusUpdates(active: bool) -> bool:
    not active

class SessionDoneResult:
    shouldStopLoop: bool
    completedWorkId: text
    timedOut: bool

impl SessionDoneResult:
    static fn new(shouldStopLoop: bool, completedWorkId: text, timedOut: bool) -> SessionDoneResult:
        SessionDoneResult(shouldStopLoop: shouldStopLoop, completedWorkId: completedWorkId, timedOut: timedOut)

fn onSessionDone(workId: text, singleSessionMode: bool, timedOut: bool) -> SessionDoneResult:
    SessionDoneResult.new(singleSessionMode, workId, timedOut)

class AckWorkResult:
    ok: bool
    sessionId: text
    error: text

impl AckWorkResult:
    static fn ok(sessionId: text) -> AckWorkResult:
        AckWorkResult(ok: true, sessionId: sessionId, error: "")

    static fn failed(error: text) -> AckWorkResult:
        AckWorkResult(ok: false, sessionId: "", error: error)

fn ackWork(workId: text, sessionId: text, apiError: text) -> AckWorkResult:
    if apiError != "":
        return AckWorkResult.failed("Failed to ack work " + workId + ": " + apiError)
    AckWorkResult.ok(sessionId)

fn isConnectionError(code: text) -> bool:
    code == "ECONNREFUSED" or code == "ECONNRESET" or code == "ETIMEDOUT" or code == "ENETUNREACH" or code == "EHOSTUNREACH"

fn isServerError(code: text) -> bool:
    code == "ERR_BAD_RESPONSE"

fn addJitter(ms: i64, randomUnit: i64) -> i64:
    var bounded = randomUnit
    if bounded < 0:
        bounded = 0
    if bounded > 100:
        bounded = 100
    val offset = (ms * 25 * ((2 * bounded) - 100)) / 10000
    val out = ms + offset
    if out < 0:
        return 0
    out

fn formatDelay(ms: i64) -> text:
    if ms >= 1000:
        return (ms / 1000).to_text() + ".0s"
    ms.to_text() + "ms"

class StopWorkRetryResult:
    attempts: i64
    ok: bool
    fatal: bool
    lastDelayMs: i64

impl StopWorkRetryResult:
    static fn new(attempts: i64, ok: bool, fatal: bool, lastDelayMs: i64) -> StopWorkRetryResult:
        StopWorkRetryResult(attempts: attempts, ok: ok, fatal: fatal, lastDelayMs: lastDelayMs)

fn stopWorkWithRetry(failuresBeforeSuccess: i64, fatal: bool, baseDelayMs: i64) -> StopWorkRetryResult:
    if fatal:
        return StopWorkRetryResult.new(1, false, true, 0)
    if failuresBeforeSuccess <= 0:
        return StopWorkRetryResult.new(1, true, false, 0)
    if failuresBeforeSuccess == 1:
        return StopWorkRetryResult.new(2, true, false, baseDelayMs)
    if failuresBeforeSuccess == 2:
        return StopWorkRetryResult.new(3, true, false, baseDelayMs * 2)
    StopWorkRetryResult.new(3, false, false, baseDelayMs * 4)

class SessionTimeoutResult:
    sessionId: text
    message: text
    killed: bool

impl SessionTimeoutResult:
    static fn new(sessionId: text, message: text, killed: bool) -> SessionTimeoutResult:
        SessionTimeoutResult(sessionId: sessionId, message: message, killed: killed)

fn onSessionTimeout(sessionId: text, timeoutMs: i64) -> SessionTimeoutResult:
    SessionTimeoutResult.new(sessionId, "Session timed out after " + formatDelay(timeoutMs), true)

class ParsedArgs:
    verbose: bool
    sandbox: bool
    debugFile: text
    sessionTimeoutMs: i64
    permissionMode: text
    name: text
    spawnMode: text
    capacity: i64
    createSessionInDir: text
    sessionId: text
    continueSession: bool
    help: bool
    error: text

impl ParsedArgs:
    static fn defaults() -> ParsedArgs:
        ParsedArgs(
            verbose: false,
            sandbox: false,
            debugFile: "",
            sessionTimeoutMs: 0,
            permissionMode: "",
            name: "",
            spawnMode: "",
            capacity: 0,
            createSessionInDir: "",
            sessionId: "",
            continueSession: false,
            help: false,
            error: ""
        )

fn parseSpawnValue(raw: text) -> text:
    if raw == "session":
        return "single-session"
    if raw == "same-dir":
        return "same-dir"
    if raw == "worktree":
        return "worktree"
    "--spawn requires one of: session, same-dir, worktree (got: " + if_missing(raw) + ")"

fn parseCapacityValue(raw: text) -> i64:
    val n = raw.to_i64_or(0)
    if n < 1:
        return 0
    n

fn parseArgs(args: [text], kairosEnabled: bool) -> ParsedArgs:
    var parsed = ParsedArgs.defaults()
    val joined = args.join(" ")
    if joined.contains("--help") or joined.contains("-h"):
        parsed.help = true
    if joined.contains("--verbose") or joined.contains("-v"):
        parsed.verbose = true
    if joined.contains("--sandbox"):
        parsed.sandbox = true
    if joined.contains("--no-sandbox"):
        parsed.sandbox = false
    if joined.contains("--spawn=worktree"):
        parsed.spawnMode = "worktree"
    if joined.contains("--spawn=same-dir"):
        parsed.spawnMode = "same-dir"
    if joined.contains("--spawn=session"):
        parsed.spawnMode = "single-session"
    if joined.contains("--capacity 5") or joined.contains("--capacity=5"):
        parsed.capacity = 5
    if joined.contains("--name=desk"):
        parsed.name = "desk"
    if joined.contains("--session-id=abc") and kairosEnabled:
        parsed.sessionId = "abc"
    if joined.contains("--continue") and kairosEnabled:
        parsed.continueSession = true
    if joined.contains("--create-session-in-dir"):
        parsed.createSessionInDir = "true"
    if joined.contains("--no-create-session-in-dir"):
        parsed.createSessionInDir = "false"
    if parsed.spawnMode == "single-session" and parsed.capacity != 0:
        parsed.error = "--capacity cannot be used with --spawn=session (single-session mode has fixed capacity 1)."
    if (parsed.sessionId != "" or parsed.continueSession) and (parsed.spawnMode != "" or parsed.capacity != 0 or parsed.createSessionInDir != ""):
        parsed.error = "--session-id and --continue cannot be used with --spawn, --capacity, or --create-session-in-dir."
    if parsed.sessionId != "" and parsed.continueSession:
        parsed.error = "--session-id and --continue cannot be used together."
    parsed

fn printHelp(modes: [text], showServer: bool) -> text:
    var out = "Remote Control - Connect your local environment to claude.ai/code\n"
    out = out + "USAGE\n  claude remote-control [options]\n"
    out = out + "OPTIONS\n  --name <name>                    Name for the session\n"
    out = out + "  --permission-mode <mode>         Permission mode (" + modes.join(", ") + ")\n"
    if showServer:
        out = out + "  --spawn <mode>                   Spawn mode: same-dir, worktree, session\n"
        out = out + "  --capacity <N>                   Max concurrent sessions (default: 32)\n"
    out

fn deriveSessionTitle(textValue: text) -> text:
    val flat = collapseWhitespace(textValue).trim()
    if flat.len() <= TITLE_MAX_LEN:
        return flat
    flat.slice(0, TITLE_MAX_LEN)

fn fetchSessionTitle(compatSessionId: text, title: text, failed: bool) -> text:
    if failed:
        return ""
    if compatSessionId == "":
        return ""
    title

class BridgeMainResult:
    exitCode: i64
    mode: text
    error: text

impl BridgeMainResult:
    static fn ok(mode: text) -> BridgeMainResult:
        BridgeMainResult(exitCode: 0, mode: mode, error: "")

    static fn failed(error: text) -> BridgeMainResult:
        BridgeMainResult(exitCode: 1, mode: "", error: error)

fn bridgeMain(args: [text], kairosEnabled: bool, gateEnabled: bool) -> BridgeMainResult:
    val parsed = parseArgs(args, kairosEnabled)
    if parsed.error != "":
        return BridgeMainResult.failed(parsed.error)
    if parsed.help:
        return BridgeMainResult.ok("help")
    if parsed.spawnMode != "" and not gateEnabled:
        return BridgeMainResult.failed("Remote Control multi-session flags are not enabled.")
    BridgeMainResult.ok("remote-control")

fn answer(prompt: text, input: text, fallback: text) -> text:
    if input.trim() == "":
        return fallback
    prompt + ":" + input.trim()

fn onStdinData(data: text) -> text:
    if data == "w":
        return "toggle-worktree"
    if data == "q":
        return "quit"
    "ignored"

fn onSigint() -> text:
    "abort"

fn onSigterm() -> text:
    "abort"

class BridgeHeadlessPermanentError:
    message: text
    name: text

impl BridgeHeadlessPermanentError:
    static fn new(message: text) -> BridgeHeadlessPermanentError:
        BridgeHeadlessPermanentError(message: message, name: "BridgeHeadlessPermanentError")

class HeadlessBridgeOpts:
    dir: text
    name: text
    spawnMode: text
    capacity: i64
    permissionMode: text
    sandbox: bool
    sessionTimeoutMs: i64
    createSessionOnStart: bool
    accessToken: text
    trustedWorkspace: bool
    baseUrl: text
    hasGitRoot: bool
    hasWorktreeCreateHook: bool

impl HeadlessBridgeOpts:
    static fn new(dir: text, spawnMode: text, capacity: i64) -> HeadlessBridgeOpts:
        HeadlessBridgeOpts(
            dir: dir,
            name: "",
            spawnMode: spawnMode,
            capacity: capacity,
            permissionMode: "",
            sandbox: false,
            sessionTimeoutMs: 0,
            createSessionOnStart: false,
            accessToken: "",
            trustedWorkspace: true,
            baseUrl: "https://api.anthropic.com",
            hasGitRoot: true,
            hasWorktreeCreateHook: false
        )

class HeadlessBridgeResult:
    ok: bool
    permanent: bool
    message: text
    environmentId: text
    initialSessionId: text
    logs: [text]

impl HeadlessBridgeResult:
    static fn ok(environmentId: text, initialSessionId: text, logs: [text]) -> HeadlessBridgeResult:
        HeadlessBridgeResult(ok: true, permanent: false, message: "", environmentId: environmentId, initialSessionId: initialSessionId, logs: logs)

    static fn failed(message: text, permanent: bool) -> HeadlessBridgeResult:
        HeadlessBridgeResult(ok: false, permanent: permanent, message: message, environmentId: "", initialSessionId: "", logs: [])

fn runBridgeHeadless(opts: HeadlessBridgeOpts, registrationError: text, precreateSessionId: text) -> HeadlessBridgeResult:
    if not opts.trustedWorkspace:
        return HeadlessBridgeResult.failed("Workspace not trusted: " + opts.dir + ". Run `claude` in that directory first to accept the trust dialog.", true)
    if opts.accessToken == "":
        return HeadlessBridgeResult.failed(BRIDGE_LOGIN_ERROR, false)
    if opts.baseUrl.starts_with("http://") and not opts.baseUrl.contains("localhost") and not opts.baseUrl.contains("127.0.0.1"):
        return HeadlessBridgeResult.failed("Remote Control base URL uses HTTP. Only HTTPS or localhost HTTP is allowed.", true)
    if opts.spawnMode == "worktree" and not opts.hasWorktreeCreateHook and not opts.hasGitRoot:
        return HeadlessBridgeResult.failed("Worktree mode requires a git repository or WorktreeCreate hooks. Directory " + opts.dir + " has neither.", true)
    if registrationError != "":
        return HeadlessBridgeResult.failed("Bridge registration failed: " + registrationError, false)
    val envId = "env-" + opts.dir
    var logs = createHeadlessBridgeLogger(opts.dir, opts.spawnMode, opts.capacity, envId)
    var sid = ""
    if opts.createSessionOnStart and precreateSessionId != "":
        sid = precreateSessionId
        logs.push("created initial session " + sid)
    HeadlessBridgeResult.ok(envId, sid, logs)

fn createHeadlessBridgeLogger(dir: text, spawnMode: text, capacity: i64, environmentId: text) -> [text]:
    [
        "registered environmentId=" + environmentId + " dir=" + dir + " spawnMode=" + spawnMode + " capacity=" + capacity.to_text(),
        "session start <id>",
        "session complete <id> (<ms>ms)",
        "session failed <id>: <err>",
        "error: <s>",
        "reconnected after <ms>ms"
    ]

fn noop() -> text:
    ""

fn bridgeMainSourceLinesModeled() -> i64:
    2999

fn collapseWhitespace(raw: text) -> text:
    var out = ""
    var previousSpace = false
    var i = 0
    while i < raw.len():
        val ch = raw.slice(i, i + 1)
        val space = ch == " " or ch == "\n" or ch == "\t" or ch == "\r"
        if space:
            if not previousSpace:
                out = out + " "
            previousSpace = true
        else:
            out = out + ch
            previousSpace = false
        i = i + 1
    out

fn if_missing(raw: text) -> text:
    if raw == "":
        return "<missing>"
    raw
