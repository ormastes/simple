const TRUSTED_DEVICE_GATE: text = "tengu_sessions_elevated_auth_enforcement"
const TRUSTED_DEVICE_ENV_VAR: text = "CLAUDE_TRUSTED_DEVICE_TOKEN"
const TRUSTED_DEVICE_PATH: text = "/api/auth/trusted_devices"
const TRUSTED_DEVICE_TIMEOUT_MS: i64 = 10000
const TRUSTED_DEVICE_TTL_DAYS: i64 = 90

class TrustedDeviceStorage:
    trustedDeviceToken: text
    readable: bool
    updateSucceeds: bool
    updateWarning: text
    updated: bool

impl TrustedDeviceStorage:
    static fn new(token: text) -> TrustedDeviceStorage:
        TrustedDeviceStorage(trustedDeviceToken: token, readable: true, updateSucceeds: true, updateWarning: "", updated: false)

    static fn unreadable() -> TrustedDeviceStorage:
        TrustedDeviceStorage(trustedDeviceToken: "", readable: false, updateSucceeds: false, updateWarning: "unreadable", updated: false)

    me readToken() -> text:
        if not me.readable:
            return ""
        me.trustedDeviceToken

    me clearToken():
        if me.readable:
            me.trustedDeviceToken = ""
            me.updated = true

    me persistToken(token: text) -> bool:
        if not me.readable:
            return false
        if not me.updateSucceeds:
            return false
        me.trustedDeviceToken = token
        me.updated = true
        true

class TrustedDeviceEnrollmentResponse:
    status: i64
    device_token: text
    device_id: text
    networkError: text

impl TrustedDeviceEnrollmentResponse:
    static fn ok(token: text, deviceId: text) -> TrustedDeviceEnrollmentResponse:
        TrustedDeviceEnrollmentResponse(status: 201, device_token: token, device_id: deviceId, networkError: "")

    static fn failed(status: i64) -> TrustedDeviceEnrollmentResponse:
        TrustedDeviceEnrollmentResponse(status: status, device_token: "", device_id: "", networkError: "")

    static fn network(message: text) -> TrustedDeviceEnrollmentResponse:
        TrustedDeviceEnrollmentResponse(status: 0, device_token: "", device_id: "", networkError: message)

class TrustedDeviceRequest:
    url: text
    display_name: text
    Authorization: text
    Content_Type: text
    timeoutMs: i64

impl TrustedDeviceRequest:
    static fn new(baseUrl: text, accessToken: text, host: text, platform: text) -> TrustedDeviceRequest:
        TrustedDeviceRequest(
            url: baseUrl + TRUSTED_DEVICE_PATH,
            display_name: trustedDeviceDisplayName(host, platform),
            Authorization: trustedDeviceAuthHeader(accessToken),
            Content_Type: trustedDeviceContentType(),
            timeoutMs: TRUSTED_DEVICE_TIMEOUT_MS
        )

class TrustedDeviceContext:
    gateEnabled: bool
    blockingGateEnabled: bool
    envToken: text
    accessToken: text
    essentialTrafficOnly: bool
    baseUrl: text
    host: text
    platform: text
    storage: TrustedDeviceStorage
    cachedToken: text
    cachePrimed: bool
    logs: [text]
    lastRequest: TrustedDeviceRequest

impl TrustedDeviceContext:
    static fn new(gateEnabled: bool, envToken: text, storageToken: text) -> TrustedDeviceContext:
        TrustedDeviceContext(
            gateEnabled: gateEnabled,
            blockingGateEnabled: gateEnabled,
            envToken: envToken,
            accessToken: "oauth",
            essentialTrafficOnly: false,
            baseUrl: "https://api.anthropic.com",
            host: "host",
            platform: "linux",
            storage: TrustedDeviceStorage.new(storageToken),
            cachedToken: "",
            cachePrimed: false,
            logs: [],
            lastRequest: TrustedDeviceRequest.new("", "", "", "")
        )

    me isGateEnabled() -> bool:
        me.gateEnabled

    me readStoredToken() -> text:
        if me.cachePrimed:
            return me.cachedToken
        if me.envToken != "":
            me.cachedToken = me.envToken
        else:
            me.cachedToken = me.storage.readToken()
        me.cachePrimed = true
        me.cachedToken

    me getTrustedDeviceToken() -> text:
        if not me.isGateEnabled():
            return ""
        me.readStoredToken()

    me clearTrustedDeviceTokenCache():
        me.cachedToken = ""
        me.cachePrimed = false

    me clearTrustedDeviceToken():
        if not me.isGateEnabled():
            return
        me.storage.clearToken()
        me.clearTrustedDeviceTokenCache()

    me enrollTrustedDevice(response: TrustedDeviceEnrollmentResponse):
        if not me.blockingGateEnabled:
            me.log("[trusted-device] Gate " + TRUSTED_DEVICE_GATE + " is off, skipping enrollment")
            return
        if me.envToken != "":
            me.log("[trusted-device] " + TRUSTED_DEVICE_ENV_VAR + " env var is set, skipping enrollment (env var takes precedence)")
            return
        if me.accessToken == "":
            me.log("[trusted-device] No OAuth token, skipping enrollment")
            return
        if me.essentialTrafficOnly:
            me.log("[trusted-device] Essential traffic only, skipping enrollment")
            return
        me.lastRequest = TrustedDeviceRequest.new(me.baseUrl, me.accessToken, me.host, me.platform)
        if response.networkError != "":
            me.log("[trusted-device] Enrollment request failed: " + response.networkError)
            return
        if response.status != 200 and response.status != 201:
            me.log("[trusted-device] Enrollment failed " + response.status.to_text())
            return
        if response.device_token == "":
            me.log("[trusted-device] Enrollment response missing device_token field")
            return
        if not me.storage.readable:
            me.log("[trusted-device] Cannot read storage, skipping token persist")
            return
        if not me.storage.persistToken(response.device_token):
            val warning = if me.storage.updateWarning != "": me.storage.updateWarning else: "unknown"
            me.log("[trusted-device] Failed to persist token: " + warning)
            return
        me.clearTrustedDeviceTokenCache()
        val deviceId = if response.device_id != "": response.device_id else: "unknown"
        me.log("[trusted-device] Enrolled device_id=" + deviceId)

    me log(message: text):
        me.logs = me.logs + [message]

fn trustedDeviceContextNew(gateEnabled: bool, envToken: text, storageToken: text) -> TrustedDeviceContext:
    TrustedDeviceContext.new(gateEnabled, envToken, storageToken)

fn getTrustedDeviceToken(ctx: TrustedDeviceContext) -> text:
    ctx.getTrustedDeviceToken()

fn clearTrustedDeviceTokenCache(ctx: TrustedDeviceContext) -> TrustedDeviceContext:
    ctx.clearTrustedDeviceTokenCache()
    ctx

fn clearTrustedDeviceToken(ctx: TrustedDeviceContext) -> TrustedDeviceContext:
    ctx.clearTrustedDeviceToken()
    ctx

fn enrollTrustedDevice(ctx: TrustedDeviceContext, response: TrustedDeviceEnrollmentResponse) -> TrustedDeviceContext:
    ctx.enrollTrustedDevice(response)
    ctx

fn trustedDeviceDisplayName(host: text, platform: text) -> text:
    "Claude Code on " + host + " · " + platform

fn trustedDeviceAuthHeader(accessToken: text) -> text:
    "Bearer " + accessToken

fn trustedDeviceGateName() -> text:
    TRUSTED_DEVICE_GATE

fn trustedDeviceEnvVarName() -> text:
    TRUSTED_DEVICE_ENV_VAR

fn trustedDevicePath() -> text:
    TRUSTED_DEVICE_PATH

fn trustedDeviceTimeoutMs() -> i64:
    TRUSTED_DEVICE_TIMEOUT_MS

fn trustedDeviceTtlDays() -> i64:
    TRUSTED_DEVICE_TTL_DAYS

fn trustedDeviceContentType() -> text:
    "application/json"
