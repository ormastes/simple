class CseShimGate:
    registered: bool
    enabled: bool

impl CseShimGate:
    static fn defaultActive() -> CseShimGate:
        CseShimGate(registered: false, enabled: true)

    static fn registered(enabled: bool) -> CseShimGate:
        CseShimGate(registered: true, enabled: enabled)

    me isEnabled() -> bool:
        if not me.registered:
            return true
        me.enabled

fn setCseShimGate(enabled: bool) -> CseShimGate:
    CseShimGate.registered(enabled)

fn defaultCseShimGate() -> CseShimGate:
    CseShimGate.defaultActive()

fn toCompatSessionId(id: text) -> text:
    toCompatSessionIdWithGate(id, CseShimGate.defaultActive())

fn toCompatSessionIdWithGate(id: text, gate: CseShimGate) -> text:
    if not id.starts_with("cse_"):
        return id
    if not gate.isEnabled():
        return id
    "session_" + id.substring("cse_".len(), id.len())

fn toInfraSessionId(id: text) -> text:
    if not id.starts_with("session_"):
        return id
    "cse_" + id.substring("session_".len(), id.len())

fn csePrefix() -> text:
    "cse_"

fn sessionPrefix() -> text:
    "session_"

fn compatEndpointFamily() -> text:
    "/v1/sessions/<id>"

fn workerEndpointFamily() -> text:
    "/v1/code/sessions/<id>/worker/*"

fn reconnectEndpointFamily() -> text:
    "/v1/environments/<id>/bridge/reconnect"

fn compatTagName() -> text:
    "TagSession"

fn infraTagName() -> text:
    "cse"

fn shimDefaultActiveReason() -> text:
    "SDK path never registers the GrowthBook gate, so the shim defaults active"

fn sameUuidDifferentTag(id: text) -> bool:
    val compat = toCompatSessionId(id)
    if not id.starts_with("cse_"):
        return false
    compat.substring("session_".len(), compat.len()) == id.substring("cse_".len(), id.len())

fn roundTripSessionId(id: text) -> text:
    toInfraSessionId(toCompatSessionId(id))

fn toCompatSessionIdForArchive(id: text) -> text:
    toCompatSessionId(id)

fn toCompatSessionIdForEvents(id: text) -> text:
    toCompatSessionId(id)

fn toInfraSessionIdForReconnect(id: text) -> text:
    toInfraSessionId(id)

fn shouldRetagForCompat(id: text, gate: CseShimGate) -> bool:
    id.starts_with("cse_") and gate.isEnabled()

fn shouldRetagForInfra(id: text) -> bool:
    id.starts_with("session_")

fn cseShimGateRegistered(gate: CseShimGate) -> bool:
    gate.registered

fn cseShimGateEnabled(gate: CseShimGate) -> bool:
    gate.isEnabled()

fn sdkBundleAvoidsBridgeEnabledImport() -> bool:
    true

fn sessionIdCompatModulePurpose() -> text:
    "Session ID tag translation helpers for the CCR v2 compat layer."
