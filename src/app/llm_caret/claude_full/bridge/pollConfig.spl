use app.llm_caret.claude_full.bridge.pollConfigDefaults.{PollIntervalConfig, defaultPollConfig}

const POLL_CONFIG_FLAG_NAME: text = "tengu_bridge_poll_interval_config"
const POLL_CONFIG_REFRESH_MS: i64 = 300000
const MIN_SEEK_WORK_INTERVAL_MS: i64 = 100
const DEFAULT_RECLAIM_OLDER_THAN_MS: i64 = 5000
const DEFAULT_SESSION_KEEPALIVE_INTERVAL_V2_MS: i64 = 120000

class PollIntervalConfigCandidate:
    poll_interval_ms_not_at_capacity: i64
    poll_interval_ms_at_capacity: i64
    non_exclusive_heartbeat_interval_ms: i64
    multisession_poll_interval_ms_not_at_capacity: i64
    multisession_poll_interval_ms_partial_capacity: i64
    multisession_poll_interval_ms_at_capacity: i64
    reclaim_older_than_ms: i64
    session_keepalive_interval_v2_ms: i64
    has_heartbeat: bool
    has_multisession_not_at_capacity: bool
    has_multisession_partial_capacity: bool
    has_multisession_at_capacity: bool
    has_reclaim: bool
    has_keepalive: bool

impl PollIntervalConfigCandidate:
    static fn fromRequired(notAtCapacity: i64, atCapacity: i64) -> PollIntervalConfigCandidate:
        PollIntervalConfigCandidate(
            poll_interval_ms_not_at_capacity: notAtCapacity,
            poll_interval_ms_at_capacity: atCapacity,
            non_exclusive_heartbeat_interval_ms: 0,
            multisession_poll_interval_ms_not_at_capacity: 0,
            multisession_poll_interval_ms_partial_capacity: 0,
            multisession_poll_interval_ms_at_capacity: 0,
            reclaim_older_than_ms: 0,
            session_keepalive_interval_v2_ms: 0,
            has_heartbeat: false,
            has_multisession_not_at_capacity: false,
            has_multisession_partial_capacity: false,
            has_multisession_at_capacity: false,
            has_reclaim: false,
            has_keepalive: false
        )

    me withHeartbeat(ms: i64) -> PollIntervalConfigCandidate:
        me.non_exclusive_heartbeat_interval_ms = ms
        me.has_heartbeat = true
        return me

    me withMultisession(notAtCapacity: i64, partialCapacity: i64, atCapacity: i64) -> PollIntervalConfigCandidate:
        me.multisession_poll_interval_ms_not_at_capacity = notAtCapacity
        me.multisession_poll_interval_ms_partial_capacity = partialCapacity
        me.multisession_poll_interval_ms_at_capacity = atCapacity
        me.has_multisession_not_at_capacity = true
        me.has_multisession_partial_capacity = true
        me.has_multisession_at_capacity = true
        return me

    me withReclaim(ms: i64) -> PollIntervalConfigCandidate:
        me.reclaim_older_than_ms = ms
        me.has_reclaim = true
        return me

    me withSessionKeepalive(ms: i64) -> PollIntervalConfigCandidate:
        me.session_keepalive_interval_v2_ms = ms
        me.has_keepalive = true
        return me

class PollConfigParseResult:
    success: bool
    config: PollIntervalConfig
    error: text

impl PollConfigParseResult:
    static fn ok(config: PollIntervalConfig) -> PollConfigParseResult:
        PollConfigParseResult(success: true, config: config, error: "")

    static fn failed(error: text) -> PollConfigParseResult:
        PollConfigParseResult(success: false, config: defaultPollConfig(), error: error)

fn getPollIntervalConfig(candidate: PollIntervalConfigCandidate) -> PollIntervalConfig:
    val parsed = parsePollIntervalConfig(candidate)
    if parsed.success:
        return parsed.config
    defaultPollConfig()

fn parsePollIntervalConfig(candidate: PollIntervalConfigCandidate) -> PollConfigParseResult:
    val cfg = materializePollIntervalConfig(candidate)
    val error = validatePollIntervalConfig(cfg)
    if error != "":
        return PollConfigParseResult.failed(error)
    PollConfigParseResult.ok(cfg)

fn materializePollIntervalConfig(candidate: PollIntervalConfigCandidate) -> PollIntervalConfig:
    val defaults = defaultPollConfig()
    PollIntervalConfig(
        poll_interval_ms_not_at_capacity: candidate.poll_interval_ms_not_at_capacity,
        poll_interval_ms_at_capacity: candidate.poll_interval_ms_at_capacity,
        non_exclusive_heartbeat_interval_ms: optionalInterval(candidate.has_heartbeat, candidate.non_exclusive_heartbeat_interval_ms, defaults.non_exclusive_heartbeat_interval_ms),
        multisession_poll_interval_ms_not_at_capacity: optionalInterval(candidate.has_multisession_not_at_capacity, candidate.multisession_poll_interval_ms_not_at_capacity, defaults.multisession_poll_interval_ms_not_at_capacity),
        multisession_poll_interval_ms_partial_capacity: optionalInterval(candidate.has_multisession_partial_capacity, candidate.multisession_poll_interval_ms_partial_capacity, defaults.multisession_poll_interval_ms_partial_capacity),
        multisession_poll_interval_ms_at_capacity: optionalInterval(candidate.has_multisession_at_capacity, candidate.multisession_poll_interval_ms_at_capacity, defaults.multisession_poll_interval_ms_at_capacity),
        reclaim_older_than_ms: optionalInterval(candidate.has_reclaim, candidate.reclaim_older_than_ms, DEFAULT_RECLAIM_OLDER_THAN_MS),
        session_keepalive_interval_v2_ms: optionalInterval(candidate.has_keepalive, candidate.session_keepalive_interval_v2_ms, DEFAULT_SESSION_KEEPALIVE_INTERVAL_V2_MS)
    )

fn validatePollIntervalConfig(cfg: PollIntervalConfig) -> text:
    if cfg.poll_interval_ms_not_at_capacity < MIN_SEEK_WORK_INTERVAL_MS:
        return "poll_interval_ms_not_at_capacity must be at least 100ms"
    if not zeroOrAtLeast100(cfg.poll_interval_ms_at_capacity):
        return "poll_interval_ms_at_capacity must be 0 or at least 100ms"
    if cfg.non_exclusive_heartbeat_interval_ms < 0:
        return "non_exclusive_heartbeat_interval_ms must be non-negative"
    if cfg.multisession_poll_interval_ms_not_at_capacity < MIN_SEEK_WORK_INTERVAL_MS:
        return "multisession_poll_interval_ms_not_at_capacity must be at least 100ms"
    if cfg.multisession_poll_interval_ms_partial_capacity < MIN_SEEK_WORK_INTERVAL_MS:
        return "multisession_poll_interval_ms_partial_capacity must be at least 100ms"
    if not zeroOrAtLeast100(cfg.multisession_poll_interval_ms_at_capacity):
        return "multisession_poll_interval_ms_at_capacity must be 0 or at least 100ms"
    if cfg.reclaim_older_than_ms < 1:
        return "reclaim_older_than_ms must be positive"
    if cfg.session_keepalive_interval_v2_ms < 0:
        return "session_keepalive_interval_v2_ms must be non-negative"
    if cfg.non_exclusive_heartbeat_interval_ms == 0 and cfg.poll_interval_ms_at_capacity == 0:
        return "single-session at-capacity liveness disabled"
    if cfg.non_exclusive_heartbeat_interval_ms == 0 and cfg.multisession_poll_interval_ms_at_capacity == 0:
        return "multisession at-capacity liveness disabled"
    ""

fn optionalInterval(hasValue: bool, value: i64, defaultValue: i64) -> i64:
    if hasValue:
        return value
    defaultValue

fn zeroOrAtLeast100(value: i64) -> bool:
    value == 0 or value >= MIN_SEEK_WORK_INTERVAL_MS

fn pollConfigFlagName() -> text:
    POLL_CONFIG_FLAG_NAME

fn pollConfigRefreshMs() -> i64:
    POLL_CONFIG_REFRESH_MS

fn pollConfigMinSeekWorkIntervalMs() -> i64:
    MIN_SEEK_WORK_INTERVAL_MS

fn pollConfigZeroOrAtLeast100Message() -> text:
    "must be 0 (disabled) or >=100ms"

fn atCapacityLivenessMessage() -> text:
    "at-capacity liveness requires heartbeat or at-capacity polling"
