class YogaMeasureResult:
    width: i64
    height: i64

class YogaLayoutNode:
    name: text
    parentName: text
    children: [text]
    computedLeft: i64
    computedTop: i64
    computedWidth: i64
    computedHeight: i64
    dirty: bool
    freed: bool
    freedRecursive: bool
    measureWidth: i64
    measureMode: text
    measureResult: YogaMeasureResult?
    styles: [text]

impl YogaLayoutNode:
    static fn new(name: text) -> YogaLayoutNode:
        YogaLayoutNode(name: name, parentName: "", children: [], computedLeft: 0, computedTop: 0, computedWidth: 0, computedHeight: 0, dirty: false, freed: false, freedRecursive: false, measureWidth: 0, measureMode: "undefined", measureResult: nil, styles: [])

    me insertChild(child: YogaLayoutNode, index: i64) -> ():
        child.parentName = me.name
        me.children = insertTextAt(me.children, child.name, index)

    me removeChild(child: YogaLayoutNode) -> ():
        me.children = removeText(me.children, child.name)
        child.parentName = ""

    me getChildCount() -> i64:
        me.children.len()

    me getParentName() -> text:
        me.parentName

    me calculateLayout(width: i64) -> ():
        if width > 0:
            me.computedWidth = width
        if val Some(result) = me.measureResult:
            me.computedWidth = result.width
            me.computedHeight = result.height
        me.dirty = false
        me.setStyle("direction", "ltr")

    me setMeasureResult(width: i64, mode: text, resultWidth: i64, resultHeight: i64) -> ():
        me.measureWidth = width
        me.measureMode = mapMeasureMode(mode)
        me.measureResult = Some(YogaMeasureResult(width: resultWidth, height: resultHeight))

    me unsetMeasureFunc() -> ():
        me.measureResult = nil

    me markDirty() -> ():
        me.dirty = true

    me getComputedLeft() -> i64:
        me.computedLeft

    me getComputedTop() -> i64:
        me.computedTop

    me getComputedWidth() -> i64:
        me.computedWidth

    me getComputedHeight() -> i64:
        me.computedHeight

    me getComputedBorder(edge: text) -> i64:
        me.getStyleI64("border:" + mapEdge(edge))

    me getComputedPadding(edge: text) -> i64:
        me.getStyleI64("padding:" + mapEdge(edge))

    me setWidth(value: i64) -> ():
        me.setStyle("width", value.to_text())

    me setWidthPercent(value: i64) -> ():
        me.setStyle("widthPercent", value.to_text())

    me setWidthAuto() -> ():
        me.setStyle("width", "auto")

    me setHeight(value: i64) -> ():
        me.setStyle("height", value.to_text())

    me setHeightPercent(value: i64) -> ():
        me.setStyle("heightPercent", value.to_text())

    me setHeightAuto() -> ():
        me.setStyle("height", "auto")

    me setMinWidth(value: i64) -> ():
        me.setStyle("minWidth", value.to_text())

    me setMinWidthPercent(value: i64) -> ():
        me.setStyle("minWidthPercent", value.to_text())

    me setMinHeight(value: i64) -> ():
        me.setStyle("minHeight", value.to_text())

    me setMinHeightPercent(value: i64) -> ():
        me.setStyle("minHeightPercent", value.to_text())

    me setMaxWidth(value: i64) -> ():
        me.setStyle("maxWidth", value.to_text())

    me setMaxWidthPercent(value: i64) -> ():
        me.setStyle("maxWidthPercent", value.to_text())

    me setMaxHeight(value: i64) -> ():
        me.setStyle("maxHeight", value.to_text())

    me setMaxHeightPercent(value: i64) -> ():
        me.setStyle("maxHeightPercent", value.to_text())

    me setFlexDirection(dir: text) -> ():
        me.setStyle("flexDirection", mapFlexDirection(dir))

    me setFlexGrow(value: i64) -> ():
        me.setStyle("flexGrow", value.to_text())

    me setFlexShrink(value: i64) -> ():
        me.setStyle("flexShrink", value.to_text())

    me setFlexBasis(value: i64) -> ():
        me.setStyle("flexBasis", value.to_text())

    me setFlexBasisPercent(value: i64) -> ():
        me.setStyle("flexBasisPercent", value.to_text())

    me setFlexWrap(wrap: text) -> ():
        me.setStyle("flexWrap", mapFlexWrap(wrap))

    me setAlignItems(align: text) -> ():
        me.setStyle("alignItems", mapAlign(align))

    me setAlignSelf(align: text) -> ():
        me.setStyle("alignSelf", mapAlign(align))

    me setJustifyContent(justify: text) -> ():
        me.setStyle("justifyContent", mapJustify(justify))

    me setDisplay(display: text) -> ():
        if display == "none":
            me.setStyle("display", "none")
        else:
            me.setStyle("display", "flex")

    me getDisplay() -> text:
        val display = me.getStyle("display")
        if display == "none":
            return "none"
        "flex"

    me setPositionType(kind: text) -> ():
        if kind == "absolute":
            me.setStyle("positionType", "absolute")
        else:
            me.setStyle("positionType", "relative")

    me setPosition(edge: text, value: i64) -> ():
        me.setStyle("position:" + mapEdge(edge), value.to_text())

    me setPositionPercent(edge: text, value: i64) -> ():
        me.setStyle("positionPercent:" + mapEdge(edge), value.to_text())

    me setOverflow(overflow: text) -> ():
        me.setStyle("overflow", mapOverflow(overflow))

    me setMargin(edge: text, value: i64) -> ():
        me.setStyle("margin:" + mapEdge(edge), value.to_text())

    me setPadding(edge: text, value: i64) -> ():
        me.setStyle("padding:" + mapEdge(edge), value.to_text())

    me setBorder(edge: text, value: i64) -> ():
        me.setStyle("border:" + mapEdge(edge), value.to_text())

    me setGap(gutter: text, value: i64) -> ():
        me.setStyle("gap:" + mapGutter(gutter), value.to_text())

    me free() -> ():
        me.freed = true

    me freeRecursive() -> ():
        me.freedRecursive = true
        me.freed = true

    me setStyle(key: text, value: text) -> ():
        me.styles = removeStyleKey(me.styles, key)
        me.styles.push(key + "=" + value)

    me getStyle(key: text) -> text:
        var i = 0
        while i < me.styles.len():
            val item = me.styles[i]
            if item.starts_with(key + "="):
                return item.slice(key.len() + 1, item.len())
            i = i + 1
        ""

    me getStyleI64(key: text) -> i64:
        parseI64(me.getStyle(key))

fn createYogaLayoutNode(name: text) -> YogaLayoutNode:
    YogaLayoutNode.new(name)

fn removeStyleKey(styles: [text], key: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < styles.len():
        if not styles[i].starts_with(key + "="):
            out.push(styles[i])
        i = i + 1
    out

fn insertTextAt(values: [text], value: text, index: i64) -> [text]:
    var out: [text] = []
    var inserted = false
    var i = 0
    while i < values.len():
        if not inserted and i == index:
            out.push(value)
            inserted = true
        out.push(values[i])
        i = i + 1
    if not inserted:
        out.push(value)
    out

fn removeText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if values[i] != value:
            out.push(values[i])
        i = i + 1
    out

fn mapEdge(edge: text) -> text:
    if edge == "all" or edge == "horizontal" or edge == "vertical" or edge == "left" or edge == "right" or edge == "top" or edge == "bottom" or edge == "start" or edge == "end":
        return edge
    "all"

fn mapGutter(gutter: text) -> text:
    if gutter == "column" or gutter == "row":
        return gutter
    "all"

fn mapMeasureMode(mode: text) -> text:
    if mode == "exactly":
        return "Exactly"
    if mode == "at-most":
        return "AtMost"
    "Undefined"

fn mapFlexDirection(dir: text) -> text:
    if dir == "row-reverse" or dir == "column" or dir == "column-reverse":
        return dir
    "row"

fn mapFlexWrap(wrap: text) -> text:
    if wrap == "wrap" or wrap == "wrap-reverse":
        return wrap
    "nowrap"

fn mapAlign(align: text) -> text:
    if align == "stretch" or align == "flex-start" or align == "center" or align == "flex-end":
        return align
    "auto"

fn mapJustify(justify: text) -> text:
    if justify == "center" or justify == "flex-end" or justify == "space-between" or justify == "space-around" or justify == "space-evenly":
        return justify
    "flex-start"

fn mapOverflow(overflow: text) -> text:
    if overflow == "hidden" or overflow == "scroll":
        return overflow
    "visible"

fn parseI64(value: text) -> i64:
    var out = 0
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch >= "0" and ch <= "9":
            out = out * 10 + digitValue(ch)
        i = i + 1
    out

fn digitValue(ch: text) -> i64:
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn yogaLayoutNodeSourceLinesModeled() -> i64:
    308

# ponytail: this is an adapter-state model; use real Yoga only when the Simple runtime exposes the native Yoga node.
# Source parity note: insertChild and removeChild forward to the underlying Yoga tree.
# Source parity note: calculateLayout always uses LTR and ignores height.
# Source parity note: measure modes map Exactly, AtMost, and Undefined.
# Source parity note: computed geometry reads are forwarded directly.
# Source parity note: edge and gutter maps cover all LayoutEdge/LayoutGutter values.
# Source parity note: display maps flex/none in both directions.
# Source parity note: position type maps absolute/relative.
# Source parity note: overflow maps visible/hidden/scroll.
# Source parity note: free and freeRecursive are lifecycle forwards.
