const MAX_FOCUS_STACK = 32

class FocusNode:
    id: text
    parentId: text
    tabIndex: i64
    isText: bool
    hasFocusManager: bool

impl FocusNode:
    static fn new(id: text, parentId: text, tabIndex: i64) -> FocusNode:
        FocusNode(id: id, parentId: parentId, tabIndex: tabIndex, isText: false, hasFocusManager: false)

class FocusManager:
    activeElement: text
    enabled: bool
    focusStack: [text]
    nodes: [FocusNode]
    dispatchLog: [text]

impl FocusManager:
    static fn new() -> FocusManager:
        FocusManager(activeElement: "", enabled: true, focusStack: [], nodes: [], dispatchLog: [])

    me registerNode(id: text, parentId: text, tabIndex: i64) -> ():
        me.nodes.push(FocusNode.new(id, parentId, tabIndex))

    me registerTextNode(id: text, parentId: text) -> ():
        me.nodes.push(FocusNode(id: id, parentId: parentId, tabIndex: -1, isText: true, hasFocusManager: false))

    me markRoot(id: text) -> ():
        var updated: [FocusNode] = []
        var i = 0
        while i < me.nodes.len():
            val node = me.nodes[i]
            if node.id == id:
                updated.push(FocusNode(id: node.id, parentId: node.parentId, tabIndex: node.tabIndex, isText: node.isText, hasFocusManager: true))
            else:
                updated.push(node)
            i = i + 1
        me.nodes = updated

    me focus(nodeId: text) -> ():
        if nodeId == me.activeElement:
            return
        if not me.enabled:
            return
        val previous = me.activeElement
        if previous != "":
            me.removeFromFocusStack(previous)
            me.focusStack.push(previous)
            me.trimFocusStack()
            me.dispatchFocusEvent(previous, "blur", nodeId)
        me.activeElement = nodeId
        me.dispatchFocusEvent(nodeId, "focus", previous)

    me blur() -> ():
        if me.activeElement == "":
            return
        val previous = me.activeElement
        me.activeElement = ""
        me.dispatchFocusEvent(previous, "blur", "")

    me handleNodeRemoved(nodeId: text, rootId: text) -> ():
        me.keepMountedStack(nodeId, rootId)
        if me.activeElement == "":
            return
        if me.activeElement != nodeId and me.isInTree(me.activeElement, rootId):
            return
        val removed = me.activeElement
        me.activeElement = ""
        me.dispatchFocusEvent(removed, "blur", "")
        while me.focusStack.len() > 0:
            val candidate = me.focusStack[me.focusStack.len() - 1]
            me.focusStack.pop()
            if me.isInTree(candidate, rootId):
                me.activeElement = candidate
                me.dispatchFocusEvent(candidate, "focus", removed)
                return

    me handleAutoFocus(nodeId: text) -> ():
        me.focus(nodeId)

    me handleClickFocus(nodeId: text) -> ():
        if me.tabIndexOf(nodeId) < 0:
            return
        me.focus(nodeId)

    me enable() -> ():
        me.enabled = true

    me disable() -> ():
        me.enabled = false

    me focusNext(rootId: text) -> ():
        me.moveFocus(1, rootId)

    me focusPrevious(rootId: text) -> ():
        me.moveFocus(-1, rootId)

    me moveFocus(direction: i64, rootId: text) -> ():
        if not me.enabled:
            return
        val tabbable = me.collectTabbable(rootId)
        if tabbable.len() == 0:
            return
        var currentIndex = -1
        var i = 0
        while i < tabbable.len():
            if tabbable[i] == me.activeElement:
                currentIndex = i
            i = i + 1
        var nextIndex = 0
        if currentIndex == -1:
            if direction == 1:
                nextIndex = 0
            else:
                nextIndex = tabbable.len() - 1
        else:
            nextIndex = (currentIndex + direction + tabbable.len()) % tabbable.len()
        me.focus(tabbable[nextIndex])

    me collectTabbable(rootId: text) -> [text]:
        var result: [text] = []
        var i = 0
        while i < me.nodes.len():
            val node = me.nodes[i]
            if not node.isText and node.tabIndex >= 0 and me.isInTree(node.id, rootId):
                result.push(node.id)
            i = i + 1
        result

    me isInTree(nodeId: text, rootId: text) -> bool:
        var current = nodeId
        while current != "":
            if current == rootId:
                return true
            current = me.parentOf(current)
        false

    me getRootNode(nodeId: text) -> text:
        var current = nodeId
        while current != "":
            if me.nodeHasFocusManager(current):
                return current
            current = me.parentOf(current)
        ""

    me getFocusManagerRoot(nodeId: text) -> text:
        me.getRootNode(nodeId)

    me dispatchFocusEvent(target: text, eventType: text, relatedTarget: text) -> ():
        me.dispatchLog.push(target + ":" + eventType + ":" + relatedTarget)

    me nodeIndex(id: text) -> i64:
        var i = 0
        while i < me.nodes.len():
            if me.nodes[i].id == id:
                return i
            i = i + 1
        -1

    me parentOf(id: text) -> text:
        val index = me.nodeIndex(id)
        if index < 0:
            return ""
        me.nodes[index].parentId

    me tabIndexOf(id: text) -> i64:
        val index = me.nodeIndex(id)
        if index < 0:
            return -1
        me.nodes[index].tabIndex

    me nodeHasFocusManager(id: text) -> bool:
        val index = me.nodeIndex(id)
        if index < 0:
            return false
        me.nodes[index].hasFocusManager

    me removeFromFocusStack(id: text) -> ():
        var kept: [text] = []
        var i = 0
        while i < me.focusStack.len():
            if me.focusStack[i] != id:
                kept.push(me.focusStack[i])
            i = i + 1
        me.focusStack = kept

    me trimFocusStack() -> ():
        while me.focusStack.len() > MAX_FOCUS_STACK:
            var kept: [text] = []
            var i = 1
            while i < me.focusStack.len():
                kept.push(me.focusStack[i])
                i = i + 1
            me.focusStack = kept

    me keepMountedStack(removedId: text, rootId: text) -> ():
        var kept: [text] = []
        var i = 0
        while i < me.focusStack.len():
            val candidate = me.focusStack[i]
            if candidate != removedId and me.isInTree(candidate, rootId):
                kept.push(candidate)
            i = i + 1
        me.focusStack = kept

fn focusManagerNew() -> FocusManager:
    FocusManager.new()

fn maxFocusStack() -> i64:
    MAX_FOCUS_STACK
