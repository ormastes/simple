class ParsedKey:
    name: text
    sequence: text
    code: text
    ctrl: bool
    shift: bool
    functionKey: bool
    meta: bool
    option: bool
    superKey: bool

impl ParsedKey:
    static fn new(name: text, sequence: text) -> ParsedKey:
        ParsedKey(name: name, sequence: sequence, code: "", ctrl: false, shift: false, functionKey: false, meta: false, option: false, superKey: false)

class Key:
    upArrow: bool
    downArrow: bool
    leftArrow: bool
    rightArrow: bool
    pageDown: bool
    pageUp: bool
    wheelUp: bool
    wheelDown: bool
    home: bool
    endKey: bool
    enterKey: bool
    escape: bool
    ctrl: bool
    shift: bool
    functionKey: bool
    tab: bool
    backspace: bool
    removeKey: bool
    meta: bool
    superKey: bool

class ParsedInput:
    key: Key
    input: text

class InputEvent:
    keypress: ParsedKey
    key: Key
    input: text

impl InputEvent:
    static fn new(keypress: ParsedKey) -> InputEvent:
        val parsed = parseKey(keypress)
        InputEvent(keypress: keypress, key: parsed.key, input: parsed.input)

fn parseKey(keypress: ParsedKey) -> ParsedInput:
    val key = Key(
        upArrow: keypress.name == "up",
        downArrow: keypress.name == "down",
        leftArrow: keypress.name == "left",
        rightArrow: keypress.name == "right",
        pageDown: keypress.name == "pagedown",
        pageUp: keypress.name == "pageup",
        wheelUp: keypress.name == "wheelup",
        wheelDown: keypress.name == "wheeldown",
        home: keypress.name == "home",
        endKey: keypress.name == "end",
        enterKey: keypress.name == "return",
        escape: keypress.name == "escape",
        ctrl: keypress.ctrl,
        shift: keypress.shift,
        functionKey: keypress.functionKey,
        tab: keypress.name == "tab",
        backspace: keypress.name == "backspace",
        removeKey: keypress.name == "delete",
        meta: keypress.meta or keypress.name == "escape" or keypress.option,
        superKey: keypress.superKey
    )
    var input = keypress.sequence
    if keypress.ctrl:
        input = keypress.name
    if keypress.ctrl and input == "space":
        input = " "
    if keypress.code != "" and keypress.name == "":
        input = ""
    if keypress.name == "" and isSgrMouseFragment(input):
        input = ""
    if input.starts_with(escapeChar()):
        input = input.slice(1, input.len())
    var processedSpecial = false
    if input.starts_with("[") and input.len() > 1 and isDigit(input.slice(1, 2)) and input.ends_with("u"):
        input = specialSequenceInput(keypress.name)
        processedSpecial = true
    if input.starts_with("[27;") and input.ends_with("~"):
        input = specialSequenceInput(keypress.name)
        processedSpecial = true
    if input.starts_with("O") and input.len() == 2 and keypress.name != "" and keypress.name.len() == 1:
        input = keypress.name
        processedSpecial = true
    if not processedSpecial and keypress.name != "" and isNonAlphanumericKey(keypress.name):
        input = ""
    if input.len() == 1 and input >= "A" and input <= "Z":
        key.shift = true
    ParsedInput(key: key, input: input)

fn specialSequenceInput(name: text) -> text:
    if name == "":
        return ""
    if name == "space":
        return " "
    if name == "escape":
        return ""
    name

fn isSgrMouseFragment(input: text) -> bool:
    input.starts_with("[<") and (input.ends_with("M") or input.ends_with("m"))

fn isDigit(value: text) -> bool:
    value >= "0" and value <= "9"

fn isNonAlphanumericKey(name: text) -> bool:
    name == "up" or name == "down" or name == "left" or name == "right" or name == "pagedown" or name == "pageup" or name == "home" or name == "end" or name == "return" or name == "escape" or name == "tab" or name == "backspace" or name == "delete"

fn escapeChar() -> text:
    ""

fn ctrlSpaceNormalizesToSpace() -> bool:
    true

fn unmappedFunctionKeysAreSuppressed() -> bool:
    true

fn sgrMouseFragmentsAreSuppressed() -> bool:
    true

fn kittyCsiUSequencesUseParsedName() -> bool:
    true

fn modifyOtherKeysSequencesUseParsedName() -> bool:
    true

fn applicationKeypadUsesParsedDigit() -> bool:
    true

fn uppercaseInputSetsShift() -> bool:
    true

fn escapeCountsAsMeta() -> bool:
    true

fn optionCountsAsMeta() -> bool:
    true

fn superKeyDistinctFromMeta() -> bool:
    true

fn inputEventSourceLinesModeled() -> i64:
    218

# Source parity note: Key includes arrows.
# Source parity note: Key includes page navigation.
# Source parity note: Key includes mouse wheel flags.
# Source parity note: Key includes home and end.
# Source parity note: Key includes return and escape.
# Source parity note: Key includes ctrl shift fn.
# Source parity note: Key includes tab backspace delete.
# Source parity note: Key includes meta and super.
# Source parity note: meta also true for escape.
# Source parity note: meta also true for option.
# Source parity note: ctrl input starts from key name.
# Source parity note: normal input starts from sequence.
# Source parity note: undefined input becomes empty string.
# Source parity note: ctrl space becomes actual space.
# Source parity note: named function-key code without name is suppressed.
# Source parity note: ESC-less SGR mouse fragments are suppressed.
# Source parity note: leading ESC is stripped from input.
# Source parity note: CSI u digit-prefixed sequence is special.
# Source parity note: unmapped Kitty functional key is swallowed.
# Source parity note: Kitty space maps to space.
# Source parity note: Kitty escape maps to empty input.
# Source parity note: xterm modifyOtherKeys is special.
# Source parity note: unmapped modifyOtherKeys keycode is swallowed.
# Source parity note: application keypad O plus letter maps to parsed digit.
# Source parity note: non-alphanumeric keys clear input.
# Source parity note: special sequences bypass non-alphanumeric clear.
# Source parity note: uppercase single char sets shift.
# Source parity note: constructor stores keypress.
# Source parity note: constructor stores parsed key.
# Source parity note: constructor stores parsed input.
