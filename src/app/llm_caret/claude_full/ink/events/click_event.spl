class ClickEvent:
    col: i64
    row: i64
    localCol: i64
    localRow: i64
    cellIsBlank: bool
    did_stop_immediate_propagation: bool

impl ClickEvent:
    static fn new(col: i64, row: i64, cellIsBlank: bool) -> ClickEvent:
        ClickEvent(
            col: col,
            row: row,
            localCol: 0,
            localRow: 0,
            cellIsBlank: cellIsBlank,
            did_stop_immediate_propagation: false
        )

    me didStopImmediatePropagation() -> bool:
        me.did_stop_immediate_propagation

    me stopImmediatePropagation() -> ():
        me.did_stop_immediate_propagation = true

    me setLocal(col: i64, row: i64) -> ():
        me.localCol = col
        me.localRow = row

    me setLocalFromBox(boxCol: i64, boxRow: i64) -> ():
        me.localCol = me.col - boxCol
        me.localRow = me.row - boxRow

    me isBlankCellClick() -> bool:
        me.cellIsBlank

    me positionText() -> text:
        me.col.to_text() + "," + me.row.to_text()

fn clickEventNew(col: i64, row: i64, cellIsBlank: bool) -> ClickEvent:
    ClickEvent.new(col, row, cellIsBlank)
