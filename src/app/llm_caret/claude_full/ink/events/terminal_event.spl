class TerminalEventInit:
    bubbles: bool
    cancelable: bool

impl TerminalEventInit:
    static fn defaults() -> TerminalEventInit:
        TerminalEventInit(bubbles: true, cancelable: true)

class TerminalEvent:
    type: text
    timeStamp: i64
    bubbles: bool
    cancelable: bool
    target: text
    currentTarget: text
    eventPhase: text
    propagationStopped: bool
    defaultPrevented: bool
    did_stop_immediate_propagation: bool
    preparedTarget: text

impl TerminalEvent:
    static fn new(event_type: text) -> TerminalEvent:
        TerminalEvent.withInit(event_type, TerminalEventInit.defaults())

    static fn withInit(event_type: text, init: TerminalEventInit) -> TerminalEvent:
        TerminalEvent(
            type: event_type,
            timeStamp: 0,
            bubbles: init.bubbles,
            cancelable: init.cancelable,
            target: "",
            currentTarget: "",
            eventPhase: "none",
            propagationStopped: false,
            defaultPrevented: false,
            did_stop_immediate_propagation: false,
            preparedTarget: ""
        )

    me stopPropagation() -> ():
        me.propagationStopped = true

    me stopImmediatePropagation() -> ():
        me.did_stop_immediate_propagation = true
        me.propagationStopped = true

    me didStopImmediatePropagation() -> bool:
        me.did_stop_immediate_propagation

    me preventDefault() -> ():
        if me.cancelable:
            me.defaultPrevented = true

    me setTarget(target: text) -> ():
        me.target = target

    me setCurrentTarget(target: text) -> ():
        me.currentTarget = target

    me clearCurrentTarget() -> ():
        me.currentTarget = ""

    me setEventPhase(phase: text) -> ():
        me.eventPhase = normalizeEventPhase(phase)

    me isPropagationStopped() -> bool:
        me.propagationStopped

    me isImmediatePropagationStopped() -> bool:
        me.didStopImmediatePropagation()

    me prepareForTarget(target: text) -> ():
        me.preparedTarget = target

    me phaseIsCapturing() -> bool:
        me.eventPhase == "capturing"

    me phaseIsAtTarget() -> bool:
        me.eventPhase == "at_target"

    me phaseIsBubbling() -> bool:
        me.eventPhase == "bubbling"

fn terminalEventNew(event_type: text) -> TerminalEvent:
    TerminalEvent.new(event_type)

fn terminalEventInit(bubbles: bool, cancelable: bool) -> TerminalEventInit:
    TerminalEventInit(bubbles: bubbles, cancelable: cancelable)

fn terminalEventWithInit(event_type: text, bubbles: bool, cancelable: bool) -> TerminalEvent:
    TerminalEvent.withInit(event_type, terminalEventInit(bubbles, cancelable))

fn normalizeEventPhase(phase: text) -> text:
    if phase == "capturing" or phase == "at_target" or phase == "bubbling":
        return phase
    "none"

fn terminalEventPhases() -> [text]:
    ["none", "capturing", "at_target", "bubbling"]
