class FocusEvent:
    type: text
    relatedTarget: text
    bubbles: bool
    cancelable: bool
    defaultPrevented: bool
    did_stop_immediate_propagation: bool

impl FocusEvent:
    static fn new(event_type: text, relatedTarget: text) -> FocusEvent:
        FocusEvent(
            type: normalizeFocusEventType(event_type),
            relatedTarget: relatedTarget,
            bubbles: true,
            cancelable: false,
            defaultPrevented: false,
            did_stop_immediate_propagation: false
        )

    me preventDefault() -> ():
        if me.cancelable:
            me.defaultPrevented = true

    me didStopImmediatePropagation() -> bool:
        me.did_stop_immediate_propagation

    me stopImmediatePropagation() -> ():
        me.did_stop_immediate_propagation = true

    me isFocus() -> bool:
        me.type == "focus"

    me isBlur() -> bool:
        me.type == "blur"

fn normalizeFocusEventType(event_type: text) -> text:
    if event_type == "blur":
        return "blur"
    "focus"

fn focusEventNew(event_type: text, relatedTarget: text) -> FocusEvent:
    FocusEvent.new(event_type, relatedTarget)
