class ParsedKeyboardKey:
    name: text
    sequence: text
    code: text
    ctrl: bool
    shift: bool
    meta: bool
    option: bool
    superKey: bool
    functionKey: bool

impl ParsedKeyboardKey:
    static fn new(name: text, sequence: text) -> ParsedKeyboardKey:
        ParsedKeyboardKey(
            name: name,
            sequence: sequence,
            code: "",
            ctrl: false,
            shift: false,
            meta: false,
            option: false,
            superKey: false,
            functionKey: false
        )

class KeyboardEvent:
    type: text
    bubbles: bool
    cancelable: bool
    key: text
    ctrl: bool
    shift: bool
    meta: bool
    superKey: bool
    functionKey: bool
    did_stop_immediate_propagation: bool

impl KeyboardEvent:
    static fn new(parsedKey: ParsedKeyboardKey) -> KeyboardEvent:
        KeyboardEvent(
            type: "keydown",
            bubbles: true,
            cancelable: true,
            key: keyFromParsed(parsedKey),
            ctrl: parsedKey.ctrl,
            shift: parsedKey.shift,
            meta: parsedKey.meta or parsedKey.option,
            superKey: parsedKey.superKey,
            functionKey: parsedKey.functionKey,
            did_stop_immediate_propagation: false
        )

    me didStopImmediatePropagation() -> bool:
        me.did_stop_immediate_propagation

    me stopImmediatePropagation() -> ():
        me.did_stop_immediate_propagation = true

    me printableChar() -> bool:
        me.key.len() == 1

fn keyFromParsed(parsed: ParsedKeyboardKey) -> text:
    val seq = parsed.sequence
    val name = parsed.name
    if parsed.ctrl:
        return name
    if seq.len() == 1:
        val code = seq.char_code_at(0)
        if code >= 32 and code != 127:
            return seq
    if name != "":
        return name
    seq

fn keyboardEventNew(parsedKey: ParsedKeyboardKey) -> KeyboardEvent:
    KeyboardEvent.new(parsedKey)

fn parsedKeyboardKeyNew(name: text, sequence: text) -> ParsedKeyboardKey:
    ParsedKeyboardKey.new(name, sequence)
