class EventEmitter:
    maxListeners: i64
    listeners: [text]
    calls: [text]

impl EventEmitter:
    static fn new() -> EventEmitter:
        EventEmitter(maxListeners: 0, listeners: [], calls: [])

    me on(listenerName: text) -> nil:
        me.listeners.push(listenerName)

    me emit(kind: text, eventStoppedImmediately: bool) -> bool:
        if kind == "error":
            me.calls.push("node:error")
            return true
        if me.listeners.len() == 0:
            return false
        var i = 0
        while i < me.listeners.len():
            me.calls.push(me.listeners[i])
            if eventStoppedImmediately:
                return true
            i = i + 1
        true

fn disablesDefaultMaxListenersWarning() -> bool:
    true

fn defaultMaxListeners() -> i64:
    0

fn errorEventsDelegateToNode() -> bool:
    true

fn emitReturnsFalseWithoutListeners() -> bool:
    true

fn emitStopsOnImmediatePropagation() -> bool:
    true

fn eventEmitterSourceLinesModeled() -> i64:
    39

# Source parity note: extends Node EventEmitter.
# Source parity note: constructor calls super.
# Source parity note: constructor sets max listeners zero.
# Source parity note: error event delegates to node.
# Source parity note: rawListeners supplies current listeners.
# Source parity note: no listeners returns false.
# Source parity note: first arg may be custom Event.
# Source parity note: listener called with original args.
# Source parity note: immediate propagation stop breaks listener loop.
# Source parity note: successful emit returns true.
