class TerminalFocusEvent:
    type: text
    did_stop_immediate_propagation: bool

impl TerminalFocusEvent:
    static fn new(event_type: text) -> TerminalFocusEvent:
        TerminalFocusEvent(
            type: normalizeTerminalFocusEventType(event_type),
            did_stop_immediate_propagation: false
        )

    me didStopImmediatePropagation() -> bool:
        me.did_stop_immediate_propagation

    me stopImmediatePropagation() -> ():
        me.did_stop_immediate_propagation = true

    me isFocus() -> bool:
        me.type == "terminalfocus"

    me isBlur() -> bool:
        me.type == "terminalblur"

fn normalizeTerminalFocusEventType(event_type: text) -> text:
    if event_type == "terminalblur":
        return "terminalblur"
    "terminalfocus"

fn terminalFocusEventNew(event_type: text) -> TerminalFocusEvent:
    TerminalFocusEvent.new(event_type)
