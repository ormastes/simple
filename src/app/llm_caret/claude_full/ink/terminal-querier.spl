class TerminalResponse:
    type: text
    mode: i64
    code: i64
    row: i64
    col: i64
    flags: i64
    value: text

impl TerminalResponse:
    static fn new(type: text) -> TerminalResponse:
        TerminalResponse(type: type, mode: 0, code: 0, row: 0, col: 0, flags: 0, value: "")

class TerminalQuery:
    request: text
    matchType: text
    mode: i64
    code: i64

class PendingTerminalQuery:
    kind: text
    query: TerminalQuery
    resolved: bool
    unsupported: bool
    responseType: text

class TerminalQuerier:
    queue: [PendingTerminalQuery]
    stdoutWrites: [text]
    resolved: [text]

impl TerminalQuerier:
    static fn new() -> TerminalQuerier:
        TerminalQuerier(queue: [], stdoutWrites: [], resolved: [])

    me send(query: TerminalQuery) -> ():
        me.queue.push(PendingTerminalQuery(kind: "query", query: query, resolved: false, unsupported: false, responseType: ""))
        me.stdoutWrites.push(query.request)

    me flush() -> ():
        me.queue.push(PendingTerminalQuery(kind: "sentinel", query: da1(), resolved: false, unsupported: false, responseType: ""))
        me.stdoutWrites.push(sentinel())

    me onResponse(response: TerminalResponse) -> ():
        val idx = me.firstMatchingQuery(response)
        if idx >= 0:
            val pending = me.queue[idx]
            me.resolved.push(pending.query.matchType + ":" + response.type)
            me.queue = removeAt(me.queue, idx)
            return
        if response.type == "da1":
            val sentinelIndex = me.firstSentinel()
            if sentinelIndex < 0:
                return
            var i = 0
            while i <= sentinelIndex:
                val pending = me.queue[i]
                if pending.kind == "query":
                    me.resolved.push(pending.query.matchType + ":undefined")
                else:
                    me.resolved.push("sentinel:resolved")
                i = i + 1
            me.queue = dropThrough(me.queue, sentinelIndex)

    me firstMatchingQuery(response: TerminalResponse) -> i64:
        var i = 0
        while i < me.queue.len():
            val pending = me.queue[i]
            if pending.kind == "query" and queryMatches(pending.query, response):
                return i
            i = i + 1
        -1

    me firstSentinel() -> i64:
        var i = 0
        while i < me.queue.len():
            if me.queue[i].kind == "sentinel":
                return i
            i = i + 1
        -1

    me pendingCount() -> i64:
        me.queue.len()

    me writtenText() -> text:
        joinText(me.stdoutWrites)

fn decrqm(mode: i64) -> TerminalQuery:
    TerminalQuery(request: csi("?" + mode.to_text() + "$p"), matchType: "decrpm", mode: mode, code: 0)

fn da1() -> TerminalQuery:
    TerminalQuery(request: csi("c"), matchType: "da1", mode: 0, code: 0)

fn da2() -> TerminalQuery:
    TerminalQuery(request: csi(">c"), matchType: "da2", mode: 0, code: 0)

fn kittyKeyboard() -> TerminalQuery:
    TerminalQuery(request: csi("?u"), matchType: "kittyKeyboard", mode: 0, code: 0)

fn cursorPosition() -> TerminalQuery:
    TerminalQuery(request: csi("?6n"), matchType: "cursorPosition", mode: 0, code: 0)

fn oscColor(code: i64) -> TerminalQuery:
    TerminalQuery(request: osc(code, "?"), matchType: "osc", mode: 0, code: code)

fn xtversion() -> TerminalQuery:
    TerminalQuery(request: csi(">0q"), matchType: "xtversion", mode: 0, code: 0)

fn queryMatches(query: TerminalQuery, response: TerminalResponse) -> bool:
    if query.matchType != response.type:
        return false
    if query.matchType == "decrpm":
        return response.mode == query.mode
    if query.matchType == "osc":
        return response.code == query.code
    true

fn response(type: text) -> TerminalResponse:
    TerminalResponse.new(type)

fn decrpmResponse(mode: i64) -> TerminalResponse:
    TerminalResponse(type: "decrpm", mode: mode, code: 0, row: 0, col: 0, flags: 0, value: "")

fn oscResponse(code: i64) -> TerminalResponse:
    TerminalResponse(type: "osc", mode: 0, code: code, row: 0, col: 0, flags: 0, value: "")

fn csi(body: text) -> text:
    "\u001B[" + body

fn osc(code: i64, body: text) -> text:
    "\u001B]" + code.to_text() + ";" + body + "\u0007"

fn sentinel() -> text:
    csi("c")

fn removeAt(values: [PendingTerminalQuery], index: i64) -> [PendingTerminalQuery]:
    var out: [PendingTerminalQuery] = []
    var i = 0
    while i < values.len():
        if i != index:
            out.push(values[i])
        i = i + 1
    out

fn dropThrough(values: [PendingTerminalQuery], index: i64) -> [PendingTerminalQuery]:
    var out: [PendingTerminalQuery] = []
    var i = index + 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn joinText(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        out = out + values[i]
        i = i + 1
    out

fn terminalQuerierSourceLinesModeled() -> i64:
    212

# ponytail: Promise resolution is modeled as resolved text entries; add async only when Simple terminal IO needs it.
# Source parity note: query builders pair request escape sequences with response matchers.
# Source parity note: DECRQM matches decrpm by mode.
# Source parity note: OSC color matches osc by code.
# Source parity note: cursor position uses DEC private CSI ?6n to avoid F-key ambiguity.
# Source parity note: flush writes a DA1 sentinel.
# Source parity note: send writes query requests immediately.
# Source parity note: response dispatch matches the first pending query, not only queue head.
# Source parity note: unmatched DA1 drains through the first sentinel.
# Source parity note: queries before the sentinel resolve undefined when unsupported.
# Source parity note: queries after the first sentinel remain queued for later batches.
