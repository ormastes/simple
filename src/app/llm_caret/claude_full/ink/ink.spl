const INK_MAIN_SOURCE_LINES = 1722

class Options:
    exitOnCtrlC: bool
    patchConsole: bool
    waitUntilExit: bool
    hasOnFrame: bool

impl Options:
    static fn new(exitOnCtrlC: bool, patchConsole: bool, waitUntilExit: bool, hasOnFrame: bool) -> Options:
        Options(exitOnCtrlC: exitOnCtrlC, patchConsole: patchConsole, waitUntilExit: waitUntilExit, hasOnFrame: hasOnFrame)

class Ink:
    isMounted: bool
    isPaused: bool
    altScreenActive: bool
    stdinRawMode: bool
    frames: i64

impl Ink:
    static fn new() -> Ink:
        Ink(isMounted: false, isPaused: false, altScreenActive: false, stdinRawMode: false, frames: 0)

    me renderRoute(hasNode: bool) -> text:
        if !hasNode:
            return "skip empty render"
        me.isMounted = true
        "mount or update reconciler root"

    me unmountRoute() -> text:
        me.isMounted = false
        me.altScreenActive = false
        me.stdinRawMode = false
        "restore terminal and unmount root"

    me pauseRoute() -> text:
        me.isPaused = true
        me.stdinRawMode = false
        "flush reconciler render once then pause"

    me resumeRoute() -> text:
        me.isPaused = false
        "resume then render immediately"

    me repaintRoute(force: bool) -> text:
        if force:
            return "forceRedraw reset framebuffer displayCursor erase render"
        "repaint invalidates prev frame render"

    me setAltScreenActiveRoute(active: bool, mouseTracking: bool) -> text:
        me.altScreenActive = active
        if active && mouseTracking:
            return "enter alt screen enable mouse tracking"
        if active:
            return "enter alt screen"
        "exit alt screen restore cursor"

fn makeAltScreenParkPatch(rows: i64) -> text:
    if rows <= 0:
        return "\x1b[H"
    "\x1b[" + rows.to_text() + ";1H"

fn deferredRenderRoute(alreadyScheduled: bool, mounted: bool, paused: bool) -> text:
    if !mounted:
        return "skip unmounted"
    if paused:
        return "defer while paused"
    if alreadyScheduled:
        return "coalesce scheduled render"
    "queue microtask then schedule deferred frame"

fn blank(width: i64) -> text:
    var out = ""
    var i = 0
    while i < width:
        out = out + " "
        i = i + 1
    out

fn toDebug(values: text) -> text:
    values

fn toError(values: text) -> text:
    values

fn interceptRoute(patchConsole: bool, stream: text) -> text:
    if !patchConsole:
        return "leave console alone"
    if stream == "stderr":
        return "capture stderr console"
    "capture stdout console"

fn interceptWriteRoute(reentered: bool, altScreenActive: bool, unmounted: bool, paused: bool) -> text:
    if reentered:
        return "passthrough original writer"
    if altScreenActive && !unmounted && !paused:
        return "mark frame contaminated schedule render"
    if altScreenActive:
        return "mark frame contaminated no schedule"
    "normalize chunk then callback once"

fn callbackRoute(kind: text, afterExit: bool) -> text:
    if afterExit:
        return "skip callback after exit"
    if kind == "frame":
        return "call onFrame with timing metadata"
    if kind == "error":
        return "write captured error"
    "write captured debug"

fn callbackFinallyRoute(callbackInstalled: bool) -> text:
    if callbackInstalled:
        return "callback exactly once in finally"
    "no callback"

fn interceptCallbackRoute(reentered: bool, callbackInstalled: bool) -> text:
    if reentered:
        return "no callback passthrough"
    if callbackInstalled:
        return "stderr callback cleanup exactly once"
    "stderr intercept no callback"

fn drainStdinRoute(isTTY: bool, readable: bool, repeated: bool) -> text:
    if !isTTY:
        return "noop non tty"
    if !readable:
        return "noop unreadable tty"
    if repeated:
        return "idempotent drain"
    "drain buffered tty input"

fn drainStdinPlatformRoute(platform: text, chunks: i64, cleanup: bool) -> text:
    if platform == "win32":
        return "noop win32"
    if chunks >= 64 && cleanup:
        return "bounded 64 reads cleanup"
    if cleanup:
        return "read until eof cleanup"
    "read loop missing cleanup"

fn blankStateRoute(rows: i64) -> text:
    if rows <= 0:
        return "cursor y 0 viewport 1 contaminated"
    "viewport rows plus one cursor y 0 contaminated"

fn lifecycleRoute(action: text, mounted: bool, paused: bool) -> text:
    if action == "render":
        return "mount update provider tree"
    if action == "unmount":
        return "synchronous restore cleanup"
    if action == "resize":
        return "update rows cols rerender"
    if action == "forceRedraw":
        return "invalidate prev frame repaint"
    if paused:
        return "paused lifecycle no write"
    if mounted:
        return "active lifecycle"
    "inactive lifecycle"

fn inputRoute(rawMode: bool, exitOnCtrlC: bool, key: text) -> text:
    if key == "\x03" && exitOnCtrlC:
        return "let app exit"
    if rawMode:
        return "dispatch keyboard input"
    "ignore inactive input"

fn resizeRoute(sizeChanged: bool, altScreen: bool, paused: bool) -> text:
    if !sizeChanged:
        return "same size resize no op"
    if altScreen:
        return "resize alt screen reset buffers needs erase rerender"
    if paused:
        return "resize while paused update tree"
    "resize rerender"

fn selectionRouteInk(action: text, hasSelection: bool) -> text:
    if action == "copy" && hasSelection:
        return "copy selection and clear"
    if action == "copyNoClear" && hasSelection:
        return "copy selection keep state"
    if action == "clear":
        return "clear text selection"
    "selection no op"

fn eventDispatchRoute(kind: text, handled: bool) -> text:
    if handled:
        return "stop dispatch"
    if kind == "click":
        return "focus then bubble click"
    if kind == "hover":
        return "dispatch hover enter leave"
    if kind == "keyboard":
        return "dispatch focused keyboard"
    "unknown event"

fn inkSourceLinesModeled() -> i64:
    INK_MAIN_SOURCE_LINES
