const RENDER_NODE_TO_OUTPUT_SOURCE_LINES = 1462

fn buildCharToSegmentMapRoute(segmentLengths: text) -> text:
    var out = ""
    var segmentIndex = 0
    for rawLen in segmentLengths.split(","):
        val length = parse_i64_or_zero(rawLen)
        var i = 0
        while i < length:
            if out != "":
                out = out + ","
            out = out + segmentIndex.to_text()
            i = i + 1
        segmentIndex = segmentIndex + 1
    out

fn parse_i64_or_zero(value: text) -> i64:
    if value == "0":
        return 0
    if value == "1":
        return 1
    if value == "2":
        return 2
    if value == "3":
        return 3
    if value == "4":
        return 4
    if value == "5":
        return 5
    0

fn applyStylesToWrappedTextRoute(segmentCount: i64, hasHyperlink: bool, trimWhitespace: bool) -> text:
    var result = "styles " + segmentCount.to_text()
    if hasHyperlink:
        result = result + " hyperlink per line"
    if trimWhitespace:
        result = result + " trimmed"
    else:
        result = result + " preserved"
    result

fn wrapWithSoftWrapRoute(mode: text, wrappedLineCount: i64) -> text:
    if mode == "wrap" && wrappedLineCount > 1:
        return "soft wraps"
    "softWrap undefined"

fn applyPaddingToTextRoute(topPadding: i64, leftPadding: i64, lineCount: i64) -> text:
    "top " + topPadding.to_text() + " left " + leftPadding.to_text() + " lines " + (topPadding + lineCount).to_text()

fn emptyPlainTextOutputRoute(text: text) -> text:
    if text == "":
        return "no write output"
    "write output"

fn renderNodeToOutputSourceLinesModeled() -> i64:
    RENDER_NODE_TO_OUTPUT_SOURCE_LINES
