class AbortError:
    message: text
    name: text

impl AbortError:
    static fn new(message: text) -> AbortError:
        AbortError(message: message, name: "AbortError")

class SdkPlaceholderResult:
    ok: bool
    error: text
    value: text

impl SdkPlaceholderResult:
    static fn notImplemented(message: text) -> SdkPlaceholderResult:
        SdkPlaceholderResult(ok: false, error: message, value: "")

    static fn value(value: text) -> SdkPlaceholderResult:
        SdkPlaceholderResult(ok: true, error: "", value: value)

class CronTask:
    id: text
    cron: text
    prompt: text
    createdAt: i64
    recurring: bool

class CronJitterConfig:
    recurringFrac: i64
    recurringCapMs: i64
    oneShotMaxMs: i64
    oneShotFloorMs: i64
    oneShotMinuteMod: i64
    recurringMaxAgeMs: i64

class ScheduledTaskEvent:
    kind: text
    tasks: [CronTask]

class ScheduledTasksHandle:
    nextFireTime: i64?
    events: [ScheduledTaskEvent]

impl ScheduledTasksHandle:
    me getNextFireTime() -> i64?:
        me.nextFireTime

class InboundPrompt:
    content: text
    uuid: text

class ConnectRemoteControlOptions:
    dir: text
    name: text
    workerType: text
    branch: text
    gitRepoUrl: text
    baseUrl: text
    orgUUID: text
    model: text
    accessToken: text

class RemoteControlHandle:
    sessionUrl: text
    environmentId: text
    bridgeSessionId: text
    writes: [text]
    state: text

impl RemoteControlHandle:
    static fn new(sessionUrl: text, environmentId: text, bridgeSessionId: text) -> RemoteControlHandle:
        RemoteControlHandle(sessionUrl: sessionUrl, environmentId: environmentId, bridgeSessionId: bridgeSessionId, writes: [], state: "ready")

    me write(msg: text) -> nil:
        me.writes.push(msg)

    me sendResult() -> nil:
        me.writes.push("result")

    me sendControlRequest(req: text) -> nil:
        me.writes.push("control_request:" + req)

    me sendControlResponse(res: text) -> nil:
        me.writes.push("control_response:" + res)

    me sendControlCancelRequest(requestId: text) -> nil:
        me.writes.push("control_cancel:" + requestId)

    me onStateChange(state: text, detail: text) -> nil:
        me.state = if detail == "": state else: state + ":" + detail

    me teardown() -> SdkPlaceholderResult:
        me.state = "teardown"
        SdkPlaceholderResult.value("teardown")

