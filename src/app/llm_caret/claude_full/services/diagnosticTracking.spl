class DiagnosticsTrackingError:
    message: text
    name: text

impl DiagnosticsTrackingError:
    static fn new(message: text) -> DiagnosticsTrackingError:
        DiagnosticsTrackingError(message: message, name: "DiagnosticsTrackingError")

class DiagnosticRangePoint:
    line: i64
    character: i64

impl DiagnosticRangePoint:
    static fn new(line: i64, character: i64) -> DiagnosticRangePoint:
        DiagnosticRangePoint(line: line, character: character)

class Diagnostic:
    message: text
    severity: text
    startLine: i64
    startCharacter: i64
    endLine: i64
    endCharacter: i64
    source: text
    code: text

impl Diagnostic:
    static fn new(message: text, severity: text, line: i64, character: i64) -> Diagnostic:
        Diagnostic(message: message, severity: severity, startLine: line, startCharacter: character, endLine: line, endCharacter: character + 1, source: "", code: "")

class DiagnosticFile:
    uri: text
    diagnostics: [Diagnostic]

impl DiagnosticFile:
    static fn new(uri: text, diagnostics: [Diagnostic]) -> DiagnosticFile:
        DiagnosticFile(uri: uri, diagnostics: diagnostics)

class DiagnosticTrackingService:
    initialized: bool
    mcpConnected: bool
    baselineKeys: [text]
    baselineValues: [[Diagnostic]]
    rightKeys: [text]
    rightValues: [[Diagnostic]]
    timestampKeys: [text]
    timestampValues: [i64]
    rpcLog: [text]
    errors: [text]

impl DiagnosticTrackingService:
    static fn new() -> DiagnosticTrackingService:
        DiagnosticTrackingService(initialized: false, mcpConnected: false, baselineKeys: [], baselineValues: [], rightKeys: [], rightValues: [], timestampKeys: [], timestampValues: [], rpcLog: [], errors: [])

    me initialize(connected: bool) -> ():
        if me.initialized:
            return
        me.mcpConnected = connected
        me.initialized = true

    me shutdown() -> ():
        me.initialized = false
        me.baselineKeys = []
        me.baselineValues = []
        me.rightKeys = []
        me.rightValues = []
        me.timestampKeys = []
        me.timestampValues = []

    me reset() -> ():
        me.baselineKeys = []
        me.baselineValues = []
        me.rightKeys = []
        me.rightValues = []
        me.timestampKeys = []
        me.timestampValues = []

    me normalizeFileUri(fileUri: text) -> text:
        var normalized = fileUri
        if normalized.starts_with("file://"):
            normalized = normalized.slice(7, normalized.len())
        elif normalized.starts_with("_claude_fs_right:"):
            normalized = normalized.slice(17, normalized.len())
        elif normalized.starts_with("_claude_fs_left:"):
            normalized = normalized.slice(16, normalized.len())
        normalized

    me ensureFileOpened(fileUri: text) -> ():
        if not me.initialized or not me.mcpConnected:
            return
        me.rpcLog.push("openFile:" + fileUri + ":preview=false")

    me beforeFileEdited(filePath: text, result: [DiagnosticFile], timestamp: i64) -> ():
        if not me.initialized or not me.mcpConnected:
            return
        val diagnosticFile = firstDiagnosticFile(result)
        val normalizedPath = me.normalizeFileUri(filePath)
        if diagnosticFile.uri != "":
            if me.normalizeFileUri(diagnosticFile.uri) != normalizedPath:
                val err = DiagnosticsTrackingError.new("Diagnostics file path mismatch: expected " + filePath + ", got " + diagnosticFile.uri + ")")
                me.errors.push(err.message)
                return
            me.setBaseline(normalizedPath, diagnosticFile.diagnostics)
        else:
            me.setBaseline(normalizedPath, [])
        me.setTimestamp(normalizedPath, timestamp)

    me getNewDiagnostics(allDiagnosticFiles: [DiagnosticFile]) -> [DiagnosticFile]:
        var out: [DiagnosticFile] = []
        if not me.initialized or not me.mcpConnected:
            return out
        var i = 0
        while i < allDiagnosticFiles.len():
            val file = allDiagnosticFiles[i]
            if file.uri.starts_with("file://") and me.hasBaseline(me.normalizeFileUri(file.uri)):
                val normalized = me.normalizeFileUri(file.uri)
                var fileToUse = file
                val right = findRightFile(allDiagnosticFiles, normalized)
                if right.uri != "":
                    val previous = me.getRight(normalized)
                    if previous.len() == 0 or not me.areDiagnosticArraysEqual(previous, right.diagnostics):
                        fileToUse = right
                    me.setRight(normalized, right.diagnostics)
                val baselineDiagnostics = me.getBaseline(normalized)
                val newDiagnostics = diffDiagnostics(fileToUse.diagnostics, baselineDiagnostics)
                if newDiagnostics.len() > 0:
                    out.push(DiagnosticFile.new(file.uri, newDiagnostics))
                me.setBaseline(normalized, fileToUse.diagnostics)
            i = i + 1
        out

    me parseDiagnosticResult(result: [DiagnosticFile]) -> [DiagnosticFile]:
        result

    me areDiagnosticsEqual(a: Diagnostic, b: Diagnostic) -> bool:
        a.message == b.message and a.severity == b.severity and a.source == b.source and a.code == b.code and a.startLine == b.startLine and a.startCharacter == b.startCharacter and a.endLine == b.endLine and a.endCharacter == b.endCharacter

    me areDiagnosticArraysEqual(a: [Diagnostic], b: [Diagnostic]) -> bool:
        if a.len() != b.len():
            return false
        var i = 0
        while i < a.len():
            if not containsDiagnostic(b, a[i], me):
                return false
            i = i + 1
        var j = 0
        while j < b.len():
            if not containsDiagnostic(a, b[j], me):
                return false
            j = j + 1
        true

    me handleQueryStart(hasConnectedIdeClient: bool) -> ():
        if not me.initialized:
            if hasConnectedIdeClient:
                me.initialize(true)
        else:
            me.reset()

    me setBaseline(key: text, diagnostics: [Diagnostic]) -> ():
        val idx = indexOfText(me.baselineKeys, key)
        if idx >= 0:
            me.baselineValues[idx] = diagnostics
        else:
            me.baselineKeys.push(key)
            me.baselineValues.push(diagnostics)

    me getBaseline(key: text) -> [Diagnostic]:
        val idx = indexOfText(me.baselineKeys, key)
        if idx >= 0:
            return me.baselineValues[idx]
        []

    me hasBaseline(key: text) -> bool:
        indexOfText(me.baselineKeys, key) >= 0

    me setRight(key: text, diagnostics: [Diagnostic]) -> ():
        val idx = indexOfText(me.rightKeys, key)
        if idx >= 0:
            me.rightValues[idx] = diagnostics
        else:
            me.rightKeys.push(key)
            me.rightValues.push(diagnostics)

    me getRight(key: text) -> [Diagnostic]:
        val idx = indexOfText(me.rightKeys, key)
        if idx >= 0:
            return me.rightValues[idx]
        []

    me setTimestamp(key: text, timestamp: i64) -> ():
        val idx = indexOfText(me.timestampKeys, key)
        if idx >= 0:
            me.timestampValues[idx] = timestamp
        else:
            me.timestampKeys.push(key)
            me.timestampValues.push(timestamp)

    static fn formatDiagnosticsSummary(files: [DiagnosticFile]) -> text:
        var result = ""
        var i = 0
        while i < files.len():
            if i > 0:
                result = result + "\n\n"
            val file = files[i]
            result = result + filenameFromUri(file.uri) + ":\n"
            var j = 0
            while j < file.diagnostics.len():
                if j > 0:
                    result = result + "\n"
                val d = file.diagnostics[j]
                result = result + "  " + DiagnosticTrackingService.getSeveritySymbol(d.severity) + " [Line " + (d.startLine + 1).to_text() + ":" + (d.startCharacter + 1).to_text() + "] " + d.message
                if d.code != "":
                    result = result + " [" + d.code + "]"
                if d.source != "":
                    result = result + " (" + d.source + ")"
                j = j + 1
            i = i + 1
        if result.len() > maxDiagnosticsSummaryChars():
            return result.slice(0, maxDiagnosticsSummaryChars() - 12) + "…[truncated]"
        result

    static fn getSeveritySymbol(severity: text) -> text:
        if severity == "Error":
            return "x"
        if severity == "Warning":
            return "!"
        if severity == "Info":
            return "i"
        if severity == "Hint":
            return "*"
        "•"

fn firstDiagnosticFile(files: [DiagnosticFile]) -> DiagnosticFile:
    if files.len() > 0:
        return files[0]
    DiagnosticFile.new("", [])

fn findRightFile(files: [DiagnosticFile], normalized: text) -> DiagnosticFile:
    val service = DiagnosticTrackingService.new()
    var i = 0
    while i < files.len():
        if files[i].uri.starts_with("_claude_fs_right:") and service.normalizeFileUri(files[i].uri) == normalized:
            return files[i]
        i = i + 1
    DiagnosticFile.new("", [])

fn diffDiagnostics(current: [Diagnostic], baseline: [Diagnostic]) -> [Diagnostic]:
    val service = DiagnosticTrackingService.new()
    var out: [Diagnostic] = []
    var i = 0
    while i < current.len():
        if not containsDiagnostic(baseline, current[i], service):
            out.push(current[i])
        i = i + 1
    out

fn containsDiagnostic(values: [Diagnostic], needle: Diagnostic, service: DiagnosticTrackingService) -> bool:
    var i = 0
    while i < values.len():
        if service.areDiagnosticsEqual(values[i], needle):
            return true
        i = i + 1
    false

fn filenameFromUri(uri: text) -> text:
    val slash = uri.rfind("/")
    if slash < 0:
        return uri
    uri.slice(slash + 1, uri.len())

fn textBlock(value: text) -> text:
    value

fn indexOfText(values: [text], needle: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return i
        i = i + 1
    -1

fn maxDiagnosticsSummaryChars() -> i64:
    4000

fn diagnosticTrackingSourceLinesModeled() -> i64:
    397

# Source parity note: class_DiagnosticsTrackingError exists for path mismatch logging.
# Source parity note: interface_Diagnostic is represented by Diagnostic fields.
# Source parity note: interface_DiagnosticFile is represented by uri and diagnostics.
# Source parity note: class_DiagnosticTrackingService tracks baseline diagnostics.
# Source parity note: function_textBlock models parseDiagnosticResult text block extraction.
# Source parity note: singleton diagnosticTracker is modeled by DiagnosticTrackingService.new in tests.
# Source parity note: right file diagnostics are preferred when changed.
# Source parity note: baseline updates after new diagnostics are calculated.
# Source parity note: summary uses one-based line and character display.
