const CLAUDE_API_SOURCE_LINES = 3419

class Options:
    streaming: bool
    model: text

impl Options:
    static fn new(streaming: bool, model: text) -> Options:
        Options(streaming: streaming, model: model)

class TaskBudgetParam:
    maxUsd: i64
    maxTokens: i64

impl TaskBudgetParam:
    static fn new(maxUsd: i64, maxTokens: i64) -> TaskBudgetParam:
        TaskBudgetParam(maxUsd: maxUsd, maxTokens: maxTokens)

fn getExtraBodyParamsRoute(hasThinking: bool, hasMetadata: bool, hasCache: bool) -> text:
    if hasThinking && hasMetadata && hasCache:
        return "extra body thinking metadata cache"
    if hasThinking:
        return "extra body thinking"
    if hasMetadata:
        return "extra body metadata"
    "extra body empty"

fn getPromptCachingEnabledRoute(disabled: bool, modelSupports: bool) -> bool:
    !disabled && modelSupports

fn getCacheControlRoute(enabled: bool, ttl1h: bool) -> text:
    if !enabled:
        return "no cache control"
    if ttl1h:
        return "cache control 1h"
    "cache control ephemeral"

fn configureEffortParamsRoute(model: text, effort: text) -> text:
    if effort == "":
        return "no effort params"
    if model.contains("opus") || model.contains("sonnet"):
        return "configure reasoning effort " + effort
    "effort unsupported"

fn configureTaskBudgetParamsRoute(hasBudget: bool, exceeded: bool) -> text:
    if exceeded:
        return "task budget exceeded"
    if hasBudget:
        return "task budget params"
    "no task budget params"

fn getAPIMetadataRoute(hasSession: bool, hasRequestId: bool) -> text:
    if hasSession && hasRequestId:
        return "api metadata session request"
    if hasSession:
        return "api metadata session"
    "api metadata empty"

fn verifyApiKeyRoute(hasKey: bool, valid: bool) -> text:
    if !hasKey:
        return "missing api key"
    if valid:
        return "api key verified"
    "api key rejected"

fn messageParamRoute(role: text, hasTool: bool, hasMedia: bool) -> text:
    if role == "user" && hasMedia:
        return "user message with media"
    if role == "user" && hasTool:
        return "user tool result message"
    if role == "assistant" && hasTool:
        return "assistant tool use message"
    if role == "assistant":
        return "assistant message param"
    "user message param"

fn previousRequestIdRoute(hasMessages: bool, hasPreviousId: bool) -> text:
    if hasMessages && hasPreviousId:
        return "previous request id"
    if hasMessages:
        return "no previous request id"
    "no messages"

fn mediaBlockRoute(kind: text, inToolResult: bool) -> text:
    if inToolResult:
        return "tool result block preserved"
    if kind == "image" || kind == "document":
        return "media block"
    "non media block"

fn queryModelWithoutStreamingRoute(success: bool, timeout: bool, fallback: bool) -> text:
    if timeout:
        return "nonstreaming timeout"
    if success:
        return "nonstreaming response"
    if fallback:
        return "fallback to streaming"
    "nonstreaming failure"

fn shouldDeferLspToolRoute(toolName: text, lspReady: bool) -> bool:
    toolName.contains("LSP") && !lspReady

fn getNonstreamingFallbackTimeoutMsRoute(configured: i64) -> i64:
    if configured > 0:
        return configured
    10000

fn mediaTrimRoute(mediaCount: i64, limit: i64, hasToolResult: bool) -> text:
    if mediaCount <= limit:
        return "media unchanged"
    if hasToolResult:
        return "trim media preserve tool results"
    "trim excess media"

fn deferredToolsRoute(hasDeferred: bool, includeNow: bool) -> text:
    if includeNow:
        return "include deferred tools"
    if hasDeferred:
        return "defer tools"
    "no deferred tools"

fn paramsFromContextRoute(hasTools: bool, hasMcp: bool, hasConfig: bool) -> text:
    if hasTools && hasMcp && hasConfig:
        return "params context tools mcp config"
    if hasTools || hasMcp:
        return "params context tools"
    "params context base"

fn streamResourceRoute(kind: text) -> text:
    if kind == "release":
        return "release stream resources"
    if kind == "clearIdle":
        return "clear stream idle timers"
    if kind == "resetIdle":
        return "reset stream idle timer"
    if kind == "cleanup":
        return "cleanup stream"
    if kind == "abortIdle":
        return "abort stalled stream"
    "stream active"

fn usageRoute(current: i64, delta: i64) -> i64:
    current + delta

fn updateUsageRoute(current: i64, eventTotal: i64) -> i64:
    if eventTotal > current:
        return eventTotal
    current

fn accumulateUsageRoute(current: i64, delta: i64) -> i64:
    if delta <= 0:
        return current
    current + delta

fn cacheBreakpointRoute(hasPinnedEdits: bool, hasSystemBlocks: bool) -> text:
    if hasPinnedEdits:
        return "add cache breakpoints for pinned edits"
    if hasSystemBlocks:
        return "add cache breakpoints for system blocks"
    "no cache breakpoints"

fn cacheReferenceRoute(hasReference: bool, cacheEnabled: bool) -> text:
    if hasReference && cacheEnabled:
        return "cache reference applied"
    if hasReference:
        return "cache reference ignored"
    "no cache reference"

fn deduplicateEditsRoute(total: i64, unique: i64) -> text:
    if unique < total:
        return "deduplicate edits"
    "edits already unique"

fn buildSystemPromptBlocksRoute(hasTools: bool, hasReminders: bool) -> text:
    if hasTools && hasReminders:
        return "system prompt tools reminders"
    if hasTools:
        return "system prompt tools"
    "system prompt base"

fn queryModelRoute(kind: text, hasModel: bool, nonStreaming: bool) -> text:
    if kind == "haiku":
        return "query haiku"
    if hasModel && nonStreaming:
        return "query model nonstreaming"
    if hasModel:
        return "query with model"
    "query default model"

fn adjustParamsForNonStreamingRoute(hasStreamOnly: bool, maxTokens: i64) -> text:
    if hasStreamOnly:
        return "remove streaming only params"
    if maxTokens > 0:
        return "set nonstreaming max tokens"
    "nonstreaming params unchanged"

fn maxOutputTokensRoute(capEnabled: bool, requested: i64, cap: i64) -> i64:
    if capEnabled && requested > cap:
        return cap
    requested

fn claudeApiSourceLinesModeled() -> i64:
    CLAUDE_API_SOURCE_LINES
