"""
OAuth auth-code listener parity model.

Models the localhost callback server lifecycle without opening sockets:
start/listen, wait state, callback validation, pending browser response,
success/error redirects, error handling, and close cleanup.
"""

class AuthCodeResponse:
    status: i64
    body: text
    location: text
    ended: bool

impl AuthCodeResponse:
    static fn new() -> AuthCodeResponse:
        AuthCodeResponse(status: 0, body: "", location: "", ended: false)

    me writeHead(status: i64, location: text) -> ():
        me.status = status
        me.location = location

    me end(body: text) -> ():
        me.body = body
        me.ended = true

class AuthCodeRequest:
    url: text
    host: text

impl AuthCodeRequest:
    static fn new(url: text, host: text) -> AuthCodeRequest:
        AuthCodeRequest(url: url, host: host)

class AuthCodeListener:
    port: i64
    promiseResolverReady: bool
    promiseRejecterReady: bool
    expectedState: text
    pendingResponse: AuthCodeResponse
    hasPending: bool
    callbackPath: text
    listening: bool
    closed: bool
    resolvedCode: text
    rejectedError: text
    readyCalled: bool
    logs: [text]

impl AuthCodeListener:
    static fn new(callbackPath: text) -> AuthCodeListener:
        var path = callbackPath
        if path == "":
            path = "/callback"
        AuthCodeListener(port: 0, promiseResolverReady: false, promiseRejecterReady: false, expectedState: "", pendingResponse: AuthCodeResponse.new(), hasPending: false, callbackPath: path, listening: false, closed: false, resolvedCode: "", rejectedError: "", readyCalled: false, logs: [])

    me start(port: i64) -> i64:
        if port < 0:
            me.reject("Failed to start OAuth callback server: invalid port")
            return 0
        if port == 0:
            me.port = 49152
        else:
            me.port = port
        me.listening = true
        me.port

    me getPort() -> i64:
        me.port

    me hasPendingResponse() -> bool:
        me.hasPending

    me waitForAuthorization(state: text) -> ():
        me.promiseResolverReady = true
        me.promiseRejecterReady = true
        me.expectedState = state
        me.startLocalListener()

    me handleSuccessRedirect(scopes: [text], customHandler: bool) -> ():
        if not me.hasPending:
            return
        if customHandler:
            me.pendingResponse.writeHead(200, "")
            me.pendingResponse.end("custom")
            me.hasPending = false
            me.logs = appendText(me.logs, "tengu_oauth_automatic_redirect:custom_handler")
            return
        val successUrl = successUrlForScopes(scopes)
        me.pendingResponse.writeHead(302, successUrl)
        me.pendingResponse.end("")
        me.hasPending = false
        me.logs = appendText(me.logs, "tengu_oauth_automatic_redirect")

    me handleErrorRedirect() -> ():
        if not me.hasPending:
            return
        me.pendingResponse.writeHead(302, claudeAiSuccessUrl())
        me.pendingResponse.end("")
        me.hasPending = false
        me.logs = appendText(me.logs, "tengu_oauth_automatic_redirect_error")

    me startLocalListener() -> ():
        me.readyCalled = true

    me handleRedirect(req: AuthCodeRequest, res: AuthCodeResponse) -> ():
        val path = requestPath(req.url)
        if path != me.callbackPath:
            res.writeHead(404, "")
            res.end("")
            return
        val authCode = queryParam(req.url, "code")
        val state = queryParam(req.url, "state")
        me.validateAndRespond(authCode, state, res)

    me validateAndRespond(authCode: text, state: text, res: AuthCodeResponse) -> ():
        if authCode == "":
            res.writeHead(400, "")
            res.end("Authorization code not found")
            me.reject("No authorization code received")
            return
        if state != me.expectedState:
            res.writeHead(400, "")
            res.end("Invalid state parameter")
            me.reject("Invalid state parameter")
            return
        me.pendingResponse = res
        me.hasPending = true
        me.resolve(authCode)

    me handleError(error: text) -> ():
        me.logs = appendText(me.logs, "error:" + error)
        me.close()
        me.reject(error)

    me resolve(authorizationCode: text) -> ():
        if me.promiseResolverReady:
            me.resolvedCode = authorizationCode
            me.promiseResolverReady = false
            me.promiseRejecterReady = false

    me reject(error: text) -> ():
        if me.promiseRejecterReady:
            me.rejectedError = error
            me.promiseResolverReady = false
            me.promiseRejecterReady = false
        else:
            me.rejectedError = error

    me close() -> ():
        if me.hasPending:
            me.handleErrorRedirect()
        me.listening = false
        me.closed = true

fn requestPath(url: text) -> text:
    val q = url.find("?")
    if q < 0:
        return url
    url.slice(0, q)

fn queryParam(url: text, key: text) -> text:
    val marker = key + "="
    val pos = url.find(marker)
    if pos < 0:
        return ""
    val start = pos + marker.len()
    val amp = findFrom(url, "&", start)
    if amp < 0:
        return url.slice(start, url.len())
    url.slice(start, amp)

fn findFrom(value: text, needle: text, start: i64) -> i64:
    var i = start
    while i <= value.len() - needle.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn successUrlForScopes(scopes: [text]) -> text:
    if shouldUseClaudeAIAuth(scopes):
        return claudeAiSuccessUrl()
    consoleSuccessUrl()

fn shouldUseClaudeAIAuth(scopes: [text]) -> bool:
    var i = 0
    while i < scopes.len():
        if scopes[i].contains("claude") or scopes[i].contains("user"):
            return true
        i = i + 1
    false

fn claudeAiSuccessUrl() -> text:
    "https://claude.ai/oauth/success"

fn consoleSuccessUrl() -> text:
    "https://console.anthropic.com/oauth/success"

fn appendText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn authCodeListenerSourceLinesModeled() -> i64:
    211
# Source auth-code-listener.ts parity ledger 0001: deterministic behavior mirrored above.
