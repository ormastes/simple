"""
OAuthService parity model for OAuth 2.0 authorization-code flow with PKCE.
"""

use app.llm_caret.claude_full.services.oauth.auth_code_listener.*

class OAuthTokenExchangeResponse:
    accessToken: text
    refreshToken: text
    expiresIn: i64
    scope: text
    accountUuid: text
    accountEmail: text
    organizationUuid: text

impl OAuthTokenExchangeResponse:
    static fn new(accessToken: text, refreshToken: text, expiresIn: i64, scope: text) -> OAuthTokenExchangeResponse:
        OAuthTokenExchangeResponse(accessToken: accessToken, refreshToken: refreshToken, expiresIn: expiresIn, scope: scope, accountUuid: "", accountEmail: "", organizationUuid: "")

class OAuthTokens:
    accessToken: text
    refreshToken: text
    expiresAt: i64
    scopes: [text]
    subscriptionType: text
    rateLimitTier: text
    profile: text
    tokenAccountUuid: text
    tokenAccountEmail: text
    organizationUuid: text

impl OAuthTokens:
    static fn new(accessToken: text, refreshToken: text, expiresAt: i64, scopes: [text], subscriptionType: text, rateLimitTier: text, profile: text, tokenAccountUuid: text, tokenAccountEmail: text, organizationUuid: text) -> OAuthTokens:
        OAuthTokens(accessToken: accessToken, refreshToken: refreshToken, expiresAt: expiresAt, scopes: scopes, subscriptionType: subscriptionType, rateLimitTier: rateLimitTier, profile: profile, tokenAccountUuid: tokenAccountUuid, tokenAccountEmail: tokenAccountEmail, organizationUuid: organizationUuid)

class OAuthFlowOptions:
    loginWithClaudeAi: bool
    inferenceOnly: bool
    expiresIn: i64
    orgUUID: text
    loginHint: text
    loginMethod: text
    skipBrowserOpen: bool

impl OAuthFlowOptions:
    static fn defaults() -> OAuthFlowOptions:
        OAuthFlowOptions(loginWithClaudeAi: false, inferenceOnly: false, expiresIn: 0, orgUUID: "", loginHint: "", loginMethod: "", skipBrowserOpen: false)

class OAuthFlowResult:
    tokens: OAuthTokens
    manualFlowUrl: text
    automaticFlowUrl: text
    openedBrowser: bool
    handlerReceivedAutomaticUrl: bool
    automaticFlow: bool
    logs: [text]

impl OAuthFlowResult:
    static fn new(tokens: OAuthTokens, manualFlowUrl: text, automaticFlowUrl: text, openedBrowser: bool, handlerReceivedAutomaticUrl: bool, automaticFlow: bool, logs: [text]) -> OAuthFlowResult:
        OAuthFlowResult(tokens: tokens, manualFlowUrl: manualFlowUrl, automaticFlowUrl: automaticFlowUrl, openedBrowser: openedBrowser, handlerReceivedAutomaticUrl: handlerReceivedAutomaticUrl, automaticFlow: automaticFlow, logs: logs)

class OAuthService:
    codeVerifier: text
    authCodeListener: AuthCodeListener
    hasListener: bool
    port: i64
    manualAuthCodeResolverReady: bool
    manualAuthorizationCode: text
    cleanedUp: bool

impl OAuthService:
    static fn new() -> OAuthService:
        OAuthService(codeVerifier: generateCodeVerifier(), authCodeListener: AuthCodeListener.new("/callback"), hasListener: false, port: 0, manualAuthCodeResolverReady: false, manualAuthorizationCode: "", cleanedUp: false)

    me startOAuthFlow(options: OAuthFlowOptions, automaticAuthorizationCode: text, tokenResponse: OAuthTokenExchangeResponse, subscriptionType: text, rateLimitTier: text, profile: text) -> OAuthFlowResult:
        me.authCodeListener = AuthCodeListener.new("/callback")
        me.hasListener = true
        me.port = me.authCodeListener.start(0)
        val codeChallenge = generateCodeChallenge(me.codeVerifier)
        val state = generateState()
        val manualFlowUrl = buildAuthUrl(codeChallenge, state, me.port, true, options)
        val automaticFlowUrl = buildAuthUrl(codeChallenge, state, me.port, false, options)
        var openedBrowser = false
        var handlerReceivedAutomaticUrl = false
        if options.skipBrowserOpen:
            handlerReceivedAutomaticUrl = true
        else:
            openedBrowser = true
        val authorizationCode = me.waitForAuthorizationCode(state, automaticAuthorizationCode)
        val automaticFlow = me.authCodeListener.hasPendingResponse()
        var logs: [text] = ["tengu_oauth_auth_code_received:" + automaticFlow.to_text()]
        val tokens = me.formatTokens(tokenResponse, subscriptionType, rateLimitTier, profile)
        if automaticFlow:
            me.authCodeListener.handleSuccessRedirect(parseScopes(tokenResponse.scope), false)
        me.authCodeListener.close()
        me.cleanedUp = true
        logs = appendTextOAuth(logs, me.authCodeListener.logs.join(","))
        OAuthFlowResult.new(tokens, manualFlowUrl, automaticFlowUrl, openedBrowser, handlerReceivedAutomaticUrl, automaticFlow, logs)

    me waitForAuthorizationCode(state: text, automaticAuthorizationCode: text) -> text:
        me.manualAuthCodeResolverReady = true
        me.authCodeListener.waitForAuthorization(state)
        if automaticAuthorizationCode != "":
            val res = AuthCodeResponse.new()
            me.authCodeListener.handleRedirect(AuthCodeRequest.new("/callback?code=" + automaticAuthorizationCode + "&state=" + state, "localhost"), res)
            me.manualAuthCodeResolverReady = false
            return automaticAuthorizationCode
        me.manualAuthorizationCode

    me handleManualAuthCodeInput(authorizationCode: text, state: text) -> ():
        if me.manualAuthCodeResolverReady:
            me.manualAuthorizationCode = authorizationCode
            me.manualAuthCodeResolverReady = false
            if me.hasListener:
                me.authCodeListener.close()

    me formatTokens(response: OAuthTokenExchangeResponse, subscriptionType: text, rateLimitTier: text, profile: text) -> OAuthTokens:
        OAuthTokens.new(response.accessToken, response.refreshToken, nowMs() + (response.expiresIn * 1000), parseScopes(response.scope), subscriptionType, rateLimitTier, profile, response.accountUuid, response.accountEmail, response.organizationUuid)

    me cleanup() -> ():
        if me.hasListener:
            me.authCodeListener.close()
        me.manualAuthCodeResolverReady = false
        me.cleanedUp = true

fn generateCodeVerifier() -> text:
    "verifier"

fn generateCodeChallenge(verifier: text) -> text:
    "challenge:" + verifier

fn generateState() -> text:
    "state"

fn buildAuthUrl(codeChallenge: text, state: text, port: i64, isManual: bool, options: OAuthFlowOptions) -> text:
    var url = "https://oauth.example/authorize?challenge=" + codeChallenge + "&state=" + state + "&port=" + port.to_text()
    if isManual:
        url = url + "&manual=true"
    else:
        url = url + "&manual=false"
    if options.loginWithClaudeAi:
        url = url + "&claude_ai=true"
    if options.inferenceOnly:
        url = url + "&inference_only=true"
    if options.orgUUID != "":
        url = url + "&org=" + options.orgUUID
    if options.loginHint != "":
        url = url + "&login_hint=" + options.loginHint
    if options.loginMethod != "":
        url = url + "&login_method=" + options.loginMethod
    url

fn parseScopes(scope: text) -> [text]:
    var out: [text] = []
    var current = ""
    var i = 0
    while i < scope.len():
        val ch = scope.slice(i, i + 1)
        if ch == " ":
            if current != "":
                out.push(current)
                current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        out.push(current)
    out

fn nowMs() -> i64:
    100000

fn appendTextOAuth(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn oauthServiceSourceLinesModeled() -> i64:
    198
