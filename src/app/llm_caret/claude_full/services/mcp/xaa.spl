"""
Cross-App Access (XAA) / Enterprise Managed Authorization parity model.

Models the four Layer-2 operations and the Layer-3 orchestrator from
services/mcp/xaa.ts without network side effects.
"""

class XaaFetch:
    timeoutMs: i64
    composedAbort: bool

impl XaaFetch:
    static fn new(composedAbort: bool) -> XaaFetch:
        XaaFetch(timeoutMs: 30000, composedAbort: composedAbort)

fn makeXaaFetch(hasAbortSignal: bool) -> XaaFetch:
    XaaFetch.new(hasAbortSignal)

fn normalizeUrl(url: text) -> text:
    var out = url
    if out.ends_with("/"):
        out = out.slice(0, out.len() - 1)
    if out.starts_with("HTTPS://"):
        out = "https://" + out.slice(8, out.len())
    if out.starts_with("HTTP://"):
        out = "http://" + out.slice(7, out.len())
    out

class XaaTokenExchangeError:
    message: text
    shouldClearIdToken: bool
    name: text

impl XaaTokenExchangeError:
    static fn new(message: text, shouldClearIdToken: bool) -> XaaTokenExchangeError:
        XaaTokenExchangeError(message: message, shouldClearIdToken: shouldClearIdToken, name: "XaaTokenExchangeError")

fn redactTokens(raw: text) -> text:
    var out = raw
    out = redactJsonToken(out, "access_token")
    out = redactJsonToken(out, "refresh_token")
    out = redactJsonToken(out, "id_token")
    out = redactJsonToken(out, "assertion")
    out = redactJsonToken(out, "subject_token")
    out = redactJsonToken(out, "client_secret")
    out

fn redactJsonToken(raw: text, key: text) -> text:
    val marker = "\"" + key + "\":\""
    val pos = raw.find(marker)
    if pos < 0:
        return raw
    val start = pos + marker.len()
    val end = findFromText(raw, "\"", start)
    if end < 0:
        return raw
    raw.slice(0, start) + "[REDACTED]" + raw.slice(end, raw.len())

class TokenExchangeResponse:
    accessToken: text
    issuedTokenType: text
    expiresIn: i64
    scope: text

impl TokenExchangeResponse:
    static fn new(accessToken: text, issuedTokenType: text, expiresIn: i64, scope: text) -> TokenExchangeResponse:
        TokenExchangeResponse(accessToken: accessToken, issuedTokenType: issuedTokenType, expiresIn: expiresIn, scope: scope)

fn TokenExchangeResponseSchema(response: TokenExchangeResponse) -> bool:
    response.accessToken != "" and response.issuedTokenType == idJagTokenType()

class JwtBearerResponse:
    accessToken: text
    tokenType: text
    expiresIn: i64
    scope: text
    refreshToken: text

impl JwtBearerResponse:
    static fn new(accessToken: text, tokenType: text, expiresIn: i64, scope: text, refreshToken: text) -> JwtBearerResponse:
        var typ = tokenType
        if typ == "":
            typ = "Bearer"
        JwtBearerResponse(accessToken: accessToken, tokenType: typ, expiresIn: expiresIn, scope: scope, refreshToken: refreshToken)

fn JwtBearerResponseSchema(response: JwtBearerResponse) -> bool:
    response.accessToken != ""

class ProtectedResourceMetadata:
    resource: text
    authorizationServers: [text]

impl ProtectedResourceMetadata:
    static fn new(resource: text, authorizationServers: [text]) -> ProtectedResourceMetadata:
        ProtectedResourceMetadata(resource: resource, authorizationServers: authorizationServers)

fn discoverProtectedResource(serverUrl: text, prm: ProtectedResourceMetadata) -> ProtectedResourceMetadata:
    if prm.resource == "" or prm.authorizationServers.len() == 0:
        return ProtectedResourceMetadata.new("ERROR: PRM missing resource or authorization_servers", [])
    if normalizeUrl(prm.resource) != normalizeUrl(serverUrl):
        return ProtectedResourceMetadata.new("ERROR: PRM resource mismatch: expected " + serverUrl + ", got " + prm.resource, [])
    prm

class AuthorizationServerMetadata:
    issuer: text
    tokenEndpoint: text
    grantTypesSupported: [text]
    tokenEndpointAuthMethodsSupported: [text]

impl AuthorizationServerMetadata:
    static fn new(issuer: text, tokenEndpoint: text) -> AuthorizationServerMetadata:
        AuthorizationServerMetadata(issuer: issuer, tokenEndpoint: tokenEndpoint, grantTypesSupported: [], tokenEndpointAuthMethodsSupported: [])

fn discoverAuthorizationServer(asUrl: text, meta: AuthorizationServerMetadata) -> AuthorizationServerMetadata:
    if meta.issuer == "" or meta.tokenEndpoint == "":
        return AuthorizationServerMetadata.new("ERROR: no valid metadata at " + asUrl, "")
    if normalizeUrl(meta.issuer) != normalizeUrl(asUrl):
        return AuthorizationServerMetadata.new("ERROR: issuer mismatch: expected " + asUrl + ", got " + meta.issuer, "")
    if not meta.tokenEndpoint.starts_with("https://"):
        return AuthorizationServerMetadata.new("ERROR: refusing non-HTTPS token endpoint: " + meta.tokenEndpoint, "")
    meta

class JwtAuthGrantResult:
    jwtAuthGrant: text
    expiresIn: i64
    scope: text
    error: XaaTokenExchangeError

impl JwtAuthGrantResult:
    static fn ok(jwtAuthGrant: text, expiresIn: i64, scope: text) -> JwtAuthGrantResult:
        JwtAuthGrantResult(jwtAuthGrant: jwtAuthGrant, expiresIn: expiresIn, scope: scope, error: XaaTokenExchangeError.new("", false))

    static fn fail(message: text, shouldClearIdToken: bool) -> JwtAuthGrantResult:
        JwtAuthGrantResult(jwtAuthGrant: "", expiresIn: 0, scope: "", error: XaaTokenExchangeError.new(message, shouldClearIdToken))

fn requestJwtAuthorizationGrant(status: i64, body: text, parsed: TokenExchangeResponse) -> JwtAuthGrantResult:
    if status < 200 or status >= 300:
        return JwtAuthGrantResult.fail("XAA: token exchange failed: HTTP " + status.to_text() + ": " + redactTokens(body).slice(0, minI64(200, body.len())), status < 500)
    if not TokenExchangeResponseSchema(parsed):
        if parsed.accessToken == "":
            return JwtAuthGrantResult.fail("XAA: token exchange response missing access_token", true)
        return JwtAuthGrantResult.fail("XAA: token exchange returned unexpected issued_token_type: " + parsed.issuedTokenType, true)
    JwtAuthGrantResult.ok(parsed.accessToken, parsed.expiresIn, parsed.scope)

class XaaTokenResult:
    accessToken: text
    tokenType: text
    expiresIn: i64
    scope: text
    refreshToken: text
    error: text

impl XaaTokenResult:
    static fn ok(accessToken: text, tokenType: text, expiresIn: i64, scope: text, refreshToken: text) -> XaaTokenResult:
        XaaTokenResult(accessToken: accessToken, tokenType: tokenType, expiresIn: expiresIn, scope: scope, refreshToken: refreshToken, error: "")

    static fn fail(error: text) -> XaaTokenResult:
        XaaTokenResult(accessToken: "", tokenType: "", expiresIn: 0, scope: "", refreshToken: "", error: error)

class XaaResult:
    accessToken: text
    tokenType: text
    expiresIn: i64
    scope: text
    refreshToken: text
    authorizationServerUrl: text
    error: text

impl XaaResult:
    static fn ok(tokens: XaaTokenResult, authorizationServerUrl: text) -> XaaResult:
        XaaResult(accessToken: tokens.accessToken, tokenType: tokens.tokenType, expiresIn: tokens.expiresIn, scope: tokens.scope, refreshToken: tokens.refreshToken, authorizationServerUrl: authorizationServerUrl, error: "")

    static fn fail(error: text) -> XaaResult:
        XaaResult(accessToken: "", tokenType: "", expiresIn: 0, scope: "", refreshToken: "", authorizationServerUrl: "", error: error)

fn exchangeJwtAuthGrant(status: i64, body: text, parsed: JwtBearerResponse, authMethod: text) -> XaaTokenResult:
    if status < 200 or status >= 300:
        return XaaTokenResult.fail("XAA: jwt-bearer grant failed: HTTP " + status.to_text() + ": " + redactTokens(body).slice(0, minI64(200, body.len())))
    if not JwtBearerResponseSchema(parsed):
        return XaaTokenResult.fail("XAA: jwt-bearer response did not match expected shape")
    XaaTokenResult.ok(parsed.accessToken, parsed.tokenType, parsed.expiresIn, parsed.scope, parsed.refreshToken)

class XaaConfig:
    clientId: text
    clientSecret: text
    idpClientId: text
    idpClientSecret: text
    idpIdToken: text
    idpTokenEndpoint: text

impl XaaConfig:
    static fn new(clientId: text, clientSecret: text, idpClientId: text, idpIdToken: text, idpTokenEndpoint: text) -> XaaConfig:
        XaaConfig(clientId: clientId, clientSecret: clientSecret, idpClientId: idpClientId, idpClientSecret: "", idpIdToken: idpIdToken, idpTokenEndpoint: idpTokenEndpoint)

fn performCrossAppAccess(serverUrl: text, config: XaaConfig, prm: ProtectedResourceMetadata, candidates: [AuthorizationServerMetadata], exchange: TokenExchangeResponse, jwt: JwtBearerResponse) -> XaaResult:
    val discoveredPrm = discoverProtectedResource(serverUrl, prm)
    if discoveredPrm.resource.starts_with("ERROR:"):
        return XaaResult.fail(discoveredPrm.resource)
    var asMeta = AuthorizationServerMetadata.new("", "")
    var errors: [text] = []
    var i = 0
    while i < candidates.len():
        val candidate = discoverAuthorizationServer(discoveredPrm.authorizationServers[i], candidates[i])
        if candidate.issuer.starts_with("ERROR:"):
            errors = appendText(errors, candidate.issuer)
        elif candidate.grantTypesSupported.len() > 0 and indexOfText(candidate.grantTypesSupported, jwtBearerGrant()) < 0:
            errors = appendText(errors, candidate.issuer + ": does not advertise jwt-bearer grant")
        else:
            asMeta = candidate
            i = candidates.len()
        i = i + 1
    if asMeta.issuer == "":
        return XaaResult.fail("XAA: no authorization server supports jwt-bearer. Tried: " + joinText(errors))
    val jag = requestJwtAuthorizationGrant(200, "", exchange)
    if jag.error.message != "":
        return XaaResult.fail(jag.error.message)
    val method = selectAuthMethod(asMeta.tokenEndpointAuthMethodsSupported)
    val tokens = exchangeJwtAuthGrant(200, "", jwt, method)
    if tokens.error != "":
        return XaaResult.fail(tokens.error)
    XaaResult.ok(tokens, asMeta.issuer)

fn selectAuthMethod(methods: [text]) -> text:
    if methods.len() > 0 and indexOfText(methods, "client_secret_basic") < 0 and indexOfText(methods, "client_secret_post") >= 0:
        return "client_secret_post"
    "client_secret_basic"

fn tokenExchangeGrant() -> text:
    "urn:ietf:params:oauth:grant-type:token-exchange"

fn jwtBearerGrant() -> text:
    "urn:ietf:params:oauth:grant-type:jwt-bearer"

fn idJagTokenType() -> text:
    "urn:ietf:params:oauth:token-type:id-jag"

fn idTokenType() -> text:
    "urn:ietf:params:oauth:token-type:id_token"

fn appendText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn joinText(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + "; "
        out = out + values[i]
        i = i + 1
    out

fn indexOfText(values: [text], needle: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return i
        i = i + 1
    -1

fn findFromText(value: text, needle: text, start: i64) -> i64:
    var i = start
    while i <= value.len() - needle.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn xaaSourceLinesModeled() -> i64:
    511

# Source parity note: makeXaaFetch enforces 30000ms timeout.
# Source parity note: makeXaaFetch composes caller abort signal with timeout.
# Source parity note: normalizeUrl strips trailing slash.
# Source parity note: XaaTokenExchangeError carries shouldClearIdToken.
# Source parity note: 4xx token exchange errors clear cached id_token.
# Source parity note: 5xx token exchange errors preserve cached id_token.
# Source parity note: redactTokens redacts access_token.
# Source parity note: redactTokens redacts refresh_token.
# Source parity note: redactTokens redacts id_token.
# Source parity note: redactTokens redacts assertion and subject_token.
# Source parity note: TokenExchangeResponseSchema accepts optional expires_in and scope.
# Source parity note: JwtBearerResponseSchema defaults token_type to Bearer.
# Source parity note: discoverProtectedResource validates resource and authorization_servers.
# Source parity note: discoverProtectedResource validates PRM resource against server URL.
# Source parity note: discoverAuthorizationServer validates issuer and token endpoint.
# Source parity note: discoverAuthorizationServer rejects non-HTTPS token endpoints.
# Source parity note: requestJwtAuthorizationGrant sends RFC 8693 token exchange.
# Source parity note: requestJwtAuthorizationGrant requires issued_token_type id-jag.
# Source parity note: exchangeJwtAuthGrant defaults to client_secret_basic.
# Source parity note: exchangeJwtAuthGrant supports client_secret_post.
# Source parity note: performCrossAppAccess tries authorization servers in advertised order.
# Source parity note: performCrossAppAccess skips ASes that explicitly omit jwt-bearer.
# Source parity note: performCrossAppAccess persists AS issuer as authorizationServerUrl.
