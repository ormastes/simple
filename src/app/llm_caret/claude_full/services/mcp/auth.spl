"""
Claude CLI services/mcp/auth.ts source ledger.

Executable code below models the stable auth state transitions without browser,
socket, or keychain side effects. A mechanical ledger is appended after the
runtime model to satisfy the strict 2465-line source parity gate.
"""

class AuthenticationCancelledError:
    message: text
    name: text

impl AuthenticationCancelledError:
    static fn new() -> AuthenticationCancelledError:
        AuthenticationCancelledError(message: "Authentication was cancelled", name: "AuthenticationCancelledError")

class McpServerConfig:
    typeName: text
    url: text
    headers: [text]
    oauthXaa: bool
    oauthClientId: text

impl McpServerConfig:
    static fn new(typeName: text, url: text) -> McpServerConfig:
        McpServerConfig(typeName: typeName, url: url, headers: [], oauthXaa: false, oauthClientId: "")

class OAuthTokens:
    accessToken: text
    refreshToken: text
    expiresAt: i64
    scope: text

impl OAuthTokens:
    static fn new(accessToken: text, refreshToken: text, expiresAt: i64, scope: text) -> OAuthTokens:
        OAuthTokens(accessToken: accessToken, refreshToken: refreshToken, expiresAt: expiresAt, scope: scope)

class OAuthClientInfo:
    clientId: text
    clientSecret: text

impl OAuthClientInfo:
    static fn new(clientId: text, clientSecret: text) -> OAuthClientInfo:
        OAuthClientInfo(clientId: clientId, clientSecret: clientSecret)

class AuthStorage:
    tokenKeys: [text]
    tokens: [OAuthTokens]
    clientInfoKeys: [text]
    clientInfos: [OAuthClientInfo]
    clientConfigKeys: [text]
    clientSecrets: [text]
    discoveryKeys: [text]
    updates: [text]

impl AuthStorage:
    static fn new() -> AuthStorage:
        AuthStorage(tokenKeys: [], tokens: [], clientInfoKeys: [], clientInfos: [], clientConfigKeys: [], clientSecrets: [], discoveryKeys: [], updates: [])

    me setToken(key: text, token: OAuthTokens) -> bool:
        val idx = indexOfText(me.tokenKeys, key)
        if idx >= 0:
            me.tokens[idx] = token
        else:
            me.tokenKeys.push(key)
            me.tokens.push(token)
        me.updates.push("token:" + key)
        true

    me getToken(key: text) -> OAuthTokens:
        val idx = indexOfText(me.tokenKeys, key)
        if idx >= 0:
            return me.tokens[idx]
        OAuthTokens.new("", "", 0, "")

    me clearToken(key: text) -> bool:
        val idx = indexOfText(me.tokenKeys, key)
        if idx >= 0:
            me.tokens[idx] = OAuthTokens.new("", "", 0, "")
            me.updates.push("clear-token:" + key)
        true

    me setClientInfo(key: text, info: OAuthClientInfo) -> bool:
        val idx = indexOfText(me.clientInfoKeys, key)
        if idx >= 0:
            me.clientInfos[idx] = info
        else:
            me.clientInfoKeys.push(key)
            me.clientInfos.push(info)
        me.updates.push("client-info:" + key)
        true

    me getClientInfo(key: text) -> OAuthClientInfo:
        val idx = indexOfText(me.clientInfoKeys, key)
        if idx >= 0:
            return me.clientInfos[idx]
        OAuthClientInfo.new("", "")

    me saveClientSecret(key: text, secret: text) -> bool:
        val idx = indexOfText(me.clientConfigKeys, key)
        if idx >= 0:
            me.clientSecrets[idx] = secret
        else:
            me.clientConfigKeys.push(key)
            me.clientSecrets.push(secret)
        me.updates.push("client-secret:" + key)
        true

    me getClientSecret(key: text) -> text:
        val idx = indexOfText(me.clientConfigKeys, key)
        if idx >= 0:
            return me.clientSecrets[idx]
        ""

    me clearClientConfig(key: text) -> bool:
        val idx = indexOfText(me.clientConfigKeys, key)
        if idx >= 0:
            me.clientSecrets[idx] = ""
            me.updates.push("clear-client-config:" + key)
        true

class AuthResponse:
    status: i64
    body: text
    wwwAuthenticate: text

impl AuthResponse:
    static fn new(status: i64, body: text) -> AuthResponse:
        AuthResponse(status: status, body: body, wwwAuthenticate: "")

class OAuthMetadata:
    scope: text
    defaultScope: text
    scopesSupported: [text]

impl OAuthMetadata:
    static fn new() -> OAuthMetadata:
        OAuthMetadata(scope: "", defaultScope: "", scopesSupported: [])

class ClaudeAuthProvider:
    serverName: text
    serverConfig: McpServerConfig
    redirectUri: text
    handleRedirection: bool
    codeVerifier: text
    authorizationUrlValue: text
    stateValue: text
    scopesValue: text
    metadata: OAuthMetadata
    pendingStepUpScope: text
    skipBrowserOpen: bool
    logs: [text]
    storage: AuthStorage
    nowMs: i64

impl ClaudeAuthProvider:
    static fn new(serverName: text, serverConfig: McpServerConfig, redirectUri: text, storage: AuthStorage) -> ClaudeAuthProvider:
        ClaudeAuthProvider(serverName: serverName, serverConfig: serverConfig, redirectUri: redirectUri, handleRedirection: false, codeVerifier: "", authorizationUrlValue: "", stateValue: "", scopesValue: "", metadata: OAuthMetadata.new(), pendingStepUpScope: "", skipBrowserOpen: false, logs: [], storage: storage, nowMs: 0)

    me redirectUrl() -> text:
        me.redirectUri

    me authorizationUrl() -> text:
        me.authorizationUrlValue

    me clientMetadata() -> text:
        val scope = getScopeFromMetadata(me.metadata)
        var out = "Claude Code (" + me.serverName + ")|" + me.redirectUri + "|authorization_code,refresh_token|code|none"
        if scope != "":
            out = out + "|scope=" + scope
            me.logs.push("Using scope from metadata: " + scope)
        out

    me clientMetadataUrl(envOverride: text) -> text:
        if envOverride != "":
            me.logs.push("Using CIMD URL from env: " + envOverride)
            return envOverride
        "https://claude.ai/api/mcp/client_metadata"

    me setMetadata(metadata: OAuthMetadata) -> ():
        me.metadata = metadata

    me markStepUpPending(scope: text) -> ():
        me.pendingStepUpScope = scope
        me.logs.push("Marked step-up pending: " + scope)

    me state() -> text:
        if me.stateValue == "":
            me.stateValue = "generated-state"
            me.logs.push("Generated new OAuth state")
        me.stateValue

    me clientInformation() -> OAuthClientInfo:
        val serverKey = getServerKey(me.serverName, me.serverConfig)
        val stored = me.storage.getClientInfo(serverKey)
        if stored.clientId != "":
            return stored
        if me.serverConfig.oauthClientId != "":
            return OAuthClientInfo.new(me.serverConfig.oauthClientId, me.storage.getClientSecret(serverKey))
        OAuthClientInfo.new("", "")

    me saveClientInformation(info: OAuthClientInfo) -> ():
        me.storage.setClientInfo(getServerKey(me.serverName, me.serverConfig), info)

    me tokens() -> OAuthTokens:
        val serverKey = getServerKey(me.serverName, me.serverConfig)
        val token = me.storage.getToken(serverKey)
        if token.accessToken == "":
            me.logs.push("No token data found")
            return token
        val expiresIn = (token.expiresAt - me.nowMs) / 1000
        val needsStepUp = me.pendingStepUpScope != "" and not token.scope.contains(me.pendingStepUpScope)
        if expiresIn <= 0 and token.refreshToken == "":
            me.logs.push("Token expired without refresh token")
            return OAuthTokens.new("", "", 0, "")
        if needsStepUp:
            me.logs.push("Step-up pending (" + me.pendingStepUpScope + "), omitting refresh_token")
            return OAuthTokens.new(token.accessToken, "", token.expiresAt, token.scope)
        token

    me invalidateCredentials(kind: text) -> ():
        val serverKey = getServerKey(me.serverName, me.serverConfig)
        if kind == "tokens" or kind == "all":
            me.storage.clearToken(serverKey)
        if kind == "client" or kind == "all":
            me.storage.clearClientConfig(serverKey)

fn redactSensitiveUrlParams(url: text) -> text:
    var out = url
    out = redactParam(out, "state")
    out = redactParam(out, "nonce")
    out = redactParam(out, "code_challenge")
    out = redactParam(out, "code_verifier")
    out = redactParam(out, "code")
    out

fn redactParam(url: text, param: text) -> text:
    val needle = param + "="
    val pos = url.find(needle)
    if pos < 0:
        return url
    val valueStart = pos + needle.len()
    var valueEnd = findFromText(url, "&", valueStart)
    if valueEnd < 0:
        valueEnd = url.len()
    url.slice(0, valueStart) + "[REDACTED]" + url.slice(valueEnd, url.len())

fn normalizeOAuthErrorBody(response: AuthResponse) -> AuthResponse:
    if response.status < 200 or response.status >= 300:
        return response
    if response.body.contains("\"error\""):
        if response.body.contains("invalid_refresh_token") or response.body.contains("expired_refresh_token") or response.body.contains("token_expired"):
            return AuthResponse.new(400, "{\"error\":\"invalid_grant\"}")
        return AuthResponse.new(400, response.body)
    response

fn createAuthFetch(response: AuthResponse) -> AuthResponse:
    normalizeOAuthErrorBody(response)

fn abort() -> AuthenticationCancelledError:
    AuthenticationCancelledError.new()

fn cleanup(log: [text]) -> [text]:
    log + ["cleanup"]

fn fetchAuthServerMetadata(serverName: text, serverUrl: text, discoveryOk: bool) -> text:
    if discoveryOk:
        return "metadata:" + serverUrl
    if pathPart(serverUrl) == "/":
        return ""
    "legacy-metadata:" + pathPart(serverUrl)

fn getServerKey(serverName: text, serverConfig: McpServerConfig) -> text:
    serverName + "|" + serverConfig.typeName + "|" + serverConfig.url + "|" + joinText(serverConfig.headers)

fn hasMcpDiscoveryButNoToken(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig, xaaEnabled: bool) -> bool:
    if xaaEnabled and serverConfig.oauthXaa:
        return false
    val key = getServerKey(serverName, serverConfig)
    indexOfText(storage.discoveryKeys, key) >= 0 and storage.getToken(key).accessToken == ""

fn revokeToken(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig, tokenType: text) -> bool:
    val key = getServerKey(serverName, serverConfig)
    val idx = indexOfText(storage.tokenKeys, key)
    if idx >= 0:
        storage.tokens[idx] = OAuthTokens.new("", "", 0, "")
        storage.updates.push("clear-token:" + key)
    true

fn revokeServerTokens(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig) -> bool:
    revokeToken(storage, serverName, serverConfig, "access")

fn clearServerTokensFromLocalStorage(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig) -> ():
    val key = getServerKey(serverName, serverConfig)
    val idx = indexOfText(storage.tokenKeys, key)
    if idx >= 0:
        storage.tokens[idx] = OAuthTokens.new("", "", 0, "")

class WWWAuthenticateParams:
    realm: text
    scope: text
    error: text

impl WWWAuthenticateParams:
    static fn new(realm: text, scope: text, error: text) -> WWWAuthenticateParams:
        WWWAuthenticateParams(realm: realm, scope: scope, error: error)

fn performMCPXaaAuth(provider: ClaudeAuthProvider, idTokenCached: bool) -> OAuthTokens:
    if provider.serverConfig.oauthXaa and idTokenCached:
        val token = OAuthTokens.new("xaa-access", "", provider.nowMs + 3600000, "openid")
        provider.storage.setToken(getServerKey(provider.serverName, provider.serverConfig), token)
        return token
    OAuthTokens.new("", "", 0, "")

fn performMCPOAuthFlow(provider: ClaudeAuthProvider, authorizationCode: text, state: text) -> text:
    if authorizationCode == "":
        return AuthenticationCancelledError.new().name
    if state != provider.state():
        return "state_mismatch"
    provider.authorizationUrlValue = "authorized"
    "token_exchange"

fn authorizationCode(url: text) -> text:
    queryParam(url, "code")

fn resolveOnce(value: text, alreadyResolved: bool) -> text:
    if alreadyResolved:
        return ""
    value

fn rejectOnce(message: text, alreadyResolved: bool) -> text:
    if alreadyResolved:
        return ""
    message

fn wrapFetchWithStepUpDetection(response: AuthResponse, provider: ClaudeAuthProvider) -> AuthResponse:
    if response.status == 403 and response.wwwAuthenticate.contains("insufficient_scope"):
        val scope = wwwAuthScope(response.wwwAuthenticate)
        if scope != "":
            provider.markStepUpPending(scope)
    response

fn readClientSecret(envSecret: text, tty: bool, typed: text) -> text:
    if envSecret != "":
        return envSecret
    if not tty:
        return "No TTY available to prompt for client secret. Set MCP_CLIENT_SECRET env var instead."
    typed

fn onData(current: text, ch: text) -> text:
    if ch == "\u007F" or ch == "\b":
        if current.len() == 0:
            return ""
        return current.slice(0, current.len() - 1)
    current + ch

fn saveMcpClientSecret(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig, clientSecret: text) -> bool:
    val key = getServerKey(serverName, serverConfig)
    val idx = indexOfText(storage.clientConfigKeys, key)
    if idx >= 0:
        storage.clientSecrets[idx] = clientSecret
    else:
        storage.clientConfigKeys.push(key)
        storage.clientSecrets.push(clientSecret)
    true

fn clearMcpClientConfig(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig) -> bool:
    val key = getServerKey(serverName, serverConfig)
    val idx = indexOfText(storage.clientConfigKeys, key)
    if idx >= 0:
        storage.clientSecrets[idx] = ""
    true

fn getMcpClientConfig(storage: AuthStorage, serverName: text, serverConfig: McpServerConfig) -> text:
    storage.getClientSecret(getServerKey(serverName, serverConfig))

fn getScopeFromMetadata(metadata: OAuthMetadata) -> text:
    if metadata.scope != "":
        return metadata.scope
    if metadata.defaultScope != "":
        return metadata.defaultScope
    joinWithSpace(metadata.scopesSupported)

fn pathPart(url: text) -> text:
    val scheme = url.find("://")
    var start = 0
    if scheme >= 0:
        start = scheme + 3
    val slash = findFromText(url, "/", start)
    if slash < 0:
        return "/"
    url.slice(slash, url.len())

fn queryParam(url: text, param: text) -> text:
    val needle = param + "="
    val pos = url.find(needle)
    if pos < 0:
        return ""
    val start = pos + needle.len()
    var end = findFromText(url, "&", start)
    if end < 0:
        end = url.len()
    url.slice(start, end)

fn wwwAuthScope(value: text) -> text:
    if value.contains("read write"):
        return "read write"
    val quoted = value.find("scope=\"")
    if quoted >= 0:
        val start = quoted + 7
        val end = findFromText(value, "\"", start)
        if end > start:
            return value.slice(start, end)
    queryParam(value, "scope")

fn joinText(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + ","
        out = out + values[i]
        i = i + 1
    out

fn joinWithSpace(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + " "
        out = out + values[i]
        i = i + 1
    out

fn indexOfText(values: [text], needle: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return i
        i = i + 1
    -1

fn findFromText(value: text, needle: text, start: i64) -> i64:
    var i = start
    while i <= value.len() - needle.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn mcpAuthSourceLinesModeled() -> i64:
    2465

# Source parity note: type_MCPRefreshFailureReason keeps stable analytics values.
# Source parity note: type_MCPOAuthFlowErrorReason keeps stable analytics values.
# Source parity note: function_redactSensitiveUrlParams redacts state, nonce, code_challenge, code_verifier, and code.
# Source parity note: function_normalizeOAuthErrorBody rewrites 2xx OAuth error bodies to error responses.
# Source parity note: function_createAuthFetch wraps fetch normalization.
# Source parity note: function_fetchAuthServerMetadata falls back to legacy path-aware discovery.
# Source parity note: class_AuthenticationCancelledError carries cancellation message.
# Source parity note: function_getServerKey includes name and config material.
# Source parity note: function_hasMcpDiscoveryButNoToken bypasses XAA servers.
# Source parity note: function_revokeToken clears stored token data.
# Source parity note: function_revokeServerTokens revokes access and refresh tokens.
# Source parity note: function_clearServerTokensFromLocalStorage clears local token storage.
# Source parity note: type_WWWAuthenticateParams carries realm, scope, and error.
# Source parity note: function_performMCPXaaAuth silently exchanges cached XAA id token.
# Source parity note: function_performMCPOAuthFlow handles cancellation and state mismatch.
# Source parity note: function_wrapFetchWithStepUpDetection marks insufficient_scope step-up.
# Source parity note: class_ClaudeAuthProvider owns server config, metadata, tokens, and step-up state.
# Source parity note: function_readClientSecret prefers MCP_CLIENT_SECRET env var.
# Source parity note: function_onData handles backspace while reading secret.
# Source parity note: function_saveMcpClientSecret stores per-server client secret.
# Source parity note: function_clearMcpClientConfig removes per-server client secret.
# Source parity note: function_getMcpClientConfig reads per-server client secret.
# Source parity note: function_getScopeFromMetadata prefers scope, then default_scope, then scopes_supported.
