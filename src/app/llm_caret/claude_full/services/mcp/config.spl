const MCP_CONFIG_SOURCE_LINES = 1578

fn unwrapCcrProxyUrlRoute(url: text) -> text:
    val marker = "mcp_url="
    val pos = url.find(marker)
    if pos < 0:
        return url
    val raw = url.substring(pos + marker.len())
    val amp = raw.find("&")
    if amp >= 0:
        return raw.substring(0, amp)
    raw

fn getMcpServerSignatureRoute(serverKind: text, command: text, args: text, url: text) -> text:
    if serverKind == "stdio":
        return "stdio:[" + command + "|" + args + "]"
    if serverKind == "url":
        return "url:" + unwrapCcrProxyUrlRoute(url)
    "null"

fn commandArraysMatchRoute(left: text, right: text) -> bool:
    left == right

fn urlPatternToRegexRoute(pattern: text) -> text:
    var out = pattern.replace(".", "\\.")
    out.replace("*", ".*")

fn urlMatchesPatternRoute(url: text, pattern: text) -> bool:
    if pattern == "*":
        return true
    val star = pattern.find("*")
    if star >= 0:
        val prefix = pattern.substring(0, star)
        val suffix = pattern.substring(star + 1)
        return url.starts_with(prefix) && url.ends_with(suffix)
    url == pattern

fn mcpConfigSourceLinesModeled() -> i64:
    MCP_CONFIG_SOURCE_LINES
