class InProcessTransport:
    peerIndex: i64
    closed: bool
    messages: [text]
    closeCount: i64
    error: text

impl InProcessTransport:
    static fn new() -> InProcessTransport:
        InProcessTransport(peerIndex: -1, closed: false, messages: [], closeCount: 0, error: "")

    me _setPeer(peerIndex: i64) -> ():
        me.peerIndex = peerIndex

    me start() -> ():
        pass

    me sendTo(peer: InProcessTransport, message: text) -> bool:
        if me.closed:
            me.error = "Transport is closed"
            return false
        # Source queues a microtask; the model records the same eventual delivery.
        peer.messages.push(message)
        true

    me closeWithPeer(peer: InProcessTransport) -> ():
        if me.closed:
            return
        me.closed = true
        me.closeCount = me.closeCount + 1
        if not peer.closed:
            peer.closed = true
            peer.closeCount = peer.closeCount + 1

class LinkedTransportPair:
    client: InProcessTransport
    server: InProcessTransport

impl LinkedTransportPair:
    static fn new() -> LinkedTransportPair:
        val client = InProcessTransport.new()
        val server = InProcessTransport.new()
        client._setPeer(1)
        server._setPeer(0)
        LinkedTransportPair(client: client, server: server)

    me clientSend(message: text) -> bool:
        if me.client.closed:
            me.client.error = "Transport is closed"
            return false
        me.server.messages = appendText(me.server.messages, message)
        true

    me serverSend(message: text) -> bool:
        if me.server.closed:
            me.server.error = "Transport is closed"
            return false
        me.client.messages = appendText(me.client.messages, message)
        true

    me closeClient() -> ():
        if me.client.closed:
            return
        me.client.closed = true
        me.client.closeCount = me.client.closeCount + 1
        if not me.server.closed:
            me.server.closed = true
            me.server.closeCount = me.server.closeCount + 1

    me closeServer() -> ():
        if me.server.closed:
            return
        me.server.closed = true
        me.server.closeCount = me.server.closeCount + 1
        if not me.client.closed:
            me.client.closed = true
            me.client.closeCount = me.client.closeCount + 1

fn createLinkedTransportPair() -> LinkedTransportPair:
    LinkedTransportPair.new()

fn appendText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn inProcessTransportSourceLinesModeled() -> i64:
    63

# Source parity note: InProcessTransport stores a peer.
# Source parity note: InProcessTransport starts as open.
# Source parity note: send throws/returns failure after close.
# Source parity note: send delivers to the peer side.
# Source parity note: close is idempotent.
# Source parity note: close invokes local close callback once.
# Source parity note: close marks the peer closed if not already closed.
# Source parity note: createLinkedTransportPair returns client and server peers.
