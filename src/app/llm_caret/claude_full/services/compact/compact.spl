const COMPACT_SERVICE_SOURCE_LINES = 1705

fn buildPostCompactMessagesRoute(hasBoundary: bool, summaryCount: i64, keptCount: i64, attachmentCount: i64, hasHooks: bool) -> text:
    var out = ""
    if hasBoundary:
        out = out + "boundary"
    if summaryCount > 0:
        out = appendCompactPart(out, "summaries")
    if keptCount > 0:
        out = appendCompactPart(out, "kept")
    if attachmentCount > 0:
        out = appendCompactPart(out, "attachments")
    if hasHooks:
        out = appendCompactPart(out, "hooks")
    out

fn appendCompactPart(existing: text, part: text) -> text:
    if existing == "":
        return part
    existing + " -> " + part

fn annotateBoundaryWithPreservedSegmentRoute(boundary: text, headUuid: text, anchorUuid: text, tailUuid: text) -> text:
    if headUuid == "" && anchorUuid == "" && tailUuid == "":
        return boundary
    boundary + " headUuid=" + headUuid + " anchorUuid=" + anchorUuid + " tailUuid=" + tailUuid

fn mergeHookInstructionsRoute(userInstructions: text, hookInstructions: text) -> text:
    if userInstructions == "":
        return hookInstructions
    if hookInstructions == "":
        return userInstructions
    userInstructions + "\n\n" + hookInstructions

fn stripImagesFromMessagesRoute(messageKind: text, hasTopLevelMedia: bool, hasNestedToolMedia: bool) -> text:
    if messageKind != "user":
        return "unchanged"
    if hasTopLevelMedia && hasNestedToolMedia:
        return "user media stripped nested media stripped"
    if hasTopLevelMedia:
        return "user media stripped"
    if hasNestedToolMedia:
        return "nested media stripped"
    "unchanged"

fn stripReinjectedAttachmentsRoute(featureGateOn: bool, attachmentKind: text) -> text:
    if featureGateOn && (attachmentKind == "skill_discovery" || attachmentKind == "skill_listing"):
        return "removed"
    "kept"

fn compactReactiveErrorMessageRoute(kind: text) -> text:
    if kind == "too_few_groups":
        return "Not enough messages to compact"
    if kind == "aborted":
        return "User aborted compaction"
    "Compaction did not produce a complete response"

fn compactServiceSourceLinesModeled() -> i64:
    COMPACT_SERVICE_SOURCE_LINES
