"""
Claude full CostThresholdDialog component parity.
"""

fn costThresholdExceeded(cost: f64, threshold: f64) -> bool:
    cost >= threshold

fn costThresholdMessage(cost: f64, threshold: f64) -> text:
    if costThresholdExceeded(cost, threshold):
        return "Cost threshold reached"
    "Cost below threshold"

fn costThresholdDialogSourceLinesModeled() -> i64:
    49
