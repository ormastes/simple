"""
Claude full FastIcon parity.
"""

fn fastIconName(name: text) -> text:
    val clean = name.trim()
    if clean == "":
        return "spark"
    clean

fn fastIconLabel(name: text, label: text) -> text:
    val clean = label.trim()
    if clean != "":
        return clean
    fastIconName(name)

fn fastIconTone(disabled: bool, active: bool) -> text:
    if disabled:
        return "disabled"
    if active:
        return "active"
    "default"

fn fastIconSourceLinesModeled() -> i64:
    45
