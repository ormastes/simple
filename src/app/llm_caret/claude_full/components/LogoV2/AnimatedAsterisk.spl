"""
Claude full LogoV2 AnimatedAsterisk parity.
"""

fn animatedAsteriskFrame(frame: i64) -> text:
    if frame % 2 == 0:
        return "*"
    "x"

fn animatedAsteriskLabel(active: bool) -> text:
    if active:
        return "animated asterisk"
    "static asterisk"

fn animatedAsteriskSourceLinesModeled() -> i64:
    49
