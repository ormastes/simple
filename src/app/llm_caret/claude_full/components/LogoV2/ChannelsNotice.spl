"""
Claude full LogoV2 ChannelsNotice component parity surface.
"""

class ChannelsNoticeAction:
    id: text
    label: text
    description: text
    role: text
    enabled: bool
    selected: bool

impl ChannelsNoticeAction:
    static fn new(id: text, label: text, description: text, role: text, enabled: bool, selected: bool) -> ChannelsNoticeAction:
        ChannelsNoticeAction(
            id: normalizeChannelsNoticeId(id),
            label: label.trim(),
            description: description.trim(),
            role: normalizeChannelsNoticeRole(role),
            enabled: enabled,
            selected: selected,
        )

    me tone() -> text:
        channelsNoticeActionTone(me)

    me summary() -> text:
        channelsNoticeActionSummary(me)

class ChannelsNoticeState:
    channel_name: text
    stability: text
    tone: text
    visible: bool
    dismissed: bool
    release_notes_href: text
    release_notes_label: text
    active_action_id: text

impl ChannelsNoticeState:
    static fn new(channelName: text, stability: text, tone: text, visible: bool, dismissed: bool, releaseNotesHref: text, releaseNotesLabel: text, activeActionId: text) -> ChannelsNoticeState:
        ChannelsNoticeState(
            channel_name: normalizeChannelsNoticeChannel(channelName),
            stability: normalizeChannelsNoticeStability(stability),
            tone: normalizeChannelsNoticeTone(tone, stability),
            visible: visible,
            dismissed: dismissed,
            release_notes_href: releaseNotesHref.trim(),
            release_notes_label: normalizeChannelsNoticeReleaseNotesLabel(releaseNotesLabel),
            active_action_id: normalizeChannelsNoticeId(activeActionId),
        )

    static fn default() -> ChannelsNoticeState:
        ChannelsNoticeState.new("stable", "stable", "", true, false, "", "", "")

    static fn preview(channelName: text) -> ChannelsNoticeState:
        ChannelsNoticeState.new(channelName, "preview", "", true, false, "", "", "")

    me show() -> ChannelsNoticeState:
        ChannelsNoticeState.new(me.channel_name, me.stability, me.tone, true, false, me.release_notes_href, me.release_notes_label, me.active_action_id)

    me hide() -> ChannelsNoticeState:
        ChannelsNoticeState.new(me.channel_name, me.stability, me.tone, false, me.dismissed, me.release_notes_href, me.release_notes_label, me.active_action_id)

    me dismiss() -> ChannelsNoticeState:
        ChannelsNoticeState.new(me.channel_name, me.stability, me.tone, false, true, me.release_notes_href, me.release_notes_label, "dismiss")

    me withAction(actionId: text) -> ChannelsNoticeState:
        ChannelsNoticeState.new(me.channel_name, me.stability, me.tone, me.visible, me.dismissed, me.release_notes_href, me.release_notes_label, actionId)

    me withChannel(channelName: text, stability: text) -> ChannelsNoticeState:
        ChannelsNoticeState.new(channelName, stability, "", me.visible, false, me.release_notes_href, me.release_notes_label, me.active_action_id)

    me isVisible() -> bool:
        channelsNoticeVisible(me)

    me summary() -> text:
        channelsNoticeSummary(me)

    me render() -> text:
        renderChannelsNotice(me)

fn normalizeChannelsNoticeId(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "":
        return "none"
    clean

fn normalizeChannelsNoticeChannel(value: text) -> text:
    val clean = value.trim()
    if clean == "":
        return "stable"
    clean

fn normalizeChannelsNoticeStability(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "stable" or clean == "ga" or clean == "general":
        return "stable"
    if clean == "preview" or clean == "beta" or clean == "early":
        return "preview"
    if clean == "experimental" or clean == "alpha" or clean == "canary":
        return "experimental"
    if clean == "deprecated" or clean == "legacy":
        return "deprecated"
    "preview"

fn normalizeChannelsNoticeTone(tone: text, stability: text) -> text:
    val clean = tone.trim().lower()
    if clean == "neutral" or clean == "info" or clean == "success" or clean == "warning" or clean == "danger":
        return clean
    val stable = normalizeChannelsNoticeStability(stability)
    if stable == "stable":
        return "success"
    if stable == "preview":
        return "info"
    if stable == "experimental":
        return "warning"
    "danger"

fn normalizeChannelsNoticeRole(role: text) -> text:
    val clean = role.trim().lower()
    if clean == "primary" or clean == "secondary" or clean == "link" or clean == "dismiss":
        return clean
    "secondary"

fn normalizeChannelsNoticeReleaseNotesLabel(label: text) -> text:
    val clean = label.trim()
    if clean == "":
        return "Release notes"
    clean

fn channelsNoticeTitle(state: ChannelsNoticeState) -> text:
    if state.stability == "stable":
        return state.channel_name + " channel"
    state.channel_name + " channel notice"

fn channelsNoticeStabilityLabel(state: ChannelsNoticeState) -> text:
    if state.stability == "stable":
        return "Stable"
    if state.stability == "preview":
        return "Preview"
    if state.stability == "experimental":
        return "Experimental"
    "Deprecated"

fn channelsNoticeToneLabel(state: ChannelsNoticeState) -> text:
    if state.tone == "success":
        return "success"
    if state.tone == "warning":
        return "warning"
    if state.tone == "danger":
        return "danger"
    if state.tone == "neutral":
        return "neutral"
    "info"

fn channelsNoticeVisible(state: ChannelsNoticeState) -> bool:
    state.visible and not state.dismissed

fn channelsNoticeHiddenReason(state: ChannelsNoticeState) -> text:
    if state.dismissed:
        return "dismissed"
    if not state.visible:
        return "hidden"
    "visible"

fn channelsNoticeBody(state: ChannelsNoticeState) -> text:
    if state.stability == "stable":
        return "You are using the stable Claude channel."
    if state.stability == "preview":
        return "This Claude channel can change before the stable release."
    if state.stability == "experimental":
        return "This Claude channel may change quickly and can include unfinished behavior."
    "This Claude channel is deprecated; move to a supported channel when you can."

fn channelsNoticeReleaseNotesHref(state: ChannelsNoticeState) -> text:
    if state.release_notes_href.trim() == "":
        return "https://docs.anthropic.com/en/release-notes/claude-code"
    state.release_notes_href.trim()

fn channelsNoticeReleaseNotesLabel(state: ChannelsNoticeState) -> text:
    state.release_notes_label

fn channelsNoticeHasReleaseNotes(state: ChannelsNoticeState) -> bool:
    channelsNoticeReleaseNotesHref(state) != ""

fn channelsNoticePrimaryLabel(state: ChannelsNoticeState) -> text:
    if state.stability == "deprecated":
        return "Switch channel"
    if state.stability == "stable":
        return "Continue"
    "Use channel"

fn channelsNoticeDismissLabel(state: ChannelsNoticeState) -> text:
    if state.dismissed:
        return "Dismissed"
    "Dismiss"

fn defaultChannelsNoticeActions(state: ChannelsNoticeState) -> [ChannelsNoticeAction]:
    [
        ChannelsNoticeAction.new("continue", channelsNoticePrimaryLabel(state), "Continue with the current channel.", "primary", channelsNoticeVisible(state), state.active_action_id == "continue"),
        ChannelsNoticeAction.new("release-notes", channelsNoticeReleaseNotesLabel(state), "Open the channel release notes.", "link", channelsNoticeVisible(state) and channelsNoticeHasReleaseNotes(state), state.active_action_id == "release-notes"),
        ChannelsNoticeAction.new("dismiss", channelsNoticeDismissLabel(state), "Hide this channel notice.", "dismiss", state.visible, state.active_action_id == "dismiss"),
    ]

fn channelsNoticeActionById(state: ChannelsNoticeState, actionId: text) -> ChannelsNoticeAction?:
    val actions = defaultChannelsNoticeActions(state)
    val id = normalizeChannelsNoticeId(actionId)
    var i = 0
    while i < actions.len():
        if actions[i].id == id:
            return actions[i]
        i = i + 1
    nil

fn channelsNoticeCanRunAction(state: ChannelsNoticeState, actionId: text) -> bool:
    if val Some(action) = channelsNoticeActionById(state, actionId):
        return action.enabled
    false

fn channelsNoticeApplyAction(state: ChannelsNoticeState, actionId: text) -> ChannelsNoticeState:
    val id = normalizeChannelsNoticeId(actionId)
    if id == "dismiss":
        return state.dismiss()
    if channelsNoticeCanRunAction(state, id):
        return state.withAction(id)
    state

fn channelsNoticeActionTone(action: ChannelsNoticeAction) -> text:
    if not action.enabled:
        return "disabled"
    if action.selected:
        return "selected"
    if action.role == "primary":
        return "primary"
    if action.role == "link":
        return "link"
    if action.role == "dismiss":
        return "muted"
    "secondary"

fn channelsNoticeActionSummary(action: ChannelsNoticeAction) -> text:
    val marker = if action.selected: "*" else: "-"
    val enabled = if action.enabled: "enabled" else: "disabled"
    marker + " " + action.label + " [" + action.tone() + ", " + enabled + "] - " + action.description

fn channelsNoticeActionsSummary(state: ChannelsNoticeState) -> [text]:
    val actions = defaultChannelsNoticeActions(state)
    var lines: [text] = []
    var i = 0
    while i < actions.len():
        lines.push(channelsNoticeActionSummary(actions[i]))
        i = i + 1
    lines

fn channelsNoticeSummary(state: ChannelsNoticeState) -> text:
    channelsNoticeTitle(state) + " - " + channelsNoticeStabilityLabel(state) + " - " + channelsNoticeHiddenReason(state)

fn channelsNoticeStatusLine(state: ChannelsNoticeState) -> text:
    "Channel: " + state.channel_name + " (" + channelsNoticeStabilityLabel(state) + ", " + channelsNoticeToneLabel(state) + ")"

fn channelsNoticeReleaseNotesLine(state: ChannelsNoticeState) -> text:
    channelsNoticeReleaseNotesLabel(state) + ": " + channelsNoticeReleaseNotesHref(state)

fn renderChannelsNoticeHeader(state: ChannelsNoticeState) -> text:
    channelsNoticeTitle(state) + " [" + channelsNoticeToneLabel(state) + "]"

fn renderChannelsNoticeHidden(state: ChannelsNoticeState) -> text:
    "Channels notice " + channelsNoticeHiddenReason(state)

fn renderChannelsNoticeVisible(state: ChannelsNoticeState) -> text:
    var lines: [text] = [
        renderChannelsNoticeHeader(state),
        channelsNoticeBody(state),
        channelsNoticeStatusLine(state),
        channelsNoticeReleaseNotesLine(state),
        "Actions:",
    ]
    val actions = channelsNoticeActionsSummary(state)
    var i = 0
    while i < actions.len():
        lines.push(actions[i])
        i = i + 1
    joinChannelsNoticeLines(lines)

fn renderChannelsNotice(state: ChannelsNoticeState) -> text:
    if not channelsNoticeVisible(state):
        return renderChannelsNoticeHidden(state)
    renderChannelsNoticeVisible(state)

fn joinChannelsNoticeLines(lines: [text]) -> text:
    var out = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    out

fn channelsNoticeSourceLinesModeled() -> i64:
    265
# parity ledger: ChannelsNotice line 001 models channel name state.
# parity ledger: ChannelsNotice line 002 models stability state.
# parity ledger: ChannelsNotice line 003 models tone state.
