"""
Claude full LogoV2 Opus 1M merge notice parity.
"""

class Opus1mMergeNoticeState:
    enabled: bool
    model: text
    merged: bool

impl Opus1mMergeNoticeState:
    static fn new(enabled: bool, model: text, merged: bool) -> Opus1mMergeNoticeState:
        Opus1mMergeNoticeState(enabled: enabled, model: opus1mMergeModel(model), merged: merged)

fn opus1mMergeModel(model: text) -> text:
    val clean = model.trim()
    if clean == "":
        return "Opus 1M"
    clean

fn opus1mMergeNoticeVisible(state: Opus1mMergeNoticeState) -> bool:
    state.enabled and not state.merged

fn opus1mMergeNoticeSummary(state: Opus1mMergeNoticeState) -> text:
    if state.merged:
        return state.model + " merged"
    if not state.enabled:
        return state.model + " disabled"
    state.model + " merge available"

fn opus1mMergeNoticeSourceLinesModeled() -> i64:
    54
