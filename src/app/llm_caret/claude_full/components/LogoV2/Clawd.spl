"""
Claude full LogoV2 Clawd component parity.
"""

class ClawdLogoState:
    variant: text
    size: text
    channel: text
    animated: bool
    showLabel: bool
    label: text

impl ClawdLogoState:
    static fn new(variant: text, size: text, channel: text, animated: bool, showLabel: bool, label: text) -> ClawdLogoState:
        ClawdLogoState(
            variant: clawdLogoVariant(variant),
            size: clawdLogoSize(size),
            channel: channel.trim(),
            animated: animated,
            showLabel: showLabel,
            label: clawdLogoLabel(label),
        )

fn clawdLogoVariant(variant: text) -> text:
    val clean = variant.trim()
    if clean == "glyph":
        return "glyph"
    if clean == "wordmark":
        return "wordmark"
    if clean == "stacked":
        return "stacked"
    if clean == "compact":
        return "compact"
    "glyph"

fn clawdLogoSize(size: text) -> text:
    val clean = size.trim()
    if clean == "xs":
        return "xs"
    if clean == "sm":
        return "sm"
    if clean == "md":
        return "md"
    if clean == "lg":
        return "lg"
    if clean == "xl":
        return "xl"
    "md"

fn clawdLogoLabel(label: text) -> text:
    val clean = label.trim()
    if clean == "":
        return "Claude"
    clean

fn clawdLogoSizeColumns(size: text) -> i64:
    val clean = clawdLogoSize(size)
    if clean == "xs":
        return 3
    if clean == "sm":
        return 5
    if clean == "lg":
        return 9
    if clean == "xl":
        return 11
    7

fn clawdLogoSizeRows(size: text) -> i64:
    val clean = clawdLogoSize(size)
    if clean == "xs":
        return 1
    if clean == "sm":
        return 2
    if clean == "lg":
        return 4
    if clean == "xl":
        return 5
    3

fn clawdLogoChannelBadge(channel: text) -> text:
    val clean = channel.trim()
    if clean == "":
        return ""
    if clean == "stable":
        return ""
    if clean == "production":
        return ""
    if clean == "dev":
        return "[dev]"
    if clean == "beta":
        return "[beta]"
    if clean == "canary":
        return "[canary]"
    "[" + clean + "]"

fn clawdLogoHasBadge(channel: text) -> bool:
    clawdLogoChannelBadge(channel) != ""

fn clawdLogoAnimatedFlag(animated: bool) -> text:
    if animated:
        return "animated"
    "static"

fn clawdLogoAnimationFrame(animated: bool, tick: i64) -> text:
    if not animated:
        return "rest"
    val phase = tick % 4
    if phase == 0:
        return "open"
    if phase == 1:
        return "blink"
    if phase == 2:
        return "look"
    "settle"

fn clawdLogoGlyph(variant: text, size: text, animated: bool, tick: i64) -> text:
    val cleanVariant = clawdLogoVariant(variant)
    val cleanSize = clawdLogoSize(size)
    val frame = clawdLogoAnimationFrame(animated, tick)
    if cleanVariant == "wordmark":
        return "Claude"
    if cleanVariant == "stacked":
        return "C\n" + frame + "\n" + cleanSize
    if cleanVariant == "compact":
        return "C"
    "Clawd:" + frame + ":" + cleanSize

fn clawdLogoVisibleLabel(state: ClawdLogoState) -> text:
    if not state.showLabel:
        return ""
    state.label

fn clawdLogoA11yLabel(state: ClawdLogoState) -> text:
    val badge = clawdLogoChannelBadge(state.channel)
    val visible = clawdLogoVisibleLabel(state)
    if visible == "" and badge == "":
        return "Claude logo"
    if visible == "":
        return "Claude logo " + badge
    if badge == "":
        return visible + " logo"
    visible + " logo " + badge

fn clawdLogoRenderKey(state: ClawdLogoState) -> text:
    state.variant + ":" + state.size + ":" + state.channel + ":" + clawdLogoAnimatedFlag(state.animated)

fn clawdLogoCompactRenderSummary(state: ClawdLogoState) -> text:
    val badge = clawdLogoChannelBadge(state.channel)
    val label = clawdLogoVisibleLabel(state)
    var out = "Clawd(" + state.variant + "," + state.size + "," + clawdLogoAnimatedFlag(state.animated)
    if badge != "":
        out = out + ",badge=" + badge
    if label != "":
        out = out + ",label=" + label
    out + ")"

fn clawdLogoFullRenderSummary(state: ClawdLogoState) -> text:
    val cols = clawdLogoSizeColumns(state.size).to_text()
    val rows = clawdLogoSizeRows(state.size).to_text()
    val badge = clawdLogoChannelBadge(state.channel)
    val label = clawdLogoVisibleLabel(state)
    var out = "ClawdLogo variant=" + state.variant
    out = out + " size=" + state.size
    out = out + " box=" + cols + "x" + rows
    out = out + " motion=" + clawdLogoAnimatedFlag(state.animated)
    if label != "":
        out = out + " label=" + label
    if badge != "":
        out = out + " channel=" + badge
    out

fn clawdLogoRenderSummary(state: ClawdLogoState, compact: bool) -> text:
    if compact:
        return clawdLogoCompactRenderSummary(state)
    clawdLogoFullRenderSummary(state)

fn clawdLogoDefault() -> ClawdLogoState:
    ClawdLogoState.new("glyph", "md", "stable", false, true, "Claude")

fn clawdLogoWithChannel(channel: text) -> ClawdLogoState:
    ClawdLogoState.new("glyph", "md", channel, false, true, "Claude")

fn clawdLogoMotionSummary(state: ClawdLogoState, tick: i64) -> text:
    clawdLogoAnimatedFlag(state.animated) + ":" + clawdLogoAnimationFrame(state.animated, tick)

fn clawdLogoLayoutSummary(state: ClawdLogoState) -> text:
    clawdLogoSizeColumns(state.size).to_text() + " columns, " + clawdLogoSizeRows(state.size).to_text() + " rows"

fn clawdLogoSourceLinesModeled() -> i64:
    239
