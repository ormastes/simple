"""
Claude full Markdown parity.
"""

class MarkdownRenderState:
    content: text
    dim_color: bool
    syntax_highlighting_disabled: bool
    theme: text

impl MarkdownRenderState:
    static fn new(content: text, dimColor: bool, syntaxHighlightingDisabled: bool, theme: text) -> MarkdownRenderState:
        MarkdownRenderState(content: stripPromptXmlTags(content), dim_color: dimColor, syntax_highlighting_disabled: syntaxHighlightingDisabled, theme: theme.trim())

fn stripPromptXmlTags(content: text) -> text:
    var clean = content
    val startTag = "<prompt>"
    val endTag = "</prompt>"
    val start = clean.find(startTag)
    if start >= 0:
        clean = clean.slice(0, start) + clean.slice(start + startTag.len())
    val end = clean.find(endTag)
    if end >= 0:
        clean = clean.slice(0, end) + clean.slice(end + endTag.len())
    clean

fn markdownHasSyntax(content: text) -> bool:
    content.contains("#") or content.contains("*") or content.contains("`") or content.contains("|") or content.contains("\n\n") or content.contains(">") or content.contains("-")

fn markdownTokenKind(content: text) -> text:
    if not markdownHasSyntax(content):
        return "paragraph"
    if content.contains("|"):
        return "table"
    if content.contains("```"):
        return "code"
    "markdown"

fn markdownShouldUseHighlight(state: MarkdownRenderState) -> bool:
    (not state.syntax_highlighting_disabled) and markdownTokenKind(state.content) == "code"

fn markdownRenderMode(state: MarkdownRenderState) -> text:
    if markdownTokenKind(state.content) == "table":
        return "table"
    if markdownShouldUseHighlight(state):
        return "highlight"
    "ansi"

fn markdownStablePrefix(content: text) -> text:
    val clean = stripPromptXmlTags(content)
    val marker = "\n\n"
    val idx = clean.find(marker)
    if idx < 0:
        return ""
    clean.slice(0, idx + marker.len())

fn markdownSummary(state: MarkdownRenderState) -> text:
    "markdown mode=" + markdownRenderMode(state) + " dim=" + state.dim_color.to_text()

fn markdownSourceLinesModeled() -> i64:
    235
