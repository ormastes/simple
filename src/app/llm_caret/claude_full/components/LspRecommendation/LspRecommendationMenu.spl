"""
Claude full LSP recommendation menu parity.
"""

val LSP_RECOMMENDATION_AUTO_DISMISS_MS = 30000

class LspRecommendationState:
    plugin_name: text
    plugin_description: text
    file_extension: text
    selected_value: text

impl LspRecommendationState:
    static fn new(pluginName: text, pluginDescription: text, fileExtension: text, selectedValue: text) -> LspRecommendationState:
        LspRecommendationState(plugin_name: pluginName.trim(), plugin_description: pluginDescription.trim(), file_extension: normalizeLspFileExtension(fileExtension), selected_value: normalizeLspRecommendationResponse(selectedValue))

fn normalizeLspFileExtension(extension: text) -> text:
    val clean = extension.trim()
    if clean == "":
        return "source"
    clean

fn normalizeLspRecommendationResponse(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "yes" or clean == "no" or clean == "never" or clean == "disable":
        return clean
    "no"

fn lspRecommendationOptions(pluginName: text) -> [text]:
    [
        "yes:Yes, install " + pluginName.trim(),
        "no:No, not now",
        "never:Never for " + pluginName.trim(),
        "disable:Disable all LSP recommendations",
    ]

fn lspRecommendationResponseForSelect(value: text) -> text:
    normalizeLspRecommendationResponse(value)

fn lspRecommendationAutoDismissResponse() -> text:
    "no"

fn lspRecommendationSummary(state: LspRecommendationState) -> text:
    "LSP Plugin Recommendation plugin=" + state.plugin_name + " ext=" + state.file_extension + " response=" + state.selected_value

fn lspRecommendationSourceLinesModeled() -> i64:
    87
