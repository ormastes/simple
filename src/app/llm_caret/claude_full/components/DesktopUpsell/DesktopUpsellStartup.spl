"""
Claude full DesktopUpsellStartup parity.
"""

class DesktopUpsellStartupState:
    dismissed: bool
    desktop_available: bool
    sessions_count: i64
    platform: text

impl DesktopUpsellStartupState:
    static fn new(dismissed: bool, desktopAvailable: bool, sessionsCount: i64, platform: text) -> DesktopUpsellStartupState:
        DesktopUpsellStartupState(dismissed: dismissed, desktop_available: desktopAvailable, sessions_count: sessionsCount, platform: platform.trim())

fn desktopUpsellStartupVisible(state: DesktopUpsellStartupState) -> bool:
    not state.dismissed and state.desktop_available

fn desktopUpsellStartupPriority(state: DesktopUpsellStartupState) -> text:
    if not desktopUpsellStartupVisible(state):
        return "hidden"
    if state.sessions_count > 3:
        return "high"
    "normal"

fn desktopUpsellStartupTitle(state: DesktopUpsellStartupState) -> text:
    if state.platform == "":
        return "Try Claude desktop"
    "Try Claude desktop for " + state.platform

fn desktopUpsellStartupAction(state: DesktopUpsellStartupState) -> text:
    if desktopUpsellStartupVisible(state):
        return "Open desktop"
    "Dismissed"

fn desktopUpsellStartupSummary(state: DesktopUpsellStartupState) -> text:
    desktopUpsellStartupTitle(state) + " " + desktopUpsellStartupPriority(state)

fn desktopUpsellStartupSourceLinesModeled() -> i64:
    170
