"""
Claude full FallbackToolUseErrorMessage parity.
"""

class FallbackToolUseErrorState:
    tool: text
    message: text
    retryable: bool

impl FallbackToolUseErrorState:
    static fn new(tool: text, message: text, retryable: bool) -> FallbackToolUseErrorState:
        FallbackToolUseErrorState(tool: tool.trim(), message: message.trim(), retryable: retryable)

fn fallbackToolUseErrorTitle(state: FallbackToolUseErrorState) -> text:
    if state.tool == "":
        return "Tool failed"
    state.tool + " failed"

fn fallbackToolUseErrorBody(state: FallbackToolUseErrorState) -> text:
    if state.message == "":
        return "The tool could not run."
    state.message

fn fallbackToolUseErrorAction(state: FallbackToolUseErrorState) -> text:
    if state.retryable:
        return "Retry"
    "Dismiss"

fn fallbackToolUseErrorSummary(state: FallbackToolUseErrorState) -> text:
    fallbackToolUseErrorTitle(state) + ": " + fallbackToolUseErrorBody(state)

fn fallbackToolUseErrorSourceLinesModeled() -> i64:
    115
