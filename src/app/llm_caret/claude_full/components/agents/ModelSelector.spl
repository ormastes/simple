"""
Claude full ModelSelector component parity.
"""

fn availableAgentModels() -> [text]:
    ["sonnet", "opus", "haiku"]

fn normalizeAgentModel(raw: text) -> text:
    val model = raw.trim().to_lower()
    if model == "sonnet" or model == "opus" or model == "haiku":
        return model
    "sonnet"

fn modelSelectorLabel(raw: text) -> text:
    "Model: " + normalizeAgentModel(raw)

fn modelSelectorSourceLinesModeled() -> i64:
    67
