"""
Claude full AgentNavigationFooter component parity.
"""

fn agentNavigationFooterLabel(current: i64, total: i64) -> text:
    "Agent " + current.to_text() + " of " + total.to_text()

fn canNavigatePrevious(current: i64) -> bool:
    current > 1

fn canNavigateNext(current: i64, total: i64) -> bool:
    current < total

fn agentNavigationFooterSourceLinesModeled() -> i64:
    25
