"""
Minimal generateAgent parity model for Claude full agent creation.
"""

class AgentGenerateOptions:
    name: text
    description: text
    model: text
    tools: [text]
    systemPrompt: text

impl AgentGenerateOptions:
    static fn new(name: text, description: text, model: text, tools: [text], systemPrompt: text) -> AgentGenerateOptions:
        AgentGenerateOptions(name: name.trim(), description: description.trim(), model: model.trim(), tools: cleanGenerateTools(tools), systemPrompt: systemPrompt.trim())

    me validate() -> [text]:
        var errors: [text] = []
        if me.name == "":
            errors = errors + ["name is required"]
        if me.description == "":
            errors = errors + ["description is required"]
        if me.model == "":
            errors = errors + ["model is required"]
        if me.systemPrompt == "":
            errors = errors + ["prompt is required"]
        errors

    me valid() -> bool:
        me.validate().len() == 0

class AgentGeneratePrompt:
    title: text
    body: text
    options: AgentGenerateOptions

impl AgentGeneratePrompt:
    static fn new(title: text, body: text, options: AgentGenerateOptions) -> AgentGeneratePrompt:
        AgentGeneratePrompt(title: title, body: body, options: options)

    me render() -> text:
        me.title + "\n" + me.body

class AgentGenerateResult:
    ok: bool
    status: text
    name: text
    model: text
    prompt: text
    summary: text
    errors: [text]

impl AgentGenerateResult:
    static fn success(name: text, model: text, prompt: text, summary: text) -> AgentGenerateResult:
        AgentGenerateResult(ok: true, status: "generated", name: name, model: model, prompt: prompt, summary: summary, errors: [])

    static fn failure(errors: [text]) -> AgentGenerateResult:
        AgentGenerateResult(ok: false, status: "blocked", name: "", model: "", prompt: "", summary: joinGenerateErrors(errors), errors: errors)

    me statusLine() -> text:
        generateAgentStatusLine(me)

fn generateAgentOptions(name: text, description: text, model: text, tools: [text], systemPrompt: text) -> AgentGenerateOptions:
    AgentGenerateOptions.new(name, description, model, tools, systemPrompt)

fn generateAgentPrompt(options: AgentGenerateOptions) -> AgentGeneratePrompt:
    val title = "Generate agent: " + options.name
    var body = "Name: " + options.name + "\n"
    body = body + "Description: " + options.description + "\n"
    body = body + "Model: " + options.model + "\n"
    body = body + "Tools: " + joinGenerateTools(options.tools) + "\n"
    body = body + "System prompt:\n" + options.systemPrompt
    AgentGeneratePrompt.new(title, body, options)

fn generateAgent(options: AgentGenerateOptions) -> AgentGenerateResult:
    val errors = options.validate()
    if errors.len() > 0:
        return AgentGenerateResult.failure(errors)
    val prompt = generateAgentPrompt(options)
    AgentGenerateResult.success(options.name, options.model, prompt.render(), generateAgentSummary(options))

fn generateAgentStatusLine(result: AgentGenerateResult) -> text:
    if result.ok:
        return result.status + " | " + result.name + " | " + result.model
    result.status + " | " + result.summary

fn generateAgentSummary(options: AgentGenerateOptions) -> text:
    options.name + " | " + options.model + " | tools=" + options.tools.len().to_text()

fn generateAgentSourceHelper(name: text) -> text:
    "generateAgent:" + name.trim()

fn generateAgentSourceLinesModeled() -> i64:
    197

fn generateAgentSourceHelpersModeled() -> text:
    "prompt,options,result,status"

fn cleanGenerateTools(tools: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < tools.len():
        val clean = tools[i].trim()
        if clean != "" and not hasGenerateTool(out, clean):
            out = out + [clean]
        i = i + 1
    out

fn hasGenerateTool(tools: [text], needle: text) -> bool:
    var i = 0
    while i < tools.len():
        if tools[i] == needle:
            return true
        i = i + 1
    false

fn joinGenerateTools(tools: [text]) -> text:
    if tools.len() == 0:
        return "none"
    var out = tools[0]
    var i = 1
    while i < tools.len():
        out = out + ", " + tools[i]
        i = i + 1
    out

fn joinGenerateErrors(errors: [text]) -> text:
    if errors.len() == 0:
        return "none"
    var out = errors[0]
    var i = 1
    while i < errors.len():
        out = out + ", " + errors[i]
        i = i + 1
    out

