"""
Minimal ToolSelector parity model for Claude full agent creation.
"""

class ToolSelectorTool:
    id: text
    name: text
    description: text
    source: text
    enabled: bool

impl ToolSelectorTool:
    static fn new(id: text, name: text, description: text, source: text, enabled: bool) -> ToolSelectorTool:
        ToolSelectorTool(id: id, name: name, description: description, source: normalizeToolSelectorSource(source), enabled: enabled)

    me matches(query: text, sourceFilter: text, includeDisabled: bool) -> bool:
        if not includeDisabled and not me.enabled:
            return false
        val normalizedSource = normalizeToolSelectorSourceFilter(sourceFilter)
        if normalizedSource != "all" and me.source != normalizedSource:
            return false
        val q = query.trim().lower()
        if q == "":
            return true
        me.id.lower().contains(q) or me.name.lower().contains(q) or me.description.lower().contains(q) or me.source.lower().contains(q)

    me statusLabel() -> text:
        if me.enabled:
            return "enabled"
        "disabled"

    me sourceLabel() -> text:
        toolSelectorSourceDisplayName(me.source)

class ToolSelectorState:
    query: text
    sourceFilter: text
    selectedIds: [text]
    includeDisabled: bool
    lastAction: text

impl ToolSelectorState:
    static fn new(query: text, sourceFilter: text, selectedIds: [text], includeDisabled: bool, lastAction: text) -> ToolSelectorState:
        ToolSelectorState(query: query, sourceFilter: normalizeToolSelectorSourceFilter(sourceFilter), selectedIds: selectedIds, includeDisabled: includeDisabled, lastAction: lastAction)

    static fn empty() -> ToolSelectorState:
        ToolSelectorState.new("", "all", [], true, "")

    me withQuery(query: text) -> ToolSelectorState:
        ToolSelectorState.new(query, me.sourceFilter, me.selectedIds, me.includeDisabled, "filter")

    me withSourceFilter(sourceFilter: text) -> ToolSelectorState:
        ToolSelectorState.new(me.query, sourceFilter, me.selectedIds, me.includeDisabled, "filter")

    me withIncludeDisabled(includeDisabled: bool) -> ToolSelectorState:
        ToolSelectorState.new(me.query, me.sourceFilter, me.selectedIds, includeDisabled, "filter")

    me withSelectedIds(selectedIds: [text], lastAction: text) -> ToolSelectorState:
        ToolSelectorState.new(me.query, me.sourceFilter, selectedIds, me.includeDisabled, lastAction)

class ToolSelectorModel:
    tools: [ToolSelectorTool]
    state: ToolSelectorState

impl ToolSelectorModel:
    static fn new(tools: [ToolSelectorTool], state: ToolSelectorState) -> ToolSelectorModel:
        ToolSelectorModel(tools: sortToolSelectorTools(tools), state: normalizeToolSelectorState(tools, state))

    me filter(query: text, sourceFilter: text) -> ToolSelectorModel:
        ToolSelectorModel.new(me.tools, ToolSelectorState.new(query, sourceFilter, me.state.selectedIds, me.state.includeDisabled, "filter"))

    me hideDisabled() -> ToolSelectorModel:
        ToolSelectorModel.new(me.tools, me.state.withIncludeDisabled(false))

    me showDisabled() -> ToolSelectorModel:
        ToolSelectorModel.new(me.tools, me.state.withIncludeDisabled(true))

    me toggle(id: text) -> ToolSelectorModel:
        ToolSelectorModel.new(me.tools, toggleToolSelectorSelection(me.tools, me.state, id))

    me clear() -> ToolSelectorModel:
        ToolSelectorModel.new(me.tools, me.state.withSelectedIds([], "clear"))

    me visibleTools() -> [ToolSelectorTool]:
        visibleToolSelectorTools(me.tools, me.state)

    me selectedTools() -> [ToolSelectorTool]:
        selectedToolSelectorTools(me.tools, me.state)

    me summary() -> text:
        toolSelectorSummary(me)

    me render() -> text:
        renderToolSelector(me.tools, me.state)

fn sampleToolSelectorTools() -> [ToolSelectorTool]:
    [
        ToolSelectorTool.new("read", "Read", "Read files from the workspace", "builtin", true),
        ToolSelectorTool.new("write", "Write", "Create and edit files", "builtin", true),
        ToolSelectorTool.new("bash", "Bash", "Run shell commands", "project", true),
        ToolSelectorTool.new("web-fetch", "Web Fetch", "Fetch URLs for research", "user", false),
        ToolSelectorTool.new("notebook", "Notebook", "Read notebook cells", "project", false)
    ]

fn createToolSelector(tools: [ToolSelectorTool]) -> ToolSelectorModel:
    ToolSelectorModel.new(tools, ToolSelectorState.empty())

fn normalizeToolSelectorState(tools: [ToolSelectorTool], state: ToolSelectorState) -> ToolSelectorState:
    var selected: [text] = []
    var i = 0
    while i < state.selectedIds.len():
        val id = state.selectedIds[i]
        if toolSelectorCanSelect(tools, id) and not toolSelectorTextContains(selected, id):
            selected.push(id)
        i = i + 1
    ToolSelectorState.new(state.query, state.sourceFilter, selected, state.includeDisabled, state.lastAction)

fn visibleToolSelectorTools(tools: [ToolSelectorTool], state: ToolSelectorState) -> [ToolSelectorTool]:
    sortToolSelectorTools(filterToolSelectorTools(tools, state.query, state.sourceFilter, state.includeDisabled))

fn filterToolSelectorTools(tools: [ToolSelectorTool], query: text, sourceFilter: text, includeDisabled: bool) -> [ToolSelectorTool]:
    var out: [ToolSelectorTool] = []
    var i = 0
    while i < tools.len():
        if tools[i].matches(query, sourceFilter, includeDisabled):
            out.push(tools[i])
        i = i + 1
    out

fn sortToolSelectorTools(tools: [ToolSelectorTool]) -> [ToolSelectorTool]:
    var out = tools
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if toolSelectorSortKey(out[i + 1]) < toolSelectorSortKey(out[i]):
                val tmp = out[i]
                out[i] = out[i + 1]
                out[i + 1] = tmp
                changed = true
            i = i + 1
    out

fn toolSelectorSortKey(tool: ToolSelectorTool) -> text:
    tool.name.lower() + "|" + tool.id.lower()

fn findToolSelectorToolById(tools: [ToolSelectorTool], id: text) -> ToolSelectorTool?:
    var i = 0
    while i < tools.len():
        if tools[i].id == id:
            return tools[i]
        i = i + 1
    nil

fn toolSelectorCanSelect(tools: [ToolSelectorTool], id: text) -> bool:
    if val Some(tool) = findToolSelectorToolById(tools, id):
        return tool.enabled
    false

fn toggleToolSelectorSelection(tools: [ToolSelectorTool], state: ToolSelectorState, id: text) -> ToolSelectorState:
    if not toolSelectorCanSelect(tools, id):
        return state.withSelectedIds(state.selectedIds, "blocked " + id)
    if toolSelectorTextContains(state.selectedIds, id):
        return state.withSelectedIds(toolSelectorRemoveText(state.selectedIds, id), "remove " + id)
    var selected = state.selectedIds
    selected.push(id)
    state.withSelectedIds(selected, "add " + id)

fn selectedToolSelectorTools(tools: [ToolSelectorTool], state: ToolSelectorState) -> [ToolSelectorTool]:
    var out: [ToolSelectorTool] = []
    var i = 0
    while i < state.selectedIds.len():
        if val Some(tool) = findToolSelectorToolById(tools, state.selectedIds[i]):
            if tool.enabled:
                out.push(tool)
        i = i + 1
    sortToolSelectorTools(out)

fn toolSelectorSelectedNames(model: ToolSelectorModel) -> [text]:
    var names: [text] = []
    val selected = model.selectedTools()
    var i = 0
    while i < selected.len():
        names.push(selected[i].name)
        i = i + 1
    names

fn toolSelectorSummary(model: ToolSelectorModel) -> text:
    val selected = model.selectedTools()
    if selected.len() == 0:
        return "No tools selected"
    "Selected " + selected.len().to_text() + " of " + model.tools.len().to_text() + ": " + joinToolSelectorText(toolSelectorSelectedNames(model), ", ")

fn renderToolSelector(tools: [ToolSelectorTool], state: ToolSelectorState) -> text:
    val visible = visibleToolSelectorTools(tools, state)
    if visible.len() == 0:
        return toolSelectorEmptyMessage(state)
    val normalized = normalizeToolSelectorState(tools, state)
    var lines: [text] = [renderToolSelectorHeader(visible.len(), tools.len(), normalized)]
    var i = 0
    while i < visible.len():
        lines.push(renderToolSelectorRow(visible[i], toolSelectorTextContains(normalized.selectedIds, visible[i].id)))
        i = i + 1
    joinToolSelectorText(lines, "\n")

fn renderToolSelectorHeader(visibleCount: i64, totalCount: i64, state: ToolSelectorState) -> text:
    "Tools " + visibleCount.to_text() + "/" + totalCount.to_text() + " · " + toolSelectorSourceDisplayName(state.sourceFilter) + renderToolSelectorDisabledBadge(state.includeDisabled) + renderToolSelectorQueryBadge(state.query)

fn renderToolSelectorDisabledBadge(includeDisabled: bool) -> text:
    if includeDisabled:
        return " · disabled shown"
    " · disabled hidden"

fn renderToolSelectorQueryBadge(query: text) -> text:
    val q = query.trim()
    if q == "":
        return ""
    " · search:" + q

fn renderToolSelectorRow(tool: ToolSelectorTool, selected: bool) -> text:
    val marker = if selected: "[x]" else: "[ ]"
    marker + " " + tool.name + " [" + tool.sourceLabel() + "] " + tool.statusLabel() + " · " + tool.description

fn toolSelectorEmptyMessage(state: ToolSelectorState) -> text:
    "No tools match " + toolSelectorFilterSummary(state)

fn toolSelectorFilterSummary(state: ToolSelectorState) -> text:
    var parts: [text] = []
    if state.query.trim() != "":
        parts.push("search \"" + state.query.trim() + "\"")
    if normalizeToolSelectorSourceFilter(state.sourceFilter) != "all":
        parts.push("source " + toolSelectorSourceDisplayName(state.sourceFilter))
    if not state.includeDisabled:
        parts.push("enabled tools")
    if parts.len() == 0:
        return "current filters"
    joinToolSelectorText(parts, " and ")

fn normalizeToolSelectorSource(source: text) -> text:
    val s = source.trim().lower()
    if s == "project":
        return "project"
    if s == "user":
        return "user"
    if s == "builtin" or s == "built-in":
        return "builtin"
    "project"

fn normalizeToolSelectorSourceFilter(sourceFilter: text) -> text:
    val s = sourceFilter.trim().lower()
    if s == "" or s == "all":
        return "all"
    if s == "project":
        return "project"
    if s == "user":
        return "user"
    if s == "builtin" or s == "built-in":
        return "builtin"
    "all"

fn toolSelectorSourceDisplayName(source: text) -> text:
    val s = normalizeToolSelectorSourceFilter(source)
    if s == "project":
        return "Project"
    if s == "user":
        return "User"
    if s == "builtin":
        return "Built-in"
    "All"

fn toolSelectorSourceOptions() -> [text]:
    ["all", "project", "user", "builtin"]

fn toolSelectorModeledSourceFile() -> text:
    "src/components/agents/ToolSelector.tsx"

fn toolSelectorModeledSourceHelper() -> text:
    "getAvailableTools"

fn toolSelectorModeledToggleHelper() -> text:
    "toggleToolSelection"

fn toolSelectorModeledSummaryHelper() -> text:
    "getToolSelectionSummary"

fn toolSelectorSourceLinesModeled() -> i64:
    561

fn toolSelectorTextContains(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn toolSelectorRemoveText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if values[i] != value:
            out.push(values[i])
        i = i + 1
    out

fn joinToolSelectorText(values: [text], separator: text) -> text:
    if values.len() == 0:
        return ""
    var out = values[0]
    var i = 1
    while i < values.len():
        out = out + separator + values[i]
        i = i + 1
    out

