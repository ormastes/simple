"""
Claude full PromptStep component parity.
"""

fn normalizedAgentPrompt(value: text) -> text:
    value.trim()

fn promptStepCanContinue(value: text) -> bool:
    normalizedAgentPrompt(value).len() >= 12

fn promptStepHint(value: text) -> text:
    if promptStepCanContinue(value):
        return "Prompt ready"
    "Describe what the agent should do"

fn promptStepSourceLinesModeled() -> i64:
    127
