class ConfirmAgentDraft:
    name: text
    description: text
    prompt: text
    model: text
    tools: [text]
    source: text
    existingAgentNames: [text]

impl ConfirmAgentDraft:
    static fn new(name: text, description: text, prompt: text, model: text, tools: [text], source: text, existingAgentNames: [text]) -> ConfirmAgentDraft:
        ConfirmAgentDraft(name: name, description: description, prompt: prompt, model: model, tools: tools, source: source, existingAgentNames: existingAgentNames)

    static fn sample() -> ConfirmAgentDraft:
        ConfirmAgentDraft.new("reviewer", "Reviews changes before commit", "Review the diff and call out regressions.", "sonnet", ["Read", "Grep"], "project", ["docs"])

    me normalizedName() -> text:
        me.name.trim()

    me normalizedDescription() -> text:
        me.description.trim()

    me normalizedPrompt() -> text:
        me.prompt.trim()

    me normalizedModel() -> text:
        me.model.trim()

    me normalizedSource() -> text:
        normalizeConfirmSource(me.source)

    me validationErrors() -> [text]:
        validateConfirmDraft(me)

    me canCreate() -> bool:
        canCreateAgent(me)

    me summary() -> ConfirmAgentSummary:
        confirmAgentSummary(me)

class ConfirmAgentSummary:
    name: text
    description: text
    promptPreview: text
    model: text
    toolsLabel: text
    source: text
    fileName: text
    validationLabel: text
    createButtonEnabled: bool

impl ConfirmAgentSummary:
    static fn new(name: text, description: text, promptPreview: text, model: text, toolsLabel: text, source: text, fileName: text, validationLabel: text, createButtonEnabled: bool) -> ConfirmAgentSummary:
        ConfirmAgentSummary(name: name, description: description, promptPreview: promptPreview, model: model, toolsLabel: toolsLabel, source: source, fileName: fileName, validationLabel: validationLabel, createButtonEnabled: createButtonEnabled)

    me render() -> text:
        renderConfirmSummary(me)

class ConfirmStepState:
    draft: ConfirmAgentDraft
    status: text
    message: text

impl ConfirmStepState:
    static fn new(draft: ConfirmAgentDraft, status: text, message: text) -> ConfirmStepState:
        ConfirmStepState(draft: draft, status: normalizeConfirmStatus(status), message: message.trim())

    static fn ready(draft: ConfirmAgentDraft) -> ConfirmStepState:
        ConfirmStepState.new(draft, "idle", "")

    me errors() -> [text]:
        me.draft.validationErrors()

    me canCreate() -> bool:
        me.status != "creating" and me.draft.canCreate()

    me createButtonLabel() -> text:
        confirmCreateButtonLabel(me)

    me statusText() -> text:
        confirmStatusText(me)

    me render() -> text:
        renderConfirmStep(me)

fn sampleConfirmDraft() -> ConfirmAgentDraft:
    ConfirmAgentDraft.sample()

fn confirmAgentSummary(draft: ConfirmAgentDraft) -> ConfirmAgentSummary:
    val errors = validateConfirmDraft(draft)
    val validationLabel = if errors.len() == 0: "Ready to create" else: joinConfirmText(errors, ", ")
    ConfirmAgentSummary.new(
        draft.normalizedName(),
        draft.normalizedDescription(),
        promptPreview(draft.normalizedPrompt()),
        normalizedModelLabel(draft.normalizedModel()),
        confirmToolsLabel(draft.tools),
        confirmSourceDisplayName(draft.normalizedSource()),
        confirmAgentFileName(draft.normalizedName()),
        validationLabel,
        errors.len() == 0
    )

fn validateConfirmDraft(draft: ConfirmAgentDraft) -> [text]:
    var errors: [text] = []
    val name = draft.normalizedName()
    if name == "":
        errors.push("name is required")
    if name != "" and not isValidConfirmAgentName(name):
        errors.push("name must use letters, numbers, dash, or underscore")
    if confirmNameExists(name, draft.existingAgentNames):
        errors.push("agent name already exists")
    if draft.normalizedDescription() == "":
        errors.push("description is required")
    if draft.normalizedPrompt() == "":
        errors.push("prompt is required")
    if draft.normalizedModel() == "":
        errors.push("model is required")
    if draft.normalizedSource() == "unknown":
        errors.push("source is invalid")
    errors

fn canCreateAgent(draft: ConfirmAgentDraft) -> bool:
    validateConfirmDraft(draft).len() == 0

fn submitConfirmStep(state: ConfirmStepState) -> ConfirmStepState:
    val errors = state.errors()
    if errors.len() > 0:
        return ConfirmStepState.new(state.draft, "error", joinConfirmText(errors, ", "))
    ConfirmStepState.new(state.draft, "success", "Created " + state.draft.normalizedName())

fn failConfirmStep(state: ConfirmStepState, message: text) -> ConfirmStepState:
    val trimmed = message.trim()
    if trimmed == "":
        return ConfirmStepState.new(state.draft, "error", "Create failed")
    ConfirmStepState.new(state.draft, "error", trimmed)

fn markConfirmCreating(state: ConfirmStepState) -> ConfirmStepState:
    if state.draft.canCreate():
        return ConfirmStepState.new(state.draft, "creating", "Creating " + state.draft.normalizedName())
    ConfirmStepState.new(state.draft, "error", joinConfirmText(state.errors(), ", "))

fn renderConfirmStep(state: ConfirmStepState) -> text:
    val summary = confirmAgentSummary(state.draft)
    joinConfirmText([
        summary.render(),
        "Create button: " + confirmEnabledLabel(state.canCreate()),
        "Button label: " + state.createButtonLabel(),
        "Status: " + state.statusText()
    ], "\n")

fn renderConfirmSummary(summary: ConfirmAgentSummary) -> text:
    joinConfirmText([
        "Confirm agent",
        "Name: " + summary.name,
        "Description: " + summary.description,
        "Prompt: " + summary.promptPreview,
        "Model: " + summary.model,
        "Tools: " + summary.toolsLabel,
        "Source: " + summary.source,
        "File: " + summary.fileName,
        "Validation: " + summary.validationLabel,
        "Create enabled: " + confirmEnabledLabel(summary.createButtonEnabled)
    ], "\n")

fn confirmCreateButtonLabel(state: ConfirmStepState) -> text:
    if state.status == "creating":
        return "Creating..."
    if state.status == "success":
        return "Created"
    "Create agent"

fn confirmStatusText(state: ConfirmStepState) -> text:
    if state.status == "success":
        if state.message != "":
            return "success | " + state.message
        return "success | Created " + state.draft.normalizedName()
    if state.status == "error":
        if state.message != "":
            return "error | " + state.message
        return "error | " + joinConfirmText(state.errors(), ", ")
    if state.status == "creating":
        if state.message != "":
            return "creating | " + state.message
        return "creating | Creating " + state.draft.normalizedName()
    if state.draft.canCreate():
        return "idle | Ready to create"
    "idle | " + joinConfirmText(state.errors(), ", ")

fn normalizeConfirmStatus(status: text) -> text:
    val normalized = status.trim().lower()
    if normalized == "creating":
        return "creating"
    if normalized == "error":
        return "error"
    if normalized == "success":
        return "success"
    "idle"

fn normalizeConfirmSource(source: text) -> text:
    val normalized = source.trim().lower()
    if normalized == "project":
        return "project"
    if normalized == "user":
        return "user"
    if normalized == "builtin" or normalized == "built-in":
        return "builtin"
    "unknown"

fn confirmSourceDisplayName(source: text) -> text:
    val normalized = normalizeConfirmSource(source)
    if normalized == "project":
        return "Project"
    if normalized == "user":
        return "User"
    if normalized == "builtin":
        return "Built-in"
    "Unknown"

fn confirmSourceOptions() -> [text]:
    ["project", "user", "builtin"]

fn confirmToolsLabel(tools: [text]) -> text:
    val normalized = normalizedConfirmTools(tools)
    if normalized.len() == 0:
        return "none"
    joinConfirmText(normalized, ", ")

fn normalizedConfirmTools(tools: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < tools.len():
        val tool = tools[i].trim()
        if tool != "" and not confirmTextContains(out, tool):
            out.push(tool)
        i = i + 1
    out

fn promptPreview(prompt: text) -> text:
    val trimmed = prompt.trim()
    if trimmed.len() <= 80:
        return trimmed
    trimmed.slice(0, 77) + "..."

fn normalizedModelLabel(model: text) -> text:
    val trimmed = model.trim()
    if trimmed == "":
        return "none"
    trimmed

fn confirmAgentFileName(name: text) -> text:
    slugConfirmAgentName(name) + ".md"

fn slugConfirmAgentName(name: text) -> text:
    var out = ""
    val trimmed = name.trim().lower()
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if isConfirmNameChar(ch):
            out = out + ch
        else:
            out = out + "-"
        i = i + 1
    trimConfirmDashes(out)

fn trimConfirmDashes(value: text) -> text:
    var out = value
    while out.starts_with("-"):
        out = out.slice(1, out.len())
    while out.ends_with("-"):
        out = out.slice(0, out.len() - 1)
    if out == "":
        return "agent"
    out

fn isValidConfirmAgentName(name: text) -> bool:
    val trimmed = name.trim()
    if trimmed == "":
        return false
    var i = 0
    while i < trimmed.len():
        if not isConfirmNameChar(trimmed.slice(i, i + 1)):
            return false
        i = i + 1
    true

fn isConfirmNameChar(ch: text) -> bool:
    val chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_"
    chars.contains(ch)

fn confirmNameExists(name: text, existingNames: [text]) -> bool:
    val normalized = name.trim().lower()
    if normalized == "":
        return false
    var i = 0
    while i < existingNames.len():
        if existingNames[i].trim().lower() == normalized:
            return true
        i = i + 1
    false

fn confirmTextContains(values: [text], needle: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn confirmEnabledLabel(enabled: bool) -> text:
    if enabled:
        return "enabled"
    "disabled"

fn joinConfirmText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn confirmStepModeledSourceFile() -> text:
    "src/components/agents/new-agent-creation/wizard-steps/ConfirmStep.tsx"

fn confirmStepModeledSourceHelper() -> text:
    "createAgent"

fn confirmStepModeledValidationHelper() -> text:
    "validateAgentDefinition"

fn confirmStepModeledStatusCount() -> i64:
    4

fn confirmStepModeledSummaryFieldCount() -> i64:
    8

fn confirmStepSourceLinesModeled() -> i64:
    377

