"""
Claude full LocationStep component parity.
"""

fn normalizeAgentLocation(raw: text) -> text:
    val value = raw.trim().to_lower()
    if value == "project" or value == "global":
        return value
    "project"

fn locationStepSummary(raw: text) -> text:
    "Location: " + normalizeAgentLocation(raw)

fn locationStepCanContinue(raw: text) -> bool:
    normalizeAgentLocation(raw) != ""

fn locationStepSourceLinesModeled() -> i64:
    79
