"""
Claude full MemoryStep component parity.
"""

fn normalizeMemoryMode(raw: text) -> text:
    val value = raw.trim().to_lower()
    if value == "none" or value == "project" or value == "global":
        return value
    "project"

fn memoryStepSummary(raw: text) -> text:
    "Memory: " + normalizeMemoryMode(raw)

fn memoryStepCanContinue(raw: text) -> bool:
    normalizeMemoryMode(raw) != ""

fn memoryStepSourceLinesModeled() -> i64:
    112
