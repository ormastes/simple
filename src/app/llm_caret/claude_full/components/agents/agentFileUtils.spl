class AgentFileMetadata:
    name: text
    description: text
    model: text
    sourcePath: text

impl AgentFileMetadata:
    static fn new(name: text, description: text, model: text, sourcePath: text) -> AgentFileMetadata:
        AgentFileMetadata(name: name, description: description, model: model, sourcePath: sourcePath)

class AgentFileParseResult:
    ok: bool
    metadata: AgentFileMetadata
    body: text
    error: text

impl AgentFileParseResult:
    static fn success(metadata: AgentFileMetadata, body: text) -> AgentFileParseResult:
        AgentFileParseResult(ok: true, metadata: metadata, body: body, error: "")

    static fn failure(error: text) -> AgentFileParseResult:
        AgentFileParseResult(ok: false, metadata: AgentFileMetadata.new("", "", "", ""), body: "", error: error)

fn isValidAgentName(name: text) -> bool:
    val clean = name.trim()
    if clean == "":
        return false
    if clean.starts_with(".") or clean.ends_with("."):
        return false
    if clean.contains("/") or clean.contains("\\") or clean.contains(".."):
        return false
    if clean.contains("\n") or clean.contains("\r") or clean.contains("\t"):
        return false
    slugifyAgentName(clean) == clean

fn isValidAgentModel(model: text) -> bool:
    val clean = model.trim()
    if clean == "":
        return true
    if clean.contains("/") or clean.contains("\\") or clean.contains(".."):
        return false
    if clean.contains("\n") or clean.contains("\r") or clean.contains("\t"):
        return false
    true

fn slugifyAgentName(name: text) -> text:
    val trimmed = name.trim()
    val lower = trimmed.lower()
    var out = ""
    var i = 0
    while i < lower.len():
        val ch = lower.slice(i, i + 1)
        if isAgentSlugChar(ch):
            out = out + ch
        elif ch == " " or ch == "_" or ch == ".":
            out = out + "-"
        i = i + 1
    while out.contains("--"):
        out = out.replace("--", "-")
    out = trimAgentSlugDash(out)
    out

fn deriveAgentMetadataFilename(name: text) -> text:
    val slug = slugifyAgentName(name)
    if slug == "":
        return ""
    slug + ".md"

fn agentMetadataPath(root: text, name: text) -> text:
    val cleanRoot = trimTrailingSlash(root.trim())
    val filename = deriveAgentMetadataFilename(name)
    if cleanRoot == "" or filename == "":
        return ""
    if not isSafeAgentRoot(cleanRoot):
        return ""
    cleanRoot + "/" + filename

fn isSafeAgentRoot(root: text) -> bool:
    val clean = root.trim()
    clean != "" and not clean.contains("\n") and not clean.contains("\r") and not clean.contains("\u0000") and not clean.contains("/../") and not clean.ends_with("/..")

fn isSafeAgentFilePath(root: text, path: text) -> bool:
    val cleanRoot = trimTrailingSlash(root.trim())
    val cleanPath = path.trim()
    if cleanRoot == "" or cleanPath == "":
        return false
    if not isSafeAgentRoot(cleanRoot):
        return false
    if cleanPath.contains("\n") or cleanPath.contains("\r") or cleanPath.contains("\u0000"):
        return false
    if cleanPath.contains("/../") or cleanPath.ends_with("/..") or cleanPath.contains("\\"):
        return false
    cleanPath.starts_with(cleanRoot + "/") and cleanPath.ends_with(".md")

fn parseAgentFile(sourcePath: text, content: text) -> AgentFileParseResult:
    if content.trim() == "":
        return AgentFileParseResult.failure("agent file is empty")
    if not sourcePath.trim().ends_with(".md"):
        return AgentFileParseResult.failure("agent file must be markdown")

    val fallbackName = nameFromAgentFilename(sourcePath)
    var name = fallbackName
    var description = ""
    var model = ""
    var bodyStart = 0
    val normalized = content.replace("\r", "")
    val lines = normalized.split("\n")
    if lines.len() > 0 and lines[0].trim() == "---":
        var i = 1
        var closed = false
        while i < lines.len():
            val line = lines[i]
            if line.trim() == "---":
                closed = true
                bodyStart = i + 1
                i = lines.len()
            else:
                val key = agentFrontmatterKey(line)
                val value = agentFrontmatterValue(line)
                if key == "name":
                    name = value
                elif key == "description":
                    description = value
                elif key == "model":
                    model = value
            i = i + 1
        if not closed:
            return AgentFileParseResult.failure("frontmatter is not closed")

    if not isValidAgentName(name):
        return AgentFileParseResult.failure("invalid agent name")
    if not isValidAgentModel(model):
        return AgentFileParseResult.failure("invalid agent model")
    AgentFileParseResult.success(AgentFileMetadata.new(name, description, model, sourcePath), joinAgentLines(lines, bodyStart))

fn formatAgentFile(metadata: AgentFileMetadata, body: text) -> text:
    if not isValidAgentName(metadata.name):
        return ""
    if not isValidAgentModel(metadata.model):
        return ""
    var out = "---\n"
    out = out + "name: " + metadata.name + "\n"
    if metadata.description != "":
        out = out + "description: " + metadata.description + "\n"
    if metadata.model != "":
        out = out + "model: " + metadata.model + "\n"
    out = out + "---\n"
    if body != "":
        out = out + body.trim() + "\n"
    out

fn agentFileSourceHelper(name: text) -> text:
    "agentFileUtils:" + deriveAgentMetadataFilename(name)

fn agentFileUtilsSourceLinesModeled() -> i64:
    272

fn agentFileUtilsSourceHelpersModeled() -> text:
    "validation,slug,filename,path,parse,format,source"

fn nameFromAgentFilename(path: text) -> text:
    val trimmed = path.trim()
    val clean = trimmed.replace("\\", "/")
    val parts = clean.split("/")
    if parts.len() == 0:
        return ""
    var file = parts[parts.len() - 1]
    if file.ends_with(".md"):
        file = file.slice(0, file.len() - 3)
    file

fn agentFrontmatterKey(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    line.slice(0, colon).trim().lower()

fn agentFrontmatterValue(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    val raw = line.slice(colon + 1, line.len())
    val trimmed = raw.trim()
    if trimmed.starts_with("\"") and trimmed.ends_with("\"") and trimmed.len() >= 2:
        return trimmed.slice(1, trimmed.len() - 1)
    trimmed

fn joinAgentLines(lines: [text], start: i64) -> text:
    var out = ""
    var i = start
    while i < lines.len():
        if i > start:
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    out.trim()

fn trimTrailingSlash(value: text) -> text:
    var out = value
    while out.ends_with("/") and out.len() > 1:
        out = out.slice(0, out.len() - 1)
    out

fn trimAgentSlugDash(value: text) -> text:
    var out = value
    while out.starts_with("-"):
        out = out.slice(1, out.len())
    while out.ends_with("-"):
        out = out.slice(0, out.len() - 1)
    out

fn isAgentSlugChar(ch: text) -> bool:
    "abcdefghijklmnopqrstuvwxyz0123456789-".contains(ch)

