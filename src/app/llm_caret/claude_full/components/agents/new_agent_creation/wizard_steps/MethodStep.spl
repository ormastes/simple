"""
Importable alias for Claude full MethodStep parity.
"""

fn normalizeAgentMethod(raw: text) -> text:
    val value = raw.trim().to_lower()
    if value == "manual" or value == "generate":
        return value
    "manual"

fn methodStepSummary(raw: text) -> text:
    "Method: " + normalizeAgentMethod(raw)

fn methodStepSourceLinesModeled() -> i64:
    79
