"""
Importable alias for Claude full ColorStep parity.
"""

fn colorStepTitle() -> text:
    "Choose a color"

fn colorStepSelectedLabel(color: text) -> text:
    "Selected " + color.trim().to_lower()

fn colorStepCanContinue(color: text) -> bool:
    color.trim() != ""

fn colorStepSourceLinesModeled() -> i64:
    83
