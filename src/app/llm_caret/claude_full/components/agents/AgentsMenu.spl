"""
Minimal AgentsMenu parity model for Claude full agents UI.
"""

class AgentsMenuItem:
    id: text
    name: text
    description: text
    source: text
    model: text
    enabled: bool
    tools: [text]

impl AgentsMenuItem:
    static fn new(id: text, name: text, description: text, source: text, model: text, enabled: bool, tools: [text]) -> AgentsMenuItem:
        AgentsMenuItem(id: id, name: name, description: description, source: normalizeAgentsMenuSource(source), model: model, enabled: enabled, tools: tools)

    me matches(query: text, sourceFilter: text) -> bool:
        val normalizedSource = normalizeAgentsMenuSourceFilter(sourceFilter)
        if normalizedSource != "all" and me.source != normalizedSource:
            return false
        val q = query.trim().lower()
        if q == "":
            return true
        me.id.lower().contains(q) or me.name.lower().contains(q) or me.description.lower().contains(q) or me.source.lower().contains(q) or me.model.lower().contains(q) or joinAgentsMenuText(me.tools, " ").lower().contains(q)

    me statusLabel() -> text:
        if me.enabled:
            return "enabled"
        "disabled"

    me actionSummary() -> text:
        agentsMenuActionSummary(me)

class AgentsMenuState:
    isOpen: bool
    query: text
    sourceFilter: text
    selectedId: text
    lastAction: text

impl AgentsMenuState:
    static fn new(isOpen: bool, query: text, sourceFilter: text, selectedId: text, lastAction: text) -> AgentsMenuState:
        AgentsMenuState(isOpen: isOpen, query: query, sourceFilter: normalizeAgentsMenuSourceFilter(sourceFilter), selectedId: selectedId, lastAction: lastAction)

    static fn closed() -> AgentsMenuState:
        AgentsMenuState.new(false, "", "all", "", "")

    me open() -> AgentsMenuState:
        AgentsMenuState.new(true, me.query, me.sourceFilter, me.selectedId, "open")

    me close() -> AgentsMenuState:
        AgentsMenuState.new(false, me.query, me.sourceFilter, me.selectedId, "close")

    me toggle() -> AgentsMenuState:
        if me.isOpen:
            return me.close()
        me.open()

    me withQuery(query: text) -> AgentsMenuState:
        AgentsMenuState.new(me.isOpen, query, me.sourceFilter, me.selectedId, "filter")

    me withSourceFilter(sourceFilter: text) -> AgentsMenuState:
        AgentsMenuState.new(me.isOpen, me.query, sourceFilter, me.selectedId, "filter")

    me withSelectedId(selectedId: text) -> AgentsMenuState:
        AgentsMenuState.new(me.isOpen, me.query, me.sourceFilter, selectedId, "select")

class AgentsMenuModel:
    items: [AgentsMenuItem]
    state: AgentsMenuState

impl AgentsMenuModel:
    static fn new(items: [AgentsMenuItem], state: AgentsMenuState) -> AgentsMenuModel:
        AgentsMenuModel(items: items, state: normalizeAgentsMenuState(items, state))

    me open() -> AgentsMenuModel:
        AgentsMenuModel.new(me.items, me.state.open())

    me close() -> AgentsMenuModel:
        AgentsMenuModel.new(me.items, me.state.close())

    me toggle() -> AgentsMenuModel:
        AgentsMenuModel.new(me.items, me.state.toggle())

    me filter(query: text, sourceFilter: text) -> AgentsMenuModel:
        AgentsMenuModel.new(me.items, AgentsMenuState.new(me.state.isOpen, query, sourceFilter, me.state.selectedId, "filter"))

    me select(id: text) -> AgentsMenuModel:
        AgentsMenuModel.new(me.items, me.state.withSelectedId(id))

    me visibleItems() -> [AgentsMenuItem]:
        visibleAgentsMenuItems(me.items, me.state)

    me selectedItem() -> AgentsMenuItem?:
        findAgentsMenuItemById(me.visibleItems(), me.state.selectedId)

    me actionSummary() -> text:
        renderAgentsMenuActionSummary(me)

    me render() -> text:
        renderAgentsMenu(me.items, me.state)

fn sampleAgentsMenuItems() -> [AgentsMenuItem]:
    [
        AgentsMenuItem.new("review", "Review", "Review diffs and regressions", "project", "sonnet", true, ["Read", "Grep"]),
        AgentsMenuItem.new("qa", "QA", "Run focused test plans", "user", "haiku", true, ["Bash"]),
        AgentsMenuItem.new("docs", "Docs", "Draft release notes", "builtin", "sonnet", false, ["Read", "Write"])
    ]

fn createAgentsMenu(items: [AgentsMenuItem]) -> AgentsMenuModel:
    AgentsMenuModel.new(items, AgentsMenuState.closed())

fn openAgentsMenu(items: [AgentsMenuItem]) -> AgentsMenuModel:
    AgentsMenuModel.new(items, AgentsMenuState.closed().open())

fn normalizeAgentsMenuState(items: [AgentsMenuItem], state: AgentsMenuState) -> AgentsMenuState:
    val visible = sortAgentsMenuItems(filterAgentsMenuItems(items, state.query, state.sourceFilter))
    if visible.len() == 0:
        return AgentsMenuState.new(state.isOpen, state.query, state.sourceFilter, "", state.lastAction)
    if state.selectedId != "" and findAgentsMenuItemById(visible, state.selectedId) != nil:
        return AgentsMenuState.new(state.isOpen, state.query, state.sourceFilter, state.selectedId, state.lastAction)
    AgentsMenuState.new(state.isOpen, state.query, state.sourceFilter, visible[0].id, state.lastAction)

fn visibleAgentsMenuItems(items: [AgentsMenuItem], state: AgentsMenuState) -> [AgentsMenuItem]:
    sortAgentsMenuItems(filterAgentsMenuItems(items, state.query, state.sourceFilter))

fn filterAgentsMenuItems(items: [AgentsMenuItem], query: text, sourceFilter: text) -> [AgentsMenuItem]:
    var out: [AgentsMenuItem] = []
    var i = 0
    while i < items.len():
        if items[i].matches(query, sourceFilter):
            out.push(items[i])
        i = i + 1
    out

fn sortAgentsMenuItems(items: [AgentsMenuItem]) -> [AgentsMenuItem]:
    var out = items
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if agentsMenuSortKey(out[i + 1]) < agentsMenuSortKey(out[i]):
                val tmp = out[i]
                out[i] = out[i + 1]
                out[i + 1] = tmp
                changed = true
            i = i + 1
    out

fn agentsMenuSortKey(item: AgentsMenuItem) -> text:
    item.name.lower() + "|" + item.id.lower()

fn findAgentsMenuItemById(items: [AgentsMenuItem], id: text) -> AgentsMenuItem?:
    var i = 0
    while i < items.len():
        if items[i].id == id:
            return items[i]
        i = i + 1
    nil

fn selectNextAgentsMenuItem(items: [AgentsMenuItem], state: AgentsMenuState) -> AgentsMenuState:
    val visible = visibleAgentsMenuItems(items, state)
    if visible.len() == 0:
        return state.withSelectedId("")
    val index = selectedAgentsMenuIndex(visible, state.selectedId)
    if index + 1 < visible.len():
        return state.withSelectedId(visible[index + 1].id)
    state.withSelectedId(visible[0].id)

fn selectPreviousAgentsMenuItem(items: [AgentsMenuItem], state: AgentsMenuState) -> AgentsMenuState:
    val visible = visibleAgentsMenuItems(items, state)
    if visible.len() == 0:
        return state.withSelectedId("")
    val index = selectedAgentsMenuIndex(visible, state.selectedId)
    if index > 0:
        return state.withSelectedId(visible[index - 1].id)
    state.withSelectedId(visible[visible.len() - 1].id)

fn selectedAgentsMenuIndex(items: [AgentsMenuItem], selectedId: text) -> i64:
    var i = 0
    while i < items.len():
        if items[i].id == selectedId:
            return i
        i = i + 1
    0

fn renderAgentsMenu(items: [AgentsMenuItem], state: AgentsMenuState) -> text:
    if not state.isOpen:
        return "Agents menu closed"
    val visible = visibleAgentsMenuItems(items, state)
    if visible.len() == 0:
        return agentsMenuEmptyMessage(state)
    val normalized = normalizeAgentsMenuState(items, state)
    var lines: [text] = [renderAgentsMenuHeader(visible.len(), items.len(), normalized)]
    var i = 0
    while i < visible.len():
        lines.push(renderAgentsMenuRow(visible[i], visible[i].id == normalized.selectedId))
        i = i + 1
    joinAgentsMenuText(lines, "\n")

fn renderAgentsMenuHeader(visibleCount: i64, totalCount: i64, state: AgentsMenuState) -> text:
    "Agents menu " + visibleCount.to_text() + "/" + totalCount.to_text() + " · " + agentsMenuSourceDisplayName(state.sourceFilter) + renderAgentsMenuQueryBadge(state.query)

fn renderAgentsMenuQueryBadge(query: text) -> text:
    val q = query.trim()
    if q == "":
        return ""
    " · search:" + q

fn renderAgentsMenuRow(item: AgentsMenuItem, selected: bool) -> text:
    val marker = if selected: ">" else: " "
    marker + " " + item.name + " [" + agentsMenuSourceDisplayName(item.source) + "] " + item.statusLabel() + " · " + item.model + " · " + item.description

fn agentsMenuEmptyMessage(state: AgentsMenuState) -> text:
    if state.query.trim() == "" and normalizeAgentsMenuSourceFilter(state.sourceFilter) == "all":
        return "No agents configured"
    "No agents match " + agentsMenuFilterSummary(state)

fn agentsMenuFilterSummary(state: AgentsMenuState) -> text:
    var parts: [text] = []
    if state.query.trim() != "":
        parts.push("search \"" + state.query.trim() + "\"")
    if normalizeAgentsMenuSourceFilter(state.sourceFilter) != "all":
        parts.push("source " + agentsMenuSourceDisplayName(state.sourceFilter))
    joinAgentsMenuText(parts, " and ")

fn agentsMenuActionSummary(item: AgentsMenuItem) -> text:
    if item.enabled:
        return "select " + item.id + " | run enabled | edit enabled"
    "select " + item.id + " | run disabled | edit enabled"

fn renderAgentsMenuActionSummary(model: AgentsMenuModel) -> text:
    if not model.state.isOpen:
        return "closed"
    if val Some(item) = model.selectedItem():
        return item.actionSummary()
    "no selection"

fn normalizeAgentsMenuSource(source: text) -> text:
    val s = source.trim().lower()
    if s == "project":
        return "project"
    if s == "user":
        return "user"
    if s == "builtin" or s == "built-in":
        return "builtin"
    "project"

fn normalizeAgentsMenuSourceFilter(sourceFilter: text) -> text:
    val s = sourceFilter.trim().lower()
    if s == "" or s == "all":
        return "all"
    if s == "project":
        return "project"
    if s == "user":
        return "user"
    if s == "builtin" or s == "built-in":
        return "builtin"
    "all"

fn agentsMenuSourceDisplayName(source: text) -> text:
    val s = normalizeAgentsMenuSourceFilter(source)
    if s == "project":
        return "Project"
    if s == "user":
        return "User"
    if s == "builtin":
        return "Built-in"
    "All"

fn agentsMenuSourceOptions() -> [text]:
    ["all", "project", "user", "builtin"]

fn agentsMenuModeledSourceFile() -> text:
    "src/components/agents/AgentsMenu.tsx"

fn agentsMenuModeledSourceHelper() -> text:
    "getAgentDefinitionsWithOverrides"

fn agentsMenuModeledMenuHook() -> text:
    "useAgentsMenu"

fn agentsMenuModeledActionCount() -> i64:
    3

fn agentsMenuSourceLinesModeled() -> i64:
    799

fn joinAgentsMenuText(values: [text], separator: text) -> text:
    if values.len() == 0:
        return ""
    var out = values[0]
    var i = 1
    while i < values.len():
        out = out + separator + values[i]
        i = i + 1
    out

