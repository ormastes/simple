"""
Minimal AgentEditor parity model for Claude full agents UI.
"""

class AgentEditorDraft:
    name: text
    description: text
    model: text
    tools: [text]
    prompt: text
    enabled: bool

impl AgentEditorDraft:
    static fn new(name: text, description: text, model: text, tools: [text], prompt: text, enabled: bool) -> AgentEditorDraft:
        AgentEditorDraft(name: name, description: description, model: model, tools: tools, prompt: prompt, enabled: enabled)

    me validate() -> [text]:
        var errors: [text] = []
        if me.name.len() == 0:
            errors = errors + ["name is required"]
        if me.model.len() == 0:
            errors = errors + ["model is required"]
        if me.prompt.len() == 0:
            errors = errors + ["prompt is required"]
        errors

    me canSave() -> bool:
        me.validate().len() == 0

    me saveSummary() -> AgentEditorSaveSummary:
        val valid = me.canSave()
        val status = if valid: "saved" else: "blocked"
        AgentEditorSaveSummary.new(status, valid, me.name, me.model, me.tools.len(), if me.enabled: "enabled" else: "disabled", me.validate())

class AgentEditorSaveSummary:
    status: text
    saved: bool
    name: text
    model: text
    toolCount: i64
    enabledLabel: text
    errors: [text]

impl AgentEditorSaveSummary:
    static fn new(status: text, saved: bool, name: text, model: text, toolCount: i64, enabledLabel: text, errors: [text]) -> AgentEditorSaveSummary:
        AgentEditorSaveSummary(status: status, saved: saved, name: name, model: model, toolCount: toolCount, enabledLabel: enabledLabel, errors: errors)

    me render() -> text:
        if not me.saved:
            return me.status + " | " + joinEditorErrors(me.errors)
        me.status + " | " + me.name + " | " + me.model + " | tools=" + me.toolCount.to_text() + " | " + me.enabledLabel

fn joinEditorErrors(errors: [text]) -> text:
    if errors.len() == 0:
        return "none"
    var out = errors[0]
    var i = 1
    while i < errors.len():
        out = out + ", " + errors[i]
        i = i + 1
    out

fn agentEditorDraft(name: text, description: text, model: text, tools: [text], prompt: text, enabled: bool) -> AgentEditorDraft:
    AgentEditorDraft.new(name, description, model, tools, prompt, enabled)

fn agentEditorEmptyDraft() -> AgentEditorDraft:
    AgentEditorDraft.new("", "", "", [], "", true)

fn agentEditorSourceLinesModeled() -> i64:
    177

fn agentEditorRequiredFieldCount() -> i64:
    3

