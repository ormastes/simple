fn agentDisplayName(name: text) -> text:
    val trimmed = name.trim()
    if trimmed == "":
        return "Unnamed agent"
    trimmed

fn agentStatusLabel(active: bool) -> text:
    if active:
        return "active"
    "inactive"

fn agentUtilsSourceLinesModeled() -> i64:
    18
