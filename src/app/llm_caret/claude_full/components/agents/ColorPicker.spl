"""
Claude full ColorPicker component parity.
"""

fn availableAgentColors() -> [text]:
    ["red", "orange", "yellow", "green", "blue", "purple", "pink", "gray"]

fn normalizeAgentColor(raw: text) -> text:
    val color = raw.trim().to_lower()
    if containsAgentColor(color):
        return color
    "gray"

fn containsAgentColor(color: text) -> bool:
    val colors = availableAgentColors()
    var i = 0
    while i < colors.len():
        if colors[i] == color:
            return true
        i = i + 1
    false

fn colorPickerLabel(raw: text) -> text:
    "Color: " + normalizeAgentColor(raw)

fn colorPickerSourceLinesModeled() -> i64:
    111
