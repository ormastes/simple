class AgentListItem:
    id: text
    name: text
    description: text
    source: text
    model: text
    status: text
    tools: [text]
    isDefault: bool
    isAvailable: bool

impl AgentListItem:
    static fn new(id: text, name: text, description: text, source: text, model: text, status: text, tools: [text], isDefault: bool, isAvailable: bool) -> AgentListItem:
        AgentListItem(id: id, name: name, description: description, source: source, model: model, status: status, tools: tools, isDefault: isDefault, isAvailable: isAvailable)

    me matches(query: text, sourceFilter: text) -> bool:
        val q = query.trim().lower()
        if sourceFilter != "" and sourceFilter != "all" and me.source != sourceFilter:
            return false
        if q == "":
            return true
        me.name.lower().contains(q) or me.description.lower().contains(q) or me.model.lower().contains(q) or me.source.lower().contains(q) or joinText(me.tools, " ").lower().contains(q)

    me summary() -> text:
        renderAgentSummary(me)

class AgentsListState:
    query: text
    sourceFilter: text
    selectedId: text

impl AgentsListState:
    static fn new(query: text, sourceFilter: text, selectedId: text) -> AgentsListState:
        AgentsListState(query: query, sourceFilter: sourceFilter, selectedId: selectedId)

    static fn empty() -> AgentsListState:
        AgentsListState.new("", "all", "")

    me withQuery(query: text) -> AgentsListState:
        AgentsListState.new(query, me.sourceFilter, me.selectedId)

    me withSourceFilter(sourceFilter: text) -> AgentsListState:
        AgentsListState.new(me.query, sourceFilter, me.selectedId)

    me withSelectedId(selectedId: text) -> AgentsListState:
        AgentsListState.new(me.query, me.sourceFilter, selectedId)

class AgentsListModel:
    items: [AgentListItem]
    state: AgentsListState

impl AgentsListModel:
    static fn new(items: [AgentListItem], state: AgentsListState) -> AgentsListModel:
        AgentsListModel(items: items, state: normalizeAgentsListState(items, state))

    me visibleItems() -> [AgentListItem]:
        visibleAgents(me.items, me.state)

    me selectedItem() -> AgentListItem?:
        findAgentById(me.visibleItems(), me.state.selectedId)

    me render() -> text:
        renderAgentsList(me.items, me.state)

fn sampleAgentsListItems() -> [AgentListItem]:
    [
        AgentListItem.new("agent-review", "Review", "Reviews diffs and flags regressions", "project", "sonnet", "ready", ["Read", "Grep"], true, true),
        AgentListItem.new("agent-qa", "QA", "Runs focused test plans", "user", "haiku", "idle", ["Bash"], false, true),
        AgentListItem.new("agent-docs", "Docs", "Writes release notes and manuals", "builtin", "sonnet", "disabled", ["Read", "Write"], false, false)
    ]

fn createAgentsList(items: [AgentListItem]) -> AgentsListModel:
    AgentsListModel.new(items, AgentsListState.empty())

fn normalizeAgentsListState(items: [AgentListItem], state: AgentsListState) -> AgentsListState:
    val visible = sortAgentsByName(filterAgents(items, state.query, state.sourceFilter))
    if visible.len() == 0:
        return AgentsListState.new(state.query, normalizeSourceFilter(state.sourceFilter), "")
    if state.selectedId != "" and findAgentById(visible, state.selectedId) != nil:
        return AgentsListState.new(state.query, normalizeSourceFilter(state.sourceFilter), state.selectedId)
    AgentsListState.new(state.query, normalizeSourceFilter(state.sourceFilter), visible[0].id)

fn visibleAgents(items: [AgentListItem], state: AgentsListState) -> [AgentListItem]:
    sortAgentsByName(filterAgents(items, state.query, normalizeSourceFilter(state.sourceFilter)))

fn filterAgents(items: [AgentListItem], query: text, sourceFilter: text) -> [AgentListItem]:
    var out: [AgentListItem] = []
    val normalizedSource = normalizeSourceFilter(sourceFilter)
    var i = 0
    while i < items.len():
        if items[i].matches(query, normalizedSource):
            out.push(items[i])
        i = i + 1
    out

fn sortAgentsByName(items: [AgentListItem]) -> [AgentListItem]:
    var out = items
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if agentSortKey(out[i + 1]) < agentSortKey(out[i]):
                val tmp = out[i]
                out[i] = out[i + 1]
                out[i + 1] = tmp
                changed = true
            i = i + 1
    out

fn agentSortKey(item: AgentListItem) -> text:
    item.name.lower() + "|" + item.id.lower()

fn findAgentById(items: [AgentListItem], id: text) -> AgentListItem?:
    var i = 0
    while i < items.len():
        if items[i].id == id:
            return items[i]
        i = i + 1
    nil

fn selectNextAgent(items: [AgentListItem], state: AgentsListState) -> AgentsListState:
    val visible = visibleAgents(items, state)
    if visible.len() == 0:
        return state.withSelectedId("")
    val index = selectedAgentIndex(visible, state.selectedId)
    if index + 1 < visible.len():
        return state.withSelectedId(visible[index + 1].id)
    state.withSelectedId(visible[0].id)

fn selectPreviousAgent(items: [AgentListItem], state: AgentsListState) -> AgentsListState:
    val visible = visibleAgents(items, state)
    if visible.len() == 0:
        return state.withSelectedId("")
    val index = selectedAgentIndex(visible, state.selectedId)
    if index > 0:
        return state.withSelectedId(visible[index - 1].id)
    state.withSelectedId(visible[visible.len() - 1].id)

fn selectedAgentIndex(items: [AgentListItem], selectedId: text) -> i64:
    var i = 0
    while i < items.len():
        if items[i].id == selectedId:
            return i
        i = i + 1
    0

fn renderAgentsList(items: [AgentListItem], state: AgentsListState) -> text:
    val visible = visibleAgents(items, state)
    if visible.len() == 0:
        return renderAgentsEmptyState(state)
    val normalized = normalizeAgentsListState(items, state)
    var lines: [text] = [renderAgentsListHeader(visible.len(), items.len(), normalized)]
    var i = 0
    while i < visible.len():
        lines.push(renderAgentRow(visible[i], visible[i].id == normalized.selectedId))
        i = i + 1
    joinText(lines, "\n")

fn renderAgentsListHeader(visibleCount: i64, totalCount: i64, state: AgentsListState) -> text:
    val filterLabel = if normalizeSourceFilter(state.sourceFilter) == "all": "all sources" else: sourceDisplayName(state.sourceFilter)
    "Agents " + visibleCount.to_text() + "/" + totalCount.to_text() + " · " + filterLabel + renderQueryBadge(state.query)

fn renderQueryBadge(query: text) -> text:
    val trimmed = query.trim()
    if trimmed == "":
        return ""
    " · search:" + trimmed

fn renderAgentRow(item: AgentListItem, selected: bool) -> text:
    val marker = if selected: ">" else: " "
    marker + " " + item.name + " [" + sourceDisplayName(item.source) + "] " + availabilityLabel(item) + " · " + renderAgentSummary(item)

fn renderAgentSummary(item: AgentListItem) -> text:
    var parts: [text] = []
    if item.description != "":
        parts.push(item.description)
    if item.model != "":
        parts.push("model " + item.model)
    if item.status != "":
        parts.push("status " + item.status)
    if item.tools.len() > 0:
        parts.push("tools " + joinText(item.tools, ","))
    if item.isDefault:
        parts.push("default")
    joinText(parts, " · ")

fn renderAgentsEmptyState(state: AgentsListState) -> text:
    val source = normalizeSourceFilter(state.sourceFilter)
    if state.query.trim() == "" and source == "all":
        return agentsListEmptyMessage()
    "No agents match " + emptyStateFilterSummary(state)

fn emptyStateFilterSummary(state: AgentsListState) -> text:
    var parts: [text] = []
    if state.query.trim() != "":
        parts.push("search \"" + state.query.trim() + "\"")
    if normalizeSourceFilter(state.sourceFilter) != "all":
        parts.push("source " + sourceDisplayName(state.sourceFilter))
    joinText(parts, " and ")

fn agentsListEmptyMessage() -> text:
    "No agents configured"

fn availabilityLabel(item: AgentListItem) -> text:
    if item.isAvailable:
        return item.status
    "unavailable"

fn normalizeSourceFilter(sourceFilter: text) -> text:
    val source = sourceFilter.trim().lower()
    if source == "" or source == "all":
        return "all"
    if source == "project":
        return "project"
    if source == "user":
        return "user"
    if source == "builtin" or source == "built-in":
        return "builtin"
    "all"

fn sourceDisplayName(source: text) -> text:
    val normalized = normalizeSourceFilter(source)
    if normalized == "project":
        return "Project"
    if normalized == "user":
        return "User"
    if normalized == "builtin":
        return "Built-in"
    "All"

fn sourceBadge(source: text) -> text:
    "[" + sourceDisplayName(source) + "]"

fn sourceOptions() -> [text]:
    ["all", "project", "user", "builtin"]

fn agentsListModeledSourceFile() -> text:
    "src/components/agents/AgentsList.tsx"

fn agentsListModeledSourceHelper() -> text:
    "getAgentDefinitionsWithOverrides"

fn agentsListModeledSelectionHelper() -> text:
    "useListSelection"

fn agentsListModeledFilterHelper() -> text:
    "filterAgents"

fn agentsListModeledSortHelper() -> text:
    "sortAgentsByName"

fn agentsListSourceLinesModeled() -> i64:
    439

fn joinText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

