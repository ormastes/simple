"""
Claude full assistant text message parity model.
"""

const ASSISTANT_TEXT_MESSAGE_SOURCE_LINES = 269
const ASSISTANT_TEXT_MAX_API_ERROR_CHARS = 1000

class AssistantTextRender:
    visible: bool
    mode: text
    text: text
    color: text
    height: i64
    margin_top: i64
    selected_background: bool
    show_dot: bool
    expandable: bool

impl AssistantTextRender:
    static fn hidden() -> AssistantTextRender:
        AssistantTextRender(visible: false, mode: "hidden", text: "", color: "", height: 0, margin_top: 0, selected_background: false, show_dot: false, expandable: false)

    static fn new(mode: text, text: text, color: text, height: i64, marginTop: i64, selected: bool, showDot: bool, expandable: bool) -> AssistantTextRender:
        AssistantTextRender(visible: true, mode: mode, text: text, color: color, height: height, margin_top: marginTop, selected_background: selected, show_dot: showDot, expandable: expandable)

fn assistantTextIsEmpty(text: text) -> bool:
    text.trim() == ""

fn assistantTextIsRateLimit(text: text) -> bool:
    text.contains("rate limit") or text.contains("Rate limit")

fn assistantTextStartsWithApiError(text: text) -> bool:
    val prefix = "API Error"
    if text.len() < prefix.len():
        return false
    text.slice(0, prefix.len()) == prefix

fn assistantTextTruncateApiError(text: text, verbose: bool) -> text:
    if verbose:
        return text
    if text.len() <= ASSISTANT_TEXT_MAX_API_ERROR_CHARS:
        return text
    text.slice(0, ASSISTANT_TEXT_MAX_API_ERROR_CHARS) + "..."

fn assistantTextMessage(text: text, addMargin: bool, shouldShowDot: bool, verbose: bool, isSelected: bool) -> AssistantTextRender:
    if assistantTextIsEmpty(text):
        return AssistantTextRender.hidden()
    if text == "NO_RESPONSE_REQUESTED":
        return AssistantTextRender.hidden()
    if assistantTextIsRateLimit(text):
        return AssistantTextRender.new("rate-limit", text, "warning", 1, if addMargin: 1 else: 0, isSelected, false, false)
    if text == "PROMPT_TOO_LONG":
        return AssistantTextRender.new("prompt-too-long", "Context limit reached - /compact or /clear to continue", "error", 1, 0, false, false, false)
    if text == "CREDIT_BALANCE_TOO_LOW":
        return AssistantTextRender.new("credit-low", "Credit balance too low - Add funds: https://platform.claude.com/settings/billing", "error", 1, 0, false, false, false)
    if text == "INVALID_API_KEY":
        return AssistantTextRender.new("invalid-api-key", text, "error", 1, 0, false, false, false)
    if text == "TOKEN_REVOKED":
        return AssistantTextRender.new("token-revoked", text, "error", 1, 0, false, false, false)
    if text == "API_TIMEOUT":
        return AssistantTextRender.new("timeout", text, "error", 1, 0, false, false, false)
    if text == "CUSTOM_OFF_SWITCH":
        return AssistantTextRender.new("custom-off-switch", "We are experiencing high demand for Opus 4.", "error", 0, 0, false, false, false)
    if text == "USER_ABORT":
        return AssistantTextRender.new("interrupted", "Interrupted by user", "error", 1, 0, false, false, false)
    if assistantTextStartsWithApiError(text):
        val truncated = assistantTextTruncateApiError(text, verbose)
        return AssistantTextRender.new("api-error", truncated, "error", 0, 0, false, false, truncated.len() < text.len())
    AssistantTextRender.new("markdown", text, "text", 0, if addMargin: 1 else: 0, isSelected, shouldShowDot, false)

fn assistantTextMessageSourceLinesModeled() -> i64:
    ASSISTANT_TEXT_MESSAGE_SOURCE_LINES
