"""
Claude full user bash output message parity model.
"""

use app.llm_caret.claude_full.components.messages.UserBashInputMessage.{extractTaggedValue}

const USER_BASH_OUTPUT_MESSAGE_SOURCE_LINES = 53

class UserBashOutputRender:
    stdout: text
    stderr: text
    verbose: bool
    wrapped_in_bash_tool_result: bool

impl UserBashOutputRender:
    static fn new(stdout: text, stderr: text, verbose: bool) -> UserBashOutputRender:
        UserBashOutputRender(stdout: stdout, stderr: stderr, verbose: verbose, wrapped_in_bash_tool_result: true)

fn userBashOutputStdout(content: text) -> text:
    val rawStdout = extractTaggedValue(content, "bash-stdout")
    val persisted = extractTaggedValue(rawStdout, "persisted-output")
    if persisted != "":
        return persisted
    rawStdout

fn userBashOutputStderr(content: text) -> text:
    extractTaggedValue(content, "bash-stderr")

fn userBashOutputMessage(content: text, verbose: bool) -> UserBashOutputRender:
    UserBashOutputRender.new(userBashOutputStdout(content), userBashOutputStderr(content), verbose)

fn userBashOutputSummary(render: UserBashOutputRender) -> text:
    "stdout:" + render.stdout + "|stderr:" + render.stderr

fn userBashOutputMessageSourceLinesModeled() -> i64:
    USER_BASH_OUTPUT_MESSAGE_SOURCE_LINES
