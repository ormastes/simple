"""
Claude full user channel message parity model.
"""

const USER_CHANNEL_MESSAGE_SOURCE_LINES = 136
const USER_CHANNEL_MESSAGE_TAG = "channel"
const USER_CHANNEL_MESSAGE_ARROW = "←"
const USER_CHANNEL_MESSAGE_TRUNCATE_AT = 60

class UserChannelRender:
    visible: bool
    source: text
    display_source: text
    user: text
    body: text
    truncated_body: text
    arrow: text
    margin_top: i64
    dim_source: bool
    arrow_color: text

impl UserChannelRender:
    static fn hidden() -> UserChannelRender:
        UserChannelRender(visible: false, source: "", display_source: "", user: "", body: "", truncated_body: "", arrow: "", margin_top: 0, dim_source: false, arrow_color: "")

    static fn new(source: text, user: text, body: text, truncatedBody: text, marginTop: i64) -> UserChannelRender:
        UserChannelRender(visible: true, source: source, display_source: userChannelDisplayServerName(source), user: user, body: body, truncated_body: truncatedBody, arrow: USER_CHANNEL_MESSAGE_ARROW, margin_top: marginTop, dim_source: true, arrow_color: "suggestion")

fn userChannelIsWhitespace(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn userChannelSkipWhitespace(value: text, start: i64) -> i64:
    var i = start
    while i < value.len() and userChannelIsWhitespace(value.slice(i, i + 1)):
        i = i + 1
    i

fn userChannelFindFrom(value: text, needle: text, start: i64) -> i64:
    if needle == "":
        return start
    var i = start
    while i + needle.len() <= value.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn userChannelAttrBoundary(attrs: text, pos: i64) -> bool:
    if pos <= 0:
        return true
    val prev = attrs.slice(pos - 1, pos)
    userChannelIsWhitespace(prev) or prev == "'" or prev == "\"" or prev == "/" or prev == "<"

fn userChannelExtractUser(attrs: text) -> text:
    val marker = "user=\""
    var start = 0
    while start < attrs.len():
        val pos = userChannelFindFrom(attrs, marker, start)
        if pos < 0:
            return ""
        if userChannelAttrBoundary(attrs, pos):
            val valueStart = pos + marker.len()
            val rest = attrs.slice(valueStart, attrs.len())
            val end = rest.find("\"")
            if end < 0:
                return ""
            return rest.slice(0, end)
        start = pos + marker.len()
    ""

fn userChannelDisplayServerName(name: text) -> text:
    val parts = name.split(":")
    if parts.len() == 0:
        return name
    parts[parts.len() - 1]

fn userChannelCollapseBody(content: text) -> text:
    val trimmed = content.trim()
    var out = ""
    var inSpace = false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if userChannelIsWhitespace(ch):
            if not inSpace and out != "":
                out = out + " "
            inSpace = true
        else:
            out = out + ch
            inSpace = false
        i = i + 1
    out

fn userChannelTruncateToWidth(value: text, width: i64) -> text:
    if value.len() <= width:
        return value
    if width <= 1:
        return "…"
    value.slice(0, width - 1) + "…"

fn userChannelMessage(textValue: text, addMargin: bool) -> UserChannelRender:
    val openPrefix = "<" + USER_CHANNEL_MESSAGE_TAG
    val openStart = textValue.find(openPrefix)
    if openStart < 0:
        return UserChannelRender.hidden()
    val sourceStart = userChannelSkipWhitespace(textValue, openStart + openPrefix.len())
    val sourcePrefix = "source=\""
    if sourceStart + sourcePrefix.len() > textValue.len() or textValue.slice(sourceStart, sourceStart + sourcePrefix.len()) != sourcePrefix:
        return UserChannelRender.hidden()
    val sourceValueStart = sourceStart + sourcePrefix.len()
    val afterSource = textValue.slice(sourceValueStart, textValue.len())
    val sourceEndRel = afterSource.find("\"")
    if sourceEndRel < 0:
        return UserChannelRender.hidden()
    val source = afterSource.slice(0, sourceEndRel)
    val sourceEnd = sourceValueStart + sourceEndRel
    val openEnd = userChannelFindFrom(textValue, ">", sourceEnd + 1)
    if openEnd < 0:
        return UserChannelRender.hidden()
    val closeTag = "</" + USER_CHANNEL_MESSAGE_TAG + ">"
    val closeStart = userChannelFindFrom(textValue, closeTag, openEnd + 1)
    if closeStart < 0:
        return UserChannelRender.hidden()
    val attrs = textValue.slice(sourceEnd + 1, openEnd)
    val body = userChannelCollapseBody(textValue.slice(openEnd + 1, closeStart))
    var margin = 0
    if addMargin:
        margin = 1
    UserChannelRender.new(source, userChannelExtractUser(attrs), body, userChannelTruncateToWidth(body, USER_CHANNEL_MESSAGE_TRUNCATE_AT), margin)

fn userChannelMessageLine(render: UserChannelRender) -> text:
    if not render.visible:
        return ""
    var userSuffix = ""
    if render.user != "":
        userSuffix = " · " + render.user
    render.arrow + " " + render.display_source + userSuffix + ": " + render.truncated_body

fn userChannelMessageSourceLinesModeled() -> i64:
    USER_CHANNEL_MESSAGE_SOURCE_LINES
# parity ledger: UserChannelMessage line 136
