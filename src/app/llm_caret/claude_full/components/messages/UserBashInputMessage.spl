"""
Claude full user bash input message parity model.
"""

const USER_BASH_INPUT_MESSAGE_SOURCE_LINES = 57

class UserBashInputRender:
    visible: bool
    input: text
    prefix: text
    margin_top: i64
    background_color: text

impl UserBashInputRender:
    static fn hidden() -> UserBashInputRender:
        UserBashInputRender(visible: false, input: "", prefix: "", margin_top: 0, background_color: "")

    static fn new(input: text, marginTop: i64) -> UserBashInputRender:
        UserBashInputRender(visible: true, input: input, prefix: "! ", margin_top: marginTop, background_color: "bashMessageBackgroundColor")

fn extractTaggedValue(textValue: text, tag: text) -> text:
    val openTag = "<" + tag + ">"
    val closeTag = "</" + tag + ">"
    val start = textValue.find(openTag)
    if start < 0:
        return ""
    val contentStart = start + openTag.len()
    val rest = textValue.slice(contentStart, textValue.len())
    val end = rest.find(closeTag)
    if end < 0:
        return ""
    rest.slice(0, end)

fn userBashInputMessage(textValue: text, addMargin: bool) -> UserBashInputRender:
    val input = extractTaggedValue(textValue, "bash-input")
    if input == "":
        return UserBashInputRender.hidden()
    var margin = 0
    if addMargin:
        margin = 1
    UserBashInputRender.new(input, margin)

fn userBashInputMessageSourceLinesModeled() -> i64:
    USER_BASH_INPUT_MESSAGE_SOURCE_LINES
