"""
Claude full user prompt message parity model.
"""

use app.llm_caret.claude_full.utils.stringUtils.{countCharInString}

const USER_PROMPT_MESSAGE_SOURCE_LINES = 79
const USER_PROMPT_MAX_DISPLAY_CHARS = 10000
const USER_PROMPT_TRUNCATE_HEAD_CHARS = 2500
const USER_PROMPT_TRUNCATE_TAIL_CHARS = 2500
const USER_PROMPT_EMPTY_ERROR = "No content found in user prompt message"

class UserPromptRender:
    visible: bool
    display_text: text
    flex_direction: text
    margin_top: i64
    background_color: text
    padding_right: i64
    use_brief_layout: bool
    timestamp: text
    logged_error: text

impl UserPromptRender:
    static fn hidden(loggedError: text) -> UserPromptRender:
        UserPromptRender(visible: false, display_text: "", flex_direction: "", margin_top: 0, background_color: "", padding_right: 0, use_brief_layout: false, timestamp: "", logged_error: loggedError)

    static fn visible(displayText: text, marginTop: i64, backgroundColor: text, paddingRight: i64, useBriefLayout: bool, timestamp: text) -> UserPromptRender:
        UserPromptRender(visible: true, display_text: displayText, flex_direction: "column", margin_top: marginTop, background_color: backgroundColor, padding_right: paddingRight, use_brief_layout: useBriefLayout, timestamp: timestamp, logged_error: "")

fn userPromptDisplayText(textValue: text) -> text:
    if textValue.len() <= USER_PROMPT_MAX_DISPLAY_CHARS:
        return textValue
    val head = textValue.slice(0, USER_PROMPT_TRUNCATE_HEAD_CHARS)
    val tail = textValue.slice(textValue.len() - USER_PROMPT_TRUNCATE_TAIL_CHARS, textValue.len())
    val hiddenLines = countCharInString(textValue, "\n", USER_PROMPT_TRUNCATE_HEAD_CHARS) - countCharInString(tail, "\n", 0)
    head + "\n... +" + hiddenLines.to_text() + " lines ...\n" + tail

fn userPromptUseBriefLayout(kairosFeatureEnabled: bool, kairosActive: bool, userMsgOptIn: bool, briefEnvEnabled: bool, growthbookBriefEnabled: bool, isBriefOnly: bool, isTranscriptMode: bool, viewingAgentTaskId: text) -> bool:
    if not kairosFeatureEnabled:
        return false
    val briefGate = kairosActive or (userMsgOptIn and (briefEnvEnabled or growthbookBriefEnabled))
    briefGate and isBriefOnly and not isTranscriptMode and viewingAgentTaskId == ""

fn userPromptBackgroundColor(isSelected: bool, useBriefLayout: bool) -> text:
    if isSelected:
        return "messageActionsBackground"
    if useBriefLayout:
        return ""
    "userMessageBackground"

fn userPromptMarginTop(addMargin: bool) -> i64:
    if addMargin:
        return 1
    0

fn userPromptPaddingRight(useBriefLayout: bool) -> i64:
    if useBriefLayout:
        return 0
    1

fn userPromptTimestamp(timestamp: text, useBriefLayout: bool) -> text:
    if useBriefLayout:
        return timestamp
    ""

fn userPromptMessage(textValue: text, addMargin: bool, isTranscriptMode: bool, timestamp: text, kairosFeatureEnabled: bool, kairosActive: bool, userMsgOptIn: bool, briefEnvEnabled: bool, growthbookBriefEnabled: bool, isBriefOnly: bool, viewingAgentTaskId: text, isSelected: bool) -> UserPromptRender:
    val displayText = userPromptDisplayText(textValue)
    if textValue == "":
        return UserPromptRender.hidden(USER_PROMPT_EMPTY_ERROR)
    val useBriefLayout = userPromptUseBriefLayout(kairosFeatureEnabled, kairosActive, userMsgOptIn, briefEnvEnabled, growthbookBriefEnabled, isBriefOnly, isTranscriptMode, viewingAgentTaskId)
    UserPromptRender.visible(displayText, userPromptMarginTop(addMargin), userPromptBackgroundColor(isSelected, useBriefLayout), userPromptPaddingRight(useBriefLayout), useBriefLayout, userPromptTimestamp(timestamp, useBriefLayout))

fn userPromptMessageSourceLinesModeled() -> i64:
    USER_PROMPT_MESSAGE_SOURCE_LINES
