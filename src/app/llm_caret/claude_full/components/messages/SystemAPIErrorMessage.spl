"""
Claude full system API error message parity model.
"""

const SYSTEM_API_ERROR_MESSAGE_SOURCE_LINES = 140
const SYSTEM_API_ERROR_MAX_CHARS = 1000

class SystemAPIErrorRender:
    visible: bool
    formatted_error: text
    displayed_error: text
    truncated: bool
    retry_in_seconds: i64
    retry_unit: text
    retry_line: text
    color: text
    flex_direction: text
    wrapped_in_response: bool
    show_expand_hint: bool

impl SystemAPIErrorRender:
    static fn hidden() -> SystemAPIErrorRender:
        SystemAPIErrorRender(
            visible: false,
            formatted_error: "",
            displayed_error: "",
            truncated: false,
            retry_in_seconds: 0,
            retry_unit: "seconds",
            retry_line: "",
            color: "",
            flex_direction: "",
            wrapped_in_response: false,
            show_expand_hint: false
        )

    static fn new(
        formattedError: text,
        displayedError: text,
        truncated: bool,
        retryInSeconds: i64,
        retryUnit: text,
        retryLine: text
    ) -> SystemAPIErrorRender:
        SystemAPIErrorRender(
            visible: true,
            formatted_error: formattedError,
            displayed_error: displayedError,
            truncated: truncated,
            retry_in_seconds: retryInSeconds,
            retry_unit: retryUnit,
            retry_line: retryLine,
            color: "error",
            flex_direction: "column",
            wrapped_in_response: true,
            show_expand_hint: truncated
        )

fn systemAPIErrorHidden(retryAttempt: i64) -> bool:
    retryAttempt < 4

fn systemAPIErrorCountdownDone(countdownMs: i64, retryInMs: i64) -> bool:
    countdownMs >= retryInMs

fn systemAPIErrorNextCountdownMs(countdownMs: i64) -> i64:
    countdownMs + 1000

fn systemAPIErrorRetrySeconds(retryInMs: i64, countdownMs: i64) -> i64:
    val remainingMs = retryInMs - countdownMs
    if remainingMs <= 0:
        return 0
    (remainingMs + 500) / 1000

fn systemAPIErrorRetryUnit(seconds: i64) -> text:
    if seconds == 1:
        return "second"
    "seconds"

fn systemAPIErrorFormat(errorText: text) -> text:
    errorText

fn systemAPIErrorTruncated(formattedError: text, verbose: bool) -> bool:
    (not verbose) and formattedError.len() > SYSTEM_API_ERROR_MAX_CHARS

fn systemAPIErrorDisplayedError(formattedError: text, verbose: bool) -> text:
    if not systemAPIErrorTruncated(formattedError, verbose):
        return formattedError
    formattedError.slice(0, SYSTEM_API_ERROR_MAX_CHARS) + "..."

fn systemAPIErrorTimeoutHint(apiTimeoutMs: text) -> text:
    if apiTimeoutMs == "":
        return ""
    " · API_TIMEOUT_MS=" + apiTimeoutMs + "ms, try increasing it"

fn systemAPIErrorRetryLine(retryInSeconds: i64, retryAttempt: i64, maxRetries: i64, apiTimeoutMs: text) -> text:
    "Retrying in " + retryInSeconds.to_text() + " " + systemAPIErrorRetryUnit(retryInSeconds) + "... (attempt " + retryAttempt.to_text() + "/" + maxRetries.to_text() + ")" + systemAPIErrorTimeoutHint(apiTimeoutMs)

fn systemAPIErrorMessage(
    retryAttempt: i64,
    errorText: text,
    retryInMs: i64,
    maxRetries: i64,
    verbose: bool,
    countdownMs: i64,
    apiTimeoutMs: text
) -> SystemAPIErrorRender:
    if systemAPIErrorHidden(retryAttempt):
        return SystemAPIErrorRender.hidden()
    val retryInSeconds = systemAPIErrorRetrySeconds(retryInMs, countdownMs)
    val formatted = systemAPIErrorFormat(errorText)
    val displayed = systemAPIErrorDisplayedError(formatted, verbose)
    val truncated = displayed.len() < formatted.len()
    SystemAPIErrorRender.new(
        formatted,
        displayed,
        truncated,
        retryInSeconds,
        systemAPIErrorRetryUnit(retryInSeconds),
        systemAPIErrorRetryLine(retryInSeconds, retryAttempt, maxRetries, apiTimeoutMs)
    )

fn systemAPIErrorMessageSourceLinesModeled() -> i64:
    SYSTEM_API_ERROR_MESSAGE_SOURCE_LINES
