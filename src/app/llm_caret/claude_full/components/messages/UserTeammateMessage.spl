"""
Claude full user teammate message parity model.
"""

const USER_TEAMMATE_MESSAGE_SOURCE_LINES = 205
const USER_TEAMMATE_MESSAGE_TAG = "teammate-message"
const USER_TEAMMATE_POINTER = ">"

class ParsedTeammateMessage:
    teammate_id: text
    content: text
    color: text
    summary: text

impl ParsedTeammateMessage:
    static fn new(teammateId: text, content: text, color: text, summary: text) -> ParsedTeammateMessage:
        ParsedTeammateMessage(teammate_id: teammateId, content: content, color: color, summary: summary)

class UserTeammateEntry:
    visible: bool
    kind: text
    display_name: text
    header: text
    body: text
    color: text
    summary: text
    margin_top: i64
    transcript_body: bool

impl UserTeammateEntry:
    static fn hidden(kind: text) -> UserTeammateEntry:
        UserTeammateEntry(visible: false, kind: kind, display_name: "", header: "", body: "", color: "", summary: "", margin_top: 0, transcript_body: false)

    static fn new(kind: text, displayName: text, body: text, color: text, summary: text, transcriptBody: bool) -> UserTeammateEntry:
        val header = "@" + displayName + USER_TEAMMATE_POINTER
        UserTeammateEntry(visible: true, kind: kind, display_name: displayName, header: header, body: body, color: color, summary: summary, margin_top: 1, transcript_body: transcriptBody)

class UserTeammateRender:
    visible: bool
    margin_top: i64
    width: text
    entries: [UserTeammateEntry]

impl UserTeammateRender:
    static fn hidden() -> UserTeammateRender:
        UserTeammateRender(visible: false, margin_top: 0, width: "", entries: [])

    static fn new(addMargin: bool, entries: [UserTeammateEntry]) -> UserTeammateRender:
        UserTeammateRender(visible: entries.len() > 0, margin_top: if addMargin: 1 else: 0, width: "100%", entries: entries)

fn userTeammateAttr(openTag: text, key: text) -> text:
    val marker = key + "=\""
    val start = openTag.find(marker)
    if start < 0:
        return ""
    val valueStart = start + marker.len()
    val rest = openTag.slice(valueStart, openTag.len())
    val end = rest.find("\"")
    if end < 0:
        return ""
    rest.slice(0, end)

fn parseTeammateMessages(textValue: text) -> [ParsedTeammateMessage]:
    val openPrefix = "<" + USER_TEAMMATE_MESSAGE_TAG
    val closeTag = "</" + USER_TEAMMATE_MESSAGE_TAG + ">"
    var out: [ParsedTeammateMessage] = []
    var cursor = 0
    while cursor < textValue.len():
        val rest = textValue.slice(cursor, textValue.len())
        val openRel = rest.find(openPrefix)
        if openRel < 0:
            return out
        val openStart = cursor + openRel
        val afterOpen = textValue.slice(openStart, textValue.len())
        val openEndRel = afterOpen.find(">")
        if openEndRel < 0:
            return out
        val openTag = afterOpen.slice(0, openEndRel + 1)
        val contentStart = openStart + openEndRel + 1
        val afterContent = textValue.slice(contentStart, textValue.len())
        val closeRel = afterContent.find(closeTag)
        if closeRel < 0:
            return out
        val teammateId = userTeammateAttr(openTag, "teammate_id")
        val content = afterContent.slice(0, closeRel).trim()
        if teammateId != "" and content != "":
            out.push(ParsedTeammateMessage.new(teammateId, content, userTeammateAttr(openTag, "color"), userTeammateAttr(openTag, "summary")))
        cursor = contentStart + closeRel + closeTag.len()
    out

fn userTeammateJsonFieldStart(content: text, key: text) -> i64:
    val marker = "\"" + key + "\""
    val keyIndex = content.find(marker)
    if keyIndex < 0:
        return -1
    val afterKey = content.slice(keyIndex + marker.len(), content.len())
    val colonIndex = afterKey.find(":")
    if colonIndex < 0:
        return -1
    var index = keyIndex + marker.len() + colonIndex + 1
    while index < content.len() and (content.slice(index, index + 1) == " " or content.slice(index, index + 1) == "\n"):
        index = index + 1
    index

fn userTeammateJsonString(content: text, key: text) -> text:
    val start = userTeammateJsonFieldStart(content, key)
    if start < 0 or content.slice(start, start + 1) != "\"":
        return ""
    var index = start + 1
    var value = ""
    var escaped = false
    while index < content.len():
        val ch = content.slice(index, index + 1)
        if escaped:
            value = value + ch
            escaped = false
        else:
            if ch == "\\":
                escaped = true
            else:
                if ch == "\"":
                    return value
                value = value + ch
        index = index + 1
    ""

fn userTeammateJsonBool(content: text, key: text) -> bool:
    val start = userTeammateJsonFieldStart(content, key)
    if start < 0:
        return false
    content.slice(start, content.len()).starts_with("true")

fn userTeammateDisplayName(teammateId: text) -> text:
    teammateId

fn userTeammateInkColor(color: text) -> text:
    if color == "":
        return "text"
    color

fn userTeammateIsShutdownApproved(content: text) -> bool:
    content.starts_with("shutdown-approved:") or userTeammateJsonString(content, "type") == "shutdown_approved"

fn userTeammateIsFilteredLifecycle(content: text) -> bool:
    userTeammateIsShutdownApproved(content) or userTeammateJsonString(content, "type") == "teammate_terminated"

fn userTeammateSpecialEntry(msg: ParsedTeammateMessage, displayName: text, color: text) -> UserTeammateEntry:
    val msgType = userTeammateJsonString(msg.content, "type")
    if msgType == "plan_approval_request":
        return UserTeammateEntry.new("plan-approval-request", displayName, userTeammateJsonString(msg.content, "planContent"), color, userTeammateJsonString(msg.content, "planFilePath"), false)
    if msgType == "plan_approval_response":
        if userTeammateJsonBool(msg.content, "approved"):
            return UserTeammateEntry.new("plan-approved", displayName, "You can now proceed with implementation. Your plan mode restrictions have been lifted.", "success", "", false)
        return UserTeammateEntry.new("plan-rejected", displayName, "Feedback: " + userTeammateJsonString(msg.content, "feedback"), "error", "", false)
    if msg.content.starts_with("shutdown-request:"):
        return UserTeammateEntry.new("shutdown-request", displayName, msg.content.slice("shutdown-request:".len(), msg.content.len()), "warning", "", false)
    if msg.content.starts_with("shutdown-rejected:"):
        return UserTeammateEntry.new("shutdown-rejected", displayName, msg.content.slice("shutdown-rejected:".len(), msg.content.len()), "subtle", "", false)
    if msg.content.starts_with("task:"):
        val parts = msg.content.slice("task:".len(), msg.content.len()).split("|")
        if parts.len() >= 3:
            return UserTeammateEntry.new("task-assignment", displayName, "Task #" + parts[0] + " assigned by " + parts[1] + ": " + parts[2], "cyan_FOR_SUBAGENTS_ONLY", "", false)
    if msgType == "idle_notification":
        return UserTeammateEntry.hidden("idle-notification")
    if msgType == "task_completed":
        var body = "Completed task #" + userTeammateJsonString(msg.content, "taskId")
        val subject = userTeammateJsonString(msg.content, "taskSubject")
        if subject != "":
            body = body + " (" + subject + ")"
        return UserTeammateEntry.new("task-completed", displayName, body, "success", "", false)
    UserTeammateEntry.hidden("")

fn userTeammateEntry(msg: ParsedTeammateMessage, isTranscriptMode: bool) -> UserTeammateEntry:
    val color = userTeammateInkColor(msg.color)
    val displayName = userTeammateDisplayName(msg.teammate_id)
    val special = userTeammateSpecialEntry(msg, displayName, color)
    if special.kind != "":
        return special
    UserTeammateEntry.new("plain", displayName, msg.content, color, msg.summary, isTranscriptMode)

fn userTeammateMessage(textValue: text, addMargin: bool, isTranscriptMode: bool) -> UserTeammateRender:
    var entries: [UserTeammateEntry] = []
    val messages = parseTeammateMessages(textValue)
    for i in 0..messages.len():
        val msg = messages[i]
        if not userTeammateIsFilteredLifecycle(msg.content):
            val entry = userTeammateEntry(msg, isTranscriptMode)
            if entry.visible:
                entries.push(entry)
    if entries.len() == 0:
        return UserTeammateRender.hidden()
    UserTeammateRender.new(addMargin, entries)

fn userTeammateMessageSourceLinesModeled() -> i64:
    USER_TEAMMATE_MESSAGE_SOURCE_LINES

# parity ledger: XML envelope parsing mirrors TEAMMATE_MSG_REGEX without regex runtime coupling.
# parity ledger: structured render branches cover plan approval, shutdown, task assignment, idle, task completed, and plain transcript content.
