"""
Claude full advisor message parity model.
"""

const ADVISOR_MESSAGE_SOURCE_LINES = 157

class AdvisorContent:
    type_name: text
    text: text
    error_code: text

impl AdvisorContent:
    static fn result(text: text) -> AdvisorContent:
        AdvisorContent(type_name: "advisor_result", text: text, error_code: "")

    static fn redacted() -> AdvisorContent:
        AdvisorContent(type_name: "advisor_redacted_result", text: "", error_code: "")

    static fn error(code: text) -> AdvisorContent:
        AdvisorContent(type_name: "advisor_tool_result_error", text: "", error_code: code)

class AdvisorBlock:
    type_name: text
    id: text
    input_json: text
    content: AdvisorContent

impl AdvisorBlock:
    static fn serverToolUse(id: text, inputJson: text) -> AdvisorBlock:
        AdvisorBlock(type_name: "server_tool_use", id: id, input_json: inputJson, content: AdvisorContent.result(""))

    static fn result(content: AdvisorContent) -> AdvisorBlock:
        AdvisorBlock(type_name: "advisor_message", id: "", input_json: "", content: content)

class AdvisorRender:
    mode: text
    body: text
    margin_top: i64
    unresolved: bool
    error: bool

impl AdvisorRender:
    static fn new(mode: text, body: text, marginTop: i64, unresolved: bool, error: bool) -> AdvisorRender:
        AdvisorRender(mode: mode, body: body, margin_top: marginTop, unresolved: unresolved, error: error)

fn advisorContains(ids: [text], id: text) -> bool:
    var i = 0
    while i < ids.len():
        if ids[i] == id:
            return true
        i = i + 1
    false

fn advisorServerToolUseRender(block: AdvisorBlock, addMargin: bool, resolvedIds: [text], erroredIds: [text], advisorModel: text) -> AdvisorRender:
    var body = "Advising"
    if advisorModel != "":
        body = body + " using " + advisorModel
    if block.input_json != "":
        body = body + " - " + block.input_json
    val resolved = advisorContains(resolvedIds, block.id)
    val errored = advisorContains(erroredIds, block.id)
    AdvisorRender.new("server-tool-use", body, if addMargin: 1 else: 0, not resolved, errored)

fn advisorResultRender(block: AdvisorBlock, verbose: bool) -> AdvisorRender:
    val content = block.content
    if content.type_name == "advisor_tool_result_error":
        return AdvisorRender.new("error", "Advisor unavailable (" + content.error_code + ")", 0, false, true)
    if content.type_name == "advisor_result":
        if verbose:
            return AdvisorRender.new("result", content.text, 0, false, false)
        return AdvisorRender.new("result", "Advisor has reviewed the conversation and will apply the feedback", 0, false, false)
    AdvisorRender.new("redacted", "Advisor has reviewed the conversation and will apply the feedback", 0, false, false)

fn advisorMessage(block: AdvisorBlock, addMargin: bool, resolvedIds: [text], erroredIds: [text], verbose: bool, advisorModel: text) -> AdvisorRender:
    if block.type_name == "server_tool_use":
        return advisorServerToolUseRender(block, addMargin, resolvedIds, erroredIds, advisorModel)
    advisorResultRender(block, verbose)

fn advisorMessageSourceLinesModeled() -> i64:
    ADVISOR_MESSAGE_SOURCE_LINES
