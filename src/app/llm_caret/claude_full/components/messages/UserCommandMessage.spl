"""
Claude full user command message parity model.
"""

use app.llm_caret.claude_full.components.messages.UserBashInputMessage.{extractTaggedValue}

const USER_COMMAND_MESSAGE_SOURCE_LINES = 107
const COMMAND_MESSAGE_TAG = "command-message"
const USER_COMMAND_POINTER = "›"

class UserCommandRender:
    visible: bool
    content: text
    pointer: text
    margin_top: i64
    background_color: text
    skill_format: bool

impl UserCommandRender:
    static fn hidden() -> UserCommandRender:
        UserCommandRender(visible: false, content: "", pointer: "", margin_top: 0, background_color: "", skill_format: false)

    static fn new(content: text, marginTop: i64, skillFormat: bool) -> UserCommandRender:
        UserCommandRender(visible: true, content: content, pointer: USER_COMMAND_POINTER + " ", margin_top: marginTop, background_color: "userMessageBackground", skill_format: skillFormat)

fn userCommandJoin(command: text, args: text) -> text:
    if args == "":
        return "/" + command
    "/" + command + " " + args

fn userCommandMessage(textValue: text, addMargin: bool) -> UserCommandRender:
    val commandMessage = extractTaggedValue(textValue, COMMAND_MESSAGE_TAG)
    if commandMessage == "":
        return UserCommandRender.hidden()
    val args = extractTaggedValue(textValue, "command-args")
    val isSkillFormat = extractTaggedValue(textValue, "skill-format") == "true"
    var margin = 0
    if addMargin:
        margin = 1
    if isSkillFormat:
        return UserCommandRender.new("Skill(" + commandMessage + ")", margin, true)
    UserCommandRender.new(userCommandJoin(commandMessage, args), margin, false)

fn userCommandMessageSourceLinesModeled() -> i64:
    USER_COMMAND_MESSAGE_SOURCE_LINES
