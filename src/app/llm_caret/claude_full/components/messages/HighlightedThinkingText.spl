"""
Claude full highlighted thinking text parity model.
"""

const HIGHLIGHTED_THINKING_TEXT_SOURCE_LINES = 161
const HIGHLIGHTED_THINKING_POINTER = "❯"

class ThinkingTriggerPosition:
    word: text
    start: i64
    end: i64

impl ThinkingTriggerPosition:
    static fn new(word: text, start: i64, end: i64) -> ThinkingTriggerPosition:
        ThinkingTriggerPosition(word: word, start: start, end: end)

class HighlightedThinkingSpan:
    key: text
    text: text
    color: text

impl HighlightedThinkingSpan:
    static fn new(key: text, text: text, color: text) -> HighlightedThinkingSpan:
        HighlightedThinkingSpan(key: key, text: text, color: color)

class HighlightedThinkingRender:
    layout: text
    pointer: text
    pointer_color: text
    label: text
    label_color: text
    timestamp: text
    timestamp_dim: bool
    body: text
    body_color: text
    padding_left: i64
    spans: [HighlightedThinkingSpan]

impl HighlightedThinkingRender:
    static fn brief(textValue: text, timestamp: text, isQueued: bool) -> HighlightedThinkingRender:
        val color = if isQueued: "subtle" else: "text"
        val labelColor = if isQueued: "subtle" else: "briefLabelYou"
        HighlightedThinkingRender(layout: "brief", pointer: "", pointer_color: "", label: "You", label_color: labelColor, timestamp: timestamp, timestamp_dim: timestamp != "", body: textValue, body_color: color, padding_left: 2, spans: [])

    static fn normal(textValue: text, pointerColor: text, spans: [HighlightedThinkingSpan]) -> HighlightedThinkingRender:
        HighlightedThinkingRender(layout: "normal", pointer: HIGHLIGHTED_THINKING_POINTER, pointer_color: pointerColor, label: "", label_color: "", timestamp: "", timestamp_dim: false, body: textValue, body_color: "text", padding_left: 0, spans: spans)

fn highlightedThinkingText(textValue: text, useBriefLayout: bool, timestamp: text, isQueued: bool, isSelected: bool, ultrathinkEnabled: bool) -> HighlightedThinkingRender:
    if useBriefLayout:
        return HighlightedThinkingRender.brief(textValue, timestamp, isQueued)
    val pointerColor = if isSelected: "suggestion" else: "subtle"
    val triggers = findHighlightedThinkingTriggerPositions(textValue, ultrathinkEnabled)
    HighlightedThinkingRender.normal(textValue, pointerColor, highlightedThinkingSpans(textValue, triggers))

fn highlightedThinkingSpans(textValue: text, triggers: [ThinkingTriggerPosition]) -> [HighlightedThinkingSpan]:
    if triggers.len() == 0:
        return [HighlightedThinkingSpan.new("plain-0", textValue, "text")]
    var parts: [HighlightedThinkingSpan] = []
    var cursor = 0
    var t = 0
    while t < triggers.len():
        val trigger = triggers[t]
        if trigger.start > cursor:
            parts.push(HighlightedThinkingSpan.new("plain-{cursor}", textValue.substring(cursor, trigger.start), "text"))
        var i = trigger.start
        while i < trigger.end:
            parts.push(HighlightedThinkingSpan.new("rb-{i}", textValue.substring(i, i + 1), highlightedThinkingRainbowColor(i - trigger.start)))
            i = i + 1
        cursor = trigger.end
        t = t + 1
    if cursor < textValue.len():
        parts.push(HighlightedThinkingSpan.new("plain-{cursor}", textValue.substring(cursor, textValue.len()), "text"))
    parts

fn findHighlightedThinkingTriggerPositions(textValue: text, ultrathinkEnabled: bool) -> [ThinkingTriggerPosition]:
    if not ultrathinkEnabled:
        return []
    val lower = textValue.lower()
    val word = "ultrathink"
    var out: [ThinkingTriggerPosition] = []
    var i = 0
    while i <= lower.len() - word.len():
        val end = i + word.len()
        if lower.substring(i, end) == word and highlightedThinkingHasWordBoundary(lower, i, end):
            out.push(ThinkingTriggerPosition.new(textValue.substring(i, end), i, end))
            i = end
        else:
            i = i + 1
    out

fn highlightedThinkingHasWordBoundary(textValue: text, start: i64, end: i64) -> bool:
    val leftOk = start == 0 or not highlightedThinkingIsWordChar(textValue.substring(start - 1, start))
    val rightOk = end >= textValue.len() or not highlightedThinkingIsWordChar(textValue.substring(end, end + 1))
    leftOk and rightOk

fn highlightedThinkingIsWordChar(ch: text) -> bool:
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    ch == "_"

fn highlightedThinkingRainbowColor(index: i64) -> text:
    val colors = highlightedThinkingRainbowColors()
    colors[index % colors.len()]

fn highlightedThinkingRainbowColors() -> [text]:
    ["rainbow_red", "rainbow_orange", "rainbow_yellow", "rainbow_green", "rainbow_blue", "rainbow_indigo", "rainbow_violet"]

fn highlightedThinkingTextSourceLinesModeled() -> i64:
    HIGHLIGHTED_THINKING_TEXT_SOURCE_LINES
