"""
Claude full assistant thinking message parity model.
"""

const ASSISTANT_THINKING_MESSAGE_SOURCE_LINES = 85

class AssistantThinkingRender:
    visible: bool
    mode: text
    label: text
    body: text
    margin_top: i64
    show_expand_hint: bool

impl AssistantThinkingRender:
    static fn hidden() -> AssistantThinkingRender:
        AssistantThinkingRender(visible: false, mode: "hidden", label: "", body: "", margin_top: 0, show_expand_hint: false)

    static fn collapsed(addMargin: bool) -> AssistantThinkingRender:
        AssistantThinkingRender(visible: true, mode: "collapsed", label: "Thinking", body: "", margin_top: if addMargin: 1 else: 0, show_expand_hint: true)

    static fn expanded(thinking: text, addMargin: bool) -> AssistantThinkingRender:
        AssistantThinkingRender(visible: true, mode: "expanded", label: "Thinking...", body: thinking, margin_top: if addMargin: 1 else: 0, show_expand_hint: false)

fn assistantThinkingMessage(thinking: text, addMargin: bool, isTranscriptMode: bool, verbose: bool, hideInTranscript: bool) -> AssistantThinkingRender:
    if thinking == "":
        return AssistantThinkingRender.hidden()
    if hideInTranscript:
        return AssistantThinkingRender.hidden()
    if isTranscriptMode:
        return AssistantThinkingRender.expanded(thinking, addMargin)
    if verbose:
        return AssistantThinkingRender.expanded(thinking, addMargin)
    AssistantThinkingRender.collapsed(addMargin)

fn assistantThinkingShouldShowFull(isTranscriptMode: bool, verbose: bool) -> bool:
    if isTranscriptMode:
        return true
    if verbose:
        return true
    false

fn assistantThinkingMessageSourceLinesModeled() -> i64:
    ASSISTANT_THINKING_MESSAGE_SOURCE_LINES
