"""
Claude full hook progress message parity model.
"""

const HOOK_PROGRESS_MESSAGE_SOURCE_LINES = 115

class HookProgressMessageInput:
    hook_event: text
    in_progress_hook_count: i64
    resolved_hook_count: i64
    is_transcript_mode: bool

impl HookProgressMessageInput:
    static fn new(hookEvent: text, inProgressHookCount: i64, resolvedHookCount: i64, isTranscriptMode: bool) -> HookProgressMessageInput:
        HookProgressMessageInput(hook_event: hookEvent, in_progress_hook_count: inProgressHookCount, resolved_hook_count: resolvedHookCount, is_transcript_mode: isTranscriptMode)

class HookProgressMessageRender:
    visible: bool
    mode: text
    prefix: text
    hook_event: text
    suffix: text
    text: text
    dim_color: bool
    bold_hook_event: bool

impl HookProgressMessageRender:
    static fn hidden() -> HookProgressMessageRender:
        HookProgressMessageRender(visible: false, mode: "hidden", prefix: "", hook_event: "", suffix: "", text: "", dim_color: false, bold_hook_event: false)

    static fn new(mode: text, prefix: text, hookEvent: text, suffix: text) -> HookProgressMessageRender:
        HookProgressMessageRender(visible: true, mode: mode, prefix: prefix, hook_event: hookEvent, suffix: suffix, text: prefix + hookEvent + suffix, dim_color: true, bold_hook_event: true)

fn hookProgressMessageIsToolHook(hookEvent: text) -> bool:
    hookEvent == "PreToolUse" or hookEvent == "PostToolUse"

fn hookProgressMessageHookNoun(count: i64) -> text:
    if count == 1:
        return " hook"
    " hooks"

fn hookProgressMessageTranscriptSuffix(count: i64) -> text:
    hookProgressMessageHookNoun(count) + " ran"

fn hookProgressMessageRunningSuffix(count: i64) -> text:
    if count == 1:
        return " hook..."
    " hooks..."

fn hookProgressMessage(input: HookProgressMessageInput) -> HookProgressMessageRender:
    val inProgressHookCount = input.in_progress_hook_count
    if inProgressHookCount == 0:
        return HookProgressMessageRender.hidden()

    if hookProgressMessageIsToolHook(input.hook_event):
        if input.is_transcript_mode:
            return HookProgressMessageRender.new("transcript-summary", inProgressHookCount.to_text() + " ", input.hook_event, hookProgressMessageTranscriptSuffix(inProgressHookCount))
        return HookProgressMessageRender.hidden()

    if input.resolved_hook_count == inProgressHookCount:
        return HookProgressMessageRender.hidden()

    HookProgressMessageRender.new("running", "Running ", input.hook_event, hookProgressMessageRunningSuffix(inProgressHookCount))

fn hookProgressMessageLine(render: HookProgressMessageRender) -> text:
    if not render.visible:
        return ""
    render.text

fn hookProgressMessageSourceLinesModeled() -> i64:
    HOOK_PROGRESS_MESSAGE_SOURCE_LINES
