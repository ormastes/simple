"""
Claude full redacted thinking message parity model.
"""

const ASSISTANT_REDACTED_THINKING_MESSAGE_SOURCE_LINES = 30

class AssistantRedactedThinkingRender:
    text: text
    margin_top: i64
    dim: bool
    italic: bool

impl AssistantRedactedThinkingRender:
    static fn new(addMargin: bool) -> AssistantRedactedThinkingRender:
        AssistantRedactedThinkingRender(text: "Thinking...", margin_top: if addMargin: 1 else: 0, dim: true, italic: true)

fn assistantRedactedThinkingMessage(addMargin: bool) -> AssistantRedactedThinkingRender:
    AssistantRedactedThinkingRender.new(addMargin)

fn assistantRedactedThinkingMessageSourceLinesModeled() -> i64:
    ASSISTANT_REDACTED_THINKING_MESSAGE_SOURCE_LINES
