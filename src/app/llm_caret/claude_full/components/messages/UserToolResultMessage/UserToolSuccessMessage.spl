"""
Claude full successful tool result message parity model.
"""

const USER_TOOL_SUCCESS_MESSAGE_SOURCE_LINES = 103

class UserToolSuccessRender:
    visible: bool
    rendered_message: text
    width_constrained: bool
    show_bash_classifier: bool
    bash_classifier_text: text
    show_transcript_classifier: bool
    transcript_classifier_text: text
    show_post_tool_hook: bool
    hook_event: text
    is_brief_only: bool

impl UserToolSuccessRender:
    static fn hidden() -> UserToolSuccessRender:
        UserToolSuccessRender(visible: false, rendered_message: "", width_constrained: false, show_bash_classifier: false, bash_classifier_text: "", show_transcript_classifier: false, transcript_classifier_text: "", show_post_tool_hook: false, hook_event: "", is_brief_only: false)

    static fn new(renderedMessage: text, widthConstrained: bool, showBashClassifier: bool, bashClassifierRule: text, showTranscriptClassifier: bool, isBriefOnly: bool) -> UserToolSuccessRender:
        val bashText = if showBashClassifier: "Auto-approved - matched \"" + bashClassifierRule + "\"" else: ""
        val transcriptText = if showTranscriptClassifier: "Allowed by auto mode classifier" else: ""
        UserToolSuccessRender(visible: true, rendered_message: renderedMessage, width_constrained: widthConstrained, show_bash_classifier: showBashClassifier, bash_classifier_text: bashText, show_transcript_classifier: showTranscriptClassifier, transcript_classifier_text: transcriptText, show_post_tool_hook: true, hook_event: "PostToolUse", is_brief_only: isBriefOnly)

fn userToolSuccessBriefOnly(kairosFeatureEnabled: bool, kairosBriefFeatureEnabled: bool, appBriefOnly: bool) -> bool:
    (kairosFeatureEnabled or kairosBriefFeatureEnabled) and appBriefOnly

fn userToolSuccessMessage(hasToolUseResult: bool, hasTool: bool, outputSchemaValid: bool, renderedMessage: text, userFacingName: text, bashClassifierFeatureEnabled: bool, classifierRule: text, transcriptClassifierFeatureEnabled: bool, yoloReason: text, kairosFeatureEnabled: bool, kairosBriefFeatureEnabled: bool, appBriefOnly: bool) -> UserToolSuccessRender:
    if not hasToolUseResult or not hasTool:
        return UserToolSuccessRender.hidden()
    if not outputSchemaValid:
        return UserToolSuccessRender.hidden()
    if renderedMessage == "":
        return UserToolSuccessRender.hidden()

    val rendersAsAssistantText = userFacingName == ""
    val showBashClassifier = bashClassifierFeatureEnabled and classifierRule != ""
    val showTranscriptClassifier = transcriptClassifierFeatureEnabled and yoloReason != ""
    val isBriefOnly = userToolSuccessBriefOnly(kairosFeatureEnabled, kairosBriefFeatureEnabled, appBriefOnly)
    UserToolSuccessRender.new(renderedMessage, not rendersAsAssistantText, showBashClassifier, classifierRule, showTranscriptClassifier, isBriefOnly)

fn userToolSuccessMessageSourceLinesModeled() -> i64:
    USER_TOOL_SUCCESS_MESSAGE_SOURCE_LINES
