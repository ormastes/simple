"""
Claude full user tool result lookup utility parity model.
"""

const USER_TOOL_RESULT_UTILS_SOURCE_LINES = 43

class UserToolLookupToolUse:
    id: text
    name: text

impl UserToolLookupToolUse:
    static fn new(id: text, name: text) -> UserToolLookupToolUse:
        UserToolLookupToolUse(id: id, name: name)

class UserToolLookupTool:
    name: text
    description: text

impl UserToolLookupTool:
    static fn new(name: text, description: text) -> UserToolLookupTool:
        UserToolLookupTool(name: name, description: description)

class UserToolLookupResult:
    found: bool
    tool_name: text
    tool_description: text
    tool_use_id: text

impl UserToolLookupResult:
    static fn none() -> UserToolLookupResult:
        UserToolLookupResult(found: false, tool_name: "", tool_description: "", tool_use_id: "")

    static fn found(tool: UserToolLookupTool, toolUse: UserToolLookupToolUse) -> UserToolLookupResult:
        UserToolLookupResult(found: true, tool_name: tool.name, tool_description: tool.description, tool_use_id: toolUse.id)

fn userToolResultFindToolByName(tools: [UserToolLookupTool], name: text) -> UserToolLookupTool:
    for tool in tools:
        if tool.name == name:
            return tool
    UserToolLookupTool.new("", "")

fn getToolFromMessages(toolUseID: text, tools: [UserToolLookupTool], toolUses: [UserToolLookupToolUse]) -> UserToolLookupResult:
    for toolUse in toolUses:
        if toolUse.id == toolUseID:
            val tool = userToolResultFindToolByName(tools, toolUse.name)
            if tool.name == "":
                return UserToolLookupResult.none()
            return UserToolLookupResult.found(tool, toolUse)
    UserToolLookupResult.none()

fn userToolResultUtilsSourceLinesModeled() -> i64:
    USER_TOOL_RESULT_UTILS_SOURCE_LINES
