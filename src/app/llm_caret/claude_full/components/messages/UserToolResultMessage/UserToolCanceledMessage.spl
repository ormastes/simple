"""
Claude full canceled tool result message parity model.
"""

const USER_TOOL_CANCELED_MESSAGE_SOURCE_LINES = 15

class UserToolCanceledRender:
    interrupted_by_user: bool
    response_height: i64

impl UserToolCanceledRender:
    static fn new() -> UserToolCanceledRender:
        UserToolCanceledRender(interrupted_by_user: true, response_height: 1)

fn userToolCanceledMessage() -> UserToolCanceledRender:
    UserToolCanceledRender.new()

fn userToolCanceledMessageSourceLinesModeled() -> i64:
    USER_TOOL_CANCELED_MESSAGE_SOURCE_LINES
