"""
Claude full grouped tool-use content parity model.
"""

const GROUPED_TOOL_USE_CONTENT_SOURCE_LINES = 57

class GroupedToolUseItem:
    id: text
    resolved: bool
    error: bool
    in_progress: bool
    progress_count: i64
    has_result: bool

impl GroupedToolUseItem:
    static fn new(id: text, resolved: bool, error: bool, inProgress: bool, progressCount: i64, hasResult: bool) -> GroupedToolUseItem:
        GroupedToolUseItem(id: id, resolved: resolved, error: error, in_progress: inProgress, progress_count: progressCount, has_result: hasResult)

class GroupedToolUseRender:
    visible: bool
    tool_name: text
    should_animate: bool
    item_count: i64

impl GroupedToolUseRender:
    static fn hidden() -> GroupedToolUseRender:
        GroupedToolUseRender(visible: false, tool_name: "", should_animate: false, item_count: 0)

    static fn new(toolName: text, shouldAnimate: bool, itemCount: i64) -> GroupedToolUseRender:
        GroupedToolUseRender(visible: true, tool_name: toolName, should_animate: shouldAnimate, item_count: itemCount)

fn groupedToolUseAnyInProgress(items: [GroupedToolUseItem]) -> bool:
    var i = 0
    while i < items.len():
        if items[i].in_progress:
            return true
        i = i + 1
    false

fn groupedToolUseContent(toolName: text, hasRenderer: bool, items: [GroupedToolUseItem], shouldAnimate: bool) -> GroupedToolUseRender:
    if not hasRenderer:
        return GroupedToolUseRender.hidden()
    GroupedToolUseRender.new(toolName, shouldAnimate and groupedToolUseAnyInProgress(items), items.len())

fn groupedToolUseResultFor(id: text, resultIds: [text]) -> bool:
    var i = 0
    while i < resultIds.len():
        if resultIds[i] == id:
            return true
        i = i + 1
    false

fn groupedToolUseContentSourceLinesModeled() -> i64:
    GROUPED_TOOL_USE_CONTENT_SOURCE_LINES
