"""
Claude full CollapsedReadSearchContent parity model.
"""

const COLLAPSED_READ_SEARCH_CONTENT_SOURCE_LINES = 483
const COLLAPSED_READ_SEARCH_MIN_HINT_DISPLAY_MS = 700

class CollapsedProgress:
    type_name: text
    elapsed_seconds: i64
    total_lines: i64
    command: text
    pattern: text
    file_path: text
    tool_name: text

impl CollapsedProgress:
    static fn bash(seconds: i64, lines: i64) -> CollapsedProgress:
        CollapsedProgress(type_name: "bash_progress", elapsed_seconds: seconds, total_lines: lines, command: "", pattern: "", file_path: "", tool_name: "")

    static fn repl(command: text, pattern: text, filePath: text, toolName: text) -> CollapsedProgress:
        CollapsedProgress(type_name: "repl_tool_call", elapsed_seconds: 0, total_lines: 0, command: command, pattern: pattern, file_path: filePath, tool_name: toolName)

class CollapsedToolUse:
    id: text
    name: text
    input_label: text
    resolved: bool
    errored: bool
    in_progress: bool
    progress: CollapsedProgress?

impl CollapsedToolUse:
    static fn new(id: text, name: text, inputLabel: text, resolved: bool, errored: bool, inProgress: bool) -> CollapsedToolUse:
        CollapsedToolUse(id: id, name: name, input_label: inputLabel, resolved: resolved, errored: errored, in_progress: inProgress, progress: nil)

    static fn withProgress(id: text, name: text, inputLabel: text, resolved: bool, errored: bool, inProgress: bool, progress: CollapsedProgress) -> CollapsedToolUse:
        CollapsedToolUse(id: id, name: name, input_label: inputLabel, resolved: resolved, errored: errored, in_progress: inProgress, progress: progress)

class CollapsedCommit:
    kind: text
    sha: text

impl CollapsedCommit:
    static fn new(kind: text, sha: text) -> CollapsedCommit:
        CollapsedCommit(kind: kind, sha: sha)

class CollapsedBranch:
    action: text
    ref_name: text

impl CollapsedBranch:
    static fn new(action: text, refName: text) -> CollapsedBranch:
        CollapsedBranch(action: action, ref_name: refName)

class CollapsedPullRequest:
    action: text
    number: i64
    url: text

impl CollapsedPullRequest:
    static fn new(action: text, number: i64, url: text) -> CollapsedPullRequest:
        CollapsedPullRequest(action: action, number: number, url: url)

class CollapsedHookInfo:
    command: text
    duration_ms: i64

impl CollapsedHookInfo:
    static fn new(command: text, durationMs: i64) -> CollapsedHookInfo:
        CollapsedHookInfo(command: command, duration_ms: durationMs)

class CollapsedMemory:
    path: text
    content: text

impl CollapsedMemory:
    static fn new(path: text, content: text) -> CollapsedMemory:
        CollapsedMemory(path: path, content: content)

class CollapsedReadSearchGroupModel:
    search_count: i64
    read_count: i64
    list_count: i64
    repl_count: i64
    memory_search_count: i64
    memory_read_count: i64
    memory_write_count: i64
    mcp_call_count: i64
    bash_count: i64
    git_op_bash_count: i64
    read_file_paths: [text]
    search_args: [text]
    latest_display_hint: text
    mcp_server_names: [text]
    commits: [CollapsedCommit]
    pushes: [text]
    branches: [CollapsedBranch]
    prs: [CollapsedPullRequest]
    hook_infos: [CollapsedHookInfo]
    hook_total_ms: i64
    relevant_memories: [CollapsedMemory]
    tool_uses: [CollapsedToolUse]

impl CollapsedReadSearchGroupModel:
    static fn empty() -> CollapsedReadSearchGroupModel:
        CollapsedReadSearchGroupModel(search_count: 0, read_count: 0, list_count: 0, repl_count: 0, memory_search_count: 0, memory_read_count: 0, memory_write_count: 0, mcp_call_count: 0, bash_count: 0, git_op_bash_count: 0, read_file_paths: [], search_args: [], latest_display_hint: "", mcp_server_names: [], commits: [], pushes: [], branches: [], prs: [], hook_infos: [], hook_total_ms: 0, relevant_memories: [], tool_uses: [])

class CollapsedSummary:
    visible: bool
    verbose: bool
    active: bool
    errored: bool
    line: text
    hint: text
    hook_line: text
    rows: [text]

impl CollapsedSummary:
    static fn hidden() -> CollapsedSummary:
        CollapsedSummary(visible: false, verbose: false, active: false, errored: false, line: "", hint: "", hook_line: "", rows: [])

    static fn line(line: text, hint: text, hookLine: text, active: bool, errored: bool) -> CollapsedSummary:
        CollapsedSummary(visible: true, verbose: false, active: active, errored: errored, line: line, hint: hint, hook_line: hookLine, rows: [])

    static fn verboseRows(rows: [text]) -> CollapsedSummary:
        CollapsedSummary(visible: true, verbose: true, active: false, errored: false, line: "", hint: "", hook_line: "", rows: rows)

fn collapsedReadSearchPlural(count: i64, singular: text) -> text:
    if count == 1:
        return singular
    singular + "s"

fn collapsedReadSearchDuration(ms: i64) -> text:
    if ms < 1000:
        return "{ms}ms"
    "{ms / 1000}s"

fn collapsedReadSearchBasename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        val ch = path.slice(i, i + 1)
        if ch == "/" or ch == "\\":
            last = i
        i = i + 1
    if last < 0:
        return path
    path.slice(last + 1, path.len())

fn collapsedReadSearchLast(values: [text]) -> text:
    if values.len() == 0:
        return ""
    values[values.len() - 1]

fn collapsedReadSearchAnyError(toolUses: [CollapsedToolUse]) -> bool:
    var i = 0
    while i < toolUses.len():
        if toolUses[i].errored:
            return true
        i = i + 1
    false

fn collapsedReadSearchHasMemoryOps(message: CollapsedReadSearchGroupModel) -> bool:
    message.memory_search_count > 0 or message.memory_read_count > 0 or message.memory_write_count > 0

fn collapsedReadSearchHasNonMemoryOps(message: CollapsedReadSearchGroupModel, fullscreen: bool) -> bool:
    val bashCount = if fullscreen: collapsedReadSearchBashCount(message) else: 0
    message.search_count > 0 or message.read_count > 0 or message.list_count > 0 or message.repl_count > 0 or message.mcp_call_count > 0 or bashCount > 0 or message.git_op_bash_count > 0 or message.commits.len() > 0 or message.pushes.len() > 0 or message.branches.len() > 0 or message.prs.len() > 0

fn collapsedReadSearchBashCount(message: CollapsedReadSearchGroupModel) -> i64:
    val count = message.bash_count - message.git_op_bash_count
    if count < 0:
        return 0
    count

fn collapsedReadSearchInitialHint(message: CollapsedReadSearchGroupModel) -> text:
    if message.latest_display_hint != "":
        return message.latest_display_hint
    val lastRead = collapsedReadSearchLast(message.read_file_paths)
    if lastRead != "":
        return lastRead
    val lastSearch = collapsedReadSearchLast(message.search_args)
    if lastSearch != "":
        return "\"" + lastSearch + "\""
    ""

fn collapsedReadSearchLiveHint(message: CollapsedReadSearchGroupModel, active: bool) -> text:
    var hint = collapsedReadSearchInitialHint(message)
    if not active:
        return hint
    var i = 0
    while i < message.tool_uses.len():
        val toolUse = message.tool_uses[i]
        if toolUse.in_progress:
            if val progress = toolUse.progress:
                if progress.type_name == "repl_tool_call":
                    if progress.file_path != "":
                        hint = progress.file_path
                    else:
                        if progress.pattern != "":
                            hint = "\"" + progress.pattern + "\""
                        else:
                            if progress.command != "":
                                hint = progress.command
                            else:
                                hint = progress.tool_name
        i = i + 1
    hint

fn collapsedReadSearchShellSuffix(message: CollapsedReadSearchGroupModel, active: bool, fullscreen: bool) -> text:
    if not fullscreen or not active:
        return ""
    var elapsed = 0
    var lines = 0
    var i = 0
    while i < message.tool_uses.len():
        val toolUse = message.tool_uses[i]
        if toolUse.in_progress:
            if val progress = toolUse.progress:
                if progress.type_name == "bash_progress" or progress.type_name == "powershell_progress":
                    if progress.elapsed_seconds > elapsed:
                        elapsed = progress.elapsed_seconds
                        lines = progress.total_lines
        i = i + 1
    if elapsed < 2:
        return ""
    val time = collapsedReadSearchDuration(elapsed * 1000)
    if lines > 0:
        return " (" + time + " · " + "{lines} " + collapsedReadSearchPlural(lines, "line") + ")"
    " (" + time + ")"

fn collapsedReadSearchJoin(values: [text], sep: text) -> text:
    var result = ""
    var i = 0
    while i < values.len():
        if result == "":
            result = values[i]
        else:
            result = result + sep + values[i]
        i = i + 1
    result

fn collapsedReadSearchCommitShas(commits: [CollapsedCommit], kind: text) -> [text]:
    var result: [text] = []
    var i = 0
    while i < commits.len():
        if commits[i].kind == kind:
            result.push(commits[i].sha)
        i = i + 1
    result

fn collapsedReadSearchPushPart(parts: [text], textValue: text) -> [text]:
    var result = parts
    result.push(textValue)
    result

fn collapsedReadSearchGitParts(message: CollapsedReadSearchGroupModel, fullscreen: bool) -> [text]:
    var parts: [text] = []
    if not fullscreen:
        return parts
    val committed = collapsedReadSearchCommitShas(message.commits, "committed")
    if committed.len() > 0:
        parts = collapsedReadSearchPushPart(parts, "Committed " + collapsedReadSearchJoin(committed, ", "))
    val amended = collapsedReadSearchCommitShas(message.commits, "amended")
    if amended.len() > 0:
        parts = collapsedReadSearchPushPart(parts, "Amended commit " + collapsedReadSearchJoin(amended, ", "))
    val picked = collapsedReadSearchCommitShas(message.commits, "cherry-picked")
    if picked.len() > 0:
        parts = collapsedReadSearchPushPart(parts, "Cherry-picked " + collapsedReadSearchJoin(picked, ", "))
    if message.pushes.len() > 0:
        parts = collapsedReadSearchPushPart(parts, "Pushed to " + collapsedReadSearchJoin(message.pushes, ", "))
    var i = 0
    while i < message.branches.len():
        val branch = message.branches[i]
        val verb = if branch.action == "rebased": "Rebased onto " else: "Merged "
        parts = collapsedReadSearchPushPart(parts, verb + branch.ref_name)
        i = i + 1
    i = 0
    while i < message.prs.len():
        val pr = message.prs[i]
        parts = collapsedReadSearchPushPart(parts, pr.action + " PR #" + "{pr.number}")
        i = i + 1
    parts

fn collapsedReadSearchOpParts(message: CollapsedReadSearchGroupModel, active: bool, fullscreen: bool) -> [text]:
    var parts = collapsedReadSearchGitParts(message, fullscreen)
    if message.search_count > 0:
        val verb = if active: "Searching for " else: "Searched for "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.search_count} " + collapsedReadSearchPlural(message.search_count, "pattern"))
    if message.read_count > 0:
        val verb = if active: "Reading " else: "Read "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.read_count} " + collapsedReadSearchPlural(message.read_count, "file"))
    if message.list_count > 0:
        val verb = if active: "Listing " else: "Listed "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.list_count} " + collapsedReadSearchPlural(message.list_count, "directory"))
    if message.repl_count > 0:
        val verb = if active: "REPL'ing " else: "REPL'd "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.repl_count} " + collapsedReadSearchPlural(message.repl_count, "time"))
    if message.mcp_call_count > 0:
        val serverLabel = if message.mcp_server_names.len() > 0: collapsedReadSearchJoin(message.mcp_server_names, ", ").replace("claude.ai ", "") else: "MCP"
        val verb = if active: "Querying " else: "Queried "
        val times = if message.mcp_call_count > 1: " {message.mcp_call_count} times" else: ""
        parts = collapsedReadSearchPushPart(parts, verb + serverLabel + times)
    val bashCount = if fullscreen: collapsedReadSearchBashCount(message) else: 0
    if bashCount > 0:
        val verb = if active: "Running " else: "Ran "
        parts = collapsedReadSearchPushPart(parts, verb + "{bashCount} bash " + collapsedReadSearchPlural(bashCount, "command"))
    parts

fn collapsedReadSearchMemoryParts(message: CollapsedReadSearchGroupModel, active: bool) -> [text]:
    var parts: [text] = []
    if message.memory_read_count > 0:
        val verb = if active: "Recalling " else: "Recalled "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.memory_read_count} " + collapsedReadSearchPlural(message.memory_read_count, "memory"))
    if message.memory_search_count > 0:
        val verb = if active: "Searching memories" else: "Searched memories"
        parts = collapsedReadSearchPushPart(parts, verb)
    if message.memory_write_count > 0:
        val verb = if active: "Writing " else: "Wrote "
        parts = collapsedReadSearchPushPart(parts, verb + "{message.memory_write_count} " + collapsedReadSearchPlural(message.memory_write_count, "memory"))
    parts

fn collapsedReadSearchHookLine(message: CollapsedReadSearchGroupModel) -> text:
    if message.hook_total_ms <= 0:
        return ""
    "Ran {message.hook_infos.len()} PreToolUse " + collapsedReadSearchPlural(message.hook_infos.len(), "hook") + " (" + collapsedReadSearchDuration(message.hook_total_ms) + ")"

fn collapsedReadSearchVerboseRows(message: CollapsedReadSearchGroupModel) -> [text]:
    var rows: [text] = []
    var i = 0
    while i < message.tool_uses.len():
        val toolUse = message.tool_uses[i]
        val state = if toolUse.errored: "error" else: if toolUse.resolved: "resolved" else: if toolUse.in_progress: "running" else: "unresolved"
        rows.push(toolUse.name + " " + toolUse.input_label + " " + state)
        i = i + 1
    i = 0
    while i < message.hook_infos.len():
        val info = message.hook_infos[i]
        rows.push("Ran hook " + info.command + " (" + collapsedReadSearchDuration(info.duration_ms) + ")")
        i = i + 1
    i = 0
    while i < message.relevant_memories.len():
        val memory = message.relevant_memories[i]
        rows.push("Recalled " + collapsedReadSearchBasename(memory.path) + ": " + memory.content)
        i = i + 1
    rows

fn collapsedReadSearchSummary(message: CollapsedReadSearchGroupModel, active: bool, verbose: bool, fullscreen: bool, teamMemoryOps: bool) -> CollapsedSummary:
    if verbose:
        return CollapsedSummary.verboseRows(collapsedReadSearchVerboseRows(message))
    if not collapsedReadSearchHasMemoryOps(message) and not teamMemoryOps and not collapsedReadSearchHasNonMemoryOps(message, fullscreen):
        return CollapsedSummary.hidden()
    val parts = collapsedReadSearchOpParts(message, active, fullscreen)
    val memParts = collapsedReadSearchMemoryParts(message, active)
    val allParts = parts + memParts
    val ellipsis = if active: "..." else: ""
    val line = collapsedReadSearchJoin(allParts, ", ") + ellipsis + " Ctrl+O"
    val hint = collapsedReadSearchLiveHint(message, active) + collapsedReadSearchShellSuffix(message, active, fullscreen)
    CollapsedSummary.line(line, hint, collapsedReadSearchHookLine(message), active, collapsedReadSearchAnyError(message.tool_uses))

fn collapsedReadSearchSourceLinesModeled() -> i64:
    COLLAPSED_READ_SEARCH_CONTENT_SOURCE_LINES
