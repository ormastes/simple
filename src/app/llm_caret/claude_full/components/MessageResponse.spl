"""
Claude full message response wrapper parity model.
"""

const MESSAGE_RESPONSE_SOURCE_LINES = 77

class MessageResponseRender:
    mode: text
    childText: text
    marker: text
    height: i64
    ratchetLock: text

impl MessageResponseRender:
    static fn nested(childText: text) -> MessageResponseRender:
        MessageResponseRender(mode: "nested", childText: childText, marker: "", height: -1, ratchetLock: "")

    static fn framed(childText: text, height: i64, ratchetLock: text) -> MessageResponseRender:
        MessageResponseRender(mode: "framed", childText: childText, marker: "  >  ", height: height, ratchetLock: ratchetLock)

fn messageResponseContextDefault() -> bool:
    false

fn messageResponseProviderValue() -> bool:
    true

fn messageResponseShouldReturnChildren(isInsideMessageResponse: bool) -> bool:
    isInsideMessageResponse

fn messageResponseRatchetLock(height: i64) -> text:
    if height >= 0:
        return ""
    "offscreen"

fn MessageResponse(childText: text, height: i64, isInsideMessageResponse: bool) -> MessageResponseRender:
    if messageResponseShouldReturnChildren(isInsideMessageResponse):
        return MessageResponseRender.nested(childText)
    MessageResponseRender.framed(childText, height, messageResponseRatchetLock(height))

fn messageResponseHasExplicitHeight(height: i64) -> bool:
    height >= 0

fn messageResponseMarker() -> text:
    "  >  "

fn messageResponseOverflowY() -> text:
    "hidden"

fn messageResponseFlexDirection() -> text:
    "row"

fn messageResponseSourceLinesModeled() -> i64:
    MESSAGE_RESPONSE_SOURCE_LINES
