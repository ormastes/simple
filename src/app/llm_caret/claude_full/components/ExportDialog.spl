"""
Claude full ExportDialog parity.
"""

class ExportDialogState:
    open: bool
    format: text
    destination: text
    include_metadata: bool

impl ExportDialogState:
    static fn new(open: bool, format: text, destination: text, includeMetadata: bool) -> ExportDialogState:
        ExportDialogState(open: open, format: normalizeExportFormat(format), destination: destination.trim(), include_metadata: includeMetadata)

fn normalizeExportFormat(format: text) -> text:
    val clean = format.trim()
    if clean == "markdown" or clean == "json" or clean == "txt":
        return clean
    "markdown"

fn exportDialogTitle(state: ExportDialogState) -> text:
    "Export " + state.format

fn exportDialogCanSubmit(state: ExportDialogState) -> bool:
    state.open and state.destination != ""

fn exportDialogSummary(state: ExportDialogState) -> text:
    val meta = if state.include_metadata: "with metadata" else: "content only"
    exportDialogTitle(state) + " to " + state.destination + " " + meta

fn exportDialogActionLabel(state: ExportDialogState) -> text:
    if exportDialogCanSubmit(state):
        return "Export"
    "Choose destination"

fn exportDialogSourceLinesModeled() -> i64:
    127
