"""
Claude full DiagnosticsDisplay parity.
"""

class DiagnosticDisplayItem:
    severity: text
    message: text
    source: text

impl DiagnosticDisplayItem:
    static fn new(severity: text, message: text, source: text) -> DiagnosticDisplayItem:
        DiagnosticDisplayItem(severity: severity.trim(), message: message.trim(), source: source.trim())

fn diagnosticSeverityTone(item: DiagnosticDisplayItem) -> text:
    if item.severity == "error":
        return "red"
    if item.severity == "warning":
        return "yellow"
    if item.severity == "info":
        return "blue"
    "neutral"

fn diagnosticDisplayMessage(item: DiagnosticDisplayItem) -> text:
    if item.message == "":
        return "No diagnostic message"
    item.message

fn diagnosticDisplaySummary(item: DiagnosticDisplayItem) -> text:
    if item.source == "":
        return item.severity + ": " + diagnosticDisplayMessage(item)
    item.severity + " " + item.source + ": " + diagnosticDisplayMessage(item)

fn diagnosticsDisplayEmpty(count: i64) -> bool:
    count == 0

fn diagnosticsDisplaySourceLinesModeled() -> i64:
    94
