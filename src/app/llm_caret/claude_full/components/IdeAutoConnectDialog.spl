"""
Claude full IdeAutoConnectDialog parity.
"""

class IdeAutoConnectState:
    open: bool
    ide_name: text
    trusted: bool
    connecting: bool
    error: text

impl IdeAutoConnectState:
    static fn new(open: bool, ideName: text, trusted: bool, connecting: bool, error: text) -> IdeAutoConnectState:
        IdeAutoConnectState(open: open, ide_name: ideName.trim(), trusted: trusted, connecting: connecting, error: error.trim())

fn ideAutoConnectTitle(state: IdeAutoConnectState) -> text:
    if state.ide_name == "":
        return "Connect IDE"
    "Connect " + state.ide_name

fn ideAutoConnectCanConnect(state: IdeAutoConnectState) -> bool:
    state.open and state.trusted and not state.connecting and state.error == ""

fn ideAutoConnectStatus(state: IdeAutoConnectState) -> text:
    if state.error != "":
        return "error"
    if state.connecting:
        return "connecting"
    if state.trusted:
        return "ready"
    "untrusted"

fn ideAutoConnectSummary(state: IdeAutoConnectState) -> text:
    ideAutoConnectTitle(state) + " " + ideAutoConnectStatus(state)

fn ideAutoConnectDialogSourceLinesModeled() -> i64:
    153
