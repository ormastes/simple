"""
Claude full message model label parity model.
"""

const MESSAGE_MODEL_SOURCE_LINES = 42

class MessageContentBlock:
    typeName: text

impl MessageContentBlock:
    static fn new(typeName: text) -> MessageContentBlock:
        MessageContentBlock(typeName: typeName)

class MessageModelMessage:
    typeName: text
    model: text
    content: [MessageContentBlock]

impl MessageModelMessage:
    static fn new(typeName: text, model: text, content: [MessageContentBlock]) -> MessageModelMessage:
        MessageModelMessage(typeName: typeName, model: model, content: content)

class MessageModelRender:
    visible: bool
    model: text
    minWidth: i64

impl MessageModelRender:
    static fn hidden() -> MessageModelRender:
        MessageModelRender(visible: false, model: "", minWidth: 0)

    static fn visible(model: text) -> MessageModelRender:
        MessageModelRender(visible: true, model: model, minWidth: model.len() + 8)

fn messageModelHasTextContent(message: MessageModelMessage) -> bool:
    var i = 0
    while i < message.content.len():
        if message.content[i].typeName == "text":
            return true
        i = i + 1
    false

fn messageModelRender(message: MessageModelMessage, isTranscriptMode: bool) -> MessageModelRender:
    if not isTranscriptMode or message.typeName != "assistant" or message.model == "" or not messageModelHasTextContent(message):
        return MessageModelRender.hidden()
    MessageModelRender.visible(message.model)

fn messageModelSourceLinesModeled() -> i64:
    MESSAGE_MODEL_SOURCE_LINES
