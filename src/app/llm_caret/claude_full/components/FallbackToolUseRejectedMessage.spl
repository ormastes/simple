fn fallbackToolUseRejectedMessage(tool: text) -> text:
    val clean = tool.trim()
    if clean == "":
        return "Tool use rejected"
    "Tool use rejected: " + clean

fn fallbackToolUseRejectedSourceLinesModeled() -> i64:
    15
