"""
Claude full managed settings security utility parity.
"""

class ManagedSettingsInput:
    shell: text
    env_keys: [text]
    hook_count: i64

impl ManagedSettingsInput:
    static fn new(shell: text, envKeys: [text], hookCount: i64) -> ManagedSettingsInput:
        ManagedSettingsInput(shell: shell.trim(), env_keys: envKeys, hook_count: clampManagedSettingsCount(hookCount))

class DangerousSettings:
    shell_settings: [text]
    env_vars: [text]
    has_hooks: bool

impl DangerousSettings:
    static fn new(shellSettings: [text], envVars: [text], hasHooks: bool) -> DangerousSettings:
        DangerousSettings(shell_settings: shellSettings, env_vars: envVars, has_hooks: hasHooks)

fn clampManagedSettingsCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn isSafeManagedEnvVar(name: text) -> bool:
    val clean = name.trim().upper()
    clean == "PATH" or clean == "HOME" or clean == "LANG" or clean == "TERM" or clean == "SHELL"

fn managedShellSettings(input: ManagedSettingsInput) -> [text]:
    var out: [text] = []
    if input.shell != "":
        out.push("shell")
    out

fn managedDangerousEnvVars(input: ManagedSettingsInput) -> [text]:
    var out: [text] = []
    var i = 0
    while i < input.env_keys.len():
        if not isSafeManagedEnvVar(input.env_keys[i]):
            out.push(input.env_keys[i])
        i = i + 1
    out

fn extractDangerousSettings(input: ManagedSettingsInput) -> DangerousSettings:
    DangerousSettings.new(managedShellSettings(input), managedDangerousEnvVars(input), input.hook_count > 0)

fn hasDangerousSettings(dangerous: DangerousSettings) -> bool:
    dangerous.shell_settings.len() > 0 or dangerous.env_vars.len() > 0 or dangerous.has_hooks

fn managedSettingsListSignature(items: [text]) -> text:
    var out = ""
    var i = 0
    while i < items.len():
        if i > 0:
            out = out + ","
        out = out + items[i]
        i = i + 1
    out

fn dangerousSettingsSignature(dangerous: DangerousSettings) -> text:
    managedSettingsListSignature(dangerous.shell_settings) + "|" + managedSettingsListSignature(dangerous.env_vars) + "|hooks=" + dangerous.has_hooks.to_text()

fn hasDangerousSettingsChanged(oldSettings: ManagedSettingsInput, newSettings: ManagedSettingsInput) -> bool:
    val oldDangerous = extractDangerousSettings(oldSettings)
    val newDangerous = extractDangerousSettings(newSettings)
    if not hasDangerousSettings(newDangerous):
        return false
    if not hasDangerousSettings(oldDangerous):
        return true
    dangerousSettingsSignature(oldDangerous) != dangerousSettingsSignature(newDangerous)

fn formatDangerousSettingsList(dangerous: DangerousSettings) -> [text]:
    var items: [text] = []
    var i = 0
    while i < dangerous.shell_settings.len():
        items.push(dangerous.shell_settings[i])
        i = i + 1
    i = 0
    while i < dangerous.env_vars.len():
        items.push(dangerous.env_vars[i])
        i = i + 1
    if dangerous.has_hooks:
        items.push("hooks")
    items

fn managedSettingsUtilsSourceLinesModeled() -> i64:
    144
