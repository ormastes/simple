"""
Claude full managed settings security dialog parity.
"""

use app.llm_caret.claude_full.components.ManagedSettingsSecurityDialog.utils.*

class ManagedSettingsSecurityDialogState:
    settings: ManagedSettingsInput
    exit_pending: bool
    exit_key_name: text
    selected_value: text

impl ManagedSettingsSecurityDialogState:
    static fn new(settings: ManagedSettingsInput, exitPending: bool, exitKeyName: text, selectedValue: text) -> ManagedSettingsSecurityDialogState:
        ManagedSettingsSecurityDialogState(settings: settings, exit_pending: exitPending, exit_key_name: managedSettingsExitKey(exitKeyName), selected_value: normalizeManagedSettingsDialogChoice(selectedValue))

fn managedSettingsExitKey(keyName: text) -> text:
    val clean = keyName.trim()
    if clean == "":
        return "Esc"
    clean

fn normalizeManagedSettingsDialogChoice(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "accept" or clean == "exit":
        return clean
    "exit"

fn managedSettingsDialogChoiceResponse(value: text) -> text:
    if normalizeManagedSettingsDialogChoice(value) == "accept":
        return "accept"
    "reject"

fn managedSettingsDialogFooter(state: ManagedSettingsSecurityDialogState) -> text:
    if state.exit_pending:
        return "Press " + state.exit_key_name + " again to exit"
    "Enter to confirm - Esc to exit"

fn managedSettingsDialogOptions() -> [text]:
    [
        "accept:Yes, I trust these settings",
        "exit:No, exit Claude Code",
    ]

fn managedSettingsDialogSummary(state: ManagedSettingsSecurityDialogState) -> text:
    val dangerous = extractDangerousSettings(state.settings)
    val items = formatDangerousSettingsList(dangerous)
    "Managed settings require approval items=" + items.len().to_text() + " footer=" + managedSettingsDialogFooter(state)

fn managedSettingsSecurityDialogSourceLinesModeled() -> i64:
    148
