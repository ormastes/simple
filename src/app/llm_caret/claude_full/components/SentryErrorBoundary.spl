class SentryErrorBoundary:
    children: text
    hasError: bool

impl SentryErrorBoundary:
    static fn new(children: text) -> SentryErrorBoundary:
        SentryErrorBoundary(children: children, hasError: false)

    static fn getDerivedStateFromError() -> bool:
        true

    me render() -> text?:
        if me.hasError:
            return nil
        me.children

    me captureError() -> nil:
        me.hasError = SentryErrorBoundary.getDerivedStateFromError()

fn initialHasError() -> bool:
    false

fn errorStateHasError() -> bool:
    true

fn rendersNullAfterError() -> bool:
    true

fn rendersChildrenBeforeError() -> bool:
    true

fn sentryErrorBoundarySourceLinesModeled() -> i64:
    26

# Source parity note: Props contains children.
# Source parity note: State contains hasError.
# Source parity note: constructor initializes hasError false.
# Source parity note: getDerivedStateFromError returns hasError true.
# Source parity note: render returns null after error.
# Source parity note: render returns children before error.
