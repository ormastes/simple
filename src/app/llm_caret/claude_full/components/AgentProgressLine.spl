"""
Claude full AgentProgressLine component parity.
"""

class AgentProgressState:
    name: text
    status: text
    completedSteps: i64
    totalSteps: i64

impl AgentProgressState:
    static fn new(name: text, status: text, completedSteps: i64, totalSteps: i64) -> AgentProgressState:
        AgentProgressState(name: name, status: status, completedSteps: completedSteps, totalSteps: totalSteps)

fn progressPercent(state: AgentProgressState) -> i64:
    if state.totalSteps <= 0:
        return 0
    (state.completedSteps * 100) / state.totalSteps

fn agentProgressLineText(state: AgentProgressState) -> text:
    state.name + " " + state.status + " " + progressPercent(state).to_text() + "%"

fn isAgentProgressComplete(state: AgentProgressState) -> bool:
    state.totalSteps > 0 and state.completedSteps >= state.totalSteps

fn agentProgressLineSourceLinesModeled() -> i64:
    135
