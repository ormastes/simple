"""
Claude full AutoModeOptInDialog component parity.
"""

class AutoModeOptInState:
    enabled: bool
    dismissed: bool

impl AutoModeOptInState:
    static fn new(enabled: bool, dismissed: bool) -> AutoModeOptInState:
        AutoModeOptInState(enabled: enabled, dismissed: dismissed)

fn autoModeDialogTitle() -> text:
    "Enable auto mode"

fn autoModeDialogVisible(state: AutoModeOptInState) -> bool:
    not state.enabled and not state.dismissed

fn autoModeDialogMessage(state: AutoModeOptInState) -> text:
    if autoModeDialogVisible(state):
        return "Auto mode can continue routine work"
    "Auto mode dialog hidden"

fn autoModeOptInDialogSourceLinesModeled() -> i64:
