"""
Claude full ClaudeInChromeOnboarding component parity.
"""

class ChromeOnboardingState:
    installed: bool
    connected: bool

impl ChromeOnboardingState:
    static fn new(installed: bool, connected: bool) -> ChromeOnboardingState:
        ChromeOnboardingState(installed: installed, connected: connected)

fn chromeOnboardingStep(state: ChromeOnboardingState) -> text:
    if not state.installed:
        return "Install Chrome extension"
    if not state.connected:
        return "Connect Chrome extension"
    "Chrome extension ready"

fn chromeOnboardingCanContinue(state: ChromeOnboardingState) -> bool:
    state.installed and state.connected

fn claudeInChromeOnboardingSourceLinesModeled() -> i64:
    120
