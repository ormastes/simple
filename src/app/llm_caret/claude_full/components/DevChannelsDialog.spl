"""
Claude full DevChannelsDialog parity.
"""

class DevChannelState:
    name: text
    active: bool
    description: text

impl DevChannelState:
    static fn new(name: text, active: bool, description: text) -> DevChannelState:
        DevChannelState(name: name.trim(), active: active, description: description.trim())

fn devChannelLabel(channel: DevChannelState) -> text:
    if channel.name == "":
        return "unnamed"
    channel.name

fn devChannelSummary(channel: DevChannelState) -> text:
    val label = devChannelLabel(channel)
    if channel.active:
        return label + " active"
    label + " inactive"

fn devChannelsDialogTitle(count: i64) -> text:
    "Dev channels " + count.to_text()

fn devChannelsDialogCanSwitch(channel: DevChannelState) -> bool:
    not channel.active and channel.name != ""

fn devChannelsDialogSourceLinesModeled() -> i64:
    104
