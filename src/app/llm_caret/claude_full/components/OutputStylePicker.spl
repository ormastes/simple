"""
Claude full OutputStylePicker parity model.
"""

const OUTPUT_STYLE_PICKER_SOURCE_LINES = 111
const DEFAULT_OUTPUT_STYLE_LABEL = "Default"
const DEFAULT_OUTPUT_STYLE_DESCRIPTION = "Claude completes coding tasks efficiently and provides concise responses"

class OutputStyleConfig:
    name: text
    description: text

impl OutputStyleConfig:
    static fn new(name: text, description: text) -> OutputStyleConfig:
        OutputStyleConfig(name: name, description: description)

class OutputStyleOption:
    label: text
    value: text
    description: text

impl OutputStyleOption:
    static fn new(label: text, value: text, description: text) -> OutputStyleOption:
        OutputStyleOption(label: label, value: value, description: description)

class OutputStylePickerView:
    initial_style: text
    is_loading: bool
    standalone: bool
    title: text
    helper_text: text
    options: [OutputStyleOption]
    selected_value: text

impl OutputStylePickerView:
    static fn new(initialStyle: text, standalone: bool) -> OutputStylePickerView:
        OutputStylePickerView(initial_style: initialStyle, is_loading: true, standalone: standalone, title: "Preferred output style", helper_text: "This changes how Claude Code communicates with you", options: [], selected_value: initialStyle)

    me finish_load(options: [OutputStyleOption]):
        self.options = options
        self.is_loading = false

    me select(value: text):
        self.selected_value = value

fn mapConfigsToOutputStyleOptions(names: [text], configs: [OutputStyleConfig]) -> [OutputStyleOption]:
    var out: [OutputStyleOption] = []
    var i = 0
    for name in names:
        if i < configs.len():
            val cfg = configs[i]
            val label = if cfg.name == "": DEFAULT_OUTPUT_STYLE_LABEL else: cfg.name
            val description = if cfg.description == "": DEFAULT_OUTPUT_STYLE_DESCRIPTION else: cfg.description
            out.push(OutputStyleOption.new(label, name, description))
        else:
            out.push(OutputStyleOption.new(DEFAULT_OUTPUT_STYLE_LABEL, name, DEFAULT_OUTPUT_STYLE_DESCRIPTION))
        i = i + 1
    out

fn outputStylePickerHideChrome(isStandaloneCommand: bool) -> bool:
    not isStandaloneCommand

fn outputStylePickerSourceLinesModeled() -> i64:
    OUTPUT_STYLE_PICKER_SOURCE_LINES
