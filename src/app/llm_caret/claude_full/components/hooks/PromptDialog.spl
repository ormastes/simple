"""
Claude full hooks PromptDialog parity.
"""

class HookPromptDialogState:
    open: bool
    title: text
    prompt: text
    dirty: bool

impl HookPromptDialogState:
    static fn new(open: bool, title: text, prompt: text, dirty: bool) -> HookPromptDialogState:
        HookPromptDialogState(open: open, title: title.trim(), prompt: prompt.trim(), dirty: dirty)

fn hookPromptDialogTitle(state: HookPromptDialogState) -> text:
    if state.title == "":
        return "Hook prompt"
    state.title

fn hookPromptDialogCanSave(state: HookPromptDialogState) -> bool:
    state.open and state.dirty and state.prompt != ""

fn hookPromptDialogSummary(state: HookPromptDialogState) -> text:
    hookPromptDialogTitle(state) + " dirty=" + state.dirty.to_text()

fn promptDialogSourceLinesModeled() -> i64:
    89
