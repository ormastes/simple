"""
Claude full hooks SelectMatcherMode parity.
"""

class MatcherModeState:
    matcher: text
    pattern: text
    case_sensitive: bool

impl MatcherModeState:
    static fn new(matcher: text, pattern: text, caseSensitive: bool) -> MatcherModeState:
        MatcherModeState(matcher: normalizeMatcherMode(matcher), pattern: pattern.trim(), case_sensitive: caseSensitive)

fn normalizeMatcherMode(matcher: text) -> text:
    val clean = matcher.trim()
    if clean == "glob" or clean == "regex" or clean == "exact":
        return clean
    "glob"

fn matcherModeLabel(state: MatcherModeState) -> text:
    state.matcher + " " + state.pattern

fn matcherModeValid(state: MatcherModeState) -> bool:
    state.pattern != ""

fn matcherModeSummary(state: MatcherModeState) -> text:
    val sensitivity = if state.case_sensitive: "case" else: "ignore-case"
    matcherModeLabel(state) + " " + sensitivity

fn selectMatcherModeSourceLinesModeled() -> i64:
    143
