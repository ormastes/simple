"""
Claude full PackageManagerAutoUpdater parity model.
"""

const PACKAGE_MANAGER_AUTO_UPDATER_SOURCE_LINES = 103

class PackageManagerAutoUpdateState:
    update_available: bool
    latest_version: text
    max_version: text
    current_version: text
    package_manager: text
    verbose: bool

impl PackageManagerAutoUpdateState:
    static fn new(updateAvailable: bool, latestVersion: text, maxVersion: text, currentVersion: text, packageManager: text, verbose: bool) -> PackageManagerAutoUpdateState:
        PackageManagerAutoUpdateState(update_available: updateAvailable, latest_version: latestVersion, max_version: maxVersion, current_version: currentVersion, package_manager: packageManager, verbose: verbose)

fn packageManagerAutoUpdaterCommand(packageManager: text) -> text:
    if packageManager == "homebrew":
        "brew upgrade claude-code"
    else if packageManager == "winget":
        "winget upgrade Anthropic.ClaudeCode"
    else if packageManager == "apk":
        "apk upgrade claude-code"
    else:
        "your package manager update command"

fn packageManagerAutoUpdaterHasUpdate(state: PackageManagerAutoUpdateState) -> bool:
    state.update_available and state.latest_version != ""

fn packageManagerAutoUpdaterMessage(state: PackageManagerAutoUpdateState) -> text:
    if not packageManagerAutoUpdaterHasUpdate(state):
        ""
    else:
        val command = packageManagerAutoUpdaterCommand(state.package_manager)
        if state.verbose:
            "currentVersion: " + state.current_version + "\nUpdate available! Run: " + command
        else:
            "Update available! Run: " + command

fn packageManagerAutoUpdaterSourceLinesModeled() -> i64:
    PACKAGE_MANAGER_AUTO_UPDATER_SOURCE_LINES
