"""
Claude full ChannelDowngradeDialog component parity.
"""

fn channelDowngradeTitle(fromChannel: text, toChannel: text) -> text:
    "Switch from " + fromChannel.trim() + " to " + toChannel.trim()

fn channelDowngradeRequiresConfirm(fromChannel: text, toChannel: text) -> bool:
    fromChannel.trim() != "" and toChannel.trim() != "" and fromChannel.trim() != toChannel.trim()

fn channelDowngradeMessage(fromChannel: text, toChannel: text) -> text:
    if channelDowngradeRequiresConfirm(fromChannel, toChannel):
        return "Confirm channel change"
    "No channel change"

fn channelDowngradeDialogSourceLinesModeled() -> i64:
    101
