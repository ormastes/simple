"""
Claude full useFeedbackSurvey parity.
"""

class FeedbackSurveyDraft:
    rating: i64
    comment: text
    contact: text
    shareTranscript: bool

impl FeedbackSurveyDraft:
    static fn new(rating: i64, comment: text, contact: text, shareTranscript: bool) -> FeedbackSurveyDraft:
        FeedbackSurveyDraft(rating: clampFeedbackSurveyRating(rating), comment: normalizeFeedbackSurveyText(comment), contact: normalizeFeedbackSurveyText(contact), shareTranscript: shareTranscript)

class FeedbackSurveyValidation:
    valid: bool
    ratingError: text
    commentError: text
    contactError: text
    transcriptError: text

impl FeedbackSurveyValidation:
    static fn new(valid: bool, ratingError: text, commentError: text, contactError: text, transcriptError: text) -> FeedbackSurveyValidation:
        FeedbackSurveyValidation(valid: valid, ratingError: ratingError.trim(), commentError: commentError.trim(), contactError: contactError.trim(), transcriptError: transcriptError.trim())

class FeedbackSurveyPayload:
    rating: i64
    comment: text
    contact: text
    shareTranscript: bool
    sentiment: text

impl FeedbackSurveyPayload:
    static fn new(rating: i64, comment: text, contact: text, shareTranscript: bool, sentiment: text) -> FeedbackSurveyPayload:
        FeedbackSurveyPayload(rating: clampFeedbackSurveyRating(rating), comment: normalizeFeedbackSurveyText(comment), contact: normalizeFeedbackSurveyText(contact), shareTranscript: shareTranscript, sentiment: sentiment.trim())

class FeedbackSurveyHookState:
    draft: FeedbackSurveyDraft
    pending: bool
    submitted: bool
    error: text
    lastSubmittedRating: i64
    lastSubmittedComment: text
    lastSubmittedContact: text
    lastSubmittedShareTranscript: bool

impl FeedbackSurveyHookState:
    static fn new(draft: FeedbackSurveyDraft, pending: bool, submitted: bool, error: text, lastSubmittedRating: i64, lastSubmittedComment: text, lastSubmittedContact: text, lastSubmittedShareTranscript: bool) -> FeedbackSurveyHookState:
        FeedbackSurveyHookState(draft: draft, pending: pending, submitted: submitted, error: error.trim(), lastSubmittedRating: clampFeedbackSurveyRating(lastSubmittedRating), lastSubmittedComment: normalizeFeedbackSurveyText(lastSubmittedComment), lastSubmittedContact: normalizeFeedbackSurveyText(lastSubmittedContact), lastSubmittedShareTranscript: lastSubmittedShareTranscript)

fn normalizeFeedbackSurveyText(value: text) -> text:
    value.trim()

fn emptyFeedbackSurveyDraft() -> FeedbackSurveyDraft:
    FeedbackSurveyDraft.new(0, "", "", true)

fn createFeedbackSurveyDraft(rating: i64, comment: text, contact: text, shareTranscript: bool) -> FeedbackSurveyDraft:
    FeedbackSurveyDraft.new(rating, comment, contact, shareTranscript)

fn createFeedbackSurveyHookState() -> FeedbackSurveyHookState:
    FeedbackSurveyHookState.new(emptyFeedbackSurveyDraft(), false, false, "", 0, "", "", false)

fn clampFeedbackSurveyRating(rating: i64) -> i64:
    if rating < 0:
        return 0
    if rating > 5:
        return 5
    rating

fn feedbackSurveyCommentLimit() -> i64:
    4000

fn feedbackSurveyContactLimit() -> i64:
    320

fn feedbackSurveyHasRating(draft: FeedbackSurveyDraft) -> bool:
    draft.rating > 0

fn feedbackSurveyHasComment(draft: FeedbackSurveyDraft) -> bool:
    draft.comment != ""

fn feedbackSurveyHasContact(draft: FeedbackSurveyDraft) -> bool:
    draft.contact != ""

fn feedbackSurveyRatingLabel(rating: i64) -> text:
    val safe = clampFeedbackSurveyRating(rating)
    if safe == 1:
        return "Very bad"
    if safe == 2:
        return "Bad"
    if safe == 3:
        return "Okay"
    if safe == 4:
        return "Good"
    if safe == 5:
        return "Great"
    "No rating"

fn feedbackSurveySentimentForRating(rating: i64) -> text:
    val safe = clampFeedbackSurveyRating(rating)
    if safe >= 4:
        return "positive"
    if safe == 3:
        return "neutral"
    if safe > 0:
        return "negative"
    "missing"

fn feedbackSurveyDraftSentiment(draft: FeedbackSurveyDraft) -> text:
    feedbackSurveySentimentForRating(draft.rating)

fn feedbackSurveyContactLooksValid(contact: text) -> bool:
    val trimmed = normalizeFeedbackSurveyText(contact)
    if trimmed == "":
        return true
    if trimmed.contains("@"):
        return trimmed.contains(".")
    trimmed.len() >= 3

fn validateFeedbackSurveyDraft(draft: FeedbackSurveyDraft) -> FeedbackSurveyValidation:
    var ratingError = ""
    var commentError = ""
    var contactError = ""
    var transcriptError = ""
    if draft.rating <= 0:
        ratingError = "Choose a rating."
    if draft.comment.len() > feedbackSurveyCommentLimit():
        commentError = "Comment is too long."
    if draft.contact.len() > feedbackSurveyContactLimit():
        contactError = "Contact is too long."
    elif not feedbackSurveyContactLooksValid(draft.contact):
        contactError = "Enter a valid contact."
    if draft.shareTranscript and draft.rating <= 0:
        transcriptError = "Choose a rating before sharing transcript context."
    val ok = ratingError == "" and commentError == "" and contactError == "" and transcriptError == ""
    FeedbackSurveyValidation.new(ok, ratingError, commentError, contactError, transcriptError)

fn feedbackSurveyDraftHasChanges(state: FeedbackSurveyHookState) -> bool:
    if state.draft.rating != state.lastSubmittedRating:
        return true
    if state.draft.comment != state.lastSubmittedComment:
        return true
    if state.draft.contact != state.lastSubmittedContact:
        return true
    state.draft.shareTranscript != state.lastSubmittedShareTranscript

fn feedbackSurveyCanSubmit(state: FeedbackSurveyHookState) -> bool:
    if state.pending:
        return false
    val validation = validateFeedbackSurveyDraft(state.draft)
    if not validation.valid:
        return false
    if state.submitted and not feedbackSurveyDraftHasChanges(state):
        return false
    true

fn feedbackSurveySubmitReason(state: FeedbackSurveyHookState) -> text:
    if state.pending:
        return "pending"
    val validation = validateFeedbackSurveyDraft(state.draft)
    if validation.ratingError != "":
        return validation.ratingError
    if validation.commentError != "":
        return validation.commentError
    if validation.contactError != "":
        return validation.contactError
    if validation.transcriptError != "":
        return validation.transcriptError
    if state.submitted and not feedbackSurveyDraftHasChanges(state):
        return "Feedback already submitted."
    ""

fn feedbackSurveyPayloadFromDraft(draft: FeedbackSurveyDraft) -> FeedbackSurveyPayload:
    FeedbackSurveyPayload.new(draft.rating, draft.comment, draft.contact, draft.shareTranscript, feedbackSurveyDraftSentiment(draft))

fn updateFeedbackSurveyRating(state: FeedbackSurveyHookState, rating: i64) -> FeedbackSurveyHookState:
    val draft = FeedbackSurveyDraft.new(rating, state.draft.comment, state.draft.contact, state.draft.shareTranscript)
    FeedbackSurveyHookState.new(draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn updateFeedbackSurveyComment(state: FeedbackSurveyHookState, comment: text) -> FeedbackSurveyHookState:
    val draft = FeedbackSurveyDraft.new(state.draft.rating, comment, state.draft.contact, state.draft.shareTranscript)
    FeedbackSurveyHookState.new(draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn updateFeedbackSurveyContact(state: FeedbackSurveyHookState, contact: text) -> FeedbackSurveyHookState:
    val draft = FeedbackSurveyDraft.new(state.draft.rating, state.draft.comment, contact, state.draft.shareTranscript)
    FeedbackSurveyHookState.new(draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn updateFeedbackSurveyShareTranscript(state: FeedbackSurveyHookState, shareTranscript: bool) -> FeedbackSurveyHookState:
    val draft = FeedbackSurveyDraft.new(state.draft.rating, state.draft.comment, state.draft.contact, shareTranscript)
    FeedbackSurveyHookState.new(draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn updateFeedbackSurveyDraft(state: FeedbackSurveyHookState, draft: FeedbackSurveyDraft) -> FeedbackSurveyHookState:
    FeedbackSurveyHookState.new(draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn beginFeedbackSurveySubmit(state: FeedbackSurveyHookState) -> FeedbackSurveyHookState:
    if not feedbackSurveyCanSubmit(state):
        return FeedbackSurveyHookState.new(state.draft, false, state.submitted, feedbackSurveySubmitReason(state), state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)
    FeedbackSurveyHookState.new(state.draft, true, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn completeFeedbackSurveySubmit(state: FeedbackSurveyHookState) -> FeedbackSurveyHookState:
    FeedbackSurveyHookState.new(state.draft, false, true, "", state.draft.rating, state.draft.comment, state.draft.contact, state.draft.shareTranscript)

fn failFeedbackSurveySubmit(state: FeedbackSurveyHookState, message: text) -> FeedbackSurveyHookState:
    var errorMessage = message.trim()
    if errorMessage == "":
        errorMessage = "Failed to submit feedback."
    FeedbackSurveyHookState.new(state.draft, false, false, errorMessage, state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn resetFeedbackSurveyDraft(state: FeedbackSurveyHookState) -> FeedbackSurveyHookState:
    FeedbackSurveyHookState.new(emptyFeedbackSurveyDraft(), false, false, "", 0, "", "", false)

fn clearFeedbackSurveyError(state: FeedbackSurveyHookState) -> FeedbackSurveyHookState:
    FeedbackSurveyHookState.new(state.draft, state.pending, state.submitted, "", state.lastSubmittedRating, state.lastSubmittedComment, state.lastSubmittedContact, state.lastSubmittedShareTranscript)

fn feedbackSurveyLifecycle(state: FeedbackSurveyHookState) -> text:
    if state.pending:
        return "pending"
    if state.error != "":
        return "error"
    if state.submitted:
        return "submitted"
    "draft"

fn feedbackSurveyReadyLabel(state: FeedbackSurveyHookState) -> text:
    if feedbackSurveyCanSubmit(state):
        return "ready"
    feedbackSurveySubmitReason(state)

fn feedbackSurveyPayloadSummary(payload: FeedbackSurveyPayload) -> text:
    val shared = if payload.shareTranscript: "with transcript" else: "without transcript"
    payload.sentiment + " rating " + payload.rating.to_text() + " " + shared

fn feedbackSurveyStateSummary(state: FeedbackSurveyHookState) -> text:
    feedbackSurveyLifecycle(state) + " " + feedbackSurveyRatingLabel(state.draft.rating)

fn useFeedbackSurveySourceLinesModeled() -> i64:
    295

