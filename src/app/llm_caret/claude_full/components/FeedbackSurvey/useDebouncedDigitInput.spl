"""
Claude full useDebouncedDigitInput parity.
"""

class DebouncedDigitInputState:
    value: text
    pending: text
    delay_ms: i64

impl DebouncedDigitInputState:
    static fn new(value: text, pending: text, delayMs: i64) -> DebouncedDigitInputState:
        DebouncedDigitInputState(value: filterDigits(value), pending: filterDigits(pending), delay_ms: clampDebounceDelay(delayMs))

fn filterDigits(input: text) -> text:
    var out = ""
    var i = 0
    while i < input.len():
        val ch = input[i]
        if ch >= "0" and ch <= "9":
            out = out + ch
        i = i + 1
    out

fn clampDebounceDelay(delayMs: i64) -> i64:
    if delayMs < 0:
        return 0
    if delayMs > 5000:
        return 5000
    delayMs

fn debouncedDigitInputCommit(state: DebouncedDigitInputState) -> DebouncedDigitInputState:
    DebouncedDigitInputState.new(state.pending, state.pending, state.delay_ms)

fn useDebouncedDigitInputSourceLinesModeled() -> i64:
    82
