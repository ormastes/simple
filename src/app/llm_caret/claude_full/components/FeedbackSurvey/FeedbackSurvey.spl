"""
Claude full FeedbackSurvey parity.
"""

class FeedbackSurveyState:
    rating: i64
    comment: text
    email: text
    submitted: bool

impl FeedbackSurveyState:
    static fn new(rating: i64, comment: text, email: text, submitted: bool) -> FeedbackSurveyState:
        FeedbackSurveyState(rating: clampFeedbackRating(rating), comment: comment.trim(), email: email.trim(), submitted: submitted)

fn clampFeedbackRating(rating: i64) -> i64:
    if rating < 0:
        return 0
    if rating > 5:
        return 5
    rating

fn feedbackSurveyCanSubmit(state: FeedbackSurveyState) -> bool:
    not state.submitted and state.rating > 0

fn feedbackSurveySentiment(state: FeedbackSurveyState) -> text:
    if state.rating >= 4:
        return "positive"
    if state.rating == 0:
        return "missing"
    "needs-attention"

fn feedbackSurveySummary(state: FeedbackSurveyState) -> text:
    feedbackSurveySentiment(state) + " rating " + state.rating.to_text()

fn submitFeedbackSurvey(state: FeedbackSurveyState) -> FeedbackSurveyState:
    if feedbackSurveyCanSubmit(state):
        return FeedbackSurveyState.new(state.rating, state.comment, state.email, true)
    state

fn feedbackSurveySourceLinesModeled() -> i64:
    173
