"""
Claude full TranscriptSharePrompt parity.
"""

class TranscriptSharePromptState:
    visible: bool
    checked: bool
    transcript_id: text

impl TranscriptSharePromptState:
    static fn new(visible: bool, checked: bool, transcriptId: text) -> TranscriptSharePromptState:
        TranscriptSharePromptState(visible: visible, checked: checked, transcript_id: transcriptId.trim())

fn transcriptSharePromptVisible(state: TranscriptSharePromptState) -> bool:
    state.visible and state.transcript_id != ""

fn transcriptSharePromptLabel(state: TranscriptSharePromptState) -> text:
    if transcriptSharePromptVisible(state):
        return "Share transcript " + state.transcript_id
    "Transcript sharing unavailable"

fn transcriptSharePromptToggle(state: TranscriptSharePromptState) -> TranscriptSharePromptState:
    if not transcriptSharePromptVisible(state):
        return state
    TranscriptSharePromptState.new(state.visible, not state.checked, state.transcript_id)

fn transcriptSharePromptSourceLinesModeled() -> i64:
    87
