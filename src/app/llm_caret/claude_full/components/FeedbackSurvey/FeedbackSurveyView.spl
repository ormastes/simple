"""
Claude full FeedbackSurveyView parity.
"""

class FeedbackSurveyViewState:
    title: text
    open: bool
    submitting: bool
    error: text

impl FeedbackSurveyViewState:
    static fn new(title: text, open: bool, submitting: bool, error: text) -> FeedbackSurveyViewState:
        FeedbackSurveyViewState(title: title.trim(), open: open, submitting: submitting, error: error.trim())

fn feedbackSurveyViewTitle(state: FeedbackSurveyViewState) -> text:
    if state.title == "":
        return "Share feedback"
    state.title

fn feedbackSurveyViewVisible(state: FeedbackSurveyViewState) -> bool:
    state.open

fn feedbackSurveyViewBusy(state: FeedbackSurveyViewState) -> bool:
    state.submitting

fn feedbackSurveyViewStatus(state: FeedbackSurveyViewState) -> text:
    if state.error != "":
        return "error"
    if state.submitting:
        return "submitting"
    "ready"

fn feedbackSurveyViewSummary(state: FeedbackSurveyViewState) -> text:
    feedbackSurveyViewTitle(state) + " " + feedbackSurveyViewStatus(state)

fn feedbackSurveyViewSourceLinesModeled() -> i64:
    107
