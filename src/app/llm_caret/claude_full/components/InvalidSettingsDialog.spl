"""
Claude full InvalidSettingsDialog parity.
"""

class InvalidSettingsState:
    open: bool
    setting: text
    message: text

impl InvalidSettingsState:
    static fn new(open: bool, setting: text, message: text) -> InvalidSettingsState:
        InvalidSettingsState(open: open, setting: setting.trim(), message: message.trim())

fn invalidSettingsTitle(state: InvalidSettingsState) -> text:
    if state.setting == "":
        return "Invalid settings"
    "Invalid setting " + state.setting

fn invalidSettingsMessage(state: InvalidSettingsState) -> text:
    if state.message == "":
        return "Settings could not be loaded"
    state.message

fn invalidSettingsSummary(state: InvalidSettingsState) -> text:
    invalidSettingsTitle(state) + ": " + invalidSettingsMessage(state)

fn invalidSettingsDialogSourceLinesModeled() -> i64:
    88
