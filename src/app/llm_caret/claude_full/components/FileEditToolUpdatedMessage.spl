"""
Claude full FileEditToolUpdatedMessage parity.
"""

class FileEditUpdatedMessageState:
    path: text
    changed: bool
    line_count: i64

impl FileEditUpdatedMessageState:
    static fn new(path: text, changed: bool, lineCount: i64) -> FileEditUpdatedMessageState:
        FileEditUpdatedMessageState(path: path.trim(), changed: changed, line_count: clampUpdatedLineCount(lineCount))

fn clampUpdatedLineCount(lineCount: i64) -> i64:
    if lineCount < 0:
        return 0
    lineCount

fn fileEditUpdatedTitle(state: FileEditUpdatedMessageState) -> text:
    if state.changed:
        return "Updated " + state.path
    "No changes " + state.path

fn fileEditUpdatedSummary(state: FileEditUpdatedMessageState) -> text:
    fileEditUpdatedTitle(state) + " lines=" + state.line_count.to_text()

fn fileEditUpdatedTone(state: FileEditUpdatedMessageState) -> text:
    if state.changed:
        return "success"
    "muted"

fn fileEditToolUpdatedMessageSourceLinesModeled() -> i64:
    123
