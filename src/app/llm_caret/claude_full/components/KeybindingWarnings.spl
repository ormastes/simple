"""
Claude full KeybindingWarnings parity.
"""

fn keybindingWarningVisible(conflicts: i64) -> bool:
    conflicts > 0

fn keybindingWarningTone(conflicts: i64) -> text:
    if conflicts > 3:
        return "error"
    if conflicts > 0:
        return "warning"
    "muted"

fn keybindingWarningSummary(conflicts: i64, scope: text) -> text:
    val clean = scope.trim()
    if conflicts <= 0:
        return "No keybinding warnings"
    if clean == "":
        return conflicts.to_text() + " keybinding warning(s)"
    conflicts.to_text() + " keybinding warning(s) in " + clean

fn keybindingWarningsSourceLinesModeled() -> i64:
    54
