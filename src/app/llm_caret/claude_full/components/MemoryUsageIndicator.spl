"""
Claude full memory usage indicator parity model.
"""

const MEMORY_USAGE_INDICATOR_SOURCE_LINES = 36

class MemoryUsageSnapshot:
    heapUsed: i64
    status: text

impl MemoryUsageSnapshot:
    static fn new(heapUsed: i64, status: text) -> MemoryUsageSnapshot:
        MemoryUsageSnapshot(heapUsed: heapUsed, status: status)

class MemoryUsageIndicatorModel:
    visible: bool
    color: text
    message: text

impl MemoryUsageIndicatorModel:
    static fn hidden() -> MemoryUsageIndicatorModel:
        MemoryUsageIndicatorModel(visible: false, color: "", message: "")

    static fn visible(color: text, formattedSize: text) -> MemoryUsageIndicatorModel:
        MemoryUsageIndicatorModel(visible: true, color: color, message: "High memory usage (" + formattedSize + ") - /heapdump")

fn memoryUsageColor(status: text) -> text:
    if status == "critical":
        return "error"
    "warning"

fn memoryUsageIndicator(snapshot: MemoryUsageSnapshot, formattedSize: text, isAntBuild: bool) -> MemoryUsageIndicatorModel:
    if not isAntBuild:
        return MemoryUsageIndicatorModel.hidden()
    if snapshot.status == "normal":
        return MemoryUsageIndicatorModel.hidden()
    MemoryUsageIndicatorModel.visible(memoryUsageColor(snapshot.status), formattedSize)

fn memoryUsageIndicatorSourceLinesModeled() -> i64:
    MEMORY_USAGE_INDICATOR_SOURCE_LINES
