"""
Claude full HistorySearchDialog parity.
"""

class HistorySearchState:
    open: bool
    query: text
    selected_index: i64
    loading: bool
    error: text

impl HistorySearchState:
    static fn new(open: bool, query: text, selectedIndex: i64, loading: bool, error: text) -> HistorySearchState:
        HistorySearchState(open: open, query: query.trim(), selected_index: clampHistoryIndex(selectedIndex), loading: loading, error: error.trim())

fn clampHistoryIndex(index: i64) -> i64:
    if index < 0:
        return 0
    index

fn historySearchVisible(state: HistorySearchState) -> bool:
    state.open

fn historySearchStatus(state: HistorySearchState) -> text:
    if state.error != "":
        return "error"
    if state.loading:
        return "loading"
    if state.query == "":
        return "ready"
    "filtered"

fn historySearchSummary(state: HistorySearchState) -> text:
    "history " + historySearchStatus(state) + " query=" + state.query

fn historySearchNext(state: HistorySearchState, count: i64) -> HistorySearchState:
    if count <= 0:
        return HistorySearchState.new(state.open, state.query, 0, state.loading, state.error)
    if state.selected_index + 1 < count:
        return HistorySearchState.new(state.open, state.query, state.selected_index + 1, state.loading, state.error)
    HistorySearchState.new(state.open, state.query, 0, state.loading, state.error)

fn historySearchDialogSourceLinesModeled() -> i64:
    117
