"""
Claude full design-system Ratchet parity.
"""

class RatchetState:
    value: i64
    min: i64
    max: i64
    step: i64

impl RatchetState:
    static fn new(value: i64, min: i64, max: i64, step: i64) -> RatchetState:
        RatchetState(value: value, min: min, max: max, step: step)

fn ratchetClamp(state: RatchetState, value: i64) -> i64:
    if value < state.min:
        return state.min
    if value > state.max:
        return state.max
    value

fn ratchetNext(state: RatchetState) -> i64:
    ratchetClamp(state, state.value + state.step)

fn ratchetPrevious(state: RatchetState) -> i64:
    ratchetClamp(state, state.value - state.step)

fn ratchetLabel(state: RatchetState) -> text:
    ratchetClamp(state, state.value).to_text()

fn ratchetSourceLinesModeled() -> i64:
    79
