"""
Claude full design-system Dialog parity.
"""

class DialogState:
    title: text
    open: bool

impl DialogState:
    static fn new(title: text, open: bool) -> DialogState:
        DialogState(title: title.trim(), open: open)

fn dialogVisible(state: DialogState) -> bool:
    state.open

fn dialogHeader(state: DialogState) -> text:
    if state.title == "":
        return "Dialog"
    state.title

fn dialogSourceLinesModeled() -> i64:
    137
