"""
Claude full design-system Tabs parity.
"""

class TabItem:
    id: text
    label: text
    panelLabel: text
    badge: text
    status: text
    disabled: bool
    hidden: bool

impl TabItem:
    static fn new(id: text, label: text, panelLabel: text, badge: text, status: text, disabled: bool, hidden: bool) -> TabItem:
        TabItem(id: normalizeTabId(id, label), label: label.trim(), panelLabel: panelLabel.trim(), badge: badge.trim(), status: normalizeTabStatus(status), disabled: disabled, hidden: hidden)

    static fn enabled(id: text, label: text) -> TabItem:
        TabItem.new(id, label, "", "", "", false, false)

    static fn unavailable(id: text, label: text) -> TabItem:
        TabItem.new(id, label, "", "", "disabled", true, false)

    me selectable() -> bool:
        tabSelectable(self)

    me displayLabel() -> text:
        tabDisplayLabel(self)

    me ariaLabel(selected: bool, orientation: text) -> text:
        tabAriaLabel(self, selected, orientation)

class TabsState:
    activeId: text
    focusedId: text
    orientation: text
    variant: text
    wrap: bool
    maxVisible: i64

impl TabsState:
    static fn new(activeId: text, focusedId: text, orientation: text, variant: text, wrap: bool, maxVisible: i64) -> TabsState:
        TabsState(activeId: activeId.trim(), focusedId: focusedId.trim(), orientation: normalizeTabsOrientation(orientation), variant: normalizeTabsVariant(variant), wrap: wrap, maxVisible: normalizeTabsMaxVisible(maxVisible))

    static fn default() -> TabsState:
        TabsState.new("", "", "horizontal", "line", true, 4)

    me withActive(activeId: text) -> TabsState:
        TabsState.new(activeId, activeId, self.orientation, self.variant, self.wrap, self.maxVisible)

    me withFocused(focusedId: text) -> TabsState:
        TabsState.new(self.activeId, focusedId, self.orientation, self.variant, self.wrap, self.maxVisible)

    me withOrientation(orientation: text) -> TabsState:
        TabsState.new(self.activeId, self.focusedId, orientation, self.variant, self.wrap, self.maxVisible)

    me withVariant(variant: text) -> TabsState:
        TabsState.new(self.activeId, self.focusedId, self.orientation, variant, self.wrap, self.maxVisible)

class TabsModel:
    items: [TabItem]
    state: TabsState

impl TabsModel:
    static fn new(items: [TabItem], state: TabsState) -> TabsModel:
        TabsModel(items: items, state: normalizeTabsState(items, state))

    static fn sample() -> TabsModel:
        TabsModel.new(sampleTabs(), TabsState.default())

    me visibleTabs() -> [TabItem]:
        tabsVisibleItems(self.items)

    me selectedTab() -> TabItem?:
        findTabById(self.visibleTabs(), self.state.activeId)

    me focusedTab() -> TabItem?:
        findTabById(self.visibleTabs(), self.state.focusedId)

    me render() -> text:
        renderTabs(self.items, self.state)

fn sampleTabs() -> [TabItem]:
    [
        TabItem.new("chat", "Chat", "Chat transcript", "3", "ready", false, false),
        TabItem.new("files", "Files", "Changed files", "", "dirty", false, false),
        TabItem.new("tools", "Tools", "Tool calls", "!", "warning", false, false),
        TabItem.new("settings", "Settings", "Settings", "", "disabled", true, false),
        TabItem.new("hidden", "Hidden", "Hidden", "", "", false, true)
    ]

fn createTabs(items: [TabItem]) -> TabsModel:
    TabsModel.new(items, TabsState.default())

fn normalizeTabsState(items: [TabItem], state: TabsState) -> TabsState:
    val visible = tabsVisibleItems(items)
    val active = normalizeTabsSelectedId(visible, state.activeId)
    var focused = state.focusedId
    if focused == "" or findSelectableTabById(visible, focused) == nil:
        focused = active
    TabsState.new(active, focused, state.orientation, state.variant, state.wrap, state.maxVisible)

fn normalizeTabsSelectedId(items: [TabItem], selectedId: text) -> text:
    val wanted = selectedId.trim()
    if wanted != "" and findSelectableTabById(items, wanted) != nil:
        return wanted
    val index = firstSelectableTabIndex(items)
    if index == -1:
        return ""
    items[index].id

fn tabsVisibleItems(items: [TabItem]) -> [TabItem]:
    var out: [TabItem] = []
    var i = 0
    while i < items.len():
        if not items[i].hidden:
            out.push(items[i])
        i = i + 1
    out

fn tabsEnabledItems(items: [TabItem]) -> [TabItem]:
    var out: [TabItem] = []
    var i = 0
    while i < items.len():
        if tabSelectable(items[i]):
            out.push(items[i])
        i = i + 1
    out

fn tabSelectable(item: TabItem) -> bool:
    item.id != "" and not item.disabled and not item.hidden

fn firstSelectableTabIndex(items: [TabItem]) -> i64:
    var i = 0
    while i < items.len():
        if tabSelectable(items[i]):
            return i
        i = i + 1
    -1

fn lastSelectableTabIndex(items: [TabItem]) -> i64:
    var i = items.len() - 1
    while i >= 0:
        if tabSelectable(items[i]):
            return i
        i = i - 1
    -1

fn tabIndexById(items: [TabItem], id: text) -> i64:
    val wanted = id.trim()
    var i = 0
    while i < items.len():
        if items[i].id == wanted:
            return i
        i = i + 1
    -1

fn findTabById(items: [TabItem], id: text) -> TabItem?:
    val index = tabIndexById(items, id)
    if index == -1:
        return nil
    items[index]

fn findSelectableTabById(items: [TabItem], id: text) -> TabItem?:
    val tab = findTabById(items, id)
    if tab == nil:
        return nil
    if val Some(item) = tab:
        if tabSelectable(item):
            return item
    nil

fn activateTab(items: [TabItem], state: TabsState, id: text) -> TabsState:
    val visible = tabsVisibleItems(items)
    if findSelectableTabById(visible, id) == nil:
        return normalizeTabsState(items, state)
    TabsState.new(id, id, state.orientation, state.variant, state.wrap, state.maxVisible)

fn focusTab(items: [TabItem], state: TabsState, id: text) -> TabsState:
    val visible = tabsVisibleItems(items)
    if findSelectableTabById(visible, id) == nil:
        return normalizeTabsState(items, state)
    TabsState.new(state.activeId, id, state.orientation, state.variant, state.wrap, state.maxVisible)

fn commitFocusedTab(items: [TabItem], state: TabsState) -> TabsState:
    activateTab(items, state, state.focusedId)

fn focusNextTab(items: [TabItem], state: TabsState) -> TabsState:
    focusTabAtIndex(items, state, nextTabIndex(tabsVisibleItems(items), state.focusedId, state.wrap))

fn focusPreviousTab(items: [TabItem], state: TabsState) -> TabsState:
    focusTabAtIndex(items, state, previousTabIndex(tabsVisibleItems(items), state.focusedId, state.wrap))

fn focusFirstTab(items: [TabItem], state: TabsState) -> TabsState:
    focusTabAtIndex(items, state, firstSelectableTabIndex(tabsVisibleItems(items)))

fn focusLastTab(items: [TabItem], state: TabsState) -> TabsState:
    focusTabAtIndex(items, state, lastSelectableTabIndex(tabsVisibleItems(items)))

fn focusTabAtIndex(items: [TabItem], state: TabsState, index: i64) -> TabsState:
    val visible = tabsVisibleItems(items)
    if index < 0 or index >= visible.len():
        return normalizeTabsState(items, state)
    state.withFocused(visible[index].id)

fn nextTabIndex(items: [TabItem], focusedId: text, wrap: bool) -> i64:
    if items.len() == 0:
        return -1
    var index = tabIndexById(items, focusedId) + 1
    if index <= 0:
        index = 0
    var scanned = 0
    while scanned < items.len():
        if index >= items.len():
            if not wrap:
                return lastSelectableTabIndex(items)
            index = 0
        if tabSelectable(items[index]):
            return index
        index = index + 1
        scanned = scanned + 1
    -1

fn previousTabIndex(items: [TabItem], focusedId: text, wrap: bool) -> i64:
    if items.len() == 0:
        return -1
    var index = tabIndexById(items, focusedId) - 1
    if index < 0:
        index = items.len() - 1
    var scanned = 0
    while scanned < items.len():
        if index < 0:
            if not wrap:
                return firstSelectableTabIndex(items)
            index = items.len() - 1
        if tabSelectable(items[index]):
            return index
        index = index - 1
        scanned = scanned + 1
    -1

fn visibleTabsForHeader(items: [TabItem], state: TabsState) -> [TabItem]:
    val visible = tabsVisibleItems(items)
    if state.maxVisible >= visible.len():
        return visible
    var out: [TabItem] = []
    var i = 0
    while i < state.maxVisible:
        out.push(visible[i])
        i = i + 1
    out

fn overflowTabs(items: [TabItem], state: TabsState) -> [TabItem]:
    val visible = tabsVisibleItems(items)
    var out: [TabItem] = []
    var i = state.maxVisible
    while i < visible.len():
        out.push(visible[i])
        i = i + 1
    out

fn tabsOverflowCount(items: [TabItem], state: TabsState) -> i64:
    overflowTabs(items, state).len()

fn tabsHasOverflow(items: [TabItem], state: TabsState) -> bool:
    tabsOverflowCount(items, state) > 0

fn tabDisplayLabel(item: TabItem) -> text:
    var label = item.label
    if label == "":
        label = item.id
    if item.badge != "":
        label = label + " (" + item.badge + ")"
    if item.status != "":
        label = label + " - " + item.status
    label

fn tabPanelLabel(item: TabItem) -> text:
    if item.panelLabel != "":
        return item.panelLabel
    if item.label != "":
        return item.label + " panel"
    item.id + " panel"

fn tabAriaLabel(item: TabItem, selected: bool, orientation: text) -> text:
    val selectedLabel = if selected: "selected" else: "not selected"
    val enabledLabel = if item.disabled: "disabled" else: "enabled"
    tabDisplayLabel(item) + " tab, " + selectedLabel + ", " + enabledLabel + ", " + normalizeTabsOrientation(orientation)

fn tabsAriaRole(state: TabsState) -> text:
    "tablist " + state.orientation

fn tabsVariantClass(state: TabsState) -> text:
    "tabs-" + state.variant + " tabs-" + state.orientation

fn tabsBadgeSummary(items: [TabItem]) -> text:
    var parts: [text] = []
    var i = 0
    while i < items.len():
        if items[i].badge != "" and not items[i].hidden:
            parts.push(items[i].label + ":" + items[i].badge)
        i = i + 1
    if parts.len() == 0:
        return "no badges"
    joinTabsText(parts, ", ")

fn tabsStatusSummary(items: [TabItem]) -> text:
    var ready = 0
    var dirty = 0
    var warning = 0
    var disabled = 0
    var i = 0
    while i < items.len():
        if not items[i].hidden:
            if items[i].status == "ready":
                ready = ready + 1
            if items[i].status == "dirty":
                dirty = dirty + 1
            if items[i].status == "warning":
                warning = warning + 1
            if items[i].disabled:
                disabled = disabled + 1
        i = i + 1
    "ready=" + ready.to_text() + " dirty=" + dirty.to_text() + " warning=" + warning.to_text() + " disabled=" + disabled.to_text()

fn renderTabs(items: [TabItem], state: TabsState) -> text:
    val normalized = normalizeTabsState(items, state)
    val visible = visibleTabsForHeader(items, normalized)
    if visible.len() == 0:
        return tabsEmptyMessage()
    var lines: [text] = [renderTabsHeader(items, normalized)]
    var i = 0
    while i < visible.len():
        lines.push(renderTabRow(visible[i], visible[i].id == normalized.activeId, visible[i].id == normalized.focusedId, normalized))
        i = i + 1
    if tabsHasOverflow(items, normalized):
        lines.push(renderTabsOverflow(items, normalized))
    lines.push("panel " + tabPanelLabel(findSelectedTabOrFallback(items, normalized)))
    joinTabsText(lines, "\n")

fn renderTabsHeader(items: [TabItem], state: TabsState) -> text:
    val visible = tabsVisibleItems(items)
    "Tabs " + visible.len().to_text() + "/" + items.len().to_text() + " " + tabsAriaRole(state) + " " + tabsVariantClass(state) + " " + tabsStatusSummary(items)

fn renderTabRow(item: TabItem, selected: bool, focused: bool, state: TabsState) -> text:
    val selectedMarker = if selected: ">" else: " "
    val focusedMarker = if focused: "*" else: " "
    selectedMarker + focusedMarker + " " + tabDisplayLabel(item) + " | " + tabAriaLabel(item, selected, state.orientation)

fn renderTabsOverflow(items: [TabItem], state: TabsState) -> text:
    val overflow = overflowTabs(items, state)
    var names: [text] = []
    var i = 0
    while i < overflow.len():
        names.push(tabDisplayLabel(overflow[i]))
        i = i + 1
    "overflow +" + overflow.len().to_text() + ": " + joinTabsText(names, ", ")

fn findSelectedTabOrFallback(items: [TabItem], state: TabsState) -> TabItem:
    val visible = tabsVisibleItems(items)
    val selected = findTabById(visible, state.activeId)
    if val Some(item) = selected:
        return item
    val index = firstSelectableTabIndex(visible)
    if index >= 0:
        return visible[index]
    TabItem.new("", "Empty", "Empty panel", "", "", true, false)

fn tabsEmptyMessage() -> text:
    "No tabs available"

fn normalizeTabId(id: text, label: text) -> text:
    val trimmed = id.trim()
    if trimmed != "":
        return trimmed
    label.trim().lower().replace(" ", "-")

fn normalizeTabStatus(status: text) -> text:
    val value = status.trim().lower()
    if value == "ready":
        return "ready"
    if value == "dirty":
        return "dirty"
    if value == "warning":
        return "warning"
    if value == "disabled":
        return "disabled"
    ""

fn normalizeTabsOrientation(orientation: text) -> text:
    val value = orientation.trim().lower()
    if value == "vertical":
        return "vertical"
    "horizontal"

fn normalizeTabsVariant(variant: text) -> text:
    val value = variant.trim().lower()
    if value == "pill":
        return "pill"
    if value == "underline":
        return "underline"
    if value == "compact":
        return "compact"
    "line"

fn normalizeTabsMaxVisible(maxVisible: i64) -> i64:
    if maxVisible < 1:
        return 1
    maxVisible

fn tabsKeyboardAction(items: [TabItem], state: TabsState, key: text) -> TabsState:
    val normalizedKey = key.trim()
    if normalizedKey == "ArrowRight" or normalizedKey == "ArrowDown":
        return focusNextTab(items, state)
    if normalizedKey == "ArrowLeft" or normalizedKey == "ArrowUp":
        return focusPreviousTab(items, state)
    if normalizedKey == "Home":
        return focusFirstTab(items, state)
    if normalizedKey == "End":
        return focusLastTab(items, state)
    if normalizedKey == "Enter" or normalizedKey == " ":
        return commitFocusedTab(items, state)
    normalizeTabsState(items, state)

fn tabsModeledSourceFile() -> text:
    "src/components/design-system/Tabs.tsx"

fn tabsModeledComponentName() -> text:
    "Tabs"

fn tabsModeledStateHelper() -> text:
    "useTabsState"

fn tabsModeledKeyboardHelper() -> text:
    "handleKeyDown"

fn tabsSourceLinesModeled() -> i64:
    339

fn joinTabsText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out
