"""
Claude full MarkdownTable parity.
"""

val MARKDOWN_TABLE_SAFETY_MARGIN = 4
val MARKDOWN_TABLE_MIN_COLUMN_WIDTH = 3
val MARKDOWN_TABLE_MAX_ROW_LINES = 4

class MarkdownTableState:
    headers: [text]
    rows: [[text]]
    terminal_width: i64

impl MarkdownTableState:
    static fn new(headers: [text], rows: [[text]], terminalWidth: i64) -> MarkdownTableState:
        MarkdownTableState(headers: headers, rows: rows, terminal_width: markdownTableWidth(terminalWidth))

fn markdownTableWidth(width: i64) -> i64:
    if width < 20:
        return 20
    width

fn markdownTableCellWidth(value: text) -> i64:
    val clean = value.trim()
    if clean.len() < MARKDOWN_TABLE_MIN_COLUMN_WIDTH:
        return MARKDOWN_TABLE_MIN_COLUMN_WIDTH
    clean.len()

fn markdownTableColumnCount(state: MarkdownTableState) -> i64:
    state.headers.len()

fn markdownTableAvailableWidth(state: MarkdownTableState) -> i64:
    val cols = markdownTableColumnCount(state)
    val border = 1 + cols * 3
    state.terminal_width - border - MARKDOWN_TABLE_SAFETY_MARGIN

fn markdownTableColumnWidth(state: MarkdownTableState) -> i64:
    val cols = markdownTableColumnCount(state)
    if cols == 0:
        return MARKDOWN_TABLE_MIN_COLUMN_WIDTH
    val available = markdownTableAvailableWidth(state)
    if available / cols < MARKDOWN_TABLE_MIN_COLUMN_WIDTH:
        return MARKDOWN_TABLE_MIN_COLUMN_WIDTH
    available / cols

fn markdownTableShouldUseVertical(state: MarkdownTableState) -> bool:
    markdownTableColumnWidth(state) <= MARKDOWN_TABLE_MIN_COLUMN_WIDTH or state.rows.len() > MARKDOWN_TABLE_MAX_ROW_LINES

fn markdownTableSummary(state: MarkdownTableState) -> text:
    if markdownTableShouldUseVertical(state):
        return "markdown-table vertical cols=" + state.headers.len().to_text()
    "markdown-table grid cols=" + state.headers.len().to_text() + " width=" + markdownTableColumnWidth(state).to_text()

fn markdownTableSourceLinesModeled() -> i64:
    321
