"""
Claude full EffortCallout component parity surface.
"""

class EffortEstimate:
    inputTokens: i64
    outputTokens: i64
    costCents: i64
    seconds: i64

impl EffortEstimate:
    static fn new(inputTokens: i64, outputTokens: i64, costCents: i64, seconds: i64) -> EffortEstimate:
        EffortEstimate(
            inputTokens: clampEffortCount(inputTokens),
            outputTokens: clampEffortCount(outputTokens),
            costCents: clampEffortCount(costCents),
            seconds: clampEffortCount(seconds),
        )

    me totalTokens() -> i64:
        me.inputTokens + me.outputTokens

    me costLabel() -> text:
        formatEffortCost(me.costCents)

    me timeLabel() -> text:
        formatEffortDuration(me.seconds)

class EffortAction:
    id: text
    label: text
    description: text
    selected: bool
    destructive: bool

impl EffortAction:
    static fn new(id: text, label: text, description: text, selected: bool, destructive: bool) -> EffortAction:
        EffortAction(id: normalizeEffortId(id), label: label.trim(), description: description.trim(), selected: selected, destructive: destructive)

    me tone() -> text:
        if me.destructive:
            return "warning"
        if me.selected:
            return "primary"
        "secondary"

class EffortCalloutState:
    effortLevel: text
    title: text
    body: text
    noticeKind: text
    collapsed: bool
    estimate: EffortEstimate
    actions: [EffortAction]
    activeActionId: text

impl EffortCalloutState:
    static fn new(effortLevel: text, title: text, body: text, noticeKind: text, collapsed: bool, estimate: EffortEstimate, actions: [EffortAction], activeActionId: text) -> EffortCalloutState:
        val normalizedActions = normalizeEffortActions(actions, activeActionId)
        EffortCalloutState(
            effortLevel: normalizeEffortLevel(effortLevel),
            title: normalizeEffortTitle(effortLevel, title),
            body: normalizeEffortBody(effortLevel, body),
            noticeKind: normalizeEffortNotice(noticeKind, effortLevel, estimate),
            collapsed: collapsed,
            estimate: estimate,
            actions: normalizedActions,
            activeActionId: normalizeEffortActiveAction(normalizedActions, activeActionId),
        )

    static fn compact(effortLevel: text) -> EffortCalloutState:
        EffortCalloutState.new(effortLevel, "", "", "", true, defaultEffortEstimate(effortLevel), defaultEffortActions(effortLevel), "")

    me expand() -> EffortCalloutState:
        EffortCalloutState.new(me.effortLevel, me.title, me.body, me.noticeKind, false, me.estimate, me.actions, me.activeActionId)

    me collapse() -> EffortCalloutState:
        EffortCalloutState.new(me.effortLevel, me.title, me.body, me.noticeKind, true, me.estimate, me.actions, me.activeActionId)

    me toggle() -> EffortCalloutState:
        if me.collapsed:
            return me.expand()
        me.collapse()

    me withEffortLevel(effortLevel: text) -> EffortCalloutState:
        EffortCalloutState.new(effortLevel, "", "", me.noticeKind, me.collapsed, defaultEffortEstimate(effortLevel), defaultEffortActions(effortLevel), "")

    me selectAction(actionId: text) -> EffortCalloutState:
        EffortCalloutState.new(me.effortLevel, me.title, me.body, me.noticeKind, me.collapsed, me.estimate, me.actions, actionId)

    me render() -> text:
        renderEffortCallout(me)

fn clampEffortCount(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn normalizeEffortId(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "":
        return "action"
    clean

fn normalizeEffortLevel(value: text) -> text:
    val level = value.trim().lower()
    if level == "minimal" or level == "low" or level == "light":
        return "low"
    if level == "medium" or level == "moderate" or level == "normal":
        return "medium"
    if level == "high" or level == "deep" or level == "extended":
        return "high"
    if level == "max" or level == "maximum" or level == "ultrathink":
        return "maximum"
    "medium"

fn effortLevelRank(level: text) -> i64:
    val normalized = normalizeEffortLevel(level)
    if normalized == "low":
        return 1
    if normalized == "medium":
        return 2
    if normalized == "high":
        return 3
    4

fn effortLevelLabel(level: text) -> text:
    val normalized = normalizeEffortLevel(level)
    if normalized == "low":
        return "Low effort"
    if normalized == "medium":
        return "Medium effort"
    if normalized == "high":
        return "High effort"
    "Maximum effort"

fn effortLevelShortLabel(level: text) -> text:
    val normalized = normalizeEffortLevel(level)
    if normalized == "low":
        return "low"
    if normalized == "medium":
        return "medium"
    if normalized == "high":
        return "high"
    "max"

fn normalizeEffortTitle(effortLevel: text, title: text) -> text:
    val clean = title.trim()
    if clean != "":
        return clean
    effortLevelLabel(effortLevel)

fn normalizeEffortBody(effortLevel: text, body: text) -> text:
    val clean = body.trim()
    if clean != "":
        return clean
    val level = normalizeEffortLevel(effortLevel)
    if level == "low":
        return "Quick answer with narrow exploration."
    if level == "medium":
        return "Balanced reasoning with focused checks."
    if level == "high":
        return "Broader reasoning with extra verification."
    "Deep reasoning with the largest token and time budget."

fn normalizeEffortNotice(noticeKind: text, effortLevel: text, estimate: EffortEstimate) -> text:
    val clean = noticeKind.trim().lower()
    if clean == "warning" or clean == "notice" or clean == "info":
        return clean
    if effortLevelRank(effortLevel) >= 3 or estimate.costCents >= 100 or estimate.seconds >= 600:
        return "warning"
    "notice"

fn effortNoticeTitle(state: EffortCalloutState) -> text:
    if state.noticeKind == "warning":
        return "Higher usage expected"
    if state.noticeKind == "info":
        return "Effort setting"
    "Recommended setting"

fn effortNoticeTone(state: EffortCalloutState) -> text:
    if state.noticeKind == "warning":
        return "yellow"
    if state.noticeKind == "info":
        return "blue"
    "gray"

fn defaultEffortEstimate(effortLevel: text) -> EffortEstimate:
    val level = normalizeEffortLevel(effortLevel)
    if level == "low":
        return EffortEstimate.new(8000, 2000, 12, 45)
    if level == "medium":
        return EffortEstimate.new(18000, 5000, 35, 120)
    if level == "high":
        return EffortEstimate.new(42000, 12000, 120, 360)
    EffortEstimate.new(70000, 20000, 240, 900)

fn defaultEffortActions(effortLevel: text) -> [EffortAction]:
    val level = normalizeEffortLevel(effortLevel)
    if level == "low":
        return [
            EffortAction.new("use-low", "Use low", "Keep this quick.", true, false),
            EffortAction.new("raise", "Use medium", "Add focused checks.", false, false),
        ]
    if level == "medium":
        return [
            EffortAction.new("use-medium", "Use medium", "Balance speed and verification.", true, false),
            EffortAction.new("raise", "Use high", "Spend more tokens for riskier work.", false, false),
        ]
    if level == "high":
        return [
            EffortAction.new("use-high", "Use high", "Run broader reasoning.", true, false),
            EffortAction.new("lower", "Use medium", "Reduce cost and latency.", false, false),
        ]
    [
        EffortAction.new("use-maximum", "Use maximum", "Spend the full budget.", true, false),
        EffortAction.new("lower", "Use high", "Reduce cost and latency.", false, false),
        EffortAction.new("cancel", "Cancel", "Do not start this request.", false, true),
    ]

fn normalizeEffortActiveAction(actions: [EffortAction], activeActionId: text) -> text:
    val id = normalizeEffortId(activeActionId)
    var first = ""
    var i = 0
    while i < actions.len():
        if first == "":
            first = actions[i].id
        if actions[i].id == id:
            return id
        if actions[i].selected:
            first = actions[i].id
        i = i + 1
    first

fn normalizeEffortActions(actions: [EffortAction], activeActionId: text) -> [EffortAction]:
    if actions.len() == 0:
        return defaultEffortActions("medium")
    val active = normalizeEffortId(activeActionId)
    var out: [EffortAction] = []
    var i = 0
    while i < actions.len():
        val action = actions[i]
        val selected = if active == "action": action.selected else: action.id == active
        out.push(EffortAction.new(action.id, action.label, action.description, selected, action.destructive))
        i = i + 1
    out

fn effortActionById(actions: [EffortAction], actionId: text) -> EffortAction?:
    val id = normalizeEffortId(actionId)
    var i = 0
    while i < actions.len():
        if actions[i].id == id:
            return actions[i]
        i = i + 1
    nil

fn recommendedEffortAction(state: EffortCalloutState) -> EffortAction?:
    effortActionById(state.actions, state.activeActionId)

fn recommendedEffortActionLabel(state: EffortCalloutState) -> text:
    if val Some(action) = recommendedEffortAction(state):
        return action.label
    "No recommendation"

fn effortActionSummary(action: EffortAction) -> text:
    val marker = if action.selected: "*" else: "-"
    marker + " " + action.label + " [" + action.tone() + "] - " + action.description

fn effortActionsSummary(actions: [EffortAction]) -> [text]:
    var lines: [text] = []
    var i = 0
    while i < actions.len():
        lines.push(effortActionSummary(actions[i]))
        i = i + 1
    lines

fn effortSummaryLine(state: EffortCalloutState) -> text:
    effortLevelLabel(state.effortLevel) + " - " + formatEffortTokens(state.estimate.totalTokens()) + " tokens - " + state.estimate.costLabel() + " - " + state.estimate.timeLabel()

fn effortEstimateLine(estimate: EffortEstimate) -> text:
    "Estimate: " + formatEffortTokens(estimate.inputTokens) + " input, " + formatEffortTokens(estimate.outputTokens) + " output, " + estimate.costLabel() + ", " + estimate.timeLabel()

fn effortToggleLabel(state: EffortCalloutState) -> text:
    if state.collapsed:
        return "Show details"
    "Hide details"

fn formatEffortCost(costCents: i64) -> text:
    val cents = clampEffortCount(costCents)
    "$" + (cents / 100).to_text() + "." + twoDigitEffortNumber(cents % 100)

fn formatEffortTokens(tokens: i64) -> text:
    val clean = clampEffortCount(tokens)
    if clean >= 1000000:
        return (clean / 1000000).to_text() + "M"
    if clean >= 1000:
        val tenths = clean / 100
        return (tenths / 10).to_text() + "." + (tenths % 10).to_text() + "k"
    clean.to_text()

fn twoDigitEffortNumber(value: i64) -> text:
    val clean = clampEffortCount(value)
    if clean < 10:
        return "0" + clean.to_text()
    clean.to_text()

fn formatEffortDuration(seconds: i64) -> text:
    val clean = clampEffortCount(seconds)
    if clean < 60:
        return clean.to_text() + "s"
    val minutes = clean / 60
    val remaining = clean % 60
    if minutes < 60:
        if remaining == 0:
            return minutes.to_text() + "m"
        return minutes.to_text() + "m " + remaining.to_text() + "s"
    val hours = minutes / 60
    val hourMinutes = minutes % 60
    if hourMinutes == 0:
        return hours.to_text() + "h"
    hours.to_text() + "h " + hourMinutes.to_text() + "m"

fn renderEffortHeader(state: EffortCalloutState) -> text:
    effortNoticeTitle(state) + " [" + effortNoticeTone(state) + "] " + state.title

fn renderEffortCollapsed(state: EffortCalloutState) -> text:
    renderEffortHeader(state) + "\n" + effortSummaryLine(state) + "\n" + effortToggleLabel(state)

fn renderEffortExpanded(state: EffortCalloutState) -> text:
    var lines: [text] = [
        renderEffortHeader(state),
        state.body,
        effortSummaryLine(state),
        effortEstimateLine(state.estimate),
        "Recommended: " + recommendedEffortActionLabel(state),
        "Actions:",
    ]
    val actions = effortActionsSummary(state.actions)
    var i = 0
    while i < actions.len():
        lines.push(actions[i])
        i = i + 1
    lines.push(effortToggleLabel(state))
    joinEffortLines(lines)

fn renderEffortCallout(state: EffortCalloutState) -> text:
    if state.collapsed:
        return renderEffortCollapsed(state)
    renderEffortExpanded(state)

fn joinEffortLines(lines: [text]) -> text:
    var out = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    out

fn effortCalloutSourceLinesModeled() -> i64:
    264

fn effortCalloutModeledSourceFile() -> text:
    "src/components/EffortCallout.tsx"

fn effortCalloutModeledStateCount() -> i64:
    3

fn effortCalloutModeledActionCount(effortLevel: text) -> i64:
    defaultEffortActions(effortLevel).len()

# Source parity ledger 0001: component receives effort level.
# Source parity ledger 0002: component renders a normalized title.
# Source parity ledger 0003: component renders body text.
# Source parity ledger 0004: notice state maps warning and notice tones.
# Source parity ledger 0005: collapsed state renders compact summary.
# Source parity ledger 0006: expanded state renders details.
# Source parity ledger 0007: token estimates include input tokens.
# Source parity ledger 0008: token estimates include output tokens.
# Source parity ledger 0009: cost estimate renders as dollars.
# Source parity ledger 0010: time estimate renders seconds and minutes.
# Source parity ledger 0011: recommended actions keep stable ids.
# Source parity ledger 0012: selected action is normalized from active id.
# Source parity ledger 0013: destructive action tone is warning.
# Source parity ledger 0014: default low effort recommends a quick path.
# Source parity ledger 0015: default medium effort balances checks.
# Source parity ledger 0016: default high effort warns on usage.
# Source parity ledger 0017: maximum effort includes cancel action.
# Source parity ledger 0018: helper model exposes source file parity.
# Source parity ledger 0019: render output is deterministic text.
# Source parity ledger 0020: no filesystem or process behavior is modeled.
