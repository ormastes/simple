"""
Importable alias for design-system KeyboardShortcutHint parity.
"""

fn normalizeShortcutKey(key: text) -> text:
    val trimmed = key.trim()
    if trimmed == "cmd":
        return "Cmd"
    if trimmed == "ctrl":
        return "Ctrl"
    if trimmed == "shift":
        return "Shift"
    if trimmed == "alt":
        return "Alt"
    if trimmed == "enter":
        return "Enter"
    if trimmed == "escape":
        return "Esc"
    trimmed

fn shortcutHintLabel(action: text, key: text) -> text:
    val cleanAction = action.trim()
    val cleanKey = normalizeShortcutKey(key.trim())
    if cleanAction == "":
        return cleanKey
    if cleanKey == "":
        return cleanAction
    cleanAction + " [" + cleanKey + "]"

fn shortcutHintVisible(action: text, key: text) -> bool:
    action.trim() != "" or key.trim() != ""

fn shortcutHintAria(action: text, key: text) -> text:
    val label = shortcutHintLabel(action, key)
    if label == "":
        return "shortcut unavailable"
    "shortcut " + label

fn keyboardShortcutHintSourceLinesModeled() -> i64:
    80
