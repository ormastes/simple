"""
Importable alias for design-system ThemeProvider parity.
"""

class ThemeProviderState:
    theme: text
    system_theme: text
    high_contrast: bool
    reduced_motion: bool

impl ThemeProviderState:
    static fn new(theme: text, systemTheme: text, highContrast: bool, reducedMotion: bool) -> ThemeProviderState:
        ThemeProviderState(theme: theme.trim(), system_theme: systemTheme.trim(), high_contrast: highContrast, reduced_motion: reducedMotion)

fn themeProviderRequestedTheme(state: ThemeProviderState) -> text:
    if state.theme == "":
        return "system"
    state.theme

fn themeProviderResolvedTheme(state: ThemeProviderState) -> text:
    val requested = themeProviderRequestedTheme(state)
    if requested == "system":
        if state.system_theme == "":
            return "light"
        return state.system_theme
    requested

fn themeProviderClassName(state: ThemeProviderState) -> text:
    val base = "theme-" + themeProviderResolvedTheme(state)
    if state.high_contrast:
        return base + " contrast"
    base

fn themeProviderMotionClass(state: ThemeProviderState) -> text:
    if state.reduced_motion:
        return "motion-reduced"
    "motion-normal"

fn themeProviderSummary(state: ThemeProviderState) -> text:
    themeProviderClassName(state) + " " + themeProviderMotionClass(state)

fn themeProviderSourceLinesModeled() -> i64:
    169
