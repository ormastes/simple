"""
Importable alias for design-system ListItem parity.
"""

class ListItemState:
    id: text
    label: text
    description: text
    selected: bool
    disabled: bool
    focused: bool

impl ListItemState:
    static fn new(id: text, label: text, description: text, selected: bool, disabled: bool, focused: bool) -> ListItemState:
        ListItemState(id: id.trim(), label: label.trim(), description: description.trim(), selected: selected, disabled: disabled, focused: focused)

fn listItemId(state: ListItemState) -> text:
    if state.id == "":
        return state.label
    state.id

fn listItemLabel(state: ListItemState) -> text:
    if state.label == "":
        return "Untitled"
    state.label

fn listItemDescription(state: ListItemState) -> text:
    state.description

fn listItemEnabled(state: ListItemState) -> bool:
    not state.disabled

fn listItemInteractive(state: ListItemState) -> bool:
    listItemEnabled(state)

fn listItemChecked(state: ListItemState) -> bool:
    state.selected

fn listItemFocusRing(state: ListItemState) -> text:
    if state.focused and not state.disabled:
        return "focus-visible"
    "focus-none"

fn listItemTone(state: ListItemState) -> text:
    if state.disabled:
        return "disabled"
    if state.selected:
        return "selected"
    if state.focused:
        return "focused"
    "default"

fn listItemSummary(state: ListItemState) -> text:
    val label = listItemLabel(state)
    if state.description == "":
        return label + " " + listItemTone(state)
    label + ": " + state.description + " " + listItemTone(state)

fn toggleListItem(state: ListItemState) -> ListItemState:
    if state.disabled:
        return state
    ListItemState(id: state.id, label: state.label, description: state.description, selected: not state.selected, disabled: state.disabled, focused: state.focused)

fn focusListItem(state: ListItemState) -> ListItemState:
    ListItemState(id: state.id, label: state.label, description: state.description, selected: state.selected, disabled: state.disabled, focused: true)

fn blurListItem(state: ListItemState) -> ListItemState:
    ListItemState(id: state.id, label: state.label, description: state.description, selected: state.selected, disabled: state.disabled, focused: false)

fn listItemSourceLinesModeled() -> i64:
    243
