"""
Importable alias for design-system LoadingState parity.
"""

class LoadingStateView:
    loading: bool
    label: text
    detail: text

impl LoadingStateView:
    static fn new(loading: bool, label: text, detail: text) -> LoadingStateView:
        LoadingStateView(loading: loading, label: label.trim(), detail: detail.trim())

fn loadingStateLabel(state: LoadingStateView) -> text:
    if state.label != "":
        return state.label
    if state.loading:
        return "Loading"
    "Ready"

fn loadingStateSummary(state: LoadingStateView) -> text:
    val label = loadingStateLabel(state)
    if state.detail == "":
        return label
    label + ": " + state.detail

fn loadingStateBusy(state: LoadingStateView) -> bool:
    state.loading

fn loadingStateTone(state: LoadingStateView) -> text:
    if state.loading:
        return "muted"
    "default"

fn loadingStateSourceLinesModeled() -> i64:
    93
