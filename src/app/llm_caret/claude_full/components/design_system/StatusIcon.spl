"""
Importable alias for design-system StatusIcon parity.
"""

fn statusIconGlyph(status: text) -> text:
    val clean = status.trim()
    if clean == "success":
        return "check"
    if clean == "warning":
        return "alert"
    if clean == "error":
        return "x"
    if clean == "loading":
        return "spinner"
    "dot"

fn statusIconTone(status: text) -> text:
    val clean = status.trim()
    if clean == "success":
        return "green"
    if clean == "warning":
        return "yellow"
    if clean == "error":
        return "red"
    if clean == "loading":
        return "blue"
    "neutral"

fn statusIconLabel(status: text, label: text) -> text:
    val cleanLabel = label.trim()
    if cleanLabel != "":
        return cleanLabel
    statusIconGlyph(status)

fn statusIconSourceLinesModeled() -> i64:
    94
