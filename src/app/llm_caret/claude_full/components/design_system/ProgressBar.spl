"""
Importable alias for design-system ProgressBar parity.
"""

fn clampProgress(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 100:
        return 100
    value

fn progressBarPercent(value: i64, total: i64) -> i64:
    if total <= 0:
        return 0
    clampProgress((value * 100) / total)

fn progressBarLabel(value: i64, total: i64) -> text:
    val pct = progressBarPercent(value, total)
    pct.to_text() + "%"

fn progressBarComplete(value: i64, total: i64) -> bool:
    progressBarPercent(value, total) >= 100

fn progressBarTone(value: i64, total: i64) -> text:
    if progressBarComplete(value, total):
        return "success"
    if progressBarPercent(value, total) == 0:
        return "muted"
    "accent"

fn progressBarSourceLinesModeled() -> i64:
    85
