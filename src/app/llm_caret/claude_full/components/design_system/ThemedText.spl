"""
Importable alias for design-system ThemedText parity.
"""

class ThemedTextState:
    text: text
    tone: text
    weight: text
    truncate: bool

impl ThemedTextState:
    static fn new(textValue: text, tone: text, weight: text, truncate: bool) -> ThemedTextState:
        ThemedTextState(text: textValue.trim(), tone: tone.trim(), weight: weight.trim(), truncate: truncate)

fn themedTextContent(state: ThemedTextState) -> text:
    state.text

fn themedTextTone(state: ThemedTextState) -> text:
    if state.tone == "":
        return "default"
    state.tone

fn themedTextWeight(state: ThemedTextState) -> text:
    if state.weight == "":
        return "regular"
    state.weight

fn themedTextClassName(state: ThemedTextState) -> text:
    val base = "text-" + themedTextTone(state) + " " + themedTextWeight(state)
    if state.truncate:
        return base + " truncate"
    base

fn themedTextVisible(state: ThemedTextState) -> bool:
    state.text != ""

fn themedTextSummary(state: ThemedTextState) -> text:
    themedTextContent(state) + " " + themedTextClassName(state)

fn themedTextSourceLinesModeled() -> i64:
    123
