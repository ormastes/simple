class PressEnterToContinueView:
    text: text
    color: text
    boldSegment: text
    sourceEllipsis: text

impl PressEnterToContinueView:
    static fn new(text: text, color: text, boldSegment: text, sourceEllipsis: text) -> PressEnterToContinueView:
        PressEnterToContinueView(text: text, color: color, boldSegment: boldSegment, sourceEllipsis: sourceEllipsis)

fn PressEnterToContinue() -> PressEnterToContinueView:
    PressEnterToContinueView.new("Press Enter to continue...", "permission", "Enter", "u2026")

fn pressEnterToContinueText() -> text:
    PressEnterToContinue().text
