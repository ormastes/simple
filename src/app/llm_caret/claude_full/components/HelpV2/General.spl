fn helpGeneralTitle() -> text:
    "Claude help"

fn helpGeneralSummary(topic: text) -> text:
    val clean = topic.trim()
    if clean == "":
        return "General help"
    "Help for " + clean

fn helpGeneralSourceLinesModeled() -> i64:
    22
