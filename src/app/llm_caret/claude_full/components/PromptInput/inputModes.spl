fn prependModeCharacterToInput(input: text, mode: text) -> text:
    if mode == "bash":
        return "!" + input
    input

fn getModeFromInput(input: text) -> text:
    if input.starts_with("!"):
        return "bash"
    "prompt"

fn getValueFromInput(input: text) -> text:
    if getModeFromInput(input) == "prompt":
        return input
    input.slice(1, input.len())

fn isInputModeCharacter(input: text) -> bool:
    input == "!"
