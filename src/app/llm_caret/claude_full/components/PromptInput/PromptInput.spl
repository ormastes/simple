const PROMPT_INPUT_SOURCE_LINES = 2338

fn promptInputFrameRoute(externalEditorOpen: bool, swarmBanner: bool) -> text:
    if externalEditorOpen:
        return "external editor message"
    if swarmBanner:
        return "swarm banner prompt shell"
    "bordered prompt shell"

fn queuedCommandsRoute(fullscreen: bool, hasQueued: bool) -> text:
    if hasQueued && !fullscreen:
        return "queued commands visible"
    "queued commands hidden"

fn stashNoticeRoute(hasStashedPrompt: bool) -> text:
    if hasStashedPrompt:
        return "stash notice visible"
    "stash notice hidden"

fn modeIndicatorOrderRoute(swarmBanner: bool) -> text:
    if swarmBanner:
        return "mode indicator before swarm input"
    "mode indicator before input"

fn inputKindRoute(vimMode: bool) -> text:
    if vimMode:
        return "vim input"
    "plain text input"

fn borderTextRoute(fastIcon: bool, fastHint: bool) -> text:
    if fastIcon && fastHint:
        return "fast border with hint"
    if fastIcon:
        return "fast border"
    "no border text"

fn footerRoute(fullscreen: bool) -> text:
    if fullscreen:
        return "footer with tasks dialog"
    "footer"

fn fullscreenNotificationsRoute(fullscreen: bool, suggestionsOpen: bool, autoModeOptIn: bool) -> text:
    if !fullscreen:
        return "notifications hidden"
    if suggestionsOpen || autoModeOptIn:
        return "notifications height zero"
    "notifications overlay"

fn typingRoute() -> text:
    "clear footer selection and abort suggestions"

fn historyNavigationRoute(direction: text, atBoundary: bool) -> text:
    if atBoundary:
        return direction + " history"
    "stay in multiline input"

fn submitRoute(nonDirectorySuggestionsOpen: bool) -> text:
    if nonDirectorySuggestionsOpen:
        return "submit blocked"
    "submit prompt"

fn insertTextRoute(text: text, insertion: text, cursor: i64, appendNeedsSpace: bool) -> text:
    if appendNeedsSpace:
        return text.substring(0, cursor) + " " + insertion + text.substring(cursor)
    text.substring(0, cursor) + insertion + text.substring(cursor)

fn promptInputSourceLinesModeled() -> i64:
    PROMPT_INPUT_SOURCE_LINES
