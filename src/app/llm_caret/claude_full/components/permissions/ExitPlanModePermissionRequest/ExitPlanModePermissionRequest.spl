"""
Claude full ExitPlanModePermissionRequest parity model.
"""

const EXIT_PLAN_MODE_PERMISSION_REQUEST_SOURCE_LINES = 767

class ExitPlanModeOption:
    label: text
    value: text

impl ExitPlanModeOption:
    static fn new(label: text, value: text) -> ExitPlanModeOption:
        ExitPlanModeOption(label: label, value: value)

class ExitPlanModeRender:
    title: text
    message: text
    plan: text
    editor_hint: text
    options: [ExitPlanModeOption]

impl ExitPlanModeRender:
    static fn emptyPlan(workerBadge: text) -> ExitPlanModeRender:
        ExitPlanModeRender(title: "Exit plan mode?", message: "Claude wants to exit plan mode", plan: "", editor_hint: workerBadge, options: [ExitPlanModeOption.new("Yes", "yes"), ExitPlanModeOption.new("No", "no")])

    static fn readyToCode(plan: text, editorHint: text, options: [ExitPlanModeOption]) -> ExitPlanModeRender:
        ExitPlanModeRender(title: "Ready to code?", message: "Claude has written up a plan and is ready to execute. Would you like to proceed?", plan: plan, editor_hint: editorHint, options: options)

class ExitPlanModeResponse:
    value: text
    done: bool
    rejected: bool
    clear_context: bool
    keep_context: bool
    permission_mode: text
    launch_ultraplan: bool

impl ExitPlanModeResponse:
    static fn new(value: text, done: bool, rejected: bool, clearContext: bool, keepContext: bool, permissionMode: text, launchUltraplan: bool) -> ExitPlanModeResponse:
        ExitPlanModeResponse(value: value, done: done, rejected: rejected, clear_context: clearContext, keep_context: keepContext, permission_mode: permissionMode, launch_ultraplan: launchUltraplan)

fn exitPlanModeApprovalOptions(showClearContext: bool, showUltraplan: bool, isAutoModeAvailable: bool, isBypassPermissionsModeAvailable: bool) -> [ExitPlanModeOption]:
    var options: [ExitPlanModeOption] = []
    if showClearContext:
        if isAutoModeAvailable:
            options.push(ExitPlanModeOption.new("Yes, clear context and use auto mode", "yes-auto-clear-context"))
        else if isBypassPermissionsModeAvailable:
            options.push(ExitPlanModeOption.new("Yes, clear context and bypass permissions", "yes-bypass-permissions"))
        else:
            options.push(ExitPlanModeOption.new("Yes, clear context and auto-accept edits", "yes-accept-edits"))
    if isAutoModeAvailable:
        options.push(ExitPlanModeOption.new("Yes, and use auto mode", "yes-resume-auto-mode"))
    else if isBypassPermissionsModeAvailable:
        options.push(ExitPlanModeOption.new("Yes, and bypass permissions", "yes-accept-edits-keep-context"))
    else:
        options.push(ExitPlanModeOption.new("Yes, auto-accept edits", "yes-accept-edits-keep-context"))
    options.push(ExitPlanModeOption.new("Yes, manually approve edits", "yes-default-keep-context"))
    if showUltraplan:
        options.push(ExitPlanModeOption.new("No, refine with Ultraplan on Claude Code on the web", "ultraplan"))
    options.push(ExitPlanModeOption.new("No, keep planning", "no"))
    options

fn exitPlanModePermissionRequest(isEmptyPlan: bool, showClearContext: bool, showUltraplan: bool, workerBadge: text, plan: text, editorHint: text, isAutoModeAvailable: bool, isBypassPermissionsModeAvailable: bool) -> ExitPlanModeRender:
    if isEmptyPlan:
        return ExitPlanModeRender.emptyPlan(workerBadge)
    ExitPlanModeRender.readyToCode(plan, editorHint, exitPlanModeApprovalOptions(showClearContext, showUltraplan, isAutoModeAvailable, isBypassPermissionsModeAvailable))

fn exitPlanModePermissionResponse(value: text, isEmptyPlan: bool, isBypassPermissionsModeAvailable: bool) -> ExitPlanModeResponse:
    if isEmptyPlan:
        if value == "yes":
            return ExitPlanModeResponse.new("yes", true, false, false, false, "default", false)
        return ExitPlanModeResponse.new("no", true, true, false, false, "", false)
    if value == "ultraplan":
        return ExitPlanModeResponse.new("ultraplan", true, true, false, false, "", true)
    if value == "no":
        return ExitPlanModeResponse.new("no", true, true, false, false, "", false)
    if value == "yes-auto-clear-context":
        return ExitPlanModeResponse.new(value, true, false, true, false, "auto", false)
    if value == "yes-resume-auto-mode":
        return ExitPlanModeResponse.new(value, true, false, false, true, "auto", false)
    if value == "yes-bypass-permissions":
        return ExitPlanModeResponse.new(value, true, false, true, false, "bypassPermissions", false)
    if value == "yes-accept-edits":
        return ExitPlanModeResponse.new(value, true, false, true, false, "acceptEdits", false)
    if value == "yes-accept-edits-keep-context":
        return ExitPlanModeResponse.new(value, true, false, false, true, if isBypassPermissionsModeAvailable: "bypassPermissions" else: "acceptEdits", false)
    ExitPlanModeResponse.new("yes-default-keep-context", true, false, false, true, "default", false)

fn exitPlanModePermissionCancel(isEmptyPlan: bool, isBypassPermissionsModeAvailable: bool) -> ExitPlanModeResponse:
    exitPlanModePermissionResponse("no", isEmptyPlan, isBypassPermissionsModeAvailable)

fn exitPlanModePermissionRequestSourceLinesModeled() -> i64:
    EXIT_PLAN_MODE_PERMISSION_REQUEST_SOURCE_LINES
