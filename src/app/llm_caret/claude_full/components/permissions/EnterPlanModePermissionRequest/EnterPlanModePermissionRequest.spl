"""
Claude full EnterPlanModePermissionRequest parity model.
"""

const ENTER_PLAN_MODE_PERMISSION_REQUEST_SOURCE_LINES = 121

class EnterPlanModeOption:
    label: text
    value: text

impl EnterPlanModeOption:
    static fn new(label: text, value: text) -> EnterPlanModeOption:
        EnterPlanModeOption(label: label, value: value)

class EnterPlanModeRender:
    title: text
    color: text
    message: text
    bullet_lines: [text]
    warning: text
    options: [EnterPlanModeOption]
    worker_badge: text

impl EnterPlanModeRender:
    static fn new(workerBadge: text) -> EnterPlanModeRender:
        EnterPlanModeRender(
            title: "Enter plan mode?",
            color: "planMode",
            message: "Claude wants to enter plan mode to explore and design an implementation approach.",
            bullet_lines: [
                "In plan mode, Claude will:",
                "Explore the codebase thoroughly",
                "Identify existing patterns",
                "Design an implementation strategy",
                "Present a plan for your approval",
            ],
            warning: "No code changes will be made until you approve the plan.",
            options: [EnterPlanModeOption.new("Yes, enter plan mode", "yes"), EnterPlanModeOption.new("No, start implementing now", "no")],
            worker_badge: workerBadge,
        )

class EnterPlanModeResponse:
    value: text
    done: bool
    rejected: bool
    transition_mode: text
    permission_update_type: text
    permission_update_mode: text
    permission_update_destination: text
    analytics_event: text
    analytics_entry_method: text
    interview_phase_enabled: bool

impl EnterPlanModeResponse:
    static fn new(value: text, done: bool, rejected: bool, transitionMode: text, permissionUpdateType: text, permissionUpdateMode: text, permissionUpdateDestination: text, analyticsEvent: text, analyticsEntryMethod: text, interviewPhaseEnabled: bool) -> EnterPlanModeResponse:
        EnterPlanModeResponse(value: value, done: done, rejected: rejected, transition_mode: transitionMode, permission_update_type: permissionUpdateType, permission_update_mode: permissionUpdateMode, permission_update_destination: permissionUpdateDestination, analytics_event: analyticsEvent, analytics_entry_method: analyticsEntryMethod, interview_phase_enabled: interviewPhaseEnabled)

fn enterPlanModePermissionRequest(workerBadge: text) -> EnterPlanModeRender:
    EnterPlanModeRender.new(workerBadge)

fn enterPlanModePermissionResponse(value: text, interviewPhaseEnabled: bool) -> EnterPlanModeResponse:
    if value == "yes":
        EnterPlanModeResponse.new("yes", true, false, "plan", "setMode", "plan", "session", "tengu_plan_enter", "tool", interviewPhaseEnabled)
    else:
        EnterPlanModeResponse.new("no", true, true, "", "", "", "", "", "", interviewPhaseEnabled)

fn enterPlanModePermissionCancel(interviewPhaseEnabled: bool) -> EnterPlanModeResponse:
    enterPlanModePermissionResponse("no", interviewPhaseEnabled)

fn enterPlanModePermissionRequestSourceLinesModeled() -> i64:
    ENTER_PLAN_MODE_PERMISSION_REQUEST_SOURCE_LINES
