"""
Claude full FilePermissionDialog ideDiffConfig parity model.
"""

const IDE_DIFF_CONFIG_SOURCE_LINES = 42

class FileEdit:
    old_string: text
    new_string: text
    replace_all: bool

impl FileEdit:
    static fn new(oldString: text, newString: text, replaceAll: bool) -> FileEdit:
        FileEdit(old_string: oldString, new_string: newString, replace_all: replaceAll)

class IDEDiffConfig:
    file_path: text
    edits: [FileEdit]
    edit_mode: text

impl IDEDiffConfig:
    static fn new(filePath: text, edits: [FileEdit], editMode: text) -> IDEDiffConfig:
        IDEDiffConfig(file_path: filePath, edits: edits, edit_mode: editMode)

class IDEDiffChangeInput:
    file_path: text
    edits: [FileEdit]

impl IDEDiffChangeInput:
    static fn new(filePath: text, edits: [FileEdit]) -> IDEDiffChangeInput:
        IDEDiffChangeInput(file_path: filePath, edits: edits)

fn createSingleEditDiffConfig(filePath: text, oldString: text, newString: text, replaceAll: bool) -> IDEDiffConfig:
    IDEDiffConfig.new(filePath, [FileEdit.new(oldString, newString, replaceAll)], "single")

fn applySingleEditDiffChanges(original: FileEdit, modifiedEdits: [FileEdit]) -> FileEdit:
    if modifiedEdits.len() > 0:
        modifiedEdits[0]
    else:
        original

fn ideDiffConfigSourceLinesModeled() -> i64:
    IDE_DIFF_CONFIG_SOURCE_LINES
