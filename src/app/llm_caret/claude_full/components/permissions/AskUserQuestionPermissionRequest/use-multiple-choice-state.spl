"""
Claude full ask-user-question multiple choice state parity model.
"""

const MULTIPLE_CHOICE_STATE_SOURCE_LINES = 179

class MultipleChoiceQuestionState:
    question: text
    selected_value: text
    text_input_value: text
    is_multi_select: bool

impl MultipleChoiceQuestionState:
    static fn new(question: text, selectedValue: text, textInputValue: text, isMultiSelect: bool) -> MultipleChoiceQuestionState:
        MultipleChoiceQuestionState(question: question, selected_value: selectedValue, text_input_value: textInputValue, is_multi_select: isMultiSelect)

class MultipleChoiceAnswer:
    question: text
    answer: text

impl MultipleChoiceAnswer:
    static fn new(question: text, answer: text) -> MultipleChoiceAnswer:
        MultipleChoiceAnswer(question: question, answer: answer)

class MultipleChoiceState:
    current_question_index: i64
    answers: [MultipleChoiceAnswer]
    question_states: [MultipleChoiceQuestionState]
    is_in_text_input: bool

impl MultipleChoiceState:
    static fn initial() -> MultipleChoiceState:
        MultipleChoiceState(current_question_index: 0, answers: [], question_states: [], is_in_text_input: false)

fn multipleChoiceNextQuestion(state: MultipleChoiceState) -> MultipleChoiceState:
    MultipleChoiceState(current_question_index: state.current_question_index + 1, answers: state.answers, question_states: state.question_states, is_in_text_input: false)

fn multipleChoicePrevQuestion(state: MultipleChoiceState) -> MultipleChoiceState:
    var nextIndex = state.current_question_index - 1
    if nextIndex < 0:
        nextIndex = 0
    MultipleChoiceState(current_question_index: nextIndex, answers: state.answers, question_states: state.question_states, is_in_text_input: false)

fn multipleChoiceSetTextInputMode(state: MultipleChoiceState, isInInput: bool) -> MultipleChoiceState:
    MultipleChoiceState(current_question_index: state.current_question_index, answers: state.answers, question_states: state.question_states, is_in_text_input: isInInput)

fn multipleChoiceUpsertAnswer(answers: [MultipleChoiceAnswer], question: text, answerValue: text) -> [MultipleChoiceAnswer]:
    var out: [MultipleChoiceAnswer] = []
    var found = false
    for answer in answers:
        if answer.question == question:
            out.push(MultipleChoiceAnswer.new(question, answerValue))
            found = true
        else:
            out.push(answer)
    if not found:
        out.push(MultipleChoiceAnswer.new(question, answerValue))
    out

fn multipleChoiceSetAnswer(state: MultipleChoiceState, question: text, answerValue: text, shouldAdvance: bool) -> MultipleChoiceState:
    val answers = multipleChoiceUpsertAnswer(state.answers, question, answerValue)
    var nextIndex = state.current_question_index
    var inText = state.is_in_text_input
    if shouldAdvance:
        nextIndex = nextIndex + 1
        inText = false
    MultipleChoiceState(current_question_index: nextIndex, answers: answers, question_states: state.question_states, is_in_text_input: inText)

fn multipleChoiceUpsertQuestionState(states: [MultipleChoiceQuestionState], question: text, selectedValue: text, textInputValue: text, isMultiSelect: bool) -> [MultipleChoiceQuestionState]:
    var out: [MultipleChoiceQuestionState] = []
    var found = false
    for state in states:
        if state.question == question:
            val selected = if selectedValue == "": state.selected_value else: selectedValue
            val textInput = if textInputValue == "": state.text_input_value else: textInputValue
            out.push(MultipleChoiceQuestionState.new(question, selected, textInput, isMultiSelect))
            found = true
        else:
            out.push(state)
    if not found:
        out.push(MultipleChoiceQuestionState.new(question, selectedValue, textInputValue, isMultiSelect))
    out

fn multipleChoiceUpdateQuestionState(state: MultipleChoiceState, question: text, selectedValue: text, textInputValue: text, isMultiSelect: bool) -> MultipleChoiceState:
    MultipleChoiceState(current_question_index: state.current_question_index, answers: state.answers, question_states: multipleChoiceUpsertQuestionState(state.question_states, question, selectedValue, textInputValue, isMultiSelect), is_in_text_input: state.is_in_text_input)

fn multipleChoiceStateSourceLinesModeled() -> i64:
    MULTIPLE_CHOICE_STATE_SOURCE_LINES
