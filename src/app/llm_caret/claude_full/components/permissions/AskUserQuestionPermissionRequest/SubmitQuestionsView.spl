"""
Claude full AskUserQuestion SubmitQuestionsView parity model.
"""

use app.llm_caret.claude_full.components.permissions.AskUserQuestionPermissionRequest.QuestionNavigationBar.*

const SUBMIT_QUESTIONS_VIEW_SOURCE_LINES = 143
const SUBMIT_QUESTIONS_TITLE = "Review your answers"
const SUBMIT_QUESTIONS_READY = "Ready to submit your answers?"

class SubmitQuestionAnswerLine:
    question: text
    answer: text

impl SubmitQuestionAnswerLine:
    static fn new(question: text, answer: text) -> SubmitQuestionAnswerLine:
        SubmitQuestionAnswerLine(question: question, answer: answer)

class SubmitQuestionOption:
    label: text
    value: text

impl SubmitQuestionOption:
    static fn new(label: text, value: text) -> SubmitQuestionOption:
        SubmitQuestionOption(label: label, value: value)

class SubmitQuestionsViewRender:
    title: text
    warning: text
    ready_text: text
    permission_result: text
    min_content_height: i64
    nav: QuestionNavigationBarRender
    answer_lines: [SubmitQuestionAnswerLine]
    options: [SubmitQuestionOption]

impl SubmitQuestionsViewRender:
    static fn new(warning: text, permissionResult: text, minContentHeight: i64, nav: QuestionNavigationBarRender, answerLines: [SubmitQuestionAnswerLine]) -> SubmitQuestionsViewRender:
        SubmitQuestionsViewRender(title: SUBMIT_QUESTIONS_TITLE, warning: warning, ready_text: SUBMIT_QUESTIONS_READY, permission_result: permissionResult, min_content_height: minContentHeight, nav: nav, answer_lines: answerLines, options: [SubmitQuestionOption.new("Submit answers", "submit"), SubmitQuestionOption.new("Cancel", "cancel")])

fn submitQuestionsAnswerFor(answers: [QuestionNavAnswer], question: text) -> text:
    for answer in answers:
        if answer.question == question:
            return answer.answer
    ""

fn submitQuestionsAnswerLines(questions: [QuestionNavQuestion], answers: [QuestionNavAnswer]) -> [SubmitQuestionAnswerLine]:
    var out: [SubmitQuestionAnswerLine] = []
    for question in questions:
        val answer = submitQuestionsAnswerFor(answers, question.question)
        if answer != "":
            out.push(SubmitQuestionAnswerLine.new(question.question, answer))
    out

fn submitQuestionsWarning(allQuestionsAnswered: bool) -> text:
    if allQuestionsAnswered:
        ""
    else:
        "⚠ You have not answered all questions"

fn submitQuestionsView(questions: [QuestionNavQuestion], currentQuestionIndex: i64, answers: [QuestionNavAnswer], allQuestionsAnswered: bool, permissionResult: text, minContentHeight: i64, columns: i64) -> SubmitQuestionsViewRender:
    val nav = questionNavigationBar(questions, currentQuestionIndex, answers, columns, false)
    SubmitQuestionsViewRender.new(submitQuestionsWarning(allQuestionsAnswered), permissionResult, minContentHeight, nav, submitQuestionsAnswerLines(questions, answers))

fn submitQuestionsViewSourceLinesModeled() -> i64:
    SUBMIT_QUESTIONS_VIEW_SOURCE_LINES
