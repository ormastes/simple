"""
Claude full BashPermissionRequest bashToolUseOptions parity model.
"""

const BASH_TOOL_USE_OPTIONS_SOURCE_LINES = 146
const BASH_TOOL_NAME = "Bash"

class BashPermissionSuggestion:
    type_name: text
    tool_name: text
    label: text

impl BashPermissionSuggestion:
    static fn new(typeName: text, toolName: text, label: text) -> BashPermissionSuggestion:
        BashPermissionSuggestion(type_name: typeName, tool_name: toolName, label: label)

class BashToolUseOption:
    type_name: text
    label: text
    value: text
    prompt_text: text
    initial_value: text
    show_label_with_value: bool

impl BashToolUseOption:
    static fn new(typeName: text, label: text, value: text, promptText: text, initialValue: text, showLabelWithValue: bool) -> BashToolUseOption:
        BashToolUseOption(type_name: typeName, label: label, value: value, prompt_text: promptText, initial_value: initialValue, show_label_with_value: showLabelWithValue)

fn bashPermissionDescriptionExists(description: text, existingDescriptions: [text]) -> bool:
    val normalized = description.lower().trim()
    for existing in existingDescriptions:
        if existing.lower().trim() == normalized:
            return true
    false

fn stripBashRedirections(command: text) -> text:
    val redirect = command.find(">")
    if redirect >= 0:
        command.substring(0, redirect).trim()
    else:
        command

fn bashPermissionHasNonBashSuggestions(suggestions: [BashPermissionSuggestion]) -> bool:
    for suggestion in suggestions:
        if suggestion.type_name == "addDirectories":
            return true
        if suggestion.type_name == "addRules" and suggestion.tool_name != BASH_TOOL_NAME:
            return true
    false

fn bashPermissionSuggestionLabel(suggestions: [BashPermissionSuggestion]) -> text:
    if suggestions.len() == 0:
        ""
    else if suggestions[0].label != "":
        suggestions[0].label
    else:
        "Yes, and don't ask again for " + stripBashRedirections(suggestions[0].tool_name)

fn bashToolUseOptions(suggestions: [BashPermissionSuggestion], showAlwaysAllowOptions: bool, yesInputMode: bool, noInputMode: bool, editablePrefix: text, canEditPrefix: bool, classifierEnabled: bool, canEditClassifierDescription: bool, classifierDescription: text, initialClassifierDescriptionEmpty: bool, existingAllowDescriptions: [text], decisionReasonType: text) -> [BashToolUseOption]:
    var options: [BashToolUseOption] = []
    if yesInputMode:
        options.push(BashToolUseOption.new("input", "Yes", "yes", "and tell Claude what to do next", "", false))
    else:
        options.push(BashToolUseOption.new("text", "Yes", "yes", "", "", false))
    if showAlwaysAllowOptions:
        val hasNonBash = bashPermissionHasNonBashSuggestions(suggestions)
        if editablePrefix != "" and canEditPrefix and not hasNonBash and suggestions.len() > 0:
            options.push(BashToolUseOption.new("input", "Yes, and don’t ask again for", "yes-prefix-edited", "command prefix (e.g., npm run:*)", editablePrefix, true))
        else if suggestions.len() > 0:
            val label = bashPermissionSuggestionLabel(suggestions)
            if label != "":
                options.push(BashToolUseOption.new("text", label, "yes-apply-suggestions", "", "", false))
        val prefixShown = options.len() > 1 and options[1].value == "yes-prefix-edited"
        if classifierEnabled and canEditClassifierDescription and not prefixShown and not initialClassifierDescriptionEmpty and not bashPermissionDescriptionExists(classifierDescription, existingAllowDescriptions) and decisionReasonType != "classifier":
            options.push(BashToolUseOption.new("input", "Yes, and don’t ask again for", "yes-classifier-reviewed", "describe what to allow...", classifierDescription, true))
    if noInputMode:
        options.push(BashToolUseOption.new("input", "No", "no", "and tell Claude what to do differently", "", false))
    else:
        options.push(BashToolUseOption.new("text", "No", "no", "", "", false))
    options

fn bashToolUseOptionsSourceLinesModeled() -> i64:
    BASH_TOOL_USE_OPTIONS_SOURCE_LINES
