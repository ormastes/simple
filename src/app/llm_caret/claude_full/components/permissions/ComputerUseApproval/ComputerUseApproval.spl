"""
Claude full ComputerUseApproval parity model.
"""

const COMPUTER_USE_APPROVAL_SOURCE_LINES = 440

class ComputerUseResolvedApp:
    bundle_id: text
    display_name: text

impl ComputerUseResolvedApp:
    static fn new(bundleId: text, displayName: text) -> ComputerUseResolvedApp:
        ComputerUseResolvedApp(bundle_id: bundleId, display_name: displayName)

class ComputerUseAppRequest:
    requested_name: text
    resolved: ComputerUseResolvedApp?
    already_granted: bool

impl ComputerUseAppRequest:
    static fn unresolved(requestedName: text) -> ComputerUseAppRequest:
        ComputerUseAppRequest(requested_name: requestedName, resolved: nil, already_granted: false)

    static fn resolvedApp(requestedName: text, bundleId: text, displayName: text, alreadyGranted: bool) -> ComputerUseAppRequest:
        ComputerUseAppRequest(requested_name: requestedName, resolved: ComputerUseResolvedApp.new(bundleId, displayName), already_granted: alreadyGranted)

class ComputerUseGrantFlags:
    clipboard_read: bool
    clipboard_write: bool
    system_key_combos: bool

impl ComputerUseGrantFlags:
    static fn none() -> ComputerUseGrantFlags:
        ComputerUseGrantFlags(false, false, false)

    static fn new(clipboardRead: bool, clipboardWrite: bool, systemKeyCombos: bool) -> ComputerUseGrantFlags:
        ComputerUseGrantFlags(clipboardRead, clipboardWrite, systemKeyCombos)

class ComputerUseTccState:
    accessibility: bool
    screen_recording: bool

impl ComputerUseTccState:
    static fn new(accessibility: bool, screenRecording: bool) -> ComputerUseTccState:
        ComputerUseTccState(accessibility: accessibility, screen_recording: screenRecording)

class ComputerUseRequest:
    apps: [ComputerUseAppRequest]
    requested_flags: ComputerUseGrantFlags
    reason: text
    will_hide_count: i64
    has_tcc_state: bool
    tcc_state: ComputerUseTccState

impl ComputerUseRequest:
    static fn appList(apps: [ComputerUseAppRequest], requestedFlags: ComputerUseGrantFlags, reason: text, willHideCount: i64) -> ComputerUseRequest:
        ComputerUseRequest(apps: apps, requested_flags: requestedFlags, reason: reason, will_hide_count: willHideCount, has_tcc_state: false, tcc_state: ComputerUseTccState.new(true, true))

    static fn tcc(tccState: ComputerUseTccState) -> ComputerUseRequest:
        ComputerUseRequest(apps: [], requested_flags: ComputerUseGrantFlags.none(), reason: "", will_hide_count: 0, has_tcc_state: true, tcc_state: tccState)

class ComputerUseOption:
    label: text
    value: text

impl ComputerUseOption:
    static fn new(label: text, value: text) -> ComputerUseOption:
        ComputerUseOption(label: label, value: value)

class ComputerUseAppRow:
    bundle_id: text
    label: text
    state: text
    sentinel_warning: text

impl ComputerUseAppRow:
    static fn new(bundleId: text, label: text, state: text, sentinelWarning: text) -> ComputerUseAppRow:
        ComputerUseAppRow(bundle_id: bundleId, label: label, state: state, sentinel_warning: sentinelWarning)

class ComputerUseRender:
    panel: text
    title: text
    reason: text
    accessibility_status: text
    screen_recording_status: text
    app_rows: [ComputerUseAppRow]
    requested_flag_keys: [text]
    will_hide_count: i64
    options: [ComputerUseOption]

impl ComputerUseRender:
    static fn new(panel: text, title: text, reason: text, accessibilityStatus: text, screenRecordingStatus: text, appRows: [ComputerUseAppRow], requestedFlagKeys: [text], willHideCount: i64, options: [ComputerUseOption]) -> ComputerUseRender:
        ComputerUseRender(panel: panel, title: title, reason: reason, accessibility_status: accessibilityStatus, screen_recording_status: screenRecordingStatus, app_rows: appRows, requested_flag_keys: requestedFlagKeys, will_hide_count: willHideCount, options: options)

class ComputerUseGrantedApp:
    bundle_id: text
    display_name: text

impl ComputerUseGrantedApp:
    static fn new(bundleId: text, displayName: text) -> ComputerUseGrantedApp:
        ComputerUseGrantedApp(bundle_id: bundleId, display_name: displayName)

class ComputerUseDeniedApp:
    bundle_id: text
    reason: text

impl ComputerUseDeniedApp:
    static fn new(bundleId: text, reason: text) -> ComputerUseDeniedApp:
        ComputerUseDeniedApp(bundle_id: bundleId, reason: reason)

class ComputerUseResponse:
    granted: [ComputerUseGrantedApp]
    denied: [ComputerUseDeniedApp]
    flags: ComputerUseGrantFlags

impl ComputerUseResponse:
    static fn new(granted: [ComputerUseGrantedApp], denied: [ComputerUseDeniedApp], flags: ComputerUseGrantFlags) -> ComputerUseResponse:
        ComputerUseResponse(granted: granted, denied: denied, flags: flags)

fn computerUseRequestedFlagKeys(flags: ComputerUseGrantFlags) -> [text]:
    var keys: [text] = []
    if flags.clipboard_read:
        keys.push("clipboardRead")
    if flags.clipboard_write:
        keys.push("clipboardWrite")
    if flags.system_key_combos:
        keys.push("systemKeyCombos")
    keys

fn computerUseSentinelWarning(bundleId: text) -> text:
    if bundleId.contains("Terminal") or bundleId.contains("shell"):
        "equivalent to shell access"
    else if bundleId.contains("Finder") or bundleId.contains("filesystem"):
        "can read/write any file"
    else if bundleId.contains("System Settings") or bundleId.contains("system_settings"):
        "can change system settings"
    else:
        ""

fn computerUseApproval(request: ComputerUseRequest) -> ComputerUseRender:
    if request.has_tcc_state:
        var options: [ComputerUseOption] = []
        if not request.tcc_state.accessibility:
            options.push(ComputerUseOption.new("Open System Settings - Accessibility", "open_accessibility"))
        if not request.tcc_state.screen_recording:
            options.push(ComputerUseOption.new("Open System Settings - Screen Recording", "open_screen_recording"))
        options.push(ComputerUseOption.new("Try again", "retry"))
        return ComputerUseRender.new(
            "tcc",
            "Computer Use needs macOS permissions",
            "",
            if request.tcc_state.accessibility: "granted" else: "not granted",
            if request.tcc_state.screen_recording: "granted" else: "not granted",
            [],
            [],
            0,
            options,
        )

    var checkedCount = 0
    var rows: [ComputerUseAppRow] = []
    for app in request.apps:
        if app.resolved.?:
            val resolved = app.resolved.unwrap()
            if app.already_granted:
                rows.push(ComputerUseAppRow.new(resolved.bundle_id, resolved.display_name, "already_granted", ""))
            else:
                checkedCount = checkedCount + 1
                rows.push(ComputerUseAppRow.new(resolved.bundle_id, resolved.display_name, "checked", computerUseSentinelWarning(resolved.bundle_id)))
        else:
            rows.push(ComputerUseAppRow.new(app.requested_name, app.requested_name, "not_installed", ""))
    val appWord = if checkedCount == 1: "app" else: "apps"
    ComputerUseRender.new(
        "app_list",
        "Computer Use wants to control these apps",
        request.reason,
        "",
        "",
        rows,
        computerUseRequestedFlagKeys(request.requested_flags),
        request.will_hide_count,
        [ComputerUseOption.new("Allow for this session (" + checkedCount.to_text() + " " + appWord + ")", "allow_all"), ComputerUseOption.new("Deny, and tell Claude what to do differently (esc)", "deny")],
    )

fn computerUseApprovalResponse(request: ComputerUseRequest, approved: bool) -> ComputerUseResponse:
    if not approved or request.has_tcc_state:
        return ComputerUseResponse.new([], [], ComputerUseGrantFlags.none())

    var granted: [ComputerUseGrantedApp] = []
    var denied: [ComputerUseDeniedApp] = []
    for app in request.apps:
        if app.resolved.?:
            val resolved = app.resolved.unwrap()
            if not app.already_granted:
                granted.push(ComputerUseGrantedApp.new(resolved.bundle_id, resolved.display_name))
        else:
            denied.push(ComputerUseDeniedApp.new(app.requested_name, "not_installed"))
    ComputerUseResponse.new(granted, denied, request.requested_flags)

fn computerUseApprovalSourceLinesModeled() -> i64:
    COMPUTER_USE_APPROVAL_SOURCE_LINES
