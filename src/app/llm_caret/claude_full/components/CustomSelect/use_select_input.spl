"""
Importable alias for CustomSelect use-select-input parity.
"""

class SelectInputState:
    query: text
    open: bool

impl SelectInputState:
    static fn new(query: text, open: bool) -> SelectInputState:
        SelectInputState(query: query.trim(), open: open)

fn updateSelectInputQuery(state: SelectInputState, value: text) -> SelectInputState:
    SelectInputState.new(value, true)

fn clearSelectInput(state: SelectInputState) -> SelectInputState:
    SelectInputState.new("", state.open)

fn selectInputSummary(state: SelectInputState) -> text:
    if state.query == "":
        return "No filter"
    "Filter: " + state.query

fn useSelectInputSourceLinesModeled() -> i64:
    287
