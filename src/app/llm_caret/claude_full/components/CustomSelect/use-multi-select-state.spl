"""
Claude full CustomSelect use-multi-select-state parity.
"""

class MultiSelectState:
    selectedValues: [text]
    maxSelection: i64
    source: text

impl MultiSelectState:
    static fn new(selectedValues: [text], maxSelection: i64, source: text) -> MultiSelectState:
        MultiSelectState(selectedValues: uniqueMultiSelectValues(selectedValues), maxSelection: maxSelection, source: source.trim())

    fn selected() -> [text]:
        copyMultiSelectValues(self.selectedValues)

    fn count() -> i64:
        self.selectedValues.len()

    fn isSelected(value: text) -> bool:
        multiSelectContains(self.selectedValues, value)

    fn canAdd(value: text) -> bool:
        val normalized = normalizeMultiSelectValue(value)
        if normalized == "":
            return false
        if self.isSelected(normalized):
            return false
        if self.maxSelection <= 0:
            return true
        self.selectedValues.len() < self.maxSelection

    fn add(value: text) -> MultiSelectState:
        val normalized = normalizeMultiSelectValue(value)
        if normalized == "":
            return self
        if self.isSelected(normalized):
            return self
        if self.maxSelection > 0 and self.selectedValues.len() >= self.maxSelection:
            return self
        var values = copyMultiSelectValues(self.selectedValues)
        values.push(normalized)
        MultiSelectState(values, self.maxSelection, self.source)

    fn remove(value: text) -> MultiSelectState:
        val normalized = normalizeMultiSelectValue(value)
        var values: [text] = []
        var i = 0
        while i < self.selectedValues.len():
            if self.selectedValues[i] != normalized:
                values.push(self.selectedValues[i])
            i = i + 1
        MultiSelectState(values, self.maxSelection, self.source)

    fn toggle(value: text) -> MultiSelectState:
        if self.isSelected(value):
            return self.remove(value)
        self.add(value)

    fn clear() -> MultiSelectState:
        MultiSelectState([], self.maxSelection, self.source)

    fn summary() -> text:
        multiSelectSummary(self.selectedValues, self.maxSelection)

    fn sourceSummary() -> text:
        multiSelectSourceSummary(self.source, self.selectedValues, self.maxSelection)

fn useMultiSelectState(initialSelected: [text], maxSelection: i64, source: text) -> MultiSelectState:
    MultiSelectState.new(initialSelected, maxSelection, source)

fn normalizeMultiSelectValue(value: text) -> text:
    value.trim()

fn copyMultiSelectValues(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn multiSelectContains(values: [text], value: text) -> bool:
    val normalized = normalizeMultiSelectValue(value)
    var i = 0
    while i < values.len():
        if values[i] == normalized:
            return true
        i = i + 1
    false

fn uniqueMultiSelectValues(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        val normalized = normalizeMultiSelectValue(values[i])
        if normalized != "" and !multiSelectContains(out, normalized):
            out.push(normalized)
        i = i + 1
    out

fn multiSelectSummary(values: [text], maxSelection: i64) -> text:
    val count = values.len()
    var label = "No options selected"
    if count == 1:
        label = "1 option selected"
    if count > 1:
        label = count.to_text() + " options selected"
    if maxSelection > 0:
        return label + " (" + count.to_text() + "/" + maxSelection.to_text() + ")"
    label

fn multiSelectSourceSummary(source: text, values: [text], maxSelection: i64) -> text:
    val cleanSource = source.trim()
    val summary = multiSelectSummary(values, maxSelection)
    if cleanSource == "":
        return summary
    cleanSource + ": " + summary

fn multiSelectSelectedValues(state: MultiSelectState) -> [text]:
    state.selected()

fn multiSelectToggle(state: MultiSelectState, value: text) -> MultiSelectState:
    state.toggle(value)

fn multiSelectAdd(state: MultiSelectState, value: text) -> MultiSelectState:
    state.add(value)

fn multiSelectRemove(state: MultiSelectState, value: text) -> MultiSelectState:
    state.remove(value)

fn multiSelectClear(state: MultiSelectState) -> MultiSelectState:
    state.clear()

fn multiSelectSourceLinesModeled() -> i64:
    414
