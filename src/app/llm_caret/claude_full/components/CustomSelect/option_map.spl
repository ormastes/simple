"""
Importable alias for CustomSelect option map parity.
"""

class SelectOption:
    value: text
    label: text

impl SelectOption:
    static fn new(value: text, label: text) -> SelectOption:
        SelectOption(value: value.trim(), label: label.trim())

fn optionLabel(option: SelectOption) -> text:
    if option.label == "":
        return option.value
    option.label

fn optionMapSourceLinesModeled() -> i64:
    50
