"""
Importable alias for CustomSelect select input option parity.
"""

class SelectInputOptionState:
    value: text
    label: text
    selected: bool
    disabled: bool

impl SelectInputOptionState:
    static fn new(value: text, label: text, selected: bool, disabled: bool) -> SelectInputOptionState:
        SelectInputOptionState(value: value.trim(), label: label.trim(), selected: selected, disabled: disabled)

fn selectInputOptionDisplay(state: SelectInputOptionState) -> text:
    val prefix = if state.selected: "[x] " else: "[ ] "
    prefix + state.label

fn selectInputOptionCanChoose(state: SelectInputOptionState) -> bool:
    not state.disabled

fn selectInputOptionSourceLinesModeled() -> i64:
    487
