"""
Claude full CustomSelect SelectMulti parity.
"""

fn selectMultiSummary(selected: [text]) -> text:
    if selected.len() == 0:
        return "No options selected"
    selected.len().to_text() + " options selected"

fn selectMultiCanClear(selected: [text]) -> bool:
    selected.len() > 0

fn selectMultiSourceLinesModeled() -> i64:
    212
