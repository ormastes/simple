"""
Importable alias for CustomSelect use-select-state parity.
"""

class SelectState:
    open: bool
    selected: text

impl SelectState:
    static fn new(open: bool, selected: text) -> SelectState:
        SelectState(open: open, selected: selected.trim())

fn openSelectState(state: SelectState) -> SelectState:
    SelectState.new(true, state.selected)

fn closeSelectState(state: SelectState) -> SelectState:
    SelectState.new(false, state.selected)

fn chooseSelectState(state: SelectState, value: text) -> SelectState:
    SelectState.new(false, value)

fn selectStateSummary(state: SelectState) -> text:
    if state.selected == "":
        return "Nothing selected"
    "Selected: " + state.selected

fn useSelectStateSourceLinesModeled() -> i64:
    157
