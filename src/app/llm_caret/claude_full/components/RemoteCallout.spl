class RemoteCalloutOption:
    label: text
    description: text
    value: text

impl RemoteCalloutOption:
    static fn new(label: text, description: text, value: text) -> RemoteCalloutOption:
        RemoteCalloutOption(label: label, description: description, value: value)

class RemoteCalloutView:
    title: text
    body: [text]
    options: [RemoteCalloutOption]
    marksSeenOnMount: bool

impl RemoteCalloutView:
    static fn new(title: text, body: [text], options: [RemoteCalloutOption], marksSeenOnMount: bool) -> RemoteCalloutView:
        RemoteCalloutView(title: title, body: body, options: options, marksSeenOnMount: marksSeenOnMount)

fn remoteCalloutOptions() -> [RemoteCalloutOption]:
    [
        RemoteCalloutOption.new("Enable Remote Control for this session", "Opens a secure connection to claude.ai.", "enable"),
        RemoteCalloutOption.new("Never mind", "You can always enable it later with /remote-control.", "dismiss"),
    ]

fn RemoteCallout() -> RemoteCalloutView:
    RemoteCalloutView.new(
        "Remote Control",
        [
            "Remote Control lets you access this CLI session from the web (claude.ai/code) or the Claude app, so you can pick up where you left off on any device.",
            "You can disconnect remote access anytime by running /remote-control again.",
        ],
        remoteCalloutOptions(),
        true,
    )

fn remoteCalloutCancelSelection() -> text:
    "dismiss"

fn handleCancel() -> text:
    remoteCalloutCancelSelection()

fn remoteCalloutSelect(value: text) -> text:
    if value == "enable":
        return "enable"
    "dismiss"

fn handleSelect(value: text) -> text:
    remoteCalloutSelect(value)

fn shouldShowRemoteCalloutRoute(remoteDialogSeen: bool, bridgeEnabled: bool, hasAccessToken: bool) -> bool:
    if remoteDialogSeen:
        return false
    if not bridgeEnabled:
        return false
    hasAccessToken

fn shouldShowRemoteCallout(remoteDialogSeen: bool, bridgeEnabled: bool, hasAccessToken: bool) -> bool:
    shouldShowRemoteCalloutRoute(remoteDialogSeen, bridgeEnabled, hasAccessToken)
