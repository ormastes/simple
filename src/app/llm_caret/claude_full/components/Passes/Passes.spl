"""
Claude full guest Passes parity model.
"""

const PASSES_SOURCE_LINES = 183

class PassStatus:
    pass_number: i64
    is_available: bool

impl PassStatus:
    static fn new(passNumber: i64, isAvailable: bool) -> PassStatus:
        PassStatus(pass_number: passNumber, is_available: isAvailable)

class PassesRender:
    loading: bool
    is_available: bool
    title: text
    body: text
    sorted_passes: [PassStatus]
    referral_link: text
    terms_url: text
    exit_hint: text

impl PassesRender:
    static fn new(loading: bool, isAvailable: bool, title: text, body: text, sortedPasses: [PassStatus], referralLink: text, termsUrl: text, exitHint: text) -> PassesRender:
        PassesRender(loading: loading, is_available: isAvailable, title: title, body: body, sorted_passes: sortedPasses, referral_link: referralLink, terms_url: termsUrl, exit_hint: exitHint)

fn passesBuildStatuses(redemptionsPresent: [bool], maxRedemptions: i64) -> [PassStatus]:
    var out: [PassStatus] = []
    var i = 0
    while i < maxRedemptions:
        val redeemed = if i < redemptionsPresent.len(): redemptionsPresent[i] else: false
        out.push(PassStatus.new(i + 1, not redeemed))
        i = i + 1
    out

fn passesAvailableCount(statuses: [PassStatus]) -> i64:
    var count = 0
    for status in statuses:
        if status.is_available:
            count = count + 1
    count

fn passesSortAvailableFirst(statuses: [PassStatus]) -> [PassStatus]:
    var out: [PassStatus] = []
    for status in statuses:
        if status.is_available:
            out.push(status)
    for status in statuses:
        if not status.is_available:
            out.push(status)
    out

fn passesTermsUrl(hasReferrerReward: bool) -> text:
    if hasReferrerReward:
        "https://support.claude.com/en/articles/13456702-claude-code-guest-passes"
    else:
        "https://support.claude.com/en/articles/12875061-claude-code-guest-passes"

fn passesRender(loading: bool, isAvailable: bool, statuses: [PassStatus], referralLink: text, hasReferrerReward: bool, rewardAmount: text, exitPending: bool, keyName: text) -> PassesRender:
    val exitHint = if exitPending: "Press " + keyName + " again to exit" else: "Enter to copy link · Esc to cancel"
    if loading:
        PassesRender.new(true, false, "", "Loading guest pass information...", [], "", "", if exitPending: "Press " + keyName + " again to exit" else: "Esc to cancel")
    else if not isAvailable:
        PassesRender.new(false, false, "", "Guest passes are not currently available.", [], "", "", if exitPending: "Press " + keyName + " again to exit" else: "Esc to cancel")
    else:
        val availableCount = passesAvailableCount(statuses)
        val body = if hasReferrerReward: "Share a free week of Claude Code with friends. If they love it and subscribe, you'll get " + rewardAmount + " of extra usage to keep building. " else: "Share a free week of Claude Code with friends. "
        PassesRender.new(false, true, "Guest passes · " + availableCount.to_text() + " left", body, passesSortAvailableFirst(statuses), referralLink, passesTermsUrl(hasReferrerReward), exitHint)

fn passesCopyReferral(referralLink: text) -> text:
    if referralLink == "":
        ""
    else:
        "Referral link copied to clipboard!"

fn passesSourceLinesModeled() -> i64:
    PASSES_SOURCE_LINES
