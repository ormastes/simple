"""
Claude full FullscreenLayout component parity.
"""

class FullscreenDimensions:
    width: i64
    height: i64

impl FullscreenDimensions:
    static fn new(width: i64, height: i64) -> FullscreenDimensions:
        FullscreenDimensions(width: fullscreenClampMin(width, 1), height: fullscreenClampMin(height, 1))

class FullscreenPanel:
    id: text
    title: text
    role: text
    minWidth: i64
    minHeight: i64
    weight: i64
    visible: bool
    scrollable: bool

impl FullscreenPanel:
    static fn new(id: text, title: text, role: text, minWidth: i64, minHeight: i64, weight: i64, visible: bool, scrollable: bool) -> FullscreenPanel:
        FullscreenPanel(id: id.trim(), title: title.trim(), role: role.trim(), minWidth: fullscreenClampMin(minWidth, 1), minHeight: fullscreenClampMin(minHeight, 1), weight: fullscreenClampMin(weight, 1), visible: visible, scrollable: scrollable)

class FullscreenOverlay:
    id: text
    title: text
    kind: text
    modal: bool
    visible: bool
    blocksInput: bool

impl FullscreenOverlay:
    static fn new(id: text, title: text, kind: text, modal: bool, visible: bool, blocksInput: bool) -> FullscreenOverlay:
        FullscreenOverlay(id: id.trim(), title: title.trim(), kind: kind.trim(), modal: modal, visible: visible, blocksInput: blocksInput)

class FullscreenLayoutState:
    dimensions: FullscreenDimensions
    panels: [FullscreenPanel]
    overlays: [FullscreenOverlay]
    focusRegion: text
    headerRequested: bool
    footerRequested: bool
    compactRequested: bool
    commandPaletteOpen: bool
    statusText: text

impl FullscreenLayoutState:
    static fn new(dimensions: FullscreenDimensions, panels: [FullscreenPanel], overlays: [FullscreenOverlay], focusRegion: text, headerRequested: bool, footerRequested: bool, compactRequested: bool, commandPaletteOpen: bool, statusText: text) -> FullscreenLayoutState:
        FullscreenLayoutState(dimensions: dimensions, panels: panels, overlays: overlays, focusRegion: focusRegion.trim(), headerRequested: headerRequested, footerRequested: footerRequested, compactRequested: compactRequested, commandPaletteOpen: commandPaletteOpen, statusText: statusText.trim())

class FullscreenRegionFrame:
    id: text
    title: text
    x: i64
    y: i64
    width: i64
    height: i64
    focused: bool
    scrollable: bool

impl FullscreenRegionFrame:
    static fn new(id: text, title: text, x: i64, y: i64, width: i64, height: i64, focused: bool, scrollable: bool) -> FullscreenRegionFrame:
        FullscreenRegionFrame(id: id, title: title, x: x, y: y, width: fullscreenClampMin(width, 1), height: fullscreenClampMin(height, 1), focused: focused, scrollable: scrollable)

class FullscreenActionSummary:
    key: text
    action: text
    target: text
    enabled: bool
    description: text

impl FullscreenActionSummary:
    static fn new(key: text, action: text, target: text, enabled: bool, description: text) -> FullscreenActionSummary:
        FullscreenActionSummary(key: key.trim(), action: action.trim(), target: target.trim(), enabled: enabled, description: description.trim())

fn fullscreenClampMin(value: i64, minimum: i64) -> i64:
    if value < minimum:
        return minimum
    value

fn fullscreenClampMax(value: i64, maximum: i64) -> i64:
    if value > maximum:
        return maximum
    value

fn fullscreenClamp(value: i64, minimum: i64, maximum: i64) -> i64:
    fullscreenClampMax(fullscreenClampMin(value, minimum), maximum)

fn fullscreenDefaultHeaderHeight() -> i64:
    3

fn fullscreenDefaultFooterHeight() -> i64:
    3

fn fullscreenNarrowWidth() -> i64:
    80

fn fullscreenShortHeight() -> i64:
    24

fn fullscreenLayoutMode(dimensions: FullscreenDimensions, compactRequested: bool) -> text:
    if compactRequested:
        return "compact"
    if dimensions.width < fullscreenNarrowWidth():
        return "stacked"
    if dimensions.height < fullscreenShortHeight():
        return "short"
    "wide"

fn fullscreenHeaderVisible(state: FullscreenLayoutState) -> bool:
    state.headerRequested and not fullscreenHasVisibleModal(state)

fn fullscreenFooterVisible(state: FullscreenLayoutState) -> bool:
    state.footerRequested and state.dimensions.height >= 10 and not fullscreenHasBlockingOverlay(state)

fn fullscreenHeaderHeight(state: FullscreenLayoutState) -> i64:
    if fullscreenHeaderVisible(state):
        return fullscreenDefaultHeaderHeight()
    0

fn fullscreenFooterHeight(state: FullscreenLayoutState) -> i64:
    if fullscreenFooterVisible(state):
        return fullscreenDefaultFooterHeight()
    0

fn fullscreenContentTop(state: FullscreenLayoutState) -> i64:
    fullscreenHeaderHeight(state)

fn fullscreenContentHeight(state: FullscreenLayoutState) -> i64:
    fullscreenClampMin(state.dimensions.height - fullscreenHeaderHeight(state) - fullscreenFooterHeight(state), 1)

fn fullscreenContentWidth(state: FullscreenLayoutState) -> i64:
    fullscreenClampMin(state.dimensions.width, 1)

fn fullscreenVisiblePanels(state: FullscreenLayoutState) -> [FullscreenPanel]:
    var out: [FullscreenPanel] = []
    var i = 0
    while i < state.panels.len():
        if state.panels[i].visible:
            out.push(state.panels[i])
        i = i + 1
    out

fn fullscreenPanelById(state: FullscreenLayoutState, id: text) -> FullscreenPanel:
    var i = 0
    while i < state.panels.len():
        if state.panels[i].id == id:
            return state.panels[i]
        i = i + 1
    FullscreenPanel.new("", "", "", 1, 1, 1, false, false)

fn fullscreenFirstVisiblePanelId(state: FullscreenLayoutState) -> text:
    val panels = fullscreenVisiblePanels(state)
    if panels.len() == 0:
        return ""
    panels[0].id

fn fullscreenFocusRegion(state: FullscreenLayoutState) -> text:
    if state.commandPaletteOpen:
        return "command-palette"
    val overlay = fullscreenTopVisibleOverlay(state)
    if overlay.id != "":
        return overlay.id
    val requested = fullscreenPanelById(state, state.focusRegion)
    if requested.visible:
        return requested.id
    fullscreenFirstVisiblePanelId(state)

fn fullscreenMoveFocus(state: FullscreenLayoutState, direction: text) -> text:
    val panels = fullscreenVisiblePanels(state)
    if panels.len() == 0:
        return ""
    val current = fullscreenFocusRegion(state)
    var index = 0
    var found = false
    var i = 0
    while i < panels.len():
        if panels[i].id == current:
            index = i
            found = true
        i = i + 1
    if not found:
        return panels[0].id
    if direction == "previous" or direction == "left" or direction == "up":
        if index == 0:
            return panels[panels.len() - 1].id
        return panels[index - 1].id
    if index + 1 >= panels.len():
        return panels[0].id
    panels[index + 1].id

fn fullscreenTopVisibleOverlay(state: FullscreenLayoutState) -> FullscreenOverlay:
    var i = state.overlays.len() - 1
    while i >= 0:
        if state.overlays[i].visible:
            return state.overlays[i]
        i = i - 1
    FullscreenOverlay.new("", "", "", false, false, false)

fn fullscreenVisibleOverlays(state: FullscreenLayoutState) -> [FullscreenOverlay]:
    var out: [FullscreenOverlay] = []
    var i = 0
    while i < state.overlays.len():
        if state.overlays[i].visible:
            out.push(state.overlays[i])
        i = i + 1
    out

fn fullscreenHasVisibleModal(state: FullscreenLayoutState) -> bool:
    var i = 0
    while i < state.overlays.len():
        val overlay = state.overlays[i]
        if overlay.visible and overlay.modal:
            return true
        i = i + 1
    false

fn fullscreenHasBlockingOverlay(state: FullscreenLayoutState) -> bool:
    if state.commandPaletteOpen:
        return true
    var i = 0
    while i < state.overlays.len():
        val overlay = state.overlays[i]
        if overlay.visible and overlay.blocksInput:
            return true
        i = i + 1
    false

fn fullscreenOverlayState(state: FullscreenLayoutState) -> text:
    if state.commandPaletteOpen:
        return "command-palette"
    val overlay = fullscreenTopVisibleOverlay(state)
    if overlay.id == "":
        return "none"
    if overlay.modal:
        return "modal:" + overlay.id
    "overlay:" + overlay.id

fn fullscreenTotalPanelWeight(panels: [FullscreenPanel]) -> i64:
    var total = 0
    var i = 0
    while i < panels.len():
        total = total + fullscreenClampMin(panels[i].weight, 1)
        i = i + 1
    fullscreenClampMin(total, 1)

fn fullscreenPanelWidth(panel: FullscreenPanel, availableWidth: i64, totalWeight: i64) -> i64:
    val weighted = availableWidth * fullscreenClampMin(panel.weight, 1) / fullscreenClampMin(totalWeight, 1)
    fullscreenClamp(weighted, panel.minWidth, availableWidth)

fn fullscreenWideFrames(state: FullscreenLayoutState) -> [FullscreenRegionFrame]:
    val panels = fullscreenVisiblePanels(state)
    var out: [FullscreenRegionFrame] = []
    if panels.len() == 0:
        return out
    val totalWeight = fullscreenTotalPanelWeight(panels)
    val top = fullscreenContentTop(state)
    val height = fullscreenContentHeight(state)
    val width = fullscreenContentWidth(state)
    val focus = fullscreenFocusRegion(state)
    var used = 0
    var i = 0
    while i < panels.len():
        val panel = panels[i]
        var panelWidth = fullscreenPanelWidth(panel, width, totalWeight)
        if i + 1 == panels.len():
            panelWidth = fullscreenClampMin(width - used, 1)
        out.push(FullscreenRegionFrame.new(panel.id, panel.title, used, top, panelWidth, height, panel.id == focus, panel.scrollable))
        used = used + panelWidth
        i = i + 1
    out

fn fullscreenStackedFrames(state: FullscreenLayoutState) -> [FullscreenRegionFrame]:
    val panels = fullscreenVisiblePanels(state)
    var out: [FullscreenRegionFrame] = []
    if panels.len() == 0:
        return out
    val top = fullscreenContentTop(state)
    val totalHeight = fullscreenContentHeight(state)
    val width = fullscreenContentWidth(state)
    val focus = fullscreenFocusRegion(state)
    val rowHeight = fullscreenClampMin(totalHeight / panels.len(), 1)
    var used = 0
    var i = 0
    while i < panels.len():
        val panel = panels[i]
        var height = fullscreenClampMin(rowHeight, panel.minHeight)
        if i + 1 == panels.len():
            height = fullscreenClampMin(totalHeight - used, 1)
        out.push(FullscreenRegionFrame.new(panel.id, panel.title, 0, top + used, width, height, panel.id == focus, panel.scrollable))
        used = used + height
        i = i + 1
    out

fn fullscreenShortFrames(state: FullscreenLayoutState) -> [FullscreenRegionFrame]:
    val panels = fullscreenVisiblePanels(state)
    var out: [FullscreenRegionFrame] = []
    if panels.len() == 0:
        return out
    val focus = fullscreenFocusRegion(state)
    var i = 0
    while i < panels.len():
        if panels[i].id == focus:
            out.push(FullscreenRegionFrame.new(panels[i].id, panels[i].title, 0, fullscreenContentTop(state), fullscreenContentWidth(state), fullscreenContentHeight(state), true, panels[i].scrollable))
            return out
        i = i + 1
    out.push(FullscreenRegionFrame.new(panels[0].id, panels[0].title, 0, fullscreenContentTop(state), fullscreenContentWidth(state), fullscreenContentHeight(state), true, panels[0].scrollable))
    out

fn fullscreenRegionFrames(state: FullscreenLayoutState) -> [FullscreenRegionFrame]:
    val mode = fullscreenLayoutMode(state.dimensions, state.compactRequested)
    if mode == "wide":
        return fullscreenWideFrames(state)
    if mode == "stacked" or mode == "compact":
        return fullscreenStackedFrames(state)
    fullscreenShortFrames(state)

fn fullscreenOverlayFrame(state: FullscreenLayoutState) -> FullscreenRegionFrame:
    val overlay = fullscreenTopVisibleOverlay(state)
    if overlay.id == "":
        return FullscreenRegionFrame.new("", "", 0, 0, 1, 1, false, false)
    val width = fullscreenClamp(state.dimensions.width - 8, 20, state.dimensions.width)
    val height = fullscreenClamp(state.dimensions.height - 6, 8, state.dimensions.height)
    val x = (state.dimensions.width - width) / 2
    val y = (state.dimensions.height - height) / 2
    FullscreenRegionFrame.new(overlay.id, overlay.title, x, y, width, height, true, true)

fn fullscreenHeaderSummary(state: FullscreenLayoutState) -> text:
    if not fullscreenHeaderVisible(state):
        return ""
    val mode = fullscreenLayoutMode(state.dimensions, state.compactRequested)
    "Claude Code · " + mode + " · " + state.dimensions.width.to_text() + "x" + state.dimensions.height.to_text()

fn fullscreenFooterSummary(state: FullscreenLayoutState) -> text:
    if not fullscreenFooterVisible(state):
        return ""
    if state.statusText != "":
        return state.statusText
    "Ctrl+O expand · Ctrl+P command · Tab focus"

fn fullscreenPanelSummary(panel: FullscreenPanel, focused: bool) -> text:
    val marker = if focused: "*" else: "-"
    marker + " " + panel.title + " [" + panel.role + "]"

fn fullscreenLayoutSummary(state: FullscreenLayoutState) -> [text]:
    var out: [text] = []
    val header = fullscreenHeaderSummary(state)
    if header != "":
        out.push(header)
    val frames = fullscreenRegionFrames(state)
    var i = 0
    while i < frames.len():
        val panel = fullscreenPanelById(state, frames[i].id)
        out.push(fullscreenPanelSummary(panel, frames[i].focused) + " " + frames[i].width.to_text() + "x" + frames[i].height.to_text())
        i = i + 1
    val overlay = fullscreenTopVisibleOverlay(state)
    if overlay.id != "":
        out.push("overlay " + overlay.kind + ": " + overlay.title)
    val footer = fullscreenFooterSummary(state)
    if footer != "":
        out.push(footer)
    out

fn fullscreenKeyboardActions(state: FullscreenLayoutState) -> [FullscreenActionSummary]:
    val blocked = fullscreenHasBlockingOverlay(state)
    val focus = fullscreenFocusRegion(state)
    [
        FullscreenActionSummary.new("tab", "focus-next", focus, not blocked, "Move focus to the next visible region"),
        FullscreenActionSummary.new("shift+tab", "focus-previous", focus, not blocked, "Move focus to the previous visible region"),
        FullscreenActionSummary.new("ctrl+p", "command-palette", "command-palette", true, "Open command palette"),
        FullscreenActionSummary.new("escape", "dismiss", fullscreenOverlayState(state), fullscreenOverlayState(state) != "none", "Dismiss the top overlay"),
        FullscreenActionSummary.new("ctrl+o", "toggle-compact", fullscreenLayoutMode(state.dimensions, state.compactRequested), not fullscreenHasVisibleModal(state), "Toggle compact fullscreen layout"),
    ]

fn fullscreenEnabledActionKeys(state: FullscreenLayoutState) -> [text]:
    val actions = fullscreenKeyboardActions(state)
    var out: [text] = []
    var i = 0
    while i < actions.len():
        if actions[i].enabled:
            out.push(actions[i].key)
        i = i + 1
    out

fn fullscreenActionLine(action: FullscreenActionSummary) -> text:
    val state = if action.enabled: "enabled" else: "disabled"
    action.key + " -> " + action.action + " (" + state + ")"

fn fullscreenKeyboardSummary(state: FullscreenLayoutState) -> [text]:
    val actions = fullscreenKeyboardActions(state)
    var out: [text] = []
    var i = 0
    while i < actions.len():
        out.push(fullscreenActionLine(actions[i]))
        i = i + 1
    out

fn fullscreenResponsiveSummary(state: FullscreenLayoutState) -> text:
    val mode = fullscreenLayoutMode(state.dimensions, state.compactRequested)
    val panels = fullscreenVisiblePanels(state).len()
    val overlays = fullscreenVisibleOverlays(state).len()
    mode + " layout, " + panels.to_text() + " panels, " + overlays.to_text() + " overlays, focus " + fullscreenFocusRegion(state)

fn fullscreenSource() -> text:
    "FullscreenLayout"

fn fullscreenLayoutSourceLinesModeled() -> i64:
    636
