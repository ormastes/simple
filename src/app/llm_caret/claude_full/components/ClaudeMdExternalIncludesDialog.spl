"""
Claude full ClaudeMdExternalIncludesDialog component parity.
"""

fn externalIncludesDialogTitle(count: i64) -> text:
    "External CLAUDE.md includes: " + count.to_text()

fn externalIncludesRequiresApproval(count: i64) -> bool:
    count > 0

fn externalIncludesDialogMessage(count: i64) -> text:
    if externalIncludesRequiresApproval(count):
        return "Review external includes"
    "No external includes"

fn claudeMdExternalIncludesDialogSourceLinesModeled() -> i64:
    136
