class ToolUseLoaderView:
    glyph: text
    color: text
    dim: bool
    minWidth: i64
    sourceGlyph: text

impl ToolUseLoaderView:
    static fn new(glyph: text, color: text, dim: bool, minWidth: i64, sourceGlyph: text) -> ToolUseLoaderView:
        ToolUseLoaderView(glyph: glyph, color: color, dim: dim, minWidth: minWidth, sourceGlyph: sourceGlyph)

fn toolUseLoaderColor(isError: bool, isUnresolved: bool) -> text:
    if isUnresolved:
        return ""
    if isError:
        return "error"
    "success"

fn blackCircleGlyph(platform: text) -> text:
    if platform == "darwin":
        return "darwin-black-circle"
    "black-circle"

fn useBlink(shouldAnimate: bool, tickVisible: bool) -> bool:
    shouldAnimate && tickVisible

fn toolUseLoaderGlyph(isError: bool, isUnresolved: bool, shouldAnimate: bool, isBlinking: bool) -> text:
    if not shouldAnimate || isBlinking || isError || not isUnresolved:
        return "o"
    " "

fn ToolUseLoader(isError: bool, isUnresolved: bool, shouldAnimate: bool, isBlinking: bool) -> ToolUseLoaderView:
    ToolUseLoaderView.new(toolUseLoaderGlyph(isError, isUnresolved, shouldAnimate, isBlinking), toolUseLoaderColor(isError, isUnresolved), isUnresolved, 2, "BLACK_CIRCLE")
