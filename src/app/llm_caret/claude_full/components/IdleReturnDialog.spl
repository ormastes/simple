"""
Claude full IdleReturnDialog parity.
"""

class IdleReturnState:
    open: bool
    idle_minutes: i64
    has_pending_work: bool
    session_name: text

impl IdleReturnState:
    static fn new(open: bool, idleMinutes: i64, hasPendingWork: bool, sessionName: text) -> IdleReturnState:
        IdleReturnState(open: open, idle_minutes: clampIdleMinutes(idleMinutes), has_pending_work: hasPendingWork, session_name: sessionName.trim())

fn clampIdleMinutes(minutes: i64) -> i64:
    if minutes < 0:
        return 0
    minutes

fn idleReturnTitle(state: IdleReturnState) -> text:
    if state.session_name == "":
        return "Return to session"
    "Return to " + state.session_name

fn idleReturnAction(state: IdleReturnState) -> text:
    if state.has_pending_work:
        return "Resume work"
    "Continue"

fn idleReturnSummary(state: IdleReturnState) -> text:
    idleReturnTitle(state) + " idle=" + state.idle_minutes.to_text()

fn idleReturnDialogSourceLinesModeled() -> i64:
    117
