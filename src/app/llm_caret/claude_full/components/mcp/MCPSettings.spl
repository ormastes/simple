"""
Claude full MCP settings parity model.
"""

const MCP_SETTINGS_SOURCE_LINES = 397

class MCPSettingsClientConfig:
    typeName: text
    scope: text
    url: text
    command: text

impl MCPSettingsClientConfig:
    static fn new(typeName: text, scope: text, url: text, command: text) -> MCPSettingsClientConfig:
        MCPSettingsClientConfig(typeName: typeName, scope: scope, url: url, command: command)

class MCPSettingsClient:
    name: text
    typeName: text
    config: MCPSettingsClientConfig
    hasOAuthTokens: bool
    hasTools: bool

impl MCPSettingsClient:
    static fn new(name: text, clientType: text, configType: text, scope: text, hasOAuthTokens: bool, hasTools: bool) -> MCPSettingsClient:
        MCPSettingsClient(name: name, typeName: clientType, config: MCPSettingsClientConfig.new(configType, scope, "", ""), hasOAuthTokens: hasOAuthTokens, hasTools: hasTools)

class MCPSettingsAgentDefinition:
    name: text
    mcpServerNames: [text]
    needsAuthNames: [text]

impl MCPSettingsAgentDefinition:
    static fn new(name: text, mcpServerNames: [text], needsAuthNames: [text]) -> MCPSettingsAgentDefinition:
        MCPSettingsAgentDefinition(name: name, mcpServerNames: mcpServerNames, needsAuthNames: needsAuthNames)

class MCPSettingsViewState:
    typeName: text
    defaultTab: text
    serverName: text
    agentServerName: text
    toolIndex: i64

impl MCPSettingsViewState:
    static fn list(defaultTab: text) -> MCPSettingsViewState:
        MCPSettingsViewState(typeName: "list", defaultTab: defaultTab, serverName: "", agentServerName: "", toolIndex: -1)

    static fn serverMenu(serverName: text) -> MCPSettingsViewState:
        MCPSettingsViewState(typeName: "server-menu", defaultTab: "", serverName: serverName, agentServerName: "", toolIndex: -1)

    static fn serverTools(serverName: text) -> MCPSettingsViewState:
        MCPSettingsViewState(typeName: "server-tools", defaultTab: "", serverName: serverName, agentServerName: "", toolIndex: -1)

    static fn serverToolDetail(serverName: text, toolIndex: i64) -> MCPSettingsViewState:
        MCPSettingsViewState(typeName: "server-tool-detail", defaultTab: "", serverName: serverName, agentServerName: "", toolIndex: toolIndex)

    static fn agentServerMenu(agentServerName: text) -> MCPSettingsViewState:
        MCPSettingsViewState(typeName: "agent-server-menu", defaultTab: "", serverName: "", agentServerName: agentServerName, toolIndex: -1)

class MCPSettingsTool:
    name: text
    serverName: text

impl MCPSettingsTool:
    static fn new(name: text, serverName: text) -> MCPSettingsTool:
        MCPSettingsTool(name: name, serverName: serverName)

class MCPSettingsPreparedServer:
    name: text
    clientName: text
    scope: text
    transport: text
    isAuthenticated: bool
    configType: text
    clientType: text

impl MCPSettingsPreparedServer:
    static fn new(name: text, clientName: text, scope: text, transport: text, isAuthenticated: bool, configType: text, clientType: text) -> MCPSettingsPreparedServer:
        MCPSettingsPreparedServer(name: name, clientName: clientName, scope: scope, transport: transport, isAuthenticated: isAuthenticated, configType: configType, clientType: clientType)

class MCPSettingsRenderDecision:
    component: text
    serverName: text
    agentServerName: text
    defaultTab: text
    toolIndex: i64
    message: text

impl MCPSettingsRenderDecision:
    static fn new(component: text, serverName: text, agentServerName: text, defaultTab: text, toolIndex: i64, message: text) -> MCPSettingsRenderDecision:
        MCPSettingsRenderDecision(component: component, serverName: serverName, agentServerName: agentServerName, defaultTab: defaultTab, toolIndex: toolIndex, message: message)

fn mcpSettingsInitialViewState() -> MCPSettingsViewState:
    MCPSettingsViewState.list("")

fn mcpSettingsIsRemoteConfig(configType: text) -> bool:
    configType == "sse" or configType == "http"

fn mcpSettingsTransportForConfig(configType: text) -> text:
    if configType == "claudeai-proxy":
        return "claudeai-proxy"
    if configType == "sse":
        return "sse"
    if configType == "http":
        return "http"
    "stdio"

fn mcpSettingsIsAuthenticated(client: MCPSettingsClient, hasSessionIngressAuth: bool) -> bool:
    if not mcpSettingsIsRemoteConfig(client.config.typeName):
        return false
    val hasSessionAuth = hasSessionIngressAuth and client.typeName == "connected"
    val hasToolsAndConnected = client.typeName == "connected" and client.hasTools
    client.hasOAuthTokens or hasSessionAuth or hasToolsAndConnected

fn mcpSettingsShouldIncludeClient(client: MCPSettingsClient) -> bool:
    client.name != "ide"

fn mcpSettingsSortClients(clients: [MCPSettingsClient]) -> [MCPSettingsClient]:
    var out: [MCPSettingsClient] = []
    var i = 0
    while i < clients.len():
        val client = clients[i]
        var inserted = false
        var next: [MCPSettingsClient] = []
        var j = 0
        while j < out.len():
            if not inserted and client.name < out[j].name:
                next.push(client)
                inserted = true
            next.push(out[j])
            j = j + 1
        if not inserted:
            next.push(client)
        out = next
        i = i + 1
    out

fn mcpSettingsFilteredClients(clients: [MCPSettingsClient]) -> [MCPSettingsClient]:
    var out: [MCPSettingsClient] = []
    var i = 0
    while i < clients.len():
        if mcpSettingsShouldIncludeClient(clients[i]):
            out.push(clients[i])
        i = i + 1
    mcpSettingsSortClients(out)

fn mcpSettingsPrepareServer(client: MCPSettingsClient, hasSessionIngressAuth: bool) -> MCPSettingsPreparedServer:
    val transport = mcpSettingsTransportForConfig(client.config.typeName)
    var authenticated = mcpSettingsIsAuthenticated(client, hasSessionIngressAuth)
    if transport == "claudeai-proxy":
        authenticated = false
    MCPSettingsPreparedServer.new(client.name, client.name, client.config.scope, transport, authenticated, client.config.typeName, client.typeName)

fn mcpSettingsPrepareServers(clients: [MCPSettingsClient], hasSessionIngressAuth: bool) -> [MCPSettingsPreparedServer]:
    val filtered = mcpSettingsFilteredClients(clients)
    var servers: [MCPSettingsPreparedServer] = []
    var i = 0
    while i < filtered.len():
        servers.push(mcpSettingsPrepareServer(filtered[i], hasSessionIngressAuth))
        i = i + 1
    servers

fn mcpSettingsContainsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn mcpSettingsExtractAgentServers(agentDefinitions: [MCPSettingsAgentDefinition]) -> [MCPListPanelAgentServerInfo]:
    var out: [MCPListPanelAgentServerInfo] = []
    var i = 0
    while i < agentDefinitions.len():
        val agent = agentDefinitions[i]
        var j = 0
        while j < agent.mcpServerNames.len():
            val serverName = agent.mcpServerNames[j]
            val needsAuth = mcpSettingsContainsText(agent.needsAuthNames, serverName)
            out.push(MCPListPanelAgentServerInfo.new(serverName, [agent.name], needsAuth))
            j = j + 1
        i = i + 1
    out

fn mcpSettingsToListPanelServer(server: MCPSettingsPreparedServer) -> MCPListPanelServerInfo:
    MCPListPanelServerInfo.new(server.name, server.clientType, server.configType, server.scope, server.transport, server.isAuthenticated)

fn mcpSettingsToListPanelServers(servers: [MCPSettingsPreparedServer]) -> [MCPListPanelServerInfo]:
    var out: [MCPListPanelServerInfo] = []
    var i = 0
    while i < servers.len():
        out.push(mcpSettingsToListPanelServer(servers[i]))
        i = i + 1
    out

fn mcpSettingsNoServersMessage() -> text:
    "No MCP servers configured. Please run /doctor if this is unexpected. Otherwise, run `claude mcp --help` or visit https://code.claude.com/docs/en/mcp to learn more."

fn mcpSettingsShouldCompleteNoServers(preparedServers: [MCPSettingsPreparedServer], filteredClientCount: i64, agentServerCount: i64) -> bool:
    if preparedServers.len() == 0 and filteredClientCount > 0:
        return false
    preparedServers.len() == 0 and agentServerCount == 0

fn mcpSettingsFindServer(servers: [MCPSettingsPreparedServer], name: text) -> MCPSettingsPreparedServer?:
    var i = 0
    while i < servers.len():
        if servers[i].name == name:
            return servers[i]
        i = i + 1
    nil

fn mcpSettingsFindAgentServer(agentServers: [MCPListPanelAgentServerInfo], name: text) -> MCPListPanelAgentServerInfo?:
    var i = 0
    while i < agentServers.len():
        if agentServers[i].name == name:
            return agentServers[i]
        i = i + 1
    nil

fn mcpSettingsToolsForServer(tools: [MCPSettingsTool], serverName: text) -> [MCPSettingsTool]:
    var out: [MCPSettingsTool] = []
    var i = 0
    while i < tools.len():
        if tools[i].serverName == serverName:
            out.push(tools[i])
        i = i + 1
    out

fn mcpSettingsDefaultTab(server: MCPSettingsPreparedServer) -> text:
    if server.transport == "claudeai-proxy":
        return "claude.ai"
    "Claude Code"

fn mcpSettingsBackToList(defaultTab: text) -> MCPSettingsViewState:
    MCPSettingsViewState.list(defaultTab)

fn mcpSettingsSelectServer(serverName: text) -> MCPSettingsViewState:
    MCPSettingsViewState.serverMenu(serverName)

fn mcpSettingsSelectAgentServer(agentServerName: text) -> MCPSettingsViewState:
    MCPSettingsViewState.agentServerMenu(agentServerName)

fn mcpSettingsViewTools(serverName: text) -> MCPSettingsViewState:
    MCPSettingsViewState.serverTools(serverName)

fn mcpSettingsSelectTool(serverName: text, index: i64) -> MCPSettingsViewState:
    MCPSettingsViewState.serverToolDetail(serverName, index)

fn mcpSettingsRecoverMissingTool(viewState: MCPSettingsViewState) -> MCPSettingsViewState:
    MCPSettingsViewState.serverTools(viewState.serverName)

fn mcpSettingsRenderDecision(viewState: MCPSettingsViewState, preparedServers: [MCPSettingsPreparedServer], agentServers: [MCPListPanelAgentServerInfo], tools: [MCPSettingsTool]) -> MCPSettingsRenderDecision:
    if viewState.typeName == "list":
        return MCPSettingsRenderDecision.new("MCPListPanel", "", "", viewState.defaultTab, -1, "")
    if viewState.typeName == "server-menu":
        if val server = mcpSettingsFindServer(preparedServers, viewState.serverName):
            val component = if server.transport == "stdio": "MCPStdioServerMenu" else: "MCPRemoteServerMenu"
            return MCPSettingsRenderDecision.new(component, server.name, "", mcpSettingsDefaultTab(server), -1, "")
        return MCPSettingsRenderDecision.new("MCPListPanel", "", "", "", -1, "")
    if viewState.typeName == "server-tools":
        if val server = mcpSettingsFindServer(preparedServers, viewState.serverName):
            return MCPSettingsRenderDecision.new("MCPToolListView", server.name, "", "", -1, "")
        return MCPSettingsRenderDecision.new("MCPListPanel", "", "", "", -1, "")
    if viewState.typeName == "server-tool-detail":
        if val server = mcpSettingsFindServer(preparedServers, viewState.serverName):
            val serverTools = mcpSettingsToolsForServer(tools, server.name)
            if viewState.toolIndex >= 0 and viewState.toolIndex < serverTools.len():
                return MCPSettingsRenderDecision.new("MCPToolDetailView", server.name, "", "", viewState.toolIndex, serverTools[viewState.toolIndex].name)
            return MCPSettingsRenderDecision.new("MCPToolListView", server.name, "", "", -1, "missing tool")
        return MCPSettingsRenderDecision.new("MCPListPanel", "", "", "", -1, "")
    if viewState.typeName == "agent-server-menu":
        if val agentServer = mcpSettingsFindAgentServer(agentServers, viewState.agentServerName):
            return MCPSettingsRenderDecision.new("MCPAgentServerMenu", "", agentServer.name, "Agents", -1, "")
        return MCPSettingsRenderDecision.new("MCPListPanel", "", "", "Agents", -1, "")
    MCPSettingsRenderDecision.new("MCPListPanel", "", "", "", -1, "")

fn mcpSettingsServerToolsCount(tools: [MCPSettingsTool], serverName: text) -> i64:
    mcpSettingsToolsForServer(tools, serverName).len()

fn mcpSettingsListPanelRender(clients: [MCPSettingsClient], agentDefinitions: [MCPSettingsAgentDefinition], hasSessionIngressAuth: bool, selectedIndex: i64, debugMode: bool) -> MCPListPanelRenderModel:
    val prepared = mcpSettingsPrepareServers(clients, hasSessionIngressAuth)
    val agents = mcpSettingsExtractAgentServers(agentDefinitions)
    mcpListPanelRender(mcpSettingsToListPanelServers(prepared), agents, selectedIndex, debugMode)

fn mcpSettingsCompletionMessage(clients: [MCPSettingsClient], preparedServers: [MCPSettingsPreparedServer], agentServers: [MCPListPanelAgentServerInfo]) -> text:
    val filtered = mcpSettingsFilteredClients(clients)
    if mcpSettingsShouldCompleteNoServers(preparedServers, filtered.len(), agentServers.len()):
        return mcpSettingsNoServersMessage()
    ""

fn mcpSettingsModeledSourceLines() -> i64:
    MCP_SETTINGS_SOURCE_LINES
