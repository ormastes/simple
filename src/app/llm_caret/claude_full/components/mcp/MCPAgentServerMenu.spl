"""
Claude full MCP agent server menu parity.
"""

class MCPAgentServerState:
    name: text
    transport: text
    url: text
    command: text
    source_agents: [text]
    needs_auth: bool
    authenticated: bool
    authenticating: bool
    authorization_url: text
    error: text

impl MCPAgentServerState:
    static fn new(name: text, transport: text, url: text, command: text, sourceAgents: [text], needsAuth: bool, authenticated: bool, authenticating: bool, authorizationUrl: text, error: text) -> MCPAgentServerState:
        MCPAgentServerState(name: name.trim(), transport: normalizeMcpAgentTransport(transport), url: url.trim(), command: command.trim(), source_agents: sourceAgents, needs_auth: needsAuth, authenticated: authenticated, authenticating: authenticating, authorization_url: authorizationUrl.trim(), error: error.trim())

fn normalizeMcpAgentTransport(transport: text) -> text:
    val clean = transport.trim().lower()
    if clean == "http" or clean == "sse" or clean == "stdio":
        return clean
    "stdio"

fn mcpAgentMenuOptions(state: MCPAgentServerState) -> [text]:
    var options: [text] = []
    if state.needs_auth:
        if state.authenticated:
            options.push("auth:Re-authenticate")
        else:
            options.push("auth:Authenticate")
    options.push("back:Back")
    options

fn mcpAgentAuthStatus(state: MCPAgentServerState) -> text:
    if not state.needs_auth:
        return "none"
    if state.authenticated:
        return "authenticated"
    "may need authentication"

fn mcpAgentVisibleMode(state: MCPAgentServerState) -> text:
    if state.authenticating:
        return "authenticating"
    "menu"

fn mcpAgentUsedBy(state: MCPAgentServerState) -> text:
    var out = ""
    var i = 0
    while i < state.source_agents.len():
        if i > 0:
            out = out + ", "
        out = out + state.source_agents[i]
        i = i + 1
    out

fn mcpAgentServerSummary(state: MCPAgentServerState) -> text:
    if state.authenticating:
        return "Authenticating with " + state.name
    state.name + " type=" + state.transport + " auth=" + mcpAgentAuthStatus(state) + " used_by=" + mcpAgentUsedBy(state)

fn mcpAgentServerMenuSourceLinesModeled() -> i64:
    182
