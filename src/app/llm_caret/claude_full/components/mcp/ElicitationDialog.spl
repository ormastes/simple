"""
Claude full MCP elicitation dialog parity model.
"""

const ELICITATION_DIALOG_SOURCE_LINES = 1168
const ELICITATION_DIALOG_SPINNER_CHARS = "braille-spinner"

class ElicitationDialogSchema:
    schemaType: text
    title: text
    description: text
    format: text
    defaultValue: text
    enumValues: [text]
    enumLabels: [text]
    required: bool
    minItems: i64
    maxItems: i64

impl ElicitationDialogSchema:
    static fn new(schemaType: text, title: text, description: text, format: text, defaultValue: text, enumValues: [text], enumLabels: [text], required: bool, minItems: i64, maxItems: i64) -> ElicitationDialogSchema:
        ElicitationDialogSchema(schemaType: schemaType, title: title, description: description, format: format, defaultValue: defaultValue, enumValues: enumValues, enumLabels: enumLabels, required: required, minItems: minItems, maxItems: maxItems)

class ElicitationDialogField:
    name: text
    schema: ElicitationDialogSchema
    value: text
    values: [text]
    error: text
    resolving: bool

impl ElicitationDialogField:
    static fn new(name: text, schema: ElicitationDialogSchema, value: text, values: [text], error: text, resolving: bool) -> ElicitationDialogField:
        ElicitationDialogField(name: name, schema: schema, value: value, values: values, error: error, resolving: resolving)

class ElicitationDialogFormState:
    serverName: text
    message: text
    fields: [ElicitationDialogField]
    currentFieldIndex: i64
    focusedButton: text
    expandedAccordion: text
    accordionOptionIndex: i64
    textInputValue: text

impl ElicitationDialogFormState:
    static fn new(serverName: text, message: text, fields: [ElicitationDialogField], currentFieldIndex: i64, focusedButton: text, expandedAccordion: text, accordionOptionIndex: i64, textInputValue: text) -> ElicitationDialogFormState:
        ElicitationDialogFormState(serverName: serverName, message: message, fields: fields, currentFieldIndex: currentFieldIndex, focusedButton: focusedButton, expandedAccordion: expandedAccordion, accordionOptionIndex: accordionOptionIndex, textInputValue: textInputValue)

class ElicitationDialogUrlState:
    serverName: text
    message: text
    url: text
    phase: text
    focusedButton: text
    showCancel: bool
    actionLabel: text
    completed: bool

impl ElicitationDialogUrlState:
    static fn new(serverName: text, message: text, url: text, phase: text, focusedButton: text, showCancel: bool, actionLabel: text, completed: bool) -> ElicitationDialogUrlState:
        ElicitationDialogUrlState(serverName: serverName, message: message, url: url, phase: phase, focusedButton: focusedButton, showCancel: showCancel, actionLabel: actionLabel, completed: completed)

class ElicitationDialogUrlParts:
    beforeDomain: text
    domain: text
    afterDomain: text

impl ElicitationDialogUrlParts:
    static fn new(beforeDomain: text, domain: text, afterDomain: text) -> ElicitationDialogUrlParts:
        ElicitationDialogUrlParts(beforeDomain: beforeDomain, domain: domain, afterDomain: afterDomain)

class ElicitationDialogRenderModel:
    title: text
    subtitle: text
    rows: [text]
    footer: text
    action: text

impl ElicitationDialogRenderModel:
    static fn new(title: text, subtitle: text, rows: [text], footer: text, action: text) -> ElicitationDialogRenderModel:
        ElicitationDialogRenderModel(title: title, subtitle: subtitle, rows: rows, footer: footer, action: action)

fn elicitationDialogIsTextField(schema: ElicitationDialogSchema) -> bool:
    schema.schemaType == "string" or schema.schemaType == "number" or schema.schemaType == "integer"

fn elicitationDialogIsEnumSchema(schema: ElicitationDialogSchema) -> bool:
    schema.enumValues.len() > 0 and schema.schemaType != "array"

fn elicitationDialogIsMultiSelectEnumSchema(schema: ElicitationDialogSchema) -> bool:
    schema.schemaType == "array" and schema.enumValues.len() > 0

fn elicitationDialogIsDateTimeSchema(schema: ElicitationDialogSchema) -> bool:
    schema.format == "date" or schema.format == "date-time"

fn elicitationDialogAdvanceSpinnerFrame(frame: i64) -> i64:
    (frame + 1) % 10

fn elicitationDialogPlural(count: i64, word: text) -> text:
    if count == 1:
        return word
    word + "s"

fn elicitationDialogCleanLabel(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        return "not set"
    trimmed

fn elicitationDialogEnumLabel(schema: ElicitationDialogSchema, value: text) -> text:
    var i = 0
    while i < schema.enumValues.len():
        if schema.enumValues[i] == value:
            if i < schema.enumLabels.len() and schema.enumLabels[i] != "":
                return schema.enumLabels[i]
            return value
        i = i + 1
    value

fn elicitationDialogContainsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn elicitationDialogAddUniqueText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    if not elicitationDialogContainsText(out, value):
        out.push(value)
    out

fn elicitationDialogRemoveText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if values[i] != value:
            out.push(values[i])
        i = i + 1
    out

fn elicitationDialogToggleMultiValue(values: [text], value: text) -> [text]:
    if elicitationDialogContainsText(values, value):
        return elicitationDialogRemoveText(values, value)
    elicitationDialogAddUniqueText(values, value)

fn elicitationDialogJoinedLabels(schema: ElicitationDialogSchema, values: [text]) -> text:
    if values.len() == 0:
        return "not set"
    var labels: [text] = []
    var i = 0
    while i < values.len():
        labels.push(elicitationDialogEnumLabel(schema, values[i]))
        i = i + 1
    labels.join(", ")

fn elicitationDialogLooksInteger(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    var i = 0
    if trimmed.slice(0, 1) == "-":
        i = 1
    if i >= trimmed.len():
        return false
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if not "0123456789".contains(ch):
            return false
        i = i + 1
    true

fn elicitationDialogLooksNumber(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    var dotCount = 0
    var digitCount = 0
    var i = 0
    if trimmed.slice(0, 1) == "-":
        i = 1
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if ch == ".":
            dotCount = dotCount + 1
            if dotCount > 1:
                return false
        elif "0123456789".contains(ch):
            digitCount = digitCount + 1
        else:
            return false
        i = i + 1
    digitCount > 0

fn elicitationDialogLooksIsoDate(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed.len() < 10:
        return false
    trimmed.slice(4, 5) == "-" and trimmed.slice(7, 8) == "-"

fn elicitationDialogValidateInput(value: text, schema: ElicitationDialogSchema) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        if schema.required:
            return "This field is required"
        return ""
    if schema.schemaType == "integer" and not elicitationDialogLooksInteger(trimmed):
        return "Enter a whole number"
    if schema.schemaType == "number" and not elicitationDialogLooksNumber(trimmed):
        return "Enter a number"
    if elicitationDialogIsDateTimeSchema(schema) and not elicitationDialogLooksIsoDate(trimmed):
        return "Enter a valid date"
    if elicitationDialogIsEnumSchema(schema) and not elicitationDialogContainsText(schema.enumValues, trimmed):
        return "Choose one of the listed options"
    ""

fn elicitationDialogValidateMultiSelect(values: [text], schema: ElicitationDialogSchema) -> text:
    if not elicitationDialogIsMultiSelectEnumSchema(schema):
        return ""
    if schema.required and values.len() == 0:
        return "This field is required"
    if schema.minItems > 0 and values.len() < schema.minItems and (schema.required or values.len() > 0):
        return "Select at least " + schema.minItems.to_text() + " " + elicitationDialogPlural(schema.minItems, "item")
    if schema.maxItems > 0 and values.len() > schema.maxItems:
        return "Select at most " + schema.maxItems.to_text() + " " + elicitationDialogPlural(schema.maxItems, "item")
    var i = 0
    while i < values.len():
        if not elicitationDialogContainsText(schema.enumValues, values[i]):
            return "Choose only listed options"
        i = i + 1
    ""

fn elicitationDialogFieldHasValue(field: ElicitationDialogField) -> bool:
    if elicitationDialogIsMultiSelectEnumSchema(field.schema):
        return field.values.len() > 0
    field.value != ""

fn elicitationDialogFieldError(field: ElicitationDialogField) -> text:
    if field.error != "":
        return field.error
    if elicitationDialogIsMultiSelectEnumSchema(field.schema):
        return elicitationDialogValidateMultiSelect(field.values, field.schema)
    elicitationDialogValidateInput(field.value, field.schema)

fn elicitationDialogRequiredFieldsValid(fields: [ElicitationDialogField]) -> bool:
    var i = 0
    while i < fields.len():
        val field = fields[i]
        if field.schema.required and not elicitationDialogFieldHasValue(field):
            return false
        if elicitationDialogFieldError(field) != "":
            return false
        i = i + 1
    true

fn elicitationDialogFirstInvalidField(fields: [ElicitationDialogField]) -> i64:
    var i = 0
    while i < fields.len():
        val field = fields[i]
        if field.schema.required and not elicitationDialogFieldHasValue(field):
            return i
        if elicitationDialogFieldError(field) != "":
            return i
        i = i + 1
    -1

fn elicitationDialogClampFieldIndex(index: i64, fields: [ElicitationDialogField]) -> i64:
    if fields.len() == 0:
        return -1
    if index < 0:
        return 0
    if index >= fields.len():
        return fields.len() - 1
    index

fn elicitationDialogNavigateIndex(currentIndex: i64, focusedButton: text, fieldCount: i64, direction: text) -> i64:
    val itemCount = fieldCount + 2
    var index = currentIndex
    if currentIndex < 0:
        index = if focusedButton == "decline": fieldCount + 1 else: fieldCount
    val delta = if direction == "up": itemCount - 1 else: 1
    (index + delta) % itemCount

fn elicitationDialogButtonForIndex(index: i64, fieldCount: i64) -> text:
    if index == fieldCount:
        return "accept"
    if index == fieldCount + 1:
        return "decline"
    ""

fn elicitationDialogRunTypeahead(buffer: text, input: text, labels: [text]) -> i64:
    val next = (buffer + input).lower()
    var i = 0
    while i < labels.len():
        if labels[i].lower().starts_with(next):
            return i
        i = i + 1
    -1

fn elicitationDialogFormatDateDisplay(value: text, schema: ElicitationDialogSchema) -> text:
    if value == "":
        return "not set"
    if not elicitationDialogIsDateTimeSchema(schema):
        return value
    if schema.format == "date-time":
        return value.replace("T", " ").replace("Z", " UTC")
    value

fn elicitationDialogFieldTitle(field: ElicitationDialogField) -> text:
    if field.schema.title != "":
        return field.schema.title
    field.name

fn elicitationDialogFieldStatusGlyph(field: ElicitationDialogField, active: bool) -> text:
    if field.resolving:
        return "spinner"
    if elicitationDialogFieldError(field) != "":
        return "warning"
    if elicitationDialogFieldHasValue(field):
        return "checked"
    if field.schema.required:
        return "required"
    if active:
        return "active"
    "empty"

fn elicitationDialogRenderChoice(field: ElicitationDialogField, active: bool, expanded: bool, optionIndex: i64) -> [text]:
    var rows: [text] = []
    val pointer = if active: "> " else: "  "
    val status = elicitationDialogFieldStatusGlyph(field, active)
    val title = elicitationDialogFieldTitle(field)
    if elicitationDialogIsMultiSelectEnumSchema(field.schema):
        val value = elicitationDialogJoinedLabels(field.schema, field.values)
        rows.push(pointer + status + " " + title + ": " + value)
        if expanded:
            var i = 0
            while i < field.schema.enumValues.len():
                val option = field.schema.enumValues[i]
                val mark = if elicitationDialogContainsText(field.values, option): "[x]" else: "[ ]"
                val optionPointer = if i == optionIndex: "> " else: "  "
                rows.push("    " + optionPointer + mark + " " + elicitationDialogEnumLabel(field.schema, option))
                i = i + 1
        return rows
    if elicitationDialogIsEnumSchema(field.schema):
        val value = if field.value == "": "not set" else: elicitationDialogEnumLabel(field.schema, field.value)
        rows.push(pointer + status + " " + title + ": " + value)
        if expanded:
            var i = 0
            while i < field.schema.enumValues.len():
                val option = field.schema.enumValues[i]
                val mark = if field.value == option: "(*)" else: "( )"
                val optionPointer = if i == optionIndex: "> " else: "  "
                rows.push("    " + optionPointer + mark + " " + elicitationDialogEnumLabel(field.schema, option))
                i = i + 1
        return rows
    if field.schema.schemaType == "boolean":
        val value = if field.value == "true": "[x]" else: if field.value == "false": "[ ]" else: "not set"
        rows.push(pointer + status + " " + title + ": " + value)
        return rows
    if elicitationDialogIsTextField(field.schema):
        val value = elicitationDialogFormatDateDisplay(field.value, field.schema)
        rows.push(pointer + status + " " + title + ": " + value)
        return rows
    rows.push(pointer + status + " " + title + ": " + elicitationDialogCleanLabel(field.value))
    rows

fn elicitationDialogRenderFormFields(state: ElicitationDialogFormState) -> [text]:
    var rows: [text] = []
    var i = 0
    while i < state.fields.len():
        val field = state.fields[i]
        val active = i == state.currentFieldIndex and state.focusedButton == ""
        val expanded = active and state.expandedAccordion == field.name
        val choiceRows = elicitationDialogRenderChoice(field, active, expanded, state.accordionOptionIndex)
        var j = 0
        while j < choiceRows.len():
            rows.push(choiceRows[j])
            j = j + 1
        if field.schema.description != "":
            rows.push("      " + field.schema.description)
        val error = elicitationDialogFieldError(field)
        if error != "":
            rows.push("      " + error)
        i = i + 1
    rows

fn elicitationDialogRenderButtons(focusedButton: text, acceptLabel: text, declineLabel: text) -> text:
    val acceptPointer = if focusedButton == "accept": ">" else: " "
    val declinePointer = if focusedButton == "decline": ">" else: " "
    acceptPointer + " " + acceptLabel + "  " + declinePointer + " " + declineLabel

fn ElicitationFormDialog(state: ElicitationDialogFormState) -> ElicitationDialogRenderModel:
    var rows = elicitationDialogRenderFormFields(state)
    rows.push(elicitationDialogRenderButtons(state.focusedButton, "Accept", "Decline"))
    val action = if elicitationDialogRequiredFieldsValid(state.fields): "accept-ready" else: "validation-needed"
    ElicitationDialogRenderModel.new("MCP server \"" + state.serverName + "\" requests your input", state.message, rows, "Esc cancel | Up/Down navigate | Backspace unset", action)

fn elicitationDialogParseUrl(url: text) -> ElicitationDialogUrlParts:
    val schemeEnd = url.find("://")
    if schemeEnd < 0:
        return ElicitationDialogUrlParts.new("", url, "")
    val hostStart = schemeEnd + 3
    var hostEnd = hostStart
    while hostEnd < url.len() and url.slice(hostEnd, hostEnd + 1) != "/" and url.slice(hostEnd, hostEnd + 1) != "?" and url.slice(hostEnd, hostEnd + 1) != "#":
        hostEnd = hostEnd + 1
    ElicitationDialogUrlParts.new(url.slice(0, hostStart), url.slice(hostStart, hostEnd), url.slice(hostEnd, url.len()))

fn elicitationDialogWaitingButtons(showCancel: bool) -> [text]:
    if showCancel:
        return ["open", "action", "cancel"]
    ["open", "action"]

fn elicitationDialogCycleWaitingButton(current: text, showCancel: bool, direction: text) -> text:
    val buttons = elicitationDialogWaitingButtons(showCancel)
    var idx = 0
    var i = 0
    while i < buttons.len():
        if buttons[i] == current:
            idx = i
        i = i + 1
    val delta = if direction == "right": 1 else: buttons.len() - 1
    buttons[(idx + delta) % buttons.len()]

fn elicitationDialogUrlAction(state: ElicitationDialogUrlState) -> text:
    if state.phase == "waiting" and state.completed:
        if state.showCancel:
            return "retry"
        return "dismiss"
    if state.phase == "prompt" and state.focusedButton == "accept":
        return "open-url"
    if state.phase == "prompt" and state.focusedButton == "decline":
        return "decline"
    if state.phase == "waiting" and state.focusedButton == "open":
        return "reopen-url"
    if state.phase == "waiting" and state.focusedButton == "cancel":
        return "cancel"
    if state.phase == "waiting":
        return if state.showCancel: "retry" else: "dismiss"
    "cancel"

fn ElicitationURLDialog(state: ElicitationDialogUrlState) -> ElicitationDialogRenderModel:
    val parts = elicitationDialogParseUrl(state.url)
    var rows: [text] = [parts.beforeDomain + "[" + parts.domain + "]" + parts.afterDomain]
    if state.phase == "waiting":
        rows.push("Waiting for the server to confirm completion...")
        rows.push(elicitationDialogUrlWaitingButtonsRow(state))
        return ElicitationDialogRenderModel.new("MCP server \"" + state.serverName + "\" - waiting for completion", state.message, rows, "Esc cancel | Left/Right switch", elicitationDialogUrlAction(state))
    rows.push(elicitationDialogRenderButtons(state.focusedButton, "Accept", "Decline"))
    ElicitationDialogRenderModel.new("MCP server \"" + state.serverName + "\" wants to open a URL", state.message, rows, "Esc cancel | Left/Right switch", elicitationDialogUrlAction(state))

fn elicitationDialogUrlWaitingButtonsRow(state: ElicitationDialogUrlState) -> text:
    val openPointer = if state.focusedButton == "open": ">" else: " "
    val actionPointer = if state.focusedButton == "action": ">" else: " "
    var row = openPointer + " Reopen URL  " + actionPointer + " " + state.actionLabel
    if state.showCancel:
        val cancelPointer = if state.focusedButton == "cancel": ">" else: " "
        row = row + "  " + cancelPointer + " Cancel"
    row

fn ElicitationDialog(mode: text, formState: ElicitationDialogFormState, urlState: ElicitationDialogUrlState) -> ElicitationDialogRenderModel:
    if mode == "url":
        return ElicitationURLDialog(urlState)
    ElicitationFormDialog(formState)

fn elicitationDialogSourceLinesModeled() -> i64:
    ELICITATION_DIALOG_SOURCE_LINES
