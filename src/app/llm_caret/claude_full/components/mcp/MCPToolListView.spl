"""
Claude full MCP tool list view parity.
"""

class MCPToolListItem:
    name: text
    display_name: text
    read_only: bool
    destructive: bool
    open_world: bool

impl MCPToolListItem:
    static fn new(name: text, displayName: text, readOnly: bool, destructive: bool, openWorld: bool) -> MCPToolListItem:
        MCPToolListItem(name: name.trim(), display_name: mcpToolListDisplayName(displayName, name), read_only: readOnly, destructive: destructive, open_world: openWorld)

fn mcpToolListDisplayName(displayName: text, fallback: text) -> text:
    val clean = displayName.trim()
    if clean == "":
        return fallback.trim()
    clean

fn mcpToolListAnnotations(tool: MCPToolListItem) -> [text]:
    var annotations: [text] = []
    if tool.read_only:
        annotations.push("read-only")
    if tool.destructive:
        annotations.push("destructive")
    if tool.open_world:
        annotations.push("open-world")
    annotations

fn mcpToolListDescription(tool: MCPToolListItem) -> text:
    val annotations = mcpToolListAnnotations(tool)
    var out = ""
    var i = 0
    while i < annotations.len():
        if i > 0:
            out = out + ", "
        out = out + annotations[i]
        i = i + 1
    out

fn mcpToolListDescriptionColor(tool: MCPToolListItem) -> text:
    if tool.destructive:
        return "error"
    if tool.read_only:
        return "success"
    "default"

fn mcpToolListSubtitle(tools: [MCPToolListItem]) -> text:
    if tools.len() == 1:
        return "1 tool"
    tools.len().to_text() + " tools"

fn mcpToolListSummary(serverName: text, tools: [MCPToolListItem]) -> text:
    if tools.len() == 0:
        return "Tools for " + serverName + ": No tools available"
    "Tools for " + serverName + ": " + mcpToolListSubtitle(tools)

fn mcpToolListViewSourceLinesModeled() -> i64:
    140
