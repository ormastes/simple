"""
Claude full MCP tool detail view parity.
"""

class MCPToolParameter:
    name: text
    kind: text
    description: text
    required: bool

impl MCPToolParameter:
    static fn new(name: text, kind: text, description: text, required: bool) -> MCPToolParameter:
        MCPToolParameter(name: name.trim(), kind: mcpToolParameterKind(kind), description: description.trim(), required: required)

class MCPToolDetailState:
    server_name: text
    tool_name: text
    display_name: text
    description: text
    read_only: bool
    destructive: bool
    open_world: bool
    parameters: [MCPToolParameter]

impl MCPToolDetailState:
    static fn new(serverName: text, toolName: text, displayName: text, description: text, readOnly: bool, destructive: bool, openWorld: bool, parameters: [MCPToolParameter]) -> MCPToolDetailState:
        MCPToolDetailState(server_name: serverName.trim(), tool_name: toolName.trim(), display_name: mcpToolDetailDisplayName(displayName, toolName), description: description.trim(), read_only: readOnly, destructive: destructive, open_world: openWorld, parameters: parameters)

fn mcpToolParameterKind(kind: text) -> text:
    val clean = kind.trim()
    if clean == "":
        return "unknown"
    clean

fn mcpToolDetailDisplayName(displayName: text, fallback: text) -> text:
    val clean = displayName.trim()
    if clean == "":
        return fallback.trim()
    clean

fn mcpToolDetailBadges(state: MCPToolDetailState) -> [text]:
    var badges: [text] = []
    if state.read_only:
        badges.push("read-only")
    if state.destructive:
        badges.push("destructive")
    if state.open_world:
        badges.push("open-world")
    badges

fn mcpToolDetailTitle(state: MCPToolDetailState) -> text:
    var out = state.display_name
    val badges = mcpToolDetailBadges(state)
    var i = 0
    while i < badges.len():
        out = out + " [" + badges[i] + "]"
        i = i + 1
    out

fn mcpToolParameterLine(parameter: MCPToolParameter) -> text:
    var out = parameter.name
    if parameter.required:
        out = out + " (required)"
    out + ": " + parameter.kind

fn mcpToolDetailSummary(state: MCPToolDetailState) -> text:
    mcpToolDetailTitle(state) + " params=" + state.parameters.len().to_text()

fn mcpToolDetailViewSourceLinesModeled() -> i64:
    211
