"""
Claude full MCP reconnect helper parity model.
"""

const MCP_RECONNECT_HELPERS_SOURCE_LINES = 48

class ReconnectResult:
    message: text
    success: bool

impl ReconnectResult:
    static fn new(message: text, success: bool) -> ReconnectResult:
        ReconnectResult(message: message, success: success)

class ReconnectClient:
    typeName: text

impl ReconnectClient:
    static fn new(typeName: text) -> ReconnectClient:
        ReconnectClient(typeName: typeName)

class ReconnectAttemptResult:
    client: ReconnectClient
    toolsCount: i64
    commandsCount: i64
    resourcesCount: i64

impl ReconnectAttemptResult:
    static fn new(clientType: text, toolsCount: i64, commandsCount: i64, resourcesCount: i64) -> ReconnectAttemptResult:
        ReconnectAttemptResult(client: ReconnectClient.new(clientType), toolsCount: toolsCount, commandsCount: commandsCount, resourcesCount: resourcesCount)

fn handleReconnectResult(result: ReconnectAttemptResult, serverName: text) -> ReconnectResult:
    if result.client.typeName == "connected":
        return ReconnectResult.new("Reconnected to " + serverName + ".", true)
    if result.client.typeName == "needs-auth":
        return ReconnectResult.new(serverName + " requires authentication. Use the 'Authenticate' option.", false)
    if result.client.typeName == "failed":
        return ReconnectResult.new("Failed to reconnect to " + serverName + ".", false)
    ReconnectResult.new("Unknown result when reconnecting to " + serverName + ".", false)

fn handleReconnectError(errorMessage: text, serverName: text) -> text:
    "Error reconnecting to " + serverName + ": " + errorMessage

fn reconnectResultHasPayload(result: ReconnectAttemptResult) -> bool:
    result.toolsCount > 0 or result.commandsCount > 0 or result.resourcesCount > 0

fn reconnectHelpersSourceLinesModeled() -> i64:
    MCP_RECONNECT_HELPERS_SOURCE_LINES
