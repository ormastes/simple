"""
Claude full MCP capabilities section parity.
"""

class CapabilitiesCounts:
    server_tools_count: i64
    server_prompts_count: i64
    server_resources_count: i64

impl CapabilitiesCounts:
    static fn new(serverToolsCount: i64, serverPromptsCount: i64, serverResourcesCount: i64) -> CapabilitiesCounts:
        CapabilitiesCounts(server_tools_count: clampCapabilityCount(serverToolsCount), server_prompts_count: clampCapabilityCount(serverPromptsCount), server_resources_count: clampCapabilityCount(serverResourcesCount))

fn clampCapabilityCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn capabilitiesList(counts: CapabilitiesCounts) -> [text]:
    var capabilities: [text] = []
    if counts.server_tools_count > 0:
        capabilities.push("tools")
    if counts.server_resources_count > 0:
        capabilities.push("resources")
    if counts.server_prompts_count > 0:
        capabilities.push("prompts")
    capabilities

fn capabilitiesSummary(counts: CapabilitiesCounts) -> text:
    val capabilities = capabilitiesList(counts)
    if capabilities.len() == 0:
        return "Capabilities: none"
    var out = "Capabilities: "
    var i = 0
    while i < capabilities.len():
        if i > 0:
            out = out + ", "
        out = out + capabilities[i]
        i = i + 1
    out

fn capabilitiesSectionSourceLinesModeled() -> i64:
    60
