"""
Claude full MCP reconnect parity.
"""

class MCPReconnectState:
    server_name: text
    client_type: text
    error: text
    reconnecting: bool

impl MCPReconnectState:
    static fn new(serverName: text, clientType: text, error: text, reconnecting: bool) -> MCPReconnectState:
        MCPReconnectState(server_name: serverName.trim(), client_type: normalizeMcpReconnectClientType(clientType), error: error.trim(), reconnecting: reconnecting)

fn normalizeMcpReconnectClientType(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "connected" or clean == "needs-auth" or clean == "pending" or clean == "failed" or clean == "disabled" or clean == "missing":
        return clean
    "failed"

fn mcpReconnectCompletionMessage(state: MCPReconnectState) -> text:
    if state.client_type == "connected":
        return "Successfully reconnected to " + state.server_name
    if state.client_type == "needs-auth":
        return state.server_name + " requires authentication. Use /mcp to authenticate."
    if state.client_type == "missing":
        return "MCP server \"" + state.server_name + "\" not found"
    if state.error != "":
        return "Error: " + state.error
    "Failed to reconnect to " + state.server_name

fn mcpReconnectVisibleState(state: MCPReconnectState) -> text:
    if state.reconnecting:
        return "reconnecting"
    if state.error != "":
        return "error"
    if state.client_type == "connected":
        return "complete"
    "error"

fn mcpReconnectSummary(state: MCPReconnectState) -> text:
    mcpReconnectVisibleState(state) + " " + mcpReconnectCompletionMessage(state)

fn mcpReconnectSourceLinesModeled() -> i64:
    166
