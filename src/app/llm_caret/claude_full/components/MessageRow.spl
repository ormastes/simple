"""
Claude full message row parity model.
"""

const MESSAGE_ROW_SOURCE_LINES = 382

class MessageRowMessage:
    type_name: text
    id: text
    display_type: text
    tool_use_id: text
    collapsible: bool
    thinking_only: bool

impl MessageRowMessage:
    static fn new(typeName: text, id: text, displayType: text, toolUseId: text, collapsible: bool, thinkingOnly: bool) -> MessageRowMessage:
        MessageRowMessage(type_name: typeName, id: id, display_type: displayType, tool_use_id: toolUseId, collapsible: collapsible, thinking_only: thinkingOnly)

class MessageRowRender:
    display_type: text
    active_collapsed_group: bool
    static_render: bool
    should_animate: bool
    transcript_mode: bool
    model_column_visible: bool
    progress_count: i64

impl MessageRowRender:
    static fn new(displayType: text, activeCollapsedGroup: bool, staticRender: bool, shouldAnimate: bool, transcriptMode: bool, modelColumnVisible: bool, progressCount: i64) -> MessageRowRender:
        MessageRowRender(display_type: displayType, active_collapsed_group: activeCollapsedGroup, static_render: staticRender, should_animate: shouldAnimate, transcript_mode: transcriptMode, model_column_visible: modelColumnVisible, progress_count: progressCount)

fn messageRowContains(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn messageRowDisplayType(msg: MessageRowMessage) -> text:
    if msg.type_name == "grouped_tool_use":
        return msg.display_type
    if msg.type_name == "collapsed_read_search":
        return "collapsed_read_search"
    msg.type_name

fn messageRowHasContentAfterIndex(messages: [MessageRowMessage], index: i64, streamingToolUseIds: [text]) -> bool:
    var i = index + 1
    while i < messages.len():
        val msg = messages[i]
        if msg.thinking_only:
            i = i + 1
            continue
        if msg.type_name == "assistant" and msg.collapsible:
            if messageRowContains(streamingToolUseIds, msg.tool_use_id):
                i = i + 1
                continue
        if msg.type_name == "system" or msg.type_name == "attachment":
            i = i + 1
            continue
        if msg.type_name == "user" and msg.display_type == "tool_result":
            i = i + 1
            continue
        if msg.type_name == "grouped_tool_use" and msg.collapsible:
            i = i + 1
            continue
        return true
    false

fn messageRowActiveCollapsedGroup(msg: MessageRowMessage, inProgressToolUseIds: [text], isLoading: bool, hasContentAfter: bool) -> bool:
    if msg.type_name != "collapsed_read_search":
        return false
    if messageRowContains(inProgressToolUseIds, msg.tool_use_id):
        return true
    if isLoading:
        if not hasContentAfter:
            return true
    false

fn messageRowShouldAnimate(msg: MessageRowMessage, canAnimate: bool, inProgressToolUseIds: [text]) -> bool:
    if not canAnimate:
        return false
    if msg.type_name == "grouped_tool_use" or msg.type_name == "collapsed_read_search":
        return messageRowContains(inProgressToolUseIds, msg.tool_use_id)
    if msg.tool_use_id == "":
        return true
    messageRowContains(inProgressToolUseIds, msg.tool_use_id)

fn messageRowShouldRenderStatic(msg: MessageRowMessage, streamingToolUseIds: [text], inProgressToolUseIds: [text], screen: text) -> bool:
    if screen == "transcript":
        return true
    if msg.tool_use_id == "":
        return true
    if messageRowContains(streamingToolUseIds, msg.tool_use_id):
        return false
    if messageRowContains(inProgressToolUseIds, msg.tool_use_id):
        return false
    true

fn messageRowProgressCount(msg: MessageRowMessage, grouped: bool, collapsed: bool, lookupCount: i64) -> i64:
    if grouped or collapsed:
        return 0
    if msg.type_name == "":
        return 0
    lookupCount

fn messageRowRender(msg: MessageRowMessage, hasContentAfter: bool, screen: text, canAnimate: bool, isLoading: bool, inProgressToolUseIds: [text], streamingToolUseIds: [text], lookupProgressCount: i64, hasModel: bool) -> MessageRowRender:
    val grouped = msg.type_name == "grouped_tool_use"
    val collapsed = msg.type_name == "collapsed_read_search"
    val transcript = screen == "transcript"
    MessageRowRender.new(
        messageRowDisplayType(msg),
        messageRowActiveCollapsedGroup(msg, inProgressToolUseIds, isLoading, hasContentAfter),
        messageRowShouldRenderStatic(msg, streamingToolUseIds, inProgressToolUseIds, screen),
        messageRowShouldAnimate(msg, canAnimate, inProgressToolUseIds),
        transcript,
        transcript and hasModel,
        messageRowProgressCount(msg, grouped, collapsed, lookupProgressCount),
    )

fn messageRowSourceLinesModeled() -> i64:
    MESSAGE_ROW_SOURCE_LINES
