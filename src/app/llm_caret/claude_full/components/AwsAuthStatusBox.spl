fn awsAuthStatusLabel(authenticated: bool) -> text:
    if authenticated:
        return "AWS authenticated"
    "AWS not authenticated"

fn awsAuthStatusCanRetry(authenticated: bool) -> bool:
    not authenticated

fn awsAuthStatusBoxSourceLinesModeled() -> i64:
    81
