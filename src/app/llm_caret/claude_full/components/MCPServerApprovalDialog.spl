"""
Claude full MCP server approval dialog parity.
"""

class MCPServerApprovalSettings:
    enabled_servers: [text]
    disabled_servers: [text]
    enable_all_project_servers: bool

impl MCPServerApprovalSettings:
    static fn new(enabledServers: [text], disabledServers: [text], enableAllProjectServers: bool) -> MCPServerApprovalSettings:
        MCPServerApprovalSettings(enabled_servers: enabledServers, disabled_servers: disabledServers, enable_all_project_servers: enableAllProjectServers)

fn normalizeMcpApprovalChoice(choice: text) -> text:
    val clean = choice.trim().lower()
    if clean == "yes" or clean == "yes_all" or clean == "no":
        return clean
    "no"

fn mcpApprovalOptions() -> [text]:
    [
        "yes_all:Use this and all future MCP servers in this project",
        "yes:Use this MCP server",
        "no:Continue without using this MCP server",
    ]

fn mcpApprovalContains(items: [text], value: text) -> bool:
    var i = 0
    while i < items.len():
        if items[i] == value:
            return true
        i = i + 1
    false

fn mcpApprovalApply(serverName: text, choice: text, settings: MCPServerApprovalSettings) -> MCPServerApprovalSettings:
    val clean = normalizeMcpApprovalChoice(choice)
    var enabled = settings.enabled_servers
    var disabled = settings.disabled_servers
    var enableAll = settings.enable_all_project_servers
    if clean == "yes" or clean == "yes_all":
        if not mcpApprovalContains(enabled, serverName):
            enabled.push(serverName)
        if clean == "yes_all":
            enableAll = true
    else:
        if not mcpApprovalContains(disabled, serverName):
            disabled.push(serverName)
    MCPServerApprovalSettings.new(enabled, disabled, enableAll)

fn mcpApprovalAnalyticsChoice(choice: text) -> text:
    normalizeMcpApprovalChoice(choice)

fn mcpApprovalTitle(serverName: text) -> text:
    "New MCP server found in .mcp.json: " + serverName.trim()

fn mcpApprovalSummary(serverName: text, choice: text, settings: MCPServerApprovalSettings) -> text:
    val updated = mcpApprovalApply(serverName, choice, settings)
    "enabled=" + updated.enabled_servers.len().to_text() + " disabled=" + updated.disabled_servers.len().to_text() + " all=" + updated.enable_all_project_servers.to_text()

fn mcpServerApprovalDialogSourceLinesModeled() -> i64:
    114
