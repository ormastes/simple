"""
Claude full IdeOnboardingDialog parity.
"""

class IdeOnboardingState:
    open: bool
    step: i64
    ide_name: text
    completed: bool

impl IdeOnboardingState:
    static fn new(open: bool, step: i64, ideName: text, completed: bool) -> IdeOnboardingState:
        IdeOnboardingState(open: open, step: clampIdeOnboardingStep(step), ide_name: ideName.trim(), completed: completed)

fn clampIdeOnboardingStep(step: i64) -> i64:
    if step < 0:
        return 0
    if step > 3:
        return 3
    step

fn ideOnboardingTitle(state: IdeOnboardingState) -> text:
    if state.ide_name == "":
        return "Set up IDE"
    "Set up " + state.ide_name

fn ideOnboardingCanContinue(state: IdeOnboardingState) -> bool:
    state.open and not state.completed

fn ideOnboardingNext(state: IdeOnboardingState) -> IdeOnboardingState:
    if state.step >= 3:
        return IdeOnboardingState.new(false, 3, state.ide_name, true)
    IdeOnboardingState.new(state.open, state.step + 1, state.ide_name, state.completed)

fn ideOnboardingSummary(state: IdeOnboardingState) -> text:
    ideOnboardingTitle(state) + " step=" + state.step.to_text()

fn ideOnboardingDialogSourceLinesModeled() -> i64:
    166
