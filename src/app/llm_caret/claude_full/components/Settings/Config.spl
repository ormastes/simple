const SETTINGS_CONFIG_SOURCE_LINES = 1821

fn settingsInitialRenderRoute() -> text:
    "search box footer hints"

fn settingsFilterRoute(query: text, id: text, label: text, searchText: text) -> bool:
    val q = query.trim()
    if q == "":
        return true
    id.contains(q) || label.contains(q) || searchText.contains(q)

fn settingsNoMatchRoute(query: text, hasMatch: bool) -> text:
    if hasMatch:
        return "settings match"
    "No settings match \"" + query + "\""

fn settingsSearchNavigationRoute(key: text, selectedIndex: i64) -> text:
    if key == "up" && selectedIndex == 0:
        return "enter search mode"
    if key == "enter" || key == "down":
        return "exit search to list"
    "stay"

fn settingsSelectionRoute(index: i64, count: i64) -> i64:
    if index < 0:
        return 0
    if index >= count:
        return count - 1
    index

fn settingsRowRenderRoute(selected: bool) -> text:
    if selected:
        return "pointer highlight"
    "plain row"

fn settingsBooleanToggleRoute(value: bool) -> bool:
    !value

fn thinkingModeToggleRoute(initialValue: bool, nextValue: bool, midConversation: bool) -> text:
    if initialValue != nextValue && midConversation:
        return "thinking warning"
    "thinking toggled"

fn settingsSubmenuRoute(row: text) -> text:
    if row == "Theme" || row == "Model" || row == "Output style" || row == "Language":
        return "open submenu hide tabs"
    "no submenu"

fn settingsEscRoute(dirty: bool) -> text:
    if dirty:
        return "revert snapshots and close"
    "close clean"

fn settingsAutoUpdatesRoute(blocked: bool, downgrade: bool) -> text:
    if blocked:
        return "auto updates disabled text"
    if downgrade:
        return "auto updates downgrade flow"
    "auto updates cycle channel"

fn settingsSaveCloseRoute(changedCount: i64) -> text:
    if changedCount > 0:
        return "changed fields summary"
    "dismissed system message"

fn settingsConfigSourceLinesModeled() -> i64:
    SETTINGS_CONFIG_SOURCE_LINES
