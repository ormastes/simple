"""
Claude full MessageTimestamp parity model.
"""

const MESSAGE_TIMESTAMP_SOURCE_LINES = 62

class MessageTimestampBlock:
    type_name: text

impl MessageTimestampBlock:
    static fn new(typeName: text) -> MessageTimestampBlock:
        MessageTimestampBlock(type_name: typeName)

class MessageTimestampRender:
    visible: bool
    text: text
    min_width: i64
    dim: bool

impl MessageTimestampRender:
    static fn new(visible: bool, text: text, minWidth: i64, dim: bool) -> MessageTimestampRender:
        MessageTimestampRender(visible: visible, text: text, min_width: minWidth, dim: dim)

fn messageTimestampHasTextBlock(content: [MessageTimestampBlock]) -> bool:
    for block in content:
        if block.type_name == "text":
            return true
    false

fn messageTimestamp(isTranscriptMode: bool, timestamp: text, messageType: text, content: [MessageTimestampBlock], formattedTimestamp: text) -> MessageTimestampRender:
    val shouldShow = isTranscriptMode and timestamp != "" and messageType == "assistant" and messageTimestampHasTextBlock(content)
    if not shouldShow:
        MessageTimestampRender.new(false, "", 0, false)
    else:
        MessageTimestampRender.new(true, formattedTimestamp, formattedTimestamp.len(), true)

fn messageTimestampSourceLinesModeled() -> i64:
    MESSAGE_TIMESTAMP_SOURCE_LINES
