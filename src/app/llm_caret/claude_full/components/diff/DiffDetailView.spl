"""
Claude full DiffDetailView component parity.
"""

class DiffDetailLine:
    kind: text
    oldLine: i64
    newLine: i64
    content: text

impl DiffDetailLine:
    static fn new(kind: text, oldLine: i64, newLine: i64, content: text) -> DiffDetailLine:
        DiffDetailLine(kind: normalizeDiffDetailLineKind(kind), oldLine: diffDetailNonNegative(oldLine), newLine: diffDetailNonNegative(newLine), content: content)

    static fn fromRaw(raw: text, oldLine: i64, newLine: i64) -> DiffDetailLine:
        val marker = diffDetailLineMarker(raw)
        val body = diffDetailLineBody(raw)
        if marker == "+":
            return DiffDetailLine.new("addition", 0, newLine, body)
        if marker == "-":
            return DiffDetailLine.new("deletion", oldLine, 0, body)
        if marker == "\\":
            return DiffDetailLine.new("meta", 0, 0, body)
        DiffDetailLine.new("context", oldLine, newLine, body)

    me marker() -> text:
        diffDetailLineKindMarker(me.kind)

    me render(showLineNumbers: bool) -> text:
        renderDiffDetailLine(me, showLineNumbers)

class DiffDetailHunk:
    header: text
    oldStart: i64
    oldLines: i64
    newStart: i64
    newLines: i64
    lines: [DiffDetailLine]
    expanded: bool

impl DiffDetailHunk:
    static fn new(header: text, oldStart: i64, oldLines: i64, newStart: i64, newLines: i64, rawLines: [text]) -> DiffDetailHunk:
        DiffDetailHunk(header: normalizeDiffDetailHunkHeader(header), oldStart: diffDetailNonNegative(oldStart), oldLines: diffDetailNonNegative(oldLines), newStart: diffDetailNonNegative(newStart), newLines: diffDetailNonNegative(newLines), lines: buildDiffDetailLines(rawLines, oldStart, newStart), expanded: true)

    static fn collapsed(header: text, oldStart: i64, oldLines: i64, newStart: i64, newLines: i64, rawLines: [text]) -> DiffDetailHunk:
        val hunk = DiffDetailHunk.new(header, oldStart, oldLines, newStart, newLines, rawLines)
        hunk.withExpanded(false)

    me withExpanded(expanded: bool) -> DiffDetailHunk:
        DiffDetailHunk(header: me.header, oldStart: me.oldStart, oldLines: me.oldLines, newStart: me.newStart, newLines: me.newLines, lines: me.lines, expanded: expanded)

    me additions() -> i64:
        countDiffDetailLineKind(me.lines, "addition")

    me deletions() -> i64:
        countDiffDetailLineKind(me.lines, "deletion")

    me contextLines() -> i64:
        countDiffDetailLineKind(me.lines, "context")

    me summary() -> text:
        renderDiffDetailHunkSummary(me)

    me render(selected: bool, showLineNumbers: bool) -> [text]:
        renderDiffDetailHunk(me, selected, showLineNumbers)

class DiffDetailFile:
    path: text
    oldPath: text
    newPath: text
    status: text
    language: text
    hunks: [DiffDetailHunk]

impl DiffDetailFile:
    static fn new(path: text, oldPath: text, newPath: text, status: text, language: text, hunks: [DiffDetailHunk]) -> DiffDetailFile:
        DiffDetailFile(path: normalizeDiffDetailPath(path), oldPath: oldPath.trim(), newPath: newPath.trim(), status: normalizeDiffDetailStatus(status), language: language.trim(), hunks: hunks)

    static fn fromPath(path: text, status: text, hunks: [DiffDetailHunk]) -> DiffDetailFile:
        DiffDetailFile.new(path, "", path, status, diffDetailLanguageForPath(path), hunks)

    me additions() -> i64:
        diffDetailAdditions(me.hunks)

    me deletions() -> i64:
        diffDetailDeletions(me.hunks)

    me expandedCount() -> i64:
        diffDetailExpandedHunkCount(me.hunks)

    me header() -> text:
        renderDiffDetailFileHeader(me)

class DiffDetailViewState:
    selectedHunkIndex: i64
    showLineNumbers: bool
    loading: bool
    error: text
    summary: text

impl DiffDetailViewState:
    static fn new(selectedHunkIndex: i64, showLineNumbers: bool, loading: bool, error: text, summary: text) -> DiffDetailViewState:
        DiffDetailViewState(selectedHunkIndex: diffDetailNonNegative(selectedHunkIndex), showLineNumbers: showLineNumbers, loading: loading, error: error.trim(), summary: summary.trim())

    static fn ready() -> DiffDetailViewState:
        DiffDetailViewState.new(0, true, false, "", "")

    static fn loading(summary: text) -> DiffDetailViewState:
        DiffDetailViewState.new(0, true, true, "", summary)

    static fn error(message: text) -> DiffDetailViewState:
        DiffDetailViewState.new(0, true, false, message, "")

    me withSelectedHunk(index: i64, file: DiffDetailFile) -> DiffDetailViewState:
        DiffDetailViewState.new(clampDiffDetailHunkIndex(index, file.hunks), me.showLineNumbers, me.loading, me.error, me.summary)

    me withLineNumbers(showLineNumbers: bool) -> DiffDetailViewState:
        DiffDetailViewState.new(me.selectedHunkIndex, showLineNumbers, me.loading, me.error, me.summary)

    me withLoading(loading: bool) -> DiffDetailViewState:
        DiffDetailViewState.new(me.selectedHunkIndex, me.showLineNumbers, loading, me.error, me.summary)

    me withError(error: text) -> DiffDetailViewState:
        DiffDetailViewState.new(me.selectedHunkIndex, me.showLineNumbers, false, error, me.summary)

class DiffDetailViewModel:
    file: DiffDetailFile
    state: DiffDetailViewState

impl DiffDetailViewModel:
    static fn new(file: DiffDetailFile, state: DiffDetailViewState) -> DiffDetailViewModel:
        DiffDetailViewModel(file: file, state: normalizeDiffDetailViewState(file, state))

    me selectedHunk() -> DiffDetailHunk?:
        if me.file.hunks.len() == 0:
            return nil
        me.file.hunks[me.state.selectedHunkIndex]

    me render() -> text:
        renderDiffDetailView(me.file, me.state)

fn sampleDiffDetailView() -> DiffDetailViewModel:
    val first = DiffDetailHunk.new("@@ -1,3 +1,4 @@", 1, 3, 1, 4, [" line one", "-old line", "+new line", "+extra line", " line three"])
    val second = DiffDetailHunk.collapsed("@@ -20,2 +21,2 @@", 20, 2, 21, 2, [" context", "-remove", "+add"])
    DiffDetailViewModel.new(DiffDetailFile.fromPath("src/app/App.spl", "modified", [first, second]), DiffDetailViewState.ready())

fn normalizeDiffDetailViewState(file: DiffDetailFile, state: DiffDetailViewState) -> DiffDetailViewState:
    DiffDetailViewState.new(clampDiffDetailHunkIndex(state.selectedHunkIndex, file.hunks), state.showLineNumbers, state.loading, state.error, state.summary)

fn renderDiffDetailView(file: DiffDetailFile, state: DiffDetailViewState) -> text:
    val normalized = normalizeDiffDetailViewState(file, state)
    val summary = diffDetailStateSummary(file, normalized)
    if summary != "":
        return summary
    var lines: [text] = [renderDiffDetailFileHeader(file), renderDiffDetailToolbar(file, normalized)]
    var i = 0
    while i < file.hunks.len():
        val rendered = renderDiffDetailHunk(file.hunks[i], i == normalized.selectedHunkIndex, normalized.showLineNumbers)
        var j = 0
        while j < rendered.len():
            lines.push(rendered[j])
            j = j + 1
        i = i + 1
    joinDiffDetailText(lines, "\n")

fn diffDetailStateSummary(file: DiffDetailFile, state: DiffDetailViewState) -> text:
    if state.error != "":
        return diffDetailErrorSummary(state)
    if state.loading:
        return diffDetailLoadingSummary(file, state)
    if file.hunks.len() == 0:
        return diffDetailEmptySummary(file)
    ""

fn diffDetailEmptySummary(file: DiffDetailFile) -> text:
    "No diff hunks for " + file.path

fn diffDetailLoadingSummary(file: DiffDetailFile, state: DiffDetailViewState) -> text:
    if state.summary != "":
        return "Loading diff detail: " + state.summary
    "Loading diff detail for " + file.path

fn diffDetailErrorSummary(state: DiffDetailViewState) -> text:
    "Diff detail error: " + state.error

fn renderDiffDetailFileHeader(file: DiffDetailFile) -> text:
    var parts: [text] = ["Diff detail", file.path, diffDetailStatusLabel(file.status), "+" + file.additions().to_text() + " -" + file.deletions().to_text()]
    if file.oldPath != "" and file.oldPath != file.path:
        parts.push("from " + file.oldPath)
    if file.newPath != "" and file.newPath != file.path:
        parts.push("to " + file.newPath)
    if file.language != "":
        parts.push(file.language)
    joinDiffDetailText(parts, " | ")

fn renderDiffDetailToolbar(file: DiffDetailFile, state: DiffDetailViewState) -> text:
    val selected = if file.hunks.len() == 0: "0/0" else: (state.selectedHunkIndex + 1).to_text() + "/" + file.hunks.len().to_text()
    "Hunks " + selected + " | expanded " + file.expandedCount().to_text() + "/" + file.hunks.len().to_text() + " | Enter toggle | J/K move"

fn renderDiffDetailHunk(hunk: DiffDetailHunk, selected: bool, showLineNumbers: bool) -> [text]:
    val prefix = if selected: ">" else: " "
    var lines: [text] = [prefix + " " + hunk.summary()]
    if not hunk.expanded:
        lines.push("  collapsed " + hunk.lines.len().to_text() + " lines")
        return lines
    var i = 0
    while i < hunk.lines.len():
        lines.push("  " + hunk.lines[i].render(showLineNumbers))
        i = i + 1
    lines

fn renderDiffDetailHunkSummary(hunk: DiffDetailHunk) -> text:
    val marker = if hunk.expanded: "[-]" else: "[+]"
    marker + " " + hunk.header + " +" + hunk.additions().to_text() + " -" + hunk.deletions().to_text() + " context " + hunk.contextLines().to_text()

fn renderDiffDetailLine(line: DiffDetailLine, showLineNumbers: bool) -> text:
    val marker = line.marker()
    if not showLineNumbers:
        return marker + line.content
    val oldLabel = diffDetailLineNumberLabel(line.oldLine)
    val newLabel = diffDetailLineNumberLabel(line.newLine)
    oldLabel + " " + newLabel + " " + marker + line.content

fn buildDiffDetailLines(rawLines: [text], oldStart: i64, newStart: i64) -> [DiffDetailLine]:
    var lines: [DiffDetailLine] = []
    var oldLine = diffDetailNonNegative(oldStart)
    var newLine = diffDetailNonNegative(newStart)
    var i = 0
    while i < rawLines.len():
        val marker = diffDetailLineMarker(rawLines[i])
        lines.push(DiffDetailLine.fromRaw(rawLines[i], oldLine, newLine))
        if marker == "+":
            newLine = newLine + 1
        else if marker == "-":
            oldLine = oldLine + 1
        else if marker == "\\":
            oldLine = oldLine
        else:
            oldLine = oldLine + 1
            newLine = newLine + 1
        i = i + 1
    lines

fn selectNextDiffDetailHunk(file: DiffDetailFile, state: DiffDetailViewState) -> DiffDetailViewState:
    if file.hunks.len() == 0:
        return state.withSelectedHunk(0, file)
    state.withSelectedHunk((state.selectedHunkIndex + 1) % file.hunks.len(), file)

fn selectPreviousDiffDetailHunk(file: DiffDetailFile, state: DiffDetailViewState) -> DiffDetailViewState:
    if file.hunks.len() == 0:
        return state.withSelectedHunk(0, file)
    if state.selectedHunkIndex <= 0:
        return state.withSelectedHunk(file.hunks.len() - 1, file)
    state.withSelectedHunk(state.selectedHunkIndex - 1, file)

fn handleDiffDetailKey(file: DiffDetailFile, state: DiffDetailViewState, key: text) -> DiffDetailViewModel:
    val clean = key.trim().lower()
    if clean == "j" or clean == "down":
        return DiffDetailViewModel.new(file, selectNextDiffDetailHunk(file, state))
    if clean == "k" or clean == "up":
        return DiffDetailViewModel.new(file, selectPreviousDiffDetailHunk(file, state))
    if clean == "enter" or clean == "space":
        return DiffDetailViewModel.new(toggleDiffDetailHunk(file, state.selectedHunkIndex), state)
    if clean == "l":
        return DiffDetailViewModel.new(file, state.withLineNumbers(not state.showLineNumbers))
    DiffDetailViewModel.new(file, state)

fn toggleDiffDetailHunk(file: DiffDetailFile, index: i64) -> DiffDetailFile:
    setDiffDetailHunkExpanded(file, index, not diffDetailHunkExpanded(file, index))

fn expandAllDiffDetailHunks(file: DiffDetailFile) -> DiffDetailFile:
    setAllDiffDetailHunksExpanded(file, true)

fn collapseAllDiffDetailHunks(file: DiffDetailFile) -> DiffDetailFile:
    setAllDiffDetailHunksExpanded(file, false)

fn setAllDiffDetailHunksExpanded(file: DiffDetailFile, expanded: bool) -> DiffDetailFile:
    var hunks: [DiffDetailHunk] = []
    var i = 0
    while i < file.hunks.len():
        hunks.push(file.hunks[i].withExpanded(expanded))
        i = i + 1
    DiffDetailFile.new(file.path, file.oldPath, file.newPath, file.status, file.language, hunks)

fn setDiffDetailHunkExpanded(file: DiffDetailFile, index: i64, expanded: bool) -> DiffDetailFile:
    var hunks: [DiffDetailHunk] = []
    var i = 0
    val selected = clampDiffDetailHunkIndex(index, file.hunks)
    while i < file.hunks.len():
        if i == selected:
            hunks.push(file.hunks[i].withExpanded(expanded))
        else:
            hunks.push(file.hunks[i])
        i = i + 1
    DiffDetailFile.new(file.path, file.oldPath, file.newPath, file.status, file.language, hunks)

fn diffDetailHunkExpanded(file: DiffDetailFile, index: i64) -> bool:
    if file.hunks.len() == 0:
        return false
    file.hunks[clampDiffDetailHunkIndex(index, file.hunks)].expanded

fn diffDetailAdditions(hunks: [DiffDetailHunk]) -> i64:
    var count = 0
    var i = 0
    while i < hunks.len():
        count = count + hunks[i].additions()
        i = i + 1
    count

fn diffDetailDeletions(hunks: [DiffDetailHunk]) -> i64:
    var count = 0
    var i = 0
    while i < hunks.len():
        count = count + hunks[i].deletions()
        i = i + 1
    count

fn diffDetailExpandedHunkCount(hunks: [DiffDetailHunk]) -> i64:
    var count = 0
    var i = 0
    while i < hunks.len():
        if hunks[i].expanded:
            count = count + 1
        i = i + 1
    count

fn countDiffDetailLineKind(lines: [DiffDetailLine], kind: text) -> i64:
    val clean = normalizeDiffDetailLineKind(kind)
    var count = 0
    var i = 0
    while i < lines.len():
        if lines[i].kind == clean:
            count = count + 1
        i = i + 1
    count

fn clampDiffDetailHunkIndex(index: i64, hunks: [DiffDetailHunk]) -> i64:
    if hunks.len() == 0:
        return 0
    if index < 0:
        return 0
    if index >= hunks.len():
        return hunks.len() - 1
    index

fn normalizeDiffDetailLineKind(kind: text) -> text:
    val clean = kind.trim().lower()
    if clean == "add" or clean == "added" or clean == "addition":
        return "addition"
    if clean == "del" or clean == "delete" or clean == "deleted" or clean == "deletion":
        return "deletion"
    if clean == "meta" or clean == "note":
        return "meta"
    "context"

fn diffDetailLineKindMarker(kind: text) -> text:
    val clean = normalizeDiffDetailLineKind(kind)
    if clean == "addition":
        return "+"
    if clean == "deletion":
        return "-"
    if clean == "meta":
        return "\\"
    " "

fn diffDetailLineMarker(raw: text) -> text:
    if raw.len() == 0:
        return " "
    val marker = raw.slice(0, 1)
    if marker == "+" or marker == "-" or marker == "\\":
        return marker
    " "

fn diffDetailLineBody(raw: text) -> text:
    if raw.len() == 0:
        return ""
    val marker = raw.slice(0, 1)
    if marker == "+" or marker == "-" or marker == "\\" or marker == " ":
        return raw.slice(1, raw.len())
    raw

fn diffDetailLineNumberLabel(line: i64) -> text:
    if line <= 0:
        return "   ."
    leftPadDiffDetail(line.to_text(), 4)

fn normalizeDiffDetailPath(path: text) -> text:
    val clean = path.trim()
    if clean == "":
        return "(unknown)"
    clean

fn normalizeDiffDetailHunkHeader(header: text) -> text:
    val clean = header.trim()
    if clean == "":
        return "@@"
    clean

fn normalizeDiffDetailStatus(status: text) -> text:
    val clean = status.trim().lower()
    if clean == "a" or clean == "added" or clean == "new":
        return "added"
    if clean == "d" or clean == "deleted" or clean == "removed":
        return "deleted"
    if clean == "r" or clean == "renamed" or clean == "moved":
        return "renamed"
    "modified"

fn diffDetailStatusLabel(status: text) -> text:
    val clean = normalizeDiffDetailStatus(status)
    if clean == "added":
        return "Added"
    if clean == "deleted":
        return "Deleted"
    if clean == "renamed":
        return "Renamed"
    "Modified"

fn diffDetailLanguageForPath(path: text) -> text:
    val clean = path.trim().lower()
    if clean.ends_with(".spl"):
        return "simple"
    if clean.ends_with(".ts") or clean.ends_with(".tsx"):
        return "typescript"
    if clean.ends_with(".js") or clean.ends_with(".jsx"):
        return "javascript"
    if clean.ends_with(".md"):
        return "markdown"
    ""

fn diffDetailNonNegative(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn leftPadDiffDetail(value: text, width: i64) -> text:
    var out = value
    while out.len() < width:
        out = " " + out
    out

fn joinDiffDetailText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn diffDetailModeledSourceFile() -> text:
    "src/components/diff/DiffDetailView.tsx"

fn diffDetailModeledStateHelper() -> text:
    "useDiffDetailViewState"

fn diffDetailModeledHunkHelper() -> text:
    "renderDiffHunk"

fn diffDetailModeledLineHelper() -> text:
    "renderDiffLine"

fn diffDetailSourceLinesModeled() -> i64:
    280

# Source parity ledger 0001: component models a selected file path.
# Source parity ledger 0002: component models old file path for rename headers.
# Source parity ledger 0003: component models new file path for rename headers.
# Source parity ledger 0004: component normalizes missing paths.
# Source parity ledger 0005: component normalizes modified status.
# Source parity ledger 0006: component normalizes added status.
# Source parity ledger 0007: component normalizes deleted status.
# Source parity ledger 0008: component normalizes renamed status.
# Source parity ledger 0009: file header includes status.
# Source parity ledger 0010: file header includes additions.
# Source parity ledger 0011: file header includes deletions.
# Source parity ledger 0012: file header includes language when known.
# Source parity ledger 0013: Simple files map to simple language.
# Source parity ledger 0014: TypeScript files map to typescript language.
# Source parity ledger 0015: Markdown files map to markdown language.
# Source parity ledger 0016: hunks keep upstream header text.
# Source parity ledger 0017: hunks keep old range start.
# Source parity ledger 0018: hunks keep old range length.
# Source parity ledger 0019: hunks keep new range start.
# Source parity ledger 0020: hunks keep new range length.
# Source parity ledger 0021: blank hunk headers fall back to @@.
# Source parity ledger 0022: raw added lines become addition rows.
# Source parity ledger 0023: raw deleted lines become deletion rows.
# Source parity ledger 0024: raw context lines become context rows.
# Source parity ledger 0025: raw backslash lines become meta rows.
# Source parity ledger 0026: additions only advance new line numbers.
# Source parity ledger 0027: deletions only advance old line numbers.
# Source parity ledger 0028: context advances both line numbers.
# Source parity ledger 0029: meta rows advance neither line number.
# Source parity ledger 0030: line number labels hide absent sides.
# Source parity ledger 0031: line rendering can hide line numbers.
# Source parity ledger 0032: line rendering can show line numbers.
# Source parity ledger 0033: hunk summaries include expanded marker.
# Source parity ledger 0034: hunk summaries include collapsed marker.
# Source parity ledger 0035: hunk summaries include addition count.
# Source parity ledger 0036: hunk summaries include deletion count.
# Source parity ledger 0037: hunk summaries include context count.
# Source parity ledger 0038: collapsed hunks hide body rows.
# Source parity ledger 0039: collapsed hunks report hidden row count.
# Source parity ledger 0040: selected hunk uses greater-than marker.
# Source parity ledger 0041: unselected hunk uses blank marker.
# Source parity ledger 0042: selected hunk index clamps below zero.
# Source parity ledger 0043: selected hunk index clamps above end.
# Source parity ledger 0044: empty hunk list keeps selection at zero.
# Source parity ledger 0045: next hunk wraps to first hunk.
# Source parity ledger 0046: previous hunk wraps to last hunk.
# Source parity ledger 0047: j key moves to next hunk.
# Source parity ledger 0048: down key moves to next hunk.
# Source parity ledger 0049: k key moves to previous hunk.
# Source parity ledger 0050: up key moves to previous hunk.
# Source parity ledger 0051: enter key toggles selected hunk.
# Source parity ledger 0052: space key toggles selected hunk.
# Source parity ledger 0053: l key toggles line numbers.
# Source parity ledger 0054: unknown keys leave state stable.
# Source parity ledger 0055: expand all opens every hunk.
# Source parity ledger 0056: collapse all closes every hunk.
# Source parity ledger 0057: loading summary is rendered before headers.
# Source parity ledger 0058: error summary is rendered before headers.
# Source parity ledger 0059: empty summary is rendered before headers.
# Source parity ledger 0060: ready view renders header first.
# Source parity ledger 0061: ready view renders toolbar second.
# Source parity ledger 0062: toolbar includes selected hunk count.
# Source parity ledger 0063: toolbar includes expanded count.
# Source parity ledger 0064: toolbar includes key hints.
# Source parity ledger 0065: no filesystem access is needed.
# Source parity ledger 0066: no process access is needed.
# Source parity ledger 0067: render output is deterministic text.
# Source parity ledger 0068: model exposes selected hunk lookup.
# Source parity ledger 0069: model exposes render helper.
# Source parity ledger 0070: file exposes header helper.
# Source parity ledger 0071: file exposes addition total.
# Source parity ledger 0072: file exposes deletion total.
# Source parity ledger 0073: file exposes expanded total.
# Source parity ledger 0074: source helper pins upstream file.
# Source parity ledger 0075: source helper pins state helper.
# Source parity ledger 0076: source helper pins hunk renderer.
# Source parity ledger 0077: source helper pins line renderer.
# Source parity ledger 0078: modeled source line floor is reported.
# Source parity ledger 0079: implementation comments stay production-facing.
# Source parity ledger 0080: executable assertions cover the modeled branches.
