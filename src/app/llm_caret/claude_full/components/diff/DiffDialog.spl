"""
Claude full DiffDialog component parity.
"""

class DiffDialogFile:
    path: text
    additions: i64
    deletions: i64
    changed: bool
    accepted: bool
    rejected: bool

impl DiffDialogFile:
    static fn new(path: text, additions: i64, deletions: i64, changed: bool, accepted: bool, rejected: bool) -> DiffDialogFile:
        DiffDialogFile(path: path.trim(), additions: additions, deletions: deletions, changed: changed, accepted: accepted, rejected: rejected)

class DiffDialogState:
    open: bool
    loading: bool
    error: text
    title: text
    summary: text
    selectedPath: text
    viewMode: text
    fileCount: i64
    changedCount: i64
    acceptedCount: i64
    rejectedCount: i64
    additions: i64
    deletions: i64

impl DiffDialogState:
    static fn new(open: bool, loading: bool, error: text, title: text, summary: text, selectedPath: text, viewMode: text, fileCount: i64, changedCount: i64, acceptedCount: i64, rejectedCount: i64, additions: i64, deletions: i64) -> DiffDialogState:
        DiffDialogState(open: open, loading: loading, error: error.trim(), title: title.trim(), summary: summary.trim(), selectedPath: selectedPath.trim(), viewMode: viewMode.trim(), fileCount: fileCount, changedCount: changedCount, acceptedCount: acceptedCount, rejectedCount: rejectedCount, additions: additions, deletions: deletions)

class DiffDialogAction:
    kind: text
    closed: bool
    path: text
    viewMode: text
    summary: text

impl DiffDialogAction:
    static fn new(kind: text, closed: bool, path: text, viewMode: text, summary: text) -> DiffDialogAction:
        DiffDialogAction(kind: kind.trim(), closed: closed, path: path.trim(), viewMode: viewMode.trim(), summary: summary.trim())

fn diffDialogClosed() -> DiffDialogState:
    DiffDialogState.new(false, false, "", "", "", "", "split", 0, 0, 0, 0, 0, 0)

fn diffDialogOpen(title: text, fileCount: i64, changedCount: i64, additions: i64, deletions: i64) -> DiffDialogState:
    DiffDialogState.new(true, false, "", title, "", "", "split", fileCount, changedCount, 0, 0, additions, deletions)

fn diffDialogWithSelection(state: DiffDialogState, path: text) -> DiffDialogState:
    DiffDialogState.new(state.open, state.loading, state.error, state.title, state.summary, path, state.viewMode, state.fileCount, state.changedCount, state.acceptedCount, state.rejectedCount, state.additions, state.deletions)

fn diffDialogWithViewMode(state: DiffDialogState, viewMode: text) -> DiffDialogState:
    DiffDialogState.new(state.open, state.loading, state.error, state.title, state.summary, state.selectedPath, diffDialogNormalizeViewMode(viewMode), state.fileCount, state.changedCount, state.acceptedCount, state.rejectedCount, state.additions, state.deletions)

fn diffDialogWithLoading(state: DiffDialogState, loading: bool) -> DiffDialogState:
    DiffDialogState.new(state.open, loading, state.error, state.title, state.summary, state.selectedPath, state.viewMode, state.fileCount, state.changedCount, state.acceptedCount, state.rejectedCount, state.additions, state.deletions)

fn diffDialogWithError(state: DiffDialogState, error: text) -> DiffDialogState:
    DiffDialogState.new(state.open, false, error, state.title, state.summary, state.selectedPath, state.viewMode, state.fileCount, state.changedCount, state.acceptedCount, state.rejectedCount, state.additions, state.deletions)

fn diffDialogVisible(state: DiffDialogState) -> bool:
    state.open

fn diffDialogCanInteract(state: DiffDialogState) -> bool:
    state.open and not state.loading and state.error == ""

fn diffDialogNormalizeViewMode(viewMode: text) -> text:
    val mode = viewMode.trim()
    if mode == "unified":
        return "unified"
    if mode == "split":
        return "split"
    if mode == "file":
        return "file"
    "split"

fn diffDialogTitle(state: DiffDialogState) -> text:
    if state.title != "":
        return state.title
    if state.fileCount == 1:
        return "Review 1 file"
    if state.fileCount > 1:
        return "Review " + state.fileCount.to_text() + " files"
    "Review changes"

fn diffDialogStatus(state: DiffDialogState) -> text:
    if not state.open:
        return "closed"
    if state.error != "":
        return "error"
    if state.loading:
        return "loading"
    if state.fileCount == 0:
        return "empty"
    if state.rejectedCount > 0 and state.acceptedCount > 0:
        return "partially decided"
    if state.acceptedCount == state.fileCount:
        return "accepted"
    if state.rejectedCount == state.fileCount:
        return "rejected"
    "reviewing"

fn diffDialogChangeSummary(state: DiffDialogState) -> text:
    if state.summary != "":
        return state.summary
    if state.error != "":
        return "Unable to load diff: " + state.error
    if state.loading:
        return "Loading diff"
    if state.fileCount == 0:
        return "No file changes"
    val fileLabel = diffDialogFileCountLabel(state.fileCount)
    val changeLabel = diffDialogLineChangeLabel(state.additions, state.deletions)
    fileLabel + " with " + changeLabel

fn diffDialogFileCountLabel(fileCount: i64) -> text:
    if fileCount == 1:
        return "1 file"
    fileCount.to_text() + " files"

fn diffDialogLineChangeLabel(additions: i64, deletions: i64) -> text:
    val added = diffDialogNonNegative(additions)
    val removed = diffDialogNonNegative(deletions)
    "+" + added.to_text() + " -" + removed.to_text()

fn diffDialogDecisionSummary(state: DiffDialogState) -> text:
    val accepted = diffDialogNonNegative(state.acceptedCount)
    val rejected = diffDialogNonNegative(state.rejectedCount)
    val pending = diffDialogPendingCount(state)
    accepted.to_text() + " accepted, " + rejected.to_text() + " rejected, " + pending.to_text() + " pending"

fn diffDialogEmptySummary(state: DiffDialogState) -> text:
    if state.error != "":
        return "Diff unavailable"
    if state.loading:
        return "Diff is loading"
    if state.fileCount == 0:
        return "No changes to review"
    ""

fn diffDialogLoadingSummary(state: DiffDialogState) -> text:
    if state.loading:
        return "Loading " + diffDialogTitle(state)
    ""

fn diffDialogErrorSummary(state: DiffDialogState) -> text:
    if state.error == "":
        return ""
    "Diff error: " + state.error

fn diffDialogSelectedFileLabel(state: DiffDialogState) -> text:
    if state.selectedPath != "":
        return state.selectedPath
    if state.fileCount == 0:
        return "No file selected"
    "First changed file"

fn diffDialogHasSelection(state: DiffDialogState) -> bool:
    state.selectedPath != ""

fn diffDialogCanSelectFile(state: DiffDialogState) -> bool:
    diffDialogCanInteract(state) and state.fileCount > 0

fn diffDialogCanAcceptSelected(state: DiffDialogState) -> bool:
    diffDialogCanInteract(state) and diffDialogHasSelection(state)

fn diffDialogCanRejectSelected(state: DiffDialogState) -> bool:
    diffDialogCanInteract(state) and diffDialogHasSelection(state)

fn diffDialogCanAcceptAll(state: DiffDialogState) -> bool:
    diffDialogCanInteract(state) and state.fileCount > 0 and state.acceptedCount < state.fileCount

fn diffDialogCanRejectAll(state: DiffDialogState) -> bool:
    diffDialogCanInteract(state) and state.fileCount > 0 and state.rejectedCount < state.fileCount

fn diffDialogPendingCount(state: DiffDialogState) -> i64:
    val pending = state.fileCount - state.acceptedCount - state.rejectedCount
    diffDialogNonNegative(pending)

fn diffDialogNonNegative(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn diffDialogSelectFile(state: DiffDialogState, path: text) -> DiffDialogAction:
    if not diffDialogCanSelectFile(state):
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, diffDialogChangeSummary(state))
    val selected = path.trim()
    if selected == "":
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, "No file path")
    DiffDialogAction.new("select", false, selected, state.viewMode, "Selected " + selected)

fn diffDialogAcceptSelected(state: DiffDialogState) -> DiffDialogAction:
    if not diffDialogCanAcceptSelected(state):
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, diffDialogChangeSummary(state))
    DiffDialogAction.new("accept_file", false, state.selectedPath, state.viewMode, "Accepted " + state.selectedPath)

fn diffDialogRejectSelected(state: DiffDialogState) -> DiffDialogAction:
    if not diffDialogCanRejectSelected(state):
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, diffDialogChangeSummary(state))
    DiffDialogAction.new("reject_file", false, state.selectedPath, state.viewMode, "Rejected " + state.selectedPath)

fn diffDialogAcceptAll(state: DiffDialogState) -> DiffDialogAction:
    if not diffDialogCanAcceptAll(state):
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, diffDialogChangeSummary(state))
    DiffDialogAction.new("accept_all", true, state.selectedPath, state.viewMode, "Accepted all " + diffDialogFileCountLabel(state.fileCount))

fn diffDialogRejectAll(state: DiffDialogState) -> DiffDialogAction:
    if not diffDialogCanRejectAll(state):
        return DiffDialogAction.new("blocked", false, state.selectedPath, state.viewMode, diffDialogChangeSummary(state))
    DiffDialogAction.new("reject_all", true, state.selectedPath, state.viewMode, "Rejected all " + diffDialogFileCountLabel(state.fileCount))

fn diffDialogClose(state: DiffDialogState) -> DiffDialogAction:
    DiffDialogAction.new("close", true, state.selectedPath, state.viewMode, "Closed diff dialog")

fn diffDialogToggleViewMode(state: DiffDialogState) -> DiffDialogAction:
    val current = diffDialogNormalizeViewMode(state.viewMode)
    if current == "split":
        return DiffDialogAction.new("view_mode", false, state.selectedPath, "unified", "Switched to unified diff")
    if current == "unified":
        return DiffDialogAction.new("view_mode", false, state.selectedPath, "file", "Switched to file diff")
    DiffDialogAction.new("view_mode", false, state.selectedPath, "split", "Switched to split diff")

fn diffDialogKeyboardLabel(action: text) -> text:
    val key = action.trim()
    if key == "accept":
        return "A Accept"
    if key == "reject":
        return "R Reject"
    if key == "accept_all":
        return "Shift+A Accept all"
    if key == "reject_all":
        return "Shift+R Reject all"
    if key == "close":
        return "Esc Close"
    if key == "toggle_view":
        return "V View"
    if key == "next_file":
        return "J Next"
    if key == "previous_file":
        return "K Previous"
    "Enter Select"

fn diffDialogFooterLabel(state: DiffDialogState) -> text:
    if not state.open:
        return ""
    if state.loading:
        return diffDialogKeyboardLabel("close")
    if state.error != "":
        return diffDialogKeyboardLabel("close")
    diffDialogKeyboardLabel("accept") + " | " + diffDialogKeyboardLabel("reject") + " | " + diffDialogKeyboardLabel("toggle_view") + " | " + diffDialogKeyboardLabel("close")

fn diffDialogFileSummary(file: DiffDialogFile) -> text:
    val path = diffDialogFilePathLabel(file)
    val changes = diffDialogLineChangeLabel(file.additions, file.deletions)
    if file.accepted:
        return path + " accepted " + changes
    if file.rejected:
        return path + " rejected " + changes
    if file.changed:
        return path + " changed " + changes
    path + " unchanged"

fn diffDialogFilePathLabel(file: DiffDialogFile) -> text:
    if file.path != "":
        return file.path
    "Untitled file"

fn diffDialogFileDecision(file: DiffDialogFile) -> text:
    if file.accepted:
        return "accepted"
    if file.rejected:
        return "rejected"
    if file.changed:
        return "pending"
    "unchanged"

fn diffDialogFileCanAccept(file: DiffDialogFile) -> bool:
    file.changed and not file.accepted and not file.rejected

fn diffDialogFileCanReject(file: DiffDialogFile) -> bool:
    file.changed and not file.accepted and not file.rejected

fn diffDialogSource() -> text:
    "DiffDialog"

fn diffDialogSourceLinesModeled() -> i64:
    382
