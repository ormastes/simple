"""
Claude full FileEditToolDiff parity.
"""

class FileEditDiffState:
    path: text
    before_text: text
    after_text: text
    expanded: bool

impl FileEditDiffState:
    static fn new(path: text, beforeText: text, afterText: text, expanded: bool) -> FileEditDiffState:
        FileEditDiffState(path: path.trim(), before_text: beforeText, after_text: afterText, expanded: expanded)

fn fileEditDiffPath(state: FileEditDiffState) -> text:
    if state.path == "":
        return "untitled"
    state.path

fn fileEditDiffChanged(state: FileEditDiffState) -> bool:
    state.before_text != state.after_text

fn fileEditDiffLineCount(textValue: text) -> i64:
    if textValue == "":
        return 0
    var count = 1
    var i = 0
    while i < textValue.len():
        if textValue[i] == "\n":
            count = count + 1
        i = i + 1
    count

fn fileEditDiffSummary(state: FileEditDiffState) -> text:
    fileEditDiffPath(state) + " " + fileEditDiffLineCount(state.before_text).to_text() + "->" + fileEditDiffLineCount(state.after_text).to_text()

fn fileEditDiffRender(state: FileEditDiffState) -> text:
    if not fileEditDiffChanged(state):
        return fileEditDiffPath(state) + " unchanged"
    if not state.expanded:
        return fileEditDiffSummary(state)
    "--- " + fileEditDiffPath(state) + "\n+++ " + fileEditDiffPath(state) + "\n" + state.after_text

fn fileEditToolDiffSourceLinesModeled() -> i64:
    180
