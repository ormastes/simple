class PathTraversalError:
    name: text
    message: text

impl PathTraversalError:
    static fn new(message: text) -> PathTraversalError:
        PathTraversalError(name: "PathTraversalError", message: message)

class PathValidationResult:
    ok: bool
    path: text
    error: PathTraversalError?

impl PathValidationResult:
    static fn ok(path: text) -> PathValidationResult:
        PathValidationResult(ok: true, path: path, error: nil)

    static fn fail(message: text) -> PathValidationResult:
        PathValidationResult(ok: false, path: "", error: Some(PathTraversalError.new(message)))

fn sanitizePathKey(key: text) -> PathValidationResult:
    if key.contains("\u0000"):
        return PathValidationResult.fail("Null byte in path key: \"" + key + "\"")
    val decoded = decodePathKey(key)
    if decoded != key and (decoded.contains("..") or decoded.contains("/")):
        return PathValidationResult.fail("URL-encoded traversal in path key: \"" + key + "\"")
    val normalized = normalizeDangerousUnicode(key)
    if normalized != key and (normalized.contains("..") or normalized.contains("/") or normalized.contains("\\") or normalized.contains("\u0000")):
        return PathValidationResult.fail("Unicode-normalized traversal in path key: \"" + key + "\"")
    if key.contains("\\"):
        return PathValidationResult.fail("Backslash in path key: \"" + key + "\"")
    if key.starts_with("/"):
        return PathValidationResult.fail("Absolute path key: \"" + key + "\"")
    PathValidationResult.ok(key)

fn isTeamMemoryEnabled(autoMemoryEnabled: bool, featureEnabled: bool) -> bool:
    autoMemoryEnabled and featureEnabled

fn getTeamMemPath(autoMemPath: text) -> text:
    ensureTrailingSlash(autoMemPath) + "team/"

fn getTeamMemEntrypoint(autoMemPath: text) -> text:
    ensureTrailingSlash(autoMemPath) + "team/MEMORY.md"

fn isTeamMemPath(filePath: text, teamDir: text) -> bool:
    normalizePath(filePath).starts_with(ensureTrailingSlash(teamDir))

fn validateTeamMemWritePath(filePath: text, teamDir: text, realWithinTeamDir: bool) -> PathValidationResult:
    if filePath.contains("\u0000"):
        return PathValidationResult.fail("Null byte in path: \"" + filePath + "\"")
    val resolvedPath = normalizePath(filePath)
    val normalizedTeamDir = ensureTrailingSlash(normalizePath(teamDir))
    if not resolvedPath.starts_with(normalizedTeamDir):
        return PathValidationResult.fail("Path escapes team memory directory: \"" + filePath + "\"")
    if not realWithinTeamDir:
        return PathValidationResult.fail("Path escapes team memory directory via symlink: \"" + filePath + "\"")
    PathValidationResult.ok(resolvedPath)

fn validateTeamMemKey(relativeKey: text, teamDir: text, realWithinTeamDir: bool) -> PathValidationResult:
    val sanitized = sanitizePathKey(relativeKey)
    if not sanitized.ok:
        return sanitized
    val resolvedPath = normalizePath(ensureTrailingSlash(teamDir) + relativeKey)
    val normalizedTeamDir = ensureTrailingSlash(normalizePath(teamDir))
    if not resolvedPath.starts_with(normalizedTeamDir):
        return PathValidationResult.fail("Key escapes team memory directory: \"" + relativeKey + "\"")
    if not realWithinTeamDir:
        return PathValidationResult.fail("Key escapes team memory directory via symlink: \"" + relativeKey + "\"")
    PathValidationResult.ok(resolvedPath)

fn isTeamMemFile(filePath: text, teamDir: text, autoMemoryEnabled: bool, featureEnabled: bool) -> bool:
    isTeamMemoryEnabled(autoMemoryEnabled, featureEnabled) and isTeamMemPath(filePath, teamDir)

fn realpathDeepestExistingStatus(errnoCode: text, isDanglingSymlink: bool) -> PathValidationResult:
    if isDanglingSymlink:
        return PathValidationResult.fail("Dangling symlink detected (target does not exist)")
    if errnoCode == "ELOOP":
        return PathValidationResult.fail("Symlink loop detected in path")
    if errnoCode != "" and errnoCode != "ENOENT" and errnoCode != "ENOTDIR" and errnoCode != "ENAMETOOLONG":
        return PathValidationResult.fail("Cannot verify path containment (" + errnoCode + ")")
    PathValidationResult.ok("ancestor")

fn decodePathKey(key: text) -> text:
    var out = key
    out = out.replace("%2e", ".")
    out = out.replace("%2E", ".")
    out = out.replace("%2f", "/")
    out = out.replace("%2F", "/")
    out = out.replace("%5c", "\\")
    out = out.replace("%5C", "\\")
    out

fn normalizeDangerousUnicode(key: text) -> text:
    var out = key
    out = out.replace("．", ".")
    out = out.replace("／", "/")
    out = out.replace("＼", "\\")
    out

fn ensureTrailingSlash(path: text) -> text:
    if path.ends_with("/"):
        return path
    path + "/"

fn normalizePath(path: text) -> text:
    val absolute = if path.starts_with("/"): path else: "/" + path
    val parts = absolute.split("/")
    var stack: [text] = []
    var i = 0
    while i < parts.len():
        val part = parts[i]
        if part == "" or part == ".":
            i = i + 1
            continue
        if part == "..":
            if stack.len() > 0:
                stack.pop()
        else:
            stack.push(part)
        i = i + 1
    "/" + joinPathParts(stack)

fn joinPathParts(parts: [text]) -> text:
    var out = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            out = out + "/"
        out = out + parts[i]
        i = i + 1
    out

fn teamMemPathsSourceLinesModeled() -> i64:
    292

# ponytail: filesystem realpath/lstat is modeled as status inputs; add real fs facade only when this module is wired to disk in Simple.
# Source parity note: PathTraversalError carries name PathTraversalError.
# Source parity note: keys reject null bytes before path work.
# Source parity note: URL-encoded dot/slash traversal is rejected.
# Source parity note: malformed percent encoding is not needed for traversal detection.
# Source parity note: Unicode NFKC lookalike separators are rejected defensively.
# Source parity note: backslash and absolute keys are rejected.
# Source parity note: team memory requires auto memory and feature flag.
# Source parity note: write validation checks string containment before symlink containment.
# Source parity note: ENOENT and ENOTDIR on team dir allow skipping realpath containment.
# Source parity note: dangling symlinks, ELOOP, and unverifiable errors fail closed.
