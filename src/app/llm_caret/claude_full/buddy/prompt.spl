class CompanionIntroAttachment:
    kind: text
    name: text
    species: text

impl CompanionIntroAttachment:
    static fn new(name: text, species: text) -> CompanionIntroAttachment:
        CompanionIntroAttachment(kind: "companion_intro", name: name, species: species)

class CompanionIntroMessage:
    msgType: text
    attachmentType: text
    attachmentName: text

impl CompanionIntroMessage:
    static fn attachment(name: text) -> CompanionIntroMessage:
        CompanionIntroMessage(msgType: "attachment", attachmentType: "companion_intro", attachmentName: name)

    static fn user() -> CompanionIntroMessage:
        CompanionIntroMessage(msgType: "user", attachmentType: "", attachmentName: "")

fn companionIntroText(name: text, species: text) -> text:
    "# Companion\n\nA small " + species + " named " + name + " sits beside the user's input box and occasionally comments in a speech bubble. You're not " + name + " - it's a separate watcher.\n\nWhen the user addresses " + name + " directly (by name), its bubble will answer. Your job in that moment is to stay out of the way: respond in ONE line or less, or just answer any part of the message meant for you. Don't explain that you're not " + name + " - they know. Don't narrate what " + name + " might say - the bubble handles that."

fn getCompanionIntroAttachment(featureEnabled: bool, hasCompanion: bool, companionMuted: bool, name: text, species: text, messages: [CompanionIntroMessage]) -> [CompanionIntroAttachment]:
    if not featureEnabled:
        return []
    if not hasCompanion:
        return []
    if companionMuted:
        return []
    if alreadyAnnounced(name, messages):
        return []
    [CompanionIntroAttachment.new(name, species)]

fn alreadyAnnounced(name: text, messages: [CompanionIntroMessage]) -> bool:
    var i = 0
    while i < messages.len():
        val msg = messages[i]
        if msg.msgType == "attachment" and msg.attachmentType == "companion_intro" and msg.attachmentName == name:
            return true
        i = i + 1
    false

fn companionIntroAttachmentType() -> text:
    "companion_intro"

fn buddyFeatureName() -> text:
    "BUDDY"

fn companionMutedConfigField() -> text:
    "companionMuted"

fn oneLineInstruction() -> text:
    "respond in ONE line or less"

fn separateWatcherInstruction() -> text:
    "it's a separate watcher"
