class BuddyTriggerPosition:
    start: i64
    end: i64

impl BuddyTriggerPosition:
    static fn new(start: i64, end: i64) -> BuddyTriggerPosition:
        BuddyTriggerPosition(start: start, end: end)

class BuddyNotificationDecision:
    shouldAdd: bool
    shouldRemoveOnCleanup: bool
    key: text
    text: text
    priority: text
    timeoutMs: i64

impl BuddyNotificationDecision:
    static fn none() -> BuddyNotificationDecision:
        BuddyNotificationDecision(shouldAdd: false, shouldRemoveOnCleanup: false, key: "", text: "", priority: "", timeoutMs: 0)

    static fn teaser() -> BuddyNotificationDecision:
        BuddyNotificationDecision(shouldAdd: true, shouldRemoveOnCleanup: true, key: buddyTeaserKey(), text: buddyCommandText(), priority: immediatePriority(), timeoutMs: buddyTeaserTimeoutMs())

class RainbowSpan:
    index: i64
    ch: text
    color: text

impl RainbowSpan:
    static fn new(index: i64, ch: text) -> RainbowSpan:
        RainbowSpan(index: index, ch: ch, color: rainbowColor(index))

fn isBuddyTeaserWindow(year: i64, monthZeroBased: i64, day: i64, isAnt: bool) -> bool:
    if isAnt:
        return true
    year == 2026 and monthZeroBased == 3 and day <= 7

fn isBuddyLive(year: i64, monthZeroBased: i64, isAnt: bool) -> bool:
    if isAnt:
        return true
    year > 2026 or (year == 2026 and monthZeroBased >= 3)

fn buddyNotificationDecision(featureEnabled: bool, hasCompanion: bool, teaserWindow: bool) -> BuddyNotificationDecision:
    if not featureEnabled:
        return BuddyNotificationDecision.none()
    if hasCompanion:
        return BuddyNotificationDecision.none()
    if not teaserWindow:
        return BuddyNotificationDecision.none()
    BuddyNotificationDecision.teaser()

fn rainbowText(textValue: text) -> [RainbowSpan]:
    var out: [RainbowSpan] = []
    var i = 0
    while i < textValue.len():
        out = out + [RainbowSpan.new(i, textValue.substring(i, i + 1))]
        i = i + 1
    out

fn findBuddyTriggerPositions(featureEnabled: bool, textValue: text) -> [BuddyTriggerPosition]:
    if not featureEnabled:
        return []
    var out: [BuddyTriggerPosition] = []
    var i = 0
    while i < textValue.len():
        if startsBuddyTriggerAt(textValue, i):
            out = out + [BuddyTriggerPosition.new(i, i + buddyCommandText().len())]
            i = i + buddyCommandText().len()
        else:
            i = i + 1
    out

fn startsBuddyTriggerAt(textValue: text, index: i64) -> bool:
    if index < 0:
        return false
    val end = index + buddyCommandText().len()
    if end > textValue.len():
        return false
    if textValue.substring(index, end) != buddyCommandText():
        return false
    if end >= textValue.len():
        return true
    not isWordChar(textValue.substring(end, end + 1))

fn isWordChar(ch: text) -> bool:
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    ch == "_"

fn rainbowColor(index: i64) -> text:
    val colors = rainbowColors()
    colors[index % colors.len()]

fn rainbowColors() -> [text]:
    ["red", "yellow", "green", "cyan", "blue", "magenta"]

fn buddyFeatureName() -> text:
    "BUDDY"

fn buddyTeaserKey() -> text:
    "buddy-teaser"

fn buddyCommandText() -> text:
    "/buddy"

fn immediatePriority() -> text:
    "immediate"

fn buddyTeaserTimeoutMs() -> i64:
    15000

fn teaserStartYear() -> i64:
    2026

fn teaserStartMonthZeroBased() -> i64:
    3

fn teaserEndDayInclusive() -> i64:
    7

fn localDateWindowReason() -> text:
    "24h rolling wave across timezones"

fn commandLiveForeverAfterLaunch() -> bool:
    true

fn notificationShownWhenNoCompanion() -> bool:
    true

fn idlePresenceHandledByCompanionSprite() -> bool:
    true

fn triggerRegexSource() -> text:
    "/\\/buddy\\b/g"

fn cleanupRemovesKey() -> text:
    buddyTeaserKey()

fn effectDependencyCount() -> i64:
    2

fn compilerMemoSlots() -> i64:
    4
