fn hatLine(hat: text) -> text:
    if hat == "crown":
        return "   \\^^^/    "
    if hat == "tophat":
        return "   [___]    "
    if hat == "propeller":
        return "    -+-     "
    if hat == "halo":
        return "   (   )    "
    if hat == "wizard":
        return "    /^\\     "
    if hat == "beanie":
        return "   (___)    "
    if hat == "tinyduck":
        return "    ,>      "
    ""

fn speciesList() -> [text]:
    ["duck", "goose", "blob", "cat", "dragon", "octopus", "owl", "penguin", "turtle", "snail", "ghost", "axolotl", "capybara", "cactus", "robot", "rabbit", "mushroom", "chonk"]

fn hatList() -> [text]:
    ["none", "crown", "tophat", "propeller", "halo", "wizard", "beanie", "tinyduck"]

fn replaceLine(lines: [text], index: i64, value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < lines.len():
        if i == index:
            out = out + [value]
        else:
            out = out + [lines[i]]
        i = i + 1
    out

fn dropFirst(lines: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < lines.len():
        out = out + [lines[i]]
        i = i + 1
    out

fn allFramesHaveBlankHatSlot(frames: [[text]]) -> bool:
    var i = 0
    while i < frames.len():
        if frames[i][0].trim() != "":
            return false
        i = i + 1
    true

fn positiveMod(value: i64, modulo: i64) -> i64:
    val raw = value % modulo
    if raw < 0:
        return raw + modulo
    raw

