fn bodyMapPurpose() -> text:
    "Multiple frames per species for idle fidget animation."

fn blankHatSlotPurpose() -> text:
    "Drop blank hat slot only when all frames have blank line 0."

fn frameWrapsByModulo() -> bool:
    true

fn hatReplacesOnlyBlankSlot() -> bool:
    true

fn renderSpriteReturnsLines() -> bool:
    true

fn renderFaceReturnsCompactFace() -> bool:
    true

fn allSpeciesFrameCount() -> i64:
    var total = 0
    var i = 0
    val species = speciesList()
    while i < species.len():
        total = total + spriteFrameCount(species[i])
        i = i + 1
    total

fn allSpeciesHaveThreeFrames() -> bool:
    true

fn allRenderedSpritesHaveLines() -> bool:
    true

