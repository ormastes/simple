class SpriteBones:
    species: text
    eye: text
    hat: text

impl SpriteBones:
    static fn new(species: text, eye: text, hat: text) -> SpriteBones:
        SpriteBones(species: species, eye: eye, hat: hat)

fn renderSprite(bones: SpriteBones, frame: i64) -> [text]:
    val frames = bodyFrames(bones.species)
    val raw = frames[positiveMod(frame, frames.len())]
    var lines: [text] = []
    var i = 0
    while i < raw.len():
        lines = lines + [raw[i].replace("@", bones.eye).replace("@", bones.eye)]
        i = i + 1
    if bones.hat != "none" and lines.len() > 0 and lines[0].trim() == "":
        lines = replaceLine(lines, 0, hatLine(bones.hat))
    if lines.len() > 0 and lines[0].trim() == "" and allFramesHaveBlankHatSlot(frames):
        return dropFirst(lines)
    lines

fn spriteFrameCount(species: text) -> i64:
    bodyFrames(species).len()

fn renderFace(bones: SpriteBones) -> text:
    val eye = bones.eye
    if bones.species == "duck" or bones.species == "goose":
        return "(" + eye + ">"
    if bones.species == "blob":
        return "(" + eye + eye + ")"
    if bones.species == "cat":
        return "=" + eye + "w" + eye + "="
    if bones.species == "dragon":
        return "<" + eye + "~" + eye + ">"
    if bones.species == "octopus":
        return "~(" + eye + eye + ")~"
    if bones.species == "owl":
        return "(" + eye + ")(" + eye + ")"
    if bones.species == "penguin":
        return "(" + eye + ">)"
    if bones.species == "turtle":
        return "[" + eye + "_" + eye + "]"
    if bones.species == "snail":
        return eye + "(@)"
    if bones.species == "ghost":
        return "/" + eye + eye + "\\"
    if bones.species == "axolotl":
        return "}" + eye + "." + eye + "{"
    if bones.species == "capybara":
        return "(" + eye + "oo" + eye + ")"
    if bones.species == "cactus":
        return "|" + eye + "  " + eye + "|"
    if bones.species == "robot":
        return "[" + eye + eye + "]"
    if bones.species == "rabbit":
        return "(" + eye + ".." + eye + ")"
    if bones.species == "mushroom":
        return "|" + eye + "  " + eye + "|"
    if bones.species == "chonk":
        return "(" + eye + "." + eye + ")"
    "(" + eye + eye + ")"

fn bodyFrames(species: text) -> [[text]]:
    if species == "duck":
        return duckFrames()
    if species == "goose":
        return gooseFrames()
    if species == "blob":
        return blobFrames()
    if species == "cat":
        return catFrames()
    if species == "dragon":
        return dragonFrames()
    if species == "octopus":
        return octopusFrames()
    if species == "owl":
        return owlFrames()
    if species == "penguin":
        return penguinFrames()
    if species == "turtle":
        return turtleFrames()
    if species == "snail":
        return snailFrames()
    if species == "ghost":
        return ghostFrames()
    if species == "axolotl":
        return axolotlFrames()
    if species == "capybara":
        return capybaraFrames()
    if species == "cactus":
        return cactusFrames()
    if species == "robot":
        return robotFrames()
    if species == "rabbit":
        return rabbitFrames()
    if species == "mushroom":
        return mushroomFrames()
    if species == "chonk":
        return chonkFrames()
    duckFrames()

