class CompanionSpriteConfig:
    buddyFeature: bool
    muted: bool
    hasCompanion: bool
    companionName: text
    rarityColor: text
    terminalColumns: i64
    fullscreen: bool
    speaking: bool
    reaction: text
    focused: bool
    petAt: i64
    tick: i64
    lastSpokeTick: i64
    petStartTick: i64
    speciesFrameCount: i64
    eye: text

impl CompanionSpriteConfig:
    static fn basic(name: text, columns: i64) -> CompanionSpriteConfig:
        CompanionSpriteConfig(buddyFeature: true, muted: false, hasCompanion: true, companionName: name, rarityColor: "primary", terminalColumns: columns, fullscreen: false, speaking: false, reaction: "", focused: false, petAt: 0, tick: 0, lastSpokeTick: 0, petStartTick: 0, speciesFrameCount: 3, eye: "o")

class CompanionSpriteRender:
    visible: bool
    reservedColumns: i64
    mode: text
    label: text
    bubbleTail: text
    fading: bool
    petting: bool
    spriteFrame: i64
    blink: bool
    heartFrame: text
    lines: [text]

impl CompanionSpriteRender:
    static fn hidden() -> CompanionSpriteRender:
        CompanionSpriteRender(visible: false, reservedColumns: 0, mode: "hidden", label: "", bubbleTail: "", fading: false, petting: false, spriteFrame: 0, blink: false, heartFrame: "", lines: [])

fn companionReservedColumns(config: CompanionSpriteConfig) -> i64:
    if not config.buddyFeature:
        return 0
    if not config.hasCompanion or config.muted:
        return 0
    if config.terminalColumns < minColsForFullSprite():
        return 0
    val bubble = if config.speaking and not config.fullscreen: bubbleWidth() else: 0
    spriteColWidth(stringWidthApprox(config.companionName)) + spritePaddingX() + bubble

fn renderCompanionSprite(config: CompanionSpriteConfig) -> CompanionSpriteRender:
    if not config.buddyFeature or not config.hasCompanion or config.muted:
        return CompanionSpriteRender.hidden()
    val petting = isPetting(config.tick, config.petStartTick, config.petAt)
    if config.terminalColumns < minColsForFullSprite():
        return renderNarrowCompanion(config, petting)
    renderFullCompanion(config, petting)

fn renderNarrowCompanion(config: CompanionSpriteConfig, petting: bool) -> CompanionSpriteRender:
    val quip = narrowQuip(config.reaction)
    val label = if quip != "": "\"" + quip + "\"" else: if config.focused: " " + config.companionName + " " else: config.companionName
    CompanionSpriteRender(visible: true, reservedColumns: 0, mode: "narrow", label: label, bubbleTail: "", fading: bubbleFading(config.reaction, config.tick, config.lastSpokeTick), petting: petting, spriteFrame: 0, blink: false, heartFrame: if petting: heartGlyph() else: "", lines: [label])

fn renderFullCompanion(config: CompanionSpriteConfig, petting: bool) -> CompanionSpriteRender:
    val frame = companionSpriteFrame(config.reaction != "", petting, config.tick, config.speciesFrameCount)
    val blink = companionShouldBlink(config.reaction != "", petting, config.tick)
    val heart = if petting: petHeartFrame(config.tick - config.petStartTick) else: ""
    val mode = if config.reaction == "": "sprite-only" else: if config.fullscreen: "fullscreen-sprite-only" else: "inline-bubble"
    val tail = if config.reaction != "" and not config.fullscreen: "right" else: ""
    val label = if config.focused: " " + config.companionName + " " else: config.companionName
    CompanionSpriteRender(visible: true, reservedColumns: companionReservedColumns(config), mode: mode, label: label, bubbleTail: tail, fading: bubbleFading(config.reaction, config.tick, config.lastSpokeTick), petting: petting, spriteFrame: frame, blink: blink, heartFrame: heart, lines: buildSpriteLines(label, heart))

fn renderFloatingBubble(config: CompanionSpriteConfig) -> CompanionSpriteRender:
    if not config.buddyFeature or not config.hasCompanion or config.muted or config.reaction == "":
        return CompanionSpriteRender.hidden()
    CompanionSpriteRender(visible: true, reservedColumns: 0, mode: "floating-bubble", label: config.reaction, bubbleTail: "down", fading: config.tick >= bubbleShowTicks() - fadeWindowTicks(), petting: false, spriteFrame: 0, blink: false, heartFrame: "", lines: wrapText(config.reaction, speechWrapWidth()))

fn wrapText(value: text, width: i64) -> [text]:
    val words = splitWords(value)
    var lines: [text] = []
    var current = ""
    var i = 0
    while i < words.len():
        val word = words[i]
        if current != "" and current.len() + word.len() + 1 > width:
            lines.push(current)
            current = word
        else:
            current = if current == "": word else: current + " " + word
        i = i + 1
    if current != "":
        lines.push(current)
    lines

fn splitWords(value: text) -> [text]:
    var words: [text] = []
    var current = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == " ":
            if current != "":
                words.push(current)
                current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        words.push(current)
    words

fn buildSpriteLines(label: text, heart: text) -> [text]:
    var lines: [text] = []
    if heart != "":
        lines.push(heart)
    lines.push("sprite-body")
    lines.push(label)
    lines

fn companionSpriteFrame(excited: bool, petting: bool, tick: i64, frameCount: i64) -> i64:
    val count = if frameCount <= 0: 1 else: frameCount
    if excited or petting:
        return tick % count
    val step = idleStep(tick)
    if step < 0:
        return 0
    step % count

fn companionShouldBlink(excited: bool, petting: bool, tick: i64) -> bool:
    if excited or petting:
        return false
    idleStep(tick) == -1

fn idleStep(tick: i64) -> i64:
    val index = tick % idleSequenceLength()
    if index == 4:
        return 1
    if index == 8:
        return -1
    if index == 11:
        return 2
    0

fn isPetting(tick: i64, petStartTick: i64, petAt: i64) -> bool:
    petAt > 0 and (tick - petStartTick) * tickMs() < petBurstMs()

fn petHeartFrame(ageTicks: i64) -> text:
    val index = ageTicks % petHeartFrameCount()
    if index == 0:
        return "   HEART    HEART   "
    if index == 1:
        return "  HEART  HEART   HEART  "
    if index == 2:
        return " HEART   HEART  HEART   "
    if index == 3:
        return "HEART  HEART      HEART "
    "dot    dot   dot  "

fn bubbleFading(reaction: text, tick: i64, lastSpokeTick: i64) -> bool:
    reaction != "" and tick - lastSpokeTick >= bubbleShowTicks() - fadeWindowTicks()

fn narrowQuip(reaction: text) -> text:
    if reaction == "":
        return ""
    if reaction.len() > narrowQuipCap():
        return reaction.slice(0, narrowQuipCap() - 1) + "..."
    reaction

fn spriteColWidth(nameWidth: i64) -> i64:
    if spriteBodyWidth() > nameWidth + nameRowPad():
        return spriteBodyWidth()
    nameWidth + nameRowPad()

fn stringWidthApprox(value: text) -> i64:
    value.len()

fn speechBubbleBorderColor(color: text, fading: bool) -> text:
    if fading:
        return "inactive"
    color

fn speechBubbleTailShape(tail: text) -> text:
    if tail == "right":
        return "horizontal"
    if tail == "down":
        return "diagonal"
    "none"

fn reactionClearAfterMs() -> i64:
    bubbleShowTicks() * tickMs()

fn floatingBubbleTickResetsOnReactionChange(oldReaction: text, newReaction: text) -> bool:
    oldReaction != newReaction

fn minColsForFullSprite() -> i64:
    100

fn tickMs() -> i64:
    500

fn bubbleShowTicks() -> i64:
    20

fn fadeWindowTicks() -> i64:
    6

fn petBurstMs() -> i64:
    2500

fn spriteBodyWidth() -> i64:
    12

fn nameRowPad() -> i64:
    2

fn spritePaddingX() -> i64:
    2

fn bubbleWidth() -> i64:
    36

fn narrowQuipCap() -> i64:
    24

fn speechWrapWidth() -> i64:
    30

fn speechBubbleBoxWidth() -> i64:
    34

fn idleSequenceLength() -> i64:
    15

fn petHeartFrameCount() -> i64:
    5

fn heartGlyph() -> text:
    "HEART"

fn bubbleShowApproxSeconds() -> i64:
    10

fn fadeWindowApproxSeconds() -> i64:
    3

fn spriteUsesInlineBubbleInScrollback() -> bool:
    true

fn spriteUsesFloatingBubbleInFullscreen() -> bool:
    true

fn narrowModeUsesNoReservation() -> bool:
    true

fn companionSpriteSourceLinesModeled() -> i64:
    370

