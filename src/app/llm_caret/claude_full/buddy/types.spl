class CompanionStats:
    debugging: i64
    patience: i64
    chaos: i64
    wisdom: i64
    snark: i64

impl CompanionStats:
    static fn new(debugging: i64, patience: i64, chaos: i64, wisdom: i64, snark: i64) -> CompanionStats:
        CompanionStats(debugging: debugging, patience: patience, chaos: chaos, wisdom: wisdom, snark: snark)

class CompanionBones:
    rarity: text
    species: text
    eye: text
    hat: text
    shiny: bool
    stats: CompanionStats

impl CompanionBones:
    static fn new(rarity: text, species: text, eye: text, hat: text, shiny: bool, stats: CompanionStats) -> CompanionBones:
        CompanionBones(rarity: rarity, species: species, eye: eye, hat: hat, shiny: shiny, stats: stats)

class CompanionSoul:
    name: text
    personality: text

impl CompanionSoul:
    static fn new(name: text, personality: text) -> CompanionSoul:
        CompanionSoul(name: name, personality: personality)

class StoredCompanion:
    name: text
    personality: text
    hatchedAt: i64

impl StoredCompanion:
    static fn new(name: text, personality: text, hatchedAt: i64) -> StoredCompanion:
        StoredCompanion(name: name, personality: personality, hatchedAt: hatchedAt)

class Companion:
    name: text
    personality: text
    hatchedAt: i64
    bones: CompanionBones

impl Companion:
    static fn new(stored: StoredCompanion, bones: CompanionBones) -> Companion:
        Companion(name: stored.name, personality: stored.personality, hatchedAt: stored.hatchedAt, bones: bones)

fn rarities() -> [text]:
    ["common", "uncommon", "rare", "epic", "legendary"]

fn species() -> [text]:
    ["duck", "goose", "blob", "cat", "dragon", "octopus", "owl", "penguin", "turtle", "snail", "ghost", "axolotl", "capybara", "cactus", "robot", "rabbit", "mushroom", "chonk"]

fn eyes() -> [text]:
    ["dot", "spark", "cross", "target", "at", "degree"]

fn hats() -> [text]:
    ["none", "crown", "tophat", "propeller", "halo", "wizard", "beanie", "tinyduck"]

fn statNames() -> [text]:
    ["DEBUGGING", "PATIENCE", "CHAOS", "WISDOM", "SNARK"]

fn rarityWeight(rarity: text) -> i64:
    if rarity == "common":
        return 60
    if rarity == "uncommon":
        return 25
    if rarity == "rare":
        return 10
    if rarity == "epic":
        return 4
    if rarity == "legendary":
        return 1
    0

fn rarityStars(rarity: text) -> text:
    if rarity == "common":
        return "*"
    if rarity == "uncommon":
        return "**"
    if rarity == "rare":
        return "***"
    if rarity == "epic":
        return "****"
    if rarity == "legendary":
        return "*****"
    ""

fn rarityColor(rarity: text) -> text:
    if rarity == "common":
        return "inactive"
    if rarity == "uncommon":
        return "success"
    if rarity == "rare":
        return "permission"
    if rarity == "epic":
        return "autoAccept"
    if rarity == "legendary":
        return "warning"
    ""

fn totalRarityWeight() -> i64:
    var total = 0
    val rs = rarities()
    var i = 0
    while i < rs.len():
        total = total + rarityWeight(rs[i])
        i = i + 1
    total

fn speciesCount() -> i64:
    species().len()

fn rarityCount() -> i64:
    rarities().len()

fn eyeCount() -> i64:
    eyes().len()

fn hatCount() -> i64:
    hats().len()

fn statCount() -> i64:
    statNames().len()

