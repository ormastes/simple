use app.llm_caret.claude_full.bridge.sessionIdCompat.{toCompatSessionId}

val PRODUCT_URL: text = "https://claude.com/claude-code"
val CLAUDE_AI_BASE_URL: text = "https://claude.ai"
val CLAUDE_AI_STAGING_BASE_URL: text = "https://claude-ai.staging.ant.dev"
val CLAUDE_AI_LOCAL_BASE_URL: text = "http://localhost:4000"

fn isRemoteSessionStaging(sessionId: text, ingressUrl: text) -> bool:
    sessionId.contains("_staging_") or ingressUrl.contains("staging")

fn isRemoteSessionLocal(sessionId: text, ingressUrl: text) -> bool:
    sessionId.contains("_local_") or ingressUrl.contains("localhost")

fn getClaudeAiBaseUrl(sessionId: text, ingressUrl: text) -> text:
    if isRemoteSessionLocal(sessionId, ingressUrl):
        return CLAUDE_AI_LOCAL_BASE_URL
    if isRemoteSessionStaging(sessionId, ingressUrl):
        return CLAUDE_AI_STAGING_BASE_URL
    CLAUDE_AI_BASE_URL

fn getRemoteSessionUrl(sessionId: text, ingressUrl: text) -> text:
    val compatId = toCompatSessionId(sessionId)
    getClaudeAiBaseUrl(compatId, ingressUrl) + "/code/" + compatId
