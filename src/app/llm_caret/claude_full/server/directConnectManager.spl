class DirectConnectConfig:
    serverUrl: text
    sessionId: text
    wsUrl: text
    authToken: text

class DirectMessage:
    type: text
    subtype: text
    requestId: text
    toolName: text
    content: text

class DirectPermissionResponse:
    behavior: text
    updatedInput: text
    message: text

class DirectConnectSessionManager:
    config: DirectConnectConfig
    wsReadyState: text
    authorizationHeader: text
    messages: [text]
    permissionRequests: [text]
    sent: [text]
    callbacks: [text]

impl DirectConnectSessionManager:
    static fn new(config: DirectConnectConfig) -> DirectConnectSessionManager:
        DirectConnectSessionManager(config: config, wsReadyState: "closed", authorizationHeader: "", messages: [], permissionRequests: [], sent: [], callbacks: [])

    me connect() -> ():
        if me.config.authToken != "":
            me.authorizationHeader = "Bearer " + me.config.authToken
        me.wsReadyState = "open"
        me.callbacks.push("connected")

    me handleMessageBatch(data: text) -> ():
        val lines = data.split("\n")
        var i = 0
        while i < lines.len():
            val line = lines[i].trim()
            if line != "":
                val parsed = parseDirectMessage(line)
                if parsed.type != "":
                    me.handleParsedMessage(parsed)
            i = i + 1

    me handleParsedMessage(parsed: DirectMessage) -> ():
        if parsed.type == "control_request":
            if parsed.subtype == "can_use_tool":
                me.permissionRequests.push(parsed.requestId + ":" + parsed.toolName)
            else:
                me.sendErrorResponse(parsed.requestId, "Unsupported control request subtype: " + parsed.subtype)
            return
        if shouldForwardSdkMessage(parsed):
            me.messages.push(parsed.type + ":" + parsed.content)

    me sendMessage(content: text) -> bool:
        if not me.isConnected():
            return false
        me.sent.push("user:" + content)
        true

    me respondToPermissionRequest(requestId: text, result: DirectPermissionResponse) -> ():
        if not me.isConnected():
            return
        if result.behavior == "allow":
            me.sent.push("control_response:success:" + requestId + ":allow:" + result.updatedInput)
        else:
            me.sent.push("control_response:success:" + requestId + ":deny:" + result.message)

    me sendInterrupt() -> ():
        if not me.isConnected():
            return
        me.sent.push("control_request:uuid:interrupt")

    me sendErrorResponse(requestId: text, error: text) -> ():
        if not me.isConnected():
            return
        me.sent.push("control_response:error:" + requestId + ":" + error)

    me disconnect() -> ():
        if me.wsReadyState != "closed":
            me.sent.push("close")
        me.wsReadyState = "closed"
        me.callbacks.push("disconnected")

    me onError() -> ():
        me.callbacks.push("error:WebSocket connection error")

    me isConnected() -> bool:
        me.wsReadyState == "open"

fn directConnectConfig(serverUrl: text, sessionId: text, wsUrl: text, authToken: text) -> DirectConnectConfig:
    DirectConnectConfig(serverUrl: serverUrl, sessionId: sessionId, wsUrl: wsUrl, authToken: authToken)

fn directPermissionAllow(updatedInput: text) -> DirectPermissionResponse:
    DirectPermissionResponse(behavior: "allow", updatedInput: updatedInput, message: "")

fn directPermissionDeny(message: text) -> DirectPermissionResponse:
    DirectPermissionResponse(behavior: "deny", updatedInput: "", message: message)

fn parseDirectMessage(line: text) -> DirectMessage:
    val parts = line.split("|")
    var type = ""
    var subtype = ""
    var requestId = ""
    var toolName = ""
    var content = ""
    if parts.len() > 0:
        type = parts[0]
    if parts.len() > 1:
        subtype = parts[1]
    if parts.len() > 2:
        requestId = parts[2]
    if parts.len() > 3:
        toolName = parts[3]
    if parts.len() > 4:
        content = parts[4]
    DirectMessage(type: type, subtype: subtype, requestId: requestId, toolName: toolName, content: content)

fn isStdoutMessage(message: DirectMessage) -> bool:
    message.type != ""

fn shouldForwardSdkMessage(parsed: DirectMessage) -> bool:
    parsed.type != "control_response" and parsed.type != "keep_alive" and parsed.type != "control_cancel_request" and parsed.type != "streamlined_text" and parsed.type != "streamlined_tool_use_summary" and not (parsed.type == "system" and parsed.subtype == "post_turn_summary")

fn directConnectManagerSourceLinesModeled() -> i64:
    213

# ponytail: message parsing uses compact test frames; add JSON parsing only when the Simple direct-connect client owns the wire protocol.
# Source parity note: auth token becomes authorization header when present.
# Source parity note: incoming websocket data is split by newline and blank lines are ignored.
# Source parity note: invalid or untyped messages are ignored.
# Source parity note: can_use_tool control requests call permission callback.
# Source parity note: unsupported control request subtypes send error responses.
# Source parity note: control responses, keep_alive, cancel, streamlined messages, and post_turn_summary are filtered.
# Source parity note: sendMessage requires open websocket and emits SDK user message shape.
# Source parity note: permission responses require open websocket and emit StructuredIO control_response.
# Source parity note: sendInterrupt emits StructuredIO control_request interrupt.
# Source parity note: disconnect closes and clears websocket.
