const QUERY_SOURCE_LINES = 1729

class QueryParams:
    prompt: text
    maxTurns: i64

impl QueryParams:
    static fn new(prompt: text, maxTurns: i64) -> QueryParams:
        QueryParams(prompt: prompt, maxTurns: maxTurns)

fn queryEnvelopeRoute(loopTerminal: text) -> text:
    "stream_request_start|" + loopTerminal

fn isWithheldMaxOutputTokensRoute(hasAssistant: bool, apiError: text) -> bool:
    hasAssistant && apiError == "max_output_tokens"

fn yieldMissingToolResultBlocksRoute(toolUseCount: i64, errorText: text, sourceToolAssistantUUID: text) -> text:
    if toolUseCount <= 0:
        return "none"
    "user tool_result error " + errorText + " source " + sourceToolAssistantUUID + " count " + toolUseCount.to_text()

fn missingToolResultItemRoute(errorText: text, sourceToolAssistantUUID: text) -> text:
    "type:user tool_result is_error:true content:" + errorText + " source:" + sourceToolAssistantUUID

fn querySourceLinesModeled() -> i64:
    QUERY_SOURCE_LINES
