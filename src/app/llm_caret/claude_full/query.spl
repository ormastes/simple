const QUERY_SOURCE_LINES = 1729

class QueryParams:
    prompt: text
    maxTurns: i64

impl QueryParams:
    static fn new(prompt: text, maxTurns: i64) -> QueryParams:
        QueryParams(prompt: prompt, maxTurns: maxTurns)

class BudgetTracker:
    continuationCount: i64
    lastDeltaTokens: i64
    lastGlobalTurnTokens: i64
    startedAt: i64

impl BudgetTracker:
    static fn new(startedAt: i64) -> BudgetTracker:
        BudgetTracker(continuationCount: 0, lastDeltaTokens: 0, lastGlobalTurnTokens: 0, startedAt: startedAt)

    me check(agentId: text, budget: i64, globalTurnTokens: i64, nowMs: i64) -> TokenBudgetDecision:
        if agentId != "" or budget <= 0:
            return tokenBudgetStopNoEvent()

        val turnTokens = globalTurnTokens
        val pct = (turnTokens * 100 + budget / 2) / budget
        val deltaSinceLastCheck = globalTurnTokens - me.lastGlobalTurnTokens
        val isDiminishing = me.continuationCount >= 3 and deltaSinceLastCheck < 500 and me.lastDeltaTokens < 500

        if not isDiminishing and turnTokens * 10 < budget * 9:
            me.continuationCount = me.continuationCount + 1
            me.lastDeltaTokens = deltaSinceLastCheck
            me.lastGlobalTurnTokens = globalTurnTokens
            return TokenBudgetDecision(action: "continue", nudgeMessage: getBudgetContinuationMessage(pct, turnTokens, budget), continuationCount: me.continuationCount, pct: pct, turnTokens: turnTokens, budget: budget, hasCompletionEvent: false, diminishingReturns: false, durationMs: 0)

        if isDiminishing or me.continuationCount > 0:
            return TokenBudgetDecision(action: "stop", nudgeMessage: "", continuationCount: me.continuationCount, pct: pct, turnTokens: turnTokens, budget: budget, hasCompletionEvent: true, diminishingReturns: isDiminishing, durationMs: nowMs - me.startedAt)

        tokenBudgetStopNoEvent()

class TokenBudgetDecision:
    action: text
    nudgeMessage: text
    continuationCount: i64
    pct: i64
    turnTokens: i64
    budget: i64
    hasCompletionEvent: bool
    diminishingReturns: bool
    durationMs: i64

fn queryEnvelopeRoute(loopTerminal: text) -> text:
    "stream_request_start|" + loopTerminal

fn isWithheldMaxOutputTokensRoute(hasAssistant: bool, apiError: text) -> bool:
    hasAssistant && apiError == "max_output_tokens"

fn yieldMissingToolResultBlocksRoute(toolUseCount: i64, errorText: text, sourceToolAssistantUUID: text) -> text:
    if toolUseCount <= 0:
        return "none"
    "user tool_result error " + errorText + " source " + sourceToolAssistantUUID + " count " + toolUseCount.to_text()

fn missingToolResultItemRoute(errorText: text, sourceToolAssistantUUID: text) -> text:
    "type:user tool_result is_error:true content:" + errorText + " source:" + sourceToolAssistantUUID

fn tokenBudgetStopNoEvent() -> TokenBudgetDecision:
    TokenBudgetDecision(action: "stop", nudgeMessage: "", continuationCount: 0, pct: 0, turnTokens: 0, budget: 0, hasCompletionEvent: false, diminishingReturns: false, durationMs: 0)

fn getBudgetContinuationMessage(pct: i64, turnTokens: i64, budget: i64) -> text:
    "Stopped at " + pct.to_text() + "% of token target (" + formatEnUsInteger(turnTokens) + " / " + formatEnUsInteger(budget) + "). Keep working \u2014 do not summarize."

fn formatEnUsInteger(value: i64) -> text:
    var raw = value.to_text()
    var sign = ""
    if raw.starts_with("-"):
        sign = "-"
        raw = raw.slice(1, raw.len())
    var out = ""
    var i = raw.len()
    while i > 3:
        val start = i - 3
        if out == "":
            out = raw.slice(start, i)
        else:
            out = raw.slice(start, i) + "," + out
        i = start
    if out == "":
        return sign + raw.slice(0, i)
    sign + raw.slice(0, i) + "," + out

fn querySourceLinesModeled() -> i64:
    QUERY_SOURCE_LINES
