class RemoteSessionConfig:
    sessionId: text
    accessToken: text
    orgUuid: text
    hasInitialPrompt: bool
    viewerOnly: bool

class RemoteMessage:
    type: text
    request_id: text
    subtype: text
    tool_use_id: text
    tool_name: text
    payload: text

class RemotePermissionResponse:
    behavior: text
    updatedInput: text
    message: text

class RemoteSessionManager:
    config: RemoteSessionConfig
    websocketActive: bool
    websocketConnected: bool
    pendingPermissionRequestIds: [text]
    pendingToolUseIds: [text]
    receivedMessages: [text]
    permissionRequests: [text]
    permissionCancelled: [text]
    sentControlResponses: [text]
    sentControlRequests: [text]
    sentRemoteMessages: [text]
    callbacks: [text]
    errors: [text]

impl RemoteSessionManager:
    static fn new(config: RemoteSessionConfig) -> RemoteSessionManager:
        RemoteSessionManager(config: config, websocketActive: false, websocketConnected: false, pendingPermissionRequestIds: [], pendingToolUseIds: [], receivedMessages: [], permissionRequests: [], permissionCancelled: [], sentControlResponses: [], sentControlRequests: [], sentRemoteMessages: [], callbacks: [], errors: [])

    me connect() -> ():
        me.websocketActive = true
        me.websocketConnected = true
        me.callbacks.push("connected")

    me handleMessage(message: RemoteMessage) -> ():
        if message.type == "control_request":
            me.handleControlRequest(message)
            return
        if message.type == "control_cancel_request":
            val idx = indexOfText(me.pendingPermissionRequestIds, message.request_id)
            var toolUseId = ""
            if idx >= 0:
                toolUseId = me.pendingToolUseIds[idx]
                me.pendingPermissionRequestIds = removeTextAt(me.pendingPermissionRequestIds, idx)
                me.pendingToolUseIds = removeTextAt(me.pendingToolUseIds, idx)
            me.permissionCancelled.push(message.request_id + ":" + toolUseId)
            return
        if message.type == "control_response":
            me.callbacks.push("control_response")
            return
        if isSDKMessage(message):
            me.receivedMessages.push(message.type + ":" + message.payload)

    me handleControlRequest(message: RemoteMessage) -> ():
        if message.subtype == "can_use_tool":
            me.pendingPermissionRequestIds.push(message.request_id)
            me.pendingToolUseIds.push(message.tool_use_id)
            me.permissionRequests.push(message.request_id + ":" + message.tool_name)
        else:
            me.sentControlResponses.push("error:" + message.request_id + ":Unsupported control request subtype: " + message.subtype)

    me sendMessage(content: text, uuid: text, success: bool) -> bool:
        me.sentRemoteMessages.push(me.config.sessionId + ":" + uuid + ":" + content)
        if not success:
            me.errors.push("Failed to send message to session " + me.config.sessionId)
        success

    me respondToPermissionRequest(requestId: text, result: RemotePermissionResponse) -> ():
        val idx = indexOfText(me.pendingPermissionRequestIds, requestId)
        if idx < 0:
            me.errors.push("No pending permission request with ID: " + requestId)
            return
        me.pendingPermissionRequestIds = removeTextAt(me.pendingPermissionRequestIds, idx)
        me.pendingToolUseIds = removeTextAt(me.pendingToolUseIds, idx)
        if result.behavior == "allow":
            me.sentControlResponses.push("success:" + requestId + ":allow:" + result.updatedInput)
        else:
            me.sentControlResponses.push("success:" + requestId + ":deny:" + result.message)

    me isConnected() -> bool:
        me.websocketActive and me.websocketConnected

    me cancelSession() -> ():
        if me.websocketActive:
            me.sentControlRequests.push("interrupt")

    me getSessionId() -> text:
        me.config.sessionId

    me disconnect() -> ():
        me.websocketConnected = false
        me.websocketActive = false
        me.pendingPermissionRequestIds = []
        me.pendingToolUseIds = []

    me reconnect() -> ():
        if me.websocketActive:
            me.callbacks.push("reconnecting")
            me.websocketConnected = true

fn isSDKMessage(message: RemoteMessage) -> bool:
    message.type != "control_request" and message.type != "control_response" and message.type != "control_cancel_request"

fn createRemoteSessionConfig(sessionId: text, accessToken: text, orgUuid: text, hasInitialPrompt: bool, viewerOnly: bool) -> RemoteSessionConfig:
    RemoteSessionConfig(sessionId: sessionId, accessToken: accessToken, orgUuid: orgUuid, hasInitialPrompt: hasInitialPrompt, viewerOnly: viewerOnly)

fn remoteMessage(type: text, payload: text) -> RemoteMessage:
    RemoteMessage(type: type, request_id: "", subtype: "", tool_use_id: "", tool_name: "", payload: payload)

fn permissionRequest(requestId: text, toolUseId: text, toolName: text) -> RemoteMessage:
    RemoteMessage(type: "control_request", request_id: requestId, subtype: "can_use_tool", tool_use_id: toolUseId, tool_name: toolName, payload: "")

fn unsupportedControlRequest(requestId: text, subtype: text) -> RemoteMessage:
    RemoteMessage(type: "control_request", request_id: requestId, subtype: subtype, tool_use_id: "", tool_name: "", payload: "")

fn controlCancel(requestId: text) -> RemoteMessage:
    RemoteMessage(type: "control_cancel_request", request_id: requestId, subtype: "", tool_use_id: "", tool_name: "", payload: "")

fn remotePermissionAllow(updatedInput: text) -> RemotePermissionResponse:
    RemotePermissionResponse(behavior: "allow", updatedInput: updatedInput, message: "")

fn remotePermissionDeny(message: text) -> RemotePermissionResponse:
    RemotePermissionResponse(behavior: "deny", updatedInput: "", message: message)

fn indexOfText(values: [text], value: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return i
        i = i + 1
    -1

fn removeTextAt(values: [text], index: i64) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if i != index:
            out.push(values[i])
        i = i + 1
    out

fn remoteSessionManagerSourceLinesModeled() -> i64:
    343

# ponytail: websocket and HTTP calls are state/log entries; add real IO only when this Simple port owns remote transport.
# Source parity note: SDK messages exclude control request/response/cancel messages.
# Source parity note: connect creates a session websocket and fires connected callback.
# Source parity note: can_use_tool requests are stored until response or cancellation.
# Source parity note: unsupported control subtypes send error responses.
# Source parity note: control cancel removes pending permission and reports tool_use_id.
# Source parity note: permission responses delete pending request before sending success.
# Source parity note: missing permission requests log an error and do not send.
# Source parity note: sendMessage returns false and logs on remote POST failure.
# Source parity note: cancelSession sends interrupt through websocket.
# Source parity note: disconnect closes websocket and clears pending permission requests.
