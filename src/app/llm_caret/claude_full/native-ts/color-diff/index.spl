"""
Pure Simple parity model for native-ts/color-diff/index.ts.

It keeps the public surface and deterministic rendering behavior needed by the
Claude CLI diff UI without loading highlight.js or shelling out.
"""

class Hunk:
    oldStart: i64
    oldLines: i64
    newStart: i64
    newLines: i64
    lines: [text]

impl Hunk:
    static fn new(oldStart: i64, oldLines: i64, newStart: i64, newLines: i64, lines: [text]) -> Hunk:
        Hunk(oldStart: oldStart, oldLines: oldLines, newStart: newStart, newLines: newLines, lines: lines)

class SyntaxTheme:
    theme: text
    source: text

impl SyntaxTheme:
    static fn new(theme: text, source: text) -> SyntaxTheme:
        SyntaxTheme(theme: theme, source: source)

class NativeModule:
    hasColorDiff: bool
    hasColorFile: bool
    hasSyntaxTheme: bool

impl NativeModule:
    static fn new() -> NativeModule:
        NativeModule(hasColorDiff: true, hasColorFile: true, hasSyntaxTheme: true)

class Color:
    r: i64
    g: i64
    b: i64
    a: i64

impl Color:
    static fn rgb(r: i64, g: i64, b: i64) -> Color:
        Color(r: r, g: g, b: b, a: 255)

    static fn ansiIdx(index: i64) -> Color:
        Color(r: index, g: 0, b: 0, a: 0)

    static fn defaultBg() -> Color:
        Color(r: 0, g: 0, b: 0, a: 1)

class Style:
    foreground: Color
    background: Color

impl Style:
    static fn new(foreground: Color, background: Color) -> Style:
        Style(foreground: foreground, background: background)

class Block:
    style: Style
    textValue: text

impl Block:
    static fn new(style: Style, textValue: text) -> Block:
        Block(style: style, textValue: textValue)

class Range:
    start: i64
    end: i64

impl Range:
    static fn new(start: i64, end: i64) -> Range:
        Range(start: start, end: end)

class Highlight:
    marker: text
    lineNumber: i64
    lines: [text]

impl Highlight:
    static fn new(marker: text, lineNumber: i64, lines: [text]) -> Highlight:
        Highlight(marker: marker, lineNumber: lineNumber, lines: lines)

fn hljs() -> text:
    "lazy-highlight-js"

fn rgb(r: i64, g: i64, b: i64) -> Color:
    Color.rgb(r, g, b)

fn ansiIdx(index: i64) -> Color:
    Color.ansiIdx(index)

fn detectColorMode(theme: text, colorterm: text) -> text:
    if theme.contains("ansi"):
        return "ansi"
    if colorterm == "truecolor" or colorterm == "24bit":
        return "truecolor"
    "color256"

fn ansi256FromRgb(r: i64, g: i64, b: i64) -> i64:
    val qr = ansiCubeIndex(r)
    val qg = ansiCubeIndex(g)
    val qb = ansiCubeIndex(b)
    val cubeIdx = 16 + (36 * qr) + (6 * qg) + qb
    val grey = (r + g + b) / 3
    if grey < 5:
        return 16
    if grey > 244 and qr == qg and qg == qb:
        return cubeIdx
    var greyLevel = (grey - 8 + 5) / 10
    if greyLevel < 0:
        greyLevel = 0
    if greyLevel > 23:
        greyLevel = 23
    val greyIdx = 232 + greyLevel
    val greyRgb = 8 + (greyLevel * 10)
    val cr = cubeLevel(qr)
    val cg = cubeLevel(qg)
    val cb = cubeLevel(qb)
    val dCube = square(r - cr) + square(g - cg) + square(b - cb)
    val dGrey = square(r - greyRgb) + square(g - greyRgb) + square(b - greyRgb)
    if dGrey < dCube:
        return greyIdx
    cubeIdx

fn ansiCubeIndex(c: i64) -> i64:
    if c < 48:
        return 0
    if c < 115:
        return 1
    if c < 155:
        return 2
    if c < 195:
        return 3
    if c < 235:
        return 4
    5

fn cubeLevel(i: i64) -> i64:
    if i == 1:
        return 95
    if i == 2:
        return 135
    if i == 3:
        return 175
    if i == 4:
        return 215
    if i == 5:
        return 255
    0

fn square(v: i64) -> i64:
    v * v

fn colorToEscape(c: Color, fg: bool, mode: text) -> text:
    if c.a == 0:
        val idx = c.r
        if idx < 8:
            if fg:
                return "\u001B[" + (30 + idx).to_text() + "m"
            return "\u001B[" + (40 + idx).to_text() + "m"
        if idx < 16:
            if fg:
                return "\u001B[" + (90 + idx - 8).to_text() + "m"
            return "\u001B[" + (100 + idx - 8).to_text() + "m"
        if fg:
            return "\u001B[38;5;" + idx.to_text() + "m"
        return "\u001B[48;5;" + idx.to_text() + "m"
    if c.a == 1:
        if fg:
            return "\u001B[39m"
        return "\u001B[49m"
    if mode == "truecolor":
        if fg:
            return "\u001B[38;2;" + c.r.to_text() + ";" + c.g.to_text() + ";" + c.b.to_text() + "m"
        return "\u001B[48;2;" + c.r.to_text() + ";" + c.g.to_text() + ";" + c.b.to_text() + "m"
    if fg:
        return "\u001B[38;5;" + ansi256FromRgb(c.r, c.g, c.b).to_text() + "m"
    "\u001B[48;5;" + ansi256FromRgb(c.r, c.g, c.b).to_text() + "m"

fn asTerminalEscaped(blocks: [Block], mode: text, skipBackground: bool, dim: bool) -> text:
    var out = "\u001B[0m"
    if dim:
        out = out + "\u001B[2m"
    var i = 0
    while i < blocks.len():
        out = out + colorToEscape(blocks[i].style.foreground, true, mode)
        if not skipBackground:
            out = out + colorToEscape(blocks[i].style.background, false, mode)
        out = out + blocks[i].textValue
        i = i + 1
    out + "\u001B[0m"

fn defaultSyntaxThemeName(themeName: text) -> text:
    if themeName.contains("ansi"):
        return "ansi"
    if themeName.contains("dark"):
        return "Monokai Extended"
    "GitHub"

fn buildTheme(themeName: text, mode: text) -> text:
    defaultSyntaxThemeName(themeName) + ":" + mode

fn defaultStyle(theme: text) -> Style:
    Style.new(Color.rgb(248, 248, 242), Color.defaultBg())

fn lineBackground(marker: text) -> text:
    if marker == "+":
        return "addLine"
    if marker == "-":
        return "deleteLine"
    "background"

fn wordBackground(marker: text) -> text:
    if marker == "+":
        return "addWord"
    if marker == "-":
        return "deleteWord"
    "background"

fn decorationColor(marker: text) -> text:
    if marker == "+":
        return "addDecoration"
    if marker == "-":
        return "deleteDecoration"
    "foreground"

fn detectLanguage(filePath: text, firstLine: text) -> text:
    if firstLine.starts_with("#!"):
        return "shell"
    if filePath.ends_with(".ts") or filePath.ends_with(".tsx"):
        return "typescript"
    if filePath.ends_with(".js") or filePath.ends_with(".jsx"):
        return "javascript"
    if filePath.ends_with(".py"):
        return "python"
    if filePath.ends_with(".md"):
        return "markdown"
    "plaintext"

fn scopeColor(scope: text, theme: text) -> text:
    theme + ":" + scope

fn flattenHljs(code: text, language: text) -> [Block]:
    [Block.new(defaultStyle(language), code)]

fn hasRootNode(code: text) -> bool:
    code != ""

fn highlightLine(lang: text, code: text, theme: text) -> [Block]:
    flattenHljs(code, lang + ":" + theme)

fn tokenize(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == " ":
            if current != "":
                out.push(current)
                current = ""
            out.push(" ")
        else:
            current = current + ch
        i = i + 1
    if current != "":
        out.push(current)
    out

fn findAdjacentPairs(markers: [text]) -> [Range]:
    var out: [Range] = []
    var i = 0
    while i + 1 < markers.len():
        if markers[i] == "-" and markers[i + 1] == "+":
            out.push(Range.new(i, i + 1))
        i = i + 1
    out

fn wordDiffStrings(oldValue: text, newValue: text) -> [Range]:
    if oldValue == newValue:
        return []
    [Range.new(0, oldValue.len()), Range.new(0, newValue.len())]

fn len(value: text) -> i64:
    value.len()

fn removeNewlines(line: text) -> text:
    line.replace("\n", "")

fn charWidth(ch: text) -> i64:
    if ch.len() > 1:
        return 2
    1

fn wrapText(line: text, width: i64) -> [text]:
    if width <= 0 or line.len() <= width:
        return [line]
    var out: [text] = []
    var i = 0
    while i < line.len():
        var end = i + width
        if end > line.len():
            end = line.len()
        out.push(line.slice(i, end))
        i = end
    out

fn curW(line: text) -> i64:
    line.len()

fn addLineNumber(line: text, lineNumber: i64, maxDigits: i64, dim: bool) -> text:
    leftPad(lineNumber.to_text(), maxDigits) + " " + line

fn addMarker(line: text, marker: text) -> text:
    marker + line

fn dimContent(line: text) -> text:
    "\u001B[2m" + line + "\u001B[22m"

fn applyBackground(line: text, marker: text) -> text:
    lineBackground(marker) + ":" + line

fn intoLines(lines: [text], dim: bool, skipBg: bool, mode: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < lines.len():
        out.push(lines[i])
        i = i + 1
    out

fn maxLineNumber(hunk: Hunk) -> i64:
    val oldEnd = maxI64(0, hunk.oldStart + hunk.oldLines - 1)
    val newEnd = maxI64(0, hunk.newStart + hunk.newLines - 1)
    maxI64(oldEnd, newEnd)

fn parseMarker(s: text) -> text:
    if s == "+" or s == "-":
        return s
    " "

class ColorDiff:
    hunk: Hunk
    firstLine: text
    filePath: text
    prefixContent: text

impl ColorDiff:
    static fn new(hunk: Hunk, firstLine: text, filePath: text, prefixContent: text) -> ColorDiff:
        ColorDiff(hunk: hunk, firstLine: firstLine, filePath: filePath, prefixContent: prefixContent)

    me render(themeName: text, width: i64, dim: bool) -> [text]:
        val mode = detectColorMode(themeName, "")
        val theme = buildTheme(themeName, mode)
        val lang = detectLanguage(me.filePath, me.firstLine)
        val maxDigits = maxLineNumber(me.hunk).to_text().len()
        var oldLine = me.hunk.oldStart
        var newLine = me.hunk.newStart
        var out: [text] = []
        var i = 0
        while i < me.hunk.lines.len():
            val raw = me.hunk.lines[i]
            val marker = parseMarker(raw.slice(0, 1))
            val code = raw.slice(1, raw.len())
            var lineNo = newLine
            if marker == "+":
                lineNo = newLine
                newLine = newLine + 1
            else if marker == "-":
                lineNo = oldLine
                oldLine = oldLine + 1
            else:
                lineNo = newLine
                oldLine = oldLine + 1
                newLine = newLine + 1
            val highlighted = removeNewlines(code)
            val effectiveWidth = maxI64(1, width - maxDigits - 3)
            val wrapped = wrapText(highlighted, effectiveWidth)
            var j = 0
            while j < wrapped.len():
                var line = addMarker(wrapped[j], marker)
                line = addLineNumber(line, lineNo, maxDigits, dim)
                if dim and marker == "-":
                    line = dimContent(line)
                out.push(line + ":" + lang + ":" + theme)
                j = j + 1
            i = i + 1
        out

class ColorFile:
    code: text
    filePath: text

impl ColorFile:
    static fn new(code: text, filePath: text) -> ColorFile:
        ColorFile(code: code, filePath: filePath)

    me render(themeName: text, width: i64, dim: bool) -> [text]:
        val lines = splitLinesDropTrailing(me.code)
        val mode = detectColorMode(themeName, "")
        val theme = buildTheme(themeName, mode)
        val firstLine = firstLineOrEmpty(lines)
        val lang = detectLanguage(me.filePath, firstLine)
        val maxDigits = lines.len().to_text().len()
        var out: [text] = []
        var i = 0
        while i < lines.len():
            val effectiveWidth = maxI64(1, width - maxDigits - 2)
            val wrapped = wrapText(removeNewlines(lines[i]), effectiveWidth)
            var j = 0
            while j < wrapped.len():
                out.push(addLineNumber(wrapped[j], i + 1, maxDigits, dim) + ":" + lang + ":" + theme)
                j = j + 1
            i = i + 1
        out

fn getSyntaxTheme(themeName: text) -> SyntaxTheme:
    SyntaxTheme.new(defaultSyntaxThemeName(themeName), "")

fn getNativeModule() -> NativeModule:
    NativeModule.new()

fn leftPad(value: text, width: i64) -> text:
    var out = value
    while out.len() < width:
        out = " " + out
    out

fn maxI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn splitLinesDropTrailing(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == "\n":
            out.push(current)
            current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        out.push(current)
    out

fn firstLineOrEmpty(lines: [text]) -> text:
    if lines.len() == 0:
        return ""
    lines[0]

fn colorDiffSourceLinesModeled() -> i64:
    999
