const BASH_SECURITY_SOURCE_LINES = 2592

fn stripSafeHeredocSubstitutionsRoute(hasQuotedDelimiter: bool, hasCommandSubstitution: bool) -> text:
    if hasCommandSubstitution && hasQuotedDelimiter:
        return "stripped safe heredoc substitution"
    if hasCommandSubstitution:
        return "unsafe heredoc substitution"
    "no heredoc substitution"

fn hasSafeHeredocSubstitutionRoute(hasQuotedDelimiter: bool, hasCommandSubstitution: bool) -> bool:
    stripSafeHeredocSubstitutionsRoute(hasQuotedDelimiter, hasCommandSubstitution) == "stripped safe heredoc substitution"

fn bashCommandIsSafeDeprecatedRoute(command: text) -> text:
    if command.starts_with("\t") || command.starts_with("&&") || command.starts_with("||") || command.starts_with("|"):
        return "ask incomplete command"
    val trimmed = command.trim()
    if trimmed == "":
        return "passthrough"
    if hasSafeHeredocSubstitutionRoute(command.contains("<<'EOF'"), command.contains("$(cat <<")):
        return "passthrough"
    if command.starts_with("git commit -m ") && command.contains("$("):
        return "ask git commit substitution"
    if command.starts_with("git commit -m "):
        return "passthrough"
    if command.starts_with("jq -f "):
        return "ask jq file"
    if command.starts_with("find "):
        return "passthrough"
    "ask"

fn bashCommandIsSafeAsyncDeprecatedRoute(command: text) -> text:
    bashCommandIsSafeDeprecatedRoute(command)

fn bashSecuritySourceLinesModeled() -> i64:
    BASH_SECURITY_SOURCE_LINES
