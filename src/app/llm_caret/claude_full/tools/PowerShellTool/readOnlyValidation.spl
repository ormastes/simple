const POWERSHELL_READ_ONLY_VALIDATION_SOURCE_LINES = 1823

fn hasSyncSecurityConcernsRoute(command: text) -> bool:
    command.contains("$(") || command.contains("@splat") || command.contains("]::")

fn isAllowlistedCommandRoute(command: text) -> bool:
    command.starts_with("Get-Content") || command.starts_with("Get-ChildItem") || command.starts_with("Write-Output") || command.starts_with("Select-Object")

fn isReadOnlyCommandRoute(command: text) -> bool:
    val trimmed = command.trim()
    if trimmed == "":
        return false
    if hasSyncSecurityConcernsRoute(trimmed):
        return false
    if trimmed.contains(">") || trimmed.contains("Set-Location") || trimmed.contains("cd "):
        return false
    if trimmed.contains("| Select-Object"):
        return true
    isAllowlistedCommandRoute(trimmed)

fn powershellReadOnlyValidationSourceLinesModeled() -> i64:
    POWERSHELL_READ_ONLY_VALIDATION_SOURCE_LINES
