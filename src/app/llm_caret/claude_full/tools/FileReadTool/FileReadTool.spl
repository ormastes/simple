"""
Claude full FileReadTool parity model.

This module models the source FileReadTool contract with deterministic data
objects so system specs can verify branches without filesystem or SDK calls.
"""

class MaxFileReadTokenExceededError:
    tokenCount: i64
    maxTokens: i64
    name: text
    message: text

impl MaxFileReadTokenExceededError:
    static fn new(tokenCount: i64, maxTokens: i64) -> MaxFileReadTokenExceededError:
        MaxFileReadTokenExceededError(
            tokenCount: tokenCount,
            maxTokens: maxTokens,
            name: "MaxFileReadTokenExceededError",
            message: "File content (" + tokenCount.to_text() + " tokens) exceeds maximum allowed tokens (" + maxTokens.to_text() + "). Use offset and limit parameters to read specific portions of the file, or search for specific content instead of reading the whole file."
        )

class FileReadListener:
    name: text
    path: text
    content: text
    calls: i64
    subscribed: bool

impl FileReadListener:
    static fn new(name: text) -> FileReadListener:
        FileReadListener(name: name, path: "", content: "", calls: 0, subscribed: true)

class FileReadListenerRegistry:
    listeners: [FileReadListener]

impl FileReadListenerRegistry:
    static fn new() -> FileReadListenerRegistry:
        FileReadListenerRegistry(listeners: [])

class FileReadInput:
    filePath: text
    content: text
    ext: text
    offset: i64
    limit: i64
    pages: text
    maxSizeBytes: i64
    maxTokens: i64
    tokenCount: i64
    totalLines: i64
    mtimeMs: i64
    originalSize: i64
    width: i64
    height: i64
    pdfPages: i64
    exists: bool
    supportedPdf: bool
    emptyImage: bool

impl FileReadInput:
    static fn textFile(filePath: text, content: text, ext: text, totalLines: i64) -> FileReadInput:
        FileReadInput(filePath: filePath, content: content, ext: ext, offset: 1, limit: 0, pages: "", maxSizeBytes: 1048576, maxTokens: 20000, tokenCount: 100, totalLines: totalLines, mtimeMs: 1000, originalSize: content.len(), width: 0, height: 0, pdfPages: 0, exists: true, supportedPdf: true, emptyImage: false)

class ImageResult:
    typeName: text
    base64: text
    mediaType: text
    originalSize: i64
    dimensions: text
    compression: text
    tokenEstimate: i64

impl ImageResult:
    static fn new(base64: text, mediaType: text, originalSize: i64, dimensions: text, compression: text, tokenEstimate: i64) -> ImageResult:
        ImageResult(typeName: "image", base64: base64, mediaType: mediaType, originalSize: originalSize, dimensions: dimensions, compression: compression, tokenEstimate: tokenEstimate)

class FileReadOutput:
    typeName: text
    filePath: text
    content: text
    numLines: i64
    startLine: i64
    totalLines: i64
    image: ImageResult
    newMessages: [text]
    error: MaxFileReadTokenExceededError
    errorMessage: text
    readStateKey: text
    freshnessPrefix: text

impl FileReadOutput:
    static fn text(filePath: text, content: text, numLines: i64, startLine: i64, totalLines: i64, readStateKey: text, freshnessPrefix: text) -> FileReadOutput:
        FileReadOutput(typeName: "text", filePath: filePath, content: content, numLines: numLines, startLine: startLine, totalLines: totalLines, image: ImageResult.new("", "", 0, "", "", 0), newMessages: [], error: MaxFileReadTokenExceededError.new(0, 0), errorMessage: "", readStateKey: readStateKey, freshnessPrefix: freshnessPrefix)

    static fn image(filePath: text, image: ImageResult, newMessages: [text]) -> FileReadOutput:
        FileReadOutput(typeName: "image", filePath: filePath, content: "", numLines: 0, startLine: 0, totalLines: 0, image: image, newMessages: newMessages, error: MaxFileReadTokenExceededError.new(0, 0), errorMessage: "", readStateKey: filePath, freshnessPrefix: "")

    static fn notebook(filePath: text, cellsJson: text) -> FileReadOutput:
        FileReadOutput(typeName: "notebook", filePath: filePath, content: cellsJson, numLines: 0, startLine: 0, totalLines: 0, image: ImageResult.new("", "", 0, "", "", 0), newMessages: [], error: MaxFileReadTokenExceededError.new(0, 0), errorMessage: "", readStateKey: filePath, freshnessPrefix: "")

    static fn pdf(filePath: text, base64: text, messages: [text]) -> FileReadOutput:
        FileReadOutput(typeName: "pdf", filePath: filePath, content: base64, numLines: 0, startLine: 0, totalLines: 0, image: ImageResult.new("", "application/pdf", base64.len(), "", "", 0), newMessages: messages, error: MaxFileReadTokenExceededError.new(0, 0), errorMessage: "", readStateKey: filePath, freshnessPrefix: "")

    static fn failed(message: text) -> FileReadOutput:
        FileReadOutput(typeName: "error", filePath: "", content: "", numLines: 0, startLine: 0, totalLines: 0, image: ImageResult.new("", "", 0, "", "", 0), newMessages: [], error: MaxFileReadTokenExceededError.new(0, 0), errorMessage: message, readStateKey: "", freshnessPrefix: "")

    static fn tokenFailed(error: MaxFileReadTokenExceededError) -> FileReadOutput:
        FileReadOutput(typeName: "error", filePath: "", content: "", numLines: 0, startLine: 0, totalLines: 0, image: ImageResult.new("", "", 0, "", "", 0), newMessages: [], error: error, errorMessage: error.message, readStateKey: "", freshnessPrefix: "")

fn isBlockedDevicePath(filePath: text) -> bool:
    val normalized = normalizePath(filePath)
    if normalized == "/dev/zero" or normalized == "/dev/random" or normalized == "/dev/urandom" or normalized == "/dev/full":
        return true
    if normalized == "/dev/stdin" or normalized == "/dev/stdout" or normalized == "/dev/stderr" or normalized == "/dev/tty" or normalized == "/dev/console":
        return true
    if normalized == "/dev/fd/0" or normalized == "/dev/fd/1" or normalized == "/dev/fd/2":
        return true
    normalized.starts_with("/proc/") and (normalized.ends_with("/fd/0") or normalized.ends_with("/fd/1") or normalized.ends_with("/fd/2"))

fn getAlternateScreenshotPath(filePath: text) -> text:
    if not filePath.ends_with(".png"):
        return ""
    val thin = thinSpace()
    if filePath.contains(" AM.png"):
        return filePath.replace(" AM.png", thin + "AM.png")
    if filePath.contains(" PM.png"):
        return filePath.replace(" PM.png", thin + "PM.png")
    if filePath.contains(thin + "AM.png"):
        return filePath.replace(thin + "AM.png", " AM.png")
    if filePath.contains(thin + "PM.png"):
        return filePath.replace(thin + "PM.png", " PM.png")
    ""

fn registerFileReadListener(registry: FileReadListenerRegistry, name: text) -> FileReadListenerRegistry:
    var out: [FileReadListener] = []
    var i = 0
    while i < registry.listeners.len():
        if registry.listeners[i].name != name:
            out.push(registry.listeners[i])
        i = i + 1
    out.push(FileReadListener.new(name))
    FileReadListenerRegistry(listeners: out)

fn unregisterFileReadListener(registry: FileReadListenerRegistry, name: text) -> FileReadListenerRegistry:
    var out: [FileReadListener] = []
    var i = 0
    while i < registry.listeners.len():
        if registry.listeners[i].name != name:
            out.push(registry.listeners[i])
        i = i + 1
    FileReadListenerRegistry(listeners: out)

fn notifyFileRead(registry: FileReadListenerRegistry, filePath: text, content: text) -> FileReadListenerRegistry:
    var out: [FileReadListener] = []
    var i = 0
    while i < registry.listeners.len():
        var item = registry.listeners[i]
        if item.subscribed:
            item.path = filePath
            item.content = content
            item.calls = item.calls + 1
        out.push(item)
        i = i + 1
    FileReadListenerRegistry(listeners: out)

fn detectSessionFileType(filePath: text, configDir: text) -> text:
    val normalized = normalizePath(filePath)
    val root = trimTrailingSlash(normalizePath(configDir))
    if not normalized.starts_with(root + "/"):
        return ""
    val rel = normalized.slice(root.len(), normalized.len())
    if rel.starts_with("/session-memory/") and rel.ends_with(".md"):
        return "session_memory"
    if rel.starts_with("/projects/") and rel.ends_with(".jsonl"):
        return "session_transcript"
    ""

fn inputSchema() -> text:
    "file_path|required; offset|optional; limit|optional; pages|optional; maxTokens|internal"

fn outputSchema() -> text:
    "text(filePath,content,numLines,startLine,totalLines) | image(base64,media_type,originalSize,dimensions) | notebook(cells) | pdf(base64)"

fn pickLineFormatInstruction(offset: i64, limit: i64) -> text:
    if offset > 1 or limit > 0:
        return "Line numbers are 1-based for the selected range."
    "Line numbers are shown as cat -n style file lines."

fn formatFileLines(lines: [text], startLine: i64) -> text:
    var out = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            out = out + "\n"
        out = out + (startLine + i).to_text() + "→" + lines[i]
        i = i + 1
    out

fn shouldIncludeFileReadMitigation(modelName: text) -> bool:
    modelName != "claude-opus-4-6"

fn memoryFileFreshnessPrefix(filePath: text, mtimeMs: i64, nowMs: i64) -> text:
    if not isAutoMemFile(filePath):
        return ""
    val ageSeconds = (nowMs - mtimeMs) / 1000
    "<system-reminder>Memory file last modified " + ageSeconds.to_text() + " seconds ago.</system-reminder>\n"

fn validateContentTokens(tokenCount: i64, maxTokens: i64, hasRange: bool) -> MaxFileReadTokenExceededError:
    if hasRange:
        return MaxFileReadTokenExceededError.new(0, 0)
    if tokenCount > maxTokens:
        return MaxFileReadTokenExceededError.new(tokenCount, maxTokens)
    MaxFileReadTokenExceededError.new(0, 0)

fn createImageResponse(base64: text, mediaType: text, originalSize: i64, width: i64, height: i64) -> ImageResult:
    var dimensions = ""
    if width > 0 and height > 0:
        dimensions = width.to_text() + "x" + height.to_text()
    ImageResult.new(base64, "image/" + mediaType, originalSize, dimensions, "standard", estimateImageTokens(originalSize))

fn callInner(input: FileReadInput, registry: FileReadListenerRegistry, configDir: text, modelName: text) -> FileReadOutput:
    if isBlockedDevicePath(input.filePath):
        return FileReadOutput.failed("Blocked device path: " + input.filePath)
    if not input.exists:
        val alternate = getAlternateScreenshotPath(input.filePath)
        if alternate != "":
            return FileReadOutput.failed("File does not exist. Did you mean " + alternate + "?")
        return FileReadOutput.failed("File does not exist: " + input.filePath)
    val hasRange = input.offset > 1 or input.limit > 0 or input.pages != ""
    val tokenError = validateContentTokens(input.tokenCount, input.maxTokens, hasRange)
    if tokenError.tokenCount > 0:
        return FileReadOutput.tokenFailed(tokenError)
    if input.ext == "ipynb":
        return FileReadOutput.notebook(input.filePath, input.content)
    if containsTextFileRead(imageFiles(), input.ext):
        if input.emptyImage:
            return FileReadOutput.failed("Image file is empty: " + input.filePath)
        val image = readImageWithTokenBudget(input.filePath, input.content, input.ext, input.originalSize, input.width, input.height, input.maxTokens)
        var messages: [text] = []
        if image.dimensions != "":
            messages.push("image metadata: " + image.dimensions)
        return FileReadOutput.image(input.filePath, image, messages)
    if input.ext == "pdf":
        if input.pages != "":
            return FileReadOutput.pdf(input.filePath, "pdf-pages:" + input.pages, ["pdf pages extracted"])
        if input.pdfPages > 100:
            return FileReadOutput.failed("This PDF has " + input.pdfPages.to_text() + " pages, which is too many to read at once. Use the pages parameter to read specific page ranges (e.g., pages: \"1-5\").")
        if not input.supportedPdf:
            return FileReadOutput.failed("Reading full PDFs is not supported with this model. Use a newer model or use the pages parameter.")
        return FileReadOutput.pdf(input.filePath, input.content, ["document:application/pdf"])
    val notified = notifyFileRead(registry, input.filePath, input.content)
    val _listenerCount = notified.listeners.len()
    val lineCount = effectiveLineCount(input.content, input.limit, input.totalLines)
    val prefix = memoryFileFreshnessPrefix(input.filePath, input.mtimeMs, input.mtimeMs + 5000)
    val mitigation = if shouldIncludeFileReadMitigation(modelName) { "\n\n<system-reminder>Whenever you read a file, consider cyber risk mitigation.</system-reminder>" } else { "" }
    FileReadOutput.text(input.filePath, input.content + mitigation, lineCount, input.offset, input.totalLines, input.filePath, prefix)

fn imageFiles() -> [text]:
    ["png", "jpg", "jpeg", "gif", "webp"]

fn readImageWithTokenBudget(filePath: text, base64: text, ext: text, originalSize: i64, width: i64, height: i64, maxTokens: i64) -> ImageResult:
    val tokenEstimate = estimateImageTokens(originalSize)
    var compression = "standard"
    var size = originalSize
    if tokenEstimate > maxTokens:
        compression = "aggressive"
        size = maxTokens * 4
    var media = ext
    if media == "jpg":
        media = "jpeg"
    ImageResult.new(base64, "image/" + media, size, width.to_text() + "x" + height.to_text(), compression, minI64(tokenEstimate, maxTokens))

fn normalizePath(path: text) -> text:
    var out = path.replace("\\", "/")
    while out.contains("//"):
        out = out.replace("//", "/")
    out

fn trimTrailingSlash(path: text) -> text:
    if path.len() > 1 and path.ends_with("/"):
        return path.slice(0, path.len() - 1)
    path

fn thinSpace() -> text:
    " "

fn isAutoMemFile(filePath: text) -> bool:
    filePath.contains("/session-memory/") and filePath.ends_with(".md")

fn effectiveLineCount(content: text, limit: i64, totalLines: i64) -> i64:
    if limit > 0 and limit < totalLines:
        return limit
    if totalLines > 0:
        return totalLines
    if content == "":
        return 0
    var count = 1
    var i = 0
    while i < content.len():
        if content.slice(i, i + 1) == "\n":
            count = count + 1
        i = i + 1
    count

fn estimateImageTokens(originalSize: i64) -> i64:
    val tokens = originalSize / 4
    if tokens < 1:
        return 1
    tokens

fn containsTextFileRead(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn fileReadToolSourceLinesModeled() -> i64:
    1183
