"""
Importable alias for Claude full thinkback-play command parity.
"""

class ThinkbackPlayRequest:
    id: text
    mode: text

impl ThinkbackPlayRequest:
    static fn new(id: text, mode: text) -> ThinkbackPlayRequest:
        ThinkbackPlayRequest(id: id.trim(), mode: mode.trim())

fn thinkbackPlayCommandName() -> text:
    "thinkback-play"

fn normalizedThinkbackPlayMode(mode: text) -> text:
    val value = mode.trim().to_lower()
    if value == "quiet" or value == "interactive":
        return value
    "interactive"

fn thinkbackPlaySummary(request: ThinkbackPlayRequest) -> text:
    if request.id == "":
        return "No thinkback selected"
    "Playing thinkback " + request.id + " in " + normalizedThinkbackPlayMode(request.mode) + " mode"

fn thinkbackPlaySourceLinesModeled() -> i64:
    43
