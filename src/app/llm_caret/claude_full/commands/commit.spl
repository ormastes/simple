"""
Claude full commit command parity.
"""

class PromptCommandDescriptor:
    typeName: text
    name: text
    description: text
    allowedTools: [text]
    contentLength: i64
    progressMessage: text
    source: text

impl PromptCommandDescriptor:
    static fn new(name: text, description: text, allowedTools: [text], contentLength: i64, progressMessage: text) -> PromptCommandDescriptor:
        PromptCommandDescriptor(typeName: "prompt", name: name, description: description, allowedTools: allowedTools, contentLength: contentLength, progressMessage: progressMessage, source: "builtin")

fn commitAllowedTools() -> [text]:
    ["Bash(git add:*)", "Bash(git status:*)", "Bash(git commit:*)"]

fn commitPromptContent(userType: text, undercover: bool, undercoverInstructions: text, commitAttribution: text) -> text:
    var prefix = ""
    if userType == "ant" and undercover:
        prefix = undercoverInstructions + "\n"
    var attribution = ""
    if commitAttribution != "":
        attribution = "\n\n" + commitAttribution
    prefix + "## Context\n\n- Current git status: !`git status`\n- Current git diff (staged and unstaged changes): !`git diff HEAD`\n- Current branch: !`git branch --show-current`\n- Recent commits: !`git log --oneline -10`\n\n## Git Safety Protocol\n\n- NEVER update the git config\n- NEVER skip hooks (--no-verify, --no-gpg-sign, etc) unless the user explicitly requests it\n- CRITICAL: ALWAYS create NEW commits. NEVER use git commit --amend, unless the user explicitly requests it\n- Do not commit files that likely contain secrets (.env, credentials.json, etc). Warn the user if they specifically request to commit those files\n- If there are no changes to commit (i.e., no untracked files and no modifications), do not create an empty commit\n- Never use git commands with the -i flag (like git rebase -i or git add -i) since they require interactive input which is not supported\n\n## Your task\n\nBased on the above changes, create a single git commit:\n\n1. Analyze all staged changes and draft a commit message\n2. Stage relevant files and create the commit using HEREDOC syntax:\n```shell\ngit commit -m \"$(cat <<'EOF'\nCommit message here." + attribution + "\nEOF\n)\"\n```"

fn commitCommandDescriptor() -> PromptCommandDescriptor:
    PromptCommandDescriptor.new("commit", "Create a git commit", commitAllowedTools(), 0, "creating commit")

fn commitSourceLinesModeled() -> i64:
    92
