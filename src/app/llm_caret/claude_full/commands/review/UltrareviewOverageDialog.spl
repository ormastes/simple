"""
Claude full UltrareviewOverageDialog parity.
"""

class UltrareviewOverage:
    used: i64
    limit: i64

impl UltrareviewOverage:
    static fn new(used: i64, limit: i64) -> UltrareviewOverage:
        UltrareviewOverage(used: used, limit: limit)

fn ultrareviewOverageMessage(overage: UltrareviewOverage) -> text:
    "Ultra review usage " + overage.used.to_text() + "/" + overage.limit.to_text()

fn ultrareviewIsOverLimit(overage: UltrareviewOverage) -> bool:
    overage.used > overage.limit

fn ultrareviewOverageDialogSourceLinesModeled() -> i64:
    95
