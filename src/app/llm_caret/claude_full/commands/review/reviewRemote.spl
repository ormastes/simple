"""
Claude full reviewRemote parity surface.
"""

class ReviewRemoteCommand:
    typeName: text
    name: text
    description: text
    argumentHint: text
    loadPath: text
    immediate: bool
    hidden: bool

impl ReviewRemoteCommand:
    static fn new() -> ReviewRemoteCommand:
        ReviewRemoteCommand(typeName: "local-jsx", name: "review", description: "Review a pull request from Claude Code remote", argumentHint: "[pull-request-url-or-number]", loadPath: "./reviewRemote.js", immediate: true, hidden: true)

class ReviewRemoteState:
    signedIn: bool
    remoteSessionId: text
    pullRequest: text
    baseBranch: text
    headBranch: text
    diffSummary: text
    fileCount: i64
    networkFailure: bool
    viewerOnly: bool

impl ReviewRemoteState:
    static fn new(signedIn: bool, remoteSessionId: text, pullRequest: text, baseBranch: text, headBranch: text, diffSummary: text, fileCount: i64, networkFailure: bool, viewerOnly: bool) -> ReviewRemoteState:
        ReviewRemoteState(signedIn: signedIn, remoteSessionId: remoteSessionId, pullRequest: pullRequest, baseBranch: baseBranch, headBranch: headBranch, diffSummary: diffSummary, fileCount: fileCount, networkFailure: networkFailure, viewerOnly: viewerOnly)

class ReviewRemoteResult:
    ok: bool
    stepName: text
    message: text
    prompt: text
    shouldStartRemote: bool
    allowMutationTools: bool

impl ReviewRemoteResult:
    static fn new(ok: bool, stepName: text, message: text, prompt: text, shouldStartRemote: bool, allowMutationTools: bool) -> ReviewRemoteResult:
        ReviewRemoteResult(ok: ok, stepName: stepName, message: message, prompt: prompt, shouldStartRemote: shouldStartRemote, allowMutationTools: allowMutationTools)

fn reviewRemoteCommand() -> ReviewRemoteCommand:
    ReviewRemoteCommand.new()

fn reviewRemoteCommandName() -> text:
    "review"

fn reviewRemoteLoadPath() -> text:
    "./reviewRemote.js"

fn reviewRemoteRequiresSignin(state: ReviewRemoteState) -> bool:
    not state.signedIn

fn reviewRemoteRequiresRemoteSession(state: ReviewRemoteState) -> bool:
    state.remoteSessionId.trim() == ""

fn reviewRemoteRequiresPullRequest(state: ReviewRemoteState) -> bool:
    state.pullRequest.trim() == ""

fn reviewRemoteHasDiff(state: ReviewRemoteState) -> bool:
    state.diffSummary.trim() != "" or state.fileCount > 0

fn reviewRemoteTargetLabel(state: ReviewRemoteState) -> text:
    val base = state.baseBranch.trim()
    val head = state.headBranch.trim()
    if base == "" and head == "":
        return "pull request"
    if base == "":
        return head
    if head == "":
        return base
    base + "..." + head

fn reviewRemoteNextStep(state: ReviewRemoteState) -> text:
    if reviewRemoteRequiresSignin(state):
        return "signin"
    if reviewRemoteRequiresRemoteSession(state):
        return "remote-session"
    if reviewRemoteRequiresPullRequest(state):
        return "pull-request"
    if not reviewRemoteHasDiff(state):
        return "load-diff"
    "review"

fn reviewRemotePrompt(state: ReviewRemoteState) -> text:
    val target = reviewRemoteTargetLabel(state)
    val pr = state.pullRequest.trim()
    val summary = state.diffSummary.trim()
    if summary == "":
        return "Review pull request " + pr + " (" + target + "). Focus on bugs, risks, regressions, and missing tests."
    "Review pull request " + pr + " (" + target + "). Diff summary: " + summary + ". Focus on bugs, risks, regressions, and missing tests."

fn reviewRemoteStatusLabel(state: ReviewRemoteState) -> text:
    val step = reviewRemoteNextStep(state)
    if step == "signin":
        return "Sign in required"
    if step == "remote-session":
        return "Remote session required"
    if step == "pull-request":
        return "Pull request required"
    if step == "load-diff":
        return "Load diff"
    "Ready to review"

fn callReviewRemote(state: ReviewRemoteState) -> ReviewRemoteResult:
    if state.networkFailure:
        return ReviewRemoteResult.new(false, "network", "Remote review failed: network error", "", false, false)
    val step = reviewRemoteNextStep(state)
    if step == "signin":
        return ReviewRemoteResult.new(false, step, "Sign in to Claude before remote review.", "", false, false)
    if step == "remote-session":
        return ReviewRemoteResult.new(false, step, "Connect a Claude Code remote session before review.", "", false, false)
    if step == "pull-request":
        return ReviewRemoteResult.new(false, step, "Provide a pull request URL or number to review.", "", false, false)
    if step == "load-diff":
        return ReviewRemoteResult.new(false, step, "Load pull request diff before review.", "", false, false)
    ReviewRemoteResult.new(true, step, "Starting remote review for " + state.pullRequest.trim(), reviewRemotePrompt(state), true, not state.viewerOnly)

fn reviewRemoteSourceLinesModeled() -> i64:
    316

