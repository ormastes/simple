"""
Claude full plugin ManageMarketplaces parity model.
"""

const MANAGE_MARKETPLACES_SOURCE_LINES = 837

class ManagedMarketplace:
    name: text
    sourceKind: text
    location: text
    scope: text
    enabled: bool

impl ManagedMarketplace:
    static fn new(name: text, sourceKind: text, location: text, scope: text, enabled: bool) -> ManagedMarketplace:
        ManagedMarketplace(name, sourceKind, location, scope, enabled)

class MarketplaceMutation:
    ok: bool
    message: text
    cacheCleared: bool
    eventName: text

impl MarketplaceMutation:
    static fn ok(message: text, eventName: text) -> MarketplaceMutation:
        MarketplaceMutation(true, message, true, eventName)

    static fn fail(message: text) -> MarketplaceMutation:
        MarketplaceMutation(false, message, false, "")

fn manageMarketplacesList(records: [ManagedMarketplace], includeDisabled: bool) -> text:
    if records.len() == 0:
        return "No marketplaces configured"
    var out = "Marketplaces:\n"
    var i = 0
    while i < records.len():
        val item = records[i]
        if includeDisabled or item.enabled:
            out = out + "  - " + item.name + " [" + item.scope + "] " + item.sourceKind + ":" + item.location + manageMarketplacesStateSuffix(item.enabled) + "\n"
        i = i + 1
    out

fn manageMarketplacesJson(records: [ManagedMarketplace], includeDisabled: bool) -> text:
    var out = "["
    var wrote = false
    var i = 0
    while i < records.len():
        val item = records[i]
        if includeDisabled or item.enabled:
            if wrote:
                out = out + ","
            out = out + "name=" + item.name + ";scope=" + item.scope + ";enabled=" + manageMarketplacesBoolJson(item.enabled)
            wrote = true
        i = i + 1
    out + "]"

fn manageMarketplacesValidateScope(scope: text) -> bool:
    scope == "user" or scope == "project" or scope == "local"

fn manageMarketplacesRemove(records: [ManagedMarketplace], name: text, scope: text) -> MarketplaceMutation:
    if not manageMarketplacesValidateScope(scope):
        return MarketplaceMutation.fail("Invalid scope: " + scope)
    if not manageMarketplacesExists(records, name, scope):
        return MarketplaceMutation.fail("Marketplace not found: " + name)
    MarketplaceMutation.ok("Removed marketplace: " + name, "tengu_marketplace_removed")

fn manageMarketplacesSetEnabled(records: [ManagedMarketplace], name: text, scope: text, enabled: bool) -> MarketplaceMutation:
    if not manageMarketplacesValidateScope(scope):
        return MarketplaceMutation.fail("Invalid scope: " + scope)
    if not manageMarketplacesExists(records, name, scope):
        return MarketplaceMutation.fail("Marketplace not found: " + name)
    val verb = if enabled: "Enabled" else: "Disabled"
    val event = if enabled: "tengu_marketplace_enabled" else: "tengu_marketplace_disabled"
    MarketplaceMutation.ok(verb + " marketplace: " + name, event)

fn manageMarketplacesExists(records: [ManagedMarketplace], name: text, scope: text) -> bool:
    var i = 0
    while i < records.len():
        val item = records[i]
        if item.name == name and item.scope == scope:
            return true
        i = i + 1
    false

fn manageMarketplacesStateSuffix(enabled: bool) -> text:
    if enabled:
        return ""
    " (disabled)"

fn manageMarketplacesBoolJson(value: bool) -> text:
    if value:
        return "true"
    "false"

fn manageMarketplacesSourceLinesModeled() -> i64:
    MANAGE_MARKETPLACES_SOURCE_LINES
