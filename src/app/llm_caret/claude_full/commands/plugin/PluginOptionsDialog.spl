"""
Claude full plugin options dialog parity model.
"""

const PLUGIN_OPTIONS_DIALOG_SOURCE_LINES = 356

class PluginOptionField:
    name: text
    label: text
    defaultValue: text
    value: text
    required: bool
    secret: bool

impl PluginOptionField:
    static fn new(name: text, label: text, defaultValue: text, value: text, required: bool, secret: bool) -> PluginOptionField:
        PluginOptionField(name, label, defaultValue, value, required, secret)

class PluginOptionsDialogProps:
    pluginName: text
    fields: [PluginOptionField]
    selectedIndex: i64
    saving: bool
    errorMessage: text

impl PluginOptionsDialogProps:
    static fn new(pluginName: text, fields: [PluginOptionField], selectedIndex: i64, saving: bool, errorMessage: text) -> PluginOptionsDialogProps:
        PluginOptionsDialogProps(pluginName, fields, selectedIndex, saving, errorMessage)

class PluginOptionsDialogModel:
    title: text
    rows: [text]
    finalValues: [text]
    focusedName: text
    canSave: bool
    saveLabel: text
    errorMessage: text

impl PluginOptionsDialogModel:
    static fn new(title: text, rows: [text], finalValues: [text], focusedName: text, canSave: bool, saveLabel: text, errorMessage: text) -> PluginOptionsDialogModel:
        PluginOptionsDialogModel(title, rows, finalValues, focusedName, canSave, saveLabel, errorMessage)

fn pluginOptionsValue(field: PluginOptionField) -> text:
    if field.value != "":
        return field.value
    field.defaultValue

fn pluginOptionsMask(field: PluginOptionField, value: text) -> text:
    if field.secret and value != "":
        return "********"
    value

fn pluginOptionsMissingRequired(fields: [PluginOptionField]) -> text:
    var i = 0
    while i < fields.len():
        val field = fields[i]
        if field.required and pluginOptionsValue(field) == "":
            return field.name
        i = i + 1
    ""

fn buildFinalValues(fields: [PluginOptionField]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < fields.len():
        val field = fields[i]
        out.push(field.name + "=" + pluginOptionsValue(field))
        i = i + 1
    out

fn pluginOptionsRows(props: PluginOptionsDialogProps) -> [text]:
    var rows: [text] = []
    var i = 0
    while i < props.fields.len():
        val field = props.fields[i]
        val prefix = if i == props.selectedIndex: "> " else: "  "
        val value = pluginOptionsMask(field, pluginOptionsValue(field))
        val mark = if field.required: " *" else: ""
        rows.push(prefix + field.label + mark + ": " + value)
        i = i + 1
    rows

fn pluginOptionsFocusedName(props: PluginOptionsDialogProps) -> text:
    if props.selectedIndex < 0 or props.selectedIndex >= props.fields.len():
        return ""
    props.fields[props.selectedIndex].name

fn PluginOptionsDialog(props: PluginOptionsDialogProps) -> PluginOptionsDialogModel:
    val missing = pluginOptionsMissingRequired(props.fields)
    val canSave = missing == "" and not props.saving
    val saveLabel = if props.saving: "Saving..." else: "Save"
    val error = if props.errorMessage != "": props.errorMessage else: if missing != "": "Missing required option: " + missing else: ""
    PluginOptionsDialogModel.new("Configure " + props.pluginName, pluginOptionsRows(props), buildFinalValues(props.fields), pluginOptionsFocusedName(props), canSave, saveLabel, error)

fn pluginOptionsDialogSubmit(props: PluginOptionsDialogProps) -> text:
    val model = PluginOptionsDialog(props)
    if not model.canSave:
        return model.errorMessage
    "save:" + props.pluginName

fn pluginOptionsDialogTemp() -> text:
    "submit"

fn pluginOptionsDialogTemp2() -> text:
    "cancel"

fn pluginOptionsDialogTemp3() -> text:
    "focus"

fn pluginOptionsDialogSourceLinesModeled() -> i64:
    PLUGIN_OPTIONS_DIALOG_SOURCE_LINES
