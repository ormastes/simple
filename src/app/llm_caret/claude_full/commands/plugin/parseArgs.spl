"""
Claude full plugin parseArgs parity.
"""

class PluginArgs:
    action: text
    target: text
    flags: [text]

impl PluginArgs:
    static fn new(action: text, target: text, flags: [text]) -> PluginArgs:
        PluginArgs(action: action, target: target, flags: flags)

fn parsePluginArgs(raw: text) -> PluginArgs:
    val trimmed = raw.trim()
    if trimmed == "":
        return PluginArgs.new("list", "", [])
    val parts = trimmed.split(" ")
    val action = parts[0]
    var target = ""
    var flags: [text] = []
    var i = 1
    while i < parts.len():
        if parts[i].starts_with("--"):
            flags.push(parts[i])
        else:
            if target == "":
                target = parts[i]
        i = i + 1
    PluginArgs.new(action, target, flags)

fn pluginArgsHasFlag(args: PluginArgs, flag: text) -> bool:
    var i = 0
    while i < args.flags.len():
        if args.flags[i] == flag:
            return true
        i = i + 1
    false

fn parseArgsSourceLinesModeled() -> i64:
    103
