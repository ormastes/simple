"""
Claude full plugin AddMarketplace parity model.
"""

const ADD_MARKETPLACE_SOURCE_LINES = 161

class AddMarketplaceRequest:
    source: text
    sourceKind: text
    scope: text
    sparse: [text]
    alreadyMaterialized: bool
    cowork: bool

impl AddMarketplaceRequest:
    static fn new(source: text, sourceKind: text, scope: text, sparse: [text], alreadyMaterialized: bool, cowork: bool) -> AddMarketplaceRequest:
        AddMarketplaceRequest(source, sourceKind, scope, sparse, alreadyMaterialized, cowork)

class AddMarketplaceResult:
    ok: bool
    message: text
    marketplaceName: text
    sourceKind: text
    scope: text
    cacheCleared: bool
    eventName: text

impl AddMarketplaceResult:
    static fn ok(message: text, marketplaceName: text, sourceKind: text, scope: text, cacheCleared: bool, eventName: text) -> AddMarketplaceResult:
        AddMarketplaceResult(true, message, marketplaceName, sourceKind, scope, cacheCleared, eventName)

    static fn fail(message: text) -> AddMarketplaceResult:
        AddMarketplaceResult(false, message, "", "", "", false, "")

fn addMarketplaceDefaultScope(scope: text) -> text:
    if scope == "":
        return "user"
    scope

fn addMarketplaceValidScope(scope: text) -> bool:
    scope == "user" or scope == "project" or scope == "local"

fn addMarketplaceValidSourceKind(kind: text) -> bool:
    kind == "github" or kind == "git" or kind == "url" or kind == "directory" or kind == "file"

fn addMarketplaceSparseAllowed(kind: text) -> bool:
    kind == "github" or kind == "git"

fn addMarketplaceInferSourceKind(source: text) -> text:
    if source.starts_with("http://") or source.starts_with("https://"):
        if source.ends_with(".git"):
            return "git"
        return "url"
    if source.starts_with("./") or source.starts_with("/") or source.starts_with("../"):
        if source.ends_with(".json"):
            return "file"
        return "directory"
    if addMarketplaceLooksLikeOwnerRepo(source):
        return "github"
    ""

fn addMarketplaceLooksLikeOwnerRepo(source: text) -> bool:
    val slash = addMarketplaceLastIndexOf(source, "/")
    slash > 0 and slash < source.len() - 1 and not source.contains("://")

fn addMarketplaceNameFromSource(source: text, sourceKind: text) -> text:
    if sourceKind == "github":
        val slash = addMarketplaceLastIndexOf(source, "/")
        if slash >= 0:
            return source.substring(slash + 1, source.len())
    addMarketplaceBasenameWithoutGitSuffix(source)

fn addMarketplaceBasenameWithoutGitSuffix(source: text) -> text:
    val slash = addMarketplaceLastIndexOf(source, "/")
    val base = if slash >= 0: source.substring(slash + 1, source.len()) else: source
    if base.ends_with(".git"):
        return base.substring(0, base.len() - 4)
    base

fn addMarketplaceValidate(request: AddMarketplaceRequest) -> text:
    val scope = addMarketplaceDefaultScope(request.scope)
    val kind = if request.sourceKind == "": addMarketplaceInferSourceKind(request.source) else: request.sourceKind
    if not addMarketplaceValidScope(scope):
        return "✖ Invalid scope '" + scope + "'. Use: user, project, or local"
    if request.sparse.len() > 0 and not addMarketplaceSparseAllowed(kind):
        return "✖ --sparse is only supported for github and git marketplace sources (got: " + kind + ")"
    if not addMarketplaceValidSourceKind(kind):
        return "✖ Invalid marketplace source format. Try: owner/repo, https://..., or ./path"
    ""

fn addMarketplaceRun(request: AddMarketplaceRequest) -> AddMarketplaceResult:
    val error = addMarketplaceValidate(request)
    if error != "":
        return AddMarketplaceResult.fail(error)
    val scope = addMarketplaceDefaultScope(request.scope)
    val kind = if request.sourceKind == "": addMarketplaceInferSourceKind(request.source) else: request.sourceKind
    val name = addMarketplaceNameFromSource(request.source, kind)
    val suffix = if request.alreadyMaterialized:
        "✓ Marketplace '" + name + "' already on disk - declared in " + scope + " settings"
    else:
        "✓ Successfully added marketplace: " + name + " (declared in " + scope + " settings)"
    AddMarketplaceResult.ok("Adding marketplace...\n" + suffix, name, kind, scope, true, "tengu_marketplace_added:" + kind)

fn addMarketplaceLastIndexOf(value: text, needle: text) -> i64:
    var i = value.len() - needle.len()
    while i >= 0:
        if value.substring(i, i + needle.len()) == needle:
            return i
        i = i - 1
    -1

fn addMarketplaceSourceLinesModeled() -> i64:
    ADD_MARKETPLACE_SOURCE_LINES
