"""
Claude full plugin installed cell parity model.
"""

const UNIFIED_INSTALLED_CELL_SOURCE_LINES = 564

class UnifiedInstalledCellProps:
    pluginId: text
    name: text
    marketplaceName: text
    description: text
    enabled: bool
    selected: bool
    expanded: bool
    trusted: bool
    local: bool
    hasUpdate: bool
    version: text
    latestVersion: text
    errorMessage: text
    commands: [text]

impl UnifiedInstalledCellProps:
    static fn new(pluginId: text, name: text, marketplaceName: text, description: text, enabled: bool, selected: bool, expanded: bool, trusted: bool, local: bool, hasUpdate: bool, version: text, latestVersion: text, errorMessage: text, commands: [text]) -> UnifiedInstalledCellProps:
        UnifiedInstalledCellProps(pluginId, name, marketplaceName, description, enabled, selected, expanded, trusted, local, hasUpdate, version, latestVersion, errorMessage, commands)

class UnifiedInstalledCellModel:
    title: text
    subtitle: text
    status: text
    marker: text
    actions: [text]
    details: [text]
    selected: bool

impl UnifiedInstalledCellModel:
    static fn new(title: text, subtitle: text, status: text, marker: text, actions: [text], details: [text], selected: bool) -> UnifiedInstalledCellModel:
        UnifiedInstalledCellModel(title, subtitle, status, marker, actions, details, selected)

fn unifiedInstalledCellStatus(props: UnifiedInstalledCellProps) -> text:
    if props.errorMessage != "":
        return "error"
    if not props.trusted:
        return "untrusted"
    if not props.enabled:
        return "disabled"
    if props.hasUpdate:
        return "update available"
    "enabled"

fn unifiedInstalledCellMarker(props: UnifiedInstalledCellProps) -> text:
    if props.selected:
        return ">"
    " "

fn unifiedInstalledCellSubtitle(props: UnifiedInstalledCellProps) -> text:
    val source = if props.local: "local" else: props.marketplaceName
    if props.version == "":
        return source
    source + " " + props.version

fn unifiedInstalledCellActions(props: UnifiedInstalledCellProps) -> [text]:
    var actions: [text] = []
    if props.errorMessage != "":
        actions.push("details")
        actions.push("remove")
        return actions
    if props.hasUpdate:
        actions.push("update")
    if props.enabled:
        actions.push("disable")
    else:
        actions.push("enable")
    actions.push("configure")
    actions.push("remove")
    actions

fn unifiedInstalledCellDetails(props: UnifiedInstalledCellProps) -> [text]:
    var details: [text] = []
    if props.expanded:
        details.push(props.description)
        if props.commands.len() > 0:
            details.push("commands: " + unifiedInstalledCellJoin(props.commands, ", "))
        if props.latestVersion != "" and props.latestVersion != props.version:
            details.push("latest: " + props.latestVersion)
        if props.errorMessage != "":
            details.push("error: " + props.errorMessage)
    details

fn UnifiedInstalledCell(props: UnifiedInstalledCellProps) -> UnifiedInstalledCellModel:
    UnifiedInstalledCellModel.new(props.name, unifiedInstalledCellSubtitle(props), unifiedInstalledCellStatus(props), unifiedInstalledCellMarker(props), unifiedInstalledCellActions(props), unifiedInstalledCellDetails(props), props.selected)

fn unifiedInstalledCellJoin(values: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + sep
        out = out + values[i]
        i = i + 1
    out

fn unifiedInstalledCellSourceLinesModeled() -> i64:
    UNIFIED_INSTALLED_CELL_SOURCE_LINES
