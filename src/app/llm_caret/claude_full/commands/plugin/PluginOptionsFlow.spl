"""
Claude full PluginOptionsFlow parity.
"""

class PluginOptionsFlowState:
    step: text
    selectedOption: text

impl PluginOptionsFlowState:
    static fn new(step: text, selectedOption: text) -> PluginOptionsFlowState:
        PluginOptionsFlowState(step: step, selectedOption: selectedOption)

fn startPluginOptionsFlow() -> PluginOptionsFlowState:
    PluginOptionsFlowState.new("choose", "")

fn choosePluginOption(state: PluginOptionsFlowState, option: text) -> PluginOptionsFlowState:
    PluginOptionsFlowState.new("confirm", option)

fn pluginOptionsFlowSourceLinesModeled() -> i64:
    134
