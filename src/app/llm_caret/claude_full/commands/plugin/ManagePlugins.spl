"""
Claude full plugin ManagePlugins parity model.
"""

const MANAGE_PLUGINS_SOURCE_LINES = 2214

class ManagedPluginInfo:
    pluginId: text
    name: text
    scope: text
    enabled: bool
    local: bool
    marketplaceName: text
    hasMcp: bool
    failed: bool

impl ManagedPluginInfo:
    static fn new(pluginId: text, name: text, scope: text, enabled: bool, local: bool, marketplaceName: text, hasMcp: bool, failed: bool) -> ManagedPluginInfo:
        ManagedPluginInfo(pluginId, name, scope, enabled, local, marketplaceName, hasMcp, failed)

class ManagePluginOperation:
    action: text
    pluginId: text
    scope: text

impl ManagePluginOperation:
    static fn new(action: text, pluginId: text, scope: text) -> ManagePluginOperation:
        ManagePluginOperation(action, pluginId, scope)

class ManagePluginResult:
    ok: bool
    message: text
    pluginId: text
    enabled: bool
    cacheCleared: bool
    eventName: text

impl ManagePluginResult:
    static fn ok(message: text, pluginId: text, enabled: bool, eventName: text) -> ManagePluginResult:
        ManagePluginResult(true, message, pluginId, enabled, true, eventName)

    static fn fail(message: text, pluginId: text) -> ManagePluginResult:
        ManagePluginResult(false, message, pluginId, false, false, "")

fn managePluginsGetBaseFileNames(paths: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < paths.len():
        val base = managePluginsBasename(paths[i])
        if base != "":
            out.push(base)
        i = i + 1
    out

fn managePluginsGetSkillDirNames(paths: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < paths.len():
        val base = managePluginsBasename(paths[i])
        if base != "" and base != "SKILL.md":
            out.push(base)
        i = i + 1
    out

fn managePluginsFilterDisabled(items: [ManagedPluginInfo]) -> [ManagedPluginInfo]:
    var out: [ManagedPluginInfo] = []
    var i = 0
    while i < items.len():
        if not items[i].enabled:
            out.push(items[i])
        i = i + 1
    out

fn managePluginsEnabledCount(items: [ManagedPluginInfo]) -> i64:
    var count = 0
    var i = 0
    while i < items.len():
        if items[i].enabled:
            count = count + 1
        i = i + 1
    count

fn managePluginsScopeLabel(scope: text) -> text:
    if scope == "local":
        return "Local"
    if scope == "project":
        return "Project"
    if scope == "user":
        return "User"
    "Unknown"

fn managePluginsMcpStatus(plugin: ManagedPluginInfo) -> text:
    if plugin.failed:
        return "error"
    if plugin.hasMcp and plugin.enabled:
        return "enabled"
    if plugin.hasMcp:
        return "disabled"
    "none"

fn managePluginsToggle(plugin: ManagedPluginInfo) -> ManagePluginResult:
    if plugin.failed:
        return ManagePluginResult.fail("Plugin failed to load: " + plugin.pluginId, plugin.pluginId)
    val enabled = not plugin.enabled
    val word = if enabled: "enabled" else: "disabled"
    ManagePluginResult.ok("Plugin " + word + ": " + plugin.name, plugin.pluginId, enabled, "tengu_plugin_" + word)

fn managePluginsUninstall(plugin: ManagedPluginInfo) -> ManagePluginResult:
    if plugin.local:
        return ManagePluginResult.fail("Local plugins cannot be uninstalled from plugin manager", plugin.pluginId)
    ManagePluginResult.ok("Plugin uninstalled: " + plugin.name, plugin.pluginId, false, "tengu_plugin_uninstalled")

fn managePluginsSearch(items: [ManagedPluginInfo], query: text) -> [ManagedPluginInfo]:
    if query == "":
        return items
    var out: [ManagedPluginInfo] = []
    var i = 0
    while i < items.len():
        val item = items[i]
        if item.name.contains(query) or item.pluginId.contains(query) or item.marketplaceName.contains(query):
            out.push(item)
        i = i + 1
    out

fn managePluginsBasename(path: text) -> text:
    val slash = managePluginsLastIndexOf(path, "/")
    if slash >= 0:
        return path.substring(slash + 1, path.len())
    path

fn managePluginsLastIndexOf(value: text, needle: text) -> i64:
    var i = value.len() - needle.len()
    while i >= 0:
        if value.substring(i, i + needle.len()) == needle:
            return i
        i = i - 1
    -1

fn managePluginsSourceLinesModeled() -> i64:
    MANAGE_PLUGINS_SOURCE_LINES
