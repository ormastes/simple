"""
Claude full keybindings command parity.
"""

class KeybindingRow:
    key: text
    action: text

impl KeybindingRow:
    static fn new(key: text, action: text) -> KeybindingRow:
        KeybindingRow(key: key, action: action)

fn defaultKeybindings() -> [KeybindingRow]:
    [
        KeybindingRow.new("ctrl+c", "cancel"),
        KeybindingRow.new("ctrl+d", "exit"),
        KeybindingRow.new("tab", "complete"),
    ]

fn keybindingsCommandName() -> text:
    "keybindings"

fn keybindingsSummary() -> text:
    "Show keyboard shortcuts"

fn keybindingsFindAction(key: text) -> text:
    val rows = defaultKeybindings()
    var i = 0
    while i < rows.len():
        if rows[i].key == key:
            return rows[i].action
        i = i + 1
    ""

fn keybindingsSourceLinesModeled() -> i64:
    53
