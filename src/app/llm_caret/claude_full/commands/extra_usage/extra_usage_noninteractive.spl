use app.llm_caret.claude_full.commands.extra_usage.extra_usage_core.*

class ExtraUsageTextResult:
    typeName: text
    value: text

impl ExtraUsageTextResult:
    static fn new(value: text) -> ExtraUsageTextResult:
        ExtraUsageTextResult("text", value)

fn callExtraUsageNoninteractive(state: ExtraUsageState) -> ExtraUsageTextResult:
    val result = runExtraUsage(state)
    if result.typeName == "message":
        return ExtraUsageTextResult.new(result.value)
    if result.opened:
        return ExtraUsageTextResult.new("Browser opened to manage extra usage. If it didn't open, visit: " + result.url)
    ExtraUsageTextResult.new("Please visit " + result.url + " to manage extra usage.")

fn extraUsageNoninteractiveSourceLinesModeled() -> i64:
    16
