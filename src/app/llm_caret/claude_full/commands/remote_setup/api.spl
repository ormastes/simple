class RedactedGithubToken:
    value: text

impl RedactedGithubToken:
    static fn new(raw: text) -> RedactedGithubToken:
        RedactedGithubToken(value: raw)

    me reveal() -> text:
        me.value

    me toString() -> text:
        redactedGithubTokenText()

    me toJSON() -> text:
        redactedGithubTokenText()

    me inspect() -> text:
        redactedGithubTokenText()

class ImportTokenResult:
    ok: bool
    github_username: text
    errorKind: text
    status: i64

impl ImportTokenResult:
    static fn success(username: text) -> ImportTokenResult:
        ImportTokenResult(ok: true, github_username: username, errorKind: "", status: 200)

    static fn failure(kind: text, status: i64) -> ImportTokenResult:
        ImportTokenResult(ok: false, github_username: "", errorKind: kind, status: status)

fn importGithubToken(token: RedactedGithubToken, prepareSucceeds: bool, responseStatus: i64, networkError: bool, username: text) -> ImportTokenResult:
    if not prepareSucceeds:
        return ImportTokenResult.failure("not_signed_in", 0)
    if networkError:
        return ImportTokenResult.failure("network", 0)
    if token.reveal() == "":
        return ImportTokenResult.failure("invalid_token", 400)
    if responseStatus == 200:
        return ImportTokenResult.success(username)
    if responseStatus == 400:
        return ImportTokenResult.failure("invalid_token", 400)
    if responseStatus == 401:
        return ImportTokenResult.failure("not_signed_in", 401)
    ImportTokenResult.failure("server", responseStatus)

fn createDefaultEnvironment(prepareSucceeds: bool, existingEnvironmentCount: i64, responseStatus: i64, networkError: bool) -> bool:
    if not prepareSucceeds:
        return false
    if existingEnvironmentCount > 0:
        return true
    if networkError:
        return false
    responseStatus >= 200 and responseStatus < 300

fn hasExistingEnvironment(fetchSucceeds: bool, environmentCount: i64) -> bool:
    fetchSucceeds and environmentCount > 0

fn isSignedIn(prepareSucceeds: bool) -> bool:
    prepareSucceeds

fn getCodeWebUrl(origin: text) -> text:
    origin + "/code"

fn importTokenUrl(baseApiUrl: text) -> text:
    baseApiUrl + "/v1/code/github/import-token"

fn createEnvironmentUrl(baseApiUrl: text) -> text:
    baseApiUrl + "/v1/environment_providers/cloud/create"

fn ccrByocBetaHeader() -> text:
    "ccr-byoc-2025-07-29"

fn redactedGithubTokenText() -> text:
    "[REDACTED:gh-token]"

fn importTokenTimeoutMs() -> i64:
    15000

fn createEnvironmentTimeoutMs() -> i64:
    15000

fn defaultEnvironmentName() -> text:
    "Default"

fn defaultEnvironmentKind() -> text:
    "anthropic_cloud"

fn defaultEnvironmentDescription() -> text:
    "Default - trusted network access"

fn defaultEnvironmentType() -> text:
    "anthropic"

fn defaultEnvironmentCwd() -> text:
    "/home/user"

fn defaultPythonVersion() -> text:
    "3.11"

fn defaultNodeVersion() -> text:
    "20"

fn allowDefaultHosts() -> bool:
    true

fn rawTokenOnlyRevealedInHttpBody() -> bool:
    true

fn networkErrorLogsCodeOnly() -> bool:
    true

fn tokenStoredEncryptedServerSide() -> bool:
    true

fn createEnvironmentFailuresNonFatal() -> bool:
    true

fn remoteSetupApiSourceLinesModeled() -> i64:
    174

# Source parity note: wraps GitHub token to redact string conversion.
# Source parity note: JSON serialization redacts token.
# Source parity note: node inspect redacts token.
# Source parity note: reveal is only for HTTP body.
# Source parity note: prepareApiRequest failure maps to not_signed_in.
# Source parity note: import-token POST uses OAuth headers.
# Source parity note: import-token POST adds anthropic beta header.
# Source parity note: import-token POST adds organization UUID header.
# Source parity note: status 200 maps to ok result.
# Source parity note: status 400 maps to invalid_token.
# Source parity note: status 401 maps to not_signed_in.
# Source parity note: other status maps to server error.
# Source parity note: axios network error maps to network.
# Source parity note: network log must not include POST body.
# Source parity note: existing environments skip default creation.
# Source parity note: default environment uses public create endpoint.
# Source parity note: default environment request includes python.
# Source parity note: default environment request includes node.
# Source parity note: default environment allows default hosts.
# Source parity note: create default environment failures are non-fatal.
