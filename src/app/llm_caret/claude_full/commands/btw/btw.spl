class BtwMessage:
    typeName: text
    stopReason: text

    static fn new(typeName: text, stopReason: text) -> BtwMessage:
        BtwMessage(typeName: typeName, stopReason: stopReason)

class BtwContext:
    contextId: text
    messages: [BtwMessage]
    tools: [text]
    mainLoopModel: text
    mcpClients: [text]

    static fn new(contextId: text, messages: [BtwMessage], tools: [text], mainLoopModel: text, mcpClients: [text]) -> BtwContext:
        BtwContext(contextId: contextId, messages: messages, tools: tools, mainLoopModel: mainLoopModel, mcpClients: mcpClients)

class LastCacheSafeParams:
    present: bool
    systemPrompt: text
    userContext: text
    systemContext: text

    static fn none() -> LastCacheSafeParams:
        LastCacheSafeParams(present: false, systemPrompt: "", userContext: "", systemContext: "")

    static fn saved(systemPrompt: text, userContext: text, systemContext: text) -> LastCacheSafeParams:
        LastCacheSafeParams(present: true, systemPrompt: systemPrompt, userContext: userContext, systemContext: systemContext)

class BtwCacheSafeParams:
    source: text
    systemPrompt: text
    userContext: text
    systemContext: text
    toolUseContextId: text
    forkContextMessages: [BtwMessage]

    static fn new(source: text, systemPrompt: text, userContext: text, systemContext: text, toolUseContextId: text, forkContextMessages: [BtwMessage]) -> BtwCacheSafeParams:
        BtwCacheSafeParams(source: source, systemPrompt: systemPrompt, userContext: userContext, systemContext: systemContext, toolUseContextId: toolUseContextId, forkContextMessages: forkContextMessages)

class BtwCallResult:
    question: text
    doneMessage: text
    display: text
    renderedSideQuestion: bool
    btwUseCount: i64

    static fn new(question: text, doneMessage: text, display: text, renderedSideQuestion: bool, btwUseCount: i64) -> BtwCallResult:
        BtwCallResult(question: question, doneMessage: doneMessage, display: display, renderedSideQuestion: renderedSideQuestion, btwUseCount: btwUseCount)

fn stripInProgressAssistantMessage(messages: [BtwMessage]) -> [BtwMessage]:
    if messages.len() == 0:
        return messages
    val last = messages[messages.len() - 1]
    if last.typeName == "assistant" and last.stopReason == "":
        var out: [BtwMessage] = []
        var i = 0
        while i < messages.len() - 1:
            out.push(messages[i])
            i = i + 1
        return out
    messages

fn buildCacheSafeParams(context: BtwContext, saved: LastCacheSafeParams, rawSystemPrompt: text, userContext: text, systemContext: text) -> BtwCacheSafeParams:
    val forkContextMessages = stripInProgressAssistantMessage(context.messages)
    if saved.present:
        return BtwCacheSafeParams.new("last-cache-safe", saved.systemPrompt, saved.userContext, saved.systemContext, context.contextId, forkContextMessages)
    BtwCacheSafeParams.new("rebuilt", rawSystemPrompt, userContext, systemContext, context.contextId, forkContextMessages)

fn callBtw(args: text, currentBtwUseCount: i64) -> BtwCallResult:
    val question = args.trim()
    if question == "":
        return BtwCallResult.new("", "Usage: /btw <your question>", "system", false, currentBtwUseCount)
    BtwCallResult.new(question, "", "", true, currentBtwUseCount + 1)

fn btwHelpText() -> text:
    "Usage: /btw <your question>"

fn btwLoadingText() -> text:
    "Answering..."

fn btwNoResponseText() -> text:
    "No response received"

fn btwFailureFallbackText() -> text:
    "Failed to get response"

fn btwDismissDisplay() -> text:
    "skip"

fn btwScrollLines() -> i64:
    3

fn btwChromeRows() -> i64:
    5

fn btwOuterChromeRows() -> i64:
    6

fn btwMaxContentHeight(rows: i64) -> i64:
    val height = rows - btwChromeRows() - btwOuterChromeRows()
    if height < 5:
        return 5
    height

fn btwDismissesKey(key: text, ctrl: bool) -> bool:
    if key == "escape" or key == "return" or key == " ":
        return true
    ctrl and (key == "c" or key == "d")

fn btwScrollDelta(key: text, ctrl: bool) -> i64:
    if key == "up" or (ctrl and key == "p"):
        return 0 - btwScrollLines()
    if key == "down" or (ctrl and key == "n"):
        return btwScrollLines()
    0

fn btwSourceLinesModeled() -> i64:
    242
