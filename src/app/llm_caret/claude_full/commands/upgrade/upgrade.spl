"""
Claude full upgrade command parity.
"""

fn upgradeCommandName() -> text:
    "upgrade"

fn upgradeChannel(raw: text) -> text:
    val channel = raw.trim().to_lower()
    if channel == "stable" or channel == "latest" or channel == "insiders":
        return channel
    "stable"

fn upgradeSummary(raw: text) -> text:
    "Upgrade channel: " + upgradeChannel(raw)

fn shouldPromptForRestart(currentVersion: text, nextVersion: text) -> bool:
    currentVersion.trim() != nextVersion.trim()

fn upgradeSourceLinesModeled() -> i64:
    37
