class BranchCommand:
    typeName: text
    name: text
    aliases: [text]
    description: text
    argumentHint: text
    loadPath: text

    static fn new(forkSubagentEnabled: bool) -> BranchCommand:
        val aliases = if forkSubagentEnabled: [] else: ["fork"]
        BranchCommand(typeName: "local-jsx", name: "branch", aliases: aliases, description: "Create a branch of the current conversation at this point", argumentHint: "[name]", loadPath: "./branch.js")

fn branchCommand(forkSubagentEnabled: bool) -> BranchCommand:
    BranchCommand.new(forkSubagentEnabled)

fn branchIndexSourceLinesModeled() -> i64:
    14
