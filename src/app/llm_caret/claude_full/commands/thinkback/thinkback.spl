"""
Claude full thinkback command model parity.
"""

class ThinkbackState:
    topic: text
    selectedAction: text
    installed: bool
    installChecked: bool
    history: [text]

impl ThinkbackState:
    static fn new(topic: text, selectedAction: text, installed: bool, installChecked: bool, history: [text]) -> ThinkbackState:
        ThinkbackState(topic: topic, selectedAction: selectedAction, installed: installed, installChecked: installChecked, history: history)

class ThinkbackResult:
    ok: bool
    status: text
    topic: text
    action: text
    summary: text
    replay: text
    state: ThinkbackState

impl ThinkbackResult:
    static fn new(ok: bool, status: text, topic: text, action: text, summary: text, replay: text, state: ThinkbackState) -> ThinkbackResult:
        ThinkbackResult(ok: ok, status: status, topic: topic, action: action, summary: summary, replay: replay, state: state)

fn getMarketplaceName() -> text: "thinkback"
fn getMarketplaceRepo() -> text: "anthropics/thinkback"
fn getPluginId() -> text: "anthropic/thinkback"
fn getThinkbackSkillDir() -> text: "skills/thinkback"
fn thinkbackCommandName() -> text: "thinkback"
fn thinkbackPlugin() -> text: getPluginId()

fn normalizeThinkbackTopic(topic: text) -> text:
    val cleaned = topic.trim().lower()
    if cleaned == "":
        return "recent conversation"
    cleaned

fn thinkbackReplayText(topic: text) -> text:
    "Replay prior context for " + normalizeThinkbackTopic(topic)

fn thinkbackSummaryText(topic: text) -> text:
    "Thinkback summary: " + normalizeThinkbackTopic(topic)

fn playAnimation(frame: i64) -> text:
    if frame <= 0:
        return "rewind-0"
    if frame == 1:
        return "rewind-1"
    "rewind-loop"

fn checkAndInstall(state: ThinkbackState) -> ThinkbackState:
    ThinkbackState.new(state.topic, state.selectedAction, true, true, state.history)

fn errorMsg(state: ThinkbackState) -> text:
    if state.installed:
        return ""
    "Thinkback plugin is not installed"

fn isDisabled(state: ThinkbackState) -> bool:
    not state.installed

fn normalizeThinkbackAction(action: text) -> text:
    val cleaned = action.trim().lower()
    if cleaned == "replay":
        return "replay"
    if cleaned == "summary":
        return "summary"
    "summary"

fn selectThinkbackAction(state: ThinkbackState, action: text) -> ThinkbackState:
    ThinkbackState.new(state.topic, normalizeThinkbackAction(action), state.installed, state.installChecked, state.history)

fn ThinkbackInstaller(state: ThinkbackState) -> ThinkbackResult:
    val installed = checkAndInstall(state)
    ThinkbackResult.new(true, "installed", normalizeThinkbackTopic(installed.topic), installed.selectedAction, "Thinkback plugin ready", "", installed)

fn ThinkbackMenu(state: ThinkbackState, action: text) -> ThinkbackResult:
    val selected = selectThinkbackAction(state, action)
    ThinkbackResult.new(not isDisabled(selected), selected.selectedAction, normalizeThinkbackTopic(selected.topic), selected.selectedAction, thinkbackSummaryText(selected.topic), thinkbackReplayText(selected.topic), selected)

fn ThinkbackFlow(state: ThinkbackState) -> ThinkbackResult:
    if isDisabled(state):
        return ThinkbackResult.new(false, "disabled", normalizeThinkbackTopic(state.topic), normalizeThinkbackAction(state.selectedAction), errorMsg(state), "", state)
    val action = normalizeThinkbackAction(state.selectedAction)
    val topic = normalizeThinkbackTopic(state.topic)
    if action == "replay":
        return ThinkbackResult.new(true, "replay", topic, action, thinkbackSummaryText(topic), thinkbackReplayText(topic), state)
    ThinkbackResult.new(true, "summary", topic, action, thinkbackSummaryText(topic), "", state)

fn callThinkback(topic: text, action: text) -> ThinkbackResult:
    ThinkbackFlow(ThinkbackState.new(topic, action, true, true, []))

fn call(topic: text) -> ThinkbackResult:
    callThinkback(topic, "summary")

fn thinkbackSourceLinesModeled() -> i64:
    553

