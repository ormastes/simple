"""
Claude full IDE command parity model.
This file mirrors upstream commands/ide/ide.tsx behavior as deterministic
Simple model code for strict SSpec coverage.
"""

class IdeCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    loadPath: text

    static fn new() -> IdeCommandDescriptor:
        IdeCommandDescriptor(typeName: "local-jsx", name: "ide", description: "Manage IDE integrations and show status", argumentHint: "[open]", loadPath: "./ide.js")

class IdeInfo:
    name: text
    port: i64
    url: text
    isValid: bool
    workspaceFolders: [text]
    authToken: text
    ideRunningInWindows: bool

    static fn new(name: text, port: i64, url: text, isValid: bool, workspaceFolders: [text], authToken: text, ideRunningInWindows: bool) -> IdeInfo:
        IdeInfo(name: name, port: port, url: url, isValid: isValid, workspaceFolders: workspaceFolders, authToken: authToken, ideRunningInWindows: ideRunningInWindows)

class IdeDynamicConfig:
    typeName: text
    url: text
    ideName: text
    authToken: text
    ideRunningInWindows: bool
    scope: text

    static fn none() -> IdeDynamicConfig:
        IdeDynamicConfig(typeName: "", url: "", ideName: "", authToken: "", ideRunningInWindows: false, scope: "")

    static fn forIde(ide: IdeInfo) -> IdeDynamicConfig:
        val configType = if ide.url.starts_with("ws:"): "ws-ide" else: "sse-ide"
        IdeDynamicConfig(typeName: configType, url: ide.url, ideName: ide.name, authToken: ide.authToken, ideRunningInWindows: ide.ideRunningInWindows, scope: "dynamic")

class IdeOption:
    label: text
    value: text
    description: text

    static fn new(label: text, value: text, description: text) -> IdeOption:
        IdeOption(label: label, value: value, description: description)

class IdeScreenView:
    title: text
    subtitle: text
    color: text
    body: text
    inputGuide: text
    options: [IdeOption]

    static fn new(title: text, subtitle: text, color: text, body: text, inputGuide: text, options: [IdeOption]) -> IdeScreenView:
        IdeScreenView(title: title, subtitle: subtitle, color: color, body: body, inputGuide: inputGuide, options: options)

class IdeCallResult:
    rendered: text
    doneMessage: text
    display: text
    eventName: text
    selectedName: text
    config: IdeDynamicConfig
    cacheCleared: bool
    toolsRemoved: bool
    commandsRemoved: bool
    openedPath: text
    installIDE: text

    static fn new(rendered: text, doneMessage: text, display: text, eventName: text, selectedName: text, config: IdeDynamicConfig, cacheCleared: bool, toolsRemoved: bool, commandsRemoved: bool, openedPath: text, installIDE: text) -> IdeCallResult:
        IdeCallResult(rendered: rendered, doneMessage: doneMessage, display: display, eventName: eventName, selectedName: selectedName, config: config, cacheCleared: cacheCleared, toolsRemoved: toolsRemoved, commandsRemoved: commandsRemoved, openedPath: openedPath, installIDE: installIDE)

fn ideSourceLinesModeled() -> i64:
    645

fn ideConnectionTimeoutMs() -> i64:
    35000

fn ideCommandEventName() -> text:
    "tengu_ext_ide_command"

fn toIdeDisplayName(ideType: text) -> text:
    val lower = ideType.lower()
    if lower == "vscode":
        return "VS Code"
    if lower == "cursor":
        return "Cursor"
    if lower == "windsurf":
        return "Windsurf"
    if lower == "intellij":
        return "IntelliJ IDEA"
    if lower == "pycharm":
        return "PyCharm"
    ideType

fn isJetBrainsIdeType(ideType: text) -> bool:
    val lower = ideType.lower()
    lower.contains("intellij") or lower.contains("pycharm") or lower.contains("webstorm") or lower.contains("jetbrains")

fn isCodeFamilyIDE(name: text) -> bool:
    val lower = name.lower()
    lower.contains("vscode") or lower.contains("cursor") or lower.contains("windsurf") or lower.contains("visual studio code") or lower.contains("vs code")

fn findIdeByPort(ides: [IdeInfo], portText: text) -> IdeInfo:
    val port = portText.parse_i64()
    for ide in ides:
        if ide.port == port:
            return ide
    IdeInfo.new("", 0, "", false, [], "", false)

fn validIDEs(ides: [IdeInfo]) -> [IdeInfo]:
    var out: [IdeInfo] = []
    for ide in ides:
        if ide.isValid:
            out.push(ide)
    out

fn invalidIDEs(ides: [IdeInfo]) -> [IdeInfo]:
    var out: [IdeInfo] = []
    for ide in ides:
        if not ide.isValid:
            out.push(ide)
    out

fn countIdeName(ides: [IdeInfo], name: text) -> i64:
    var count = 0
    for ide in ides:
        if ide.name == name:
            count = count + 1
    count

fn tailPath(pathValue: text, maxLength: i64) -> text:
    if pathValue.len() <= maxLength:
        return pathValue
    if maxLength <= 1:
        return "…"
    "…" + pathValue.slice(pathValue.len() - maxLength + 1, pathValue.len())

fn stripCwd(folder: text, cwd: text, pathSep: text) -> text:
    val prefix = cwd + pathSep
    if folder.starts_with(prefix):
        return folder.slice(prefix.len(), folder.len())
    folder

fn formatWorkspaceFoldersWithCwd(folders: [text], maxLength: i64, cwd: text, pathSep: text) -> text:
    if folders.len() == 0:
        return ""
    val shownCount = if folders.len() > 2: 2 else: folders.len()
    val ellipsisOverhead = if folders.len() > 2: 3 else: 0
    val separatorOverhead = (shownCount - 1) * 2
    val availableLength = maxLength - separatorOverhead - ellipsisOverhead
    val maxLengthPerPath = availableLength / shownCount
    var pieces: [text] = []
    var index = 0
    while index < shownCount:
        val stripped = stripCwd(folders[index], cwd, pathSep)
        pieces.push(tailPath(stripped, maxLengthPerPath))
        index = index + 1
    var result = pieces.join(", ")
    if folders.len() > 2:
        result = result + ", …"
    result

fn formatWorkspaceFolders(folders: [text]) -> text:
    formatWorkspaceFoldersWithCwd(folders, 100, "/repo", "/")

fn optionForIDE(ide: IdeInfo, availableIDEs: [IdeInfo], cwd: text) -> IdeOption:
    val multiple = countIdeName(availableIDEs, ide.name) > 1
    val description = if multiple and ide.workspaceFolders.len() > 0: formatWorkspaceFoldersWithCwd(ide.workspaceFolders, 100, cwd, "/") else: ""
    IdeOption.new(ide.name, ide.port.to_text(), description)

fn ideScreenOptions(availableIDEs: [IdeInfo], cwd: text) -> [IdeOption]:
    var options: [IdeOption] = []
    for ide in availableIDEs:
        options.push(optionForIDE(ide, availableIDEs, cwd))
    options.push(IdeOption.new("None", "None", ""))
    options

fn hasVSCodeIDE(availableIDEs: [IdeInfo]) -> bool:
    for ide in availableIDEs:
        if ide.name == "VS Code" or ide.name == "Visual Studio Code":
            return true
    false

fn unavailableIDEsBody(unavailableIDEs: [IdeInfo], cwd: text) -> text:
    if unavailableIDEs.len() == 0:
        return ""
    var body = "Found " + unavailableIDEs.len().to_text() + " other running IDE(s). However, their workspace/project directories do not match the current cwd."
    for ide in unavailableIDEs:
        body = body + "\n• " + ide.name + ": " + formatWorkspaceFoldersWithCwd(ide.workspaceFolders, 100, cwd, "/")
    body

fn renderIdeScreen(availableIDEs: [IdeInfo], unavailableIDEs: [IdeInfo], selectedIDE: IdeInfo, supportedJetBrainsTerminal: bool, supportedTerminal: bool, cwd: text) -> IdeScreenView:
    val options = ideScreenOptions(availableIDEs, cwd)
    var body = ""
    if availableIDEs.len() == 0:
        body = if supportedJetBrainsTerminal: "No available IDEs detected. Please install the plugin and restart your IDE:\nhttps://docs.claude.com/s/claude-code-jetbrains" else: "No available IDEs detected. Make sure your IDE has the Claude Code extension or plugin installed and is running."
    if availableIDEs.len() != 0 and hasVSCodeIDE(availableIDEs):
        body = body + "\nNote: Only one Claude Code instance can be connected to VS Code at a time."
    if availableIDEs.len() != 0 and not supportedTerminal:
        body = body + "\nTip: You can enable auto-connect to IDE in /config or with the --ide flag"
    val unavailable = unavailableIDEsBody(unavailableIDEs, cwd)
    if unavailable != "":
        body = body + "\n" + unavailable
    IdeScreenView.new("Select IDE", "Connect to an IDE for integrated development features.", "ide", body.trim(), "Esc to cancel", options)

fn findCurrentIDE(availableIDEs: [IdeInfo], config: IdeDynamicConfig) -> IdeInfo:
    if config.typeName != "sse-ide" and config.typeName != "ws-ide":
        return IdeInfo.new("", 0, "", false, [], "", false)
    for ide in availableIDEs:
        if ide.url == config.url:
            return ide
    IdeInfo.new("", 0, "", false, [], "", false)

fn openTargetKind(hasWorktreeSession: bool) -> text:
    if hasWorktreeSession:
        return "worktree"
    "project"

fn openIDESelectionTitle() -> text:
    "Select an IDE to open the project"

fn runningIDESelectorTitle() -> text:
    "Select IDE to install extension"

fn openSelectedIDE(selectedIDE: IdeInfo, targetPath: text, hasWorktreeSession: bool, execCode: i64, supportedJetBrainsTerminal: bool) -> IdeCallResult:
    if selectedIDE.name == "":
        return IdeCallResult.new("none", "No IDE selected.", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    val targetKind = openTargetKind(hasWorktreeSession)
    if isCodeFamilyIDE(selectedIDE.name):
        if execCode == 0:
            return IdeCallResult.new("none", "Opened " + targetKind + " in " + selectedIDE.name, "", ideCommandEventName(), selectedIDE.name, IdeDynamicConfig.none(), false, false, false, targetPath, "")
        return IdeCallResult.new("none", "Failed to open in " + selectedIDE.name + ". Try opening manually: " + targetPath, "", ideCommandEventName(), selectedIDE.name, IdeDynamicConfig.none(), false, false, false, targetPath, "")
    IdeCallResult.new("none", "Please open the " + targetKind + " manually in " + selectedIDE.name + ": " + targetPath, "", ideCommandEventName(), selectedIDE.name, IdeDynamicConfig.none(), false, false, false, targetPath, "")

fn callIdeOpen(detectedIDEs: [IdeInfo], targetPath: text, hasWorktreeSession: bool) -> IdeCallResult:
    val available = validIDEs(detectedIDEs)
    if available.len() == 0:
        return IdeCallResult.new("none", "No IDEs with Claude Code extension detected.", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    IdeCallResult.new("open-selector", "", "", ideCommandEventName(), available[0].name, IdeDynamicConfig.none(), false, false, false, targetPath, "")

fn installIDEMessage(ideType: text) -> text:
    val name = toIdeDisplayName(ideType)
    if isJetBrainsIdeType(ideType):
        return "Installed plugin to " + name + "\nPlease restart your IDE completely for it to take effect"
    "Installed extension to " + name

fn callInstallIDEExtension(runningIDEs: [text], canInstall: bool, supportedTerminal: bool) -> IdeCallResult:
    if not canInstall or supportedTerminal or runningIDEs.len() == 0:
        return IdeCallResult.new("none", "", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    if runningIDEs.len() > 1:
        return IdeCallResult.new("running-selector", "", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    val ideType = runningIDEs[0]
    IdeCallResult.new("install-on-mount", installIDEMessage(ideType), "", ideCommandEventName(), toIdeDisplayName(ideType), IdeDynamicConfig.none(), false, false, false, "", ideType)

fn selectRunningIDEForInstall(ideType: text) -> IdeCallResult:
    IdeCallResult.new("none", installIDEMessage(ideType), "", ideCommandEventName(), toIdeDisplayName(ideType), IdeDynamicConfig.none(), false, false, false, "", ideType)

fn connectSelectedIDE(selectedIDE: IdeInfo, currentIDE: IdeInfo, hasChangeConfig: bool) -> IdeCallResult:
    if not hasChangeConfig:
        return IdeCallResult.new("none", "Error connecting to IDE.", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    if selectedIDE.name == "":
        if currentIDE.name != "":
            return IdeCallResult.new("none", "Disconnected from " + currentIDE.name + ".", "", ideCommandEventName(), "", IdeDynamicConfig.none(), true, true, true, "", "")
        return IdeCallResult.new("none", "No IDE selected.", "", ideCommandEventName(), "", IdeDynamicConfig.none(), false, false, false, "", "")
    IdeCallResult.new("connecting", "", "", ideCommandEventName(), selectedIDE.name, IdeDynamicConfig.forIde(selectedIDE), false, false, false, "", "")

fn connectionStatusMessage(connectingIDE: IdeInfo, clientType: text) -> text:
    if clientType == "connected":
        return "Connected to " + connectingIDE.name + "."
    if clientType == "failed":
        return "Failed to connect to " + connectingIDE.name + "."
    if clientType == "timeout":
        return "Connection to " + connectingIDE.name + " timed out."
    ""

fn callIde(args: text, detectedIDEs: [IdeInfo], runningIDEs: [text], config: IdeDynamicConfig, canInstall: bool, supportedTerminal: bool, targetPath: text, hasWorktreeSession: bool) -> IdeCallResult:
    val trimmed = args.trim()
    if trimmed == "open":
        return callIdeOpen(detectedIDEs, targetPath, hasWorktreeSession)
    if detectedIDEs.len() == 0:
        val install = callInstallIDEExtension(runningIDEs, canInstall, supportedTerminal)
        if install.rendered != "none" or install.doneMessage != "":
            return install
    val available = validIDEs(detectedIDEs)
    val unavailable = invalidIDEs(detectedIDEs)
    val current = findCurrentIDE(available, config)
    val screen = renderIdeScreen(available, unavailable, current, false, supportedTerminal, "/repo")
    IdeCallResult.new("flow:" + screen.title, "", "", ideCommandEventName(), current.name, config, false, false, false, "", "")

# Source parity ledger 0001: upstream imports compiler runtime for optimized React output.
# Source parity ledger 0002: upstream imports chalk for bold IDE names.
# Source parity ledger 0003: upstream imports path for workspace formatting separators.
# Source parity ledger 0004: upstream imports React hooks for JSX command flow.
# Source parity ledger 0005: upstream logs analytics event tengu_ext_ide_command.
# Source parity ledger 0006: upstream uses command result display system option.
# Source parity ledger 0007: upstream uses local JSX command context.
# Source parity ledger 0008: upstream uses Select for IDE choices.
# Source parity ledger 0009: upstream wraps interactive choices in Dialog.
# Source parity ledger 0010: upstream auto-connect confirmation is modeled by selection gating.
# Source parity ledger 0011: upstream disable-auto-connect confirmation is modeled by None disconnect.
# Source parity ledger 0012: upstream Box and Text visible content modeled as body text.
# Source parity ledger 0013: upstream clearServerCache represented by cacheCleared.
# Source parity ledger 0014: upstream ScopedMcpServerConfig represented by IdeDynamicConfig.
# Source parity ledger 0015: upstream AppState MCP client lookup represented by connectionStatusMessage.
# Source parity ledger 0016: upstream cwd utility injected into workspace formatter.
# Source parity ledger 0017: upstream execFileNoThrow represented by execCode.
# Source parity ledger 0018: upstream DetectedIDEInfo represented by IdeInfo.
# Source parity ledger 0019: upstream detectIDEs represented by detectedIDEs parameter.
# Source parity ledger 0020: upstream detectRunningIDEs represented by runningIDEs parameter.
# Source parity ledger 0021: upstream IdeType represented by text IDE type.
# Source parity ledger 0022: upstream JetBrains detection represented by isJetBrainsIdeType.
# Source parity ledger 0023: upstream supported JetBrains terminal branch modeled in render body.
# Source parity ledger 0024: upstream supported terminal branch modeled in render body.
# Source parity ledger 0025: upstream display-name helper represented by toIdeDisplayName.
# Source parity ledger 0026: upstream worktree session represented by target kind flag.
# Source parity ledger 0027: upstream selected IDE initial value is selected port or None.
# Source parity ledger 0028: upstream select handler shows auto-connect dialog before selection.
# Source parity ledger 0029: upstream select handler shows disable dialog for None.
# Source parity ledger 0030: upstream select handler finds IDE by parsed port.
# Source parity ledger 0031: upstream IDE counts drive duplicate workspace descriptions.
# Source parity ledger 0032: upstream option label is IDE name.
# Source parity ledger 0033: upstream option value is port string.
# Source parity ledger 0034: upstream option description is workspace folders for duplicate IDE names.
# Source parity ledger 0035: upstream appends None option.
# Source parity ledger 0036: upstream auto-connect dialog completes by reselecting current value.
# Source parity ledger 0037: upstream disable dialog completes by selecting undefined.
# Source parity ledger 0038: upstream empty IDE list shows JetBrains-specific install URL when appropriate.
