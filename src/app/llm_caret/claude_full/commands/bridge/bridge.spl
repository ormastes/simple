class BridgeCommand:
    typeName: text
    name: text
    aliases: [text]
    description: text
    argumentHint: text
    immediate: bool
    bridgeModeFeature: bool
    bridgeEnabled: bool

    me isEnabled() -> bool:
        self.bridgeModeFeature and self.bridgeEnabled

    me isHidden() -> bool:
        not self.isEnabled()

class BridgeAppState:
    replBridgeConnected: bool
    replBridgeEnabled: bool
    replBridgeOutboundOnly: bool
    replBridgeExplicit: bool
    replBridgeInitialName: text
    replBridgeSessionActive: bool
    replBridgeSessionUrl: text
    replBridgeConnectUrl: text
    showRemoteCallout: bool

class BridgeCallResult:
    componentName: text
    initialName: text
    showDisconnectDialog: bool
    showRemoteCallout: bool
    connect: bool
    onDoneMessage: text
    onDoneDisplay: text
    logAction: text
    error: text

class BridgeDialogModel:
    title: text
    displayUrl: text
    focusIndex: i64
    showQR: bool
    qrButtonText: text
    helpText: text

class BridgePrerequisiteInput:
    policyAllowed: bool
    disabledReason: text
    envLessEnabled: bool
    kairosFeature: bool
    assistantMode: bool
    envLessVersionError: text
    bridgeMinVersionError: text
    accessToken: text

fn bridgeCommandFor(bridgeModeFeature: bool, bridgeEnabled: bool) -> BridgeCommand:
    BridgeCommand(
        typeName: "local-jsx",
        name: "remote-control",
        aliases: ["rc"],
        description: "Connect this terminal for remote-control sessions",
        argumentHint: "[name]",
        immediate: true,
        bridgeModeFeature: bridgeModeFeature,
        bridgeEnabled: bridgeEnabled,
    )

fn bridgeCommand() -> BridgeCommand:
    bridgeCommandFor(true, true)

fn defaultBridgeState() -> BridgeAppState:
    BridgeAppState(
        replBridgeConnected: false,
        replBridgeEnabled: false,
        replBridgeOutboundOnly: false,
        replBridgeExplicit: false,
        replBridgeInitialName: "",
        replBridgeSessionActive: false,
        replBridgeSessionUrl: "",
        replBridgeConnectUrl: "",
        showRemoteCallout: false,
    )

fn trimInitialName(args: text) -> text:
    args.trim()

fn bridgeAlreadyFullControl(state: BridgeAppState) -> bool:
    (state.replBridgeConnected or state.replBridgeEnabled) and not state.replBridgeOutboundOnly

fn callBridgeCommand(args: text, state: BridgeAppState, prereqError: text, shouldShowCallout: bool) -> BridgeCallResult:
    val name = trimInitialName(args)
    if bridgeAlreadyFullControl(state):
        return BridgeCallResult(
            componentName: "BridgeDisconnectDialog",
            initialName: name,
            showDisconnectDialog: true,
            showRemoteCallout: false,
            connect: false,
            onDoneMessage: "",
            onDoneDisplay: "",
            logAction: "",
            error: "",
        )
    if prereqError != "":
        return BridgeCallResult(
            componentName: "BridgeToggle",
            initialName: name,
            showDisconnectDialog: false,
            showRemoteCallout: false,
            connect: false,
            onDoneMessage: prereqError,
            onDoneDisplay: "system",
            logAction: "preflight_failed",
            error: prereqError,
        )
    if shouldShowCallout and not state.showRemoteCallout:
        return BridgeCallResult(
            componentName: "RemoteCallout",
            initialName: name,
            showDisconnectDialog: false,
            showRemoteCallout: true,
            connect: false,
            onDoneMessage: "",
            onDoneDisplay: "system",
            logAction: "",
            error: "",
        )
    BridgeCallResult(
        componentName: "BridgeToggle",
        initialName: name,
        showDisconnectDialog: false,
        showRemoteCallout: false,
        connect: true,
        onDoneMessage: "Remote Control connecting...",
        onDoneDisplay: "system",
        logAction: "connect",
        error: "",
    )

fn connectedBridgeState(state: BridgeAppState, name: text) -> BridgeAppState:
    if state.replBridgeEnabled and not state.replBridgeOutboundOnly:
        return state
    BridgeAppState(
        replBridgeConnected: state.replBridgeConnected,
        replBridgeEnabled: true,
        replBridgeOutboundOnly: false,
        replBridgeExplicit: true,
        replBridgeInitialName: name,
        replBridgeSessionActive: state.replBridgeSessionActive,
        replBridgeSessionUrl: state.replBridgeSessionUrl,
        replBridgeConnectUrl: state.replBridgeConnectUrl,
        showRemoteCallout: state.showRemoteCallout,
    )

fn calloutBridgeState(state: BridgeAppState, name: text) -> BridgeAppState:
    if state.showRemoteCallout:
        return state
    BridgeAppState(
        replBridgeConnected: state.replBridgeConnected,
        replBridgeEnabled: state.replBridgeEnabled,
        replBridgeOutboundOnly: state.replBridgeOutboundOnly,
        replBridgeExplicit: state.replBridgeExplicit,
        replBridgeInitialName: name,
        replBridgeSessionActive: state.replBridgeSessionActive,
        replBridgeSessionUrl: state.replBridgeSessionUrl,
        replBridgeConnectUrl: state.replBridgeConnectUrl,
        showRemoteCallout: true,
    )

fn disconnectedBridgeState(state: BridgeAppState) -> BridgeAppState:
    if not state.replBridgeEnabled:
        return state
    BridgeAppState(
        replBridgeConnected: state.replBridgeConnected,
        replBridgeEnabled: false,
        replBridgeOutboundOnly: false,
        replBridgeExplicit: false,
        replBridgeInitialName: state.replBridgeInitialName,
        replBridgeSessionActive: state.replBridgeSessionActive,
        replBridgeSessionUrl: state.replBridgeSessionUrl,
        replBridgeConnectUrl: state.replBridgeConnectUrl,
        showRemoteCallout: state.showRemoteCallout,
    )

fn bridgeDisplayUrl(state: BridgeAppState) -> text:
    if state.replBridgeSessionActive:
        return state.replBridgeSessionUrl
    state.replBridgeConnectUrl

fn bridgeDialogModel(state: BridgeAppState, focusIndex: i64, showQR: bool) -> BridgeDialogModel:
    BridgeDialogModel(
        title: "Remote Control",
        displayUrl: bridgeDisplayUrl(state),
        focusIndex: focusIndex,
        showQR: showQR,
        qrButtonText: bridgeQrButtonText(showQR),
        helpText: "Enter to select - Esc to continue",
    )

fn bridgeQrButtonText(showQR: bool) -> text:
    if showQR:
        return "Hide QR code"
    "Show QR code"

fn bridgeFocusNext(focusIndex: i64) -> i64:
    (focusIndex + 1) % 3

fn bridgeFocusPrevious(focusIndex: i64) -> i64:
    (focusIndex - 1 + 3) % 3

fn bridgeAcceptAction(focusIndex: i64) -> text:
    if focusIndex == 0:
        return "disconnect"
    if focusIndex == 1:
        return "toggle_qr"
    "continue"

fn bridgeQrLines(qrText: text) -> [text]:
    val lines = qrText.split("\n")
    var out: [text] = []
    for line in lines:
        if line.len() > 0:
            out.push(line)
    out

fn bridgeUsesEnvLessPrereq(input: BridgePrerequisiteInput) -> bool:
    if input.kairosFeature and input.envLessEnabled and input.assistantMode:
        return false
    input.envLessEnabled

fn checkBridgePrerequisitesModel(input: BridgePrerequisiteInput) -> text:
    if not input.policyAllowed:
        return "Remote Control is disabled by your organization's policy."
    if input.disabledReason != "":
        return input.disabledReason
    if bridgeUsesEnvLessPrereq(input):
        if input.envLessVersionError != "":
            return input.envLessVersionError
    else:
        if input.bridgeMinVersionError != "":
            return input.bridgeMinVersionError
    if input.accessToken == "":
        return "Log in to use Remote Control."
    ""

fn bridgeDisconnectMessage() -> text:
    "Remote Control disconnected."

