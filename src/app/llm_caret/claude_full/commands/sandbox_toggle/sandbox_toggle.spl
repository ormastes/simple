class SandboxToggleState:
    enabled: bool

impl SandboxToggleState:
    static fn new(enabled: bool) -> SandboxToggleState:
        SandboxToggleState(enabled: enabled)

fn sandboxToggleCommandName() -> text:
    "sandbox-toggle"

fn toggleSandbox(state: SandboxToggleState) -> SandboxToggleState:
    SandboxToggleState.new(not state.enabled)

fn sandboxToggleMessage(state: SandboxToggleState) -> text:
    if state.enabled:
        return "Sandbox enabled"
    "Sandbox disabled"

fn sandboxToggleSourceLinesModeled() -> i64:
    82
