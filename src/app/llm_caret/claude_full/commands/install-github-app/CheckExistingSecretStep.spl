"""
Claude full install-github-app CheckExistingSecretStep parity model.
"""

class CheckExistingSecretStepModel:
    secretName: text
    checked: bool
    found: bool
    status: text
    message: text

impl CheckExistingSecretStepModel:
    static fn new(secretName: text, checked: bool, found: bool) -> CheckExistingSecretStepModel:
        val normalized = checkExistingSecretNormalizeName(secretName)
        CheckExistingSecretStepModel(
            secretName: normalized,
            checked: checked,
            found: found,
            status: checkExistingSecretStatus(checked, found),
            message: checkExistingSecretMessage(normalized, checked, found),
        )

fn checkExistingSecretNormalizeName(secretName: text) -> text:
    val value = secretName.trim()
    if value == "":
        return "ANTHROPIC_API_KEY"
    value

fn checkExistingSecretStatus(checked: bool, found: bool) -> text:
    if not checked:
        return "checking"
    if found:
        return "found"
    "missing"

fn checkExistingSecretMessage(secretName: text, checked: bool, found: bool) -> text:
    val normalized = checkExistingSecretNormalizeName(secretName)
    if not checked:
        return "Checking for GitHub secret " + normalized
    if found:
        return "Found GitHub secret " + normalized
    "GitHub secret " + normalized + " was not found"

fn checkExistingSecretCanReuse(checked: bool, found: bool) -> bool:
    checked and found

fn checkExistingSecretCommand(owner: text, repo: text, secretName: text) -> text:
    "gh secret list --repo " + owner.trim() + "/" + repo.trim() + " --json name | contains " + checkExistingSecretNormalizeName(secretName)

fn checkExistingSecretNextStep(checked: bool, found: bool) -> text:
    if checkExistingSecretCanReuse(checked, found):
        return "create-workflow"
    if checked:
        return "api-key"
    "check-existing-secret"

fn checkExistingSecretStepSourceLinesModeled() -> i64:
    189
