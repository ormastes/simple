"""
Claude full install-github-app WarningsStep parity.
"""

fn warningsStepTitle() -> text:
    "Warnings"

fn warningsStepCommandTitle() -> text:
    "Install GitHub App"

fn warningsStepStatus() -> text:
    "warning"

fn warningsStepNoWarningsLine() -> text:
    "No warnings"

fn warningsStepContinuePrompt() -> text:
    "Press Enter to continue"

fn warningsStepFormat(count: i64) -> text:
    if count == 0:
        return warningsStepNoWarningsLine()
    if count == 1:
        return "1 warning found"
    "{count} warnings found"

fn warningsStepPermissionWarning() -> text:
    "Repository permissions may need to be updated"

fn warningsStepSecretWarning(secretName: text) -> text:
    "Secret may already exist: " + secretName.trim()

fn warningsStepWorkflowWarning(path: text) -> text:
    "Workflow may already exist: " + path.trim()

fn warningsStepSourceLinesModeled() -> i64:
    72
