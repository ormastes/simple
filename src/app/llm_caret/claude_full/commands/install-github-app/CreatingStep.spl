"""
Claude full install-github-app CreatingStep parity.
"""

fn creatingStepTitle() -> text:
    "Create GitHub Actions workflow"

fn creatingStepCommandTitle() -> text:
    "Install GitHub App"

fn creatingStepStatusPending() -> text:
    "pending"

fn creatingStepStatusInProgress() -> text:
    "in-progress"

fn creatingStepStatusCompleted() -> text:
    "completed"

fn creatingStepStatusSuccess() -> text:
    "success"

fn creatingStepStatusWarning() -> text:
    "warning"

fn creatingStepWorkflowPrompt(skipWorkflow: bool) -> text:
    if skipWorkflow:
        return "Skip workflow update (configure secrets only)"
    "Create GitHub Actions workflow"

fn creatingStepProgressLabel(currentWorkflowInstallStep: text, secretExists: bool) -> text:
    if currentWorkflowInstallStep == "repo":
        return "Getting repository information"
    if currentWorkflowInstallStep == "secret":
        if secretExists:
            return "Using existing API key secret"
        return "Setting up secret"
    if currentWorkflowInstallStep == "branch":
        return "Creating branch"
    if currentWorkflowInstallStep == "pr":
        return "Opening pull request page"
    if currentWorkflowInstallStep == "files":
        return "Creating workflow files"
    if currentWorkflowInstallStep == "file":
        return "Creating workflow file"
    currentWorkflowInstallStep

fn creatingStepSourceLinesModeled() -> i64:
    64
