"""
Claude full install-github-app ErrorStep parity.
"""

fn errorStepTitle() -> text:
    "Install GitHub App"

fn errorStepStatus() -> text:
    "error"

fn errorStepErrorLine(error: text) -> text:
    "Error: " + error

fn errorStepReasonLine(reason: text) -> text:
    "Reason: " + reason

fn errorStepFixHeader() -> text:
    "How to fix:"

fn errorStepManualHelpLine() -> text:
    "For manual setup instructions, see:"

fn errorStepManualCommand() -> text:
    "claude"

fn errorStepExitPrompt() -> text:
    "Press any key to exit"

fn errorStepSummary(error: text, reason: text, instructions: text) -> text:
    errorStepErrorLine(error) + "\n" + errorStepReasonLine(reason) + "\n" + errorStepFixHeader() + "\n" + instructions

fn errorStepSourceLinesModeled() -> i64:
    84
