use app.llm_caret.claude_full.utils.extraUsage.{isBilledAsExtraUsage}

class ModelAppState:
    mainLoopModel: text
    mainLoopModelForSession: text
    fastMode: bool
    effortValue: text

    static fn new(mainLoopModel: text, mainLoopModelForSession: text, fastMode: bool, effortValue: text) -> ModelAppState:
        ModelAppState(mainLoopModel: mainLoopModel, mainLoopModelForSession: mainLoopModelForSession, fastMode: fastMode, effortValue: effortValue)

class ModelCallResult:
    rendered: text
    doneMessage: text
    display: text
    eventName: text
    nextState: ModelAppState
    validated: bool
    fastCooldownCleared: bool
    fastModeToggledOff: bool

    static fn new(rendered: text, doneMessage: text, display: text, eventName: text, nextState: ModelAppState, validated: bool, fastCooldownCleared: bool, fastModeToggledOff: bool) -> ModelCallResult:
        ModelCallResult(rendered: rendered, doneMessage: doneMessage, display: display, eventName: eventName, nextState: nextState, validated: validated, fastCooldownCleared: fastCooldownCleared, fastModeToggledOff: fastModeToggledOff)

fn commonModelInfoArgs() -> [text]:
    ["", "current", "status", "show"]

fn commonModelHelpArgs() -> [text]:
    ["help", "-h", "--help", "?"]

fn modelAliases() -> [text]:
    ["default", "sonnet", "opus", "haiku", "opus[1m]", "sonnet[1m]"]

fn getDefaultMainLoopModelSetting() -> text:
    "default"

fn renderDefaultModelSetting(model: text) -> text:
    if model == "default" or model == "":
        return "Default"
    renderModelName(model)

fn renderModelName(model: text) -> text:
    if model == "":
        return "Default"
    val m = model.lower()
    if m == "opus" or m == "claude-opus-4-6":
        return "Opus 4.6"
    if m == "sonnet" or m == "claude-sonnet-4-6":
        return "Sonnet 4.6"
    if m == "haiku":
        return "Haiku"
    if m.contains("[1m]"):
        return model + " (1M context)"
    model

fn renderModelLabel(model: text) -> text:
    if model == "":
        return renderDefaultModelSetting(getDefaultMainLoopModelSetting()) + " (default)"
    renderDefaultModelSetting(model)

fn isKnownAlias(model: text) -> bool:
    modelAliases().contains(model.lower().trim())

fn isModelAllowed(model: text) -> bool:
    not model.lower().contains("blocked")

fn isOpus1mUnavailable(model: text, hasAccess: bool, mergeEnabled: bool) -> bool:
    val m = model.lower()
    (not hasAccess) and (not mergeEnabled) and m.contains("opus") and m.contains("[1m]")

fn isSonnet1mUnavailable(model: text, hasAccess: bool) -> bool:
    val m = model.lower()
    (not hasAccess) and (m.contains("sonnet[1m]") or m.contains("sonnet-4-6[1m]"))

fn validateModelName(model: text, validationError: text) -> text:
    if validationError != "":
        return validationError
    if model.trim() == "":
        return "Model '" + model + "' not found"
    ""

fn isFastModeSupportedByModel(model: text) -> bool:
    val m = model.lower()
    m.contains("opus") and (m.contains("4-6") or m == "opus" or m.contains("[1m]"))

fn setModelMessage(modelValue: text, wasFastModeOn: bool, fastModeEnabled: bool, opus1mMergeEnabled: bool) -> text:
    var message = "Set model to " + renderModelLabel(modelValue)
    var fastOn = false
    var fastOff = false
    if fastModeEnabled:
        if (not isFastModeSupportedByModel(modelValue)) and wasFastModeOn:
            fastOff = true
        else:
            if isFastModeSupportedByModel(modelValue) and wasFastModeOn:
                message = message + " · Fast mode ON"
                fastOn = true
    if isBilledAsExtraUsage(modelValue, fastOn, opus1mMergeEnabled):
        message = message + " · Billed as extra usage"
    if fastOff:
        message = message + " · Fast mode OFF"
    message

fn applyModel(modelValue: text, state: ModelAppState, fastModeEnabled: bool, opus1mMergeEnabled: bool) -> ModelCallResult:
    val fastOff = fastModeEnabled and state.fastMode and not isFastModeSupportedByModel(modelValue)
    val nextFast = if fastOff: false else: state.fastMode
    val next = ModelAppState.new(modelValue, "", nextFast, state.effortValue)
    ModelCallResult.new("done", setModelMessage(modelValue, state.fastMode, fastModeEnabled, opus1mMergeEnabled), "", "", next, false, fastModeEnabled, fastOff)

fn showCurrentModel(state: ModelAppState) -> ModelCallResult:
    val displayModel = renderModelLabel(state.mainLoopModel)
    val effortInfo = if state.effortValue != "": " (effort: " + state.effortValue + ")" else: ""
    if state.mainLoopModelForSession != "":
        return ModelCallResult.new("done", "Current model: " + renderModelLabel(state.mainLoopModelForSession) + " (session override from plan mode)\nBase model: " + displayModel + effortInfo, "", "tengu_model_command_inline_help", state, false, false, false)
    ModelCallResult.new("done", "Current model: " + displayModel + effortInfo, "", "tengu_model_command_inline_help", state, false, false, false)

fn cancelModelPicker(state: ModelAppState) -> ModelCallResult:
    ModelCallResult.new("done", "Kept model as " + renderModelLabel(state.mainLoopModel), "system", "tengu_model_command_menu", state, false, false, false)

fn selectModelFromPicker(model: text, effort: text, state: ModelAppState, fastModeEnabled: bool, opus1mMergeEnabled: bool) -> ModelCallResult:
    val applied = applyModel(model, state, fastModeEnabled, opus1mMergeEnabled)
    val suffix = if effort != "": " with " + effort + " effort" else: ""
    ModelCallResult.new(applied.rendered, "Set model to " + renderModelLabel(model) + suffix + applied.doneMessage.replace("Set model to " + renderModelLabel(model), ""), applied.display, "tengu_model_command_menu", applied.nextState, applied.validated, applied.fastCooldownCleared, applied.fastModeToggledOff)

fn setModelFromArg(args: text, state: ModelAppState, allowOpus1m: bool, allowSonnet1m: bool, opus1mMergeEnabled: bool, fastModeEnabled: bool, validationError: text) -> ModelCallResult:
    val raw = args.trim()
    val model = if raw == "default": "" else: raw
    if model != "" and not isModelAllowed(model):
        return ModelCallResult.new("done", "Model '" + model + "' is not available. Your organization restricts model selection.", "system", "tengu_model_command_inline", state, false, false, false)
    if model != "" and isOpus1mUnavailable(model, allowOpus1m, opus1mMergeEnabled):
        return ModelCallResult.new("done", "Opus 4.6 with 1M context is not available for your account. Learn more: https://code.claude.com/docs/en/model-config#extended-context-with-1m", "system", "tengu_model_command_inline", state, false, false, false)
    if model != "" and isSonnet1mUnavailable(model, allowSonnet1m):
        return ModelCallResult.new("done", "Sonnet 4.6 with 1M context is not available for your account. Learn more: https://code.claude.com/docs/en/model-config#extended-context-with-1m", "system", "tengu_model_command_inline", state, false, false, false)
    if model == "":
        val appliedDefault = applyModel("", state, fastModeEnabled, opus1mMergeEnabled)
        return ModelCallResult.new(appliedDefault.rendered, appliedDefault.doneMessage, appliedDefault.display, "tengu_model_command_inline", appliedDefault.nextState, false, appliedDefault.fastCooldownCleared, appliedDefault.fastModeToggledOff)
    if isKnownAlias(model):
        val appliedAlias = applyModel(model, state, fastModeEnabled, opus1mMergeEnabled)
        return ModelCallResult.new(appliedAlias.rendered, appliedAlias.doneMessage, appliedAlias.display, "tengu_model_command_inline", appliedAlias.nextState, false, appliedAlias.fastCooldownCleared, appliedAlias.fastModeToggledOff)
    val validation = validateModelName(model, validationError)
    if validation != "":
        return ModelCallResult.new("done", validation, "system", "tengu_model_command_inline", state, true, false, false)
    val appliedCustom = applyModel(model, state, fastModeEnabled, opus1mMergeEnabled)
    ModelCallResult.new(appliedCustom.rendered, appliedCustom.doneMessage, appliedCustom.display, "tengu_model_command_inline", appliedCustom.nextState, true, appliedCustom.fastCooldownCleared, appliedCustom.fastModeToggledOff)

fn callModel(args: text, state: ModelAppState, allowOpus1m: bool, allowSonnet1m: bool, opus1mMergeEnabled: bool, fastModeEnabled: bool, validationError: text) -> ModelCallResult:
    val trimmed = args.trim()
    val lower = trimmed.lower()
    if commonModelInfoArgs().contains(lower):
        return showCurrentModel(state)
    if commonModelHelpArgs().contains(lower):
        return ModelCallResult.new("done", "Run /model to open the model selection menu, or /model [modelName] to set the model.", "system", "", state, false, false, false)
    setModelFromArg(trimmed, state, allowOpus1m, allowSonnet1m, opus1mMergeEnabled, fastModeEnabled, validationError)

fn modelPickerRendered(state: ModelAppState, fastModeEnabled: bool, fastModeAvailable: bool) -> ModelCallResult:
    val showNotice = fastModeEnabled and state.fastMode and isFastModeSupportedByModel(state.mainLoopModel) and fastModeAvailable
    val marker = if showNotice: "picker:fast-notice" else: "picker"
    ModelCallResult.new(marker, "", "", "", state, false, false, false)

fn modelSourceLinesModeled() -> i64:
    296

