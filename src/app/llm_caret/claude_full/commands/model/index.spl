use app.llm_caret.claude_full.commands.model.model.*

class ModelCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    immediate: bool
    loadPath: text

    static fn new(currentModel: text, immediate: bool) -> ModelCommandDescriptor:
        ModelCommandDescriptor(typeName: "local-jsx", name: "model", description: "Set the AI model for Claude Code (currently " + renderModelName(currentModel) + ")", argumentHint: "[model]", immediate: immediate, loadPath: "./model.js")

fn modelCommand(currentModel: text, immediate: bool) -> ModelCommandDescriptor:
    ModelCommandDescriptor.new(currentModel, immediate)

fn modelIndexSourceLinesModeled() -> i64:
    16
