"""
Claude full interactive context command parity.
"""

class ContextCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    isEnabled: bool

impl ContextCommandDescriptor:
    static fn new(isEnabled: bool) -> ContextCommandDescriptor:
        ContextCommandDescriptor(typeName: "local-jsx", name: "context", description: "Show current context usage", argumentHint: "", isEnabled: isEnabled)

class ContextUsage:
    usedTokens: i64
    maxTokens: i64
    transcriptTokens: i64
    systemTokens: i64
    toolTokens: i64

impl ContextUsage:
    static fn new(usedTokens: i64, maxTokens: i64, transcriptTokens: i64, systemTokens: i64, toolTokens: i64) -> ContextUsage:
        ContextUsage(usedTokens: usedTokens, maxTokens: maxTokens, transcriptTokens: transcriptTokens, systemTokens: systemTokens, toolTokens: toolTokens)

class ContextCommandView:
    title: text
    percentText: text
    status: text
    detail: text

impl ContextCommandView:
    static fn new(title: text, percentText: text, status: text, detail: text) -> ContextCommandView:
        ContextCommandView(title: title, percentText: percentText, status: status, detail: detail)

fn contextPercent(usage: ContextUsage) -> i64:
    if usage.maxTokens <= 0:
        return 0
    (usage.usedTokens * 100) / usage.maxTokens

fn contextStatus(usage: ContextUsage) -> text:
    val percent = contextPercent(usage)
    if percent >= 95:
        return "critical"
    if percent >= 80:
        return "warning"
    "healthy"

fn renderContextCommand(usage: ContextUsage) -> ContextCommandView:
    val percent = contextPercent(usage)
    ContextCommandView.new("Context Usage", percent.to_text() + "%", contextStatus(usage), "transcript=" + usage.transcriptTokens.to_text() + " system=" + usage.systemTokens.to_text() + " tools=" + usage.toolTokens.to_text())

fn contextCommandSourceLinesModeled() -> i64:
    63
