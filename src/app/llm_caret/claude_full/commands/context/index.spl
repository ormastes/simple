use app.llm_caret.claude_full.commands.context.context.*

fn contextCommand(isEnabled: bool) -> ContextCommandDescriptor:
    ContextCommandDescriptor.new(isEnabled)

fn contextCommandName() -> text:
    contextCommand(true).name

fn contextCommandDescription() -> text:
    contextCommand(true).description

fn contextCommandType() -> text:
    contextCommand(true).typeName

fn contextIndexSourceLinesModeled() -> i64:
    24
