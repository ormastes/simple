"""
Claude full session command parity.
"""

class SessionSummary:
    id: text
    title: text
    messageCount: i64

impl SessionSummary:
    static fn new(id: text, title: text, messageCount: i64) -> SessionSummary:
        SessionSummary(id: id, title: title, messageCount: messageCount)

fn sessionCommandName() -> text:
    "session"

fn sessionDisplay(summary: SessionSummary) -> text:
    summary.title + " (" + summary.messageCount.to_text() + ")"

fn sessionSourceLinesModeled() -> i64:
    139
