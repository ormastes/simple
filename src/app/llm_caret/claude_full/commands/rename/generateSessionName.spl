"""
Claude full rename session-name generation parity.
"""

fn collapseSessionWhitespace(value: text) -> text:
    var out = ""
    var inWhitespace = false
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == " " or ch == "\n" or ch == "\t" or ch == "\r":
            if not inWhitespace:
                out = out + " "
            inWhitespace = true
        else:
            out = out + ch
            inWhitespace = false
        i = i + 1
    out.trim()

fn stripSessionPrefix(value: text) -> text:
    val trimmed = value.trim()
    if trimmed.starts_with("Human:"):
        return trimmed.slice("Human:".len(), trimmed.len()).trim()
    if trimmed.starts_with("User:"):
        return trimmed.slice("User:".len(), trimmed.len()).trim()
    trimmed

fn truncateSessionName(value: text, maxLength: i64) -> text:
    if value.len() <= maxLength:
        return value
    value.slice(0, maxLength).trim()

fn generateSessionName(prompt: text) -> text:
    val normalized = collapseSessionWhitespace(stripSessionPrefix(prompt))
    if normalized == "":
        return "Untitled conversation"
    truncateSessionName(normalized, 80)

fn generateSessionNameFromMessages(messages: [text]) -> text:
    var i = 0
    while i < messages.len():
        val candidate = generateSessionName(messages[i])
        if candidate != "Untitled conversation":
            return candidate
        i = i + 1
    "Untitled conversation"

fn generateSessionNameSourceLinesModeled() -> i64:
    67
