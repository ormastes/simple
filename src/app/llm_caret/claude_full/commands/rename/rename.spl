"""
Claude full rename command parity.
"""

use app.llm_caret.claude_full.commands.rename.generateSessionName.generateSessionNameFromMessages

class RenameState:
    sessionId: text
    currentName: text
    transcriptPath: text
    messages: [text]

impl RenameState:
    static fn new(sessionId: text, currentName: text, transcriptPath: text, messages: [text]) -> RenameState:
        RenameState(sessionId: sessionId, currentName: currentName, transcriptPath: transcriptPath, messages: messages)

class RenameResult:
    ok: bool
    sessionId: text
    name: text
    message: text
    shouldPersist: bool

impl RenameResult:
    static fn new(ok: bool, sessionId: text, name: text, message: text, shouldPersist: bool) -> RenameResult:
        RenameResult(ok: ok, sessionId: sessionId, name: name, message: message, shouldPersist: shouldPersist)

fn renameCommandEmptyNameMessage() -> text:
    "Please provide a new conversation name."

fn renameCommandSuccessMessage(name: text) -> text:
    "Renamed conversation to \"" + name + "\""

fn renameCommandGeneratedMessage(name: text) -> text:
    "Generated conversation name: \"" + name + "\""

fn effectiveRenameName(args: text, state: RenameState) -> text:
    val requested = args.trim()
    if requested != "":
        return requested
    generateSessionNameFromMessages(state.messages)

fn callRenameCommand(args: text, state: RenameState) -> RenameResult:
    val name = effectiveRenameName(args, state)
    if name == "" or name == "Untitled conversation":
        return RenameResult.new(false, state.sessionId, state.currentName, renameCommandEmptyNameMessage(), false)
    if name == state.currentName:
        return RenameResult.new(true, state.sessionId, name, "Conversation name unchanged.", false)
    val msg = if args.trim() == "": renameCommandGeneratedMessage(name) else: renameCommandSuccessMessage(name)
    RenameResult.new(true, state.sessionId, name, msg, true)

fn renameShouldPersist(result: RenameResult) -> bool:
    result.ok and result.shouldPersist

fn renameSourceLinesModeled() -> i64:
    87
