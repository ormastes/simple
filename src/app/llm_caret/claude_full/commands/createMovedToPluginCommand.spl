"""
Claude full moved-to-plugin command factory parity.
"""

class MovedToPluginCommand:
    typeName: text
    name: text
    description: text
    pluginName: text
    installCommand: text
    runCommand: text
    aliases: [text]

impl MovedToPluginCommand:
    static fn new(name: text, description: text, pluginName: text, installCommand: text, runCommand: text, aliases: [text]) -> MovedToPluginCommand:
        MovedToPluginCommand(typeName: "local", name: name, description: description, pluginName: pluginName, installCommand: installCommand, runCommand: runCommand, aliases: aliases)

class MovedToPluginResult:
    message: text
    display: text
    blocked: bool

impl MovedToPluginResult:
    static fn new(message: text, display: text, blocked: bool) -> MovedToPluginResult:
        MovedToPluginResult(message: message, display: display, blocked: blocked)

fn createMovedToPluginCommand(name: text, description: text, pluginName: text, aliases: [text]) -> MovedToPluginCommand:
    MovedToPluginCommand.new(name, description, pluginName, "/plugin install " + pluginName, "/" + name, aliases)

fn runMovedToPluginCommand(command: MovedToPluginCommand) -> MovedToPluginResult:
    MovedToPluginResult.new("The /" + command.name + " command has moved to the " + command.pluginName + " plugin. Install it with " + command.installCommand + " and then run " + command.runCommand + ".", "system", true)

fn movedToPluginAliasCount(command: MovedToPluginCommand) -> i64:
    command.aliases.len()

fn movedToPluginSourceLinesModeled() -> i64:
    65
