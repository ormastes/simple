"""
Claude full brief command parity.
"""

class BriefConfig:
    enableSlashCommand: bool

impl BriefConfig:
    static fn new(enableSlashCommand: bool) -> BriefConfig:
        BriefConfig(enableSlashCommand: enableSlashCommand)

class BriefAppState:
    isBriefOnly: bool
    userMsgOptIn: bool
    kairosActive: bool

impl BriefAppState:
    static fn new(isBriefOnly: bool, userMsgOptIn: bool, kairosActive: bool) -> BriefAppState:
        BriefAppState(isBriefOnly: isBriefOnly, userMsgOptIn: userMsgOptIn, kairosActive: kairosActive)

class BriefCommandResult:
    state: BriefAppState
    doneMessage: text
    display: text
    metaMessage: text
    eventEnabled: bool
    gated: bool

impl BriefCommandResult:
    static fn new(state: BriefAppState, doneMessage: text, display: text, metaMessage: text, eventEnabled: bool, gated: bool) -> BriefCommandResult:
        BriefCommandResult(state: state, doneMessage: doneMessage, display: display, metaMessage: metaMessage, eventEnabled: eventEnabled, gated: gated)

class BriefCommand:
    typeName: text
    name: text
    description: text
    immediate: bool
    enabled: bool

impl BriefCommand:
    static fn new(kairosFeature: bool, kairosBriefFeature: bool, config: BriefConfig) -> BriefCommand:
        BriefCommand(typeName: "local-jsx", name: "brief", description: "Toggle brief-only mode", immediate: true, enabled: (kairosFeature or kairosBriefFeature) and config.enableSlashCommand)

fn toggleBriefCommand(state: BriefAppState, entitled: bool) -> BriefCommandResult:
    val newState = not state.isBriefOnly
    if newState and not entitled:
        return BriefCommandResult.new(state, "Brief tool is not enabled for your account", "system", "", false, true)
    val next = BriefAppState.new(newState, newState, state.kairosActive)
    var meta = ""
    if not state.kairosActive:
        if newState:
            meta = "<system-reminder>\nBrief mode is now enabled. Use the Brief tool for all user-facing output - plain text outside it is hidden from the user's view.\n</system-reminder>"
        else:
            meta = "<system-reminder>\nBrief mode is now disabled. The Brief tool is no longer available - reply with plain text.\n</system-reminder>"
    var done = "Brief-only mode disabled"
    if newState:
        done = "Brief-only mode enabled"
    BriefCommandResult.new(next, done, "system", meta, newState, false)

fn briefSourceLinesModeled() -> i64:
    130
