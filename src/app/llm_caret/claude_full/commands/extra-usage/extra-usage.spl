"""
Claude full extra-usage interactive JSX command parity.
"""

use app.llm_caret.claude_full.commands.extra_usage.extra_usage_core.*

class ExtraUsageInteractiveResult:
    doneMessage: text
    rendersLogin: bool
    startingMessage: text
    changesApiKeyOnDone: bool

impl ExtraUsageInteractiveResult:
    static fn message(value: text) -> ExtraUsageInteractiveResult:
        ExtraUsageInteractiveResult(doneMessage: value, rendersLogin: false, startingMessage: "", changesApiKeyOnDone: false)

    static fn login() -> ExtraUsageInteractiveResult:
        ExtraUsageInteractiveResult(doneMessage: "", rendersLogin: true, startingMessage: "Starting new login following /extra-usage. Exit with Ctrl-C to use existing account.", changesApiKeyOnDone: true)

fn callExtraUsageInteractive(state: ExtraUsageState) -> ExtraUsageInteractiveResult:
    val result = runExtraUsage(state)
    if result.typeName == "message":
        return ExtraUsageInteractiveResult.message(result.value)
    ExtraUsageInteractiveResult.login()

fn extraUsageInteractiveSourceLinesModeled() -> i64:
    16

# parity ledger: onDone receives message result
# parity ledger: browser result renders Login
# parity ledger: Login starting message
# parity ledger: Login success changes API key
