"""
Claude full extra-usage command index parity.
"""

use app.llm_caret.claude_full.commands.extra_usage.extra_usage_core.*

class ExtraUsageCommand:
    typeName: text
    name: text
    description: text
    supportsNonInteractive: bool
    isHidden: bool
    enabled: bool
    loadPath: text

impl ExtraUsageCommand:
    static fn interactive(state: ExtraUsageState) -> ExtraUsageCommand:
        ExtraUsageCommand(typeName: "local-jsx", name: "extra-usage", description: EXTRA_USAGE_DESCRIPTION, supportsNonInteractive: false, isHidden: false, enabled: isExtraUsageAllowed(state) and !state.nonInteractive, loadPath: "./extra-usage.js")

    static fn noninteractive(state: ExtraUsageState) -> ExtraUsageCommand:
        ExtraUsageCommand(typeName: "local", name: "extra-usage", description: EXTRA_USAGE_DESCRIPTION, supportsNonInteractive: true, isHidden: !state.nonInteractive, enabled: isExtraUsageAllowed(state) and state.nonInteractive, loadPath: "./extra-usage-noninteractive.js")

fn extraUsageCommand(state: ExtraUsageState) -> ExtraUsageCommand:
    ExtraUsageCommand.interactive(state)

fn extraUsageNonInteractiveCommand(state: ExtraUsageState) -> ExtraUsageCommand:
    ExtraUsageCommand.noninteractive(state)

fn extraUsageCommandName() -> text:
    "extra-usage"

fn extraUsageIndexSourceLinesModeled() -> i64:
    31

