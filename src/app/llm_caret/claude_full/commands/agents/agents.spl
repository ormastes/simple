"""
Claude full agents command call parity.
"""

class AgentsMenuView:
    tools: [text]
    onExitBound: bool

impl AgentsMenuView:
    static fn new(tools: [text]) -> AgentsMenuView:
        AgentsMenuView(tools: tools, onExitBound: true)

fn callAgentsCommand(permissionTools: [text]) -> AgentsMenuView:
    AgentsMenuView.new(permissionTools)

fn agentsCommandSourceLinesModeled() -> i64:
    11
