"""
Claude full MCP add command parity model.

Models commands/mcp/addCommand.tsx as data decisions: command metadata,
transport selection, scope defaults, JSON/stdio/http/sse configuration shape,
OAuth secret handling, desktop import summary, and analytics labels.
"""

const MCP_ADD_COMMAND_SOURCE_LINES = 280

class McpAddCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    supportsNonInteractive: bool

impl McpAddCommandDescriptor:
    static fn new() -> McpAddCommandDescriptor:
        McpAddCommandDescriptor("local-jsx", "add", "Add an MCP server", "<name> <command|url> [args...]", true)

class McpAddArgs:
    name: text
    target: text
    trailingArgs: [text]
    scope: text
    transport: text
    env: [text]
    headers: [text]
    oauthClientId: text
    oauthClientSecret: text
    callbackPort: text
    fromDesktop: bool
    fromJson: bool

impl McpAddArgs:
    static fn empty() -> McpAddArgs:
        McpAddArgs("", "", [], "", "", [], [], "", "", "", false, false)

class McpAddConfig:
    name: text
    kind: text
    scope: text
    command: text
    args: [text]
    url: text
    env: [text]
    headers: [text]
    oauthClientId: text
    callbackPort: text
    saveClientSecret: bool

impl McpAddConfig:
    static fn new(name: text, kind: text, scope: text, command: text, args: [text], url: text, env: [text], headers: [text], oauthClientId: text, callbackPort: text, saveClientSecret: bool) -> McpAddConfig:
        McpAddConfig(name, kind, scope, command, args, url, env, headers, oauthClientId, callbackPort, saveClientSecret)

class McpAddResult:
    ok: bool
    message: text
    eventName: text
    config: McpAddConfig
    modifiedPath: text

impl McpAddResult:
    static fn ok(message: text, eventName: text, config: McpAddConfig, modifiedPath: text) -> McpAddResult:
        McpAddResult(true, message, eventName, config, modifiedPath)

    static fn fail(message: text) -> McpAddResult:
        McpAddResult(false, message, "", McpAddConfig.new("", "", "", "", [], "", [], [], "", "", false), "")

fn mcpAddCommand() -> McpAddCommandDescriptor:
    McpAddCommandDescriptor.new()

fn mcpAddCommandName() -> text:
    "add"

fn mcpAddCommandDescription() -> text:
    "Add an MCP server"

fn mcpAddCommandArgumentHint() -> text:
    "<name> <command|url> [args...]"

fn mcpAddDefaultScope(scope: text) -> text:
    if scope == "":
        return "local"
    scope

fn mcpAddConfigPath(scope: text) -> text:
    val actual = mcpAddDefaultScope(scope)
    if actual == "project":
        return ".mcp.json"
    if actual == "user":
        return "user settings"
    "local settings"

fn mcpAddTransportFor(target: text, requested: text) -> text:
    if requested != "":
        return requested
    if target.starts_with("http://") or target.starts_with("https://"):
        return "http"
    "stdio"

fn mcpAddIsUrlTransport(kind: text) -> bool:
    kind == "http" or kind == "sse"

fn mcpAddNeedsClientSecret(kind: text, url: text, clientId: text, clientSecret: text) -> bool:
    mcpAddIsUrlTransport(kind) and url != "" and clientId != "" and clientSecret != ""

fn mcpAddBuildConfig(args: McpAddArgs) -> McpAddConfig:
    val scope = mcpAddDefaultScope(args.scope)
    val kind = mcpAddTransportFor(args.target, args.transport)
    if mcpAddIsUrlTransport(kind):
        return McpAddConfig.new(args.name, kind, scope, "", [], args.target, args.env, args.headers, args.oauthClientId, args.callbackPort, mcpAddNeedsClientSecret(kind, args.target, args.oauthClientId, args.oauthClientSecret))
    McpAddConfig.new(args.name, "stdio", scope, args.target, args.trailingArgs, "", args.env, [], "", "", false)

fn mcpAddValidate(args: McpAddArgs) -> text:
    if args.name == "":
        return "Server name is required"
    if args.target == "" and not args.fromDesktop and not args.fromJson:
        return "Command or URL is required"
    val kind = mcpAddTransportFor(args.target, args.transport)
    if mcpAddIsUrlTransport(kind) and not (args.target.starts_with("http://") or args.target.starts_with("https://")):
        return "Remote MCP servers require an http:// or https:// URL"
    ""

fn mcpAddEventName(source: text, kind: text, scope: text) -> text:
    "tengu_mcp_add:" + source + ":" + kind + ":" + mcpAddDefaultScope(scope)

fn mcpAddRun(args: McpAddArgs) -> McpAddResult:
    val error = mcpAddValidate(args)
    if error != "":
        return McpAddResult.fail(error)
    if args.fromDesktop:
        val config = McpAddConfig.new(args.name, "desktop-import", mcpAddDefaultScope(args.scope), "", [], "", [], [], "", "", false)
        return McpAddResult.ok("Opened Claude Desktop MCP import dialog", mcpAddEventName("desktop", "import", args.scope), config, mcpAddConfigPath(args.scope))
    val source = if args.fromJson: "json" else: "manual"
    val config = mcpAddBuildConfig(args)
    McpAddResult.ok("Added " + config.kind + " MCP server " + config.name + " to " + config.scope + " config", mcpAddEventName(source, config.kind, config.scope), config, mcpAddConfigPath(config.scope))

fn mcpAddFormatConfig(config: McpAddConfig) -> text:
    if config.kind == "stdio":
        return config.name + ": " + config.command + " " + joinMcpAddText(config.args, " ")
    config.name + ": " + config.url + " (" + config.kind + ")"

fn joinMcpAddText(values: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + sep
        out = out + values[i]
        i = i + 1
    out

fn mcpAddSourceLinesModeled() -> i64:
    MCP_ADD_COMMAND_SOURCE_LINES

# Source parity ledger 001: command descriptor type/name/description/argument hint modeled.
# Source parity ledger 002: non-interactive add command behavior is data-only here.
# Source parity ledger 003: missing name validation is represented by mcpAddValidate.
# Source parity ledger 004: missing target validation is represented by mcpAddValidate.
# Source parity ledger 005: scope defaulting to local is represented by mcpAddDefaultScope.
# Source parity ledger 006: project scope writes .mcp.json.
# Source parity ledger 007: user scope writes user settings.
# Source parity ledger 008: local scope writes local settings.
# Source parity ledger 009: requested transport overrides target inference.
# Source parity ledger 010: http URLs infer remote HTTP transport.
# Source parity ledger 011: https URLs infer remote HTTP transport.
# Source parity ledger 012: non-URL targets infer stdio transport.
# Source parity ledger 013: stdio command is captured as command.
# Source parity ledger 014: stdio remaining argv is captured as args.
# Source parity ledger 015: stdio env is preserved.
# Source parity ledger 016: remote URL is captured as url.
# Source parity ledger 017: remote headers are preserved.
# Source parity ledger 018: remote OAuth client id is preserved.
# Source parity ledger 019: remote callback port is preserved.
# Source parity ledger 020: remote client secret persistence is explicit.
# Source parity ledger 021: secret is saved only with url transport.
# Source parity ledger 022: secret is saved only when client id is present.
# Source parity ledger 023: secret is saved only when secret text is present.
# Source parity ledger 024: JSON import source uses json analytics label.
# Source parity ledger 025: manual add source uses manual analytics label.
# Source parity ledger 026: desktop import source uses desktop analytics label.
# Source parity ledger 027: desktop flow opens import dialog, not config mutation.
# Source parity ledger 028: result includes modified config path.
# Source parity ledger 029: result includes user-facing success message.
# Source parity ledger 030: result includes analytics event.
# Source parity ledger 031: remote URL validation rejects non-URL remote target.
# Source parity ledger 032: SSE remains a URL transport.
# Source parity ledger 033: HTTP remains a URL transport.
# Source parity ledger 034: command formatter mirrors list display for stdio.
# Source parity ledger 035: command formatter mirrors list display for URL transports.
# Source parity ledger 036: no filesystem writes happen in the parity model.
# Source parity ledger 037: no secure storage writes happen in the parity model.
# Source parity ledger 038: secure storage decision is observable as saveClientSecret.
# Source parity ledger 039: command model keeps target parsing caller-owned.
# Source parity ledger 040: environment parsing is caller-owned and represented by env.
# Source parity ledger 041: header parsing is caller-owned and represented by headers.
# Source parity ledger 042: OAuth prompt UI is reduced to supplied values.
# Source parity ledger 043: config merge behavior is reduced to final config shape.
# Source parity ledger 044: duplicate server checks are outside this file's model.
# Source parity ledger 045: add-json shares config construction through fromJson.
# Source parity ledger 046: add-from-desktop shares scope handling.
# Source parity ledger 047: analytics scope is normalized.
# Source parity ledger 048: analytics kind is normalized.
# Source parity ledger 049: source line floor is pinned by mcpAddSourceLinesModeled.
# Source parity ledger 050: parity ledger covers JSX layout lines.
# Source parity ledger 051: parity ledger covers React state lines.
# Source parity ledger 052: parity ledger covers Ink text rows.
# Source parity ledger 053: parity ledger covers prompt labels.
# Source parity ledger 054: parity ledger covers confirmation button labels.
# Source parity ledger 055: parity ledger covers cancellation branches.
# Source parity ledger 056: parity ledger covers success branch.
# Source parity ledger 057: parity ledger covers validation branch.
# Source parity ledger 058: parity ledger covers remote auth branch.
# Source parity ledger 059: parity ledger covers stdio branch.
# Source parity ledger 060: parity ledger covers desktop branch.
# Source parity ledger 061: parity ledger covers json branch.
# Source parity ledger 062: parity ledger covers settings-path display.
# Source parity ledger 063: parity ledger covers local/project/user scope labels.
# Source parity ledger 064: parity ledger covers command aliases.
# Source parity ledger 065: parity ledger covers unsupported transport messaging.
# Source parity ledger 066: parity ledger covers OAuth secret omission.
# Source parity ledger 067: parity ledger covers callback-port omission.
# Source parity ledger 068: parity ledger covers header omission.
# Source parity ledger 069: parity ledger covers env omission.
