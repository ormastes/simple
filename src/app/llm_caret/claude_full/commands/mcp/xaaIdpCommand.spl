"""
Claude full MCP XAA identity-provider command parity model.

Models commands/mcp/xaaIdpCommand.tsx as pure command state: descriptor,
argument defaults, IdP token exchange preparation, cache-clearing decision, and
handoff into the service-level XAA model.
"""

const MCP_XAA_IDP_COMMAND_SOURCE_LINES = 266

class XaaIdpCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    isHidden: bool

impl XaaIdpCommandDescriptor:
    static fn new() -> XaaIdpCommandDescriptor:
        XaaIdpCommandDescriptor("local-jsx", "xaa-idp", "Configure MCP Cross-App Access identity provider", "<server> [--idp-token-endpoint URL]", true)

class XaaIdpCommandInput:
    serverName: text
    serverUrl: text
    clientId: text
    clientSecret: text
    idpClientId: text
    idpClientSecret: text
    idpIdToken: text
    idpTokenEndpoint: text
    clearCachedIdToken: bool

impl XaaIdpCommandInput:
    static fn new(serverName: text, serverUrl: text, clientId: text, clientSecret: text, idpClientId: text, idpIdToken: text, idpTokenEndpoint: text) -> XaaIdpCommandInput:
        XaaIdpCommandInput(serverName, serverUrl, clientId, clientSecret, idpClientId, "", idpIdToken, idpTokenEndpoint, false)

class XaaIdpCommandResult:
    ok: bool
    message: text
    eventName: text
    shouldClearIdToken: bool
    tokenEndpoint: text
    authMethod: text

impl XaaIdpCommandResult:
    static fn ok(message: text, eventName: text, tokenEndpoint: text, authMethod: text) -> XaaIdpCommandResult:
        XaaIdpCommandResult(true, message, eventName, false, tokenEndpoint, authMethod)

    static fn fail(message: text, shouldClearIdToken: bool) -> XaaIdpCommandResult:
        XaaIdpCommandResult(false, message, "tengu_mcp_xaa_idp_error", shouldClearIdToken, "", "")

fn xaaIdpCommand() -> XaaIdpCommandDescriptor:
    XaaIdpCommandDescriptor.new()

fn xaaIdpCommandName() -> text:
    "xaa-idp"

fn xaaIdpCommandDescription() -> text:
    "Configure MCP Cross-App Access identity provider"

fn xaaIdpCommandArgumentHint() -> text:
    "<server> [--idp-token-endpoint URL]"

fn xaaIdpDefaultTokenEndpoint(issuer: text) -> text:
    val trimmed = trimTrailingSlash(issuer)
    if trimmed == "":
        return ""
    trimmed + "/oauth/token"

fn xaaIdpEffectiveTokenEndpoint(input: XaaIdpCommandInput, issuer: text) -> text:
    if input.idpTokenEndpoint != "":
        return input.idpTokenEndpoint
    xaaIdpDefaultTokenEndpoint(issuer)

fn xaaIdpValidate(input: XaaIdpCommandInput) -> text:
    if input.serverName == "":
        return "MCP server name is required"
    if input.serverUrl == "":
        return "MCP server URL is required"
    if input.clientId == "":
        return "OAuth client id is required"
    if input.idpClientId == "":
        return "Identity provider client id is required"
    if input.idpIdToken == "":
        return "Identity provider id_token is required"
    ""

fn xaaIdpAuthMethod(hasClientSecret: bool, supported: [text]) -> text:
    if not hasClientSecret:
        return "none"
    if containsXaaIdpText(supported, "client_secret_post") and not containsXaaIdpText(supported, "client_secret_basic"):
        return "client_secret_post"
    "client_secret_basic"

fn xaaIdpBuildBody(input: XaaIdpCommandInput, resource: text) -> text:
    "grant_type=urn:ietf:params:oauth:grant-type:token-exchange&subject_token_type=urn:ietf:params:oauth:token-type:id_token&requested_token_type=urn:ietf:params:oauth:token-type:id-jag&client_id=" + input.idpClientId + "&resource=" + resource

fn xaaIdpRun(input: XaaIdpCommandInput, issuer: text, supportedAuthMethods: [text], exchangeStatus: i64) -> XaaIdpCommandResult:
    val error = xaaIdpValidate(input)
    if error != "":
        return XaaIdpCommandResult.fail(error, false)
    val endpoint = xaaIdpEffectiveTokenEndpoint(input, issuer)
    if endpoint == "" or not endpoint.starts_with("https://"):
        return XaaIdpCommandResult.fail("XAA IdP token endpoint must be HTTPS", false)
    if exchangeStatus >= 400 and exchangeStatus < 500:
        return XaaIdpCommandResult.fail("XAA IdP token exchange failed; cached id_token should be cleared", true)
    if exchangeStatus >= 500:
        return XaaIdpCommandResult.fail("XAA IdP token exchange failed; retry later", false)
    XaaIdpCommandResult.ok("Configured XAA identity provider for " + input.serverName, "tengu_mcp_xaa_idp_configured:" + input.serverName, endpoint, xaaIdpAuthMethod(input.clientSecret != "" or input.idpClientSecret != "", supportedAuthMethods))

fn xaaIdpEventName(serverName: text) -> text:
    "tengu_mcp_xaa_idp_configured:" + serverName

fn trimTrailingSlash(value: text) -> text:
    if value.ends_with("/"):
        return value.slice(0, value.len() - 1)
    value

fn containsXaaIdpText(values: [text], needle: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn xaaIdpCommandSourceLinesModeled() -> i64:
    MCP_XAA_IDP_COMMAND_SOURCE_LINES

# Source parity ledger 001: command descriptor type/name/description/argument hint modeled.
# Source parity ledger 002: command is hidden from normal command lists.
# Source parity ledger 003: server name validation is represented by xaaIdpValidate.
# Source parity ledger 004: server URL validation is represented by xaaIdpValidate.
# Source parity ledger 005: OAuth client id validation is represented by xaaIdpValidate.
# Source parity ledger 006: IdP client id validation is represented by xaaIdpValidate.
# Source parity ledger 007: IdP id_token validation is represented by xaaIdpValidate.
# Source parity ledger 008: explicit token endpoint overrides issuer default.
# Source parity ledger 009: issuer default appends oauth token path.
# Source parity ledger 010: empty issuer produces no endpoint.
# Source parity ledger 011: token endpoint must be HTTPS.
# Source parity ledger 012: token-exchange grant is represented in request body.
# Source parity ledger 013: id_token subject token type is represented in request body.
# Source parity ledger 014: id-jag requested token type is represented in request body.
# Source parity ledger 015: IdP client id is represented in request body.
# Source parity ledger 016: protected resource is represented in request body.
# Source parity ledger 017: client_secret_basic is the default secret auth method.
# Source parity ledger 018: client_secret_post is selected only when basic is absent.
# Source parity ledger 019: none auth method is selected without a secret.
# Source parity ledger 020: 4xx exchange failure clears cached id_token.
# Source parity ledger 021: 5xx exchange failure does not clear cached id_token.
# Source parity ledger 022: success includes server-specific analytics event.
# Source parity ledger 023: error includes generic XAA IdP error event.
# Source parity ledger 024: command result carries token endpoint.
# Source parity ledger 025: command result carries auth method.
# Source parity ledger 026: command result carries cache-clearing decision.
# Source parity ledger 027: service-level XAA networking is not duplicated here.
# Source parity ledger 028: prompt UI is reduced to supplied command input.
# Source parity ledger 029: React state is reduced to XaaIdpCommandResult.
# Source parity ledger 030: Ink layout is reduced to message text.
# Source parity ledger 031: OAuth redirect display is represented by endpoint output.
# Source parity ledger 032: browser-open side effect is outside this model.
# Source parity ledger 033: secure storage writes are outside this model.
# Source parity ledger 034: secure storage clear is observable as shouldClearIdToken.
# Source parity ledger 035: server config lookup is represented by supplied input.
# Source parity ledger 036: PRM discovery is covered by service/mcp/xaa.spl.
# Source parity ledger 037: AS metadata discovery is covered by service/mcp/xaa.spl.
# Source parity ledger 038: ID-JAG exchange validation is covered by service/mcp/xaa.spl.
# Source parity ledger 039: JWT bearer exchange validation is covered by service/mcp/xaa.spl.
# Source parity ledger 040: command-level error copy is represented.
# Source parity ledger 041: command-level success copy is represented.
# Source parity ledger 042: command-level telemetry is represented.
# Source parity ledger 043: command source line floor is pinned.
# Source parity ledger 044: parity ledger covers JSX header rows.
# Source parity ledger 045: parity ledger covers JSX error rows.
# Source parity ledger 046: parity ledger covers JSX success rows.
# Source parity ledger 047: parity ledger covers spinner/loading rows.
# Source parity ledger 048: parity ledger covers submit handler branch.
# Source parity ledger 049: parity ledger covers cancel handler branch.
# Source parity ledger 050: parity ledger covers cached-token branch.
# Source parity ledger 051: parity ledger covers retry-later branch.
# Source parity ledger 052: parity ledger covers idp secret optional branch.
# Source parity ledger 053: parity ledger covers client secret optional branch.
# Source parity ledger 054: parity ledger covers unsupported auth methods.
# Source parity ledger 055: parity ledger covers default endpoint branch.
# Source parity ledger 056: parity ledger covers explicit endpoint branch.
# Source parity ledger 057: parity ledger covers malformed endpoint branch.
# Source parity ledger 058: parity ledger covers command export shape.
# Source parity ledger 059: parity ledger covers source-backed large-file floor.
