class EffortCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    immediate: bool
    loadPath: text

    static fn new(inferenceConfigImmediate: bool) -> EffortCommandDescriptor:
        EffortCommandDescriptor(typeName: "local-jsx", name: "effort", description: "Set effort level for model usage", argumentHint: "[low|medium|high|max|auto]", immediate: inferenceConfigImmediate, loadPath: "./effort.js")

fn effortCommand(inferenceConfigImmediate: bool) -> EffortCommandDescriptor:
    EffortCommandDescriptor.new(inferenceConfigImmediate)

fn effortIndexSourceLinesModeled() -> i64:
    13
