class EffortCommandResult:
    message: text
    hasEffortUpdate: bool
    effortValue: text
    settingsValue: text
    loggedEffort: text

    static fn new(message: text, hasEffortUpdate: bool, effortValue: text, settingsValue: text, loggedEffort: text) -> EffortCommandResult:
        EffortCommandResult(message: message, hasEffortUpdate: hasEffortUpdate, effortValue: effortValue, settingsValue: settingsValue, loggedEffort: loggedEffort)

class EffortCallResult:
    rendered: text
    message: text
    hasEffortUpdate: bool
    effortValue: text
    settingsValue: text
    loggedEffort: text

    static fn new(rendered: text, message: text, hasEffortUpdate: bool, effortValue: text, settingsValue: text, loggedEffort: text) -> EffortCallResult:
        EffortCallResult(rendered: rendered, message: message, hasEffortUpdate: hasEffortUpdate, effortValue: effortValue, settingsValue: settingsValue, loggedEffort: loggedEffort)

fn effortHelpMessage() -> text:
    "Usage: /effort [low|medium|high|max|auto]\n\nEffort levels:\n- low: Quick, straightforward implementation\n- medium: Balanced approach with standard testing\n- high: Comprehensive implementation with extensive testing\n- max: Maximum capability with deepest reasoning (Opus 4.6 only)\n- auto: Use the default effort level for your model"

fn isEffortHelpArg(args: text) -> bool:
    val normalized = args.trim()
    normalized == "help" or normalized == "-h" or normalized == "--help"

fn isEffortLevel(value: text) -> bool:
    value == "low" or value == "medium" or value == "high" or value == "max"

fn toPersistableEffort(value: text) -> text:
    if value == "max":
        return ""
    value

fn getEffortValueDescription(value: text) -> text:
    if value == "low":
        return "Quick, straightforward implementation"
    if value == "medium":
        return "Balanced approach with standard testing"
    if value == "high":
        return "Comprehensive implementation with extensive testing"
    if value == "max":
        return "Maximum capability with deepest reasoning (Opus 4.6 only)"
    "Use the default effort level for your model"

fn getDisplayedEffortLevel(model: text, appStateEffort: text) -> text:
    if appStateEffort != "":
        return appStateEffort
    val lowerModel = model.lower()
    if lowerModel.contains("opus"):
        return "high"
    if lowerModel.contains("sonnet"):
        return "medium"
    "medium"

fn normalizeEffortEnvOverride(envRaw: text) -> text:
    val normalized = envRaw.trim().lower()
    if normalized == "":
        return ""
    if normalized == "auto" or normalized == "unset":
        return "auto"
    if isEffortLevel(normalized):
        return normalized
    ""

fn setEffortValue(effortValue: text, envRaw: text, settingsError: text) -> EffortCommandResult:
    val persistable = toPersistableEffort(effortValue)
    if persistable != "" and settingsError != "":
        return EffortCommandResult.new("Failed to set effort level: " + settingsError, false, "", persistable, "")
    val envOverride = normalizeEffortEnvOverride(envRaw)
    if envOverride != "" and envOverride != "auto" and envOverride != effortValue:
        if persistable == "":
            return EffortCommandResult.new("Not applied: CLAUDE_CODE_EFFORT_LEVEL=" + envRaw + " overrides effort this session, and " + effortValue + " is session-only (nothing saved)", true, effortValue, persistable, effortValue)
        return EffortCommandResult.new("CLAUDE_CODE_EFFORT_LEVEL=" + envRaw + " overrides this session - clear it and " + effortValue + " takes over", true, effortValue, persistable, effortValue)
    val suffix = if persistable == "": " (this session only)" else: ""
    EffortCommandResult.new("Set effort level to " + effortValue + suffix + ": " + getEffortValueDescription(effortValue), true, effortValue, persistable, effortValue)

fn unsetEffortLevel(envRaw: text, settingsError: text) -> EffortCommandResult:
    if settingsError != "":
        return EffortCommandResult.new("Failed to set effort level: " + settingsError, false, "", "", "")
    val envOverride = normalizeEffortEnvOverride(envRaw)
    if envOverride != "" and envOverride != "auto":
        return EffortCommandResult.new("Cleared effort from settings, but CLAUDE_CODE_EFFORT_LEVEL=" + envRaw + " still controls this session", true, "", "", "auto")
    EffortCommandResult.new("Effort level set to auto", true, "", "", "auto")

fn showCurrentEffort(appStateEffort: text, model: text, envRaw: text) -> EffortCommandResult:
    val envOverride = normalizeEffortEnvOverride(envRaw)
    val effectiveValue = if envOverride == "auto": "" else: if envOverride != "": envOverride else: appStateEffort
    if effectiveValue == "":
        val level = getDisplayedEffortLevel(model, appStateEffort)
        return EffortCommandResult.new("Effort level: auto (currently " + level + ")", false, "", "", "")
    EffortCommandResult.new("Current effort level: " + effectiveValue + " (" + getEffortValueDescription(effectiveValue) + ")", false, "", "", "")

fn executeEffort(args: text, envRaw: text, settingsError: text) -> EffortCommandResult:
    val normalized = args.lower()
    if normalized == "auto" or normalized == "unset":
        return unsetEffortLevel(envRaw, settingsError)
    if not isEffortLevel(normalized):
        return EffortCommandResult.new("Invalid argument: " + args + ". Valid options are: low, medium, high, max, auto", false, "", "", "")
    setEffortValue(normalized, envRaw, settingsError)

fn callEffort(args: text, appStateEffort: text, model: text, envRaw: text, settingsError: text) -> EffortCallResult:
    val trimmed = args.trim()
    if isEffortHelpArg(trimmed):
        return EffortCallResult.new("done", effortHelpMessage(), false, "", "", "")
    if trimmed == "" or trimmed == "current" or trimmed == "status":
        val result = showCurrentEffort(appStateEffort, model, envRaw)
        return EffortCallResult.new("show-current", result.message, result.hasEffortUpdate, result.effortValue, result.settingsValue, result.loggedEffort)
    val result = executeEffort(trimmed, envRaw, settingsError)
    EffortCallResult.new("apply-and-close", result.message, result.hasEffortUpdate, result.effortValue, result.settingsValue, result.loggedEffort)

fn effortSourceLinesModeled() -> i64:
    182
