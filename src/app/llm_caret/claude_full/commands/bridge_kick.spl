"""
Claude full bridge-kick command parity.
"""

const BRIDGE_KICK_USAGE = "/bridge-kick <subcommand>"

class BridgeDebugHandle:
    connected: bool
    firedCloseCode: i64
    faultMethod: text
    faultKind: text
    faultStatus: i64
    faultErrorType: text
    faultCount: i64
    pollWoken: bool
    reconnectForced: bool
    description: text

impl BridgeDebugHandle:
    static fn new() -> BridgeDebugHandle:
        BridgeDebugHandle(connected: true, firedCloseCode: 0, faultMethod: "", faultKind: "", faultStatus: 0, faultErrorType: "", faultCount: 0, pollWoken: false, reconnectForced: false, description: "bridge ready")

    fn fireClose(code: i64) -> BridgeDebugHandle:
        var next = self.copy()
        next.firedCloseCode = code
        next

    fn injectFault(method: text, kind: text, status: i64, errorType: text, count: i64) -> BridgeDebugHandle:
        var next = self.copy()
        next.faultMethod = method
        next.faultKind = kind
        next.faultStatus = status
        next.faultErrorType = errorType
        next.faultCount = count
        next

    fn wakePollLoop() -> BridgeDebugHandle:
        var next = self.copy()
        next.pollWoken = true
        next

    fn forceReconnect() -> BridgeDebugHandle:
        var next = self.copy()
        next.reconnectForced = true
        next

    fn copy() -> BridgeDebugHandle:
        BridgeDebugHandle(connected: self.connected, firedCloseCode: self.firedCloseCode, faultMethod: self.faultMethod, faultKind: self.faultKind, faultStatus: self.faultStatus, faultErrorType: self.faultErrorType, faultCount: self.faultCount, pollWoken: self.pollWoken, reconnectForced: self.reconnectForced, description: self.description)

class BridgeKickResult:
    handle: BridgeDebugHandle
    message: text

impl BridgeKickResult:
    static fn new(handle: BridgeDebugHandle, message: text) -> BridgeKickResult:
        BridgeKickResult(handle: handle, message: message)

fn callBridgeKick(args: text, handleRegistered: bool, handle: BridgeDebugHandle) -> BridgeKickResult:
    if not handleRegistered:
        return BridgeKickResult.new(handle, "No bridge debug handle registered. Remote Control must be connected (USER_TYPE=ant).")
    val trimmed = args.trim()
    val parts = trimmed.split(" ")
    val sub = partAt(parts, 0)
    val a = partAt(parts, 1)
    val b = partAt(parts, 2)
    if sub == "close":
        val code = bridgeKickParseStatus(a, 0)
        if code == 0:
            return BridgeKickResult.new(handle, "close: need a numeric code\n" + BRIDGE_KICK_USAGE)
        return BridgeKickResult.new(handle.fireClose(code), "Fired transport close(" + code.to_text() + "). Watch debug.log for [bridge:repl] recovery.")
    if sub == "poll":
        if a == "transient":
            return BridgeKickResult.new(handle.injectFault("pollForWork", "transient", 503, "", 1).wakePollLoop(), "Next poll will throw a transient (axios rejection). Poll loop woken.")
        val status = bridgeKickParseStatus(a, 0)
        if status == 0:
            return BridgeKickResult.new(handle, "poll: need 'transient' or a status code\n" + BRIDGE_KICK_USAGE)
        var errorType = b
        if errorType == "":
            if status == 404:
                errorType = "not_found_error"
            else:
                errorType = "authentication_error"
        return BridgeKickResult.new(handle.injectFault("pollForWork", "fatal", status, errorType, 1).wakePollLoop(), "Next poll will throw BridgeFatalError(" + status.to_text() + ", " + errorType + "). Poll loop woken.")
    if sub == "register":
        if a == "fatal":
            return BridgeKickResult.new(handle.injectFault("registerBridgeEnvironment", "fatal", 403, "permission_error", 1), "Next registerBridgeEnvironment will 403. Trigger with close/reconnect.")
        val n = bridgeKickParseStatus(b, 1)
        return BridgeKickResult.new(handle.injectFault("registerBridgeEnvironment", "transient", 503, "", n), "Next " + n.to_text() + " registerBridgeEnvironment call(s) will transient-fail. Trigger with close/reconnect.")
    if sub == "reconnect-session":
        return BridgeKickResult.new(handle.injectFault("reconnectSession", "fatal", 404, "not_found_error", 2), "Next 2 POST /bridge/reconnect calls will 404. doReconnect Strategy 1 falls through to Strategy 2.")
    if sub == "heartbeat":
        val status = bridgeKickParseStatus(a, 401)
        var errorType = "not_found_error"
        if status == 401:
            errorType = "authentication_error"
        return BridgeKickResult.new(handle.injectFault("heartbeatWork", "fatal", status, errorType, 1), "Next heartbeat will " + status.to_text() + ". Watch for onHeartbeatFatal -> work-state teardown.")
    if sub == "reconnect":
        return BridgeKickResult.new(handle.forceReconnect(), "Called reconnectEnvironmentWithSession(). Watch debug.log.")
    if sub == "status":
        return BridgeKickResult.new(handle, handle.description)
    BridgeKickResult.new(handle, BRIDGE_KICK_USAGE)

fn partAt(parts: [text], index: i64) -> text:
    if index < parts.len():
        return parts[index]
    ""

fn bridgeKickParseStatus(value: text, fallback: i64) -> i64:
    if value == "1002":
        return 1002
    if value == "1006":
        return 1006
    if value == "404":
        return 404
    if value == "403":
        return 403
    if value == "401":
        return 401
    if value == "503":
        return 503
    if value == "3":
        return 3
    if value == "2":
        return 2
    if value == "1":
        return 1
    fallback

class BridgeKickCommand:
    typeName: text
    name: text
    description: text
    enabled: bool
    supportsNonInteractive: bool

impl BridgeKickCommand:
    static fn new(userType: text) -> BridgeKickCommand:
        BridgeKickCommand(typeName: "local", name: "bridge-kick", description: "Inject bridge failure states for manual recovery testing", enabled: userType == "ant", supportsNonInteractive: false)

fn bridgeKickSourceLinesModeled() -> i64:
    200
