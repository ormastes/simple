"""
Claude full advisor command parity.
"""

class AdvisorAppState:
    mainLoopModel: text
    advisorModel: text

impl AdvisorAppState:
    static fn new(mainLoopModel: text, advisorModel: text) -> AdvisorAppState:
        AdvisorAppState(mainLoopModel: mainLoopModel, advisorModel: advisorModel)

class AdvisorCommandResult:
    state: AdvisorAppState
    message: text
    settingsUpdated: bool

impl AdvisorCommandResult:
    static fn new(state: AdvisorAppState, message: text, settingsUpdated: bool) -> AdvisorCommandResult:
        AdvisorCommandResult(state: state, message: message, settingsUpdated: settingsUpdated)

class AdvisorCommand:
    typeName: text
    name: text
    description: text
    argumentHint: text
    supportsNonInteractive: bool
    enabled: bool

impl AdvisorCommand:
    static fn new(enabled: bool) -> AdvisorCommand:
        AdvisorCommand(typeName: "local", name: "advisor", description: "Configure the advisor model", argumentHint: "[<model>|off]", supportsNonInteractive: true, enabled: enabled)

fn callAdvisorCommand(args: text, state: AdvisorAppState, userCanConfigure: bool, validModel: bool, validAdvisorModel: bool, baseSupportsAdvisor: bool) -> AdvisorCommandResult:
    val arg = args.trim().to_lower()
    if arg == "":
        if state.advisorModel == "":
            return AdvisorCommandResult.new(state, "Advisor: not set\nUse \"/advisor <model>\" to enable (e.g. \"/advisor opus\").", false)
        if not baseSupportsAdvisor:
            return AdvisorCommandResult.new(state, "Advisor: " + state.advisorModel + " (inactive)\nThe current model (" + state.mainLoopModel + ") does not support advisors.", false)
        return AdvisorCommandResult.new(state, "Advisor: " + state.advisorModel + "\nUse \"/advisor unset\" to disable or \"/advisor <model>\" to change.", false)
    if arg == "unset" or arg == "off":
        val previous = state.advisorModel
        val next = AdvisorAppState.new(state.mainLoopModel, "")
        if previous == "":
            return AdvisorCommandResult.new(next, "Advisor already unset.", true)
        return AdvisorCommandResult.new(next, "Advisor disabled (was " + previous + ").", true)
    val normalized = normalizeAdvisorModel(arg)
    if not validModel:
        return AdvisorCommandResult.new(state, "Unknown model: " + arg + " (" + normalized + ")", false)
    if not validAdvisorModel:
        return AdvisorCommandResult.new(state, "The model " + arg + " (" + normalized + ") cannot be used as an advisor", false)
    val nextState = AdvisorAppState.new(state.mainLoopModel, normalized)
    if not baseSupportsAdvisor:
        return AdvisorCommandResult.new(nextState, "Advisor set to " + normalized + ".\nNote: Your current model (" + state.mainLoopModel + ") does not support advisors. Switch to a supported model to use the advisor.", true)
    AdvisorCommandResult.new(nextState, "Advisor set to " + normalized + ".", true)

fn normalizeAdvisorModel(arg: text) -> text:
    if arg == "opus":
        return "claude-opus"
    if arg == "sonnet":
        return "claude-sonnet"
    arg

fn advisorCommandSourceLinesModeled() -> i64:
    109
