class MobilePlatform:
    name: text
    url: text

    static fn new(name: text, url: text) -> MobilePlatform:
        MobilePlatform(name: name, url: url)

class MobileKeyResult:
    platform: text
    done: bool
    prevented: bool

    static fn new(platform: text, done: bool, prevented: bool) -> MobileKeyResult:
        MobileKeyResult(platform: platform, done: done, prevented: prevented)

class MobileQrView:
    platform: text
    url: text
    qrCode: text
    qrLines: [text]
    controls: text
    tabIndex: i64
    autoFocus: bool

    static fn new(platform: text, url: text, qrCode: text, qrLines: [text]) -> MobileQrView:
        MobileQrView(platform: platform, url: url, qrCode: qrCode, qrLines: qrLines, controls: "iOS / Android (tab to switch, esc to close)", tabIndex: 0, autoFocus: true)

fn iosMobilePlatform() -> MobilePlatform:
    MobilePlatform.new("ios", "https://apps.apple.com/app/claude-by-anthropic/id6473753684")

fn androidMobilePlatform() -> MobilePlatform:
    MobilePlatform.new("android", "https://play.google.com/store/apps/details?id=com.anthropic.claude")

fn normalizeMobilePlatform(platform: text) -> text:
    val p = platform.trim().lower()
    if p == "android":
        return "android"
    "ios"

fn mobilePlatformUrl(platform: text) -> text:
    if normalizeMobilePlatform(platform) == "android":
        return androidMobilePlatform().url
    iosMobilePlatform().url

fn toggleMobilePlatform(platform: text) -> text:
    if normalizeMobilePlatform(platform) == "ios":
        return "android"
    "ios"

fn mobileQrOptions() -> text:
    "type=utf8,errorCorrectionLevel=L"

fn generatedMobileQr(platform: text) -> text:
    "QR(" + normalizeMobilePlatform(platform) + "):" + mobilePlatformUrl(platform)

fn mobileQrLines(qrCode: text) -> [text]:
    var lines: [text] = []
    for line in qrCode.split("\n"):
        if line.length() > 0:
            lines.push(line)
    lines

fn renderMobileQr(platform: text, qrCode: text) -> MobileQrView:
    val p = normalizeMobilePlatform(platform)
    MobileQrView.new(p, mobilePlatformUrl(p), qrCode, mobileQrLines(qrCode))

fn renderGeneratedMobileQr(platform: text) -> MobileQrView:
    renderMobileQr(platform, generatedMobileQr(platform))

fn handleMobileKey(platform: text, key: text, ctrl: bool) -> MobileKeyResult:
    val k = key.lower()
    if k == "q" or (ctrl and k == "c") or k == "escape":
        return MobileKeyResult.new(normalizeMobilePlatform(platform), true, true)
    if k == "tab" or k == "left" or k == "right":
        return MobileKeyResult.new(toggleMobilePlatform(platform), false, true)
    MobileKeyResult.new(normalizeMobilePlatform(platform), false, false)

fn mobileCallResult() -> text:
    "MobileQRCode"

fn mobileSourceLinesModeled() -> i64:
    273

