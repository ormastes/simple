"""
Claude full config panel command parity.
"""

class SettingsView:
    defaultTab: text
    onCloseBound: bool
    contextBound: bool

impl SettingsView:
    static fn new(defaultTab: text) -> SettingsView:
        SettingsView(defaultTab: defaultTab, onCloseBound: true, contextBound: true)

fn callConfigCommand() -> SettingsView:
    SettingsView.new("Config")

fn configCommandSourceLinesModeled() -> i64:
    6
