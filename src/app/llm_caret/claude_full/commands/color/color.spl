"""
Claude full color command parity.
"""

class ColorCommandState:
    isTeammate: bool
    sessionId: text
    transcriptPath: text
    currentName: text
    currentColor: text

impl ColorCommandState:
    static fn new(isTeammate: bool, sessionId: text, transcriptPath: text, currentName: text, currentColor: text) -> ColorCommandState:
        ColorCommandState(isTeammate: isTeammate, sessionId: sessionId, transcriptPath: transcriptPath, currentName: currentName, currentColor: currentColor)

class ColorCommandResult:
    state: ColorCommandState
    savedColor: text
    message: text
    display: text

impl ColorCommandResult:
    static fn new(state: ColorCommandState, savedColor: text, message: text) -> ColorCommandResult:
        ColorCommandResult(state: state, savedColor: savedColor, message: message, display: "system")

fn callColorCommand(args: text, state: ColorCommandState, agentColors: [text]) -> ColorCommandResult:
    if state.isTeammate:
        return ColorCommandResult.new(state, "", "Cannot set color: This session is a swarm teammate. Teammate colors are assigned by the team leader.")
    if args.trim() == "":
        return ColorCommandResult.new(state, "", "Please provide a color. Available colors: " + joinColorList(agentColors) + ", default")
    val colorArg = args.trim().to_lower()
    if isResetColorAlias(colorArg):
        val next = ColorCommandState.new(state.isTeammate, state.sessionId, state.transcriptPath, state.currentName, "")
        return ColorCommandResult.new(next, "default", "Session color reset to default")
    if not containsColor(agentColors, colorArg):
        return ColorCommandResult.new(state, "", "Invalid color \"" + colorArg + "\". Available colors: " + joinColorList(agentColors) + ", default")
    val next = ColorCommandState.new(state.isTeammate, state.sessionId, state.transcriptPath, state.currentName, colorArg)
    ColorCommandResult.new(next, colorArg, "Session color set to: " + colorArg)

fn isResetColorAlias(value: text) -> bool:
    value == "default" or value == "reset" or value == "none" or value == "gray" or value == "grey"

fn containsColor(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn joinColorList(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + ", "
        out = out + values[i]
        i = i + 1
    out

fn colorCommandSourceLinesModeled() -> i64:
    93
