"""
Claude full color command descriptor parity.
"""

class ColorCommandDescriptor:
    typeName: text
    name: text
    description: text
    immediate: bool
    argumentHint: text
    loadPath: text

impl ColorCommandDescriptor:
    static fn new() -> ColorCommandDescriptor:
        ColorCommandDescriptor(typeName: "local-jsx", name: "color", description: "Set the prompt bar color for this session", immediate: true, argumentHint: "<color|default>", loadPath: "./color.js")

fn colorIndexSourceLinesModeled() -> i64:
    16
