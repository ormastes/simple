"""
Claude full install-slack-app command parity.
"""

class InstallSlackAppCommand:
    typeName: text
    name: text
    description: text
    url: text

impl InstallSlackAppCommand:
    static fn new() -> InstallSlackAppCommand:
        InstallSlackAppCommand(typeName: "local", name: "install-slack-app", description: "Install the Claude Slack app", url: "https://slack.com/apps")

fn installSlackAppCommand() -> InstallSlackAppCommand:
    InstallSlackAppCommand.new()

fn installSlackAppMessage(workspace: text) -> text:
    if workspace.trim() == "":
        return "Open Slack app installation"
    "Open Slack app installation for " + workspace.trim()

fn installSlackAppSourceLinesModeled() -> i64:
    30
