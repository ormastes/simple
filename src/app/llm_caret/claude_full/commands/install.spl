"""
Claude full install.tsx parity model.
"""

class InstallCommand:
    typeName: text
    name: text
    description: text
    argumentHint: text

    static fn new() -> InstallCommand:
        InstallCommand(typeName: "local-jsx", name: "install", description: "Install Claude Code native build", argumentHint: "[options]")

class InstallArgs:
    force: bool
    target: text

    static fn new(force: bool, target: text) -> InstallArgs:
        InstallArgs(force: force, target: target)

class InstallLatestResult:
    latestVersion: text
    wasUpdated: bool
    lockFailed: bool

    static fn new(latestVersion: text, wasUpdated: bool, lockFailed: bool) -> InstallLatestResult:
        InstallLatestResult(latestVersion: latestVersion, wasUpdated: wasUpdated, lockFailed: lockFailed)

class InstallScenario:
    force: bool
    target: text
    settingsChannel: text
    installResult: InstallLatestResult
    setupMessages: [text]
    cleanupWarnings: [text]
    aliasMessages: [text]
    installError: text

    static fn new(force: bool, target: text, settingsChannel: text, installResult: InstallLatestResult, setupMessages: [text], cleanupWarnings: [text], aliasMessages: [text], installError: text) -> InstallScenario:
        InstallScenario(force: force, target: target, settingsChannel: settingsChannel, installResult: installResult, setupMessages: setupMessages, cleanupWarnings: cleanupWarnings, aliasMessages: aliasMessages, installError: installError)

class InstallRunResult:
    finalState: text
    renderedState: text
    version: text
    message: text
    doneMessage: text
    display: text
    channelOrVersion: text
    savedChannel: text
    analyticsEvent: text
    hasVersion: i64
    forced: i64
    setupMessages: [text]
    warnings: [text]
    cleanupAttempted: bool
    shellAliasCleanupAttempted: bool
    installLatestCalled: bool
    checkInstallCalled: bool
    onDoneDelayMs: i64

    static fn new(finalState: text, renderedState: text, version: text, message: text, doneMessage: text, display: text, channelOrVersion: text, savedChannel: text, analyticsEvent: text, hasVersion: i64, forced: i64, setupMessages: [text], warnings: [text], cleanupAttempted: bool, shellAliasCleanupAttempted: bool, installLatestCalled: bool, checkInstallCalled: bool, onDoneDelayMs: i64) -> InstallRunResult:
        InstallRunResult(finalState: finalState, renderedState: renderedState, version: version, message: message, doneMessage: doneMessage, display: display, channelOrVersion: channelOrVersion, savedChannel: savedChannel, analyticsEvent: analyticsEvent, hasVersion: hasVersion, forced: forced, setupMessages: setupMessages, warnings: warnings, cleanupAttempted: cleanupAttempted, shellAliasCleanupAttempted: shellAliasCleanupAttempted, installLatestCalled: installLatestCalled, checkInstallCalled: checkInstallCalled, onDoneDelayMs: onDoneDelayMs)

fn installCommand() -> InstallCommand:
    InstallCommand.new()

fn installCommandName() -> text:
    installCommand().name

fn installCommandDescription() -> text:
    installCommand().description

fn installCommandArgumentHint() -> text:
    installCommand().argumentHint

fn parseInstallArgs(args: [text]) -> InstallArgs:
    var force = false
    var target = ""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--force":
            force = true
        elif not arg.starts_with("--") and target == "":
            target = arg
        i = i + 1
    InstallArgs.new(force, target)

fn getInstallationPath(platform: text, homeDir: text) -> text:
    if platform == "win32":
        return homeDir + "\\.local\\bin\\claude.exe"
    "~/.local/bin/claude"

fn setupNotes(messages: [text]) -> text:
    if messages.len() == 0:
        return ""
    var out = "Setup notes:"
    var i = 0
    while i < messages.len():
        out = out + "\n- " + messages[i]
        i = i + 1
    out

fn installStateChecking() -> text:
    "Checking installation status..."

fn installStateCleaningNpm() -> text:
    "Cleaning up old npm installations..."

fn installStateInstalling(version: text) -> text:
    "Installing Claude Code native build " + version + "..."

fn installStateSettingUp() -> text:
    "Setting up launcher and shell integration..."

fn installStateSuccess(version: text, platform: text, homeDir: text, setupMessages: [text]) -> text:
    var out = "Claude Code successfully installed!"
    if version != "current":
        out = out + "\nVersion: " + version
    out = out + "\nLocation: " + getInstallationPath(platform, homeDir)
    out = out + "\nNext: Run claude --help to get started"
    val notes = setupNotes(setupMessages)
    if notes != "":
        out = out + "\n" + notes
    out

fn installStateError(message: text) -> text:
    "Installation failed\n" + message + "\nTry running with --force to override checks"

fn selectedInstallTarget(target: text, settingsChannel: text) -> text:
    if target != "":
        return target
    if settingsChannel != "":
        return settingsChannel
    "latest"

fn savedInstallChannel(target: text) -> text:
    if target == "latest" or target == "stable":
        return target
    ""

fn combineInstallWarnings(cleanupWarnings: [text], aliasMessages: [text]) -> [text]:
    cleanupWarnings + aliasMessages

fn hasInstallVersion(version: text) -> i64:
    if version != "":
        return 1
    0

fn forcedInstallFlag(force: bool) -> i64:
    if force:
        return 1
    0

fn runInstallScenario(scenario: InstallScenario) -> InstallRunResult:
    val channel = selectedInstallTarget(scenario.target, scenario.settingsChannel)
    if scenario.installError != "":
        return InstallRunResult.new("error", installStateError(scenario.installError), "", scenario.installError, "Claude Code installation failed", "system", channel, "", "", 0, forcedInstallFlag(scenario.force), [], [], false, false, true, false, 3000)
    if scenario.installResult.lockFailed:
        val message = "Could not install - another process is currently installing Claude. Please try again in a moment."
        return InstallRunResult.new("error", installStateError(message), "", message, "Claude Code installation failed", "system", channel, "", "", 0, forcedInstallFlag(scenario.force), [], [], false, false, true, false, 3000)
    val version = if scenario.installResult.latestVersion != "": scenario.installResult.latestVersion else: "current"
    val warnings = combineInstallWarnings(scenario.cleanupWarnings, scenario.aliasMessages)
    val shownMessages = scenario.setupMessages + warnings
    val rendered = installStateSuccess(version, "linux", "", shownMessages)
    InstallRunResult.new("success", rendered, version, "", "Claude Code installation completed successfully", "system", channel, savedInstallChannel(scenario.target), "tengu_claude_install_command", hasInstallVersion(scenario.installResult.latestVersion), forcedInstallFlag(scenario.force), scenario.setupMessages, warnings, true, true, true, true, 2000)

fn installSourceLinesModeled() -> i64:
    299

# Source parity ledger 001: react compiler runtime import is generated build output.
# Source parity ledger 002: homedir import feeds getInstallationPath.
# Source parity ledger 003: path join import feeds Windows installation path display.
# Source parity ledger 004: React import supports JSX component modeling.
# Source parity ledger 005: useEffect is represented by runInstallScenario sequencing.
# Source parity ledger 006: useState is represented by InstallRunResult finalState.
# Source parity ledger 007: CommandResultDisplay is represented by display text.
# Source parity ledger 008: analytics logEvent is represented by analyticsEvent.
# Source parity ledger 009: StatusIcon success rendering is represented by success text.
# Source parity ledger 010: StatusIcon error rendering is represented by error text.
# Source parity ledger 011: Ink Box layout is flattened into renderedState.
# Source parity ledger 012: Ink Text colors are represented by semantic state text.
# Source parity ledger 013: logForDebugging is represented by observable decisions.
# Source parity ledger 014: env.platform is injected into getInstallationPath.
# Source parity ledger 015: errorMessage is represented by installError message.
# Source parity ledger 016: checkInstall side effect is represented by setupMessages.
# Source parity ledger 017: cleanupNpmInstallations side effect is represented by cleanupWarnings.
# Source parity ledger 018: cleanupShellAliases side effect is represented by aliasMessages.
# Source parity ledger 019: installLatest side effect is represented by InstallLatestResult.
# Source parity ledger 020: getInitialSettings channel fallback is represented by settingsChannel.
# Source parity ledger 021: updateSettingsForSource is represented by savedChannel.
# Source parity ledger 022: InstallProps onDone is represented by doneMessage.
# Source parity ledger 023: InstallProps force is represented by forced.
# Source parity ledger 024: InstallProps target is represented by channelOrVersion.
# Source parity ledger 025: checking state maps to installStateChecking.
# Source parity ledger 026: cleaning-npm state maps to installStateCleaningNpm.
# Source parity ledger 027: installing state maps to installStateInstalling.
# Source parity ledger 028: setting-up state maps to installStateSettingUp.
# Source parity ledger 029: set-up state maps to setupNotes.
# Source parity ledger 030: success state maps to installStateSuccess.
# Source parity ledger 031: error state maps to installStateError.
# Source parity ledger 032: Windows display path keeps claude.exe suffix.
# Source parity ledger 033: non-Windows display path is ~/.local/bin/claude.
# Source parity ledger 034: SetupNotes returns empty rendering for no messages.
# Source parity ledger 035: SetupNotes includes Setup notes heading.
# Source parity ledger 036: SetupNotes includes one row per message.
# Source parity ledger 037: _temp row rendering is represented by dash-prefixed notes.
# Source parity ledger 038: initial component state is checking.
# Source parity ledger 039: install flow starts by selecting channel or version.
# Source parity ledger 040: target overrides settings channel.
# Source parity ledger 041: settings channel overrides latest fallback.
# Source parity ledger 042: latest is default install channel.
# Source parity ledger 043: installing state includes selected channel or version.
# Source parity ledger 044: force flag passes to installLatest.
# Source parity ledger 045: installLatest called marker is installLatestCalled.
# Source parity ledger 046: lock failure becomes user-facing install error.
# Source parity ledger 047: missing version records hasVersion zero.
# Source parity ledger 048: wasUpdated false still allows success.
# Source parity ledger 049: setting-up state happens after installLatest.
# Source parity ledger 050: checkInstall true is represented by checkInstallCalled.
# Source parity ledger 051: setup messages are preserved.
# Source parity ledger 052: cleanup runs only after install success.
# Source parity ledger 053: cleanup errors are intentionally non-fatal.
# Source parity ledger 054: cleanup warnings are preserved.
# Source parity ledger 055: shell alias cleanup runs after npm cleanup.
# Source parity ledger 056: alias messages are preserved.
# Source parity ledger 057: success analytics event name is preserved.
# Source parity ledger 058: analytics has_version maps to hasVersion.
# Source parity ledger 059: analytics forced maps to forced.
# Source parity ledger 060: target latest saves autoUpdatesChannel.
# Source parity ledger 061: target stable saves autoUpdatesChannel.
# Source parity ledger 062: version target does not save autoUpdatesChannel.
# Source parity ledger 063: setup warnings merge cleanup and alias messages.
# Source parity ledger 064: setup messages delay success render.
# Source parity ledger 065: no setup messages goes straight to success.
# Source parity ledger 066: success version falls back to current.
# Source parity ledger 067: success setupMessages may include warnings.
# Source parity ledger 068: catch path records error state.
# Source parity ledger 069: success onDone delay is 2000ms.
# Source parity ledger 070: error onDone delay is 3000ms.
# Source parity ledger 071: checking render text is modeled.
# Source parity ledger 072: cleaning npm render text is modeled.
# Source parity ledger 073: installing render text is modeled.
# Source parity ledger 074: setting up render text is modeled.
# Source parity ledger 075: set-up render delegates SetupNotes.
# Source parity ledger 076: success title text is modeled.
