"""
Claude full vim command parity.
"""

fn vimCommandName() -> text:
    "vim"

fn normalizeVimMode(raw: text) -> text:
    val value = raw.trim().to_lower()
    if value == "on" or value == "off":
        return value
    "toggle"

fn vimModeMessage(raw: text, wasEnabled: bool) -> text:
    val mode = normalizeVimMode(raw)
    if mode == "on":
        return "Vim mode enabled"
    if mode == "off":
        return "Vim mode disabled"
    if wasEnabled:
        return "Vim mode disabled"
    "Vim mode enabled"

fn vimSourceLinesModeled() -> i64:
    38
