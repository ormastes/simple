class ResumeLog:
    sessionId: text
    isSidechain: bool
    isLite: bool
    modifiedMillis: i64
    projectDir: text
    customTitle: text

    static fn new(sessionId: text, isSidechain: bool, isLite: bool, modifiedMillis: i64, projectDir: text, customTitle: text) -> ResumeLog:
        ResumeLog(sessionId: sessionId, isSidechain: isSidechain, isLite: isLite, modifiedMillis: modifiedMillis, projectDir: projectDir, customTitle: customTitle)

class ResumeCallResult:
    renderKind: text
    doneMessage: text
    display: text
    resumedSessionId: text
    entrypoint: text
    loadedFullLog: bool

    static fn new(renderKind: text, doneMessage: text, display: text, resumedSessionId: text, entrypoint: text, loadedFullLog: bool) -> ResumeCallResult:
        ResumeCallResult(renderKind: renderKind, doneMessage: doneMessage, display: display, resumedSessionId: resumedSessionId, entrypoint: entrypoint, loadedFullLog: loadedFullLog)

fn resumeHelpMessage(resultType: text, arg: text, count: i64) -> text:
    if resultType == "sessionNotFound":
        return "Session " + arg + " was not found."
    "Found " + count.to_text() + " sessions matching " + arg + ". Please use /resume to pick a specific session."

fn resumeErrorPointer(args: text) -> text:
    "/resume " + args

fn filterResumableSessions(logs: [ResumeLog], currentSessionId: text) -> [ResumeLog]:
    var out: [ResumeLog] = []
    var i = 0
    while i < logs.len():
        val log = logs[i]
        if not log.isSidechain and log.sessionId != currentSessionId:
            out.push(log)
        i = i + 1
    out

fn callResume(args: text, currentSessionId: text, logs: [ResumeLog], directLogs: [ResumeLog], titleMatches: [ResumeLog], customTitleEnabled: bool) -> ResumeCallResult:
    val arg = args.trim()
    if arg == "":
        return ResumeCallResult.new("picker", "", "", "", "", false)
    if logs.len() == 0:
        return ResumeCallResult.new("error", "No conversations found to resume.", "", "", "", false)
    val maybeSessionId = validateUuid(arg)
    if maybeSessionId != "":
        val matching = newestLogForSession(logs, maybeSessionId)
        if matching.sessionId != "":
            return resumeSuccess(matching, "slash_command_session_id")
        val direct = newestLogForSession(directLogs, maybeSessionId)
        if direct.sessionId != "":
            return resumeSuccess(direct, "slash_command_session_id")
    if customTitleEnabled:
        if titleMatches.len() == 1:
            val titleLog = titleMatches[0]
            if titleLog.sessionId != "":
                return resumeSuccess(titleLog, "slash_command_title")
        if titleMatches.len() > 1:
            return ResumeCallResult.new("error", resumeHelpMessage("multipleMatches", arg, titleMatches.len()), "", "", "", false)
    ResumeCallResult.new("error", resumeHelpMessage("sessionNotFound", arg, 0), "", "", "", false)

fn selectResumeLog(log: ResumeLog, isCrossProject: bool, isSameRepoWorktree: bool, command: text) -> ResumeCallResult:
    if validateUuid(log.sessionId) == "":
        return ResumeCallResult.new("done", "Failed to resume conversation", "", "", "", false)
    if isCrossProject and not isSameRepoWorktree:
        val message = "\nThis conversation is from a different directory.\n\nTo resume, run:\n  " + command + "\n\n(Command copied to clipboard)\n"
        return ResumeCallResult.new("done", message, "user", "", "", false)
    resumeSuccess(log, "slash_command_picker")

fn resumeLoadingMessage() -> text:
    "Loading conversations..."

fn resumeResumingMessage() -> text:
    "Resuming conversation..."

fn resumeCancelResult() -> ResumeCallResult:
    ResumeCallResult.new("done", "Resume cancelled", "system", "", "", false)

fn resumeLoadFailureResult() -> ResumeCallResult:
    ResumeCallResult.new("done", "Failed to load conversations", "", "", "", false)

fn resumeNoConversationsResult() -> ResumeCallResult:
    ResumeCallResult.new("done", "No conversations found to resume", "", "", "", false)

fn resumeFailureResult(errorMessage: text) -> ResumeCallResult:
    ResumeCallResult.new("done", "Failed to resume: " + errorMessage, "", "", "", false)

fn resumeDoneSkipResult() -> ResumeCallResult:
    ResumeCallResult.new("done", "", "skip", "", "", false)

fn resumeSuccess(log: ResumeLog, entrypoint: text) -> ResumeCallResult:
    ResumeCallResult.new("resume", "", "skip", log.sessionId, entrypoint, log.isLite)

fn newestLogForSession(logs: [ResumeLog], sessionId: text) -> ResumeLog:
    var best = ResumeLog.new("", false, false, 0, "", "")
    var i = 0
    while i < logs.len():
        val log = logs[i]
        if log.sessionId == sessionId and (best.sessionId == "" or log.modifiedMillis > best.modifiedMillis):
            best = log
        i = i + 1
    best

fn validateUuid(value: text) -> text:
    if value.len() != 36:
        return ""
    var i = 0
    while i < value.len():
        val ch = value[i]
        val hyphen = i == 8 or i == 13 or i == 18 or i == 23
        if hyphen:
            if ch != "-":
                return ""
        else:
            if not isHex(ch):
                return ""
        i = i + 1
    value

fn isHex(ch: text) -> bool:
    (ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "f") or (ch >= "A" and ch <= "F")

fn resumeSourceLinesModeled() -> i64:
    274
