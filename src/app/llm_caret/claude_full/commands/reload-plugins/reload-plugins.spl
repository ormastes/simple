class ReloadPluginsResult:
    message: text
    count: i64

impl ReloadPluginsResult:
    static fn new(message: text, count: i64) -> ReloadPluginsResult:
        ReloadPluginsResult(message: message, count: count)

fn reloadPluginsCommandName() -> text:
    "reload-plugins"

fn reloadPluginsResult(count: i64) -> ReloadPluginsResult:
    ReloadPluginsResult.new("Reloaded plugins: " + count.to_text(), count)

fn reloadPluginsSourceLinesModeled() -> i64:
    61
