"""
Import-safe setupGitHubActions parity.
"""

class GitHubActionsSetupPlan:
    repo: text
    secretName: text
    workflowAction: text
    workflowPath: text

impl GitHubActionsSetupPlan:
    static fn new(repo: text, secretName: text, workflowAction: text) -> GitHubActionsSetupPlan:
        GitHubActionsSetupPlan(repo: setupGitHubActionsRepoArg(repo), secretName: setupGitHubActionsSecretName(secretName), workflowAction: setupGitHubActionsNormalizeWorkflowAction(workflowAction), workflowPath: setupGitHubActionsWorkflowPath())

fn setupGitHubActionsWorkflowPath() -> text: ".github/workflows/claude.yml"
fn setupGitHubActionsDefaultSecretName() -> text: "ANTHROPIC_API_KEY"
fn setupGitHubActionsWorkflowName() -> text: "Claude Code"
fn setupGitHubActionsActionRef() -> text: "anthropics/claude-code-action@beta"
fn setupGitHubActionsRepoArg(repo: text) -> text:
    var value = repo.trim()
    if value.ends_with(".git"):
        value = value.slice(0, value.len() - 4)
    if value.starts_with("https://github.com/"):
        value = value.slice("https://github.com/".len(), value.len())
    if value.starts_with("git@github.com:"):
        value = value.slice("git@github.com:".len(), value.len())
    value
fn setupGitHubActionsSecretName(secretName: text) -> text:
    val value = secretName.trim()
    if value == "":
        return setupGitHubActionsDefaultSecretName()
    value
fn setupGitHubActionsNormalizeWorkflowAction(action: text) -> text:
    val value = action.trim()
    if value == "create" or value == "overwrite" or value == "skip":
        return value
    "create"
fn setupGitHubActionsShouldWriteWorkflow(action: text) -> bool:
    val value = setupGitHubActionsNormalizeWorkflowAction(action)
    value == "create" or value == "overwrite"
fn setupGitHubActionsShouldSetSecret(secretName: text) -> bool:
    setupGitHubActionsSecretName(secretName) != ""
fn setupGitHubActionsSecretCommand(repo: text, secretName: text) -> text:
    "gh secret set " + setupGitHubActionsSecretName(secretName) + " --repo " + setupGitHubActionsRepoArg(repo)
fn setupGitHubActionsWorkflowHeader() -> text: "name: " + setupGitHubActionsWorkflowName()
fn setupGitHubActionsWorkflowTrigger() -> text: "on: [pull_request_issue_comment, issues]"
fn setupGitHubActionsWorkflowUsesLine() -> text: "uses: " + setupGitHubActionsActionRef()
fn setupGitHubActionsWorkflowSecretLine(secretName: text) -> text:
    "anthropic_api_key: ${{ secrets." + setupGitHubActionsSecretName(secretName) + " }}"
fn setupGitHubActionsWorkflowYaml(secretName: text) -> text:
    setupGitHubActionsWorkflowHeader() + "\n" + setupGitHubActionsWorkflowTrigger() + "\n" + setupGitHubActionsWorkflowUsesLine() + "\n" + setupGitHubActionsWorkflowSecretLine(secretName)
fn setupGitHubActionsSummary(repo: text, secretName: text, workflowAction: text) -> text:
    val plan = GitHubActionsSetupPlan.new(repo, secretName, workflowAction)
    "setup GitHub Actions for " + plan.repo + " with " + plan.secretName + " using " + plan.workflowAction
fn setupGitHubActionsSourceLinesModeled() -> i64: 325
