"""
Claude full install-github-app ApiKeyStep parity model.
"""

class ApiKeyStepModel:
    option: text
    apiKey: text
    existingSecretName: text
    canContinue: bool
    submitLabel: text
    helperText: text
    maskedKey: text

impl ApiKeyStepModel:
    static fn new(option: text, apiKey: text, existingSecretName: text) -> ApiKeyStepModel:
        val normalized = apiKeyStepNormalizeOption(option)
        ApiKeyStepModel(
            option: normalized,
            apiKey: apiKey,
            existingSecretName: apiKeyStepNormalizeSecretName(existingSecretName),
            canContinue: apiKeyStepCanContinue(normalized, apiKey, existingSecretName),
            submitLabel: apiKeyStepSubmitLabel(normalized),
            helperText: apiKeyStepHelperText(normalized),
            maskedKey: apiKeyStepMask(apiKey),
        )

fn apiKeyStepNormalizeOption(option: text) -> text:
    val value = option.trim()
    if value == "oauth" or value == "existing-key" or value == "new-key" or value == "existing-secret":
        return value
    "oauth"

fn apiKeyStepNormalizeSecretName(secretName: text) -> text:
    val value = secretName.trim()
    if value == "":
        return "ANTHROPIC_API_KEY"
    value

fn apiKeyStepCanContinue(option: text, apiKey: text, existingSecretName: text) -> bool:
    val normalized = apiKeyStepNormalizeOption(option)
    if normalized == "new-key":
        return apiKey.trim().starts_with("sk-ant-")
    if normalized == "existing-secret":
        return apiKeyStepNormalizeSecretName(existingSecretName) != ""
    true

fn apiKeyStepSubmitLabel(option: text) -> text:
    val normalized = apiKeyStepNormalizeOption(option)
    if normalized == "oauth":
        return "Sign in with Anthropic"
    if normalized == "existing-key":
        return "Use existing API key"
    if normalized == "existing-secret":
        return "Use existing GitHub secret"
    "Create GitHub secret"

fn apiKeyStepHelperText(option: text) -> text:
    val normalized = apiKeyStepNormalizeOption(option)
    if normalized == "oauth":
        return "Create an Anthropic API key with OAuth, then store it as a GitHub Actions secret."
    if normalized == "existing-key":
        return "Use the ANTHROPIC_API_KEY already available in this environment."
    if normalized == "existing-secret":
        return "Reuse a repository or organization secret already configured in GitHub."
    "Paste an Anthropic API key beginning with sk-ant-."

fn apiKeyStepMask(apiKey: text) -> text:
    val value = apiKey.trim()
    if value == "":
        return ""
    if value.len() <= 8:
        return "********"
    value.slice(0, 4) + "..." + value.slice(value.len() - 4, value.len())

fn apiKeyStepValidationMessage(option: text, apiKey: text, existingSecretName: text) -> text:
    val normalized = apiKeyStepNormalizeOption(option)
    if normalized == "new-key" and not apiKey.trim().starts_with("sk-ant-"):
        return "Enter a valid Anthropic API key."
    if normalized == "existing-secret" and apiKeyStepNormalizeSecretName(existingSecretName) == "":
        return "Enter a GitHub secret name."
    ""

fn apiKeyStepNextAction(option: text) -> text:
    val normalized = apiKeyStepNormalizeOption(option)
    if normalized == "oauth":
        return "oauth"
    if normalized == "existing-key":
        return "environment"
    if normalized == "existing-secret":
        return "reuse-secret"
    "create-secret"

fn apiKeyStepRenderSummary(option: text, apiKey: text, existingSecretName: text) -> text:
    val model = ApiKeyStepModel.new(option, apiKey, existingSecretName)
    model.submitLabel + " | " + model.helperText + " | " + model.maskedKey

fn apiKeyStepSourceLinesModeled() -> i64:
    230
