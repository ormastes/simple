"""
Claude full install-github-app command parity model.
"""

use app.llm_caret.claude_full.commands.install_github_app.ApiKeyStep.*
use app.llm_caret.claude_full.commands.install_github_app.ChooseRepoStep.*
use app.llm_caret.claude_full.commands.install_github_app.CheckExistingSecretStep.*

class InstallGitHubAppCommand:
    typeName: text
    name: text
    description: text
    url: text

impl InstallGitHubAppCommand:
    static fn new() -> InstallGitHubAppCommand:
        InstallGitHubAppCommand(typeName: "local", name: "install-github-app", description: "Install the Claude GitHub app", url: "https://github.com/apps/claude")

class InstallGitHubAppState:
    step: text
    repoUrl: text
    currentRepo: text
    useCurrentRepo: bool
    apiKeyOption: text
    apiKey: text
    secretName: text
    workflowAction: text
    githubCliAvailable: bool
    repoPermissionsOk: bool
    workflowFilePresent: bool
    secretPresent: bool
    message: text

impl InstallGitHubAppState:
    static fn initial(currentRepo: text) -> InstallGitHubAppState:
        InstallGitHubAppState(
            step: "check-github",
            repoUrl: "",
            currentRepo: currentRepo.trim(),
            useCurrentRepo: currentRepo.trim() != "",
            apiKeyOption: "oauth",
            apiKey: "",
            secretName: "ANTHROPIC_API_KEY",
            workflowAction: "create",
            githubCliAvailable: false,
            repoPermissionsOk: false,
            workflowFilePresent: false,
            secretPresent: false,
            message: "Install the Claude GitHub app",
        )

fn installGitHubAppCommand() -> InstallGitHubAppCommand:
    InstallGitHubAppCommand.new()

fn checkGitHubCLI(exitCode: i64, output: text) -> bool:
    exitCode == 0 and not output.contains("not found")

fn runSetupGitHubActions(repoUrl: text, secretName: text, workflowAction: text) -> text:
    val repoArg = chooseRepoGhRepoArg(repoUrl)
    if repoArg == "":
        return "missing repository"
    "setup GitHub Actions for " + repoArg + " with " + checkExistingSecretNormalizeName(secretName) + " using " + installGitHubAppNormalizeWorkflowAction(workflowAction)

fn openGitHubAppInstallation(repoUrl: text) -> text:
    val repoArg = chooseRepoGhRepoArg(repoUrl)
    if repoArg == "":
        return "https://github.com/apps/claude/installations/new"
    "https://github.com/apps/claude/installations/new?repository=" + repoArg

fn checkRepositoryPermissions(exitCode: i64, output: text) -> bool:
    exitCode == 0 and not output.contains("Resource not accessible") and not output.contains("permission")

fn checkExistingWorkflowFile(found: bool) -> text:
    if found:
        return "existing-workflow"
    "no-workflow"

fn checkExistingSecret(found: bool) -> text:
    if found:
        return "existing-secret"
    "missing-secret"

fn hasAnthropicKey(value: text) -> bool:
    value.trim().starts_with("sk-ant-")

fn installGitHubAppNormalizeWorkflowAction(action: text) -> text:
    val value = action.trim()
    if value == "create" or value == "overwrite" or value == "skip":
        return value
    "create"

fn handleRepoUrlChange(state: InstallGitHubAppState, repoUrl: text) -> InstallGitHubAppState:
    InstallGitHubAppState(
        step: chooseRepoNextStep(repoUrl),
        repoUrl: repoUrl.trim(),
        currentRepo: state.currentRepo,
        useCurrentRepo: false,
        apiKeyOption: state.apiKeyOption,
        apiKey: state.apiKey,
        secretName: state.secretName,
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: chooseRepoIsValid(repoUrl),
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: chooseRepoMessage(repoUrl),
    )

fn handleApiKeyChange(state: InstallGitHubAppState, apiKey: text) -> InstallGitHubAppState:
    InstallGitHubAppState(
        step: state.step,
        repoUrl: state.repoUrl,
        currentRepo: state.currentRepo,
        useCurrentRepo: state.useCurrentRepo,
        apiKeyOption: "new-key",
        apiKey: apiKey.trim(),
        secretName: state.secretName,
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: state.repoPermissionsOk,
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: apiKeyStepValidationMessage("new-key", apiKey, state.secretName),
    )

fn handleApiKeyOptionChange(state: InstallGitHubAppState, option: text) -> InstallGitHubAppState:
    InstallGitHubAppState(
        step: state.step,
        repoUrl: state.repoUrl,
        currentRepo: state.currentRepo,
        useCurrentRepo: state.useCurrentRepo,
        apiKeyOption: apiKeyStepNormalizeOption(option),
        apiKey: state.apiKey,
        secretName: state.secretName,
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: state.repoPermissionsOk,
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: apiKeyStepHelperText(option),
    )

fn handleCreateOAuthToken(state: InstallGitHubAppState) -> InstallGitHubAppState:
    handleApiKeyOptionChange(state, "oauth")

fn handleOAuthSuccess(state: InstallGitHubAppState, apiKey: text) -> InstallGitHubAppState:
    handleApiKeyChange(state, apiKey)

fn handleOAuthCancel(state: InstallGitHubAppState) -> InstallGitHubAppState:
    handleApiKeyOptionChange(state, "new-key")

fn handleSecretNameChange(state: InstallGitHubAppState, secretName: text) -> InstallGitHubAppState:
    InstallGitHubAppState(
        step: state.step,
        repoUrl: state.repoUrl,
        currentRepo: state.currentRepo,
        useCurrentRepo: state.useCurrentRepo,
        apiKeyOption: state.apiKeyOption,
        apiKey: state.apiKey,
        secretName: checkExistingSecretNormalizeName(secretName),
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: state.repoPermissionsOk,
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: "Secret " + checkExistingSecretNormalizeName(secretName),
    )

fn handleToggleUseCurrentRepo(state: InstallGitHubAppState) -> InstallGitHubAppState:
    val useCurrent = not state.useCurrentRepo
    val selected = chooseRepoSelectedUrl(state.repoUrl, useCurrent, state.currentRepo)
    InstallGitHubAppState(
        step: chooseRepoNextStep(selected),
        repoUrl: selected,
        currentRepo: state.currentRepo,
        useCurrentRepo: useCurrent,
        apiKeyOption: state.apiKeyOption,
        apiKey: state.apiKey,
        secretName: state.secretName,
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: chooseRepoIsValid(selected),
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: chooseRepoMessage(selected),
    )

fn handleToggleUseExistingKey(state: InstallGitHubAppState) -> InstallGitHubAppState:
    handleApiKeyOptionChange(state, "existing-key")

fn handleToggleUseExistingSecret(state: InstallGitHubAppState) -> InstallGitHubAppState:
    handleApiKeyOptionChange(state, "existing-secret")

fn handleWorkflowAction(state: InstallGitHubAppState, action: text) -> InstallGitHubAppState:
    InstallGitHubAppState(
        step: state.step,
        repoUrl: state.repoUrl,
        currentRepo: state.currentRepo,
        useCurrentRepo: state.useCurrentRepo,
        apiKeyOption: state.apiKeyOption,
        apiKey: state.apiKey,
        secretName: state.secretName,
        workflowAction: installGitHubAppNormalizeWorkflowAction(action),
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: state.repoPermissionsOk,
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: "Workflow action " + installGitHubAppNormalizeWorkflowAction(action),
    )

fn handleSubmit(state: InstallGitHubAppState) -> InstallGitHubAppState:
    val repoOk = chooseRepoIsValid(state.repoUrl)
    val keyOk = apiKeyStepCanContinue(state.apiKeyOption, state.apiKey, state.secretName)
    var nextStep = "error"
    var message = "Cannot install Claude GitHub app yet"
    if repoOk and keyOk:
        nextStep = "creating"
        message = runSetupGitHubActions(state.repoUrl, state.secretName, state.workflowAction)
    InstallGitHubAppState(
        step: nextStep,
        repoUrl: state.repoUrl,
        currentRepo: state.currentRepo,
        useCurrentRepo: state.useCurrentRepo,
        apiKeyOption: state.apiKeyOption,
        apiKey: state.apiKey,
        secretName: state.secretName,
        workflowAction: state.workflowAction,
        githubCliAvailable: state.githubCliAvailable,
        repoPermissionsOk: repoOk,
        workflowFilePresent: state.workflowFilePresent,
        secretPresent: state.secretPresent,
        message: message,
    )

fn installGitHubAppDismissKey(key: text) -> bool:
    key == "escape" or key == "q"

fn installGitHubAppCall(currentRepo: text) -> InstallGitHubAppState:
    InstallGitHubAppState.initial(currentRepo)

