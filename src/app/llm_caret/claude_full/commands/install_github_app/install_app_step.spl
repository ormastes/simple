"""
Import-safe InstallAppStep parity.
"""

fn installAppStepTitle() -> text: "Install the Claude GitHub App"
fn installAppStepCommandTitle() -> text: "Install GitHub App"
fn installAppStepConfirmKey() -> text: "confirm:yes"
fn installAppStepUrl() -> text: "https://github.com/apps/claude"
fn installAppStepBrowserFallback() -> text: "If your browser doesn't open automatically, visit:"
fn installAppStepRepositoryLine(repoUrl: text) -> text: "Please install the app for repository: " + repoUrl
fn installAppStepRepositoryWarning() -> text: "Important: Make sure to grant access to this specific repository"
fn installAppStepContinuePrompt() -> text: "Press Enter once you've installed the app"
fn installAppStepTroubleLine() -> text: "Having trouble? See manual setup instructions at:"
fn installAppStepManualCommand() -> text: "claude"
fn installAppStepSourceLinesModeled() -> i64: 93
