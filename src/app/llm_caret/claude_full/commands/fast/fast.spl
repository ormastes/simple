class FastAppState:
    mainLoopModel: text
    mainLoopModelForSession: text
    fastMode: bool

    static fn new(mainLoopModel: text, mainLoopModelForSession: text, fastMode: bool) -> FastAppState:
        FastAppState(mainLoopModel: mainLoopModel, mainLoopModelForSession: mainLoopModelForSession, fastMode: fastMode)

class FastApplyResult:
    appState: FastAppState
    settingsFastMode: text
    cooldownCleared: bool
    modelSwitched: bool

    static fn new(appState: FastAppState, settingsFastMode: text, cooldownCleared: bool, modelSwitched: bool) -> FastApplyResult:
        FastApplyResult(appState: appState, settingsFastMode: settingsFastMode, cooldownCleared: cooldownCleared, modelSwitched: modelSwitched)

class FastCallResult:
    rendered: text
    doneMessage: text
    display: text
    eventName: text
    eventSource: text
    unavailableReason: text
    appState: FastAppState
    settingsFastMode: text
    cooldownCleared: bool
    modelSwitched: bool
    prefetchAwaited: bool

    static fn new(rendered: text, doneMessage: text, display: text, eventName: text, eventSource: text, unavailableReason: text, appState: FastAppState, settingsFastMode: text, cooldownCleared: bool, modelSwitched: bool, prefetchAwaited: bool) -> FastCallResult:
        FastCallResult(rendered: rendered, doneMessage: doneMessage, display: display, eventName: eventName, eventSource: eventSource, unavailableReason: unavailableReason, appState: appState, settingsFastMode: settingsFastMode, cooldownCleared: cooldownCleared, modelSwitched: modelSwitched, prefetchAwaited: prefetchAwaited)

class FastPickerView:
    title: text
    subtitle: text
    inputGuide: text
    body: text
    link: text
    color: text

    static fn new(title: text, subtitle: text, inputGuide: text, body: text, link: text, color: text) -> FastPickerView:
        FastPickerView(title: title, subtitle: subtitle, inputGuide: inputGuide, body: body, link: link, color: color)

fn fastModeModelDisplay() -> text:
    "Opus 4.6"

fn getFastModeModel(opus1mMergeEnabled: bool) -> text:
    if opus1mMergeEnabled:
        return "opus[1m]"
    "opus"

fn fastModePricing() -> text:
    "$30/$150 per Mtok"

fn fastIcon(enabled: bool) -> text:
    if enabled:
        return "⚡"
    "⚡"

fn isFastModeSupportedByModel(fastModeEnabled: bool, model: text) -> bool:
    if not fastModeEnabled:
        return false
    model.lower().contains("opus-4-6")

fn applyFastMode(enable: bool, state: FastAppState, fastModeEnabled: bool, opus1mMergeEnabled: bool) -> FastApplyResult:
    if enable:
        val needsModelSwitch = not isFastModeSupportedByModel(fastModeEnabled, state.mainLoopModel)
        val model = if needsModelSwitch: getFastModeModel(opus1mMergeEnabled) else: state.mainLoopModel
        val sessionModel = if needsModelSwitch: "" else: state.mainLoopModelForSession
        return FastApplyResult.new(FastAppState.new(model, sessionModel, true), "true", true, needsModelSwitch)
    FastApplyResult.new(FastAppState.new(state.mainLoopModel, state.mainLoopModelForSession, false), "", true, false)

fn shortcutDoneMessage(enable: bool, startingModel: text, fastModeEnabled: bool) -> text:
    if enable:
        val modelUpdated = if not isFastModeSupportedByModel(fastModeEnabled, startingModel): " · model set to " + fastModeModelDisplay() else: ""
        return fastIcon(true) + " Fast mode ON" + modelUpdated + " · " + fastModePricing()
    "Fast mode OFF"

fn handleFastModeShortcut(enable: bool, state: FastAppState, fastModeEnabled: bool, unavailableReason: text, opus1mMergeEnabled: bool) -> FastCallResult:
    if unavailableReason != "":
        return FastCallResult.new("none", "Fast mode unavailable: " + unavailableReason, "", "", "", unavailableReason, state, "", false, false, true)
    val applied = applyFastMode(enable, state, fastModeEnabled, opus1mMergeEnabled)
    val message = shortcutDoneMessage(enable, state.mainLoopModel, fastModeEnabled)
    FastCallResult.new("none", message, "", "tengu_fast_mode_toggled", "shortcut", "", applied.appState, applied.settingsFastMode, applied.cooldownCleared, applied.modelSwitched, true)

fn pickerTitle(isCooldown: bool) -> text:
    fastIcon(true) + " Fast mode (research preview)"

fn pickerSubtitle() -> text:
    "High-speed mode for " + fastModeModelDisplay() + ". Billed as extra usage at a premium rate. Separate rate limits apply."

fn pickerInputGuide(pendingExit: bool, isUnavailable: bool, keyName: text) -> text:
    if pendingExit:
        return "Press " + keyName + " again to exit"
    if isUnavailable:
        return "Esc to cancel"
    "Tab to toggle · Enter to confirm · Esc to cancel"

fn cooldownMessage(reason: text, resetIn: text) -> text:
    val prefix = if reason == "overloaded": "Fast mode overloaded and is temporarily unavailable" else: "You've hit your fast limit"
    prefix + " · resets in " + resetIn

fn pickerBody(enableFastMode: bool, unavailableReason: text, cooldownReason: text, resetIn: text) -> text:
    if unavailableReason != "":
        return unavailableReason
    var body = "Fast mode " + if enableFastMode: "ON " else: "OFF"
    body = body + " " + fastModePricing()
    if cooldownReason != "":
        body = body + "\n" + cooldownMessage(cooldownReason, resetIn)
    body

fn renderFastModePicker(initialFastMode: bool, unavailableReason: text, cooldownReason: text, resetIn: text, pendingExit: bool, keyName: text) -> FastPickerView:
    FastPickerView.new(pickerTitle(cooldownReason != ""), pickerSubtitle(), pickerInputGuide(pendingExit, unavailableReason != "", keyName), pickerBody(initialFastMode, unavailableReason, cooldownReason, resetIn), "https://code.claude.com/docs/en/fast-mode", "fastMode")

fn confirmFastModePicker(enableFastMode: bool, initialState: FastAppState, fastModeEnabled: bool, unavailableReason: text, opus1mMergeEnabled: bool) -> FastCallResult:
    if unavailableReason != "":
        return FastCallResult.new("picker", "", "", "", "", unavailableReason, initialState, "", false, false, true)
    val applied = applyFastMode(enableFastMode, initialState, fastModeEnabled, opus1mMergeEnabled)
    val message = shortcutDoneMessage(enableFastMode, initialState.mainLoopModel, fastModeEnabled)
    FastCallResult.new("done", message, "", "tengu_fast_mode_toggled", "picker", "", applied.appState, applied.settingsFastMode, applied.cooldownCleared, applied.modelSwitched, true)

fn cancelFastModePicker(initialFastMode: bool, state: FastAppState, fastModeEnabled: bool, unavailableReason: text, opus1mMergeEnabled: bool) -> FastCallResult:
    if unavailableReason != "":
        if initialFastMode:
            val applied = applyFastMode(false, state, fastModeEnabled, opus1mMergeEnabled)
            return FastCallResult.new("done", "Fast mode OFF", "system", "", "", unavailableReason, applied.appState, applied.settingsFastMode, applied.cooldownCleared, applied.modelSwitched, true)
        return FastCallResult.new("done", "Fast mode OFF", "system", "", "", unavailableReason, state, "", false, false, true)
    val message = if initialFastMode: fastIcon(true) + " Kept Fast mode ON" else: "Kept Fast mode OFF"
    FastCallResult.new("done", message, "system", "", "", "", state, "", false, false, true)

fn togglePickerSelection(current: bool, unavailableReason: text) -> bool:
    if unavailableReason != "":
        return current
    not current

fn callFast(args: text, state: FastAppState, fastModeEnabled: bool, unavailableReason: text, opus1mMergeEnabled: bool) -> FastCallResult:
    if not fastModeEnabled:
        return FastCallResult.new("none", "", "", "", "", "", state, "", false, false, false)
    val arg = args.trim().lower()
    if arg == "on" or arg == "off":
        return handleFastModeShortcut(arg == "on", state, fastModeEnabled, unavailableReason, opus1mMergeEnabled)
    FastCallResult.new("picker", "", "", "tengu_fast_mode_picker_shown", "", unavailableReason, state, "", false, false, true)

fn fastSourceLinesModeled() -> i64:
    268

