class FastCommandDescriptor:
    typeName: text
    name: text
    description: text
    availability: [text]
    enabled: bool
    hidden: bool
    argumentHint: text
    immediate: bool
    loadPath: text

    static fn new(enabled: bool, immediate: bool) -> FastCommandDescriptor:
        FastCommandDescriptor(typeName: "local-jsx", name: "fast", description: "Toggle fast mode (" + fastModeModelDisplay() + " only)", availability: ["claude-ai", "console"], enabled: enabled, hidden: not enabled, argumentHint: "[on|off]", immediate: immediate, loadPath: "./fast.js")

fn fastCommand(enabled: bool, immediate: bool) -> FastCommandDescriptor:
    FastCommandDescriptor.new(enabled, immediate)

fn fastModeModelDisplay() -> text:
    "Opus 4.6"

fn fastIndexSourceLinesModeled() -> i64:
    26

