use app.llm_caret.claude_full.commands.clear.caches.{ClearSessionCachesResult, clearSessionCaches}

class ClearTask:
    id: text
    kind: text
    agentId: text
    hasBackgroundedFlag: bool
    isBackgrounded: bool
    status: text

    static fn new(id: text, kind: text, agentId: text, hasBackgroundedFlag: bool, isBackgrounded: bool, status: text) -> ClearTask:
        ClearTask(id: id, kind: kind, agentId: agentId, hasBackgroundedFlag: hasBackgroundedFlag, isBackgrounded: isBackgrounded, status: status)

class ClearConversationInput:
    messageCount: i64
    tasks: [ClearTask]
    proactiveEnabled: bool
    kairosEnabled: bool
    canSetConversationId: bool
    hasSetAppState: bool
    lastMainRequestId: text
    hookMessages: [text]
    worktreeSession: text
    coordinatorModeEnabled: bool
    coordinatorMode: bool
    userType: text
    hasClaudeSessionEnv: bool

    static fn new(messageCount: i64, tasks: [ClearTask], proactiveEnabled: bool, kairosEnabled: bool, canSetConversationId: bool, hasSetAppState: bool, lastMainRequestId: text, hookMessages: [text], worktreeSession: text, coordinatorModeEnabled: bool, coordinatorMode: bool, userType: text, hasClaudeSessionEnv: bool) -> ClearConversationInput:
        ClearConversationInput(messageCount: messageCount, tasks: tasks, proactiveEnabled: proactiveEnabled, kairosEnabled: kairosEnabled, canSetConversationId: canSetConversationId, hasSetAppState: hasSetAppState, lastMainRequestId: lastMainRequestId, hookMessages: hookMessages, worktreeSession: worktreeSession, coordinatorModeEnabled: coordinatorModeEnabled, coordinatorMode: coordinatorMode, userType: userType, hasClaudeSessionEnv: hasClaudeSessionEnv)

class ClearConversationResult:
    messagesCleared: bool
    finalMessages: [text]
    contextBlockedReset: bool
    conversationIdRegenerated: bool
    cacheResult: ClearSessionCachesResult
    preservedAgentIds: [text]
    killedTaskIds: [text]
    taskOutputEvictions: [text]
    runningTaskOutputSymlinkIds: [text]
    appStateReset: bool
    attributionReset: bool
    fileHistoryReset: bool
    mcpClientsCleared: bool
    pluginReconnectKeyPreserved: bool
    planSlugsCleared: bool
    sessionMetadataCleared: bool
    sessionIdRegenerated: bool
    envSessionIdUpdated: bool
    sessionFilePointerReset: bool
    modePersisted: text
    worktreeStateSaved: text
    cacheEvictionRequestId: text

    static fn new(messagesCleared: bool, finalMessages: [text], contextBlockedReset: bool, conversationIdRegenerated: bool, cacheResult: ClearSessionCachesResult, preservedAgentIds: [text], killedTaskIds: [text], taskOutputEvictions: [text], runningTaskOutputSymlinkIds: [text], appStateReset: bool, attributionReset: bool, fileHistoryReset: bool, mcpClientsCleared: bool, pluginReconnectKeyPreserved: bool, planSlugsCleared: bool, sessionMetadataCleared: bool, sessionIdRegenerated: bool, envSessionIdUpdated: bool, sessionFilePointerReset: bool, modePersisted: text, worktreeStateSaved: text, cacheEvictionRequestId: text) -> ClearConversationResult:
        ClearConversationResult(messagesCleared: messagesCleared, finalMessages: finalMessages, contextBlockedReset: contextBlockedReset, conversationIdRegenerated: conversationIdRegenerated, cacheResult: cacheResult, preservedAgentIds: preservedAgentIds, killedTaskIds: killedTaskIds, taskOutputEvictions: taskOutputEvictions, runningTaskOutputSymlinkIds: runningTaskOutputSymlinkIds, appStateReset: appStateReset, attributionReset: attributionReset, fileHistoryReset: fileHistoryReset, mcpClientsCleared: mcpClientsCleared, pluginReconnectKeyPreserved: pluginReconnectKeyPreserved, planSlugsCleared: planSlugsCleared, sessionMetadataCleared: sessionMetadataCleared, sessionIdRegenerated: sessionIdRegenerated, envSessionIdUpdated: envSessionIdUpdated, sessionFilePointerReset: sessionFilePointerReset, modePersisted: modePersisted, worktreeStateSaved: worktreeStateSaved, cacheEvictionRequestId: cacheEvictionRequestId)

fn clearConversation(input: ClearConversationInput) -> ClearConversationResult:
    val preservedAgentIds = collectPreservedAgentIds(input.tasks)
    val killedTaskIds = collectKilledTaskIds(input.tasks)
    val outputEvictions = killedTaskIds
    val cacheResult = clearSessionCaches(preservedAgentIds)
    val finalMessages = if input.hookMessages.len() > 0: input.hookMessages else: []
    ClearConversationResult.new(
        true,
        finalMessages,
        input.proactiveEnabled or input.kairosEnabled,
        input.canSetConversationId,
        cacheResult,
        preservedAgentIds,
        killedTaskIds,
        outputEvictions,
        collectRunningPreservedLocalAgentTaskIds(input.tasks),
        input.hasSetAppState,
        input.hasSetAppState,
        input.hasSetAppState,
        input.hasSetAppState,
        input.hasSetAppState,
        true,
        true,
        true,
        input.userType == "ant" and input.hasClaudeSessionEnv,
        true,
        persistedMode(input.coordinatorModeEnabled, input.coordinatorMode),
        input.worktreeSession,
        input.lastMainRequestId,
    )

fn shouldKillTask(task: ClearTask) -> bool:
    task.hasBackgroundedFlag and not task.isBackgrounded

fn isPreservableAgentTask(task: ClearTask) -> bool:
    task.kind == "local_agent" or task.kind == "in_process_teammate"

fn collectPreservedAgentIds(tasks: [ClearTask]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < tasks.len():
        val task = tasks[i]
        if not shouldKillTask(task) and isPreservableAgentTask(task):
            out.push(task.agentId)
        i = i + 1
    out

fn collectKilledTaskIds(tasks: [ClearTask]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < tasks.len():
        val task = tasks[i]
        if shouldKillTask(task):
            out.push(task.id)
        i = i + 1
    out

fn collectRunningPreservedLocalAgentTaskIds(tasks: [ClearTask]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < tasks.len():
        val task = tasks[i]
        if not shouldKillTask(task) and task.kind == "local_agent" and task.status == "running":
            out.push(task.id)
        i = i + 1
    out

fn persistedMode(coordinatorModeEnabled: bool, coordinatorMode: bool) -> text:
    if not coordinatorModeEnabled:
        return ""
    if coordinatorMode:
        return "coordinator"
    "normal"

fn clearConversationSourceLinesModeled() -> i64:
    251
# Source parity ledger 0102: session end hooks execute before clear.
# Source parity ledger 0103: cache eviction hint records last main request id.
# Source parity ledger 0104: preserved task decision is computed before cache clear.
# Source parity ledger 0105: tasks with isBackgrounded false are killed.
# Source parity ledger 0106: tasks without foreground flag are preserved.
# Source parity ledger 0107: local agent tasks contribute agent ids.
# Source parity ledger 0108: in-process teammate tasks contribute agent ids.
# Source parity ledger 0109: messages are cleared before cache wipe.
# Source parity ledger 0110: proactive context blocked state resets when enabled.
# Source parity ledger 0111: kairos context blocked state resets when enabled.
# Source parity ledger 0112: conversation id regenerates only when setter exists.
# Source parity ledger 0113: clearSessionCaches receives preserved agent ids.
# Source parity ledger 0114: cwd reset is represented by clear result.
# Source parity ledger 0115: read file state clear is represented by clear result.
# Source parity ledger 0116: discovered skill names clear is represented by clear result.
# Source parity ledger 0117: loaded nested memory paths clear is represented by clear result.
# Source parity ledger 0118: app state update is optional.
# Source parity ledger 0119: killed running shell task cleanup is represented by killed ids.
# Source parity ledger 0120: killed abortable task cleanup is represented by killed ids.
# Source parity ledger 0121: killed task unregister cleanup is represented by killed ids.
# Source parity ledger 0122: task output evictions match killed ids.
# Source parity ledger 0123: preserved tasks remain in next task map.
# Source parity ledger 0124: attribution state reset follows app state update.
# Source parity ledger 0125: standalone agent context reset is represented by app state reset.
# Source parity ledger 0126: file history reset follows app state update.
# Source parity ledger 0127: MCP clients clear follows app state update.
# Source parity ledger 0128: MCP tools clear follows app state update.
# Source parity ledger 0129: MCP commands clear follows app state update.
