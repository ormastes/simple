class ClearSessionCachesResult:
    preservedAgentIds: [text]
    hasPreservedAgents: bool
    resetPromptCacheBreakDetection: bool
    clearedPendingCallbacks: bool
    clearedDumpState: bool
    memoryLoadReason: text
    clearedCacheNames: [text]
    asyncCacheNames: [text]

    static fn new(preservedAgentIds: [text], hasPreservedAgents: bool, resetPromptCacheBreakDetection: bool, clearedPendingCallbacks: bool, clearedDumpState: bool, memoryLoadReason: text, clearedCacheNames: [text], asyncCacheNames: [text]) -> ClearSessionCachesResult:
        ClearSessionCachesResult(preservedAgentIds: preservedAgentIds, hasPreservedAgents: hasPreservedAgents, resetPromptCacheBreakDetection: resetPromptCacheBreakDetection, clearedPendingCallbacks: clearedPendingCallbacks, clearedDumpState: clearedDumpState, memoryLoadReason: memoryLoadReason, clearedCacheNames: clearedCacheNames, asyncCacheNames: asyncCacheNames)

fn clearSessionCaches(preservedAgentIds: [text]) -> ClearSessionCachesResult:
    val hasPreserved = preservedAgentIds.len() > 0
    ClearSessionCachesResult.new(
        preservedAgentIds,
        hasPreserved,
        not hasPreserved,
        not hasPreserved,
        not hasPreserved,
        "session_start",
        baseClearedCacheNames(),
        asyncClearedCacheNames(),
    )

fn baseClearedCacheNames() -> [text]:
    [
        "user-context",
        "system-context",
        "git-status",
        "session-start-date",
        "file-suggestions",
        "commands",
        "system-prompt-injection",
        "last-emitted-date",
        "post-compact-cleanup",
        "sent-skill-names",
        "memory-files-session-start",
        "stored-image-paths",
        "session-ingress",
        "repository-detection",
        "bash-command-prefix",
        "invoked-skills",
        "git-dir-resolution",
        "dynamic-skills",
        "lsp-diagnostics",
        "magic-docs",
        "session-env-vars",
    ]

fn asyncClearedCacheNames() -> [text]:
    [
        "tungsten-session-usage",
        "commit-attribution",
        "web-fetch-url-cache",
        "tool-search-description-cache",
        "agent-definitions-cache",
        "skill-tool-prompt-cache",
    ]

