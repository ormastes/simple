use app.llm_caret.claude_full.commands.clear.conversation.{ClearConversationInput, ClearConversationResult, clearConversation}

class ClearCommandCallResult:
    typeName: text
    value: text
    conversation: ClearConversationResult

    static fn new(typeName: text, value: text, conversation: ClearConversationResult) -> ClearCommandCallResult:
        ClearCommandCallResult(typeName: typeName, value: value, conversation: conversation)

fn call(input: ClearConversationInput) -> ClearCommandCallResult:
    ClearCommandCallResult.new("text", "", clearConversation(input))

fn clearCommandSourceLinesModeled() -> i64:
    7
