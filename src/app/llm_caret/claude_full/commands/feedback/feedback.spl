"""
Claude full feedback command parity.
"""

class FeedbackCommandDescriptor:
    typeName: text
    name: text
    description: text
    url: text

impl FeedbackCommandDescriptor:
    static fn new() -> FeedbackCommandDescriptor:
        FeedbackCommandDescriptor(typeName: "local", name: "feedback", description: "Open feedback form", url: "https://github.com/anthropics/claude-code/issues")

fn feedbackCommand() -> FeedbackCommandDescriptor:
    FeedbackCommandDescriptor.new()

fn feedbackCommandMessage() -> text:
    "Opening feedback form: " + feedbackCommand().url

fn feedbackCommandSourceLinesModeled() -> i64:
    24
