fn clampCursor(value: text, cursor: i64) -> i64:
    if cursor < 0:
        return 0
    if cursor > value.len():
        return value.len()
    cursor

fn isTypeaheadBoundary(ch: text) -> bool:
    ch == " " || ch == "\n" || ch == "\t"

fn extractCompletionTokenRoute(value: text, cursor: i64) -> text:
    val end = clampCursor(value, cursor)
    if end == 0:
        return "nil"
    var start = end
    while start > 0 && not isTypeaheadBoundary(value.substring(start - 1, start)):
        start = start - 1
    if start == end:
        return "nil"
    start.to_text() + "|" + value.substring(start, end)

fn stripTypeaheadQuotes(value: text) -> text:
    if value.len() >= 2 && value.starts_with("\"") && value.ends_with("\""):
        return value.substring(1, value.len() - 1)
    if value.len() >= 2 && value.starts_with("'") && value.ends_with("'"):
        return value.substring(1, value.len() - 1)
    value

fn extractSearchTokenRoute(token: text) -> text:
    var out = token.trim()
    if out.starts_with("@"):
        out = out.substring(1, out.len())
    stripTypeaheadQuotes(out)

fn formatPromptReplacementRoute(value: text) -> text:
    if value.contains(" "):
        return "@\"" + value + "\""
    "@" + value

fn formatBashReplacementRoute(value: text) -> text:
    if value.contains(" "):
        return "\"" + value + "\""
    value

fn applyDirectorySuggestionRoute(value: text, start: i64, end: i64, suggestion: text) -> text:
    value.substring(0, start) + formatPromptReplacementRoute(suggestion) + "/" + value.substring(end, value.len())

fn applyShellSuggestionRoute(value: text, start: i64, end: i64, suggestion: text) -> text:
    value.substring(0, start) + formatBashReplacementRoute(suggestion) + value.substring(end, value.len())

fn preservedSelectionRoute(selection: text, start: i64, end: i64) -> text:
    if selection != "" && end > start:
        return selection
    "nil"

fn typeaheadWords(value: text) -> [text]:
    var words: [text] = []
    var token = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == " " || ch == "\t":
            if token != "":
                words.push(token)
                token = ""
        else:
            token = token + ch
        i = i + 1
    if token != "":
        words.push(token)
    words

fn hasCommandWithArgumentsRoute(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    val parts = typeaheadWords(trimmed)
    parts.len() > 1 && parts[0] != "" && parts[1] != ""
