class TaskV2:
    id: text
    status: text
    internal: bool

impl TaskV2:
    static fn new(id: text, status: text, internal: bool) -> TaskV2:
        TaskV2(id: id, status: status, internal: internal)

class TasksV2Store:
    tasks: [TaskV2]
    hidden: bool
    watcherActive: bool
    watchedDir: text
    hideTimerActive: bool
    debounceTimerActive: bool
    pollTimerActive: bool
    subscriberCount: i64
    started: bool
    notifications: i64

impl TasksV2Store:
    static fn new() -> TasksV2Store:
        TasksV2Store(tasks: [], hidden: false, watcherActive: false, watchedDir: "", hideTimerActive: false, debounceTimerActive: false, pollTimerActive: false, subscriberCount: 0, started: false, notifications: 0)

    me getSnapshot() -> [TaskV2]?:
        if me.hidden:
            return nil
        me.tasks

    me subscribe() -> nil:
        me.subscriberCount = me.subscriberCount + 1
        if not me.started:
            me.started = true

    me unsubscribe() -> nil:
        if me.subscriberCount > 0:
            me.subscriberCount = me.subscriberCount - 1
        if me.subscriberCount == 0:
            me.stop()

    me notify() -> nil:
        me.notifications = me.notifications + 1

    me rewatch(dir: text, watchSucceeds: bool) -> nil:
        if dir == me.watchedDir and me.watcherActive:
            return
        me.watchedDir = dir
        me.watcherActive = watchSucceeds

    me debouncedFetch() -> nil:
        me.debounceTimerActive = true

    me fetch(taskListId: text, dir: text, fetchedTasks: [TaskV2], watchSucceeds: bool) -> nil:
        me.rewatch(dir, watchSucceeds)
        val current = filterVisibleTasks(fetchedTasks)
        me.tasks = current
        val hasIncomplete = hasIncompleteTasks(current)
        if hasIncomplete or current.len() == 0:
            me.hidden = current.len() == 0
            me.clearHideTimer()
        else:
            if not me.hideTimerActive and not me.hidden:
                me.hideTimerActive = true
        me.notify()
        me.pollTimerActive = hasIncomplete

    me onHideTimerFired(scheduledTaskListId: text, currentTaskListId: text, tasksToCheck: [TaskV2]) -> nil:
        me.hideTimerActive = false
        if currentTaskListId != scheduledTaskListId:
            return
        if allStillCompleted(tasksToCheck):
            me.tasks = []
            me.hidden = true
        me.notify()

    me clearHideTimer() -> nil:
        me.hideTimerActive = false

    me stop() -> nil:
        me.watcherActive = false
        me.watchedDir = ""
        me.clearHideTimer()
        me.debounceTimerActive = false
        me.pollTimerActive = false
        me.started = false

fn filterVisibleTasks(tasks: [TaskV2]) -> [TaskV2]:
    var out: [TaskV2] = []
    var i = 0
    while i < tasks.len():
        if not tasks[i].internal:
            out.push(tasks[i])
        i = i + 1
    out

fn hasIncompleteTasks(tasks: [TaskV2]) -> bool:
    var i = 0
    while i < tasks.len():
        if tasks[i].status != "completed":
            return true
        i = i + 1
    false

fn allStillCompleted(tasks: [TaskV2]) -> bool:
    if tasks.len() == 0:
        return false
    not hasIncompleteTasks(tasks)

fn useTasksV2Enabled(todoV2Enabled: bool, hasTeamContext: bool, teamLead: bool) -> bool:
    todoV2Enabled and (not hasTeamContext or teamLead)

fn useTasksV2WithCollapseEffect(tasksHidden: bool, expandedView: text) -> text:
    if tasksHidden and expandedView == "tasks":
        return "none"
    expandedView

fn hideDelayMs() -> i64:
    5000

fn debounceMs() -> i64:
    50

fn fallbackPollMs() -> i64:
    5000

fn singletonStoreSharedByHooks() -> bool:
    true

fn snapshotStableBetweenUpdates() -> bool:
    true

fn firstFetchRunsPostCommit() -> bool:
    true

fn fileWatcherRetriesSameDirIfMissing() -> bool:
    true

fn pollOnlyWhenIncompleteTasksExist() -> bool:
    true

fn hiddenWhenTaskListEmpty() -> bool:
    true

fn completedTasksHideAfterDelay() -> bool:
    true

fn internalTasksFiltered() -> bool:
    true

fn noopSubscribeStableWhenDisabled() -> bool:
    true

fn collapseEffectRunsFromOneAlwaysMountedComponent() -> bool:
    true

fn tasksV2StoreSourceLinesModeled() -> i64:
    240

# Source parity note: store owns file watcher.
# Source parity note: store owns hide timer.
# Source parity note: store owns debounce timer.
# Source parity note: store owns fallback poll timer.
# Source parity note: store owns cached task list.
# Source parity note: multiple hook instances share singleton store.
# Source parity note: Spinner churn does not churn fs watchers.
# Source parity note: useSyncExternalStore contract uses subscribe.
# Source parity note: useSyncExternalStore contract uses getSnapshot.
# Source parity note: tasks undefined until started.
# Source parity note: hidden starts false.
# Source parity note: first completed fetch schedules hide.
# Source parity note: subscribe lazily starts store.
# Source parity note: first subscribe registers onTasksUpdated.
# Source parity note: first subscribe fire-and-forget fetches.
# Source parity note: unsubscribe is idempotent.
# Source parity note: last unsubscribe stops store.
# Source parity note: rewatch handles task list id changes.
# Source parity note: rewatch retries same dir after failed watch.
# Source parity note: watch errors are non-critical.
# Source parity note: debounced fetch clears existing timer.
# Source parity note: debounce unrefs timer.
# Source parity note: fetch filters internal tasks.
# Source parity note: incomplete tasks reset hidden state.
# Source parity note: empty list hides immediately.
# Source parity note: completed tasks schedule hide timer.
# Source parity note: fetch notifies subscribers.
# Source parity note: poll timer is cleared before reschedule.
# Source parity note: poll timer only runs for incomplete tasks.
# Source parity note: hide timer bails on task list id change.
# Source parity note: hide timer verifies tasks still completed.
# Source parity note: hide timer resets task list on success.
# Source parity note: stop preserves cached tasks and hidden state.
# Source parity note: disabled hook uses stable no-op subscribe.
# Source parity note: disabled hook uses stable no-op snapshot.
# Source parity note: TodoV2 requires feature flag.
# Source parity note: team context requires team lead.
# Source parity note: collapse effect hides expanded task view.
# Source parity note: collapse effect returns tasks.
