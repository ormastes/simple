const CLAUDE_REPL_SOURCE_LINES = 5005

class Props:
    transcriptMode: bool
    verbose: bool
    initialMessage: text

impl Props:
    static fn new(transcriptMode: bool, verbose: bool, initialMessage: text) -> Props:
        Props(transcriptMode: transcriptMode, verbose: verbose, initialMessage: initialMessage)

class Screen:
    name: text
    active: bool

impl Screen:
    static fn new(name: text, active: bool) -> Screen:
        Screen(name: name, active: active)

fn proactiveNoOpSubscribeRoute() -> text:
    "proactive no op unsubscribe"

fn proactiveFalseRoute() -> bool:
    false

fn suggestBgPrNoopRoute() -> text:
    "suggest background pr noop"

fn shouldShowAntModelSwitchRoute(model: text, hasPrompt: bool, isTranscriptMode: bool) -> bool:
    model == "ant" && hasPrompt && !isTranscriptMode

fn medianRoute(count: i64, odd: bool) -> text:
    if count == 0:
        return "median none"
    if odd:
        return "median middle"
    "median average pair"

fn transcriptModeFooterRoute(searchOpen: bool, matchCount: i64, currentMatch: i64) -> text:
    if searchOpen && matchCount > 0:
        return "footer search matches"
    if searchOpen:
        return "footer search no matches"
    "footer transcript controls"

fn transcriptSearchBarRoute(query: text, focused: bool, matchCount: i64) -> text:
    if query == "":
        return "search empty"
    if focused && matchCount > 0:
        return "search focused with matches"
    if focused:
        return "search focused no matches"
    "search blurred"

fn animatedTerminalTitleRoute(titleDisabled: bool, rename: text, reducedMotion: bool) -> text:
    if titleDisabled:
        return "terminal title disabled"
    if reducedMotion:
        return "static terminal title"
    if rename != "":
        return "animated renamed terminal title"
    "animated terminal title"

fn replRoute(screen: text, loading: bool, transcriptMode: bool) -> text:
    if transcriptMode:
        return "render transcript screen"
    if loading:
        return "render loading repl"
    if screen == "permission":
        return "render permission overlay"
    "render repl"

fn transcriptRenderRoute(screen: text, dumpMode: bool, virtualScroll: bool) -> text:
    if screen == "transcript" && !dumpMode && virtualScroll:
        return "alternate screen transcript keybindings search"
    if screen == "transcript":
        return "render transcript dump"
    "render normal screen"

fn remoteCalloutRoute(showRemote: bool, hasMcp: bool) -> text:
    if showRemote && hasMcp:
        return "show remote mcp callout"
    if showRemote:
        return "show remote callout"
    "hide remote callout"

fn setMessagesRoute(hasRestore: bool, hasUnseen: bool) -> text:
    if hasRestore:
        return "restore message sync"
    if hasUnseen:
        return "insert unseen divider"
    "set visible messages"

fn scrollRoute(userPinned: bool, newOutput: bool) -> text:
    if userPinned:
        return "preserve user scroll"
    if newOutput:
        return "repin scroll to bottom"
    "scroll unchanged"

fn queryEventRoute(kind: text, streaming: bool, hasToolUse: bool) -> text:
    if kind == "assistant" && streaming:
        return "append streaming assistant text"
    if kind == "tool" && hasToolUse:
        return "update in progress tool use"
    if kind == "error":
        return "show query error"
    "record query event"

fn onQueryRoute(firstUserMessage: bool, background: bool, hasNotifications: bool) -> text:
    if background:
        return "start background query"
    if firstUserMessage && hasNotifications:
        return "submit first query with notification attachments"
    if firstUserMessage:
        return "submit first user query"
    "submit followup query"

fn executeImmediateCommandRoute(hasCommand: bool, queued: bool, pastedBytes: i64) -> text:
    if !hasCommand:
        return "no immediate command"
    if queued:
        return "queue command for dialog"
    if pastedBytes > 0:
        return "execute command with pasted text refs"
    "execute command"

fn focusedInputDialogRoute(hasPermission: bool, hasElicitation: bool, hasSandbox: bool) -> text:
    if hasPermission:
        return "permission dialog focused"
    if hasElicitation:
        return "elicitation dialog focused"
    if hasSandbox:
        return "sandbox dialog focused"
    "prompt input focused"

fn handleQueuedCommandOnCancelRoute(hasQueued: bool, shouldRestore: bool) -> text:
    if hasQueued && shouldRestore:
        return "restore queued command input"
    if hasQueued:
        return "discard queued command"
    "no queued command"

fn toolPermissionOverlayRoute(hasRequest: bool, approved: bool, denied: bool) -> text:
    if approved:
        return "permission approved"
    if denied:
        return "permission denied"
    if hasRequest:
        return "show permission overlay"
    "no permission overlay"

fn handleExitRoute(hasRunningAgents: bool, hasRunningTools: bool, force: bool) -> text:
    if force:
        return "force exit"
    if hasRunningAgents:
        return "confirm exit running agents"
    if hasRunningTools:
        return "confirm exit running tools"
    "exit immediately"

fn transcriptRoute(action: text) -> text:
    if action == "enter":
        return "enter transcript mode"
    if action == "exit":
        return "exit transcript mode"
    if action == "search":
        return "update transcript search matches"
    "transcript unchanged"

fn transcriptKeyRoute(key: text, searchCount: i64, repeatCount: i64) -> text:
    if key == "/":
        return "activate transcript search arm anchor"
    if (key == "n" || key == "N") && searchCount > 0:
        return "advance transcript search jump " + repeatCount.to_text()
    if key == "v":
        return "export transcript open editor"
    if key == "escape" || key == "enter":
        return "exit transcript search"
    "transcript key ignored"

fn submitRoute(loading: bool, slashCommand: bool, immediateLocal: bool, remoteMode: bool, hasPasted: bool) -> text:
    if slashCommand && immediateLocal && loading:
        return "execute immediate local command while loading"
    if remoteMode && !immediateLocal:
        return "remote create user message send"
    if hasPasted:
        return "handle prompt submit with pasted refs"
    "handle prompt submit with tool context"

fn queryGuardRoute(tryStartOk: bool, completionOk: bool, userCancel: bool, hasPendingText: bool) -> text:
    if !tryStartOk:
        return "enqueue input because query guard busy"
    if completionOk:
        return "query guard end reset loading notify bridge"
    if userCancel && !hasPendingText:
        return "restore interrupted message into prompt"
    "query guard active"

fn focusedInputDialogPriorityRoute(hasToolPermission: bool, hasWorker: bool, hasSandbox: bool, hasElicitation: bool, activeInputSuppressed: bool) -> text:
    if activeInputSuppressed:
        return "prompt input suppressed by active dialog"
    if hasToolPermission:
        return "tool permission dialog focused"
    if hasWorker:
        return "worker request dialog focused"
    if hasSandbox:
        return "sandbox request dialog focused"
    if hasElicitation:
        return "elicitation dialog focused"
    "prompt input focused"

fn cancelRoute(focused: text, hasQueued: bool, hasText: bool) -> text:
    if focused == "toolPermission":
        return "abort head tool permission and clear queue"
    if focused == "sandbox":
        return "cancel sandbox prompt"
    if !hasQueued && !hasText:
        return "normal abort restore interrupted prompt"
    if hasQueued:
        return "cancel queued input"
    "clear prompt text"

fn suspendResumeRoute(action: text) -> text:
    if action == "suspend":
        return "suspend repl input"
    if action == "resume":
        return "resume repl input"
    "repl active"

fn appendStdoutRoute(idle: bool, stdout: text) -> text:
    if stdout == "":
        return "skip empty stdout"
    if idle:
        return "append stdout when idle"
    "buffer stdout until idle"

fn replSourceLinesModeled() -> i64:
    CLAUDE_REPL_SOURCE_LINES
