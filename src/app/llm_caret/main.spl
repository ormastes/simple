# LLM Caret - CLI Entry Point
#
# Wires the already-production-grade library (config.spl, provider.spl,
# tools.spl, chat.spl, chat_tui.spl, server.spl) into a runnable command:
#
#   bin/simple run src/app/llm_caret/main.spl [options]
#
# Options:
#   --provider <name>        claude_cli | opencode_cli | claude_api | openai |
#                             openai_compat | local_torch (default: config file's
#                             defaults.provider, else claude_cli)
#   --model <name>           model id (default: provider's configured model)
#   --config <path>          load an llm_caret.sdn config file (config.spl)
#   --system <prompt>        system prompt
#   --resume <session_id>    resume a persisted session (see session.spl)
#   --workspace <path>       tool sandbox root for bash/read_file/write_file/
#                             list_dir/glob (default: cwd)
#   --dangerously-allow-all  auto-approve mutating tools (bash/write_file)
#   --plain                  force the plain (non-TUI) renderer
#   --tui                    force the full-screen TUI renderer
#   --server                 run the HTTP proxy (server.spl) instead of chat
#   --port <n>                proxy port (default 8317, or $LLM_CARET_PORT)
#   -h / --help              show this help
#
# Sessions persist to ~/.llm_caret/sessions/<id>.json (session.spl) so
# --resume restores a prior transcript + provider session id across runs.

use app.io.mod.{env_get, home, file_exists}
use std.nogc_sync_mut.cli.cli_util.{get_cli_args}
use std.nogc_sync_mut.http_server.{SimpleHttpServer, Router, HttpRequest, HttpResponse}
use std.nogc_sync_mut.http_server.types.{HttpStatus, http_method_to_text}
use std.log.{info as log_info}

use app.llm_caret.config.{load_config, config_loaded,
    config_default_provider, config_claude_cli_path, config_claude_cli_model,
    config_opencode_cli_path, config_opencode_cli_model,
    config_claude_api_key, config_claude_api_base_url, config_claude_api_model,
    config_openai_api_key, config_openai_base_url, config_openai_model,
    config_compat_base_url, config_compat_model, config_compat_api_key}
use app.llm_caret.provider.{LLMResponse, dispatch_send, is_valid_provider, list_providers, new_llm_error}
use app.llm_caret.tools.{PermissionPolicy, ToolCall, ModelResponse,
    default_policy, allow_all_policy, parse_tool_use_blocks, new_model_text, new_model_tools}
use app.llm_caret.types.{Message, new_user_message, new_assistant_message}
use app.llm_caret.chat.{AgentResult, run_agent_loop}
use app.llm_caret.chat_tui.{ChatTui, make_chat_tui, caret_chat, caret_is_tty}
use app.llm_caret.json_helpers.{build_message_json, ja}
use app.llm_caret.server.{handle_route, build_error_response,
    build_chat_completion_response, build_anthropic_response,
    parse_chat_request_content, parse_chat_request_model}
use app.llm_caret.session.{
    Session, new_session, session_path, save_session, load_session,
    list_session_ids, gen_session_id
}

# ============================================================================
# Argument parsing (pure - unit-testable without a live process)
# ============================================================================

struct MainArgs:
    provider: text
    model: text
    config_path: text
    system_prompt: text
    resume_id: text
    workspace_root: text
    allow_all: bool
    ui_mode: text        # "auto" | "tui" | "plain"
    server_mode: bool
    port: i64
    help: bool
    unknown: text        # first unrecognized --flag (empty if none)

fn parse_main_args(args: [text]) -> MainArgs:
    var provider = ""
    var model = ""
    var config_path = ""
    var system_prompt = ""
    var resume_id = ""
    var workspace_root = ""
    var allow_all = false
    var ui_mode = "auto"
    var server_mode = false
    var port: i64 = 0
    var help = false
    var unknown = ""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "-h" or arg == "--help":
            help = true
        elif arg == "--provider" and i + 1 < args.len():
            provider = args[i + 1]
            i = i + 1
        elif arg.starts_with("--provider="):
            provider = arg.substring(11)
        elif arg == "--model" and i + 1 < args.len():
            model = args[i + 1]
            i = i + 1
        elif arg.starts_with("--model="):
            model = arg.substring(8)
        elif arg == "--config" and i + 1 < args.len():
            config_path = args[i + 1]
            i = i + 1
        elif arg.starts_with("--config="):
            config_path = arg.substring(9)
        elif arg == "--system" and i + 1 < args.len():
            system_prompt = args[i + 1]
            i = i + 1
        elif arg.starts_with("--system="):
            system_prompt = arg.substring(9)
        elif arg == "--resume" and i + 1 < args.len():
            resume_id = args[i + 1]
            i = i + 1
        elif arg.starts_with("--resume="):
            resume_id = arg.substring(9)
        elif arg == "--workspace" and i + 1 < args.len():
            workspace_root = args[i + 1]
            i = i + 1
        elif arg.starts_with("--workspace="):
            workspace_root = arg.substring(12)
        elif arg == "--dangerously-allow-all":
            allow_all = true
        elif arg == "--plain":
            ui_mode = "plain"
        elif arg == "--tui":
            ui_mode = "tui"
        elif arg == "--server":
            server_mode = true
        elif arg == "--port" and i + 1 < args.len():
            port = int(args[i + 1]) ?? 0
            i = i + 1
        elif arg.starts_with("--port="):
            port = int(arg.substring(7)) ?? 0
        elif arg.starts_with("--") and unknown == "":
            unknown = arg
        i = i + 1
    MainArgs(
        provider: provider, model: model, config_path: config_path,
        system_prompt: system_prompt, resume_id: resume_id,
        workspace_root: workspace_root, allow_all: allow_all,
        ui_mode: ui_mode, server_mode: server_mode, port: port,
        help: help, unknown: unknown
    )

# ============================================================================
# Help text
# ============================================================================

fn print_help():
    print "Usage: simple run src/app/llm_caret/main.spl [options]"
    print ""
    print "Interactive LLM chat shell (Claude-CLI-like) with real tool use"
    print "(bash / read_file / write_file / list_dir / glob) gated by a"
    print "permission policy, and an optional OpenAI/Anthropic-compatible"
    print "HTTP proxy."
    print ""
    print "Options:"
    print "  --provider <name>        claude_cli | opencode_cli | claude_api |"
    print "                           openai | openai_compat | local_torch"
    print "  --model <name>           model id (default: provider's configured model)"
    print "  --config <path>          load an llm_caret.sdn config file"
    print "  --system <prompt>        system prompt"
    print "  --resume <session_id>    resume a persisted session"
    print "  --workspace <path>       tool sandbox root (default: cwd)"
    print "  --dangerously-allow-all  auto-approve mutating tools (bash/write_file)"
    print "  --plain                  force the plain (non-TUI) renderer"
    print "  --tui                    force the full-screen TUI renderer"
    print "  --server                 run the HTTP proxy instead of interactive chat"
    print "  --port <n>               proxy port (default 8317, or $LLM_CARET_PORT)"
    print "  -h, --help               show this help"
    print ""
    print "Slash commands (interactive mode): /help /exit /new /model <m>"
    print "  /provider <p> /sessions /resume <id>"
    print ""
    print "Examples:"
    print "  simple run src/app/llm_caret/main.spl --plain"
    print "  simple run src/app/llm_caret/main.spl --provider claude_api --model claude-opus-4-20250514"
    print "  simple run src/app/llm_caret/main.spl --resume 2026-07-19-abc123"
    print "  simple run src/app/llm_caret/main.spl --server --port 8317"

# ============================================================================
# Config resolution
# ============================================================================

fn _effective_provider(args: MainArgs) -> text:
    if args.provider != "":
        return args.provider
    if config_loaded():
        return config_default_provider()
    "claude_cli"

fn _effective_model(provider: text, args: MainArgs) -> text:
    if args.model != "":
        return args.model
    if provider == "claude_cli":
        return config_claude_cli_model()
    if provider == "opencode_cli":
        return config_opencode_cli_model()
    if provider == "claude_api":
        return config_claude_api_model()
    if provider == "openai":
        return config_openai_model()
    if provider == "openai_compat":
        return config_compat_model()
    ""

fn _effective_cli_path(provider: text) -> text:
    if provider == "claude_cli":
        return config_claude_cli_path()
    if provider == "opencode_cli":
        return config_opencode_cli_path()
    ""

fn _effective_api_key(provider: text) -> text:
    if provider == "claude_api":
        return config_claude_api_key()
    if provider == "openai":
        return config_openai_api_key()
    if provider == "openai_compat":
        return config_compat_api_key()
    ""

fn _effective_base_url(provider: text) -> text:
    if provider == "claude_api":
        return config_claude_api_base_url()
    if provider == "openai":
        return config_openai_base_url()
    if provider == "openai_compat":
        return config_compat_base_url()
    ""

fn _effective_port(args: MainArgs) -> i64:
    if args.port > 0:
        return args.port
    val env_port = env_get("LLM_CARET_PORT") ?? ""
    if env_port != "":
        val parsed = int(env_port) ?? 0
        if parsed > 0:
            return parsed
    8317

# ============================================================================
# Runtime state (module-level - the responder fn cannot capture/mutate outer
# vars, so the active provider config + running session id live here, set once
# by main_configure before the chat/agent loop starts).
# ============================================================================

var RT_PROVIDER = ""
var RT_MODEL = ""
var RT_API_KEY = ""
var RT_BASE_URL = ""
var RT_CLI_PATH = ""
var RT_SYSTEM_PROMPT = ""
var RT_SESSION_ID = ""
var RT_MAX_TOKENS: i64 = 0

fn main_configure(provider: text, model: text, api_key: text, base_url: text,
                  cli_path: text, system_prompt: text, session_id: text, max_tokens: i64):
    RT_PROVIDER = provider
    RT_MODEL = model
    RT_API_KEY = api_key
    RT_BASE_URL = base_url
    RT_CLI_PATH = cli_path
    RT_SYSTEM_PROMPT = system_prompt
    RT_SESSION_ID = session_id
    RT_MAX_TOKENS = max_tokens

fn main_session_id() -> text:
    RT_SESSION_ID

# ============================================================================
# LLMResponse -> ModelResponse mapping (pure, unit-testable: no network/CLI).
# This is the piece that lets the real tool-use loop (chat.run_agent_loop)
# drive claude_api-style providers, which return tool_use blocks embedded in
# the raw wire JSON rather than a separate structured field.
# ============================================================================

fn build_model_response(resp: LLMResponse) -> ModelResponse:
    if resp.is_error:
        return new_model_text("ERROR: " + resp.error)
    val calls = parse_tool_use_blocks(resp.raw)
    if calls.len() > 0:
        return new_model_tools(resp.content, calls)
    new_model_text(resp.content)

fn _last_user_content(msgs: [Message]) -> text:
    var i = msgs.len() - 1
    while i >= 0:
        if msgs[i].role == "user":
            return msgs[i].content
        i = i - 1
    ""

fn _messages_json(msgs: [Message]) -> text:
    var items: [text] = []
    for m in msgs:
        items = items + [build_message_json(m.role, m.content)]
    ja(items)

# The real responder handed to run_agent_loop / caret_chat. Thin by design:
# all its logic (LLMResponse -> ModelResponse, tool_use parsing) is covered by
# the pure build_model_response tests; this just threads the running
# transcript + session id through provider.dispatch_send.
fn main_responder(msgs: [Message]) -> ModelResponse:
    val prompt = _last_user_content(msgs)
    val messages_json = _messages_json(msgs)
    val resp = dispatch_send(
        RT_PROVIDER, prompt, RT_MODEL, RT_API_KEY, RT_BASE_URL, RT_CLI_PATH,
        RT_SYSTEM_PROMPT, RT_SESSION_ID, 0, RT_MAX_TOKENS, messages_json
    )
    if resp.session_id != "":
        RT_SESSION_ID = resp.session_id
    build_model_response(resp)

# ============================================================================
# HTTP proxy (--server)
# ============================================================================

fn _status_for_path(path: text) -> HttpStatus:
    if path == "/v1/health" or path == "/v1/models":
        return HttpStatus.Ok
    HttpStatus.NotFound

# Pure core of the proxy request handler: no sockets, fully unit-testable by
# passing a fake dispatch fn. Real production dispatch is provider.dispatch_send
# via main_responder's sibling below; tests inject a canned one.
fn proxy_handle(method: text, path: text, body: text,
                dispatch: fn(text, text) -> LLMResponse) -> (i64, text):
    if method == "POST" and (path == "/v1/chat/completions" or path == "/v1/messages"):
        val content = parse_chat_request_content(body)
        if content == "":
            return (400, build_error_response("messages required", 400))
        val model = parse_chat_request_model(body)
        val resp = dispatch(content, model)
        if resp.is_error:
            return (502, build_error_response(resp.error, 502))
        if path == "/v1/messages":
            return (200, build_anthropic_response(resp.content, resp.model, resp.stop_reason))
        return (200, build_chat_completion_response(resp.content, resp.model, resp.stop_reason))
    val body_text = handle_route(method, path, body)
    val status = _status_for_path(path)
    (status.http_status_code_i64(), body_text)

fn _proxy_dispatch(content: text, model: text) -> LLMResponse:
    var use_model = model
    if use_model == "":
        use_model = RT_MODEL
    val messages_json = ja([build_message_json("user", content)])
    dispatch_send(RT_PROVIDER, content, use_model, RT_API_KEY, RT_BASE_URL,
                   RT_CLI_PATH, RT_SYSTEM_PROMPT, "", 0, RT_MAX_TOKENS, messages_json)

fn _to_http_status(code: i64) -> HttpStatus:
    if code == 200: return HttpStatus.Ok
    if code == 400: return HttpStatus.BadRequest
    if code == 404: return HttpStatus.NotFound
    if code == 502: return HttpStatus.BadGateway
    HttpStatus.InternalError

fn _http_handle(req: HttpRequest) -> HttpResponse:
    val method = http_method_to_text(req.method)
    val (code, body) = proxy_handle(method, req.path, req.body, _proxy_dispatch)
    log_info("llm_caret.server", method + " " + req.path + " -> " + code.to_text())
    HttpResponse(
        status: _to_http_status(code),
        headers: [("Content-Type", "application/json; charset=utf-8")],
        body: body
    )

fn run_server(port: i64):
    var router = Router.new()
    router.mount("/v1", _http_handle)
    router.set_not_found(_http_handle)
    print "llm_caret HTTP proxy listening on 127.0.0.1:{port}"
    var server = SimpleHttpServer.new("127.0.0.1", port, router)
    server.start()

# ============================================================================
# Session integration
# ============================================================================

fn _resolve_workspace(args: MainArgs) -> text:
    if args.workspace_root != "":
        return args.workspace_root
    val cwd_env = env_get("PWD") ?? ""
    if cwd_env != "":
        return cwd_env
    "."

fn _build_policy(args: MainArgs, workspace_root: text) -> PermissionPolicy:
    if args.allow_all:
        return allow_all_policy(workspace_root)
    default_policy(workspace_root)

# ============================================================================
# main()
# ============================================================================

fn main() -> i64:
    val raw_args = get_cli_args()
    val args = parse_main_args(raw_args)
    if args.help:
        print_help()
        return 0
    if args.unknown != "":
        print "Error: unknown option '{args.unknown}'"
        print ""
        print_help()
        return 2

    if args.config_path != "":
        if not file_exists(args.config_path):
            print "Error: config file not found: {args.config_path}"
            return 2
        val err = load_config(args.config_path)
        if err != "":
            print "Error: {err}"
            return 2

    val provider = _effective_provider(args)
    if not is_valid_provider(provider):
        print "Error: unknown provider '{provider}'"
        print "Valid providers: {list_providers().join(", ")}"
        return 2

    val model = _effective_model(provider, args)
    val api_key = _effective_api_key(provider)
    val base_url = _effective_base_url(provider)
    val cli_path = _effective_cli_path(provider)
    val workspace_root = _resolve_workspace(args)
    val policy = _build_policy(args, workspace_root)

    if args.server_mode:
        main_configure(provider, model, api_key, base_url, cli_path, args.system_prompt, "", 0)
        run_server(_effective_port(args))
        return 0

    var session_id = ""
    var conv: [Message] = []
    if args.resume_id != "":
        val loaded = load_session(args.resume_id)
        match loaded:
            Some(sess):
                session_id = sess.provider_session_id
                conv = sess.messages
            nil:
                print "Error: no saved session '{args.resume_id}'"
                return 2

    main_configure(provider, model, api_key, base_url, cli_path, args.system_prompt, session_id, 0)

    val ui = make_chat_tui("llm_caret - {provider}")
    caret_chat(ui, policy, main_responder, args.ui_mode)
    0
