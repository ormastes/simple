# ============================================================================
# Config resolution
# ============================================================================

fn _effective_provider(args: MainArgs) -> text:
    if args.provider != "":
        return args.provider
    if config_loaded():
        return config_default_provider()
    "claude_cli"

fn _default_model(provider: text) -> text:
    if provider == "dummy":
        return "dummy-hello"
    if provider == "claude_cli":
        return config_claude_cli_model()
    if provider == "opencode_cli":
        return config_opencode_cli_model()
    if provider == "claude_api":
        return config_claude_api_model()
    if provider == "openai":
        return config_openai_model()
    if provider == "openai_compat":
        return config_compat_model()
    ""

fn _effective_model(provider: text, args: MainArgs) -> text:
    if args.model != "":
        return args.model
    _default_model(provider)

struct ResumeBackend:
    provider: text
    model: text
    reuse_provider_session: bool

fn resolve_resume_backend(
    requested_provider: text,
    requested_model: text,
    saved_provider: text,
    saved_model: text
) -> ResumeBackend:
    val provider = if requested_provider == "":
        saved_provider
    else:
        requested_provider
    val normalized_saved_model = if saved_model == "":
        _default_model(saved_provider)
    else:
        saved_model
    val model = if requested_model != "":
        requested_model
    elif provider == saved_provider:
        normalized_saved_model
    else:
        _default_model(provider)
    ResumeBackend(
        provider: provider,
        model: model,
        reuse_provider_session:
            provider == saved_provider and model == normalized_saved_model
    )

fn _effective_cli_path(provider: text) -> text:
    if provider == "claude_cli":
        return config_claude_cli_path()
    if provider == "opencode_cli":
        return config_opencode_cli_path()
    ""

fn _effective_api_key(provider: text) -> text:
    if provider == "claude_api":
        return config_claude_api_key()
    if provider == "openai":
        return config_openai_api_key()
    if provider == "openai_compat":
        return config_compat_api_key()
    ""

fn _effective_base_url(provider: text) -> text:
    if provider == "claude_api":
        return config_claude_api_base_url()
    if provider == "openai":
        return config_openai_base_url()
    if provider == "openai_compat":
        return config_compat_base_url()
    ""

fn _effective_port(args: MainArgs) -> i64:
    if args.port > 0:
        return args.port
    val env_port = env_get("LLM_CARET_PORT") ?? ""
    if env_port != "":
        val parsed = int(env_port) ?? 0
        if parsed > 0:
            return parsed
    8317

# ============================================================================
# Runtime state (module-level - the responder fn cannot capture/mutate outer
# vars, so the active provider config + running session id live here, set once
# by main_configure before the chat/agent loop starts).
# ============================================================================

var RT_PROVIDER = ""
var RT_MODEL = ""
var RT_API_KEY = ""
var RT_BASE_URL = ""
var RT_CLI_PATH = ""
var RT_SYSTEM_PROMPT = ""
var RT_SESSION_ID = ""
var RT_MAX_TOKENS: i64 = 0

fn main_configure(provider: text, model: text, api_key: text, base_url: text,
                  cli_path: text, system_prompt: text, session_id: text, max_tokens: i64):
    RT_PROVIDER = provider
    RT_MODEL = model
    RT_API_KEY = api_key
    RT_BASE_URL = base_url
    RT_CLI_PATH = cli_path
    RT_SYSTEM_PROMPT = system_prompt
    RT_SESSION_ID = session_id
    RT_MAX_TOKENS = max_tokens

fn main_session_id() -> text:
    RT_SESSION_ID

# ============================================================================
# LLMResponse -> ModelResponse mapping (pure, unit-testable: no network/CLI).
# This is the piece that lets the real tool-use loop (chat.run_agent_loop)
# drive claude_api-style providers, which return tool_use blocks embedded in
# the raw wire JSON rather than a separate structured field.
# ============================================================================

fn build_model_response(resp: LLMResponse) -> ModelResponse:
    if resp.is_error:
        return new_model_text("ERROR: " + resp.error)
    val calls = parse_tool_use_blocks(resp.raw)
    if calls.len() > 0:
        return new_model_tools(resp.content, calls)
    new_model_text(resp.content)

fn _last_user_content(msgs: [Message]) -> text:
    var i = msgs.len() - 1
    while i >= 0:
        if msgs[i].role == "user":
            return msgs[i].content
        i = i - 1
    ""

fn _messages_json(msgs: [Message]) -> text:
    var items: [text] = []
    for m in msgs:
        items = items + [build_message_json(m.role, m.content)]
    ja(items)

# The real responder handed to run_agent_loop / caret_chat. Thin by design:
# all its logic (LLMResponse -> ModelResponse, tool_use parsing) is covered by
# the pure build_model_response tests; this just threads the running
# transcript + session id through provider.dispatch_send.
fn main_responder(msgs: [Message]) -> ModelResponse:
    val prompt = _last_user_content(msgs)
    val messages_json = _messages_json(msgs)
    val resp = dispatch_send(
        RT_PROVIDER, prompt, RT_MODEL, RT_API_KEY, RT_BASE_URL, RT_CLI_PATH,
        RT_SYSTEM_PROMPT, RT_SESSION_ID, 0, RT_MAX_TOKENS, messages_json
    )
    if resp.session_id != "":
        RT_SESSION_ID = resp.session_id
    build_model_response(resp)

# ============================================================================
# HTTP proxy (--server)
# ============================================================================

fn status_for_path(path: text) -> i64:
    if path == "/v1/health" or path == "/v1/models":
        return 200
    404

# Pure core of the proxy request handler: no sockets, fully unit-testable by
# passing a fake dispatch fn. Real production dispatch is _proxy_dispatch
# (provider.dispatch_send) below; tests inject a canned one.
fn proxy_handle(method: text, path: text, body: text,
                dispatch: fn(text, text) -> LLMResponse) -> (i64, text):
    if method == "POST" and (path == "/v1/chat/completions" or path == "/v1/messages"):
        val content = parse_chat_request_content(body)
        if content == "":
            return (400, build_error_response("messages required", 400))
        val model = parse_chat_request_model(body)
        val resp = dispatch(content, model)
        if resp.is_error:
            return (502, build_error_response(resp.error, 502))
        if path == "/v1/messages":
            return (200, build_anthropic_response(resp.content, resp.model, resp.stop_reason))
        return (200, build_chat_completion_response(resp.content, resp.model, resp.stop_reason))
    val body_text = handle_route(method, path, body)
    (status_for_path(path), body_text)

fn _proxy_dispatch(content: text, model: text) -> LLMResponse:
    var use_model = model
    if use_model == "":
        use_model = RT_MODEL
    val messages_json = ja([build_message_json("user", content)])
    dispatch_send(RT_PROVIDER, content, use_model, RT_API_KEY, RT_BASE_URL,
                   RT_CLI_PATH, RT_SYSTEM_PROMPT, "", 0, RT_MAX_TOKENS, messages_json)

fn _to_http_status(code: i64) -> HttpStatus:
    if code == 200: return HttpStatus.OK
    if code == 400: return HttpStatus.BadRequest
    if code == 401: return HttpStatus.Unauthorized
    if code == 404: return HttpStatus.NotFound
    if code == 413: return HttpStatus.PayloadTooLarge
    if code == 429: return HttpStatus.TooManyRequests
    if code == 502: return HttpStatus.BadGateway
    HttpStatus.InternalError

# ============================================================================
# Server hardening: bearer auth, request size cap, per-client rate limit.
# All pure/testable (guard_request takes now_ms + required_token explicitly);
# only the in-memory rate-limit table is module state (parallel arrays - this
# stdlib slice's Dict has documented quirks on erased keys, see
# .claude/memory - a small linear scan over "concurrent client count" entries
# is simpler and correctness-safe).
# ============================================================================

val MAX_BODY_BYTES: i64 = 1000000
val RATE_LIMIT_PER_MIN: i64 = 60
val RATE_WINDOW_MS: i64 = 60000

var RATE_KEYS: [text] = []
var RATE_STARTS: [i64] = []
var RATE_COUNTS: [i64] = []

fn rate_limit_reset():
    RATE_KEYS = []
    RATE_STARTS = []
    RATE_COUNTS = []

fn rate_limit_check(key: text, now_ms: i64) -> bool:
    var new_keys: [text] = []
    var new_starts: [i64] = []
    var new_counts: [i64] = []
    var allowed = true
    var found = false
    var i = 0
    while i < RATE_KEYS.len():
        if RATE_KEYS[i] == key:
            found = true
            var start = RATE_STARTS[i]
            var count = RATE_COUNTS[i]
            if now_ms - start > RATE_WINDOW_MS:
                start = now_ms
                count = 1
            elif count >= RATE_LIMIT_PER_MIN:
                allowed = false
            else:
                count = count + 1
            new_keys = new_keys + [RATE_KEYS[i]]
            new_starts = new_starts + [start]
            new_counts = new_counts + [count]
        else:
            new_keys = new_keys + [RATE_KEYS[i]]
            new_starts = new_starts + [RATE_STARTS[i]]
            new_counts = new_counts + [RATE_COUNTS[i]]
        i = i + 1
    if not found:
        new_keys = new_keys + [key]
        new_starts = new_starts + [now_ms]
        new_counts = new_counts + [1]
    RATE_KEYS = new_keys
    RATE_STARTS = new_starts
    RATE_COUNTS = new_counts
    allowed

fn required_token() -> text:
    env_get("LLM_CARET_TOKEN") ?? ""

fn bearer_ok(auth_header: text, required: text) -> bool:
    if required == "":
        return true
    val prefix = "Bearer "
    if not auth_header.starts_with(prefix):
        return false
    auth_header.substring(prefix.len()) == required

# Pure gate: auth -> size cap -> rate limit, ahead of routing. Returns
# (allowed, status_code, body); status/body only meaningful when allowed is
# false. `rate_limit_key` isolates the mutable rate-limit table from the pure
# decision so this stays unit-testable (inject a fresh key per test).
fn guard_request(auth_header: text, body: text, required: text,
                  rate_limit_key: text, now_ms: i64) -> (bool, i64, text):
    if not bearer_ok(auth_header, required):
        return (false, 401, build_error_response("missing or invalid bearer token", 401))
    if body.len() > MAX_BODY_BYTES:
        return (false, 413, build_error_response("request body too large (max " + MAX_BODY_BYTES.to_text() + " bytes)", 413))
    if not rate_limit_check(rate_limit_key, now_ms):
        return (false, 429, build_error_response("rate limit exceeded (" + RATE_LIMIT_PER_MIN.to_text() + " req/min)", 429))
    (true, 200, "")

fn _http_handle(req: HttpRequest) -> HttpResponse:
    val method = http_method_to_text(req.method)
    val guard = guard_request(req.header("Authorization"), req.body, required_token(), req.remote_addr, current_time_ms())
    var code = guard.1
    var body = guard.2
    if guard.0:
        val result = proxy_handle(method, req.path, req.body, _proxy_dispatch)
        code = result.0
        body = result.1
    # Access log: level-gated via SIMPLE_LOG (default off - std.log's
    # documented behavior), so this costs ~nothing when not enabled.
    log_info("llm_caret.server", method + " " + req.path + " " + req.remote_addr + " -> " + code.to_text())
    HttpResponse(
        status: _to_http_status(code),
        headers: [("Content-Type", "application/json; charset=utf-8")],
        body: body
    )

fn run_server(port: i64):
    var router = Router.new()
    router.mount("/v1", _http_handle)
    router.set_not_found(_http_handle)
    print "llm_caret HTTP proxy listening on 127.0.0.1:{port}"
    if required_token() != "":
        print "  auth: bearer token required (LLM_CARET_TOKEN set)"
    var server = SimpleHttpServer.new("127.0.0.1", port.to_i32(), router)
    server.start()

# ============================================================================
# Browser GUI (--gui)
# ============================================================================

fn _gui_dispatch(prompt: text) -> LLMResponse:
    val messages_json = ja([build_message_json("user", prompt)])
    dispatch_send(RT_PROVIDER, prompt, RT_MODEL, RT_API_KEY, RT_BASE_URL,
                  RT_CLI_PATH, RT_SYSTEM_PROMPT, "", 0, RT_MAX_TOKENS,
                  messages_json)

fn _gui_http_handle(method: text, path: text, request_body: text) -> (i64, text, text):
    print "llm_caret GUI request {method} {path}"
    var status = 404
    var content_type = "application/json; charset=utf-8"
    var body = caret_gui_json_error("not found")
    if method == "GET" and path == "/":
        status = 200
        content_type = "text/html; charset=utf-8"
        body = caret_gui_html()
    elif method == "POST" and path == "/api/chat":
        val prompt = caret_gui_prompt(request_body)
        if prompt == "":
            status = 400
            body = caret_gui_json_error("message required")
        else:
            val response = _gui_dispatch(prompt)
            if response.is_error:
                status = 502
                body = caret_gui_json_error(response.error)
            else:
                status = 200
                body = caret_gui_json_content(response.content)
    (status, content_type, body)

fn _gui_read_request(stream: TcpStream) -> Result<(text, text, text), text>:
    val request_line = match stream.read_line():
        Err(e): return Err("Failed to read request line: {e}")
        Ok(line): line.trim()
    val parts = request_line.split(" ")
    if parts.len() < 2:
        return Err("Malformed request line")
    val method = parts[0]
    val path = parts[1]
    if method != "GET" and method != "POST":
        return Err("Unsupported request method")

    var content_length: i64 = 0
    var header_count = 0
    loop:
        val header = match stream.read_line():
            Err(e): return Err("Failed to read request header: {e}")
            Ok(line): line.trim()
        if header == "":
            break
        header_count = header_count + 1
        if header_count > 64 or header.len() > 8192:
            return Err("Request headers too large")
        val colon = header.index_of(":")
        if colon > 0 and header.slice(0, colon).trim().to_lower() == "content-length":
            content_length = header.slice(colon + 1, header.len()).trim().to_i64() ?? -1
            if content_length < 0 or content_length > 1048576:
                return Err("Invalid Content-Length")

    var body = ""
    if content_length > 0:
        match stream.read_exact(content_length):
            Err(e): return Err("Failed to read request body: {e}")
            Ok(bytes): body = rt_bytes_to_text(bytes)
    Ok((method, path, body))

fn _gui_status_text(status: i64) -> text:
    if status == 200: return "OK"
    if status == 400: return "Bad Request"
    if status == 404: return "Not Found"
    if status == 502: return "Bad Gateway"
    "Internal Server Error"

fn _gui_write_response(stream: TcpStream, status: i64, content_type: text, body: text) -> bool:
    var response = "HTTP/1.1 {status} {_gui_status_text(status)}\r\n"
    response = response + "Content-Type: {content_type}\r\n"
    response = response + "Content-Length: {body.len()}\r\n"
    response = response + "Connection: close\r\n\r\n"
    response = response + body
    match stream.write_text(response):
        Ok(_):
            match stream.flush():
                Ok(_):
                    print "llm_caret GUI response {status} bytes={body.len()}"
                    true
                Err(e):
                    print "llm_caret GUI flush error: {e}"
                    false
        Err(e):
            print "llm_caret GUI write error: {e}"
            false

fn _gui_handle_connection(stream: TcpStream):
    match _gui_read_request(stream):
        Err(e):
            val error_body = caret_gui_json_error(e)
            val _error_written = _gui_write_response(stream, 400, "application/json; charset=utf-8", error_body)
        Ok(req):
            val response = _gui_http_handle(req.0, req.1, req.2)
            val _written = _gui_write_response(stream, response.0, response.1, response.2)
    val _closed = stream.close()

fn _caret_electron_binary() -> text:
    val app_binary = "tools/electron-shell/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron"
    if file_exists(app_binary):
        return app_binary
    val shim = "tools/electron-shell/node_modules/.bin/electron"
    if file_exists(shim):
        return shim
    ""

fn _gui_ready(host: text, port: i32, shell: text) -> bool:
    val url = "http://{host}:{port}/"
    print "llm_caret GUI ready at {url} shell={shell}"
    if shell == "electron":
        val electron = _caret_electron_binary()
        if electron == "":
            print "Error: Electron is not installed under tools/electron-shell/node_modules"
            return false
        var electron_env: {text: text} = {}
        electron_env["SIMPLE_ELECTRON_TITLE"] = "LLM Caret — Electron"
        electron_env["SIMPLE_ELECTRON_WIDTH"] = "900"
        electron_env["SIMPLE_ELECTRON_HEIGHT"] = "680"
        var electron_args = ["--no-sandbox"]
        val debug_port = env_get("LLM_CARET_ELECTRON_DEBUG_PORT") ?? ""
        if debug_port != "":
            electron_args.push("--remote-debugging-port=" + debug_port)
        electron_args.push("tools/electron-shell")
        electron_args.push("--url")
        electron_args.push(url)
        val pid = process_spawn_async_env(
            electron,
            electron_args,
            electron_env)
        if pid <= 0:
            print "Error: failed to launch Electron"
            return false
        print "llm_caret Electron launched pid={pid} url={url}"
        return true
    var opener = ""
    if file_exists("/usr/bin/open"):
        opener = "/usr/bin/open"
    elif file_exists("/usr/bin/xdg-open"):
        opener = "/usr/bin/xdg-open"
    if opener != "":
        val pid = process_spawn_async(opener, [url])
        if pid < 0:
            print "Open {url} in a browser."
    else:
        print "Open {url} in a browser."
    true

fn run_gui(port: i64, shell: text) -> i64:
    val host = "127.0.0.1"
    val addr = "{host}:{port}"
    match TcpListener.bind(addr):
        Err(e):
            print "Error: Failed to bind to {addr}: {e}"
            return 1
        Ok(listener):
            if not _gui_ready(host, port.to_i32(), shell):
                val _closed = listener.close()
                return 1
            var running = true
            while running:
                match listener.accept():
                    Err(e):
                        print "Accept error: {e}"
                        running = false
                    Ok(stream):
                        # Browsers may open speculative idle sockets. Bound request
                        # reads so one such socket cannot stall the GUI accept loop.
                        stream.set_read_timeout(1000)
                        _gui_handle_connection(stream)
    0

# ============================================================================
# Session integration
# ============================================================================

fn _resolve_workspace(args: MainArgs) -> text:
    if args.workspace_root != "":
        return args.workspace_root
    val cwd_env = env_get("PWD") ?? ""
    if cwd_env != "":
        return cwd_env
    "."

fn _build_policy(args: MainArgs, workspace_root: text) -> PermissionPolicy:
    if args.allow_all:
        return allow_all_policy(workspace_root)
    default_policy(workspace_root)

# ============================================================================
# SessionHooks wiring - the slash-command effects that need main.spl's
# runtime state (RT_* vars) or session.spl's disk I/O. Kept thin: each just
# mutates/reads RT_* or calls session.spl; chat_tui.spl's dispatch_slash owns
# all the /command parsing + control-flow decisions.
# ============================================================================

fn _slash_on_model(name: text) -> text:
    RT_MODEL = name
    "model set to " + name

fn _slash_on_provider(name: text) -> ProviderSwitchResult:
    if not is_valid_provider(name):
        return ProviderSwitchResult(
            accepted: false,
            message: "unknown provider: " + name + " (valid: " +
                list_providers().join(", ") + ")",
            provider: RT_PROVIDER,
            model: RT_MODEL
        )
    RT_PROVIDER = name
    RT_MODEL = _default_model(name)
    RT_API_KEY = _effective_api_key(name)
    RT_BASE_URL = _effective_base_url(name)
    RT_CLI_PATH = _effective_cli_path(name)
    RT_SESSION_ID = ""
    ProviderSwitchResult(
        accepted: true,
        message: "provider set to " + name,
        provider: name,
        model: RT_MODEL
    )

fn _slash_on_sessions() -> text:
    val ids = list_session_ids()
    if ids.len() == 0:
        return "No saved sessions."
    "Sessions:\n  " + ids.join("\n  ")

fn _slash_on_new() -> text:
    RT_SESSION_ID = ""
    gen_session_id()

fn _slash_on_resume(id: text) -> SessionResumeResult:
    val loaded = load_session(id)
    match loaded:
        Some(sess):
            if not is_valid_provider(sess.provider):
                return SessionResumeResult(
                    found: false,
                    message: "saved session '" + id +
                        "' has unknown provider '" + sess.provider + "'",
                    messages: [], session_id: "",
                    provider: "", model: ""
                )
            RT_PROVIDER = sess.provider
            RT_MODEL = if sess.model == "":
                _default_model(sess.provider)
            else:
                sess.model
            RT_API_KEY = _effective_api_key(RT_PROVIDER)
            RT_BASE_URL = _effective_base_url(RT_PROVIDER)
            RT_CLI_PATH = _effective_cli_path(RT_PROVIDER)
            RT_SESSION_ID = sess.provider_session_id
            return SessionResumeResult(
                found: true,
                message: "resumed session " + id,
                messages: sess.messages,
                session_id: sess.id,
                provider: RT_PROVIDER,
                model: RT_MODEL
            )
        nil:
            return SessionResumeResult(
                found: false,
                message: "no saved session '" + id + "'",
                messages: [], session_id: "",
                provider: "", model: ""
            )

fn _on_persist(session_id: text, conv: [Message]):
    save_session(Session(
        id: session_id, provider: RT_PROVIDER, model: RT_MODEL,
        provider_session_id: RT_SESSION_ID, messages: conv,
        updated_at_ms: current_time_ms()
    ))

fn _build_session_hooks(active_session_id: text) -> SessionHooks:
    SessionHooks(
        session_id: active_session_id,
        on_model: _slash_on_model,
        on_provider: _slash_on_provider,
        on_sessions: _slash_on_sessions,
        on_new: _slash_on_new,
        on_resume: _slash_on_resume,
        on_persist: _on_persist
    )

# ============================================================================
# main()
# ============================================================================

fn main() -> i64:
    val raw_args = get_cli_args()
    val args = parse_main_args(raw_args)
    if args.help:
        print_help()
        return 0
    if args.unknown != "":
        print "Error: unknown option '{args.unknown}'"
        print ""
        print_help()
        return 2

    if args.config_path != "":
        if not file_exists(args.config_path):
            print "Error: config file not found: {args.config_path}"
            return 2
        val err = load_config(args.config_path)
        if err != "":
            print "Error: {err}"
            return 2

    var provider = _effective_provider(args)
    if not is_valid_provider(provider):
        print "Error: unknown provider '{provider}'"
        print "Valid providers: {list_providers().join(", ")}"
        return 2

    var model = _effective_model(provider, args)
    val workspace_root = _resolve_workspace(args)
    val policy = _build_policy(args, workspace_root)

    if args.server_mode:
        val api_key = _effective_api_key(provider)
        val base_url = _effective_base_url(provider)
        val cli_path = _effective_cli_path(provider)
        main_configure(provider, model, api_key, base_url, cli_path, args.system_prompt, "", 0)
        run_server(_effective_port(args))
        return 0

    var active_session_id = gen_session_id()
    var provider_session_id = ""
    var conv: [Message] = []
    if args.resume_id != "":
        val loaded = load_session(args.resume_id)
        match loaded:
            Some(sess):
                val backend = resolve_resume_backend(
                    args.provider, args.model, sess.provider, sess.model
                )
                provider = backend.provider
                model = backend.model
                if not is_valid_provider(provider):
                    print "Error: saved session has unknown provider '{provider}'"
                    return 2
                active_session_id = sess.id
                if backend.reuse_provider_session:
                    provider_session_id = sess.provider_session_id
                conv = sess.messages
            nil:
                print "Error: no saved session '{args.resume_id}'"
                return 2

    val api_key = _effective_api_key(provider)
    val base_url = _effective_base_url(provider)
    val cli_path = _effective_cli_path(provider)
    main_configure(provider, model, api_key, base_url, cli_path, args.system_prompt, provider_session_id, 0)

    if args.ui_mode == "metal_gui":
        if provider != "dummy":
            print "Error: --metal-gui currently requires --provider dummy"
            return 2
        return run_caret_metal_gui(args.prompt)

    if args.prompt != "":
        val response = main_responder([Message(role: "user", content: args.prompt)])
        print response.text
        if response.text.starts_with("ERROR: "):
            return 1
        return 0

    if args.ui_mode == "gui":
        return run_gui(_effective_port(args), "browser")

    if args.ui_mode == "electron":
        return run_gui(_effective_port(args), "electron")

    val status_text = "provider=" + provider + " model=" + model + " session=" + active_session_id
    val ui = make_chat_tui_with_status("llm_caret - {provider}", status_text)
    val hooks = _build_session_hooks(active_session_id)
    caret_chat(ui, policy, main_responder, args.ui_mode, hooks, conv)
    0
