# LLM Caret - CLI Entry Point
#
# Wires the already-production-grade library (config.spl, provider.spl,
# tools.spl, chat.spl, chat_tui.spl, server.spl) into a runnable command:
#
#   bin/simple run src/app/llm_caret/main.spl [options]
#
# Options:
#   --provider <name>        dummy | claude_cli | opencode_cli | claude_api | openai |
#                             openai_compat | local_torch (default: config file's
#                             defaults.provider, else claude_cli)
#   --model <name>           model id (default: provider's configured model)
#   --config <path>          load an llm_caret.sdn config file (config.spl)
#   --system <prompt>        system prompt
#   --resume <session_id>    resume a persisted session (see session.spl)
#   --workspace <path>       tool sandbox root for bash/read_file/write_file/
#                             list_dir/glob (default: cwd)
#   --dangerously-allow-all  auto-approve mutating tools (bash/write_file)
#   --plain                  force the plain (non-TUI) renderer
#   --tui                    force the full-screen TUI renderer
#   --gui                    launch the browser GUI renderer
#   --electron               launch the GUI in the canonical Electron shell
#   --metal-gui              launch pure Simple Web/Draw IR/Engine2D Metal GUI
#   --prompt <text>          send one prompt, print the response, and exit
#   --server                 run the HTTP proxy (server.spl) instead of chat
#   --port <n>                proxy port (default 8317, or $LLM_CARET_PORT)
#   -h / --help              show this help
#
# Sessions persist to ~/.llm_caret/sessions/<id>.json (session.spl) so
# --resume restores a prior transcript + provider session id across runs.

use app.io.mod.{env_get, file_exists, current_time_ms, process_spawn_async,
    process_spawn_async_env}
use std.nogc_sync_mut.cli.cli_util.{get_cli_args}
use std.nogc_sync_mut.http_server.{SimpleHttpServer, Router, HttpRequest, HttpResponse,
    HttpStatus, http_method_to_text}
use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.log.{info as log_info}

extern fn rt_bytes_to_text(data: [u8]) -> text

use app.llm_caret.config.{load_config, config_loaded,
    config_default_provider, config_claude_cli_path, config_claude_cli_model,
    config_opencode_cli_path, config_opencode_cli_model,
    config_claude_api_key, config_claude_api_base_url, config_claude_api_model,
    config_openai_api_key, config_openai_base_url, config_openai_model,
    config_compat_base_url, config_compat_model, config_compat_api_key}
use app.llm_caret.provider.{LLMResponse, dispatch_send, is_valid_provider, list_providers}
use app.llm_caret.tools.{PermissionPolicy, ModelResponse,
    default_policy, allow_all_policy, parse_tool_use_blocks, new_model_text, new_model_tools}
use app.llm_caret.types.{Message}
use app.llm_caret.chat_tui.{
    make_chat_tui_with_status,
    caret_chat,
    ProviderSwitchResult,
    SessionResumeResult,
    SessionHooks
}
use app.llm_caret.json_helpers.{build_message_json, ja}
use app.llm_caret.server.{handle_route, build_error_response,
    build_chat_completion_response, build_anthropic_response,
    parse_chat_request_content, parse_chat_request_model}
use app.llm_caret.session.{Session, save_session, load_session, list_session_ids, gen_session_id}
use app.llm_caret.gui.{caret_gui_html, caret_gui_prompt,
    caret_gui_json_content, caret_gui_json_error}
use app.llm_caret.gui_metal.{run_caret_metal_gui}

# ============================================================================
# Argument parsing (pure - unit-testable without a live process)
# ============================================================================

struct MainArgs:
    provider: text
    model: text
    config_path: text
    system_prompt: text
    resume_id: text
    workspace_root: text
    prompt: text
    allow_all: bool
    ui_mode: text        # "auto" | "tui" | "plain"
    server_mode: bool
    port: i64
    help: bool
    unknown: text        # first unrecognized --flag (empty if none)

fn parse_main_args(args: [text]) -> MainArgs:
    var provider = ""
    var model = ""
    var config_path = ""
    var system_prompt = ""
    var resume_id = ""
    var workspace_root = ""
    var prompt = ""
    var allow_all = false
    var ui_mode = "auto"
    var server_mode = false
    var port: i64 = 0
    var help = false
    var unknown = ""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "-h" or arg == "--help":
            help = true
        elif arg == "--provider" and i + 1 < args.len():
            provider = args[i + 1]
            i = i + 1
        elif arg.starts_with("--provider="):
            provider = arg.substring(11)
        elif arg == "--model" and i + 1 < args.len():
            model = args[i + 1]
            i = i + 1
        elif arg.starts_with("--model="):
            model = arg.substring(8)
        elif arg == "--config" and i + 1 < args.len():
            config_path = args[i + 1]
            i = i + 1
        elif arg.starts_with("--config="):
            config_path = arg.substring(9)
        elif arg == "--system" and i + 1 < args.len():
            system_prompt = args[i + 1]
            i = i + 1
        elif arg.starts_with("--system="):
            system_prompt = arg.substring(9)
        elif arg == "--resume" and i + 1 < args.len():
            resume_id = args[i + 1]
            i = i + 1
        elif arg.starts_with("--resume="):
            resume_id = arg.substring(9)
        elif arg == "--workspace" and i + 1 < args.len():
            workspace_root = args[i + 1]
            i = i + 1
        elif arg.starts_with("--workspace="):
            workspace_root = arg.substring(12)
        elif arg == "--prompt" and i + 1 < args.len():
            prompt = args[i + 1]
            i = i + 1
        elif arg.starts_with("--prompt="):
            prompt = arg.substring(9)
        elif arg == "--dangerously-allow-all":
            allow_all = true
        elif arg == "--plain":
            ui_mode = "plain"
        elif arg == "--tui":
            ui_mode = "tui"
        elif arg == "--gui":
            ui_mode = "gui"
        elif arg == "--electron":
            ui_mode = "electron"
        elif arg == "--metal-gui":
            ui_mode = "metal_gui"
        elif arg == "--server":
            server_mode = true
        elif arg == "--port" and i + 1 < args.len():
            port = int(args[i + 1]) ?? 0
            i = i + 1
        elif arg.starts_with("--port="):
            port = int(arg.substring(7)) ?? 0
        elif arg.starts_with("--") and unknown == "":
            unknown = arg
        i = i + 1
    MainArgs(
        provider: provider, model: model, config_path: config_path,
        system_prompt: system_prompt, resume_id: resume_id,
        workspace_root: workspace_root, prompt: prompt, allow_all: allow_all,
        ui_mode: ui_mode, server_mode: server_mode, port: port,
        help: help, unknown: unknown
    )

