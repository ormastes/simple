# LLM Caret typed infrastructure compatibility capsule.
#
# This module owns pure validation/conversion plus the direct-argv execution
# seam. Provider HTTP and authentication remain in ITF or canonical CLIs.

use app.io.mod.{process_run_bounded}

val INFRA_MAX_ARGS: i64 = 128
val INFRA_MAX_ARG_BYTES: i64 = 8192
val INFRA_TIMEOUT_MS: i64 = 120000
val INFRA_OUTPUT_BYTES: i64 = 30000

struct InfraPlan:
    family: text
    provider: text
    operation: text
    safety: text
    adapter: text
    transport: text
    program: text
    args: [text]
    format: text
    supported: bool
    error: text
    capability_json: text

struct InfraExecution:
    plan: InfraPlan
    stdout: text
    stderr: text
    exit_code: i64
    success: bool

fn _q() -> text:
    "\""

fn _json_escape(s: text) -> text:
    var out = ""
    var i: i64 = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\"":
            out = out + "\\\""
        elif ch == "\n":
            out = out + "\\n"
        elif ch == "\r":
            out = out + "\\r"
        elif ch == "\t":
            out = out + "\\t"
        else:
            out = out + ch
        i = i + 1
    out

fn _json_unescape(s: text) -> text:
    var out = ""
    var i: i64 = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\" and i + 1 < s.len():
            val nx = s[i + 1]
            if nx == "n":
                out = out + "\n"
            elif nx == "r":
                out = out + "\r"
            elif nx == "t":
                out = out + "\t"
            elif nx == "\"":
                out = out + "\""
            elif nx == "\\":
                out = out + "\\"
            elif nx == "/":
                out = out + "/"
            else:
                out = out + nx
            i = i + 2
        else:
            out = out + ch
            i = i + 1
    out

fn _json_get_str(json: text, key: text) -> text:
    val marker = _q() + key + _q() + ":"
    val idx = json.index_of(marker) ?? -1
    if idx < 0:
        return ""
    val rest = json.substring(idx + marker.len()).trim()
    if not rest.starts_with(_q()):
        return ""
    val value = rest.substring(1)
    var end: i64 = 0
    var escaped = false
    while end < value.len():
        val ch = value[end]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return _json_unescape(value.substring(0, end))
        end = end + 1
    ""

fn _split_args(raw: text) -> [text]:
    if raw == "":
        return []
    var args: [text] = []
    for line in raw.split("\n"):
        if line != "":
            args.push(line)
    args

fn _contains(items: text, item: text) -> bool:
    items.contains("|" + item + "|")

fn _tail(operation: text) -> text:
    val parts = operation.split(".")
    if parts.len() == 0:
        return operation
    parts[parts.len() - 1]

fn _valid_safety(safety: text) -> bool:
    safety == "read" or safety == "write" or safety == "destructive" or safety == "auth"

fn infra_safety_class(family: text, input: text) -> text:
    val operation = _json_get_str(input, "operation")
    if operation == "capabilities" or operation == "capability":
        return "read"
    if operation == "raw":
        val raw_safety = _json_get_str(input, "raw_safety")
        if _valid_safety(raw_safety):
            return raw_safety
        return "invalid"
    if family == "storage" and operation.starts_with("s3api."):
        val api_action = _tail(operation)
        if api_action.starts_with("list-") or api_action.starts_with("get-") or api_action.starts_with("head-") or api_action.starts_with("describe-"):
            return "read"
        if api_action.starts_with("delete-") or api_action.starts_with("abort-"):
            return "destructive"
        if api_action.starts_with("put-") or api_action.starts_with("create-") or api_action.starts_with("upload-") or api_action.starts_with("copy-") or api_action.starts_with("complete-") or api_action.starts_with("restore-"):
            return "write"
        return "invalid"
    val action = _tail(operation)
    if family == "repo" and action == "watch":
        return "read"
    if family == "repo" and (action == "sync" or action == "run"):
        return "write"
    if _contains("|list|get|view|search|stat|status|folders|messages|download|diff|history|ls|cp|sync|presign|", action):
        # cp/sync are refined below for storage.
        if family == "storage" and (action == "cp" or action == "sync"):
            return "write"
        return "read"
    if _contains("|create|update|edit|comment|post|put|upload|send|mark|approve|review|enable|rerun|clone|fork|checkout|reopen|transition|watch|stop|", action):
        return "write"
    if _contains("|delete|remove|rm|merge|close|cancel|disable|move|mv|overwrite|unapprove|", action):
        return "destructive"
    if _contains("|auth|login|logout|credential|", action):
        return "auth"
    "invalid"

fn _empty_plan(family: text, provider: text, operation: text, format: text, error: text) -> InfraPlan:
    InfraPlan(
        family: family,
        provider: provider,
        operation: operation,
        safety: "invalid",
        adapter: "",
        transport: "",
        program: "",
        args: [],
        format: format,
        supported: false,
        error: error,
        capability_json: ""
    )

fn _plan(family: text, provider: text, operation: text, safety: text, adapter: text, transport: text, program: text, args: [text], format: text) -> InfraPlan:
    InfraPlan(
        family: family,
        provider: provider,
        operation: operation,
        safety: safety,
        adapter: adapter,
        transport: transport,
        program: program,
        args: args,
        format: format,
        supported: true,
        error: "",
        capability_json: ""
    )

fn _capability_plan(family: text, provider: text, format: text, body: text) -> InfraPlan:
    InfraPlan(
        family: family,
        provider: provider,
        operation: "capabilities",
        safety: "read",
        adapter: "static_registry",
        transport: "none",
        program: "",
        args: [],
        format: format,
        supported: true,
        error: "",
        capability_json: body
    )

fn _cap_row(provider: text, route: text, operations: text, notes: text) -> text:
    "{\"provider\":\"" + _json_escape(provider) + "\",\"route\":\"" + _json_escape(route) + "\",\"operations\":\"" + _json_escape(operations) + "\",\"notes\":\"" + _json_escape(notes) + "\"}"

fn _capabilities(family: text, provider: text) -> text:
    var rows: [text] = []
    if family == "repo":
        if provider == "" or provider == "github":
            rows.push(_cap_row("github", "gh", "repo.*,pr.*,issue.*,workflow.*,run.*,raw", "native gh surface; raw accepts gh api argv with explicit safety"))
        if provider == "" or provider == "bitbucket":
            rows.push(_cap_row("bitbucket", "bin/simple itf bb", "pr.view,pr.create,pr.comment.list,pr.comment.create,pr.approve,pr.merge,pr.status,raw", "mapped subset; current ITF pure transport is unproven and fails closed; GitHub workflows are unsupported"))
    elif family == "task":
        if provider == "" or provider == "jira":
            rows.push(_cap_row("jira", "acli jira", "workitem.view,workitem.search,workitem.create,workitem.edit,workitem.transition,workitem.delete,raw", "JQL/workflows/custom fields stay provider-native"))
        if provider == "" or provider == "github":
            rows.push(_cap_row("github", "gh issue", "issue.list,issue.view,issue.create,issue.edit,issue.comment,issue.close,issue.reopen,raw", "repository issue subset"))
    elif family == "storage":
        if provider == "" or provider == "s3":
            rows.push(_cap_row("s3", "aws", "s3.ls,s3.cp,s3.mv,s3.rm,s3.sync,s3api.*,raw", "native AWS CLI contract"))
        if provider == "" or provider == "minio":
            rows.push(_cap_row("minio", "aws --endpoint-url", "s3.ls,s3.cp,s3.mv,s3.rm,s3.sync,s3api.*,raw", "S3-compatible endpoint; endpoint is required"))
    elif family == "mail":
        if provider == "" or provider == "gmail":
            rows.push(_cap_row("gmail", "gws gmail", "messages.*,threads.*,labels.*,drafts.*,attachments.get,history.list,watch,stop,raw", "Gmail resource model; gws transport is provisional"))
        if provider == "" or provider == "outlook":
            rows.push(_cap_row("outlook", "bin/simple itf outlook", "folders.list,messages.list,messages.get,messages.move,messages.mark,raw", "Graph subset; current ITF pure transport is unproven and fails closed; labels/drafts/send are unsupported"))
    elif family == "wiki":
        if provider == "" or provider == "confluence":
            rows.push(_cap_row("confluence", "bin/simple itf wiki", "page.list,page.get,page.create,page.update,page.delete,page.search,raw", "current ITF pure transport is unproven and fails closed; storage-to-Markdown conversion may be lossy"))
        if provider == "" or provider == "github":
            rows.push(_cap_row("github", "git reads; bin/simple itf github-wiki writes", "page.list,page.get,page.create,page.update,page.delete,page.search,raw", "Markdown files and git revisions"))
    if rows.len() == 0:
        return ""
    "{\"family\":\"" + _json_escape(family) + "\",\"status\":\"ok\",\"providers\":[" + rows.join(",") + "]}"

fn _has_dotdot(path: text) -> bool:
    for part in path.split("/"):
        if part == "..":
            return true
    false

fn _path_error(root: text, path: text) -> text:
    if path == "" or path == "-" or path.starts_with("s3://"):
        return ""
    if _has_dotdot(path):
        return "path traversal is not allowed: " + path
    var clean_root = root
    while clean_root.len() > 1 and clean_root.ends_with("/"):
        clean_root = clean_root.substring(0, clean_root.len() - 1)
    var full = path
    if not full.starts_with("/"):
        full = clean_root + "/" + full
    if full == clean_root or full.starts_with(clean_root + "/"):
        return ""
    "path escapes workspace root: " + path

fn _validate_paths(root: text, args: [text]) -> text:
    for candidate in args:
        if not candidate.starts_with("s3://") and not candidate.starts_with("http://") and not candidate.starts_with("https://"):
            if candidate.starts_with("/") or _has_dotdot(candidate):
                val generic_error = _path_error(root, candidate)
                if generic_error != "":
                    return generic_error
    var i: i64 = 0
    while i < args.len():
        val arg = args[i]
        if _contains("|--file|--out|--output|--from-file|--repo-path|--body-file|", arg):
            if i + 1 >= args.len():
                return arg + " requires a workspace path"
            val err = _path_error(root, args[i + 1])
            if err != "":
                return err
            i = i + 1
        i = i + 1
    ""

fn _validate_common(family: text, provider: text, operation: text, format: text, args: [text], input: text, root: text) -> text:
    if not _contains("|repo|task|storage|mail|wiki|", family):
        return "unknown infrastructure family: " + family
    if operation == "":
        return "missing required 'operation'"
    if format != "human" and format != "json" and format != "ndjson":
        return "format must be human, json, or ndjson"
    if operation != "capabilities" and operation != "capability" and provider == "":
        return "missing required 'provider'"
    if args.len() > INFRA_MAX_ARGS:
        return "too many argv items"
    val secret_flags = ["--token", "--password", "--secret", "--api-key", "--access-key", "--secret-key", "--client-secret"]
    for arg in args:
        if arg.len() > INFRA_MAX_ARG_BYTES:
            return "argv item exceeds size limit"
        if arg.contains("\r"):
            return "carriage returns are not allowed in argv"
        val lower_arg = arg.lower()
        for flag in secret_flags:
            if lower_arg == flag or lower_arg.starts_with(flag + "="):
                return "credentials must use the provider credential store or environment, not argv"
        if lower_arg.starts_with("authorization:") or lower_arg.starts_with("bearer ") or lower_arg.contains("access_token") or lower_arg.contains("refresh_token") or lower_arg.contains("client_secret"):
            return "credentials must use the provider credential store or environment, not argv"
        if family == "mail" and _contains("|--body|--raw-body|--mime|", lower_arg):
            return "mail body/MIME content must use a provider file or stdin route, not argv"
    val compact_input = input.lower().replace(" ", "").replace("\t", "").replace("\r", "").replace("\n", "")
    if compact_input.contains("\"token\":") or compact_input.contains("\"password\":") or compact_input.contains("\"secret\":") or compact_input.contains("\"authorization\":") or compact_input.contains("\"access_token\":") or compact_input.contains("\"refresh_token\":") or compact_input.contains("\"client_secret\":"):
        return "credentials must use the provider credential store or environment, not tool input"
    _validate_paths(root, args)

fn _machine_args(format: text, args: [text]) -> [text]:
    if (format == "json" or format == "ndjson") and not args.contains("--json"):
        return args + ["--json"]
    args

fn _flag_value(args: [text], flag: text) -> text:
    var i: i64 = 0
    while i + 1 < args.len():
        if args[i] == flag:
            return args[i + 1]
        i = i + 1
    ""

fn _wiki_page_safe(page: text) -> bool:
    page != "" and not page.starts_with("/") and not page.contains("\\") and not _has_dotdot(page) and page.ends_with(".md")

fn _repo_plan(provider: text, operation: text, args: [text], format: text) -> InfraPlan:
    val safety = infra_safety_class("repo", "{\"operation\":\"" + operation + "\"}")
    if provider == "github":
        if operation == "raw":
            return _plan("repo", provider, operation, "invalid", "github_cli", "gh", "gh", args, format)
        if _contains("|repo.view|repo.list|repo.clone|repo.create|repo.fork|repo.sync|pr.list|pr.view|pr.create|pr.checkout|pr.diff|pr.status|pr.review|pr.merge|pr.close|pr.reopen|issue.list|issue.view|issue.create|issue.edit|issue.comment|issue.close|issue.reopen|workflow.list|workflow.view|workflow.run|workflow.enable|workflow.disable|run.list|run.view|run.watch|run.download|run.rerun|run.cancel|run.delete|", operation):
            return _plan("repo", provider, operation, safety, "github_cli", "gh", "gh", operation.split(".") + _machine_args(format, args), format)
    elif provider == "bitbucket":
        var prefix: [text] = []
        if operation == "pr.view" or operation == "pr.create":
            prefix = ["itf", "bb", "pr", _tail(operation)]
        elif operation == "pr.comment.list":
            prefix = ["itf", "bb", "comment", "list"]
        elif operation == "pr.comment.create":
            prefix = ["itf", "bb", "comment", "post"]
        elif operation == "pr.approve":
            prefix = ["itf", "bb", "approve"]
        elif operation == "pr.merge":
            prefix = ["itf", "bb", "merge"]
        elif operation == "pr.status":
            prefix = ["itf", "bb", "status"]
        elif operation == "raw":
            prefix = ["itf", "bb"]
        if prefix.len() > 0:
            return _plan("repo", provider, operation, safety, "itf_bitbucket", "simple_itf", "bin/simple", prefix + _machine_args(format, args), format)
    _empty_plan("repo", provider, operation, format, "unsupported repository capability: " + provider + "/" + operation)

fn _task_plan(provider: text, operation: text, args: [text], format: text) -> InfraPlan:
    val safety = infra_safety_class("task", "{\"operation\":\"" + operation + "\"}")
    if provider == "jira":
        if operation == "raw":
            return _plan("task", provider, operation, safety, "jira_acli", "acli", "acli", ["jira"] + args, format)
        if _contains("|workitem.view|workitem.search|workitem.create|workitem.edit|workitem.transition|workitem.delete|", operation):
            return _plan("task", provider, operation, safety, "jira_acli", "acli", "acli", ["jira"] + operation.split(".") + _machine_args(format, args), format)
    elif provider == "github":
        if operation == "raw":
            return _plan("task", provider, operation, safety, "github_cli", "gh", "gh", ["issue"] + args, format)
        if _contains("|issue.list|issue.view|issue.create|issue.edit|issue.comment|issue.close|issue.reopen|", operation):
            return _plan("task", provider, operation, safety, "github_cli", "gh", "gh", operation.split(".") + _machine_args(format, args), format)
    _empty_plan("task", provider, operation, format, "unsupported task capability: " + provider + "/" + operation)

fn _storage_plan(provider: text, operation: text, args: [text], format: text, endpoint: text) -> InfraPlan:
    val safety = infra_safety_class("storage", "{\"operation\":\"" + operation + "\"}")
    if provider != "s3" and provider != "minio":
        return _empty_plan("storage", provider, operation, format, "unsupported storage provider: " + provider)
    var prefix: [text] = []
    if provider == "minio":
        if endpoint == "":
            return _empty_plan("storage", provider, operation, format, "MinIO requires 'endpoint'")
        if endpoint.contains("@") or endpoint.contains("\n"):
            return _empty_plan("storage", provider, operation, format, "endpoint must not contain credentials or control characters")
        prefix = ["--endpoint-url", endpoint]
    if operation == "raw":
        return _plan("storage", provider, operation, safety, "aws_s3_cli", "aws_cli", "aws", prefix + args, format)
    val parts = operation.split(".")
    if parts.len() != 2:
        return _empty_plan("storage", provider, operation, format, "storage operation must be s3.<action> or s3api.<action>")
    if parts[0] == "s3" and not _contains("|ls|cp|mv|rm|sync|presign|", parts[1]):
        return _empty_plan("storage", provider, operation, format, "unsupported aws s3 action: " + parts[1])
    if parts[0] != "s3" and parts[0] != "s3api":
        return _empty_plan("storage", provider, operation, format, "unsupported storage group: " + parts[0])
    _plan("storage", provider, operation, safety, "aws_s3_cli", "aws_cli", "aws", prefix + parts + args, format)

fn _mail_plan(provider: text, operation: text, args: [text], format: text) -> InfraPlan:
    val safety = infra_safety_class("mail", "{\"operation\":\"" + operation + "\"}")
    if provider == "gmail":
        if operation == "raw":
            return _plan("mail", provider, operation, safety, "gmail_gws", "gws_cli_provisional", "gws", ["gmail"] + args, format)
        val parts = operation.split(".")
        if parts.len() == 2 and _contains("|messages|threads|labels|drafts|history|", parts[0]):
            return _plan("mail", provider, operation, safety, "gmail_gws", "gws_cli_provisional", "gws", ["gmail", "users", parts[0], parts[1]] + args, format)
        if operation == "attachments.get":
            return _plan("mail", provider, operation, safety, "gmail_gws", "gws_cli_provisional", "gws", ["gmail", "users", "messages", "attachments", "get"] + args, format)
        if operation == "watch" or operation == "stop":
            return _plan("mail", provider, operation, safety, "gmail_gws", "gws_cli_provisional", "gws", ["gmail", "users", operation] + args, format)
    elif provider == "outlook":
        var action = ""
        if operation == "folders.list": action = "folders"
        elif operation == "messages.list": action = "messages"
        elif operation == "messages.get": action = "get"
        elif operation == "messages.move": action = "move"
        elif operation == "messages.mark": action = "mark"
        if operation == "raw":
            return _plan("mail", provider, operation, safety, "itf_outlook", "simple_itf", "bin/simple", ["itf", "outlook"] + args, format)
        if action != "":
            return _plan("mail", provider, operation, safety, "itf_outlook", "simple_itf", "bin/simple", ["itf", "outlook", action] + _machine_args(format, args), format)
    _empty_plan("mail", provider, operation, format, "unsupported mail capability: " + provider + "/" + operation)

fn _wiki_plan(provider: text, operation: text, args: [text], format: text) -> InfraPlan:
    val safety = infra_safety_class("wiki", "{\"operation\":\"" + operation + "\"}")
    var command = ""
    if operation == "page.list": command = "list"
    elif operation == "page.get": command = "view"
    elif operation == "page.create": command = "create"
    elif operation == "page.update": command = "edit"
    elif operation == "page.delete": command = "delete"
    elif operation == "page.search": command = "search"
    if provider == "confluence":
        if operation == "raw":
            return _plan("wiki", provider, operation, safety, "itf_confluence", "simple_itf", "bin/simple", ["itf", "wiki"] + args, format)
        if command != "":
            return _plan("wiki", provider, operation, safety, "itf_confluence", "simple_itf", "bin/simple", ["itf", "wiki", command] + _machine_args(format, args), format)
    elif provider == "github":
        if operation == "page.list" or operation == "page.get" or operation == "page.search":
            val repo = _flag_value(args, "--repo-path")
            if repo == "":
                return _empty_plan("wiki", provider, operation, format, "--repo-path is required")
            if operation == "page.list":
                if args.len() != 2:
                    return _empty_plan("wiki", provider, operation, format, "page.list accepts only --repo-path")
                return _plan("wiki", provider, operation, safety, "github_wiki_git", "git", "git", ["-C", repo, "ls-files", "--", "*.md"], format)
            if operation == "page.get":
                val page = _flag_value(args, "--page")
                if args.len() != 4 or not _wiki_page_safe(page):
                    return _empty_plan("wiki", provider, operation, format, "page.get requires a safe relative --page .md path")
                return _plan("wiki", provider, operation, safety, "github_wiki_git", "git", "git", ["-C", repo, "show", "HEAD:" + page], format)
            val query = _flag_value(args, "--query")
            if args.len() != 4 or query == "":
                return _empty_plan("wiki", provider, operation, format, "page.search requires --query")
            return _plan("wiki", provider, operation, safety, "github_wiki_git", "git", "git", ["-C", repo, "grep", "-n", "-e", query, "--", "*.md"], format)
        if operation == "raw":
            return _plan("wiki", provider, operation, safety, "itf_github_wiki", "git", "bin/simple", ["itf", "github-wiki", "raw"] + args, format)
        if command != "":
            return _plan("wiki", provider, operation, safety, "itf_github_wiki", "git", "bin/simple", ["itf", "github-wiki", command] + _machine_args(format, args), format)
    _empty_plan("wiki", provider, operation, format, "unsupported wiki capability: " + provider + "/" + operation)

fn plan_infra_call(family: text, input: text, workspace_root: text) -> InfraPlan:
    val provider = _json_get_str(input, "provider").lower()
    val operation = _json_get_str(input, "operation").lower()
    var format = _json_get_str(input, "format").lower()
    if format == "":
        format = "human"
    val args = _split_args(_json_get_str(input, "args"))
    val common_error = _validate_common(family, provider, operation, format, args, input, workspace_root)
    if common_error != "":
        return _empty_plan(family, provider, operation, format, common_error)
    if operation == "capabilities" or operation == "capability":
        val body = _capabilities(family, provider)
        if body == "":
            return _empty_plan(family, provider, operation, format, "unknown provider for " + family + ": " + provider)
        return _capability_plan(family, provider, format, body)
    var plan = _empty_plan(family, provider, operation, format, "unknown infrastructure family")
    if family == "repo":
        plan = _repo_plan(provider, operation, args, format)
    elif family == "task":
        plan = _task_plan(provider, operation, args, format)
    elif family == "storage":
        plan = _storage_plan(provider, operation, args, format, _json_get_str(input, "endpoint"))
    elif family == "mail":
        plan = _mail_plan(provider, operation, args, format)
    elif family == "wiki":
        plan = _wiki_plan(provider, operation, args, format)
    if plan.supported and operation == "raw":
        val raw_safety = _json_get_str(input, "raw_safety")
        if not _valid_safety(raw_safety):
            return _empty_plan(family, provider, operation, format, "raw requires raw_safety=read|write|destructive|auth")
        plan.safety = raw_safety
    elif plan.supported and plan.safety == "invalid":
        return _empty_plan(family, provider, operation, format, "operation has no safety classification: " + operation)
    plan

fn _bounded_runner(program: text, args: [text]) -> (text, text, i64):
    process_run_bounded(program, args, INFRA_TIMEOUT_MS, INFRA_OUTPUT_BYTES)

fn execute_infra_plan_with(plan: InfraPlan, runner: fn(text, [text]) -> (text, text, i64)) -> InfraExecution:
    if not plan.supported:
        return InfraExecution(plan: plan, stdout: "", stderr: plan.error, exit_code: 2, success: false)
    if plan.program == "":
        return InfraExecution(plan: plan, stdout: plan.capability_json, stderr: "", exit_code: 0, success: true)
    val (stdout, stderr, code) = runner(plan.program, plan.args)
    InfraExecution(plan: plan, stdout: stdout ?? "", stderr: stderr ?? "", exit_code: code, success: code == 0)

fn execute_infra_plan(plan: InfraPlan) -> InfraExecution:
    execute_infra_plan_with(plan, _bounded_runner)

fn render_infra_execution(result: InfraExecution) -> text:
    val plan = result.plan
    if plan.format == "json" or plan.format == "ndjson":
        val status = if result.success: "ok" else: "error"
        return "{\"family\":\"" + _json_escape(plan.family) + "\",\"provider\":\"" + _json_escape(plan.provider) + "\",\"operation\":\"" + _json_escape(plan.operation) + "\",\"safety\":\"" + _json_escape(plan.safety) + "\",\"adapter\":\"" + _json_escape(plan.adapter) + "\",\"transport\":\"" + _json_escape(plan.transport) + "\",\"status\":\"" + status + "\",\"exit_code\":" + result.exit_code.to_text() + ",\"stdout\":\"" + _json_escape(result.stdout) + "\",\"stderr\":\"" + _json_escape(result.stderr) + "\"}"
    if plan.operation == "capabilities" or plan.operation == "capability":
        return result.stdout
    var lines: [text] = [
        "route: " + plan.family + "/" + plan.provider + "/" + plan.operation,
        "safety: " + plan.safety,
        "adapter: " + plan.adapter,
        "transport: " + plan.transport,
        "exit_code: " + result.exit_code.to_text()
    ]
    if result.stdout != "":
        lines.push(result.stdout)
    if result.stderr != "":
        lines.push("[stderr]\n" + result.stderr)
    lines.join("\n")

fn execute_infra_call(family: text, input: text, workspace_root: text) -> (bool, text):
    val result = execute_infra_plan(plan_infra_call(family, input, workspace_root))
    (result.success, render_infra_execution(result))
