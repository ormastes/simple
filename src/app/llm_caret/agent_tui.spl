# LLM Caret - Agent handoff TUI rendering

use app.llm_caret.agent_plan.{AgentLaunchPlan, AgentCapabilitySet, AgentTeamMessage}
use app.llm_caret.agent_mailbox.{AgentTeamMailbox}

fn _section(title: text, values: [text]) -> text:
    var out = title + "\n"
    if values.len() == 0:
        return out + "  - none\n"
    for value in values:
        if value != "":
            out = out + "  - " + value + "\n"
    out

pub fn render_agent_handoff_tui(plan: AgentLaunchPlan, caps: AgentCapabilitySet) -> text:
    "LLM Caret Agent Handoff\n" +
        "Mode: " + plan.mode + "\n" +
        "Summary: " + plan.summary + "\n" +
        _section("Agents", caps.agent_paths) +
        _section("Skills", caps.skill_paths) +
        _section("MCP", caps.mcp_servers) +
        _section("Plugins", caps.plugins)

pub fn render_agent_mailbox_tui(mailbox: AgentTeamMailbox) -> text:
    var out = "LLM Caret Team Mailbox\nTeam: " + mailbox.team_id + "\n"
    for message in mailbox.messages:
        out = out + message.channel + ": " + message.from_agent + " -> " + message.to_agent + "\n"
        out = out + "  " + message.body + "\n"
    out

pub fn render_agent_messages_tui(messages: [AgentTeamMessage]) -> text:
    var out = "LLM Caret Agent Messages\n"
    for message in messages:
        out = out + message.channel + ": " + message.from_agent + " -> " + message.to_agent + "\n"
        out = out + "  " + message.body + "\n"
    out

export render_agent_handoff_tui, render_agent_mailbox_tui, render_agent_messages_tui
