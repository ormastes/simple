# LLM Caret pure-Simple GUI interaction model.
#
# The model is renderer-free: Electron, Simple Web/Metal, and tests can apply
# the same deterministic keyboard/submission transitions without GPU handles.

val CARET_NATIVE_KEY_ENTER: i64 = 13
val CARET_NATIVE_KEY_BACKSPACE: i64 = 8
val CARET_NATIVE_PROMPT_MAX: i32 = 80

struct CaretNativeState:
    prompt: text
    user: text
    assistant: text
    status: text
    turn: i32
    focused: bool

struct CaretNativeStep:
    state: CaretNativeState
    submit_prompt: text

fn caret_native_state() -> CaretNativeState:
    CaretNativeState(
        prompt: "", user: "", assistant: "", status: "connected",
        turn: 0, focused: true)

fn caret_native_state_with_prompt(prompt: text) -> CaretNativeState:
    CaretNativeState(
        prompt: prompt, user: "", assistant: "", status: "connected",
        turn: 0, focused: true)

fn _caret_native_key_char(code: i64) -> text:
    val letters = "abcdefghijklmnopqrstuvwxyz"
    val digits = "0123456789"
    if code >= 65 and code <= 90:
        val idx = (code - 65).to_i32()
        return letters.substring(idx, idx + 1)
    if code >= 48 and code <= 57:
        val idx = (code - 48).to_i32()
        return digits.substring(idx, idx + 1)
    if code == 32:
        return " "
    ""

fn _caret_native_with_prompt(state: CaretNativeState, prompt: text) -> CaretNativeState:
    CaretNativeState(
        prompt: prompt, user: state.user, assistant: state.assistant,
        status: state.status, turn: state.turn, focused: true)

fn caret_native_key(state: CaretNativeState, code: i64) -> CaretNativeStep:
    if code == CARET_NATIVE_KEY_ENTER:
        val prompt = state.prompt.trim()
        return CaretNativeStep(state: state, submit_prompt: prompt)
    if code == CARET_NATIVE_KEY_BACKSPACE:
        if state.prompt.len() == 0:
            return CaretNativeStep(state: state, submit_prompt: "")
        val prompt = state.prompt.substring(0, state.prompt.len() - 1)
        return CaretNativeStep(state: _caret_native_with_prompt(state, prompt), submit_prompt: "")
    val ch = _caret_native_key_char(code)
    if ch == "" or state.prompt.len() >= CARET_NATIVE_PROMPT_MAX:
        return CaretNativeStep(state: state, submit_prompt: "")
    CaretNativeStep(
        state: _caret_native_with_prompt(state, state.prompt + ch),
        submit_prompt: "")

fn caret_native_apply_response(state: CaretNativeState, prompt: text, response: text) -> CaretNativeState:
    CaretNativeState(
        prompt: "", user: prompt, assistant: response, status: "connected",
        turn: state.turn + 1, focused: true)
