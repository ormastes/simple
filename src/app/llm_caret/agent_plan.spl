# LLM Caret - Agent/team planning helpers

struct AgentLaunchRequest:
    provider: text
    agent_md_path: text
    skill_path: text
    task_desc: text
    model: text
    session_id: text
    extra_args: [text]

struct AgentLaunchPlan:
    provider: text
    mode: text
    prompt: text
    argv: [text]
    summary: text

struct AgentReviewRequest:
    reviewer: text
    changed_files: [text]
    guidance: text

struct AgentFileChangeSet:
    agent_id: text
    changed_files: [text]

struct AgentFileFingerprint:
    agent_id: text
    path: text
    fingerprint: text

struct AgentCapabilitySet:
    agent_paths: [text]
    skill_paths: [text]
    mcp_servers: [text]
    plugins: [text]

struct AgentTeamMessage:
    from_agent: text
    to_agent: text
    channel: text
    body: text

fn _provider_or_default(provider: text) -> text:
    if provider == "":
        return "claude_cli"
    provider

fn _append_if_non_empty(args: [text], flag: text, value: text) -> [text]:
    if value == "":
        return args
    args + [flag, value]

fn _base_argv(provider: text, prompt: text, model: text, session_id: text, extra_args: [text]) -> [text]:
    var args: [text] = []
    if provider == "codex":
        args = ["exec", prompt]
    else:
        args = ["-p", prompt, "--output-format", "json"]
    args = _append_if_non_empty(args, "--model", model)
    args = _append_if_non_empty(args, "--resume", session_id)
    for arg in extra_args:
        if arg != "":
            args = args + [arg]
    args

fn _agent_prompt(req: AgentLaunchRequest) -> text:
    "Agent: " + req.agent_md_path + "\nSkill: " + req.skill_path + "\nTask: " + req.task_desc

fn _append_lines(label: text, values: [text]) -> text:
    var result = label + ":"
    for value in values:
        if value != "":
            result = result + "\n- " + value
    result

pub fn build_agent_launch_plan(req: AgentLaunchRequest) -> AgentLaunchPlan:
    val provider = _provider_or_default(req.provider)
    val prompt = _agent_prompt(req)
    AgentLaunchPlan(
        provider: provider,
        mode: "agent",
        prompt: prompt,
        argv: _base_argv(provider, prompt, req.model, req.session_id, req.extra_args),
        summary: "agent:" + req.agent_md_path
    )

pub fn build_agent_capability_launch_plan(req: AgentLaunchRequest, caps: AgentCapabilitySet) -> AgentLaunchPlan:
    val provider = _provider_or_default(req.provider)
    val prompt = _agent_prompt(req) + "\n" + _append_lines("Agents", caps.agent_paths) + "\n" + _append_lines("Skills", caps.skill_paths) + "\n" + _append_lines("MCP", caps.mcp_servers) + "\n" + _append_lines("Plugins", caps.plugins)
    AgentLaunchPlan(
        provider: provider,
        mode: "agent_capabilities",
        prompt: prompt,
        argv: _base_argv(provider, prompt, req.model, req.session_id, req.extra_args),
        summary: "agent-capabilities:" + caps.agent_paths.len().to_text() + ":" + caps.skill_paths.len().to_text() + ":" + caps.mcp_servers.len().to_text() + ":" + caps.plugins.len().to_text()
    )

pub fn build_agent_team_plan(requests: [AgentLaunchRequest], interaction_mode: text) -> AgentLaunchPlan:
    var prompt = "Team interaction: " + interaction_mode
    var count = 0
    for req in requests:
        count = count + 1
        prompt = prompt + "\n\nMember " + count.to_text() + "\n" + _agent_prompt(req)
    AgentLaunchPlan(
        provider: "team",
        mode: "team",
        prompt: prompt,
        argv: ["team", interaction_mode, count.to_text()],
        summary: "team:" + count.to_text()
    )

pub fn build_agent_team_interaction_plan(messages: [AgentTeamMessage], interaction_mode: text) -> AgentLaunchPlan:
    var prompt = "Team interaction: " + interaction_mode
    var count = 0
    for msg in messages:
        count = count + 1
        prompt = prompt + "\n" + msg.channel + ": " + msg.from_agent + " -> " + msg.to_agent + "\n" + msg.body
    AgentLaunchPlan(
        provider: "team",
        mode: "team_interaction",
        prompt: prompt,
        argv: ["team-interaction", interaction_mode, count.to_text()],
        summary: "team-interaction:" + interaction_mode + ":" + count.to_text()
    )

pub fn build_btw_side_interaction_plan(messages: [AgentTeamMessage]) -> AgentLaunchPlan:
    build_agent_team_interaction_plan(messages, "btw-side")

pub fn build_low_agent_review_plan(req: AgentReviewRequest) -> AgentLaunchPlan:
    var prompt = "Reviewer: " + req.reviewer + "\nGuidance: " + req.guidance + "\nChanged files:"
    for path in req.changed_files:
        prompt = prompt + "\n- " + path
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "review",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "review:" + req.changed_files.len().to_text()
    )

pub fn build_agent_change_review_plan(changes: [AgentFileChangeSet], guidance: text) -> AgentLaunchPlan:
    var prompt = "Guidance: " + guidance + "\nAgent file changes:"
    var count = 0
    for change in changes:
        prompt = prompt + "\nAgent: " + change.agent_id
        for path in change.changed_files:
            count = count + 1
            prompt = prompt + "\n- " + path
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "agent_change_review",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "agent-change-review:" + count.to_text()
    )

fn _fingerprint_for(files: [AgentFileFingerprint], agent_id: text, path: text) -> text:
    for file in files:
        if file.agent_id == agent_id and file.path == path:
            return file.fingerprint
    ""

fn _has_change(changes: [AgentFileChangeSet], agent_id: text, path: text) -> bool:
    for change in changes:
        if change.agent_id == agent_id:
            for changed in change.changed_files:
                if changed == path:
                    return true
    false

fn _add_agent_change(changes: [AgentFileChangeSet], agent_id: text, path: text) -> [AgentFileChangeSet]:
    if path == "" or _has_change(changes, agent_id, path):
        return changes
    var result: [AgentFileChangeSet] = []
    var added = false
    for change in changes:
        if change.agent_id == agent_id:
            result = result + [AgentFileChangeSet(agent_id: change.agent_id, changed_files: change.changed_files + [path])]
            added = true
        else:
            result = result + [change]
    if not added:
        result = result + [AgentFileChangeSet(agent_id: agent_id, changed_files: [path])]
    result

pub fn track_agent_file_changes(before: [AgentFileFingerprint], after: [AgentFileFingerprint]) -> [AgentFileChangeSet]:
    var changes: [AgentFileChangeSet] = []
    for file in after:
        val old_fp = _fingerprint_for(before, file.agent_id, file.path)
        if old_fp == "" or old_fp != file.fingerprint:
            changes = _add_agent_change(changes, file.agent_id, file.path)
    for file in before:
        val new_fp = _fingerprint_for(after, file.agent_id, file.path)
        if new_fp == "":
            changes = _add_agent_change(changes, file.agent_id, file.path)
    changes

pub fn build_claude_advisor_plan(topic: text, context: text) -> AgentLaunchPlan:
    val prompt = "Advisor topic: " + topic + "\nContext: " + context
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "advisor",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "advisor:" + topic
    )

pub fn build_codex_goal_plan(objective: text, context: text) -> AgentLaunchPlan:
    val prompt = "Goal: " + objective + "\nContext: " + context
    AgentLaunchPlan(
        provider: "codex",
        mode: "goal",
        prompt: prompt,
        argv: _base_argv("codex", prompt, "", "", []),
        summary: "goal:" + objective
    )

export AgentLaunchRequest, AgentLaunchPlan, AgentReviewRequest, AgentFileChangeSet, AgentFileFingerprint, AgentCapabilitySet, AgentTeamMessage
export build_agent_launch_plan, build_agent_capability_launch_plan, build_agent_team_plan, build_agent_team_interaction_plan, build_btw_side_interaction_plan, build_low_agent_review_plan, build_agent_change_review_plan, track_agent_file_changes, build_claude_advisor_plan, build_codex_goal_plan
