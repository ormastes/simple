# LLM Caret - Agent/team planning helpers

struct AgentLaunchRequest:
    provider: text
    agent_md_path: text
    skill_path: text
    task_desc: text
    model: text
    session_id: text
    extra_args: [text]

struct AgentLaunchPlan:
    provider: text
    mode: text
    prompt: text
    argv: [text]
    summary: text

struct AgentReviewRequest:
    reviewer: text
    changed_files: [text]
    guidance: text

struct AgentFileChangeSet:
    agent_id: text
    changed_files: [text]

fn _provider_or_default(provider: text) -> text:
    if provider == "":
        return "claude_cli"
    provider

fn _append_if_non_empty(args: [text], flag: text, value: text) -> [text]:
    if value == "":
        return args
    args + [flag, value]

fn _base_argv(provider: text, prompt: text, model: text, session_id: text, extra_args: [text]) -> [text]:
    var args: [text] = []
    if provider == "codex":
        args = ["exec", prompt]
    else:
        args = ["-p", prompt, "--output-format", "json"]
    args = _append_if_non_empty(args, "--model", model)
    args = _append_if_non_empty(args, "--resume", session_id)
    for arg in extra_args:
        if arg != "":
            args = args + [arg]
    args

fn _agent_prompt(req: AgentLaunchRequest) -> text:
    "Agent: " + req.agent_md_path + "\nSkill: " + req.skill_path + "\nTask: " + req.task_desc

pub fn build_agent_launch_plan(req: AgentLaunchRequest) -> AgentLaunchPlan:
    val provider = _provider_or_default(req.provider)
    val prompt = _agent_prompt(req)
    AgentLaunchPlan(
        provider: provider,
        mode: "agent",
        prompt: prompt,
        argv: _base_argv(provider, prompt, req.model, req.session_id, req.extra_args),
        summary: "agent:" + req.agent_md_path
    )

pub fn build_agent_team_plan(requests: [AgentLaunchRequest], interaction_mode: text) -> AgentLaunchPlan:
    var prompt = "Team interaction: " + interaction_mode
    var count = 0
    for req in requests:
        count = count + 1
        prompt = prompt + "\n\nMember " + count.to_text() + "\n" + _agent_prompt(req)
    AgentLaunchPlan(
        provider: "team",
        mode: "team",
        prompt: prompt,
        argv: ["team", interaction_mode, count.to_text()],
        summary: "team:" + count.to_text()
    )

pub fn build_low_agent_review_plan(req: AgentReviewRequest) -> AgentLaunchPlan:
    var prompt = "Reviewer: " + req.reviewer + "\nGuidance: " + req.guidance + "\nChanged files:"
    for path in req.changed_files:
        prompt = prompt + "\n- " + path
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "review",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "review:" + req.changed_files.len().to_text()
    )

pub fn build_agent_change_review_plan(changes: [AgentFileChangeSet], guidance: text) -> AgentLaunchPlan:
    var prompt = "Guidance: " + guidance + "\nAgent file changes:"
    var count = 0
    for change in changes:
        prompt = prompt + "\nAgent: " + change.agent_id
        for path in change.changed_files:
            count = count + 1
            prompt = prompt + "\n- " + path
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "agent_change_review",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "agent-change-review:" + count.to_text()
    )

pub fn build_claude_advisor_plan(topic: text, context: text) -> AgentLaunchPlan:
    val prompt = "Advisor topic: " + topic + "\nContext: " + context
    AgentLaunchPlan(
        provider: "claude_cli",
        mode: "advisor",
        prompt: prompt,
        argv: _base_argv("claude_cli", prompt, "", "", []),
        summary: "advisor:" + topic
    )

pub fn build_codex_goal_plan(objective: text, context: text) -> AgentLaunchPlan:
    val prompt = "Goal: " + objective + "\nContext: " + context
    AgentLaunchPlan(
        provider: "codex",
        mode: "goal",
        prompt: prompt,
        argv: _base_argv("codex", prompt, "", "", []),
        summary: "goal:" + objective
    )

export AgentLaunchRequest, AgentLaunchPlan, AgentReviewRequest, AgentFileChangeSet
export build_agent_launch_plan, build_agent_team_plan, build_low_agent_review_plan, build_agent_change_review_plan, build_claude_advisor_plan, build_codex_goal_plan
