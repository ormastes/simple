# LLM Caret - Agent file change snapshots

use app.io.mod.{file_exists, file_hash_sha256}
use app.llm_caret.agent_plan.{AgentFileFingerprint, AgentFileChangeSet, track_agent_file_changes}

pub fn snapshot_agent_files(agent_id: text, paths: [text]) -> [AgentFileFingerprint]:
    var result: [AgentFileFingerprint] = []
    for path in paths:
        if path != "" and file_exists(path):
            result = result + [AgentFileFingerprint(agent_id: agent_id, path: path, fingerprint: file_hash_sha256(path))]
    result

pub fn detect_agent_file_changes(before: [AgentFileFingerprint], after: [AgentFileFingerprint]) -> [AgentFileChangeSet]:
    track_agent_file_changes(before, after)

export snapshot_agent_files, detect_agent_file_changes
