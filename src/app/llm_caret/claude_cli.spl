# LLM Caret - Claude CLI Wrapper (PRIMARY)
#
# Wraps the Claude CLI binary as a subprocess.
# Two pure functions (fully testable without Claude binary):
#   - build_claude_args: maps config to CLI flags
#   - parse_claude_json_response: parses JSON output
# One impure function (integration):
#   - claude_cli_send: calls process_run

use app.io.mod.{process_run}
use app.llm_caret.redact.{redact}
use std.common.json.parser.{json_parse}
use std.common.json.object_ops.{json_object_get, json_object_has}
use std.common.json.array_ops.{json_array_get, json_array_length}
use std.common.json.serializer.{json_serialize}
use std.common.json.types.{
    json_get_type,
    json_to_boolean,
    json_to_number,
    json_to_string
}

fn _json_text(object: any, key: text) -> text:
    val value = json_to_string(json_object_get(object, key))
    if value == nil: "" else: value

fn _json_i64(object: any, key: text) -> i64:
    val value = json_to_number(json_object_get(object, key))
    if value == nil: 0 else: value as i64

fn _json_bool(object: any, key: text) -> bool:
    val value = json_to_boolean(json_object_get(object, key))
    if value == nil: false else: value

fn _json_raw(object: any, key: text) -> text:
    val value = json_object_get(object, key)
    if value == nil:
        return ""
    json_serialize(value)

fn _json_optional_kind(object: any, key: text, expected: text) -> bool:
    if not json_object_has(object, key):
        return true
    json_get_type(json_object_get(object, key)) == expected

fn _json_text_fields_valid(object: any, keys: [text]) -> bool:
    for key in keys:
        if not _json_optional_kind(object, key, "string"):
            return false
    true

fn _json_has_usage_key(object: any, key: text) -> bool:
    if object == nil or json_get_type(object) != "object":
        return false
    if json_object_has(object, key):
        return true
    val usage = json_object_get(object, "usage")
    usage != nil and json_get_type(usage) == "object" and
        json_object_has(usage, key)

fn _json_usage_kinds_valid(object: any) -> bool:
    val usage = json_object_get(object, "usage")
    if usage != nil and json_get_type(usage) != "object":
        return false
    for key in [
        "input_tokens", "output_tokens",
        "input_tokens_used", "output_tokens_used"
    ]:
        if not _json_optional_kind(object, key, "number"):
            return false
        if json_object_has(object, key):
            val direct = json_to_number(json_object_get(object, key))
            if direct < 0.0 or direct != direct.to_i64().to_f64():
                return false
        if usage != nil and not _json_optional_kind(usage, key, "number"):
            return false
        if usage != nil and json_object_has(usage, key):
            val nested = json_to_number(json_object_get(usage, key))
            if nested < 0.0 or nested != nested.to_i64().to_f64():
                return false
    val message = json_object_get(object, "message")
    if message != nil:
        if json_get_type(message) != "object":
            return false
        if not _json_usage_kinds_valid(message):
            return false
    true

fn _json_usage_i64(object: any, key: text) -> i64:
    if object == nil or json_get_type(object) != "object":
        return 0
    if json_object_has(object, key):
        return _json_i64(object, key)
    val usage = json_object_get(object, "usage")
    if usage != nil and json_object_has(usage, key):
        return _json_i64(usage, key)
    0

fn _json_message_field(object: any, key: text) -> text:
    val direct = _json_text(object, key)
    if direct != "":
        return direct
    _json_text(json_object_get(object, "message"), key)

fn _json_message_usage_i64(object: any, key: text) -> i64:
    if _json_has_usage_key(object, key):
        return _json_usage_i64(object, key)
    _json_usage_i64(json_object_get(object, "message"), key)

fn _json_message_content(object: any) -> text:
    val message = json_object_get(object, "message")
    val content = json_object_get(message, "content")
    if json_get_type(content) != "array":
        return _json_text(object, "text")
    var parts: [text] = []
    var i = 0
    while i < json_array_length(content):
        val block = json_array_get(content, i)
        if _json_text(block, "type") == "text":
            val value = _json_text(block, "text")
            if value != "":
                parts = parts + [value]
        i = i + 1
    parts.join("")

# ============================================================================
# Response struct (inline for import safety)
# ============================================================================

struct CliResponse:
    content: text
    model: text
    session_id: text
    stop_reason: text
    input_tokens: i64
    output_tokens: i64
    error: text
    is_error: bool
    raw: text

struct CliStreamEvent:
    event_type: text
    content: text
    session_id: text
    model: text
    stop_reason: text
    input_tokens: i64
    output_tokens: i64

fn _invalid_cli_response(raw: text, reason: text) -> CliResponse:
    CliResponse(
        content: "",
        model: "",
        session_id: "",
        stop_reason: "error",
        input_tokens: 0,
        output_tokens: 0,
        error: reason,
        is_error: true,
        raw: redact(raw)
    )

fn _invalid_stream_event(reason: text) -> CliStreamEvent:
    CliStreamEvent(
        event_type: "error",
        content: reason,
        session_id: "",
        model: "",
        stop_reason: "invalid",
        input_tokens: 0,
        output_tokens: 0
    )

fn _supported_stream_type(event_type: text) -> bool:
    event_type == "content_block_start" or
    event_type == "content_block_delta" or
    event_type == "content_block_stop" or
    event_type == "message_start" or
    event_type == "message_delta" or
    event_type == "message_stop" or
    event_type == "ping" or
    event_type == "system" or
    event_type == "assistant" or
    event_type == "user" or
    event_type == "result" or
    event_type == "error" or
    event_type == "rate_limit_event"

# ============================================================================
# Pure Function: build_claude_args
# ============================================================================

pub fn build_claude_args(prompt: text, model: text, output_format: text, system_prompt: text, session_id: text, max_turns: i64, max_tokens: i64, json_schema: text, tools: [text], extra_args: [text], verbose: bool) -> [text]:
    var args: [text] = []
    # Prompt (required for one-shot)
    args = args + ["-p", prompt]
    # Output format
    if output_format != "":
        args = args + ["--output-format", output_format]
    else:
        args = args + ["--output-format", "json"]
    # Model
    if model != "":
        args = args + ["--model", model]
    # System prompt
    if system_prompt != "":
        args = args + ["--system-prompt", system_prompt]
    # Session resume
    if session_id != "":
        args = args + ["--resume", session_id]
    # Max turns
    if max_turns > 0:
        args = args + ["--max-turns", max_turns.to_text()]
    # max_tokens is retained in this API for provider-config compatibility.
    # Current Claude Code does not expose --max-tokens; callers targeting an
    # older/custom CLI may opt in explicitly through extra_args.
    # JSON schema
    if json_schema != "":
        args = args + ["--json-schema", json_schema]
    # Tools: Claude Code exposes one variadic option, so emit the flag once
    # followed by every configured tool.
    var emitted_tools = false
    for tool in tools:
        if tool != "":
            if not emitted_tools:
                args = args + ["--allowedTools"]
                emitted_tools = true
            args = args + [tool]
    # Verbose
    if verbose:
        args = args + ["--verbose"]
    # Extra args (appended at end)
    for arg in extra_args:
        if arg != "":
            args = args + [arg]
    args

# Simplified builder using module config defaults
fn build_claude_args_simple(prompt: text) -> [text]:
    build_claude_args(prompt, "", "", "", "", 0, 0, "", [], [], false)

pub fn build_claude_stream_args(prompt: text, model: text, system_prompt: text, session_id: text, max_turns: i64) -> [text]:
    # Current Claude Code requires verbose mode for stream-json output.
    build_claude_args(prompt, model, "stream-json", system_prompt, session_id, max_turns, 0, "", [], [], true)

# ============================================================================
# Pure Function: parse_claude_json_response
# ============================================================================

pub fn parse_claude_json_response(raw: text) -> CliResponse:
    if raw.trim() == "":
        return _invalid_cli_response("", "empty response")
    val parsed = json_parse(raw)
    if parsed == nil or json_get_type(parsed) != "object":
        return _invalid_cli_response(raw, "invalid JSON response from claude CLI")

    val has_result = json_object_has(parsed, "result")
    val has_structured = json_object_has(parsed, "structured_output")
    if has_result and not _json_optional_kind(parsed, "result", "string"):
        return _invalid_cli_response(
            raw, "claude CLI result field must be a string"
        )
    if not _json_optional_kind(parsed, "is_error", "boolean"):
        return _invalid_cli_response(
            raw, "claude CLI is_error field must be boolean"
        )
    if not _json_usage_kinds_valid(parsed):
        return _invalid_cli_response(
            raw, "claude CLI usage fields must be numeric, non-negative integers"
        )
    if not _json_text_fields_valid(
        parsed, ["model", "session_id", "stop_reason"]
    ):
        return _invalid_cli_response(
            raw, "claude CLI model, session, and stop fields must be strings"
        )
    val response_message = json_object_get(parsed, "message")
    if response_message != nil and not _json_text_fields_valid(
        response_message, ["model"]
    ):
        return _invalid_cli_response(
            raw, "claude CLI message model field must be a string"
        )
    val is_err = _json_bool(parsed, "is_error")
    if not has_result and not has_structured and not is_err:
        return _invalid_cli_response(raw, "claude CLI response is missing result")

    var result_text = _json_text(parsed, "result")
    if result_text == "" and has_structured:
        result_text = _json_raw(parsed, "structured_output")
    val model_text = _json_message_field(parsed, "model")
    val session = _json_text(parsed, "session_id")
    var final_in_tok = _json_usage_i64(parsed, "input_tokens")
    var final_out_tok = _json_usage_i64(parsed, "output_tokens")
    if final_in_tok == 0:
        final_in_tok = _json_usage_i64(parsed, "input_tokens_used")
    if final_out_tok == 0:
        final_out_tok = _json_usage_i64(parsed, "output_tokens_used")
    var error_text = ""
    if is_err:
        error_text = result_text
        if error_text == "":
            error_text = _json_text(parsed, "error")
        if error_text == "":
            error_text = _json_text(json_object_get(parsed, "error"), "message")
        if error_text == "":
            error_text = "claude CLI returned an error"
    var final_stop = _json_text(parsed, "stop_reason")
    if final_stop == "":
        final_stop = "end_turn"
    if is_err:
        final_stop = "error"
    # Redact secrets from anything that is display/log-shaped (error text,
    # raw CLI output echoed back for debugging) -- never from fields used
    # only internally for further parsing (already extracted above).
    CliResponse(
        content: if is_err: "" else: result_text,
        model: model_text,
        session_id: session,
        stop_reason: final_stop,
        input_tokens: final_in_tok,
        output_tokens: final_out_tok,
        error: redact(error_text),
        is_error: is_err,
        raw: redact(raw)
    )

# ============================================================================
# Pure Function: parse_claude_stream_line
# ============================================================================

pub fn parse_claude_stream_line(line: text) -> CliStreamEvent:
    val trimmed = line.trim()
    if trimmed == "":
        return CliStreamEvent(
            event_type: "empty",
            content: "",
            session_id: "",
            model: "",
            stop_reason: "",
            input_tokens: 0,
            output_tokens: 0
        )
    val parsed = json_parse(trimmed)
    if parsed == nil or json_get_type(parsed) != "object":
        return _invalid_stream_event("invalid JSON in claude CLI stream")
    val etype = _json_text(parsed, "type")
    if etype == "":
        return _invalid_stream_event("claude CLI stream event is missing type")
    if not _supported_stream_type(etype):
        return _invalid_stream_event(
            "unsupported claude CLI stream event type: " + etype
        )
    if not _json_usage_kinds_valid(parsed):
        return _invalid_stream_event(
            "claude CLI stream usage fields must be numeric, non-negative integers"
        )
    if not _json_text_fields_valid(
        parsed, ["session_id", "model", "stop_reason"]
    ):
        return _invalid_stream_event(
            "claude CLI stream metadata fields must be strings"
        )
    val stream_message = json_object_get(parsed, "message")
    if stream_message != nil and not _json_text_fields_valid(
        stream_message, ["model"]
    ):
        return _invalid_stream_event(
            "claude CLI stream message model field must be a string"
        )
    val stream_delta = json_object_get(parsed, "delta")
    if stream_delta != nil and json_get_type(stream_delta) != "object":
        return _invalid_stream_event(
            "claude CLI stream delta field must be an object"
        )
    if etype == "assistant" and stream_message != nil:
        val assistant_content = json_object_get(stream_message, "content")
        if assistant_content != nil and json_get_type(assistant_content) != "array":
            return _invalid_stream_event(
                "claude CLI assistant content field must be an array"
            )
        if assistant_content != nil:
            var block_index = 0
            while block_index < json_array_length(assistant_content):
                val block = json_array_get(assistant_content, block_index)
                if (json_get_type(block) != "object" or
                    not _json_optional_kind(block, "type", "string") or
                    (_json_text(block, "type") == "text" and
                     not _json_optional_kind(block, "text", "string"))):
                    return _invalid_stream_event(
                        "claude CLI assistant content blocks must be typed objects"
                    )
                block_index = block_index + 1
    var content_val = ""
    var sid = ""
    var mdl = ""
    var stop_val = ""
    var in_tok = 0
    var out_tok = 0
    if etype == "content_block_delta":
        val delta = json_object_get(parsed, "delta")
        content_val = _json_text(delta, "text")
        if content_val == "":
            content_val = _json_text(delta, "partial_json")
    elif etype == "message_stop":
        stop_val = _json_text(parsed, "stop_reason")
        if stop_val == "":
            stop_val = "end_turn"
    elif etype == "message_start":
        mdl = _json_message_field(parsed, "model")
        sid = _json_text(parsed, "session_id")
        in_tok = _json_message_usage_i64(parsed, "input_tokens")
        out_tok = _json_message_usage_i64(parsed, "output_tokens")
    elif etype == "message_delta":
        stop_val = _json_text(json_object_get(parsed, "delta"), "stop_reason")
        out_tok = _json_usage_i64(parsed, "output_tokens")
    elif etype == "system":
        # Claude Code stream-json init envelope.
        sid = _json_text(parsed, "session_id")
        mdl = _json_text(parsed, "model")
    elif etype == "assistant":
        # Claude Code stream-json assistant envelope. Aggregate all text
        # blocks; tool-use details are delivered by their dedicated events.
        content_val = _json_message_content(parsed)
        sid = _json_text(parsed, "session_id")
        mdl = _json_message_field(parsed, "model")
        in_tok = _json_message_usage_i64(parsed, "input_tokens")
        out_tok = _json_message_usage_i64(parsed, "output_tokens")
    elif etype == "result":
        # Claude Code final envelope.
        if not _json_optional_kind(parsed, "is_error", "boolean"):
            return _invalid_stream_event(
                "claude CLI result is_error field must be boolean"
            )
        if json_object_has(parsed, "result") and
           not _json_optional_kind(parsed, "result", "string"):
            return _invalid_stream_event(
                "claude CLI result field must be a string"
            )
        val result_is_error = _json_bool(parsed, "is_error")
        if not json_object_has(parsed, "result") and
           not json_object_has(parsed, "structured_output") and
           not result_is_error:
            return _invalid_stream_event(
                "claude CLI result event is missing result"
            )
        content_val = _json_text(parsed, "result")
        if content_val == "" and json_object_has(parsed, "structured_output"):
            content_val = _json_raw(parsed, "structured_output")
        sid = _json_text(parsed, "session_id")
        mdl = _json_message_field(parsed, "model")
        stop_val = _json_text(parsed, "stop_reason")
        in_tok = _json_usage_i64(parsed, "input_tokens")
        out_tok = _json_usage_i64(parsed, "output_tokens")
        if result_is_error:
            if content_val == "":
                content_val = _json_text(parsed, "error")
            if content_val == "":
                content_val = _json_text(
                    json_object_get(parsed, "error"), "message"
                )
            if content_val == "":
                content_val = "claude CLI returned an error"
            content_val = redact(content_val)
            stop_val = "error"
    elif etype == "error":
        content_val = _json_text(parsed, "error")
        if content_val == "":
            content_val = _json_text(
                json_object_get(parsed, "error"), "message"
            )
        content_val = redact(content_val)
        if content_val == "":
            content_val = "claude CLI stream error"
        stop_val = "error"
    CliStreamEvent(
        event_type: etype,
        content: content_val,
        session_id: sid,
        model: mdl,
        stop_reason: stop_val,
        input_tokens: in_tok,
        output_tokens: out_tok
    )

# ============================================================================
# Impure Function: claude_cli_send
# ============================================================================

pub fn claude_cli_send(cli_path: text, prompt: text, model: text, system_prompt: text, session_id: text, max_turns: i64, max_tokens: i64, json_schema: text, tools: [text], extra_args: [text]) -> CliResponse:
    val args = build_claude_args(prompt, model, "json", system_prompt, session_id, max_turns, max_tokens, json_schema, tools, extra_args, false)
    val result = process_run(cli_path, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2
    if exit_code != 0:
        var err_msg = "claude CLI exited with code " + exit_code.to_text()
        if stderr != "":
            err_msg = err_msg + ": " + stderr
        # stderr can echo request headers/config/env on CLI failure --
        # redact before it reaches CliResponse.error (logged/displayed).
        return CliResponse(
            content: "",
            model: "",
            session_id: "",
            stop_reason: "error",
            input_tokens: 0,
            output_tokens: 0,
            error: redact(err_msg),
            is_error: true,
            raw: redact(stdout)
        )
    parse_claude_json_response(stdout)

# Stream execution: returns list of parsed NDJSON events
pub fn claude_cli_stream(cli_path: text, prompt: text, model: text, system_prompt: text, session_id: text, max_turns: i64) -> [CliStreamEvent]:
    val args = build_claude_stream_args(prompt, model, system_prompt, session_id, max_turns)
    val result = process_run(cli_path, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2
    var events: [CliStreamEvent] = []
    if exit_code != 0:
        var err_msg = "claude CLI exited with code " + exit_code.to_text()
        if stderr != "":
            err_msg = err_msg + ": " + stderr
        events = events + [CliStreamEvent(
            event_type: "error",
            content: redact(err_msg),
            session_id: "",
            model: "",
            stop_reason: "error",
            input_tokens: 0,
            output_tokens: 0
        )]
        return events
    val lines = stdout.split("\n")
    var saw_event = false
    var saw_message_stop = false
    var saw_final = false
    for line in lines:
        if line.trim() != "":
            val evt = parse_claude_stream_line(line)
            if evt.stop_reason == "invalid":
                return [evt]
            if saw_final:
                return [_invalid_stream_event(
                    "claude CLI stream emitted data after a terminal event"
                )]
            if (saw_message_stop and
                evt.event_type != "result" and
                evt.event_type != "error"):
                return [_invalid_stream_event(
                    "claude CLI stream emitted data after message_stop"
                )]
            events = events + [evt]
            if evt.event_type != "empty":
                saw_event = true
            if evt.event_type == "message_stop":
                saw_message_stop = true
            elif (evt.event_type == "result" or
                  (evt.event_type == "error" and evt.stop_reason == "error")):
                saw_final = true
    if not saw_event:
        return [CliStreamEvent(
            event_type: "error",
            content: "claude CLI returned no valid stream events",
            session_id: "",
            model: "",
            stop_reason: "error",
            input_tokens: 0,
            output_tokens: 0
        )]
    if not saw_message_stop and not saw_final:
        events = events + [CliStreamEvent(
            event_type: "error",
            content: "claude CLI stream ended before a terminal event",
            session_id: "",
            model: "",
            stop_reason: "error",
            input_tokens: 0,
            output_tokens: 0
        )]
    events
