# Lightweight text contract shared by the TUI renderer and interface specs.

fn caret_role_label(role: text) -> text:
    if role == "user":
        return "You"
    if role == "assistant":
        return "Assistant"
    role

fn caret_turn_line(role: text, content: text) -> text:
    caret_role_label(role) + ": " + content
