# LLM Caret - Session Persistence
#
# Persists a conversation (transcript + provider session id) to
# ~/.llm_caret/sessions/<id>.json so `--resume <id>` / `/resume <id>` can
# restore it across process runs and within a single interactive session.
#
# Storage is one small JSON file per session id (hand-rolled reader/writer,
# matching json_helpers.spl's dependency-light style - no external JSON lib
# in this stdlib slice). Session transcripts are internal to llm_caret, so
# SDN (the repo's preferred config/data format) is not required here.

use app.io.mod.{home, file_exists, file_read, file_write, dir_create_all, dir_list, is_dir, getpid, current_time_ms}
use app.llm_caret.types.{Message}
use app.llm_caret.json_helpers.{jo6, ja, build_message_json, json_find}
use std.mcp.helpers.{jp, js}

# extract_json_string/extract_json_int are deliberately NOT imported from
# json_helpers.spl here - under a whole-tree `simple test` build those names
# resolve to an unrelated same-signature fn in a different module (confirmed
# via a zero-hit sentinel print: json_helpers.extract_json_string was never
# invoked despite editing it, while a local private fn with the identical
# body worked correctly), so calls silently ran the wrong module's code and
# truncated escaped content at the first embedded quote. Every other
# llm_caret file (tools.spl _json_get_str, provider.spl, chat.spl, mod.spl,
# server.spl) already avoids the shared json_helpers functions for exactly
# this reason - keep a local copy here too rather than relying on the
# collision-prone shared ones. Filed as a cross-module fn-name collision bug
# (same class as the documented struct-name collision landmine); a real fix
# belongs in the compiler's symbol resolution, out of scope for this package.

struct Session:
    id: text
    provider: text
    model: text
    provider_session_id: text
    messages: [Message]
    updated_at_ms: i64

fn _sessions_dir() -> text:
    home() + "/.llm_caret/sessions"

fn session_path(id: text) -> text:
    _sessions_dir() + "/" + id + ".json"

# Timestamp + pid keeps ids unique across quick successive calls without a
# process-wide counter (which would need module state shared across files).
fn gen_session_id() -> text:
    "sess-" + current_time_ms().to_text() + "-" + getpid().to_text()

fn new_session(id: text, provider: text, model: text) -> Session:
    Session(id: id, provider: provider, model: model, provider_session_id: "", messages: [], updated_at_ms: 0)

# ============================================================================
# JSON encode
# ============================================================================

fn _messages_json(msgs: [Message]) -> text:
    var items: [text] = []
    for m in msgs:
        items = items + [build_message_json(m.role, m.content)]
    ja(items)

fn session_to_json(sess: Session) -> text:
    jo6(
        jp("id", js(sess.id)),
        jp("provider", js(sess.provider)),
        jp("model", js(sess.model)),
        jp("provider_session_id", js(sess.provider_session_id)),
        jp("updated_at_ms", sess.updated_at_ms.to_text()),
        jp("messages", _messages_json(sess.messages))
    )

# ============================================================================
# JSON decode (brace/quote-aware object scanner, same idiom as
# tools.spl's _extract_object_at - required because message content can
# itself contain literal '{'/'}' characters, e.g. tool output).
# ============================================================================

fn _extract_object_at(json: text, start: i64) -> text:
    var depth = 0
    var i = start
    var in_str = false
    var escaped = false
    while i < json.len():
        val ch = json.substring(i, i + 1)
        if in_str:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == "{":
                depth = depth + 1
            elif ch == "}":
                depth = depth - 1
                if depth == 0:
                    return json.substring(start, i + 1)
        i = i + 1
    json.substring(start)

# Local escape-aware string/int extractors (NOT imported from
# json_helpers.spl - see the collision note above). Mirrors
# json_helpers.extract_json_string/extract_json_int's logic, kept private
# to this module so it can't collide with any other module's same-named fn.
fn _extract_json_string(json: text, key: text) -> text:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx = json_find(json, search)
    if idx < 0:
        return ""
    val after = json.substring(idx + search.len())
    val trimmed = after.trim()
    if trimmed.starts_with(quote):
        val rest = trimmed.substring(1)
        var end = 0
        var escaped = false
        while end < rest.len():
            val ch = rest.substring(end, end + 1)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                return rest.substring(0, end)
            end = end + 1
    ""

fn _extract_json_int(json: text, key: text) -> i64:
    val search = "\"" + key + "\":"
    val idx = json_find(json, search)
    if idx < 0:
        return 0
    val after = json.substring(idx + search.len()).trim()
    var end = 0
    while end < after.len():
        val ch = after.substring(end, end + 1)
        val is_digit = ch >= "0" and ch <= "9"
        val is_neg = ch == "-" and end == 0
        if not (is_digit or is_neg):
            break
        end = end + 1
    if end == 0:
        return 0
    int(after.substring(0, end))

# extract_json_string returns the RAW escaped slice between quotes (it does
# not unescape) - fine for content with no JSON-special chars, but message
# content routinely contains quotes/backslashes (tool output, code). Undo
# the json_helpers.build_message_json / std.mcp.helpers.js() escaping here so
# round-tripping is lossless. Mirrors tools.spl's proven _json_unescape.
fn _json_unescape(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\\" and i + 1 < s.len():
            val nx = s[i + 1]
            if nx == "n":
                out = out + "\n"
            elif nx == "t":
                out = out + "\t"
            elif nx == "r":
                out = out + "\r"
            elif nx == "\"":
                out = out + "\""
            elif nx == "\\":
                out = out + "\\"
            else:
                out = out + nx
            i = i + 2
        else:
            out = out + ch
            i = i + 1
    out

fn _extract_json_string_unescaped(json: text, key: text) -> text:
    _json_unescape(_extract_json_string(json, key))

fn parse_messages_array(json: text) -> [Message]:
    val key = "\"messages\":"
    val idx = json_find(json, key)
    if idx < 0:
        return []
    var j = idx + key.len()
    while j < json.len() and json.substring(j, j + 1) != "[":
        j = j + 1
    if j >= json.len():
        return []
    var msgs: [Message] = []
    var i = j + 1
    while i < json.len():
        val ch = json.substring(i, i + 1)
        if ch == "]":
            break
        if ch == "{":
            val obj = _extract_object_at(json, i)
            val role = _extract_json_string_unescaped(obj, "role")
            val content = _extract_json_string_unescaped(obj, "content")
            msgs = msgs + [Message(role: role, content: content)]
            i = i + obj.len()
        else:
            i = i + 1
    msgs

fn session_from_json(raw: text) -> Session:
    Session(
        id: _extract_json_string_unescaped(raw, "id"),
        provider: _extract_json_string_unescaped(raw, "provider"),
        model: _extract_json_string_unescaped(raw, "model"),
        provider_session_id: _extract_json_string_unescaped(raw, "provider_session_id"),
        messages: parse_messages_array(raw),
        updated_at_ms: _extract_json_int(raw, "updated_at_ms")
    )

# ============================================================================
# Disk I/O
# ============================================================================

fn save_session(sess: Session) -> bool:
    dir_create_all(_sessions_dir())
    file_write(session_path(sess.id), session_to_json(sess))

fn load_session(id: text) -> Session?:
    val path = session_path(id)
    if not file_exists(path):
        return nil
    val raw = file_read(path) ?? ""
    if raw == "":
        return nil
    Some(session_from_json(raw))

fn list_session_ids() -> [text]:
    val dir = _sessions_dir()
    if not is_dir(dir):
        return []
    val entries = dir_list(dir) ?? []
    var ids: [text] = []
    for e in entries:
        if e.ends_with(".json"):
            ids = ids + [e.substring(0, e.len() - 5)]
    ids
