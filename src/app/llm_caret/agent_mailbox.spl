# LLM Caret - Pure agent team mailbox

use app.llm_caret.agent_plan.{AgentTeamMessage}

struct AgentTeamMailbox:
    team_id: text
    messages: [AgentTeamMessage]

pub fn new_agent_team_mailbox(team_id: text) -> AgentTeamMailbox:
    AgentTeamMailbox(team_id: team_id, messages: [])

pub fn post_agent_team_message(mailbox: AgentTeamMailbox, message: AgentTeamMessage) -> AgentTeamMailbox:
    AgentTeamMailbox(team_id: mailbox.team_id, messages: mailbox.messages + [message])

pub fn post_btw_message(mailbox: AgentTeamMailbox, from_agent: text, to_agent: text, body: text) -> AgentTeamMailbox:
    post_agent_team_message(mailbox, AgentTeamMessage(from_agent: from_agent, to_agent: to_agent, channel: "btw", body: body))

pub fn post_side_message(mailbox: AgentTeamMailbox, from_agent: text, to_agent: text, body: text) -> AgentTeamMailbox:
    post_agent_team_message(mailbox, AgentTeamMessage(from_agent: from_agent, to_agent: to_agent, channel: "side", body: body))

pub fn agent_team_inbox(mailbox: AgentTeamMailbox, agent_id: text) -> [AgentTeamMessage]:
    var result: [AgentTeamMessage] = []
    for message in mailbox.messages:
        if message.to_agent == agent_id or message.to_agent == "*" or message.to_agent == "all":
            result = result + [message]
    result

pub fn agent_team_channel(mailbox: AgentTeamMailbox, channel: text) -> [AgentTeamMessage]:
    var result: [AgentTeamMessage] = []
    for message in mailbox.messages:
        if message.channel == channel:
            result = result + [message]
    result

pub fn agent_team_transcript(mailbox: AgentTeamMailbox) -> [AgentTeamMessage]:
    mailbox.messages

export AgentTeamMailbox
export new_agent_team_mailbox, post_agent_team_message, post_btw_message, post_side_message, agent_team_inbox, agent_team_channel, agent_team_transcript
