# snpm scripts — Lifecycle script runner

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{SnpmManifest}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val LIFECYCLE_PHASES = ["preinstall", "install", "postinstall", "prepublish", "publish", "postpublish", "pretest", "test", "posttest", "preuninstall", "uninstall", "postuninstall"]

fn run_lifecycle(phase: text, manifest: SnpmManifest, config: SnpmConfig) -> i32:
    """Run a lifecycle script if defined in manifest."""
    var i = 0
    while i < manifest.scripts.len():
        val script = manifest.scripts[i]
        if script.first == phase:
            print "> {phase}: {script.second}"
            val result = rt_process_run("sh", ["-c", script.second])
            if result.0 != "":
                print result.0
            if result.1 != "":
                print result.1
            return result.2.to_i32()
        i = i + 1
    0  # No script defined, success

fn run_pre_post(action: text, manifest: SnpmManifest, config: SnpmConfig):
    """Run pre and post lifecycle hooks for an action."""
    run_lifecycle("pre{action}", manifest, config)
    run_lifecycle(action, manifest, config)
    run_lifecycle("post{action}", manifest, config)

fn has_script(name: text, manifest: SnpmManifest) -> bool:
    """Check if a named script exists."""
    var i = 0
    while i < manifest.scripts.len():
        if manifest.scripts[i].first == name:
            return true
        i = i + 1
    false

fn list_scripts(manifest: SnpmManifest):
    """Print all available scripts."""
    if manifest.scripts.len() == 0:
        print "No scripts defined"
        return
    print "Available scripts:"
    var i = 0
    while i < manifest.scripts.len():
        val script = manifest.scripts[i]
        print "  {script.first}: {script.second}"
        i = i + 1
