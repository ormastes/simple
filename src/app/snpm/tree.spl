# snpm dependency tree — build and display dependency tree with hoisting

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest, SnpmManifest}

extern fn rt_file_exists(path: text) -> bool

class TreeNode:
    name: text
    version: text
    depth: i64
    children: [TreeNode]
    is_hoisted: bool

    static fn create(name: text, version: text, depth: i64) -> TreeNode:
        TreeNode(name: name, version: version, depth: depth, children: [], is_hoisted: false)

fn build_tree(manifest: SnpmManifest, config: SnpmConfig) -> [TreeNode]:
    """Build dependency tree from manifest."""
    var nodes: [TreeNode] = []
    var i = 0
    while i < manifest.dependencies.len():
        val dep = manifest.dependencies[i]
        val name = dep.first
        val constraint = dep.second
        val installed_ver = _get_installed_version(name, config)
        var node = TreeNode.create(name, installed_ver, 0)
        # Check for transitive deps
        val pkg_manifest_path = "{config.modules_dir}/{name}/package.sdn"
        if rt_file_exists(pkg_manifest_path):
            val sub_result = parse_manifest(pkg_manifest_path)
            match sub_result:
                Ok(sub_manifest):
                    var j = 0
                    while j < sub_manifest.dependencies.len():
                        val sub_dep = sub_manifest.dependencies[j]
                        val child = TreeNode.create(sub_dep.first, sub_dep.second, 1)
                        node.children.push(child)
                        j = j + 1
                _: pass_dn
        nodes.push(node)
        i = i + 1
    nodes

fn print_tree(nodes: [TreeNode], prefix: text):
    """Print dependency tree with box-drawing characters."""
    var i = 0
    while i < nodes.len():
        val node = nodes[i]
        val is_last = i == nodes.len() - 1
        val connector = if is_last: "└── " else: "├── "
        val child_prefix = if is_last: "    " else: "│   "
        val status = if node.is_hoisted: " (hoisted)" else: ""
        print "{prefix}{connector}{node.name}@{node.version}{status}"
        if node.children.len() > 0:
            print_tree(node.children, prefix + child_prefix)
        i = i + 1

fn _get_installed_version(name: text, config: SnpmConfig) -> text:
    val path = "{config.modules_dir}/{name}/package.sdn"
    if rt_file_exists(path):
        val result = parse_manifest(path)
        match result:
            Ok(m): return m.version
            _: pass_dn
    "(not installed)"
