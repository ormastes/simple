# snpm installer — install resolved packages to spl_modules/

use app.snpm.config.{SnpmConfig}
use app.snpm.resolver.{ResolvedPackage}

use std.io_runtime.{mkdir_p, file_write}

fn install_packages(packages: [ResolvedPackage], config: SnpmConfig):
    """Install resolved packages into spl_modules/."""
    mkdir_p(config.modules_dir)
    var i = 0
    while i < packages.len():
        val pkg = packages[i]
        _install_single(pkg, config)
        i = i + 1

fn _install_single(pkg: ResolvedPackage, config: SnpmConfig):
    """Install a single package."""
    val pkg_dir = "{config.modules_dir}/{pkg.name}"
    mkdir_p(pkg_dir)

    # Create package.sdn in the installed directory
    var manifest = "package:\n"
    manifest = manifest + "    name: \"{pkg.name}\"\n"
    manifest = manifest + "    version: \"{pkg.version}\"\n"
    file_write("{pkg_dir}/package.sdn", manifest)

    # Create src directory placeholder
    mkdir_p("{pkg_dir}/src")
    file_write("{pkg_dir}/src/mod.spl", "# {pkg.name} v{pkg.version}\n# Installed by snpm\n")

    print "  + {pkg.name}@{pkg.version}"
