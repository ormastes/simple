# snpm workspace — Monorepo workspace support

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest, SnpmManifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_list_dir(path: text) -> [text]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_mkdir(path: text) -> bool

fn discover_workspaces(root: text, patterns: [text]) -> [text]:
    """Discover workspace directories matching glob patterns."""
    var workspaces: [text] = []
    var i = 0
    while i < patterns.len():
        val pattern = patterns[i]
        # Simple glob: "packages/*" → list packages/ directory
        if pattern.ends_with("/*"):
            var dir = root + "/"
            var j = 0
            while j < pattern.len() - 2:
                dir = dir + pattern[j]
                j = j + 1
            if rt_file_exists(dir):
                val entries = rt_file_list_dir(dir)
                var k = 0
                while k < entries.len():
                    val entry_path = dir + "/" + entries[k]
                    if rt_file_exists(entry_path + "/package.sdn"):
                        workspaces.push(entry_path)
                    k = k + 1
        else:
            val ws_path = root + "/" + pattern
            if rt_file_exists(ws_path + "/package.sdn"):
                workspaces.push(ws_path)
        i = i + 1
    workspaces

fn link_workspaces(workspaces: [text], config: SnpmConfig):
    """Create symlinks between workspace packages in spl_modules/."""
    rt_mkdir(config.modules_dir)
    var i = 0
    while i < workspaces.len():
        val ws = workspaces[i]
        val result = parse_manifest(ws + "/package.sdn")
        match result:
            Ok(manifest):
                val link_path = "{config.modules_dir}/{manifest.name}"
                rt_process_run("ln", ["-sf", ws, link_path])
                print "  {manifest.name} -> {ws}"
            Err(msg):
                print "  warning: {msg}"
        i = i + 1
