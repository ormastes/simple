# snpm uninstall — Remove packages

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest, write_manifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool

fn cmd_uninstall(config: SnpmConfig, args: [text]):
    """Remove a package from dependencies and spl_modules/."""
    if args.len() == 0:
        print "snpm: missing package name"
        print "Usage: snpm uninstall <pkg>"
        return

    val name = args[0]
    print "snpm: removing {name}..."

    # Remove from manifest
    if rt_file_exists(config.manifest_name):
        val manifest_result = parse_manifest(config.manifest_name)
        match manifest_result:
            Ok(manifest):
                var new_deps: [Pair<text, text>] = []
                var removed = false
                var i = 0
                while i < manifest.dependencies.len():
                    val dep = manifest.dependencies[i]
                    if dep.first != name:
                        new_deps.push(dep)
                    else:
                        removed = true
                    i = i + 1
                if removed:
                    manifest.dependencies = new_deps
                    write_manifest(manifest, config.manifest_name)
                    print "snpm: removed {name} from dependencies"
                else:
                    print "snpm: {name} not found in dependencies"
            Err(msg):
                print "snpm: {msg}"

    # Remove from spl_modules/
    val pkg_dir = "{config.modules_dir}/{name}"
    if rt_file_exists(pkg_dir):
        rt_file_delete(pkg_dir)
        print "snpm: deleted {pkg_dir}/"
