# snpm registry client — HTTP communication with package registry

use app.snpm.config.{SnpmConfig}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

class PackageInfo:
    name: text
    version: text
    description: text
    tarball_url: text

fn fetch_package_info(name: text, config: SnpmConfig) -> Result<PackageInfo, text>:
    """Fetch package metadata from registry via curl."""
    val url = "{config.registry_url}/api/v1/packages/{name}"
    val result = rt_process_run("curl", ["-s", "-f", url])
    if result.2 != 0:
        return Err("Failed to fetch package info for '{name}': HTTP error")
    # Parse response (simplified — assume SDN format)
    val body = result.0
    Ok(PackageInfo(name: name, version: "latest", description: "", tarball_url: "{config.registry_url}/{name}/-/{name}-latest.spk"))

fn download_package(name: text, version: text, config: SnpmConfig) -> Result<text, text>:
    """Download package tarball to cache directory."""
    val url = "{config.registry_url}/{name}/-/{name}-{version}.spk"
    val cache_path = "{config.cache_dir}/{name}/{version}"
    val tarball = "{cache_path}/{name}-{version}.spk"

    # Create cache directory
    extern fn rt_mkdir(path: text) -> bool
    rt_mkdir(cache_path)

    val result = rt_process_run("curl", ["-s", "-f", "-o", tarball, url])
    if result.2 != 0:
        return Err("Failed to download {name}@{version}")
    Ok(tarball)

fn search_registry(query: text, config: SnpmConfig) -> [PackageInfo]:
    """Search registry for packages matching query."""
    val url = "{config.registry_url}/api/v1/search?q={query}"
    val result = rt_process_run("curl", ["-s", "-f", url])
    if result.2 != 0:
        var empty: [PackageInfo] = []
        return empty
    # Return empty for now — would parse response
    var results: [PackageInfo] = []
    results
