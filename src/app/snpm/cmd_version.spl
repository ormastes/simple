# snpm version — Bump package version

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest, write_manifest}

extern fn rt_file_exists(path: text) -> bool

fn cmd_version(config: SnpmConfig, args: [text]):
    """Bump package version or show current."""
    if not rt_file_exists(config.manifest_name):
        print "snpm: no {config.manifest_name} found"
        return

    val manifest_result = parse_manifest(config.manifest_name)
    match manifest_result:
        Err(msg):
            print "snpm: {msg}"
            return
        Ok(manifest):
            if args.len() == 0:
                print manifest.version
                return

            val bump = args[0]
            val parts = manifest.version.split(".")
            var major = if parts.len() > 0: parts[0].parse_i64() ?? 0 else: 0
            var minor = if parts.len() > 1: parts[1].parse_i64() ?? 0 else: 0
            var patch = if parts.len() > 2: parts[2].parse_i64() ?? 0 else: 0

            match bump:
                "major":
                    major = major + 1
                    minor = 0
                    patch = 0
                "minor":
                    minor = minor + 1
                    patch = 0
                "patch":
                    patch = patch + 1
                _:
                    # Treat as exact version
                    manifest.version = bump
                    write_manifest(manifest, config.manifest_name)
                    print "v{manifest.version}"
                    return

            manifest.version = "{major}.{minor}.{patch}"
            write_manifest(manifest, config.manifest_name)
            print "v{manifest.version}"
