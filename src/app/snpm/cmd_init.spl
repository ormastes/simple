# snpm init — Create package.sdn interactively

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{SnpmManifest, write_manifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_get_cwd() -> text

fn cmd_init(config: SnpmConfig, args: [text]):
    """Create a new package.sdn in the current directory."""
    val manifest_path = config.manifest_name
    if rt_file_exists(manifest_path):
        print "snpm: {manifest_path} already exists"
        return

    var manifest = SnpmManifest.empty()

    # Use directory name as default package name
    val cwd = rt_get_cwd()
    var dir_name = cwd
    var last_slash = -1
    var i = 0
    for ch in cwd:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash >= 0:
        dir_name = cwd.slice(last_slash + 1, cwd.len())
    manifest.name = dir_name

    # Check for --yes flag (accept defaults)
    var use_defaults = false
    var ai = 0
    while ai < args.len():
        if args[ai] == "-y" or args[ai] == "--yes":
            use_defaults = true
        ai = ai + 1

    # Set default scripts
    manifest.scripts.push(Pair(first: "build", second: "simple build"))
    manifest.scripts.push(Pair(first: "test", second: "simple test"))
    manifest.scripts.push(Pair(first: "start", second: "simple run src/main.spl"))

    write_manifest(manifest, manifest_path)
    print "Created {manifest_path}"
    print ""
    print "  name: {manifest.name}"
    print "  version: {manifest.version}"
    print "  license: {manifest.license}"
