# snpm cache — Local package cache management

use app.snpm.config.{SnpmConfig}
use std.io_runtime.{mkdir_p, dir_list, file_exists, file_delete, process_run}

fn get_cached(name: text, version: text, config: SnpmConfig) -> text:
    """Check if package is cached, return path or empty string."""
    val cache_path = "{config.cache_dir}/{name}/{version}"
    val tarball = "{cache_path}/{name}-{version}.spk"
    if file_exists(tarball):
        return tarball
    ""

fn cache_package(name: text, version: text, source_path: text, config: SnpmConfig):
    """Copy package tarball to cache."""
    val cache_dir = "{config.cache_dir}/{name}/{version}"
    mkdir_p("{config.cache_dir}/{name}")
    mkdir_p(cache_dir)
    process_run("cp", [source_path, "{cache_dir}/{name}-{version}.spk"])

fn cache_clean(config: SnpmConfig):
    """Remove all cached packages."""
    if file_exists(config.cache_dir):
        file_delete(config.cache_dir)
        print "snpm: cache cleared"
    else:
        print "snpm: cache already empty"

fn cache_info(config: SnpmConfig):
    """Show cache information."""
    print "Cache directory: {config.cache_dir}"
    if not file_exists(config.cache_dir):
        print "Cache is empty"
        return
    val entries = dir_list(config.cache_dir)
    print "Cached packages: {entries.len()}"
    var i = 0
    while i < entries.len():
        print "  {entries[i]}"
        i = i + 1
