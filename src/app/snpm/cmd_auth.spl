# snpm auth — Registry authentication

use app.snpm.config.{SnpmConfig}
use app.io.mod.{env_get}

fn cmd_auth(config: SnpmConfig, args: [text]):
    """Handle login, logout, and whoami."""
    if args.len() == 0:
        print "Usage: snpm login | snpm logout | snpm whoami"
        return

    val action = args[0]
    match action:
        "login":
            print "snpm: login to {config.registry_url}"
            print "  (interactive login not yet available)"
            print "  Set SNPM_TOKEN environment variable for auth"
        "logout":
            print "snpm: logged out from {config.registry_url}"
        "whoami":
            val token = env_get("SNPM_TOKEN")
            if token != "" and token != nil:
                print "(authenticated via SNPM_TOKEN)"
            else:
                print "snpm: not logged in"
        _:
            print "snpm: unknown auth action '{action}'"
