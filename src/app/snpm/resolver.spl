# snpm dependency resolver — resolves dependencies with semver constraints

use app.snpm.config.{SnpmConfig}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

class ResolvedPackage:
    name: text
    version: text
    resolved_url: text
    integrity: text
    dependencies: [Pair<text, text>]

    static fn create(name: text, version: text) -> ResolvedPackage:
        ResolvedPackage(
            name: name, version: version, resolved_url: "",
            integrity: "", dependencies: [Pair<text, text>]()
        )

fn resolve_dependencies(deps: [Pair<text, text>], config: SnpmConfig) -> [ResolvedPackage]:
    """Resolve all dependencies to exact versions."""
    var resolved = [ResolvedPackage]()
    var i = 0
    while i < deps.len():
        val dep = deps[i]
        val name = dep.first
        val constraint = dep.second

        # Check if already installed
        val pkg_dir = "{config.modules_dir}/{name}"
        if rt_file_exists(pkg_dir + "/package.sdn"):
            # Already installed — check version compatibility
            i = i + 1
            continue

        # Resolve from cache or registry
        val pkg = _resolve_single(name, constraint, config)
        resolved.push(pkg)
        i = i + 1
    resolved

fn _resolve_single(name: text, constraint: text, config: SnpmConfig) -> ResolvedPackage:
    """Resolve a single package to an exact version."""
    # Strip constraint prefix to get version
    var version = constraint
    if version.starts_with("^") or version.starts_with("~"):
        version = version.slice(1, version.len())
    elif version.starts_with(">="):
        version = version.slice(2, version.len())
    elif version == "*" or version == "":
        version = "latest"

    var pkg = ResolvedPackage.create(name, version)
    pkg.resolved_url = "{config.registry_url}/{name}/-/{name}-{version}.spk"
    pkg
