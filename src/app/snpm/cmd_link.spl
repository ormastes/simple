# snpm link — Symlink local package for development

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_mkdir(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_get_cwd() -> text

fn cmd_link(config: SnpmConfig, args: [text]):
    """Create a symlink in spl_modules/ to a local package."""
    if args.len() == 0:
        # Link current package globally
        if not rt_file_exists(config.manifest_name):
            print "snpm: no {config.manifest_name} found"
            return
        val manifest_result = parse_manifest(config.manifest_name)
        match manifest_result:
            Ok(manifest):
                val cwd = rt_get_cwd()
                print "snpm: linked {manifest.name} -> {cwd}"
            Err(msg):
                print "snpm: {msg}"
        return

    # Link a specific local path
    val target = args[0]
    if not rt_file_exists(target + "/package.sdn"):
        print "snpm: no package.sdn in {target}"
        return

    val target_manifest = parse_manifest(target + "/package.sdn")
    match target_manifest:
        Ok(manifest):
            rt_mkdir(config.modules_dir)
            val link_path = "{config.modules_dir}/{manifest.name}"
            val result = rt_process_run("ln", ["-sf", target, link_path])
            if result.2 == 0:
                print "snpm: {manifest.name} -> {target}"
            else:
                print "snpm: link failed"
        Err(msg):
            print "snpm: {msg}"
