# snpm — Simple Package Manager (npm-like)
# Full-featured package manager for Simple language projects.
#
# Usage:
#   simple snpm init                  — Create package.sdn
#   simple snpm install [pkg]         — Install dependencies
#   simple snpm uninstall <pkg>       — Remove package
#   simple snpm update [pkg]          — Update dependencies
#   simple snpm publish               — Publish to registry
#   simple snpm run <script>          — Run project script
#   simple snpm test                  — Run test script
#   simple snpm pack                  — Create .spk tarball
#   simple snpm link                  — Symlink local package
#   simple snpm list                  — Show dependency tree
#   simple snpm outdated              — Check for updates
#   simple snpm search <query>        — Search registry
#   simple snpm info <pkg>            — Package info
#   simple snpm login                 — Registry auth
#   simple snpm version [bump]        — Bump version

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

use app.snpm.config.{SnpmConfig, default_config}
use app.snpm.cmd_init.{cmd_init}
use app.snpm.cmd_install.{cmd_install}
use app.snpm.cmd_uninstall.{cmd_uninstall}
use app.snpm.cmd_run.{cmd_run}
use app.snpm.cmd_publish.{cmd_publish}
use app.snpm.cmd_list.{cmd_list}
use app.snpm.cmd_search.{cmd_search}
use app.snpm.cmd_pack.{cmd_pack}
use app.snpm.cmd_version.{cmd_version}
use app.snpm.cmd_auth.{cmd_auth}
use app.snpm.cmd_link.{cmd_link}
use app.snpm.cmd_update.{cmd_update}

fn _start():
    val args = _get_args()
    if args.len() == 0:
        _print_help()
        return

    val config = default_config()
    val command = args[0]
    var cmd_args = [text]()
    var i = 1
    while i < args.len():
        cmd_args.push(args[i])
        i = i + 1

    match command:
        "init":
            cmd_init(config, cmd_args)
        "install": cmd_install(config, cmd_args)
        "i": cmd_install(config, cmd_args)
        "add": cmd_install(config, cmd_args)
        "uninstall": cmd_uninstall(config, cmd_args)
        "remove": cmd_uninstall(config, cmd_args)
        "rm": cmd_uninstall(config, cmd_args)
        "update": cmd_update(config, cmd_args)
        "up": cmd_update(config, cmd_args)
        "publish": cmd_publish(config, cmd_args)
        "run": cmd_run(config, cmd_args)
        "test": cmd_run(config, ["test"])
        "start": cmd_run(config, ["start"])
        "pack": cmd_pack(config, cmd_args)
        "link": cmd_link(config, cmd_args)
        "list": cmd_list(config, cmd_args)
        "ls": cmd_list(config, cmd_args)
        "outdated": cmd_list(config, ["--outdated"])
        "search": cmd_search(config, cmd_args)
        "info": cmd_search(config, ["--info"] + cmd_args)
        "login": cmd_auth(config, ["login"])
        "logout": cmd_auth(config, ["logout"])
        "whoami": cmd_auth(config, ["whoami"])
        "version": cmd_version(config, cmd_args)
        "--version": print "snpm v0.9.5"
        "-v": print "snpm v0.9.5"
        "--help": _print_help()
        "-h": _print_help()
        _:
            print "snpm: unknown command '{command}'"
            print "Run 'snpm --help' for usage."

fn _print_help():
    print "snpm — Simple Package Manager"
    print ""
    print "Usage: simple snpm <command> [args]"
    print ""
    print "Commands:"
    print "  init                  Create package.sdn"
    print "  install [pkg[@ver]]   Install dependencies"
    print "  uninstall <pkg>       Remove package"
    print "  update [pkg]          Update dependencies"
    print "  publish               Publish to registry"
    print "  run <script>          Run project script"
    print "  test                  Run test script"
    print "  pack                  Create .spk tarball"
    print "  link                  Symlink local package"
    print "  list                  Show dependency tree"
    print "  outdated              Check for updates"
    print "  search <query>        Search registry"
    print "  info <pkg>            Package info"
    print "  login / logout        Registry authentication"
    print "  version [bump]        Bump version"
    print ""
    print "Aliases: i=install, rm=uninstall, up=update, ls=list"

fn _get_args() -> [text]:
    [text]()
