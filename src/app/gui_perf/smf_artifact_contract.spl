# Emit contract-only evidence for a GUI SMF dynlib artifact.

use app.gui_perf.smf_dynlib_artifact.{
    gui_smf_artifact_contract,
    gui_smf_artifact_contract_missing,
    gui_smf_artifact_contract_row
}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn main() -> i64:
    val artifact = _env_or("SIMPLE_GUI_DYNLIB_ARTIFACT", "build/gui/pure_gui_hot.smf")
    val symbol = _env_or("SIMPLE_GUI_DYNLIB_SYMBOL", "gui_dynlib_hot_probe_tick")
    if artifact == "":
        print gui_smf_artifact_contract_row(gui_smf_artifact_contract_missing("", symbol))
        return 1
    val bytes = rt_file_read_bytes(artifact) ?? []
    if bytes.len() == 0:
        print gui_smf_artifact_contract_row(gui_smf_artifact_contract_missing(artifact, symbol))
        return 1
    val contract = gui_smf_artifact_contract(artifact, bytes, symbol)
    print gui_smf_artifact_contract_row(contract)
    if contract.status == "pass":
        return 0
    1
