# Validate a saved macOS SMF/dynlib evidence transcript.

use app.gui_perf.macos_smf_dynlib_evidence_core.{gui_mac_smf_dynlib_transcript_check_row}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn main() -> i64:
    val path = _env_or("SIMPLE_GUI_DYNLIB_TRANSCRIPT", "")
    if path == "":
        print "GUI_MAC_SMF_DYNLIB_TRANSCRIPT status=fail reason=missing-transcript-path"
        return 1
    val transcript = rt_file_read_text(path)
    val row = gui_mac_smf_dynlib_transcript_check_row(transcript)
    print row
    if row.contains("status=pass"):
        return 0
    1
