# Linux repeatable SMF dynlib hot-response gate.

use app.gui_perf.macos_smf_dynlib_evidence_core.{
    gui_mac_smf_dynlib_shell_quote,
    gui_mac_smf_dynlib_env_assign,
    gui_mac_smf_dynlib_select_stdout_row,
    gui_mac_smf_dynlib_row_kind,
    gui_mac_smf_dynlib_row_has,
    gui_mac_smf_dynlib_row_key_count,
    gui_mac_smf_dynlib_row_value,
    gui_mac_smf_dynlib_evidence_token,
    gui_mac_smf_dynlib_unsigned_decimal_token
}

extern fn rt_env_get(key: text) -> text
extern fn rt_platform_name() -> text
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

class GuiLinuxSmfDynlibE2ePaths:
    simple_bin: text
    build_dir: text
    dynlib_path: text
    smf_path: text
    wrapper_path: text
    probe_path: text

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _shell(command: text, timeout_ms: i64) -> (text, text, i32):
    rt_process_run_timeout("/bin/sh", ["-c", command], timeout_ms)

fn gui_linux_smf_dynlib_e2e_default_paths(simple_bin: text) -> GuiLinuxSmfDynlibE2ePaths:
    GuiLinuxSmfDynlibE2ePaths(
        simple_bin: simple_bin,
        build_dir: "build/gui",
        dynlib_path: "build/gui/libpure_gui_hot.so",
        smf_path: "build/gui/pure_gui_hot.smf",
        wrapper_path: "build/gui/smf_wrap_host_dynlib",
        probe_path: "build/gui/smf_dynlib_probe"
    )

fn gui_linux_smf_dynlib_e2e_mkdir_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    "mkdir -p " + gui_mac_smf_dynlib_shell_quote(paths.build_dir)

fn gui_linux_smf_dynlib_e2e_compile_dynlib_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    "SIMPLE_LIB=src " + gui_mac_smf_dynlib_shell_quote(paths.simple_bin) +
    " compile src/app/gui_perf/pure_gui_hot_dynlib_export.spl --native --shared --strip -o " +
    gui_mac_smf_dynlib_shell_quote(paths.dynlib_path)

fn gui_linux_smf_dynlib_e2e_compile_wrapper_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    "SIMPLE_LIB=src " + gui_mac_smf_dynlib_shell_quote(paths.simple_bin) +
    " compile src/app/gui_perf/smf_wrap_host_dynlib.spl --native --strip -o " +
    gui_mac_smf_dynlib_shell_quote(paths.wrapper_path)

fn gui_linux_smf_dynlib_e2e_compile_probe_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    "SIMPLE_LIB=src " + gui_mac_smf_dynlib_shell_quote(paths.simple_bin) +
    " compile src/app/gui_perf/smf_dynlib_probe.spl --native --strip -o " +
    gui_mac_smf_dynlib_shell_quote(paths.probe_path)

fn gui_linux_smf_dynlib_e2e_wrap_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_ARCH", "x86_64") + " " +
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_INPUT", paths.dynlib_path) + " " +
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_SMF_OUTPUT", paths.smf_path) + " " +
    gui_mac_smf_dynlib_shell_quote(paths.wrapper_path)

fn gui_linux_smf_dynlib_e2e_probe_command(paths: GuiLinuxSmfDynlibE2ePaths) -> text:
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_ARCH", "x86_64") + " " +
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_ARTIFACT", paths.smf_path) + " " +
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_HOST_PROFILE", "linux-x86_64") + " " +
    gui_mac_smf_dynlib_env_assign("SIMPLE_GUI_DYNLIB_HOST_CPU", gui_mac_smf_dynlib_evidence_token(_env_or("SIMPLE_GUI_DYNLIB_HOST_CPU", "linux-x86_64"))) + " " +
    gui_mac_smf_dynlib_shell_quote(paths.probe_path)

fn gui_linux_smf_dynlib_e2e_accepts_probe_row(row: text) -> bool:
    val p99_text = gui_mac_smf_dynlib_row_value(row, "p99_us")
    gui_mac_smf_dynlib_row_kind(row, "GUI_DYNLIB_PERF") and
    gui_mac_smf_dynlib_row_has(row, "artifact", "build/gui/pure_gui_hot.smf") and
    gui_mac_smf_dynlib_row_has(row, "dynlib_path", "build/gui/pure_gui_hot.smf.extracted.so") and
    gui_mac_smf_dynlib_row_has(row, "host_os", "linux") and
    gui_mac_smf_dynlib_row_has(row, "host_arch", "x86_64") and
    gui_mac_smf_dynlib_row_has(row, "host_profile", "linux-x86_64") and
    gui_mac_smf_dynlib_row_has(row, "loader", "smf_dynlib") and
    gui_mac_smf_dynlib_row_has(row, "dynload", "smf_dynlib") and
    gui_mac_smf_dynlib_row_has(row, "host_dynload", "sffi") and
    gui_mac_smf_dynlib_row_has(row, "symbol", "gui_dynlib_hot_probe_tick") and
    gui_mac_smf_dynlib_row_has(row, "call_source", "dynlib_symbol_call") and
    gui_mac_smf_dynlib_row_has(row, "pass", "true") and
    gui_mac_smf_dynlib_row_key_count(row, "error") == 1 and
    gui_mac_smf_dynlib_row_key_count(row, "p99_us") == 1 and
    gui_mac_smf_dynlib_row_key_count(row, "threshold_us") == 1 and
    gui_mac_smf_dynlib_row_has(row, "samples", "128") and
    gui_mac_smf_dynlib_row_has(row, "expected_samples", "128") and
    gui_mac_smf_dynlib_row_has(row, "threshold_us", "1000") and
    gui_mac_smf_dynlib_unsigned_decimal_token(p99_text) and
    p99_text.len() <= 3

fn gui_linux_smf_dynlib_e2e_probe_reject_reason(row: text) -> text:
    if row == "":
        return "missing-or-duplicate-probe-row"
    if not gui_mac_smf_dynlib_row_kind(row, "GUI_DYNLIB_PERF"):
        return "wrong-row-kind"
    if not gui_mac_smf_dynlib_row_has(row, "artifact", "build/gui/pure_gui_hot.smf"):
        return "wrong-artifact"
    if not gui_mac_smf_dynlib_row_has(row, "dynlib_path", "build/gui/pure_gui_hot.smf.extracted.so"):
        return "wrong-dynlib-path"
    if not gui_mac_smf_dynlib_row_has(row, "host_os", "linux"):
        return "wrong-host-os"
    if not gui_mac_smf_dynlib_row_has(row, "host_arch", "x86_64"):
        return "wrong-host-arch"
    if not gui_mac_smf_dynlib_row_has(row, "host_profile", "linux-x86_64"):
        return "wrong-host-profile"
    if not gui_mac_smf_dynlib_row_has(row, "loader", "smf_dynlib"):
        return "wrong-loader"
    if not gui_mac_smf_dynlib_row_has(row, "dynload", "smf_dynlib"):
        return "wrong-dynload"
    if not gui_mac_smf_dynlib_row_has(row, "host_dynload", "sffi"):
        return "wrong-host-dynload"
    if not gui_mac_smf_dynlib_row_has(row, "symbol", "gui_dynlib_hot_probe_tick"):
        return "wrong-symbol"
    if not gui_mac_smf_dynlib_row_has(row, "call_source", "dynlib_symbol_call"):
        return "wrong-call-source"
    if not gui_mac_smf_dynlib_row_has(row, "pass", "true"):
        return "probe-failed"
    if gui_mac_smf_dynlib_row_key_count(row, "error") != 1:
        return "bad-error-field-count"
    if gui_mac_smf_dynlib_row_key_count(row, "p99_us") != 1:
        return "bad-p99-field-count"
    if gui_mac_smf_dynlib_row_key_count(row, "threshold_us") != 1:
        return "bad-threshold-field-count"
    val p99_text = gui_mac_smf_dynlib_row_value(row, "p99_us")
    if not gui_mac_smf_dynlib_row_has(row, "samples", "128"):
        return "wrong-samples-" + gui_mac_smf_dynlib_row_value(row, "samples")
    if not gui_mac_smf_dynlib_row_has(row, "expected_samples", "128"):
        return "wrong-expected-samples"
    if not gui_mac_smf_dynlib_row_has(row, "threshold_us", "1000"):
        return "wrong-threshold"
    if p99_text == "":
        return "missing-p99"
    if not gui_mac_smf_dynlib_unsigned_decimal_token(p99_text):
        return "bad-p99-token"
    if p99_text.len() > 3:
        return "p99-over-threshold"
    ""

fn _run_step(name: text, command: text, timeout_ms: i64) -> bool:
    val (stdout, stderr, code) = _shell(command, timeout_ms)
    if stdout.trim() != "":
        print stdout.trim()
    if code != 0:
        print "GUI_LINUX_SMF_DYNLIB_E2E_GATE status=fail step=" + name + " exit_code=" + code.to_text() + " stderr=" + stderr.replace("\n", " ").trim()
        return false
    true

fn main() -> i64:
    if rt_platform_name() != "linux":
        print "GUI_LINUX_SMF_DYNLIB_E2E_GATE status=skip reason=requires-linux"
        return 0
    val paths = gui_linux_smf_dynlib_e2e_default_paths(_env_or("SIMPLE_BIN", "src/compiler_rust/target/debug/simple"))
    if not _run_step("mkdir", gui_linux_smf_dynlib_e2e_mkdir_command(paths), 5000):
        return 1
    if not _run_step("compile-dynlib", gui_linux_smf_dynlib_e2e_compile_dynlib_command(paths), 240000):
        return 1
    if not _run_step("compile-wrapper", gui_linux_smf_dynlib_e2e_compile_wrapper_command(paths), 120000):
        return 1
    if not _run_step("compile-probe", gui_linux_smf_dynlib_e2e_compile_probe_command(paths), 120000):
        return 1
    if not _run_step("wrap-smf", gui_linux_smf_dynlib_e2e_wrap_command(paths), 30000):
        return 1
    val (probe_out, probe_err, probe_code) = _shell(gui_linux_smf_dynlib_e2e_probe_command(paths), 30000)
    if probe_out.trim() != "":
        print probe_out.trim()
    val row = gui_mac_smf_dynlib_select_stdout_row(probe_out, "GUI_DYNLIB_PERF")
    val reject_reason = gui_linux_smf_dynlib_e2e_probe_reject_reason(row)
    if probe_code != 0 or reject_reason != "":
        print "GUI_LINUX_SMF_DYNLIB_E2E_GATE status=fail step=probe-smf reason=" + reject_reason + " exit_code=" + probe_code.to_text() + " stderr=" + probe_err.replace("\n", " ").trim()
        return 1
    print "GUI_LINUX_SMF_DYNLIB_E2E_GATE status=pass artifact=build/gui/pure_gui_hot.smf dynload=smf_dynlib host_dynload=sffi"
    0
