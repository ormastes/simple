# Pure GUI hot-path dynamic-library export.
#
# This source is intentionally i64-only for the current SFFI/dynlib call ABI.
# It mirrors the pure GUI command-count probe without importing WM, web
# renderer, native GUI runtime, or pixel-rendering code.

fn _pure_gui_hot_command_count(iteration: i64) -> i64:
    if iteration < 0:
        return 4
    4

@export("C")
fn gui_dynlib_hot_probe_tick(iteration: i64) -> i64:
    _pure_gui_hot_command_count(iteration)
