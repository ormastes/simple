# Pure GUI hot-path dynamic-library export.
#
# This source is intentionally i64-only for the current SFFI/dynlib call ABI.
# It delegates to the pure GUI command-count probe without importing WM, web
# renderer, native GUI runtime, or pixel-rendering code.

use std.gui.pure_core.{gui_representative_hot_probe_event_tick}

@export("C")
fn gui_dynlib_hot_probe_tick(iteration: i64, pointer_x: i64, pointer_y: i64, key_code: i64) -> i64:
    gui_representative_hot_probe_event_tick(iteration, pointer_x, pointer_y, key_code)
