# Emit SimpleOS SMF dynload evidence for a GUI SMF dynlib artifact.

use app.gui_perf.simpleos_smf_dynload.{gui_simpleos_smf_dynload_probe, gui_simpleos_smf_dynload_row}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn main() -> i64:
    val artifact = _env_or("SIMPLE_GUI_DYNLIB_ARTIFACT", "build/gui/pure_gui_hot.smf")
    val symbol = _env_or("SIMPLE_GUI_DYNLIB_SYMBOL", "gui_dynlib_hot_probe_tick")
    val bytes = if artifact == "": [] else: rt_file_read_bytes(artifact) ?? []
    val evidence = gui_simpleos_smf_dynload_probe(artifact, bytes, symbol)
    print gui_simpleos_smf_dynload_row(evidence)
    if evidence.pass:
        return 0
    1
