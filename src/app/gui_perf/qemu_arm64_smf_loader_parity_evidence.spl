# Emit loader-backed QEMU ARM64 parity evidence for a GUI SMF dynlib artifact.

use app.gui_perf.simpleos_smf_dynload.{gui_simpleos_smf_dynload_probe}
use app.gui_perf.qemu_arm64_smf_loader_parity.{gui_qemu_arm64_smf_loader_parity, gui_qemu_arm64_smf_loader_parity_row}
use std.gui.pure_core.{gui_pointer_event, gui_key_event, gui_dispatch_events, gui_empty_batch}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _representative_batch():
    gui_dispatch_events([
        gui_pointer_event("pointer_move", "button.save", 12, 24),
        gui_pointer_event("pointer_down", "button.save", 12, 24),
        gui_pointer_event("pointer_up", "button.save", 12, 24),
        gui_key_event("input.name", "A", "a")
    ], 0)

fn main() -> i64:
    val artifact = _env_or("SIMPLE_GUI_DYNLIB_ARTIFACT", "")
    val symbol = _env_or("SIMPLE_GUI_DYNLIB_SYMBOL", "gui_dynlib_hot_probe_tick")
    val bytes = if artifact == "": [] else: rt_file_read_bytes(artifact) ?? []
    val evidence = gui_simpleos_smf_dynload_probe(artifact, bytes, symbol)
    val batch = if evidence.pass: _representative_batch() else: gui_empty_batch()
    val parity = gui_qemu_arm64_smf_loader_parity(evidence, batch)
    print gui_qemu_arm64_smf_loader_parity_row(parity)
    if parity.status == "loader-contract-pass":
        return 0
    1
