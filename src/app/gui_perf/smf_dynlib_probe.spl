# Pure GUI SMF/dynlib hot-response probe CLI.

use app.gui_perf.smf_dynlib_probe_core.{gui_dynlib_probe_config_from_env, gui_dynlib_probe_run}
use std.gui.pure_smf_dynlib_perf.{gui_dynlib_perf_report_row}

fn main() -> i64:
    val config = gui_dynlib_probe_config_from_env()
    val report = gui_dynlib_probe_run(config)
    print gui_dynlib_perf_report_row(report)
    if report.pass:
        return 0
    1
