# Emit contract-only QEMU ARM64 parity evidence for a GUI SMF dynlib artifact.

use app.gui_perf.smf_dynlib_artifact.{gui_smf_artifact_contract, gui_smf_artifact_contract_missing}
use app.gui_perf.qemu_arm64_smf_parity.{gui_qemu_arm64_smf_parity, gui_qemu_arm64_smf_parity_row}
use std.gui.pure_core.{gui_pointer_event, gui_key_event, gui_dispatch_events, gui_empty_batch}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _representative_batch():
    gui_dispatch_events([
        gui_pointer_event("pointer_move", "button.save", 12, 24),
        gui_pointer_event("pointer_down", "button.save", 12, 24),
        gui_pointer_event("pointer_up", "button.save", 12, 24),
        gui_key_event("input.name", "A", "a")
    ], 0)

fn main() -> i64:
    val artifact = _env_or("SIMPLE_GUI_DYNLIB_ARTIFACT", "")
    val symbol = _env_or("SIMPLE_GUI_DYNLIB_SYMBOL", "gui_dynlib_hot_probe_tick")
    if artifact == "":
        val missing = gui_smf_artifact_contract_missing("", symbol)
        print gui_qemu_arm64_smf_parity_row(gui_qemu_arm64_smf_parity(missing, gui_empty_batch()))
        return 1
    val bytes = rt_file_read_bytes(artifact) ?? []
    if bytes.len() == 0:
        val missing = gui_smf_artifact_contract_missing(artifact, symbol)
        print gui_qemu_arm64_smf_parity_row(gui_qemu_arm64_smf_parity(missing, gui_empty_batch()))
        return 1
    val contract = gui_smf_artifact_contract(artifact, bytes, symbol)
    val parity = gui_qemu_arm64_smf_parity(contract, _representative_batch())
    print gui_qemu_arm64_smf_parity_row(parity)
    if parity.status == "contract-pass":
        return 0
    1
