# MD Diagram Scanner — parse <!-- sdn-diagram:id=... --> regions from Markdown

struct SdnDiagramRegion:
    id: text
    start_line: i64
    end_line: i64
    sdn_source: text
    existing_hash: text
    ascii_content: text
    layout: text
    direction: text

fn scan_diagram_regions(content: text) -> [SdnDiagramRegion]:
    val lines = content.split("\n")
    var regions = [SdnDiagramRegion][]
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("<!-- sdn-diagram:id="):
            val id = _extract_comment_id(line)
            if id != "":
                val region = _scan_one_region(lines, i, id)
                if region.id != "":
                    regions.push(region)
        i = i + 1
    regions

fn _extract_comment_id(line: text) -> text:
    val prefix = "<!-- sdn-diagram:id="
    if not line.starts_with(prefix):
        return ""
    val rest = line.replace(prefix, "")
    val end_idx = rest.index_of(" ")
    if end_idx < 0:
        val end_idx2 = rest.index_of("-")
        if end_idx2 < 0:
            return ""
        return rest.replace(" -->", "").trim()
    rest.replace(" -->", "").trim()

fn _scan_one_region(lines: [text], start: i64, id: text) -> SdnDiagramRegion:
    var end_line = -1
    var sdn_source = ""
    var existing_hash = ""
    var ascii_content = ""
    var layout = "dag"
    var direction = "LR"
    var in_sdn_fence = false
    var in_ascii_fence = false
    var i = start + 1
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()
        if trimmed == "<!-- sdn-diagram:end -->":
            end_line = i
            break
        if trimmed.starts_with("```sdn"):
            val attrs = _parse_fence_attrs(trimmed)
            existing_hash = _get_attr(attrs, "hash")
            in_sdn_fence = true
            i = i + 1
            continue
        if in_sdn_fence and trimmed == "```":
            in_sdn_fence = false
            i = i + 1
            continue
        if in_sdn_fence:
            if sdn_source != "":
                sdn_source = sdn_source + "\n"
            sdn_source = sdn_source + line
            if trimmed.starts_with("@layout "):
                layout = trimmed.replace("@layout ", "").trim()
            elif trimmed.starts_with("@direction "):
                direction = trimmed.replace("@direction ", "").trim()
            i = i + 1
            continue
        if trimmed.starts_with("```ascii"):
            in_ascii_fence = true
            i = i + 1
            continue
        if in_ascii_fence and trimmed == "```":
            in_ascii_fence = false
            i = i + 1
            continue
        if in_ascii_fence:
            if ascii_content != "":
                ascii_content = ascii_content + "\n"
            ascii_content = ascii_content + line
        i = i + 1
    if end_line < 0:
        return SdnDiagramRegion {
            id: "", start_line: start, end_line: start,
            sdn_source: "", existing_hash: "", ascii_content: "",
            layout: layout, direction: direction
        }
    SdnDiagramRegion {
        id: id, start_line: start, end_line: end_line,
        sdn_source: sdn_source, existing_hash: existing_hash,
        ascii_content: ascii_content, layout: layout, direction: direction
    }

struct FenceAttr:
    key: text
    value: text

fn _parse_fence_attrs(fence_line: text) -> [FenceAttr]:
    var attrs = [FenceAttr][]
    val parts = fence_line.replace("```sdn", "").replace("```ascii", "").trim().split(" ")
    for part in parts:
        val trimmed = part.trim()
        if trimmed == "":
            continue
        val eq_idx = trimmed.index_of("=")
        if eq_idx > 0:
            val key = trimmed.substring(0, eq_idx)
            val value = trimmed.substring(eq_idx + 1, trimmed.len())
            attrs.push(FenceAttr { key: key, value: value })
    attrs

fn _get_attr(attrs: [FenceAttr], key: text) -> text:
    for attr in attrs:
        if attr.key == key:
            return attr.value
    ""

fn preprocess_sdn_source(raw_sdn: text) -> (text, text, text):
    val lines = raw_sdn.split("\n")
    var cleaned = ""
    var layout = "dag"
    var direction = "LR"
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("@layout "):
            layout = trimmed.replace("@layout ", "").trim()
            continue
        if trimmed.starts_with("@direction "):
            direction = trimmed.replace("@direction ", "").trim()
            val dir_line = "direction: " + direction
            if cleaned != "":
                cleaned = cleaned + "\n"
            cleaned = cleaned + dir_line
            continue
        if cleaned != "":
            cleaned = cleaned + "\n"
        cleaned = cleaned + line
    (cleaned, layout, direction)
