# MD Diagram Update — scan Markdown files, update stale SDN diagrams

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help}
use app.io.mod (dir_walk, file_read, file_write, file_exists, cwd)
use std.log.{error, info}
use std.editor.services.sdn_graph.{sdn_graph_parse}
use std.editor.services.sdn_graph_ascii.{sdn_graph_render_ascii}
use app.md_diagram_update.scanner.{scan_diagram_regions, preprocess_sdn_source}
use app.md_diagram_update.canonical.{canonical_hash}
use app.md_diagram_update.block.{emit_diagram_block}

fn print_help():
    print "Usage: simple md-diagram-update [options] [file.md ...]"
    print ""
    print "Scan Markdown files for SDN diagram blocks and update stale ASCII art."
    print ""
    print "Options:"
    print "  --check      Dry-run: exit 1 if any diagrams are stale"
    print "  --json       Output results as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg.starts_with("--log-") or arg.starts_with("--surface") or arg.starts_with("--progress")

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("md-diagram-update", log_opts.error)
        return 1

    var check_only = false
    var as_json = false
    var target_files = [text][]

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--check":
            check_only = true
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif arg.ends_with(".md"):
            target_files.push(arg)
        ai = ai + 1

    if target_files.len() == 0:
        val root = cwd()
        target_files = _collect_md_files(root)

    var total_stale = 0
    var total_updated = 0
    var files_changed = [text][]

    for fpath in target_files:
        val content = file_read(fpath)
        if content == "":
            continue
        val regions = scan_diagram_regions(content)
        if regions.len() == 0:
            continue
        var file_changed = false
        var new_content = content
        var offset = 0
        for region in regions:
            if region.id == "":
                continue
            val preprocess = preprocess_sdn_source(region.sdn_source)
            val cleaned_sdn = preprocess[0]
            val layout = preprocess[1]
            val direction = preprocess[2]
            val graph = sdn_graph_parse(cleaned_sdn)
            val new_hash = canonical_hash(graph, layout, direction)
            if new_hash == region.existing_hash:
                continue
            total_stale = total_stale + 1
            if check_only:
                if not as_json:
                    print "STALE: {fpath} diagram '{region.id}' (hash {region.existing_hash} != {new_hash})"
                continue
            val ascii = sdn_graph_render_ascii(graph, layout, direction)
            val new_block = emit_diagram_block(region.id, region.sdn_source, new_hash, ascii)
            new_content = _replace_region(new_content, region.start_line + offset, region.end_line + offset, new_block)
            val old_span = region.end_line - region.start_line + 1
            val new_span = new_block.split("\n").len()
            offset = offset + (new_span - old_span)
            file_changed = true
            total_updated = total_updated + 1
        if file_changed and not check_only:
            file_write(fpath, new_content)
            files_changed.push(fpath)

    if as_json:
        var json = "{\"stale\":" + str(total_stale) + ",\"updated\":" + str(total_updated) + ",\"files\":["
        var fi = 0
        for fc in files_changed:
            if fi > 0:
                json = json + ","
            json = json + "\"" + fc + "\""
            fi = fi + 1
        json = json + "]}"
        print json
    elif not check_only:
        if total_updated > 0:
            print "Updated {str(total_updated)} diagram(s) in {str(files_changed.len())} file(s)."
        else:
            print "All diagrams are up to date."
    elif total_stale > 0:
        print "{str(total_stale)} stale diagram(s) found. Run 'simple md-diagram-update' to fix."

    if total_stale > 0:
        return 1
    0

fn _collect_md_files(root: text) -> [text]:
    var result = [text][]
    val entries = dir_walk(root)
    for entry in entries:
        if entry.ends_with(".md"):
            result.push(entry)
    result

fn _replace_region(content: text, start_line: i64, end_line: i64, replacement: text) -> text:
    val lines = content.split("\n")
    var result = ""
    var i = 0
    while i < lines.len():
        if i == start_line:
            if result != "":
                result = result + "\n"
            result = result + replacement
            i = end_line + 1
            continue
        if result != "":
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result
