# Simple Tool - cat
#
# Concatenate files and print to stdout.

use std.cli.cli_util (get_cli_args)
use app.io.mod (file_exists, file_read, eprint)
use app.tools.common.args (parse_args, has_flag)
use app.tools.common.stdio (read_stdin_text)

fn print_help():
    print "Usage: cat [OPTIONS] [FILE...]"
    print ""
    print "Concatenate FILE(s) to standard output."
    print "With no FILE, or when FILE is -, read standard input."
    print ""
    print "Options:"
    print "  -n          Number all output lines"
    print "  -b          Number nonempty output lines"
    print "  -s          Suppress repeated empty output lines"
    print "  --help      Display this help"

fn main() -> i64:
    val args = get_cli_args()
    val parsed = parse_args(args)

    if has_flag(parsed, "", "help"):
        print_help()
        return 0

    val number_all = has_flag(parsed, "n", "number")
    val number_nonempty = has_flag(parsed, "b", "number-nonblank")
    val squeeze_blank = has_flag(parsed, "s", "squeeze-blank")

    val files = parsed.positional
    var exit_code = 0
    var line_num = 1
    var prev_blank = false

    if files.len() == 0:
        val content = read_stdin_text()
        val lines = content.split("\n")
        for line in lines:
            val is_blank = line.trim().len() == 0
            if squeeze_blank and is_blank and prev_blank:
                prev_blank = true
            else:
                if number_nonempty:
                    if is_blank:
                        print ""
                    else:
                        print "     {line_num}\t{line}"
                        line_num = line_num + 1
                elif number_all:
                    print "     {line_num}\t{line}"
                    line_num = line_num + 1
                else:
                    print line
                prev_blank = is_blank
    else:
        for path in files:
            if path == "-":
                val content = read_stdin_text()
                val lines = content.split("\n")
                for line in lines:
                    val is_blank = line.trim().len() == 0
                    if squeeze_blank and is_blank and prev_blank:
                        prev_blank = true
                    else:
                        if number_nonempty:
                            if is_blank:
                                print ""
                            else:
                                print "     {line_num}\t{line}"
                                line_num = line_num + 1
                        elif number_all:
                            print "     {line_num}\t{line}"
                            line_num = line_num + 1
                        else:
                            print line
                        prev_blank = is_blank
            elif not file_exists(path):
                eprint("cat: {path}: No such file or directory")
                exit_code = 1
            else:
                val content = file_read(path)
                val lines = content.split("\n")
                for line in lines:
                    val is_blank = line.trim().len() == 0
                    if squeeze_blank and is_blank and prev_blank:
                        prev_blank = true
                    else:
                        if number_nonempty:
                            if is_blank:
                                print ""
                            else:
                                print "     {line_num}\t{line}"
                                line_num = line_num + 1
                        elif number_all:
                            print "     {line_num}\t{line}"
                            line_num = line_num + 1
                        else:
                            print line
                        prev_blank = is_blank

    exit_code
