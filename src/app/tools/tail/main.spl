# Simple Tool - tail
#
# Output the last part of files.

use std.cli.cli_util (get_cli_args)
use app.io.mod (file_exists, file_read, eprint)
use app.tools.common.args (parse_args, has_flag, get_option)
use app.tools.common.stdio (read_stdin_text)

fn print_help():
    print "Usage: tail [OPTIONS] [FILE...]"
    print ""
    print "Print the last 10 lines of each FILE to standard output."
    print "With no FILE, read standard input."
    print ""
    print "Options:"
    print "  -n NUM      Print the last NUM lines (default: 10)"
    print "  -c NUM      Print the last NUM bytes"
    print "  -q          Never print headers giving file names"
    print "  -v          Always print headers giving file names"
    print "  --help      Display this help"

fn tail_lines(content: text, n: i64) -> text:
    """Get last n lines of content."""
    val lines = content.split("\n")
    if n >= lines.len():
        return content
    val start = lines.len() - n
    var result: [text] = []
    var i = start
    while i < lines.len():
        result.push(lines[i])
        i = i + 1
    result.join("\n")

fn tail_bytes(content: text, n: i64) -> text:
    """Get last n bytes of content."""
    if n >= content.len():
        return content
    content[content.len() - n:]

fn main() -> i64:
    val args = get_cli_args()
    val parsed = parse_args(args)

    if has_flag(parsed, "", "help"):
        print_help()
        return 0

    val quiet = has_flag(parsed, "q", "quiet")
    val verbose = has_flag(parsed, "v", "verbose")

    val n_str = get_option(parsed, "n", "")
    val c_str = get_option(parsed, "c", "")

    var num_lines = 10
    var use_bytes = false
    var num_bytes = 0

    if n_str.len() > 0:
        num_lines = n_str.to_int()
    if c_str.len() > 0:
        use_bytes = true
        num_bytes = c_str.to_int()

    val files = parsed.positional
    var exit_code = 0
    val show_header = (files.len() > 1 and not quiet) or verbose

    if files.len() == 0:
        val content = read_stdin_text()
        if use_bytes:
            print tail_bytes(content, num_bytes)
        else:
            print tail_lines(content, num_lines)
    else:
        var file_idx = 0
        for path in files:
            if not file_exists(path):
                eprint("tail: cannot open '{path}' for reading: No such file or directory")
                exit_code = 1
            else:
                if show_header:
                    if file_idx > 0:
                        print ""
                    print "==> {path} <=="
                val content = file_read(path)
                if use_bytes:
                    print tail_bytes(content, num_bytes)
                else:
                    print tail_lines(content, num_lines)
            file_idx = file_idx + 1

    exit_code
