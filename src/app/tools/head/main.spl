# Simple Tool - head
#
# Output the first part of files.

use std.cli.cli_util (get_cli_args)
use app.io.mod (file_exists, file_read, eprint)
use app.tools.common.args (parse_args, has_flag, get_option)
use app.tools.common.stdio (read_stdin_text)

fn print_help():
    print "Usage: head [OPTIONS] [FILE...]"
    print ""
    print "Print the first 10 lines of each FILE to standard output."
    print "With no FILE, read standard input."
    print ""
    print "Options:"
    print "  -n NUM      Print the first NUM lines (default: 10)"
    print "  -c NUM      Print the first NUM bytes"
    print "  -q          Never print headers giving file names"
    print "  -v          Always print headers giving file names"
    print "  --help      Display this help"

fn head_lines(content: text, n: i64) -> text:
    """Get first n lines of content."""
    val lines = content.split("\n")
    var result: [text] = []
    var count = 0
    for line in lines:
        if count >= n:
            return result.join("\n")
        result.push(line)
        count = count + 1
    result.join("\n")

fn head_bytes(content: text, n: i64) -> text:
    """Get first n bytes of content."""
    if n >= content.len():
        return content
    content[:n]

fn main() -> i64:
    val args = get_cli_args()
    val parsed = parse_args(args)

    if has_flag(parsed, "", "help"):
        print_help()
        return 0

    val quiet = has_flag(parsed, "q", "quiet")
    val verbose = has_flag(parsed, "v", "verbose")

    val n_str = get_option(parsed, "n", "")
    val c_str = get_option(parsed, "c", "")

    # Check for -n and -c in short flags (e.g., -n5 pattern)
    var num_lines = 10
    var use_bytes = false
    var num_bytes = 0

    if n_str.len() > 0:
        num_lines = n_str.to_int()
    if c_str.len() > 0:
        use_bytes = true
        num_bytes = c_str.to_int()

    # Handle -NUM shorthand (parse short flags for digits)
    for f in parsed.flags:
        if f == "n" or f == "c" or f == "q" or f == "v":
            pass
        # Digit flags would be positional

    val files = parsed.positional

    # Check if positional args start with a number (for -N shorthand)
    if files.len() > 0 and files[0].starts_with("-"):
        val maybe_num = files[0][1:]
        if maybe_num.len() > 0:
            val parsed_num = maybe_num.to_int()
            if parsed_num > 0:
                num_lines = parsed_num

    var exit_code = 0
    val show_header = (files.len() > 1 and not quiet) or verbose

    if files.len() == 0:
        val content = read_stdin_text()
        if use_bytes:
            print head_bytes(content, num_bytes)
        else:
            print head_lines(content, num_lines)
    else:
        var file_idx = 0
        for path in files:
            if not file_exists(path):
                eprint("head: cannot open '{path}' for reading: No such file or directory")
                exit_code = 1
            else:
                if show_header:
                    if file_idx > 0:
                        print ""
                    print "==> {path} <=="
                val content = file_read(path)
                if use_bytes:
                    print head_bytes(content, num_bytes)
                else:
                    print head_lines(content, num_lines)
            file_idx = file_idx + 1

    exit_code
