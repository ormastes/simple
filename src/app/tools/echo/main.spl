# Simple Tool - echo
#
# Print arguments to stdout, separated by spaces.

use std.cli.cli_util (get_cli_args)

fn print_help():
    print "Usage: echo [OPTIONS] [STRING...]"
    print ""
    print "Print STRING(s) to standard output."
    print ""
    print "Options:"
    print "  -n          Do not output trailing newline"
    print "  -e          Enable interpretation of backslash escapes"
    print "  --help      Display this help"

fn process_escapes(s: text) -> text:
    """Process backslash escape sequences."""
    var result = ""
    var i = 0
    while i < s.len():
        if s[i:i + 1] == "\\" and i + 1 < s.len():
            val next = s[i + 1:i + 2]
            if next == "n":
                result = result + "\n"
                i = i + 2
            elif next == "t":
                result = result + "\t"
                i = i + 2
            elif next == "\\":
                result = result + "\\"
                i = i + 2
            else:
                result = result + s[i:i + 1]
                i = i + 1
        else:
            result = result + s[i:i + 1]
            i = i + 1
    result

fn main() -> i64:
    val args = get_cli_args()

    var no_newline = false
    var escape = false
    var strings: [text] = []
    var flags_done = false

    for arg in args:
        if not flags_done:
            if arg == "--help":
                print_help()
                return 0
            elif arg == "-n":
                no_newline = true
            elif arg == "-e":
                escape = true
            elif arg == "-ne" or arg == "-en":
                no_newline = true
                escape = true
            else:
                flags_done = true
                strings.push(arg)
        else:
            strings.push(arg)

    var output = ""
    var i = 0
    for s in strings:
        if i > 0:
            output = output + " "
        if escape:
            output = output + process_escapes(s)
        else:
            output = output + s
        i = i + 1

    if no_newline:
        # Print without trailing newline
        val out = std.common.io.pipe.Stdout.new()
        val _ = out.write_text(output)
        val _ = out.flush()
    else:
        print output

    0
