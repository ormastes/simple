# Build All Tools
#
# Compiles all 14 standalone native tool binaries.

use std.cli.cli_util (get_cli_args)
use app.io.mod (process_run, file_exists, dir_create_all, eprint)

fn print_help():
    print "Usage: simple tools-build [OPTIONS]"
    print ""
    print "Build all standalone native tool binaries."
    print ""
    print "Options:"
    print "  --release    Build with optimizations"
    print "  --clean      Remove existing binaries first"
    print "  --help       Display this help"

fn build_tool(name: text, release: bool) -> bool:
    """Compile a single tool to a native binary."""
    val src = "src/app/tools/{name}/main.spl"
    val out = "bin/tools/{name}"

    if not file_exists(src):
        eprint("tools-build: source not found: {src}")
        return false

    var cmd = "bin/simple compile {src} -o {out}"
    if release:
        cmd = cmd + " --release"

    print "  Building {name}..."
    val result = process_run(cmd, "", 120000)
    if result.exit_code != 0:
        eprint("  FAILED: {name}")
        if result.stderr.len() > 0:
            eprint("  {result.stderr}")
        return false

    print "  OK: {out}"
    true

fn main() -> i64:
    val args = get_cli_args()

    var release = false
    var clean = false

    for arg in args:
        if arg == "--help":
            print_help()
            return 0
        elif arg == "--release":
            release = true
        elif arg == "--clean":
            clean = true

    val tools = [
        "echo", "cat", "wc", "head", "tail",
        "grep", "sort", "uniq", "cut", "tee",
        "find", "ls", "sed", "tr"
    ]

    # Ensure output directory exists
    dir_create_all("bin/tools")

    print "Building {tools.len()} tools..."
    if release:
        print "Mode: release"
    else:
        print "Mode: debug"
    print ""

    var success = 0
    var failed = 0

    for tool in tools:
        if build_tool(tool, release):
            success = success + 1
        else:
            failed = failed + 1

    print ""
    print "Results: {success} succeeded, {failed} failed out of {tools.len()} tools"

    if failed > 0:
        1
    else:
        0
