# Tools Common - Argument Parsing
#
# POSIX-style flag parsing for standalone tools.

struct ParsedArgs:
    """Parsed command-line arguments.

    flags: single-char flags (e.g., 'n', 'l', 'c')
    long_flags: long flags (e.g., "reverse", "number")
    options: key=value options (e.g., "delimiter" -> "\t")
    positional: non-flag arguments (files, patterns)
    """
    flags: [text]
    long_flags: [text]
    options: {text: text}
    positional: [text]

fn parse_args(args: [text]) -> ParsedArgs:
    """Parse POSIX-style arguments.

    Handles:
    - Combined short flags: -nlc -> flags ['n', 'l', 'c']
    - Long flags: --reverse -> long_flags ["reverse"]
    - Long options: --delimiter=X -> options {"delimiter": "X"}
    - Positional args: file.txt -> positional ["file.txt"]
    - -- stops flag parsing
    """
    var flags: [text] = []
    var long_flags: [text] = []
    var options: {text: text} = {}
    var positional: [text] = []
    var stop_flags = false

    for arg in args:
        if stop_flags:
            positional.push(arg)
        elif arg == "--":
            stop_flags = true
        elif arg.starts_with("--"):
            val rest = arg[2:]
            val eq_idx = rest.index_of("=")
            if eq_idx >= 0:
                val key = rest[:eq_idx]
                val value = rest[eq_idx + 1:]
                options[key] = value
            else:
                long_flags.push(rest)
        elif arg.starts_with("-") and arg.len() > 1:
            # Combined short flags like -nlc
            var i = 1
            while i < arg.len():
                flags.push(arg[i:i + 1])
                i = i + 1
        else:
            positional.push(arg)

    ParsedArgs(
        flags: flags,
        long_flags: long_flags,
        options: options,
        positional: positional
    )

fn has_flag(parsed: ParsedArgs, short: text, long: text) -> bool:
    """Check if a flag is present (short or long form)."""
    if short.len() > 0:
        for f in parsed.flags:
            if f == short:
                return true
    if long.len() > 0:
        for lf in parsed.long_flags:
            if lf == long:
                return true
    false

fn get_option(parsed: ParsedArgs, key: text, default: text) -> text:
    """Get an option value or default."""
    val v = parsed.options[key]
    if v != nil:
        v
    else:
        default
