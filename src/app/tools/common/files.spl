# Tools Common - File Helpers
#
# Common file reading patterns for tools.

use app.io.mod (file_exists, file_read)
use app.io.mod (eprint)
use app.tools.common.stdio (read_stdin_text)

fn read_file_or_stdin(path: text) -> text:
    """Read from file if path given, otherwise read from stdin.

    If path is empty or "-", reads from stdin.
    """
    if path == "" or path == "-":
        return read_stdin_text()
    if not file_exists(path):
        eprint("{path}: No such file or directory")
        return ""
    file_read(path)

fn read_file_lines(path: text) -> [text]:
    """Read file and split into lines."""
    val content = read_file_or_stdin(path)
    if content.len() == 0:
        return []
    content.split("\n")

fn process_files_or_stdin(paths: [text], handler: fn(text, text)):
    """Process multiple files or stdin if no files given.

    Calls handler(filename, content) for each file.
    """
    if paths.len() == 0:
        val content = read_stdin_text()
        handler("-", content)
    else:
        for path in paths:
            val content = read_file_or_stdin(path)
            handler(path, content)
