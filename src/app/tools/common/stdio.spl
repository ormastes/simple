# Tools Common - Standard I/O Helpers
#
# Shared utilities for reading from stdin or files.

use std.common.io.pipe.{Stdin}

fn read_stdin_text() -> text:
    """Read all text from stdin until EOF."""
    val input = Stdin.new()
    val result = input.read_text()
    if result.is_ok():
        result.unwrap()
    else:
        ""

fn read_stdin_lines() -> [text]:
    """Read all lines from stdin."""
    val content = read_stdin_text()
    if content.len() == 0:
        return []
    content.split("\n")
