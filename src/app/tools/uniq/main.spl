# Simple Tool - uniq
#
# Report or omit repeated lines.

use std.cli.cli_util (get_cli_args)
use app.io.mod (file_exists, file_read, eprint)
use app.tools.common.args (parse_args, has_flag)
use app.tools.common.files (read_file_or_stdin)

fn print_help():
    print "Usage: uniq [OPTIONS] [INPUT [OUTPUT]]"
    print ""
    print "Filter adjacent matching lines from INPUT."
    print "With no INPUT, read standard input."
    print ""
    print "Options:"
    print "  -c          Prefix lines by the number of occurrences"
    print "  -d          Only print duplicate lines"
    print "  -u          Only print unique lines"
    print "  -i          Ignore differences in case when comparing"
    print "  --help      Display this help"

fn lines_equal(a: text, b: text, ignore_case: bool) -> bool:
    """Compare two lines, optionally ignoring case."""
    if ignore_case:
        a.lower() == b.lower()
    else:
        a == b

fn main() -> i64:
    val args = get_cli_args()
    val parsed = parse_args(args)

    if has_flag(parsed, "", "help"):
        print_help()
        return 0

    val show_count = has_flag(parsed, "c", "count")
    val duplicates_only = has_flag(parsed, "d", "repeated")
    val unique_only = has_flag(parsed, "u", "")
    val ignore_case = has_flag(parsed, "i", "ignore-case")

    val positional = parsed.positional
    val input_path = if positional.len() > 0: positional[0] else: ""

    val content = read_file_or_stdin(input_path)
    val lines = content.split("\n")

    # Remove trailing empty line
    var input_lines: [text] = []
    for line in lines:
        input_lines.push(line)
    if input_lines.len() > 0 and input_lines[input_lines.len() - 1] == "":
        input_lines = input_lines[:input_lines.len() - 1]

    if input_lines.len() == 0:
        return 0

    var prev_line = input_lines[0]
    var count = 1
    var i = 1

    while i < input_lines.len():
        val current = input_lines[i]
        if lines_equal(current, prev_line, ignore_case):
            count = count + 1
        else:
            # Output prev_line with its count
            val should_print = (not duplicates_only and not unique_only) or (duplicates_only and count > 1) or (unique_only and count == 1)
            if should_print:
                if show_count:
                    var count_str = "{count}"
                    while count_str.len() < 7:
                        count_str = " " + count_str
                    print "{count_str} {prev_line}"
                else:
                    print prev_line
            prev_line = current
            count = 1
        i = i + 1

    # Output last group
    val should_print = (not duplicates_only and not unique_only) or (duplicates_only and count > 1) or (unique_only and count == 1)
    if should_print:
        if show_count:
            var count_str = "{count}"
            while count_str.len() < 7:
                count_str = " " + count_str
            print "{count_str} {prev_line}"
        else:
            print prev_line

    0
