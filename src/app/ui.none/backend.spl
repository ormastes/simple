# None/Headless Render Backend
#
# Implements RenderBackend with no actual display output.
# Captures render output for testing and provides event injection.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent, WidgetNode, WidgetRect}
use common.ui.capability.{Capability, NotSupported}
use common.ui.semantic_contract.{
    SEMANTIC_UI_STAGE_STATE,
    SEMANTIC_UI_STATUS_AVAILABLE,
    SemanticUiSnapshot,
    semantic_ui_snapshot_from_state_with_capabilities,
    semantic_ui_snapshot_to_json,
    semantic_ui_snapshot_transport_json
}
use common.ui.web_render_api.{WEB_RENDER_TARGET_HEADLESS, web_render_capabilities_for_target}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.none.event_queue.{EventQueue}

# =========================================================================
# None Backend
# =========================================================================

class NoneBackend:
    initialized: bool
    width: i32
    height: i32
    event_queue: EventQueue
    render_history: [text]
    last_rendered_html: text

    static fn new() -> Result<NoneBackend, text>:
        return Ok(NoneBackend(
            initialized: false,
            width: 80,
            height: 24,
            event_queue: EventQueue.new(),
            render_history: [],
            last_rendered_html: ""
        ))

    # --- Lifecycle ---

    me init() -> Result<bool, text>:
        self.initialized = true
        return Ok(true)

    me shutdown():
        self.initialized = false

    # --- Rendering ---

    me render(state: UIState) -> Result<bool, text>:
        val html = render_html_tree(state.tree.root_node(), state)
        self.last_rendered_html = html
        self.render_history.push(html)
        return Ok(true)

    fn render_html(state: UIState) -> text:
        return render_html_tree(state.tree.root_node(), state)

    # --- Events ---

    me poll_event(timeout_ms: i32) -> UIEvent?:
        return self.event_queue.dequeue()

    # --- Capabilities ---

    fn capabilities() -> [Capability]:
        return []

    fn supports_mouse() -> bool:
        return false

    fn supports_color() -> bool:
        return false

    fn supports_images() -> bool:
        return false

    fn supports_touch() -> bool:
        return false

    # --- Viewport ---

    fn viewport_width() -> i32:
        return self.width

    fn viewport_height() -> i32:
        return self.height

    # --- Backend Info ---

    fn backend_name() -> text:
        return "none"

    # --- Test Helpers ---

    me inject_event(event: UIEvent):
        self.event_queue.push(event)

    me inject_events(events: [UIEvent]):
        self.event_queue.push_all(events)

    fn render_count() -> i32:
        return self.render_history.len()

    fn last_html() -> text:
        return self.last_rendered_html

    fn semantic_snapshot_json(state: UIState) -> text:
        semantic_ui_snapshot_to_json(none_semantic_snapshot(state))

    fn semantic_snapshot_envelope_json(state: UIState, surface_id: text, revision: u64) -> text:
        semantic_ui_snapshot_transport_json(WEB_RENDER_TARGET_HEADLESS, surface_id, revision, none_semantic_snapshot(state))

    fn html_at(index: i32) -> text:
        if index < 0 or index >= self.render_history.len():
            return ""
        return self.render_history[index]

    me clear_history():
        self.render_history = []
        self.last_rendered_html = ""

    me set_viewport(width: i32, height: i32):
        self.width = width
        self.height = height

fn none_semantic_snapshot(state: UIState) -> SemanticUiSnapshot:
    semantic_ui_snapshot_from_state_with_capabilities(state, SEMANTIC_UI_STAGE_STATE, SEMANTIC_UI_STATUS_AVAILABLE, web_render_capabilities_for_target(WEB_RENDER_TARGET_HEADLESS))
