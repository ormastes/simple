# None/Headless Render Backend
#
# Implements RenderBackend with no actual display output.
# Captures render output for testing and provides event injection.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent}
use app.ui.render.widgets.{render_html_tree}
use app.ui.none.event_queue.{EventQueue}

# =========================================================================
# None Backend
# =========================================================================

class NoneBackend:
    initialized: bool
    width: i32
    height: i32
    event_queue: EventQueue
    render_history: [text]
    last_rendered_html: text

    static fn new() -> Result<NoneBackend, text>:
        return Ok(NoneBackend(
            initialized: false,
            width: 80,
            height: 24,
            event_queue: EventQueue.new(),
            render_history: [],
            last_rendered_html: ""
        ))

    # --- Lifecycle ---

    fn init() -> Result<bool, text>:
        self.initialized = true
        return Ok(true)

    fn shutdown():
        self.initialized = false

    # --- Rendering ---

    fn render(state: UIState) -> Result<bool, text>:
        val html = render_html_tree(state.tree.root, state)
        self.last_rendered_html = html
        self.render_history.push(html)
        return Ok(true)

    fn render_html(state: UIState) -> text:
        return render_html_tree(state.tree.root, state)

    # --- Events ---

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        return self.event_queue.dequeue()

    # --- Capabilities ---

    fn supports_mouse() -> bool:
        return false

    fn supports_color() -> bool:
        return false

    fn supports_images() -> bool:
        return false

    fn supports_touch() -> bool:
        return false

    # --- Viewport ---

    fn viewport_width() -> i32:
        return self.width

    fn viewport_height() -> i32:
        return self.height

    # --- Backend Info ---

    fn backend_name() -> text:
        return "none"

    # --- Test Helpers ---

    fn inject_event(event: UIEvent):
        self.event_queue.push(event)

    fn inject_events(events: [UIEvent]):
        self.event_queue.push_all(events)

    fn render_count() -> i32:
        return self.render_history.len()

    fn last_html() -> text:
        return self.last_rendered_html

    fn html_at(index: i32) -> text:
        if index < 0 or index >= self.render_history.len():
            return ""
        return self.render_history[index]

    fn clear_history():
        self.render_history = []
        self.last_rendered_html = ""

    fn set_viewport(width: i32, height: i32):
        self.width = width
        self.height = height
