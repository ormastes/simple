# Headless Application
#
# Runs the UI system without a display for testing and CI.
# Processes injected events and captures render output.

use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state, update_state, update_tree, is_quit_event}
use common.ui.session.{UISession}
use common.ui.access_store.{ui_access_store_runtime_open, ui_access_store_runtime_open_with_override}
use app.ui.none.backend.{NoneBackend}

extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# Headless App
# =========================================================================

class HeadlessApp:
    file_path: text
    session: UISession
    backend: NoneBackend

    static fn new(file_path: text) -> Result<HeadlessApp, text>:
        return HeadlessApp.new_with_access_store_path(file_path, "")

    static fn new_with_access_store_path(file_path: text, access_db_path: text) -> Result<HeadlessApp, text>:
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                var session = UISession.new(tree)
                session.set_active_backend("none")
                if access_db_path != "":
                    val store = ui_access_store_runtime_open_with_override(access_db_path, file_path, "none")
                    if store != nil:
                        session.attach_access_store(store)
                val backend_result = NoneBackend.new()
                match backend_result:
                    Err(e):
                        return Err(e)
                    Ok(backend):
                        val init_result = backend.init()
                        match init_result:
                            Err(e):
                                return Err(e)
                            Ok(_):
                                pass_dn

                        return Ok(HeadlessApp(
                            file_path: file_path,
                            session: session,
                            backend: backend
                        ))

    me run() -> Result<bool, text>:
        """Process all queued events, rendering after each."""
        # Initial render
        val render_result = self.backend.render(self.session.current_state())
        match render_result:
            Err(e):
                return Err(e)
            Ok(_):
                pass_dn

        # Process all queued events
        while true:
            val event = self.backend.poll_event(0)
            if event == nil:
                break

            if is_quit_event(event):
                self.backend.shutdown()
                return Ok(true)

            self.session.dispatch(event)
            val r = self.backend.render(self.session.current_state())
            match r:
                Err(e):
                    return Err(e)
                Ok(_):
                    pass_dn

        return Ok(true)

    me run_single_event(event: UIEvent) -> UIState:
        """Process one event and return the new state."""
        self.session.dispatch(event)
        val r = self.backend.render(self.session.current_state())
        return self.session.current_state()

    fn current_state() -> UIState:
        return self.session.current_state()

    me inject_event(event: UIEvent):
        self.backend.inject_event(event)

    me inject_events(events: [UIEvent]):
        self.backend.inject_events(events)

    fn render_count() -> i32:
        return self.backend.render_count()

    fn last_html() -> text:
        return self.backend.last_html()

# =========================================================================
# Entry Point
# =========================================================================

fn run_headless(file_path: text) -> i64:
    return run_headless_with_access_store(file_path, "")

fn run_headless_with_access_store(file_path: text, access_db_path: text) -> i64:
    """Start headless mode for a .ui.sdn file."""
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val app_result = HeadlessApp.new_with_access_store_path(file_path, access_db_path)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            val run_result = app.run()
            match run_result:
                Err(e):
                    print "Error during headless run: {e}"
                    return 1
                Ok(_):
                    print "Headless UI completed."
                    return 0
