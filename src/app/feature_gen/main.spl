# Simple CLI - feature-gen command
# Generates tracking feature documentation from doc/08_tracking/feature/feature_db.sdn

use std.cli.cli_util.{get_cli_args, parse_csv_fields}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod.{file_exists, file_read, file_write, dir_create}
use std.log.{error}

val FEATURE_DB_PATH = "doc/08_tracking/feature/feature_db.sdn"
val FEATURE_MD_PATH = "doc/08_tracking/feature/feature.md"
val REQUEST_MD_PATH = "doc/08_tracking/feature/request_feature.md"
val CURRENT_MD_PATH = "doc/08_tracking/feature/current_feature.md"
val DONE_MD_PATH = "doc/08_tracking/feature/done_feature.md"
val GROUP_DIR = "doc/08_tracking/feature/group"

fn print_help():
    print "Usage: simple feature-gen [options]"
    print ""
    print "Generate feature tracking documentation from feature_db.sdn."
    print ""
    print "Outputs:"
    print "  doc/08_tracking/feature/feature.md           Group/status index"
    print "  doc/08_tracking/feature/request_feature.md   Requested features"
    print "  doc/08_tracking/feature/current_feature.md   Current feature work"
    print "  doc/08_tracking/feature/done_feature.md      Done feature records"
    print "  doc/08_tracking/feature/group/*.md           Per-group pages"
    print ""
    print "Options:"
    print "  --json       Output summary as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _json_escape(value: text) -> text:
    val slashes = value.replace("\\", "\\\\")
    val quotes = slashes.replace("\"", "\\\"")
    quotes.replace("\n", "\\n")

struct Feature:
    id: text
    group: text
    device: text
    component: text
    title: text
    description: text
    status: text
    priority: text
    source_file: text
    requirement: text
    research: text
    plan: text
    architecture: text
    design: text
    system_spec: text
    spec_doc: text
    implementation: text
    unit_tests: text
    integration_tests: text
    guide: text
    external_system: text
    external_id: text
    external_url: text
    last_synced_at: text
    created_at: text
    updated_at: text
    valid: bool

fn load_features() -> [Feature]:
    if not file_exists(FEATURE_DB_PATH):
        error("feature-gen", "{FEATURE_DB_PATH} not found")
        return []

    val content = file_read(FEATURE_DB_PATH)
    val lines = content.split("\n")
    var features: [Feature] = []
    var in_table = false

    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("features |"):
            in_table = true
            continue
        if not in_table or trimmed == "" or trimmed.starts_with("#"):
            if in_table and trimmed != "" and not trimmed.starts_with("#") and not trimmed.starts_with(" "):
                in_table = false
            continue

        val fields = parse_csv_fields(trimmed)
        if fields.len() >= 27:
            features.push(Feature(
                id: fields[0],
                group: fields[1],
                device: fields[2],
                component: fields[3],
                title: fields[4],
                description: fields[5],
                status: fields[6],
                priority: fields[7],
                source_file: fields[8],
                requirement: fields[9],
                research: fields[10],
                plan: fields[11],
                architecture: fields[12],
                design: fields[13],
                system_spec: fields[14],
                spec_doc: fields[15],
                implementation: fields[16],
                unit_tests: fields[17],
                integration_tests: fields[18],
                guide: fields[19],
                external_system: fields[20],
                external_id: fields[21],
                external_url: fields[22],
                last_synced_at: fields[23],
                created_at: fields[24],
                updated_at: fields[25],
                valid: fields[26] == "true"
            ))

    features

fn normalize_group(group: text) -> text:
    if group == "":
        return "general"
    group

fn get_groups(features: [Feature]) -> [text]:
    var groups: [text] = []
    for f in features:
        if f.valid:
            val group = normalize_group(f.group)
            if not groups.contains(group):
                groups.push(group)
    groups

fn count_group_status(features: [Feature], group: text, status: text) -> i64:
    var count = 0
    for f in features:
        if f.valid and normalize_group(f.group) == group and f.status == status:
            count = count + 1
    count

fn count_group_total(features: [Feature], group: text) -> i64:
    var count = 0
    for f in features:
        if f.valid and normalize_group(f.group) == group:
            count = count + 1
    count

fn count_status(features: [Feature], status: text) -> i64:
    var count = 0
    for f in features:
        if f.valid and f.status == status:
            count = count + 1
    count

fn count_valid(features: [Feature]) -> i64:
    var count = 0
    for f in features:
        if f.valid:
            count = count + 1
    count

fn sanitize_name(name: text) -> text:
    name.replace(" ", "_").replace("/", "_").replace("\\", "_")

fn link_or_dash(path: text) -> text:
    if path == "" or path == "none" or path == "tbd":
        return "-"
    "[link]({path})"

fn generate_feature_md(features: [Feature]) -> text:
    val groups = get_groups(features)
    val total = count_valid(features)
    val request = count_status(features, "request")
    val current = count_status(features, "current")
    val done = count_status(features, "done")
    val blocked = count_status(features, "blocked")
    val rejected = count_status(features, "rejected")

    var lines: [text] = []
    lines.push("# Feature Tracking")
    lines.push("")
    lines.push("**Database:** `{FEATURE_DB_PATH}`")
    lines.push("**Generated:** 2026-06-04")
    lines.push("")
    lines.push("| Total | Request | Current | Done | Blocked | Rejected |")
    lines.push("|-------|---------|---------|------|---------|----------|")
    lines.push("| {total} | {request} | {current} | {done} | {blocked} | {rejected} |")
    lines.push("")
    lines.push("## Groups")
    lines.push("")
    lines.push("| Group | Total | Request | Current | Done | Blocked | Rejected |")
    lines.push("|-------|-------|---------|---------|------|---------|----------|")
    for group in groups:
        val safe = sanitize_name(group)
        lines.push("| [{group}](group/{safe}.md) | {count_group_total(features, group)} | {count_group_status(features, group, \"request\")} | {count_group_status(features, group, \"current\")} | {count_group_status(features, group, \"done\")} | {count_group_status(features, group, \"blocked\")} | {count_group_status(features, group, \"rejected\")} |")
    lines.push("")
    lines.join("\n")

fn generate_status_md(features: [Feature], status: text, title: text) -> text:
    var lines: [text] = []
    lines.push("# {title}")
    lines.push("")
    lines.push("**Database:** `{FEATURE_DB_PATH}`")
    lines.push("")
    lines.push("| ID | Group | Priority | Title | Requirement | External |")
    lines.push("|----|-------|----------|-------|-------------|----------|")
    for f in features:
        if f.valid and f.status == status:
            lines.push("| {f.id} | {normalize_group(f.group)} | {f.priority} | {f.title} | {link_or_dash(f.requirement)} | {link_or_dash(f.external_url)} |")
    lines.push("")
    lines.join("\n")

fn generate_group_md(features: [Feature], group: text) -> text:
    var lines: [text] = []
    lines.push("# Feature Group: {group}")
    lines.push("")
    lines.push("| ID | Status | Device | Component | Priority | Title | Pipeline Evidence |")
    lines.push("|----|--------|--------|-----------|----------|-------|-------------------|")
    for f in features:
        if f.valid and normalize_group(f.group) == group:
            var evidence = ""
            if f.requirement != "": evidence = evidence + " req"
            if f.research != "": evidence = evidence + " research"
            if f.plan != "": evidence = evidence + " plan"
            if f.architecture != "": evidence = evidence + " arch"
            if f.design != "": evidence = evidence + " design"
            if f.system_spec != "": evidence = evidence + " system_spec"
            if f.spec_doc != "": evidence = evidence + " spec_doc"
            if f.implementation != "": evidence = evidence + " impl"
            if f.unit_tests != "": evidence = evidence + " unit"
            if f.integration_tests != "": evidence = evidence + " integration"
            if f.guide != "": evidence = evidence + " guide"
            if evidence == "": evidence = "-"
            lines.push("| {f.id} | {f.status} | {f.device} | {f.component} | {f.priority} | {f.title} | {evidence.trim()} |")
    lines.push("")
    lines.join("\n")

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("feature-gen", log_opts.error)
        return 1

    var as_json = log_opts.log_mode == "json"
    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        ai = ai + 1

    val features = load_features()
    if features.len() == 0:
        if as_json:
            print "{\"command\":\"feature-gen\",\"status\":\"error\",\"features\":0,\"groups\":0}"
        else:
            print "No features found in {FEATURE_DB_PATH}"
        return 1

    file_write(FEATURE_MD_PATH, generate_feature_md(features))
    file_write(REQUEST_MD_PATH, generate_status_md(features, "request", "Requested Features"))
    file_write(CURRENT_MD_PATH, generate_status_md(features, "current", "Current Features"))
    file_write(DONE_MD_PATH, generate_status_md(features, "done", "Done Features"))

    dir_create(GROUP_DIR, true)
    val groups = get_groups(features)
    for group in groups:
        val safe = sanitize_name(group)
        file_write("{GROUP_DIR}/{safe}.md", generate_group_md(features, group))

    if log_opts.progress != "summary" and not as_json:
        val progress_line = render_progress(log_opts.progress, features.len(), features.len(), "feature-gen")
        if progress_line != "":
            print progress_line
    if as_json:
        val db_json = _json_escape(FEATURE_DB_PATH)
        print "{\"command\":\"feature-gen\",\"status\":\"ok\",\"features\":{features.len()},\"groups\":{groups.len()},\"db\":\"{db_json}\"}"
    else:
        print "Done. Generated tracking docs for {features.len()} features in {groups.len()} groups."
    0
