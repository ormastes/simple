# Simple CLI - replay command
# Dispatches to native SReplay for .srr traces, or FFI for legacy replay.

use std.cli.cli_util (get_cli_args)
use app.io.cli_commands (cli_replay)
use app.replay.replay_session (run_replay)

fn has_srr_arg(args: [text]) -> bool:
    for arg in args:
        if arg.ends_with(".srr"):
            return true
    false

fn main() -> i64:
    val args = get_cli_args()
    if has_srr_arg(args):
        run_replay(args)
        0
    else:
        cli_replay(args)
