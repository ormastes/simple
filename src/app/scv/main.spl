# SCV CLI.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (cwd)
use std.scv.store.{scv_init_repo, scv_restore_op, scv_mark_current_state}
use std.scv.working_copy.{scv_snapshot, scv_auto_snapshot, scv_watch, scv_status, scv_log, scv_log_branch, scv_op_log}
use std.scv.parser.{scv_parse_gate, scv_parse_index}
use std.scv.parser_registry.{scv_parsers, scv_parser_install, scv_parser_verify, scv_langmap, scv_langmap_set}
use std.scv.diff.{scv_diff}
use std.scv.gates.{scv_compile_gate, scv_test_gate, scv_public_ready}
use std.scv.maintenance.{scv_stats, scv_export_tree, scv_export_manifest, scv_import_manifest, scv_rebuild_object_index, scv_gc_dry_run, scv_gc_prune, scv_gc}
use std.scv.fast_import.{scv_export_git_fast_import, scv_import_git_fast_import}
use std.scv.integrity.{scv_fsck}
use std.scv.pack.{scv_pack_status, scv_pack_write, scv_pack_verify, scv_pack_import, scv_private_sync, scv_private_sync_verify, scv_private_sync_import}
use std.scv.pack_v2.{scv_pack_write_v2, scv_pack_verify_v2, scv_pack_read_object}
use std.scv.public_remote.{scv_public_export, scv_public_export_verify, scv_public_push, scv_public_push_verify, scv_public_pull}
use std.scv.network_remote.{scv_network_push, scv_network_push_chunked, scv_network_push_cas, scv_network_push_verify, scv_network_pull, scv_network_config_set_auth, scv_network_config_set_tls_no_verify, scv_network_pull_simulate_interrupt, scv_network_pull_discard}
use std.scv.merge.{scv_merge_commits, scv_conflicts, scv_resolve_conflict}
use std.scv.refs.{scv_bookmarks, scv_bookmark_set, scv_tag_list, scv_tag_set}

extern fn rt_stdout_write(data: [u8]) -> i64

fn scv_help() -> text:
    var lines: [text] = []
    lines.push("Usage: scv <init|snapshot|auto-snapshot|watch|status|log|op-log|restore-op|diff|parse-gate|parse-index|compile-gate|test-gate|mark-state|public-ready|stats|fsck|export-tree|export-manifest|import-manifest|export-git-fast-import|import-git-fast-import|db-index|pack-status|pack-write|pack-verify|pack-import|private-sync|private-sync-verify|private-sync-import|public-export|public-export-verify|public-push|public-push-verify|public-pull|network-push|network-push-verify|network-push-cas|network-pull|network-config|gc-dry-run|gc-prune|merge-commits|conflicts|resolve-conflict|bookmarks|bookmark-set|parsers|parser-install|parser-verify|langmap|langmap-set>")
    lines.push("")
    lines.push("Shared log options:")
    for line in log_options_help():
        lines.push("  {line}")
    lines.join("\n") + "\n"

fn scv_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn scv_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if scv_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn scv_cli_result(result: text) -> i64:
    print result
    if result.starts_with("ERROR"):
        1
    else:
        0

fn scv_cli_watch(root: text, args: [text]) -> i64:
    var iterations = 0
    var poll_ms = 1000
    var i = 1
    while i < args.len():
        val arg = args[i]
        if arg == "--once":
            iterations = 1
        elif arg == "--iterations":
            if i + 1 >= args.len():
                print "ERROR watch --iterations requires a number"
                return 1
            iterations = args[i + 1].to_i64() ?? -1
            i = i + 1
        elif arg == "--poll-ms":
            if i + 1 >= args.len():
                print "ERROR watch --poll-ms requires a number"
                return 1
            poll_ms = args[i + 1].to_i64() ?? -1
            i = i + 1
        else:
            print "ERROR unknown watch option: {arg}"
            return 1
        i = i + 1
    scv_cli_result(scv_watch(root, iterations, poll_ms))

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        print "ERROR scv {log_opts.error}"
        return 1
    val args = scv_clean_args(raw_args)
    val root = cwd()
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"scv\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print scv_help()
        return 0
    val cmd = args[0]
    match cmd:
        case "init":
            return scv_cli_result(scv_init_repo(root))
        case "snapshot":
            return scv_cli_result(scv_snapshot(root))
        case "auto-snapshot":
            return scv_cli_result(scv_auto_snapshot(root))
        case "watch":
            return scv_cli_watch(root, args)
        case "status", "st":
            return scv_cli_result(scv_status(root))
        case "log":
            val log_branch = if args.len() >= 2: args[1] else: ""
            if log_branch == "":
                return scv_cli_result(scv_log(root))
            else:
                return scv_cli_result(scv_log_branch(root, log_branch))
        case "op-log":
            return scv_cli_result(scv_op_log(root))
        case "restore-op":
            if args.len() < 2:
                print "ERROR restore-op requires an operation id"
                return 1
            return scv_cli_result(scv_restore_op(root, args[1]))
        case "diff":
            val mode = if args.len() >= 2: args[1] else: "--raw"
            return scv_cli_result(scv_diff(root, mode))
        case "parse-gate":
            if args.len() < 2:
                print "ERROR parse-gate requires a path"
                return 1
            return scv_cli_result(scv_parse_gate(root, args[1]))
        case "parsers":
            return scv_cli_result(scv_parsers(root))
        case "parser-install":
            if args.len() < 5:
                print "ERROR parser-install requires language, grammar, version, and wasm path"
                return 1
            val abi = if args.len() >= 6: args[5] else: "wasm32"
            return scv_cli_result(scv_parser_install(root, args[1], args[2], args[3], args[4], abi))
        case "parser-verify":
            return scv_cli_result(scv_parser_verify(root))
        case "parse-index":
            return scv_cli_result(scv_parse_index(root))
        case "langmap":
            return scv_cli_result(scv_langmap(root))
        case "langmap-set":
            if args.len() < 5:
                print "ERROR langmap-set requires extension, language, grammar, and version"
                return 1
            return scv_cli_result(scv_langmap_set(root, args[1], args[2], args[3], args[4]))
        case "compile-gate":
            if args.len() < 2:
                print "ERROR compile-gate requires a command"
                return 1
            return scv_cli_result(scv_compile_gate(root, args[1]))
        case "test-gate":
            if args.len() < 2:
                print "ERROR test-gate requires a command"
                return 1
            return scv_cli_result(scv_test_gate(root, args[1]))
        case "mark-state":
            if args.len() < 2:
                print "ERROR mark-state requires a state"
                return 1
            return scv_cli_result(scv_mark_current_state(root, args[1]))
        case "public-ready":
            return scv_cli_result(scv_public_ready(root))
        case "stats":
            return scv_cli_result(scv_stats(root))
        case "fsck":
            return scv_cli_result(scv_fsck(root))
        case "export-tree":
            if args.len() < 2:
                print "ERROR export-tree requires an output directory"
                return 1
            return scv_cli_result(scv_export_tree(root, args[1]))
        case "export-manifest":
            if args.len() < 2:
                print "ERROR export-manifest requires an output path"
                return 1
            return scv_cli_result(scv_export_manifest(root, args[1]))
        case "import-manifest":
            if args.len() < 3:
                print "ERROR import-manifest requires a manifest path and source directory"
                return 1
            return scv_cli_result(scv_import_manifest(root, args[1], args[2]))
        case "export-git-fast-import":
            if args.len() < 2:
                print "ERROR export-git-fast-import requires an output path"
                return 1
            var export_branch = "main"
            var export_since = ""
            var export_i = 2
            while export_i < args.len():
                val export_arg = args[export_i]
                if export_arg == "--since":
                    if export_i + 1 >= args.len():
                        print "ERROR --since requires a commit id"
                        return 1
                    export_since = args[export_i + 1]
                    export_i = export_i + 1
                elif not export_arg.starts_with("--"):
                    export_branch = export_arg
                export_i = export_i + 1
            return scv_cli_result(scv_export_git_fast_import(root, args[1], export_branch, export_since))
        case "import-git-fast-import":
            if args.len() < 2:
                print "ERROR import-git-fast-import requires an input path"
                return 1
            return scv_cli_result(scv_import_git_fast_import(root, args[1]))
        case "db-index":
            return scv_cli_result(scv_rebuild_object_index(root))
        case "pack-status":
            return scv_cli_result(scv_pack_status(root))
        case "pack-write":
            return scv_cli_result(scv_pack_write(root))
        case "pack-verify":
            val pack_id = if args.len() >= 2: args[1] else: ""
            return scv_cli_result(scv_pack_verify(root, pack_id))
        case "pack-import":
            if args.len() < 2:
                print "ERROR pack-import requires a pack directory"
                return 1
            val pack_id = if args.len() >= 3: args[2] else: ""
            return scv_cli_result(scv_pack_import(root, args[1], pack_id))
        case "pack-write-v2":
            return scv_cli_result(scv_pack_write_v2(root))
        case "pack-verify-v2":
            val pack_id_v2 = if args.len() >= 2: args[1] else: ""
            return scv_cli_result(scv_pack_verify_v2(root, pack_id_v2))
        case "pack-read-object":
            if args.len() < 3:
                print "ERROR pack-read-object requires kind and object-id"
                return 1
            val kind = args[1]
            val object_id = args[2]
            val pack_filter = if args.len() >= 4: args[3] else: ""
            val data = scv_pack_read_object(root, pack_filter, object_id)
            if data.len() == 0:
                print "ERROR pack-read-object not found: {object_id}"
                return 1
            rt_stdout_write(data)
            return 0
        case "private-sync":
            if args.len() < 2:
                print "ERROR private-sync requires an output directory"
                return 1
            return scv_cli_result(scv_private_sync(root, args[1]))
        case "private-sync-verify":
            if args.len() < 2:
                print "ERROR private-sync-verify requires an output directory"
                return 1
            return scv_cli_result(scv_private_sync_verify(args[1]))
        case "private-sync-import":
            if args.len() < 2:
                print "ERROR private-sync-import requires an output directory"
                return 1
            return scv_cli_result(scv_private_sync_import(root, args[1]))
        case "public-export":
            if args.len() < 2:
                print "ERROR public-export requires an output directory"
                return 1
            val branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_public_export(root, args[1], branch))
        case "public-export-verify":
            if args.len() < 2:
                print "ERROR public-export-verify requires an output directory"
                return 1
            return scv_cli_result(scv_public_export_verify(args[1]))
        case "public-push":
            if args.len() < 2:
                print "ERROR public-push requires a remote directory"
                return 1
            val branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_public_push(root, args[1], branch))
        case "public-push-verify":
            if args.len() < 2:
                print "ERROR public-push-verify requires a remote directory"
                return 1
            val branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_public_push_verify(args[1], branch))
        case "public-pull":
            if args.len() < 2:
                print "ERROR public-pull requires a remote directory"
                return 1
            val branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_public_pull(root, args[1], branch))
        case "gc-dry-run":
            return scv_cli_result(scv_gc_dry_run(root))
        case "gc-prune":
            return scv_cli_result(scv_gc_prune(root))
        case "gc":
            return scv_cli_result(scv_gc(root))
        case "merge-commits":
            if args.len() < 4:
                print "ERROR merge-commits requires base, left, and right commits"
                return 1
            return scv_cli_result(scv_merge_commits(root, args[1], args[2], args[3]))
        case "conflicts":
            return scv_cli_result(scv_conflicts(root))
        case "resolve-conflict":
            if args.len() < 2:
                print "ERROR resolve-conflict requires a conflict id"
                return 1
            return scv_cli_result(scv_resolve_conflict(root, args[1]))
        case "bookmarks":
            return scv_cli_result(scv_bookmarks(root))
        case "bookmark-set":
            if args.len() < 2:
                print "ERROR bookmark-set requires a name"
                return 1
            val commit = if args.len() >= 3: args[2] else: ""
            return scv_cli_result(scv_bookmark_set(root, args[1], commit))
        case "network-push":
            if args.len() < 3:
                print "ERROR network-push requires a base URL and remote directory"
                return 1
            var net_push_branch = "main"
            var net_push_chunk = 0
            var net_push_i = 3
            while net_push_i < args.len():
                val net_push_arg = args[net_push_i]
                if net_push_arg.starts_with("--chunk-bytes="):
                    net_push_chunk = net_push_arg[14:].to_i64() ?? 0
                elif not net_push_arg.starts_with("--"):
                    net_push_branch = net_push_arg
                net_push_i = net_push_i + 1
            if net_push_chunk > 0:
                return scv_cli_result(scv_network_push_chunked(args[1], args[2], net_push_branch, net_push_chunk))
            return scv_cli_result(scv_network_push(args[1], args[2], net_push_branch))
        case "network-push-verify":
            if args.len() < 2:
                print "ERROR network-push-verify requires a remote directory"
                return 1
            val branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_network_push_verify(args[1], branch))
        case "network-push-cas":
            if args.len() < 5:
                print "ERROR network-push-cas requires base URL, remote directory, branch, and old-etag"
                return 1
            return scv_cli_result(scv_network_push_cas(args[1], args[2], args[3], args[4]))
        case "network-pull":
            if args.len() < 3:
                print "ERROR network-pull requires a base URL and remote directory"
                return 1
            val branch = if args.len() >= 4: args[3] else: "main"
            return scv_cli_result(scv_network_pull(args[1], args[2], branch))
        case "network-pull-simulate-interrupt":
            if args.len() < 3:
                print "ERROR network-pull-simulate-interrupt requires a base URL and remote directory"
                return 1
            val nps_branch = if args.len() >= 4: args[3] else: "main"
            return scv_cli_result(scv_network_pull_simulate_interrupt(args[1], args[2], nps_branch))
        case "network-pull-discard":
            if args.len() < 2:
                print "ERROR network-pull-discard requires a remote directory"
                return 1
            val npd_branch = if args.len() >= 3: args[2] else: "main"
            return scv_cli_result(scv_network_pull_discard(args[1], npd_branch))
        case "network-config":
            if args.len() < 2:
                print "ERROR network-config requires a subcommand"
                return 1
            if args[1] == "set-auth":
                if args.len() < 3:
                    print "ERROR network-config set-auth requires an auth kind"
                    return 1
                val kind = args[2]
                if kind == "token":
                    var header_name = "Authorization"
                    var token_val = ""
                    var nc_i = 3
                    while nc_i < args.len():
                        val nc_arg = args[nc_i]
                        if nc_arg.starts_with("--header="):
                            header_name = nc_arg[9:]
                        elif nc_arg.starts_with("--token="):
                            token_val = nc_arg[8:]
                        nc_i = nc_i + 1
                    return scv_cli_result(scv_network_config_set_auth(kind, header_name, token_val))
                print "ERROR network-config set-auth unknown kind: {kind}"
                return 1
            if args[1] == "set-tls-no-verify":
                var base_url_nc = ""
                var nc2_i = 2
                while nc2_i < args.len():
                    val nc2_arg = args[nc2_i]
                    if nc2_arg.starts_with("--base-url="):
                        base_url_nc = nc2_arg[11:]
                    nc2_i = nc2_i + 1
                if base_url_nc == "":
                    print "ERROR network-config set-tls-no-verify requires --base-url="
                    return 1
                return scv_cli_result(scv_network_config_set_tls_no_verify(base_url_nc))
            print "ERROR network-config unknown subcommand: {args[1]}"
            return 1
        case "tag-list":
            return scv_cli_result(scv_tag_list(root))
        case "tag-set":
            if args.len() < 3:
                print "ERROR tag-set requires a name and commit"
                return 1
            return scv_cli_result(scv_tag_set(root, args[1], args[2]))
        case _:
            print scv_help()
            return 1
