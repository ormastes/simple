# `simple model3d <sub>` — 3D scene/object CLI on the engine3d software raster.
#
# Subcommands:
#   inspect <scene.sdn>              Validate a scene and print node tree,
#                                    mesh/vertex counts, materials, bounds.
#   render <scene.sdn> --out <ppm>   Render the scene headless to a P3 PPM.
#       [--width N] [--height N]     Default 256x192, range 8..1024.
#       [--eye X,Y,Z] [--target X,Y,Z] [--fov DEG]  Override scene camera.
#   gen heightmap --seed N --w W --d D --out <scene.sdn>
#       Sample seeded fbm2 per column, emit one box node per column
#       (height -> size.y, center.y = h/2). Loadable by `inspect`/`render`
#       unchanged — it is already box-node scene SDN.
#   gen tilemap --seed N --w W --h H --out <map.sdn>
#       Seeded cellular-automata cave (4-5 rule) -> `[[i32]]` grid, emitted
#       as `tilemap: { cols, rows, cells }` SDN (see cave_ca.spl).
#   gen wfc --seed N --w W --h H [--tileset file.sdn] --out <map.sdn>
#       Seeded tiled-model Wave Function Collapse -> `[[i32]]` grid of tile
#       ids, emitted as the SAME `tilemap: { cols, rows, cells }` SDN shape
#       (loadable identically). Defaults to a built-in grass/water/coast
#       demo tileset; `--tileset` overrides with an SDN adjacency-rule file
#       (see wfc.spl).
#
# Scene format: SDN (the project data format — see test/fixtures/model3d/).
#   scene:
#     name: "demo"
#     background: "203040"              # RRGGBB hex, optional "#" prefix
#     camera: { eye: [0.0, 0.0, 6.0], target: [0.0, 0.0, 0.0], fov_deg: 60.0 }
#     nodes: [{ name: "cube", shape: "box", center: [0.0, 0.0, 0.0], size: [2.0, 2.0, 2.0], color: "CC3020" }]
#
# Exit codes: 0 success, 1 failure (missing/malformed/invalid scene, write
# failure), 2 usage error. Scene files are a trust boundary: every field is
# validated with a path-qualified error message; malformed input never panics.
#
# NOTE: value extraction is written with `if val Some(..)`/`if val Ok(..)`
# instead of match-arm early returns — see
# doc/08_tracking/bug/interp_match_or_pattern_early_return_swallowed_2026-06-13.md

use std.cli.cli_util.{get_cli_args}
use std.io_runtime.{file_exists, file_read, write_file}
use std.sdn.{SdnValue, parse}
use std.common.color.convert.{hex_to_int}
use std.common.math.noise.{perm_new, fbm2}
use std.common.cave_ca.{CaveGrid, ca_generate}
use std.common.wfc.{TileSet, demo_tileset, parse_tileset, wfc_generate}
use std.gpu.engine3d.engine.{Engine3D}
use std.gpu.engine3d.types3d.{
    vertex3d_pos_normal, material_unlit,
    mat4_identity, mat4_perspective, mat4_look_at,
    CULL_NONE, color3d_r, color3d_g, color3d_b
}

val MIN_DIM: i64 = 8
val MAX_DIM: i64 = 1024

class Vec3:
    x: f64
    y: f64
    z: f64

class Node3:
    name: text
    shape: text
    center: Vec3
    size: Vec3
    color: u32
    # Nested objects: a child's `center` is RELATIVE to its parent's world
    # center (positions compose additively through the tree). `size` is the
    # node's absolute box extent in world units, not a normalized scale
    # factor, so it does NOT compose — a child's size is never multiplied by
    # its parent's size. See `_submit_node_tree` / `node_world_positions`.
    children: [Node3]

class Scene3:
    name: text
    background: u32
    eye: Vec3
    target: Vec3
    fov_deg: f64
    nodes: [Node3]

    # Find a node by name (searching the tree, depth-first) and append
    # `child` under it. Returns false without modifying the scene if no node
    # named `parent_name` exists.
    me embed(parent_name: text, child: Node3) -> bool:
        val r = _embed_into(self.nodes, parent_name, child)
        self.nodes = r.nodes
        r.found

class _EmbedResult:
    nodes: [Node3]
    found: bool

# Recursive helper for Scene3.embed — searches `nodes` and their descendants
# for `parent_name` and returns a REBUILT array with `child` appended under
# it (assigning through an indexed nested field, e.g. `nodes[i].children =
# ...`, is not a supported assignment target — only plain `self.field` /
# local-`var` targets are — so this rebuilds the tree functionally instead).
fn _embed_into(nodes: [Node3], parent_name: text, child: Node3) -> _EmbedResult:
    var out: [Node3] = []
    var found = false
    for n in nodes:
        if found:
            out.push(n)
        elif n.name == parent_name:
            var kids = n.children
            kids.push(child)
            out.push(Node3(name: n.name, shape: n.shape, center: n.center, size: n.size, color: n.color, children: kids))
            found = true
        else:
            val r = _embed_into(n.children, parent_name, child)
            if r.found:
                out.push(Node3(name: n.name, shape: n.shape, center: n.center, size: n.size, color: n.color, children: r.nodes))
                found = true
            else:
                out.push(n)
    _EmbedResult(nodes: out, found: found)

# Maximum nesting depth for both rendering and world-position traversal.
val MAX_NODE_DEPTH: i64 = 8

class NodeWorldPos:
    name: text
    pos: Vec3

fn _collect_world_positions(n: Node3, offset: Vec3, depth: i64) -> [NodeWorldPos]:
    val world = Vec3(x: n.center.x + offset.x, y: n.center.y + offset.y, z: n.center.z + offset.z)
    var out: [NodeWorldPos] = [NodeWorldPos(name: n.name, pos: world)]
    if depth < MAX_NODE_DEPTH:
        for c in n.children:
            for p in _collect_world_positions(c, world, depth + 1):
                out.push(p)
    out

# Pure introspection helper: flattens the scene's node tree (parent, then
# children) into world-space positions, composing each child's relative
# `center` additively with its parent's already-composed world position.
fn node_world_positions(scene: Scene3) -> [NodeWorldPos]:
    var out: [NodeWorldPos] = []
    for n in scene.nodes:
        for p in _collect_world_positions(n, Vec3(x: 0.0, y: 0.0, z: 0.0), 0):
            out.push(p)
    out

# ============================================================================
# Scene loading + validation (trust boundary)
# ============================================================================

fn _vec3_of(v: SdnValue, what: text) -> Result<Vec3, text>:
    if val Some(items) = v.as_array():
        if items.len() != 3:
            return Err("{what}: expected 3 numbers, got {items.len()}")
        var out: [f64] = []
        var bad: i64 = -1
        var i: i64 = 0
        while i < 3:
            if val Some(f) = items[i].as_f64():
                out.push(f)
            else:
                if bad < 0:
                    bad = i
            i = i + 1
        if bad >= 0:
            return Err("{what}: element {bad} is not a number (got {items[bad].type_name()})")
        return Ok(Vec3(x: out[0], y: out[1], z: out[2]))
    Err("{what}: expected an array of 3 numbers (got {v.type_name()})")

fn _is_hex6(s: text) -> bool:
    if s.len() != 6:
        return false
    var i = 0
    while i < 6:
        val ch = s[i:i + 1].to_upper()
        val is_digit = ch >= "0" and ch <= "9"
        val is_alpha = ch >= "A" and ch <= "F"
        if (not is_digit and not is_alpha):
            return false
        i = i + 1
    true

fn _color_of(v: SdnValue, what: text) -> Result<u32, text>:
    if val Some(raw) = v.as_str():
        var hexs = raw
        if hexs.starts_with("#"):
            hexs = hexs.slice(1, hexs.len())
        if not _is_hex6(hexs):
            return Err("{what}: expected RRGGBB hex color, got \"{raw}\"")
        val n = hex_to_int(hexs.to_upper())
        return Ok((n + 0xFF000000) as u32)
    Err("{what}: expected a hex color string (got {v.type_name()})")

fn _node_of(v: SdnValue, idx: i64) -> Result<Node3, text>:
    if not v.is_dict():
        return Err("nodes[{idx}]: expected a node dict (got {v.type_name()})")
    var name = ""
    if val Some(nv) = v.get("name"):
        if val Some(s) = nv.as_str():
            name = s
        else:
            return Err("nodes[{idx}].name: expected a string")
    else:
        return Err("nodes[{idx}]: missing required field `name`")
    var shape = ""
    if val Some(sv) = v.get("shape"):
        if val Some(s) = sv.as_str():
            shape = s
        else:
            return Err("nodes[{idx}] \"{name}\".shape: expected a string")
    else:
        return Err("nodes[{idx}] \"{name}\": missing required field `shape`")
    if shape != "box":
        return Err("nodes[{idx}] \"{name}\": unsupported shape \"{shape}\" (supported: box)")
    var center = Vec3(x: 0.0, y: 0.0, z: 0.0)
    if val Some(cv) = v.get("center"):
        val r = _vec3_of(cv, "nodes[{idx}] \"{name}\".center")
        if val Err(e) = r:
            return Err(e)
        if val Ok(c) = r:
            center = c
    else:
        return Err("nodes[{idx}] \"{name}\": missing required field `center`")
    var size = Vec3(x: 0.0, y: 0.0, z: 0.0)
    if val Some(sv2) = v.get("size"):
        val r = _vec3_of(sv2, "nodes[{idx}] \"{name}\".size")
        if val Err(e) = r:
            return Err(e)
        if val Ok(s) = r:
            size = s
    else:
        return Err("nodes[{idx}] \"{name}\": missing required field `size`")
    if (size.x <= 0.0 or size.y <= 0.0 or size.z <= 0.0):
        return Err("nodes[{idx}] \"{name}\".size: all extents must be > 0")
    var color: u32 = 0
    if val Some(colv) = v.get("color"):
        val r = _color_of(colv, "nodes[{idx}] \"{name}\".color")
        if val Err(e) = r:
            return Err(e)
        if val Ok(c) = r:
            color = c
    else:
        return Err("nodes[{idx}] \"{name}\": missing required field `color`")
    Ok(Node3(name: name, shape: shape, center: center, size: size, color: color, children: []))

fn load_scene(path: text) -> Result<Scene3, text>:
    if not file_exists(path):
        return Err("scene file not found: {path}")
    val src = file_read(path)
    val parsed = parse(src)
    if val Err(e) = parsed:
        return Err("{path}: invalid SDN: {e}")
    var root = SdnValue.null()
    if val Ok(v) = parsed:
        root = v
    var sc = SdnValue.null()
    if val Some(s) = root.get("scene"):
        sc = s
    else:
        return Err("{path}: missing top-level `scene` block")
    if not sc.is_dict():
        return Err("{path}: `scene` must be a dict (got {sc.type_name()})")
    var name = "unnamed"
    if val Some(nv) = sc.get("name"):
        name = nv.as_str() ?? "unnamed"
    var background: u32 = 0xFF202020
    if val Some(bv) = sc.get("background"):
        val r = _color_of(bv, "scene.background")
        if val Err(e) = r:
            return Err("{path}: {e}")
        if val Ok(c) = r:
            background = c
    # Camera block: optional, each field optional with proven defaults.
    var eye = Vec3(x: 0.0, y: 1.0, z: 6.0)
    var target = Vec3(x: 0.0, y: 0.0, z: 0.0)
    var fov_deg: f64 = 60.0
    if val Some(cam) = sc.get("camera"):
        if not cam.is_dict():
            return Err("{path}: scene.camera must be a dict (got {cam.type_name()})")
        if val Some(ev) = cam.get("eye"):
            val r = _vec3_of(ev, "scene.camera.eye")
            if val Err(e) = r:
                return Err("{path}: {e}")
            if val Ok(v3) = r:
                eye = v3
        if val Some(tv) = cam.get("target"):
            val r = _vec3_of(tv, "scene.camera.target")
            if val Err(e) = r:
                return Err("{path}: {e}")
            if val Ok(v3) = r:
                target = v3
        if val Some(fv) = cam.get("fov_deg"):
            if val Some(f) = fv.as_f64():
                fov_deg = f
            else:
                return Err("{path}: scene.camera.fov_deg must be a number")
    if (fov_deg < 10.0 or fov_deg > 170.0):
        return Err("{path}: scene.camera.fov_deg must be in 10..170 (got {fov_deg})")
    var items: [SdnValue] = []
    if val Some(nodes_v) = sc.get("nodes"):
        if val Some(a) = nodes_v.as_array():
            items = a
        else:
            return Err("{path}: scene.nodes must be an array (got {nodes_v.type_name()})")
    else:
        return Err("{path}: missing `scene.nodes`")
    if items.len() == 0:
        return Err("{path}: scene.nodes is empty — nothing to inspect or render")
    var nodes: [Node3] = []
    var i: i64 = 0
    while i < items.len():
        val r = _node_of(items[i], i)
        if val Err(e) = r:
            return Err("{path}: {e}")
        if val Ok(n) = r:
            nodes.push(n)
        i = i + 1
    Ok(Scene3(name: name, background: background, eye: eye, target: target, fov_deg: fov_deg, nodes: nodes))

# ============================================================================
# inspect
# ============================================================================

fn _hex2(n: i64) -> text:
    val digits = "0123456789ABCDEF"
    val hi = (n / 16) % 16
    val lo = n % 16
    digits[hi:hi + 1] + digits[lo:lo + 1]

fn _color_hex(c: u32) -> text:
    "#" + _hex2(color3d_r(c) as i64) + _hex2(color3d_g(c) as i64) + _hex2(color3d_b(c) as i64)

fn _fmt_vec(v: Vec3) -> text:
    "({v.x}, {v.y}, {v.z})"

fn inspect_report(scene: Scene3) -> [text]:
    var lines: [text] = []
    lines.push("scene {scene.name}")
    lines.push("camera: eye={_fmt_vec(scene.eye)} target={_fmt_vec(scene.target)} fov={scene.fov_deg}")
    lines.push("background: {_color_hex(scene.background)}")
    lines.push("nodes: {scene.nodes.len()}")
    var total_tris: i64 = 0
    var total_verts: i64 = 0
    var min_x = scene.nodes[0].center.x
    var min_y = scene.nodes[0].center.y
    var min_z = scene.nodes[0].center.z
    var max_x = min_x
    var max_y = min_y
    var max_z = min_z
    for n in scene.nodes:
        # box mesh = 12 triangles, 36 submitted vertices
        val tris: i64 = 12
        val verts: i64 = 36
        total_tris = total_tris + tris
        total_verts = total_verts + verts
        lines.push("+- {n.name}  {n.shape}  center={_fmt_vec(n.center)} size={_fmt_vec(n.size)}  material=unlit({_color_hex(n.color)})  tris={tris} verts={verts}")
        val hx = n.size.x / 2.0
        val hy = n.size.y / 2.0
        val hz = n.size.z / 2.0
        if n.center.x - hx < min_x: min_x = n.center.x - hx
        if n.center.y - hy < min_y: min_y = n.center.y - hy
        if n.center.z - hz < min_z: min_z = n.center.z - hz
        if n.center.x + hx > max_x: max_x = n.center.x + hx
        if n.center.y + hy > max_y: max_y = n.center.y + hy
        if n.center.z + hz > max_z: max_z = n.center.z + hz
    lines.push("totals: tris={total_tris} verts={total_verts}")
    lines.push("bounds: min=({min_x}, {min_y}, {min_z}) max=({max_x}, {max_y}, {max_z})")
    lines

fn cmd_inspect(path: text) -> i64:
    val r = load_scene(path)
    if val Err(e) = r:
        print "error: {e}"
        return 1
    if val Ok(scene) = r:
        for line in inspect_report(scene):
            print line
    0

# ============================================================================
# render
# ============================================================================

# Flattens `n` and its descendants (parent first, then children — matches
# `node_world_positions`' traversal order) into a plain list of world-space
# nodes (`children` cleared, since world coordinates are already baked in).
# Capped at MAX_NODE_DEPTH to bound pathological/cyclic embed()-built trees.
# Pure data — no `Engine3D` handle in scope at all.
fn _flatten_node_tree(n: Node3, offset: Vec3, depth: i64) -> [Node3]:
    val world_center = Vec3(x: n.center.x + offset.x, y: n.center.y + offset.y, z: n.center.z + offset.z)
    var out: [Node3] = [Node3(name: n.name, shape: n.shape, center: world_center, size: n.size, color: n.color, children: [])]
    if depth < MAX_NODE_DEPTH:
        for c in n.children:
            for wn in _flatten_node_tree(c, world_center, depth + 1):
                out.push(wn)
    out

# Plain parallel arrays — one entry per world-space box to draw.
class _BoxArrays:
    cx: [f32]
    cy: [f32]
    cz: [f32]
    sx: [f32]
    sy: [f32]
    sz: [f32]
    col: [u32]

fn _flatten_to_arrays(scene: Scene3) -> _BoxArrays:
    var cx: [f32] = []
    var cy: [f32] = []
    var cz: [f32] = []
    var sx: [f32] = []
    var sy: [f32] = []
    var sz: [f32] = []
    var col: [u32] = []
    for n in scene.nodes:
        for wn in _flatten_node_tree(n, Vec3(x: 0.0, y: 0.0, z: 0.0), 0):
            cx.push(wn.center.x as f32)
            cy.push(wn.center.y as f32)
            cz.push(wn.center.z as f32)
            sx.push(wn.size.x as f32)
            sy.push(wn.size.y as f32)
            sz.push(wn.size.z as f32)
            col.push(wn.color)
    _BoxArrays(cx: cx, cy: cy, cz: cz, sx: sx, sy: sy, sz: sz, col: col)

# NOTE: box-drawing is INLINED into `render_scene`'s loop rather than routed
# through a `_submit_box(mut e: Engine3D, cx, cy, cz, sx, sy, sz, col)`
# free-function helper, deliberately. Reproduced in isolation with an A/B
# probe: a free function taking `mut Engine3D` as an explicit parameter,
# called with 6 or more OTHER arguments that are genuinely dynamic
# (loaded from an array/variable rather than compile-time literals/consts),
# silently drops every `submit_triangle` call inside it — the returned
# framebuffer still clears to the right background color, but no geometry
# ever rasterizes. This reproduces regardless of how the 6+ dynamic values
# are packaged (separate scalar args, pre-bound locals, a packed `[f32]`
# array, or a slice) and regardless of scalar width (`f32`/`f64`) — the
# threshold is strictly the COUNT of non-constant values reaching such a
# call (5 dynamic args: fine; 6+: broken). Calling `e.submit_triangle(...)`
# directly as a METHOD on the local `e` (not passing `e` positionally into
# another free function) avoids the bug entirely, which is why this is
# inlined instead of factored into a reusable helper. See
# doc/08_tracking/bug/model3d_mut_engine_free_fn_six_dynamic_args_drops_mutation_2026-07-11.md
# — presumably the same family as the already-tracked
# `struct_param_mutation_semantics_2026-07-03.md` /
# `browser_engine_free_fn_arg_mutation_lost_2026-06-30.md` class-mutation
# codegen bugs, just triggered by dynamic-argument COUNT rather than a
# class-typed argument.
fn render_scene(scene: Scene3, w: i64, h: i64) -> [u32]:
    val boxes = _flatten_to_arrays(scene)
    val cx = boxes.cx
    val cy = boxes.cy
    val cz = boxes.cz
    val sx = boxes.sx
    val sy = boxes.sy
    val sz = boxes.sz
    val col = boxes.col
    var e = Engine3D.create(w as i32, h as i32)
    val fov_rad = scene.fov_deg * 3.141592653589793 / 180.0
    val proj = mat4_perspective(fov_rad as f32, (w as f32) / (h as f32), 0.1, 100.0)
    val view = mat4_look_at(
        scene.eye.x as f32, scene.eye.y as f32, scene.eye.z as f32,
        scene.target.x as f32, scene.target.y as f32, scene.target.z as f32,
        0.0, 1.0, 0.0)
    e.set_camera(view, proj)
    e.set_cull_mode(CULL_NONE)
    e.begin_frame()
    e.clear(scene.background)
    e.clear_depth()
    var i: i64 = 0
    while i < cx.len():
        val m = mat4_identity()
        val mat = material_unlit(col[i])
        val x0 = cx[i] - sx[i] / 2.0
        val x1 = cx[i] + sx[i] / 2.0
        val y0 = cy[i] - sy[i] / 2.0
        val y1 = cy[i] + sy[i] / 2.0
        val z0 = cz[i] - sz[i] / 2.0
        val z1 = cz[i] + sz[i] / 2.0
        # front (+z)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z1,0.0,0.0,1.0), vertex3d_pos_normal(x1,y0,z1,0.0,0.0,1.0), vertex3d_pos_normal(x1,y1,z1,0.0,0.0,1.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z1,0.0,0.0,1.0), vertex3d_pos_normal(x1,y1,z1,0.0,0.0,1.0), vertex3d_pos_normal(x0,y1,z1,0.0,0.0,1.0), mat, m)
        # back (-z)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,0.0,0.0,-1.0), vertex3d_pos_normal(x1,y1,z0,0.0,0.0,-1.0), vertex3d_pos_normal(x1,y0,z0,0.0,0.0,-1.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,0.0,0.0,-1.0), vertex3d_pos_normal(x0,y1,z0,0.0,0.0,-1.0), vertex3d_pos_normal(x1,y1,z0,0.0,0.0,-1.0), mat, m)
        # top (+y)
        e.submit_triangle(vertex3d_pos_normal(x0,y1,z0,0.0,1.0,0.0), vertex3d_pos_normal(x0,y1,z1,0.0,1.0,0.0), vertex3d_pos_normal(x1,y1,z1,0.0,1.0,0.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x0,y1,z0,0.0,1.0,0.0), vertex3d_pos_normal(x1,y1,z1,0.0,1.0,0.0), vertex3d_pos_normal(x1,y1,z0,0.0,1.0,0.0), mat, m)
        # bottom (-y)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,0.0,-1.0,0.0), vertex3d_pos_normal(x1,y0,z1,0.0,-1.0,0.0), vertex3d_pos_normal(x0,y0,z1,0.0,-1.0,0.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,0.0,-1.0,0.0), vertex3d_pos_normal(x1,y0,z0,0.0,-1.0,0.0), vertex3d_pos_normal(x1,y0,z1,0.0,-1.0,0.0), mat, m)
        # left (-x)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,-1.0,0.0,0.0), vertex3d_pos_normal(x0,y0,z1,-1.0,0.0,0.0), vertex3d_pos_normal(x0,y1,z1,-1.0,0.0,0.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x0,y0,z0,-1.0,0.0,0.0), vertex3d_pos_normal(x0,y1,z1,-1.0,0.0,0.0), vertex3d_pos_normal(x0,y1,z0,-1.0,0.0,0.0), mat, m)
        # right (+x)
        e.submit_triangle(vertex3d_pos_normal(x1,y0,z0,1.0,0.0,0.0), vertex3d_pos_normal(x1,y1,z1,1.0,0.0,0.0), vertex3d_pos_normal(x1,y0,z1,1.0,0.0,0.0), mat, m)
        e.submit_triangle(vertex3d_pos_normal(x1,y0,z0,1.0,0.0,0.0), vertex3d_pos_normal(x1,y1,z0,1.0,0.0,0.0), vertex3d_pos_normal(x1,y1,z1,1.0,0.0,0.0), mat, m)
        i = i + 1
    e.end_frame()
    e.read_pixels()

fn ppm_text(pixels: [u32], w: i64, h: i64) -> text:
    var body = ""
    var y: i64 = 0
    while y < h:
        var row = ""
        var x: i64 = 0
        while x < w:
            val p = pixels[y * w + x]
            row = row + "{color3d_r(p)} {color3d_g(p)} {color3d_b(p)}\n"
            x = x + 1
        body = body + row
        y = y + 1
    "P3\n{w} {h}\n255\n" + body

# ============================================================================
# argument parsing
# ============================================================================

fn _parse_int(s: text) -> i64?:
    if s.len() == 0:
        return None
    var i = 0
    var n: i64 = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if (ch < "0" or ch > "9"):
            return None
        n = n * 10 + hex_to_int(ch)
        i = i + 1
    Some(n)

fn _parse_num(s: text) -> f64?:
    if s.len() == 0:
        return None
    var i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        val ok = (ch >= "0" and ch <= "9") or ch == "." or ch == "-" or ch == "+"
        if not ok:
            return None
        i = i + 1
    Some(s.to_f64())

fn _parse_vec3_arg(s: text) -> Vec3?:
    val parts = s.split(",")
    if parts.len() != 3:
        return None
    var out: [f64] = []
    var i = 0
    while i < 3:
        if val Some(f) = _parse_num(parts[i].trim()):
            out.push(f)
        else:
            return None
        i = i + 1
    Some(Vec3(x: out[0], y: out[1], z: out[2]))

# ============================================================================
# gen heightmap / gen tilemap
# ============================================================================

fn _height_color(h: f64) -> text:
    if h < 1.0: "2060A0"
    elif h < 2.0: "40A040"
    elif h < 2.8: "807040"
    else: "F0F0F0"

fn _gen_heightmap_text(seed: i64, w: i64, d: i64) -> text:
    val perm = perm_new(seed)
    var nodes_text = ""
    var z: i64 = 0
    while z < d:
        var x: i64 = 0
        while x < w:
            val fx = (x as f64) * 0.15
            val fz = (z as f64) * 0.15
            val raw = fbm2(perm, fx, fz, 4, 2.0, 0.5)
            val hh = 0.2 + (raw + 1.0) * 0.5 * 3.0
            val cx = (x as f64) - (w as f64) / 2.0
            val cz = (z as f64) - (d as f64) / 2.0
            val cy = hh / 2.0
            val color = _height_color(hh)
            if nodes_text != "":
                nodes_text = nodes_text + ", "
            # NOTE: literal `{`/`}` (SDN dict syntax) must be doubled to
            # `{{`/`}}` inside an interpolated string — a single `{ ... }`
            # containing other `{placeholder}`s is swallowed whole as one
            # failed placeholder lookup otherwise. See
            # doc/08_tracking/bug/interp_brace_literal_collides_with_string_interpolation_2026-07-03.md
            nodes_text = nodes_text + "{{ name: \"col_{x}_{z}\", shape: \"box\", center: [{cx}, {cy}, {cz}], size: [1.0, {hh}, 1.0], color: \"{color}\" }}"
            x = x + 1
        z = z + 1
    val eye_z = (d as f64) * 0.8 + 8.0
    "scene:\n  name: \"heightmap_seed{seed}\"\n  background: \"203040\"\n  camera: {{ eye: [0.0, 8.0, {eye_z}], target: [0.0, 0.0, 0.0], fov_deg: 60.0 }}\n  nodes: [{nodes_text}]\n"

# Shared `tilemap: { cols, rows, cells }` SDN serializer — used by both
# `gen tilemap` (CA cells) and `gen wfc` (WFC-collapsed cells) so the two
# emit the exact same loadable shape.
fn _cells_to_tilemap_sdn(cols: i64, rows: i64, cells: [[i32]]) -> text:
    var rows_text = ""
    var y: i64 = 0
    while y < rows:
        var row_text = ""
        var x: i64 = 0
        while x < cols:
            if row_text != "":
                row_text = row_text + ", "
            row_text = row_text + "{cells[y][x]}"
            x = x + 1
        if rows_text != "":
            rows_text = rows_text + ", "
        rows_text = rows_text + "[{row_text}]"
        y = y + 1
    "tilemap:\n  cols: {cols}\n  rows: {rows}\n  cells: [{rows_text}]\n"

fn _gen_tilemap_text(seed: i64, w: i64, h: i64) -> text:
    val cave = ca_generate(seed, w, h, 0.45, 30)
    _cells_to_tilemap_sdn(cave.cols, cave.rows, cave.cells)

fn _gen_wfc_text(seed: i64, w: i64, h: i64, tileset: TileSet) -> Result<text, text>:
    val r = wfc_generate(tileset, w, h, seed)
    if val Err(e) = r:
        return Err(e)
    var cells: [[i32]] = []
    if val Ok(c) = r:
        cells = c
    Ok(_cells_to_tilemap_sdn(w, h, cells))

fn cmd_gen_heightmap(args: [text]) -> i64:
    var seed_opt: i64? = None
    var w: i64 = 0
    var d: i64 = 0
    var out_path = ""
    var i: i64 = 0
    while i < args.len():
        val a = args[i]
        if (a == "--seed" or a == "--w" or a == "--d" or a == "--out"):
            if i + 1 >= args.len():
                print "error: {a} requires a value"
                return 2
            val v = args[i + 1]
            if a == "--seed":
                if val Some(n) = _parse_int(v):
                    seed_opt = Some(n)
                else:
                    print "error: --seed expects a non-negative integer, got \"{v}\""
                    return 2
            elif a == "--w":
                if val Some(n) = _parse_int(v):
                    w = n
                else:
                    print "error: --w expects a positive integer, got \"{v}\""
                    return 2
            elif a == "--d":
                if val Some(n) = _parse_int(v):
                    d = n
                else:
                    print "error: --d expects a positive integer, got \"{v}\""
                    return 2
            else:
                out_path = v
            i = i + 2
        else:
            print "error: unknown option {a}"
            return 2
    var seed: i64 = 0
    if val Some(s) = seed_opt:
        seed = s
    else:
        print "error: simple model3d gen heightmap --seed N --w W --d D --out <scene.sdn> — missing --seed"
        return 2
    if (w <= 0 or d <= 0):
        print "error: --w/--d must be positive integers (got {w}x{d})"
        return 2
    if out_path == "":
        print "error: simple model3d gen heightmap --seed N --w W --d D --out <scene.sdn> — missing --out"
        return 2
    val scene_text = _gen_heightmap_text(seed, w, d)
    if not write_file(out_path, scene_text):
        print "error: failed to write {out_path}"
        return 1
    print "wrote {out_path} ({w}x{d} columns, seed {seed})"
    0

fn cmd_gen_tilemap(args: [text]) -> i64:
    var seed_opt: i64? = None
    var w: i64 = 0
    var h: i64 = 0
    var out_path = ""
    var i: i64 = 0
    while i < args.len():
        val a = args[i]
        if (a == "--seed" or a == "--w" or a == "--h" or a == "--out"):
            if i + 1 >= args.len():
                print "error: {a} requires a value"
                return 2
            val v = args[i + 1]
            if a == "--seed":
                if val Some(n) = _parse_int(v):
                    seed_opt = Some(n)
                else:
                    print "error: --seed expects a non-negative integer, got \"{v}\""
                    return 2
            elif a == "--w":
                if val Some(n) = _parse_int(v):
                    w = n
                else:
                    print "error: --w expects a positive integer, got \"{v}\""
                    return 2
            elif a == "--h":
                if val Some(n) = _parse_int(v):
                    h = n
                else:
                    print "error: --h expects a positive integer, got \"{v}\""
                    return 2
            else:
                out_path = v
            i = i + 2
        else:
            print "error: unknown option {a}"
            return 2
    var seed: i64 = 0
    if val Some(s) = seed_opt:
        seed = s
    else:
        print "error: simple model3d gen tilemap --seed N --w W --h H --out <map.sdn> — missing --seed"
        return 2
    if (w <= 0 or h <= 0):
        print "error: --w/--h must be positive integers (got {w}x{h})"
        return 2
    if out_path == "":
        print "error: simple model3d gen tilemap --seed N --w W --h H --out <map.sdn> — missing --out"
        return 2
    val map_text = _gen_tilemap_text(seed, w, h)
    if not write_file(out_path, map_text):
        print "error: failed to write {out_path}"
        return 1
    print "wrote {out_path} ({w}x{h} cells, seed {seed})"
    0

fn cmd_gen_wfc(args: [text]) -> i64:
    var seed_opt: i64? = None
    var w: i64 = 0
    var h: i64 = 0
    var out_path = ""
    var tileset_path = ""
    var i: i64 = 0
    while i < args.len():
        val a = args[i]
        if (a == "--seed" or a == "--w" or a == "--h" or a == "--out" or a == "--tileset"):
            if i + 1 >= args.len():
                print "error: {a} requires a value"
                return 2
            val v = args[i + 1]
            if a == "--seed":
                if val Some(n) = _parse_int(v):
                    seed_opt = Some(n)
                else:
                    print "error: --seed expects a non-negative integer, got \"{v}\""
                    return 2
            elif a == "--w":
                if val Some(n) = _parse_int(v):
                    w = n
                else:
                    print "error: --w expects a positive integer, got \"{v}\""
                    return 2
            elif a == "--h":
                if val Some(n) = _parse_int(v):
                    h = n
                else:
                    print "error: --h expects a positive integer, got \"{v}\""
                    return 2
            elif a == "--tileset":
                tileset_path = v
            else:
                out_path = v
            i = i + 2
        else:
            print "error: unknown option {a}"
            return 2
    var seed: i64 = 0
    if val Some(s) = seed_opt:
        seed = s
    else:
        print "error: simple model3d gen wfc --seed N --w W --h H --out <map.sdn> — missing --seed"
        return 2
    if (w <= 0 or h <= 0):
        print "error: --w/--h must be positive integers (got {w}x{h})"
        return 2
    if out_path == "":
        print "error: simple model3d gen wfc --seed N --w W --h H --out <map.sdn> — missing --out"
        return 2
    var tileset = demo_tileset()
    if tileset_path != "":
        if not file_exists(tileset_path):
            print "error: tileset file not found: {tileset_path}"
            return 1
        val parsed = parse_tileset(file_read(tileset_path))
        if val Err(e) = parsed:
            print "error: {tileset_path}: {e}"
            return 1
        if val Ok(ts) = parsed:
            tileset = ts
    val text_r = _gen_wfc_text(seed, w, h, tileset)
    if val Err(e) = text_r:
        print "error: {e}"
        return 1
    var map_text = ""
    if val Ok(t) = text_r:
        map_text = t
    if not write_file(out_path, map_text):
        print "error: failed to write {out_path}"
        return 1
    print "wrote {out_path} ({w}x{h} cells, seed {seed})"
    0

fn cmd_gen(args: [text]) -> i64:
    if args.len() < 1:
        print "error: simple model3d gen <heightmap|tilemap|wfc> [options] — missing gen mode"
        return 2
    val mode = args[0]
    var rest: [text] = []
    var i: i64 = 1
    while i < args.len():
        rest.push(args[i])
        i = i + 1
    if mode == "heightmap":
        return cmd_gen_heightmap(rest)
    elif mode == "tilemap":
        return cmd_gen_tilemap(rest)
    elif mode == "wfc":
        return cmd_gen_wfc(rest)
    print "error: unknown gen mode: {mode} (supported: heightmap, tilemap, wfc)"
    2

fn print_usage():
    print "Usage: simple model3d <subcommand> [args]"
    print ""
    print "Subcommands:"
    print "  inspect <scene.sdn>              Validate scene; print node tree, counts, materials, bounds"
    print "  render <scene.sdn> --out <ppm>   Render headless to a P3 PPM"
    print "      [--width N] [--height N]     Default 256x192, range {MIN_DIM}..{MAX_DIM}"
    print "      [--eye X,Y,Z] [--target X,Y,Z] [--fov DEG]  Override scene camera"
    print "  gen heightmap --seed N --w W --d D --out <scene.sdn>   Seeded fbm2 heightmap -> box-node scene SDN"
    print "  gen tilemap --seed N --w W --h H --out <map.sdn>       Seeded CA cave (4-5 rule) -> [[i32]] tilemap SDN"
    print "  gen wfc --seed N --w W --h H [--tileset f.sdn] --out <map.sdn>  Seeded WFC -> [[i32]] tilemap SDN"
    print ""
    print "Exit codes: 0 ok, 1 failure, 2 usage error"

fn cmd_render(args: [text]) -> i64:
    var scene_path = ""
    var out_path = ""
    var w: i64 = 256
    var h: i64 = 192
    var eye_override: Vec3? = None
    var target_override: Vec3? = None
    var fov_override: f64? = None
    var i: i64 = 0
    while i < args.len():
        val a = args[i]
        if (a == "--out" or a == "--width" or a == "--height" or a == "--eye" or a == "--target" or a == "--fov"):
            if i + 1 >= args.len():
                print "error: {a} requires a value"
                return 2
            val v = args[i + 1]
            if a == "--out":
                out_path = v
            elif (a == "--width" or a == "--height"):
                if val Some(n) = _parse_int(v):
                    if a == "--width":
                        w = n
                    else:
                        h = n
                else:
                    print "error: {a} expects a positive integer, got \"{v}\""
                    return 2
            elif (a == "--eye" or a == "--target"):
                if val Some(v3) = _parse_vec3_arg(v):
                    if a == "--eye":
                        eye_override = Some(v3)
                    else:
                        target_override = Some(v3)
                else:
                    print "error: {a} expects X,Y,Z numbers, got \"{v}\""
                    return 2
            else:
                if val Some(f) = _parse_num(v):
                    fov_override = Some(f)
                else:
                    print "error: --fov expects a number, got \"{v}\""
                    return 2
            i = i + 2
        elif a.starts_with("--"):
            print "error: unknown option {a}"
            return 2
        else:
            if scene_path != "":
                print "error: unexpected extra argument \"{a}\""
                return 2
            scene_path = a
            i = i + 1
    if scene_path == "":
        print "error: simple model3d render <scene.sdn> --out <file.ppm> — missing scene file"
        return 2
    if out_path == "":
        print "error: simple model3d render <scene.sdn> --out <file.ppm> — missing --out"
        return 2
    if (w < MIN_DIM or w > MAX_DIM or h < MIN_DIM or h > MAX_DIM):
        print "error: --width/--height must be in {MIN_DIM}..{MAX_DIM} (got {w}x{h})"
        return 2
    val loaded = load_scene(scene_path)
    if val Err(e) = loaded:
        print "error: {e}"
        return 1
    var scene = Scene3(name: "", background: 0, eye: Vec3(x: 0.0, y: 0.0, z: 0.0), target: Vec3(x: 0.0, y: 0.0, z: 0.0), fov_deg: 60.0, nodes: [])
    if val Ok(s) = loaded:
        scene = s
    if val Some(v3) = eye_override:
        scene.eye = v3
    if val Some(v3) = target_override:
        scene.target = v3
    if val Some(f) = fov_override:
        if (f < 10.0 or f > 170.0):
            print "error: --fov must be in 10..170 (got {f})"
            return 2
        scene.fov_deg = f
    val pixels = render_scene(scene, w, h)
    if not write_file(out_path, ppm_text(pixels, w, h)):
        print "error: failed to write {out_path}"
        return 1
    print "wrote {out_path} ({w}x{h}, {scene.nodes.len()} nodes)"
    0

fn main() -> i64:
    val args = get_cli_args()
    if args.len() < 1:
        print_usage()
        return 2
    val sub = args[0]
    if (sub == "--help" or sub == "-h" or sub == "help"):
        print_usage()
        return 0
    if sub == "inspect":
        if args.len() < 2:
            print "error: simple model3d inspect <scene.sdn> — missing scene file"
            return 2
        if args.len() > 2:
            print "error: simple model3d inspect takes exactly one scene file"
            return 2
        return cmd_inspect(args[1])
    if sub == "render":
        var rest: [text] = []
        var i: i64 = 1
        while i < args.len():
            rest.push(args[i])
            i = i + 1
        return cmd_render(rest)
    if sub == "gen":
        var rest: [text] = []
        var i: i64 = 1
        while i < args.len():
            rest.push(args[i])
            i = i + 1
        return cmd_gen(rest)
    print "error: unknown subcommand: {sub}"
    print_usage()
    2
