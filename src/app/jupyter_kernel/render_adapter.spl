# Jupyter Kernel Render Adapter
#
# Bridges the Jupyter kernel app to the shared UI render contract.
# Produces RenderResult showing kernel status, cell execution history,
# and a notebook-style view with cell cards.
#
# Uses shared components: html_card, html_badge, fmt_duration_ms

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_escape, html_card, html_badge,
    html_metric_card, html_section, html_grid,
    css_dark_theme, css_light_theme, css_color_var}
use app.ui.render.css.{card_css, grid_css, badge_css, table_css}
use app.ui.render.table.{TableBuilder, ALIGN_LEFT, ALIGN_RIGHT}
use app.ui.render.fmt.{fmt_duration_ms, fmt_count, fmt_number, separator}

# =========================================================================
# Main Entry Point
# =========================================================================

fn render_jupyter_kernel(config: RenderConfig) -> RenderResult:
    """Render Jupyter kernel status via the shared render contract."""
    val fmt = config.format
    match fmt:
        "html":
            return render_kernel_html(config)
        "both":
            return RenderResult.both(
                render_kernel_text(config),
                render_kernel_html_body(config)
            )
        _:
            return RenderResult.text(render_kernel_text(config))

# =========================================================================
# Text Rendering
# =========================================================================

fn render_kernel_text(config: RenderConfig) -> text:
    """Render kernel status as plain text."""
    var out = ""
    out = "{out}{separator(\"=\", config.width)}\n"
    out = "{out}  Simple Jupyter Kernel Status\n"
    out = "{out}{separator(\"=\", config.width)}\n\n"

    # Kernel info
    out = "{out}Kernel:   simple-kernel 0.1.0\n"
    out = "{out}Language: Simple 0.2.0\n"
    out = "{out}Protocol: Jupyter 5.4\n"
    out = "{out}Status:   idle\n\n"

    # Execution history
    out = "{out}Cell Execution History:\n"
    var tb = TableBuilder.new(["In", "Status", "Time", "Code"])
    tb = tb.set_alignment(0, ALIGN_RIGHT)
    tb = tb.set_alignment(2, ALIGN_RIGHT)
    tb = tb.set_max_width(3, 40)
    tb = tb.add_row(["[1]", "ok", fmt_duration_ms(45), "val name = \"Alice\""])
    tb = tb.add_row(["[2]", "ok", fmt_duration_ms(120), "fn square(x): x * x"])
    tb = tb.add_row(["[3]", "ok", fmt_duration_ms(80), "print \"Hello, {name}!\""])
    tb = tb.add_row(["[4]", "error", fmt_duration_ms(230), "val result = undefined_fn()"])
    tb = tb.add_row(["[5]", "ok", fmt_duration_ms(55), "val items = [1, 2, 3, 4, 5]"])
    out = "{out}{tb.build()}\n"

    out = "{out}Executed: {fmt_count(5, \"cell\", \"cells\")} "
    out = "{out}(4 succeeded, 1 failed)\n"
    out

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_kernel_html(config: RenderConfig) -> text:
    """Render kernel status as a full HTML page."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val cell_css = render_cell_css()
    val css = "{theme_css}\n{card_css()}\n{grid_css()}\n{badge_css()}\n{table_css()}\n{cell_css}"
    val body = render_kernel_html_body(config)
    html_page("Simple Jupyter Kernel", css, body)

fn render_kernel_html_body(config: RenderConfig) -> text:
    """Render the kernel status HTML body content."""
    var h = "<div style=\"max-width:960px; margin:0 auto\">\n"
    h = "{h}<h1 style=\"margin-bottom:16px\">Simple Jupyter Kernel</h1>\n"

    # Status metric cards
    val status_badge = html_badge("Idle", css_color_var("green"))
    val cards = [
        html_metric_card("Kernel", "simple-kernel", "v0.1.0"),
        html_metric_card("Status", status_badge, ""),
        html_metric_card("Cells Executed", "5", "4 ok, 1 error"),
        html_metric_card("Language", "Simple 0.2.0", "Jupyter 5.4")
    ]
    h = "{h}{html_grid(4, \"12px\", cards)}\n"

    # Notebook-style cell cards
    h = "{h}<h2 style=\"font-size:16px; margin:20px 0 12px; color:var(--text-dim, #8b949e)\">Cell History</h2>\n"

    h = "{h}{render_cell_card(1, \"ok\", 45, \"val name = \\\"Alice\\\"\", \"\")}\n"
    h = "{h}{render_cell_card(2, \"ok\", 120, \"fn square(x): x * x\", \"\")}\n"
    h = "{h}{render_cell_card(3, \"ok\", 80, \"print \\\"Hello, {name}!\\\"\", \"Hello, Alice!\")}\n"
    h = "{h}{render_cell_card(4, \"error\", 230, \"val result = undefined_fn()\", \"ExecutionError: undefined_fn is not defined\")}\n"
    h = "{h}{render_cell_card(5, \"ok\", 55, \"val items = [1, 2, 3, 4, 5]\", \"\")}\n"

    h = "{h}</div>\n"
    h

# =========================================================================
# Cell Card Helper
# =========================================================================

fn render_cell_card(index: i64, status: text, time_ms: i64, code: text, output: text) -> text:
    """Render a single notebook cell as an HTML card."""
    val status_color = if status == "ok": css_color_var("green") else: css_color_var("red")
    val status_label = if status == "ok": "OK" else: "Error"
    val badge = html_badge(status_label, status_color)
    val time_str = fmt_duration_ms(time_ms)

    var h = "<div class=\"cell-card\">\n"
    h = "{h}  <div class=\"cell-header\">\n"
    h = "{h}    <span class=\"cell-index\">In [{index}]</span>\n"
    h = "{h}    {badge}\n"
    h = "{h}    <span class=\"cell-time\">{html_escape(time_str)}</span>\n"
    h = "{h}  </div>\n"
    h = "{h}  <pre class=\"cell-code\">{html_escape(code)}</pre>\n"

    if output != "":
        val out_class = if status == "ok": "cell-output" else: "cell-error"
        h = "{h}  <pre class=\"{out_class}\">{html_escape(output)}</pre>\n"

    h = "{h}</div>\n"
    h

fn render_cell_css() -> text:
    """CSS for notebook-style cell cards."""
    var s = ""
    s = "{s}.cell-card {\n"
    s = "{s}  background: var(--bg-card, #161b22);\n"
    s = "{s}  border: 1px solid var(--border, #30363d);\n"
    s = "{s}  border-radius: 8px;\n"
    s = "{s}  margin-bottom: 8px;\n"
    s = "{s}  overflow: hidden;\n"
    s = "{s}}\n"
    s = "{s}.cell-header {\n"
    s = "{s}  display: flex;\n"
    s = "{s}  align-items: center;\n"
    s = "{s}  gap: 8px;\n"
    s = "{s}  padding: 8px 12px;\n"
    s = "{s}  border-bottom: 1px solid var(--border, #30363d);\n"
    s = "{s}  font-size: 12px;\n"
    s = "{s}}\n"
    s = "{s}.cell-index {\n"
    s = "{s}  font-family: 'SF Mono', 'Cascadia Code', monospace;\n"
    s = "{s}  color: var(--blue, #58a6ff);\n"
    s = "{s}  font-weight: 600;\n"
    s = "{s}}\n"
    s = "{s}.cell-time {\n"
    s = "{s}  color: var(--text-dim, #8b949e);\n"
    s = "{s}  margin-left: auto;\n"
    s = "{s}}\n"
    s = "{s}.cell-code {\n"
    s = "{s}  font-family: 'SF Mono', 'Cascadia Code', monospace;\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  padding: 10px 12px;\n"
    s = "{s}  margin: 0;\n"
    s = "{s}  background: var(--bg, #0d1117);\n"
    s = "{s}}\n"
    s = "{s}.cell-output {\n"
    s = "{s}  font-family: 'SF Mono', 'Cascadia Code', monospace;\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  padding: 8px 12px;\n"
    s = "{s}  margin: 0;\n"
    s = "{s}  color: var(--green, #3fb950);\n"
    s = "{s}  border-top: 1px solid var(--border, #30363d);\n"
    s = "{s}}\n"
    s = "{s}.cell-error {\n"
    s = "{s}  font-family: 'SF Mono', 'Cascadia Code', monospace;\n"
    s = "{s}  font-size: 13px;\n"
    s = "{s}  padding: 8px 12px;\n"
    s = "{s}  margin: 0;\n"
    s = "{s}  color: var(--red, #f85149);\n"
    s = "{s}  border-top: 1px solid var(--border, #30363d);\n"
    s = "{s}}\n"
    s
