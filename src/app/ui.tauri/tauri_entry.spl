# Minimal Tauri Entry Point
#
# Parses .ui.sdn and outputs JSON IPC render message to stdout.

use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use common.text_advanced.{escape_json}

extern fn rt_cli_get_args() -> [text]

fn get_args() -> [text]:
    rt_cli_get_args()

fn args_len(a: [text]) -> i64:
    a.len()

fn arg_ends(s: text, suffix: text) -> bool:
    s.ends_with(suffix)

fn find_sdn_file(args: [text]) -> text:
    var i = 0
    val count = args_len(args)
    while i < count:
        val arg = args[i]
        i = i + 1
        if arg_ends(arg, ".ui.sdn"):
            return arg
    return ""

fn emit_render(html: text):
    val escaped = escape_json(html)
    print "{\"type\":\"render\",\"html\":\"{escaped}\"}"

fn emit_error(msg: text):
    val escaped = escape_json(msg)
    emit_render("<div style=\"padding:24px;color:#ff6b6b\"><h2>Error</h2><pre>{escaped}</pre></div>")

fn tauri_render_fragment(file_path: text) -> Result<text, text>:
    val tree_result = parse_ui_to_tree(file_path)
    match tree_result:
        Err(e):
            return Err(e)
        Ok(tree):
            val state = init_state(tree)
            val css = generate_css(state.tree.theme_name())
            val body_html = render_html_tree(state.tree.root_node(), state)
            return Ok("<style>{css}</style><div class=\"tauri-app-root\">{body_html}</div>")

fn main() -> i64:
    val args = get_args()
    val file_path = find_sdn_file(args)

    if file_path == "":
        emit_render("<div style=\"padding:24px\"><h2>No .ui.sdn file specified</h2></div>")
        return 1

    val result = tauri_render_fragment(file_path)
    match result:
        case Ok(html):
            emit_render(html)
            return 0
        case Err(e):
            emit_error(e)
            return 1
