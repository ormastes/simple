# Minimal Tauri Entry Point
#
# Parses .ui.sdn and outputs JSON IPC render message to stdout.

use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use common.ui.web_render_api.{WEB_RENDER_TARGET_TAURI, WebRenderRequest, web_render_to_artifact}

extern fn rt_cli_get_args() -> [text]

fn get_args() -> [text]:
    rt_cli_get_args()

fn args_len(a: [text]) -> i64:
    a.len()

fn arg_ends(s: text, suffix: text) -> bool:
    s.ends_with(suffix)

fn find_sdn_file(args: [text]) -> text:
    var i = 0
    val count = args_len(args)
    while i < count:
        val arg = args[i]
        i = i + 1
        if arg_ends(arg, ".ui.sdn"):
            return arg
    return ""

fn emit_render(html: text):
    val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", html, "", "", 1280, 720).with_surface("main")
    print web_render_to_artifact(req).ipc_json

fn emit_error(msg: text):
    emit_render("<div style=\"padding:24px;color:#ff6b6b\"><h2>Error</h2><pre>{msg}</pre></div>")

fn tauri_render_fragment(file_path: text) -> Result<text, text>:
    val tree_result = parse_ui_to_tree(file_path)
    match tree_result:
        Err(e):
            return Err(e)
        Ok(tree):
            val state = init_state(tree)
            val css = generate_css(state.tree.theme_name())
            val body_html = render_html_tree(state.tree.root_node(), state)
            return Ok("<style>{css}</style><div class=\"tauri-app-root\">{body_html}</div>")

pub fn tauri_entry_render_ipc(file_path: text) -> Result<text, text>:
    val fragment = tauri_render_fragment(file_path)
    match fragment:
        Err(e):
            return Err(e)
        Ok(html):
            val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", html, "", "", 1280, 720).with_surface("main")
            return Ok(web_render_to_artifact(req).ipc_json)

fn main() -> i64:
    val args = get_args()
    val file_path = find_sdn_file(args)

    if file_path == "":
        emit_render("<div style=\"padding:24px\"><h2>No .ui.sdn file specified</h2></div>")
        return 1

    val result = tauri_entry_render_ipc(file_path)
    match result:
        case Ok(ipc_json):
            print ipc_json
            return 0
        case Err(e):
            emit_error(e)
            return 1
