# Minimal Tauri Entry Point
#
# Parses .ui.sdn and outputs JSON IPC render message to stdout.

use common.ui.parse.sdn.{parse_ui_file}

extern fn rt_cli_get_args() -> [text]

fn get_args() -> [text]:
    rt_cli_get_args()

fn args_len(a: [text]) -> i64:
    a.len()

fn arg_ends(s: text, suffix: text) -> bool:
    s.ends_with(suffix)

fn find_sdn_file(args: [text]) -> text:
    var i = 0
    val count = args_len(args)
    while i < count:
        val arg = args[i]
        i = i + 1
        if arg_ends(arg, ".ui.sdn"):
            return arg
    return ""

fn json_escape_char(ch: text) -> text:
    if ch == "\\":
        return "\\\\"
    if ch == "\"":
        return "\\\""
    if ch == "\n":
        return "\\n"
    if ch == "\r":
        return "\\r"
    if ch == "\t":
        return "\\t"
    return ch

fn str_len(s: text) -> i64:
    s.len()

fn json_escape(s: text) -> text:
    var result = ""
    var ci = 0
    val slen = str_len(s)
    while ci < slen:
        val ch = s[ci]
        ci = ci + 1
        result = result + json_escape_char(ch)
    return result

fn emit_render(html: text):
    val escaped = json_escape(html)
    print "{\"type\":\"render\",\"html\":\"{escaped}\"}"

fn emit_error(msg: text):
    val escaped = json_escape(msg)
    emit_render("<div style=\"padding:24px;color:#ff6b6b\"><h2>Error</h2><pre>{escaped}</pre></div>")

fn main() -> i64:
    val args = get_args()
    val file_path = find_sdn_file(args)

    if file_path == "":
        emit_render("<div style=\"padding:24px\"><h2>No .ui.sdn file specified</h2></div>")
        return 1

    val result = parse_ui_file(file_path)
    match result:
        case Ok(html):
            emit_render(html)
            return 0
        case Err(e):
            emit_error(e)
            return 1
