# Tauri Application Main Loop
#
# Runs the Tauri mode: loads .ui.sdn, renders HTML via IPC,
# polls stdin for JSON events from the Tauri shell.

use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state, update_state, update_tree, is_quit_event}
use app.ui.tauri.backend.{TauriBackend}
use app.ui.tauri.ipc.{parse_ipc_message, build_ipc_render}
use app.ui.render.widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use app.io.env_ops.{env_get}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_stdin_read_line() -> text?
extern fn rt_cli_get_args() -> [text]

# =========================================================================
# Tauri App
# =========================================================================

class TauriApp:
    file_path: text
    state: UIState
    backend: TauriBackend
    running: bool
    last_file_content: text

    static fn new(file_path: text, port: i32) -> Result<TauriApp, text>:
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                val state = init_state(tree)
                val backend_result = TauriBackend.new(port)
                match backend_result:
                    Err(e):
                        return Err(e)
                    Ok(backend):
                        val init_result = backend.init()
                        match init_result:
                            Err(e):
                                return Err(e)
                            Ok(_):
                                pass_dn

                        val content = if rt_file_exists(file_path):
                            rt_file_read_text(file_path)
                        else:
                            ""

                        return Ok(TauriApp(
                            file_path: file_path,
                            state: state,
                            backend: backend,
                            running: true,
                            last_file_content: content
                        ))

    me run():
        """Main Tauri IPC loop."""
        # Initial render
        self.send_render()

        while self.running:
            val event = self.poll_ipc()

            if event != nil:
                match event:
                    UIEvent.Quit:
                        self.running = false
                    _:
                        self.state = update_state(self.state, event)
                        self.check_file_changes()
                        self.send_render()
            else:
                # No event — check for file changes
                self.check_file_changes()

        # Cleanup
        self.backend.shutdown()

    fn poll_ipc() -> UIEvent?:
        """Read a line from stdin and parse as IPC message."""
        val line = rt_stdin_read_line()
        if line == nil:
            return nil
        if line == "":
            return nil
        return parse_ipc_message(line)

    fn send_render():
        """Render the current state and send via IPC to stdout."""
        val theme = self.state.tree.theme_name()
        val css = generate_css(theme)
        val body_html = render_html_tree(self.state.tree.root_node(), self.state)
        val html = "<html><head><style>{css}</style></head><body><div id=\"app\">{body_html}</div></body></html>"
        val ipc_msg = build_ipc_render(html)
        print ipc_msg


    me check_file_changes():
        """Check if the .ui.sdn file has changed and reload if so."""
        if not rt_file_exists(self.file_path):
            return

        val current_content = rt_file_read_text(self.file_path)
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_to_tree(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.state = update_tree(self.state, new_tree)
                Err(e):
                    # Keep old state on parse error
                    pass_dn

fn tauri_shared_wm_requested(args: [text], env_val: text) -> bool:
    for a in args:
        if a == "--shared-wm":
            return true
    env_val == "1"

fn tauri_shared_wm_error() -> text:
    return "Error: shared WM mode is not supported by the standalone Tauri shell yet. Run without --shared-wm, or use a shared-WM-capable host backend such as browser or electron."

# =========================================================================
# Entry Point
# =========================================================================

fn run_tauri(file_path: text, port: i32) -> i64:
    """Start Tauri mode for a .ui.sdn file."""
    val args = rt_cli_get_args()
    val shared_wm_env = env_get("SIMPLE_UI_TAURI_SHARED_WM")
    if tauri_shared_wm_requested(args, shared_wm_env):
        print tauri_shared_wm_error()
        return 1
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val app_result = TauriApp.new(file_path, port)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            app.run()
            return 0
