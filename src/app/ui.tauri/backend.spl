# Tauri Render Backend
#
# Implements RenderBackend for Tauri desktop applications.
# Uses the shared IPC protocol over stdin/stdout JSON.
# This is the default GUI backend.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent, WidgetNode, WidgetRect}
use common.ui.capability.{Capability, NotSupported}
use common.ui.semantic_contract.{
    SEMANTIC_UI_STAGE_RENDERER,
    SEMANTIC_UI_STATUS_AVAILABLE,
    SemanticUiCommand,
    SemanticUiRenderTransportBundle,
    SemanticUiSnapshot,
    semantic_ui_render_transport_bundle,
    semantic_ui_snapshot_from_state_with_capabilities,
    semantic_ui_snapshot_to_json,
    semantic_ui_snapshot_transport_json
}
use common.ui.capability_policy.{CapabilityPolicy, require_capability}
use common.ui.web_render_api.{
    WEB_RENDER_TARGET_TAURI,
    WebRenderHostWindowCommand,
    WebRenderRequest,
    web_render_body_html,
    web_render_capabilities_for_target,
    web_render_host_window_command_to_json,
    web_render_ipc_json_with_html_and_semantic,
    web_render_input_envelope_from_event,
    web_render_input_envelope_to_json,
    web_render_to_artifact
}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use app.ui.web.backend.{web_render_patch_transport_json, web_render_snapshot_transport_json}
use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_notification, build_ipc_dialog}

extern fn rt_stdin_read_line() -> text?

fn tauri_render_ipc_json(state: UIState, viewport_w: i32, viewport_h: i32) -> text:
    val theme = state.tree.theme_name()
    val css = generate_css(theme)
    val body_html = render_html_tree(state.tree.root_node(), state)
    val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", body_html, css, "", viewport_w, viewport_h)
    web_render_to_artifact(req).ipc_json

fn tauri_semantic_render_ipc_json(state: UIState, viewport_w: i32, viewport_h: i32) -> text:
    val theme = state.tree.theme_name()
    val css = generate_css(theme)
    val body_html = render_html_tree(state.tree.root_node(), state)
    val full_html = "<html><head><title></title><style>" + css + "</style></head><body><div id=\"app\">" + body_html + "</div></body></html>"
    val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", body_html, css, "", viewport_w, viewport_h)
    web_render_ipc_json_with_html_and_semantic(req, full_html, semantic_ui_snapshot_to_json(tauri_semantic_snapshot(state)))

# =========================================================================
# Tauri Backend
# =========================================================================

class TauriBackend:
    port: i32
    initialized: bool
    capability_policy: CapabilityPolicy
    touch_supported: bool

    static fn new(port: i32) -> Result<TauriBackend, text>:
        return Ok(TauriBackend(
            port: port,
            initialized: false,
            capability_policy: CapabilityPolicy.allow_all("tauri_main"),
            touch_supported: false
        ))

    static fn new_with_policy(port: i32, policy: CapabilityPolicy) -> Result<TauriBackend, text>:
        return Ok(TauriBackend(
            port: port,
            initialized: false,
            capability_policy: policy,
            touch_supported: false
        ))

    static fn new_mobile(port: i32) -> Result<TauriBackend, text>:
        return Ok(TauriBackend(
            port: port,
            initialized: false,
            capability_policy: CapabilityPolicy.allow_all("tauri_mobile"),
            touch_supported: true
        ))

    static fn new_android(port: i32) -> Result<TauriBackend, text>:
        return TauriBackend.new_mobile(port)

    static fn new_ios(port: i32) -> Result<TauriBackend, text>:
        return TauriBackend.new_mobile(port)

    static fn new_mobile_with_policy(port: i32, policy: CapabilityPolicy) -> Result<TauriBackend, text>:
        return Ok(TauriBackend(
            port: port,
            initialized: false,
            capability_policy: policy,
            touch_supported: true
        ))

    # --- Lifecycle ---

    me init() -> Result<bool, text>:
        self.initialized = true
        return Ok(true)

    me shutdown():
        self.initialized = false

    # --- Rendering ---

    fn render(state: UIState) -> Result<bool, text>:
        print tauri_render_ipc_json(state, self.viewport_width(), self.viewport_height())
        return Ok(true)

    fn render_html(state: UIState) -> text:
        val body = render_html_tree(state.tree.root_node(), state)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", body, "", "", self.viewport_width(), self.viewport_height())
        return web_render_body_html(req)

    # --- Events ---

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        val line = rt_stdin_read_line()
        if line == nil:
            return nil
        if line == "":
            return nil
        return parse_ipc_message(line)

    fn input_envelope_json(surface_id: text, event: UIEvent) -> text:
        val env = web_render_input_envelope_from_event(WEB_RENDER_TARGET_TAURI, surface_id, event)
        web_render_input_envelope_to_json(env)

    fn snapshot_envelope_json(surface_id: text, revision: u64, snapshot_json: text) -> text:
        web_render_snapshot_transport_json(WEB_RENDER_TARGET_TAURI, surface_id, revision, snapshot_json)

    fn patch_envelope_json(surface_id: text, from_sequence: u64, to_sequence: u64, patches_json: text, snapshot_json: text) -> text:
        web_render_patch_transport_json(WEB_RENDER_TARGET_TAURI, surface_id, from_sequence, to_sequence, patches_json, snapshot_json)

    fn host_window_command_json(cmd: WebRenderHostWindowCommand) -> text:
        web_render_host_window_command_to_json(cmd)

    fn semantic_snapshot_json(state: UIState) -> text:
        semantic_ui_snapshot_to_json(tauri_semantic_snapshot(state))

    fn semantic_snapshot_envelope_json(state: UIState, surface_id: text, revision: u64) -> text:
        semantic_ui_snapshot_transport_json(WEB_RENDER_TARGET_TAURI, surface_id, revision, tauri_semantic_snapshot(state))

    fn semantic_transport_bundle(state: UIState, surface_id: text, command: SemanticUiCommand, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text) -> SemanticUiRenderTransportBundle:
        semantic_ui_render_transport_bundle(WEB_RENDER_TARGET_TAURI, surface_id, tauri_semantic_snapshot(state), command, revision, from_sequence, to_sequence, patches_json)

    fn semantic_render_ipc_json(state: UIState) -> text:
        tauri_semantic_render_ipc_json(state, self.viewport_width(), self.viewport_height())

    # --- Capabilities ---

    fn capabilities() -> [Capability]:
        var caps = web_render_capabilities_for_target(WEB_RENDER_TARGET_TAURI)
        if self.touch_supported:
            caps = caps.push(Capability.Touch)
            return caps
        return caps

    fn supports_mouse() -> bool:
        return true

    fn supports_color() -> bool:
        return true

    fn supports_images() -> bool:
        return true

    fn supports_touch() -> bool:
        return self.touch_supported

    # --- Viewport ---

    fn viewport_width() -> i32:
        # Responsive: Tauri WebView adapts to window/screen size
        return 1280

    fn viewport_height() -> i32:
        return 720

    # --- Backend Info ---

    fn backend_name() -> text:
        return "tauri"

    # --- Optional: Override supported capabilities ---

    fn render_image(node: WidgetNode, rect: WidgetRect) -> Result<bool, NotSupported>:
        # Tauri webview handles images natively via HTML <img> tags
        return Ok(true)

    fn show_notification(title: text, body: text) -> Result<bool, NotSupported>:
        val cap_check = require_capability(self.capability_policy, Capability.Notification)
        match cap_check:
            Err(e): return Err(e)
            _: pass_dn
        val msg = build_ipc_notification(title, body)
        print msg
        return Ok(true)

    fn show_dialog(kind: text, title: text, message: text) -> Result<text, NotSupported>:
        val cap_check = require_capability(self.capability_policy, Capability.NativeDialogs)
        match cap_check:
            Err(e): return Err(e)
            _: pass_dn
        val msg = build_ipc_dialog(kind, title, message)
        print msg
        return Ok("")

    # --- Tauri-specific ---

    fn generate_full_page(state: UIState) -> text:
        """Generate a complete HTML page for Tauri webview."""
        val body = render_html_tree(state.tree.root_node(), state)
        val css = generate_css(state.tree.theme_name())
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_TAURI, "", body, css, "", self.viewport_width(), self.viewport_height())
        return web_render_to_artifact(req).html

fn tauri_semantic_snapshot(state: UIState) -> SemanticUiSnapshot:
    semantic_ui_snapshot_from_state_with_capabilities(state, SEMANTIC_UI_STAGE_RENDERER, SEMANTIC_UI_STATUS_AVAILABLE, web_render_capabilities_for_target(WEB_RENDER_TARGET_TAURI))
