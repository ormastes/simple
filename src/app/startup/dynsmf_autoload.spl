use os.smf.dynsmf_session.{
    DynSmfSession,
    DynSmfEvidenceRow,
    DynSmfManifestEntry,
    dynsmf_default_manifest,
    dynsmf_policy_from_args_env,
    dynsmf_session_autoload_checked,
    dynsmf_session_new,
    dynsmf_session_queue_missing_background_compiles,
    dynsmf_srchash_path,
    dynsmf_source_hash_current,
    dynsmf_manifest_source_path,
    dynsmf_background_compile_action,
    dynsmf_abi_path,
    dynsmf_ifacehash_path,
    dynsmf_interface_hash_current,
    dynsmf_artifact_status
}
use app.io.mod.{env_get, process_spawn_async}

fn dynsmf_dispatch_background_compiles(session: DynSmfSession, manifest: [DynSmfManifestEntry]) -> DynSmfSession:
    var out = session
    var idx = 0
    while idx < out.evidence.len():
        val row = out.evidence[idx]
        if (row.action == dynsmf_background_compile_action() and row.status == "queued"):
            var found_source = ""
            var found_path = ""
            var found_abi = ""
            var mid = 0
            while mid < manifest.len():
                if manifest[mid].id == row.library_id:
                    found_source = dynsmf_manifest_source_path(manifest[mid])
                    found_path = manifest[mid].path
                    found_abi = manifest[mid].abi_version
                mid = mid + 1
            if found_source != "" and found_path != "":
                val current_hash = dynsmf_source_hash_current(found_source)
                val current_iface_hash = dynsmf_interface_hash_current(found_source)
                val srchash_sidecar = dynsmf_srchash_path(found_path)
                val ifacehash_sidecar = dynsmf_ifacehash_path(found_path)
                val abi_sidecar = dynsmf_abi_path(found_path)
                # Sidecars are written only after a successful compile so a
                # failed/partial compile never leaves a fresh-looking status.
                val shell_cmd = "bin/simple compile " + found_source + " -o " + found_path +
                    " && printf %s " + current_hash.to_text() + " > " + srchash_sidecar +
                    " && printf %s " + current_iface_hash.to_text() + " > " + ifacehash_sidecar +
                    " && printf %s " + found_abi + " > " + abi_sidecar
                val pid = process_spawn_async("sh", ["-c", shell_cmd])
                if pid > 0:
                    out.evidence.push(DynSmfEvidenceRow(library_id: row.library_id, action: dynsmf_background_compile_action(), policy_source: out.policy.source, status: "dispatched", handle: pid, generation: out.generation, reason: "spawned_pid:" + pid.to_text()))
                else:
                    out.evidence.push(DynSmfEvidenceRow(library_id: row.library_id, action: dynsmf_background_compile_action(), policy_source: out.policy.source, status: "failed", handle: 0, generation: out.generation, reason: "spawn_failed"))
        idx = idx + 1
    out

export dynsmf_dispatch_background_compiles

pub fn dynsmf_startup_session_for_manifest_from_values(args: [text], env_dynsmf: text, env_disable: text, session_id: text, manifest: [DynSmfManifestEntry]) -> DynSmfSession:
    val policy = dynsmf_policy_from_args_env(args, env_dynsmf, env_disable)
    val queued = dynsmf_session_queue_missing_background_compiles(dynsmf_session_new(session_id, policy), manifest)
    val dispatched = dynsmf_dispatch_background_compiles(queued, manifest)
    dynsmf_session_autoload_checked(dispatched, manifest)

pub fn dynsmf_startup_session_from_values(args: [text], env_dynsmf: text, env_disable: text, session_id: text) -> DynSmfSession:
    dynsmf_startup_session_for_manifest_from_values(args, env_dynsmf, env_disable, session_id, dynsmf_default_manifest())

pub fn dynsmf_startup_session(args: [text], session_id: text) -> DynSmfSession:
    dynsmf_startup_session_from_values(
        args,
        env_get("SIMPLE_DYNSMF") ?? "",
        env_get("SIMPLE_DYNSMF_DISABLE") ?? "",
        session_id
    )

pub fn dynsmf_startup_summary(session: DynSmfSession) -> text:
    var loaded = 0
    var skipped = 0
    var failed = 0
    var idx = 0
    while idx < session.evidence.len():
        val row = session.evidence[idx]
        if row.status == "loaded":
            loaded = loaded + 1
        elif row.status == "skipped":
            skipped = skipped + 1
        elif row.status == "failed":
            failed = failed + 1
        idx = idx + 1
    "dynsmf session=" + session.session_id +
        " policy=" + session.policy.source +
        " loaded=" + loaded.to_text() +
        " skipped=" + skipped.to_text() +
        " failed=" + failed.to_text() +
        " evidence=" + session.evidence.len().to_text()

# Per-entry artifact status lines (fresh / stale_impl / stale_interface /
# stale_source / abi_mismatch / missing_file / invalid_magic / ...), additive
# to the existing session-evidence log so --dynsmf-status can distinguish
# "module-only rebuild is sufficient" (stale_impl) from "dependents need a
# rebuild too" (stale_interface) instead of one generic staleness reason.
pub fn dynsmf_startup_artifact_status_lines_for_manifest(manifest: [DynSmfManifestEntry]) -> [text]:
    var rows: [text] = []
    var idx = 0
    while idx < manifest.len():
        val status = dynsmf_artifact_status(manifest[idx])
        rows.push(status.library_id + ":" + status.reason + ":ready=" + status.ready.to_text())
        idx = idx + 1
    rows

pub fn dynsmf_startup_artifact_status_lines() -> [text]:
    dynsmf_startup_artifact_status_lines_for_manifest(dynsmf_default_manifest())
