# Shared IPC Protocol
#
# JSON-based IPC protocol shared between Electron and Tauri backends.
# Messages are sent over stdin/stdout as newline-delimited JSON.

use app.ui.ipc.protocol.{IpcMessageKind, parse_ipc_message, build_ipc_render,
    build_ipc_dialog, build_ipc_notification, build_ipc_window_control,
    build_ipc_file_dialog, build_ipc_request_http, extract_json_field,
    escape_ipc_json}

# Async channel-based IPC handler
use app.ui.ipc.async_handler.{start_ipc_reader, start_ipc_writer}
