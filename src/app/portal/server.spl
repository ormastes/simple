"""
# Portal HTTP Server

Hand-rolled HTTP over `TcpListener`/`TcpStream`, following the proven
`app.simple_portal.server` pattern (raw socket loop, no framework). The
existing `web_framework`/`WebRouter`/`WebApp` stack under `src/lib` is not
wired to an actual socket (`WebApp.start()` only prints; its controller
response helpers return bare tuples where an `HttpResponseData` struct is
required) — building on it would mean fixing shared-lib code well outside
this app's scope, so this server talks to `std.http_server.types`/`response`
directly instead, exactly like `simple_portal` does.

`route_request` is exposed separately from the accept loop so specs can
drive it directly without opening a real socket (mirrors
`simple_portal_server_spec.spl`).
"""

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.http_server.response.{build_html, serialize_response}
use std.http_server.types.{HttpResponseData}
use std.common.web.html_escape.{html_escape}
use std.common.markdown.render.{render_markdown_line_html}
use app.portal.git_repo.{
    RepoInfo, TreeEntry, CommitEntry,
    sanitize_repo_name, sanitize_ref, sanitize_path,
    list_repos, find_repo, repo_default_ref,
    git_ls_tree, git_show_blob, git_log, git_show_commit,
    resolve_ref_and_path
}
use app.portal.git_views.{
    render_repos_index, render_repo_landing, render_tree,
    render_blob, render_commits, render_commit_diff
}
use app.portal.template.{render_layout, render_home_page, render_error_page, render_login_page}
use app.portal.services.auth_service.{hash_password, verify_password, sign_session_cookie, verify_session_cookie}
use std.web_framework.form_parser.{parse_url_encoded}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(key: text) -> text

val PUBLIC_ROOT = "src/app/portal/public"
val COMMITS_PAGE_SIZE: i64 = 30
val SESSION_COOKIE_NAME = "portal_session"

fn default_repo_root() -> text:
    val configured = rt_env_get("PORTAL_REPO_ROOT")
    if configured == nil or configured == "":
        "."
    else:
        configured

fn _env_or(key: text, fallback: text) -> text:
    val v = rt_env_get(key)
    if v == nil or v == "":
        fallback
    else:
        v

fn _auth_enabled_from_env() -> bool:
    _env_or("PORTAL_AUTH", "") == "1"

# ============================================================================
# PortalServer
# ============================================================================

class PortalServer:
    host: text
    port: text
    repo_root: text
    auth_enabled: bool
    auth_user: text
    auth_pass: text
    auth_secret: text

impl PortalServer:
    static fn new(host: text, port: text) -> PortalServer:
        PortalServer.with_repo_root(host, port, default_repo_root())

    static fn with_repo_root(host: text, port: text, repo_root: text) -> PortalServer:
        PortalServer(
            host: host, port: port, repo_root: repo_root,
            auth_enabled: _auth_enabled_from_env(),
            auth_user: _env_or("PORTAL_AUTH_USER", "admin"),
            auth_pass: _env_or("PORTAL_AUTH_PASSWORD", "admin"),
            auth_secret: _env_or("PORTAL_AUTH_SECRET", "portal-session-default-secret")
        )

    fn start():
        print "Starting Simple Portal on http://{self.host}:{self.port}"
        print "Git repo root: {self.repo_root}"
        match TcpListener.bind("{self.host}:{self.port}"):
            Err(e):
                print "Failed to bind portal on {self.host}:{self.port}: {e}"
            Ok(listener):
                loop:
                    match listener.accept():
                        Ok(stream):
                            self.handle_connection(stream)
                        Err(e):
                            print "Accept error: {e}"

    fn handle_connection(stream: TcpStream):
        match stream.read_line():
            Err(_):
                val _ = stream.close()
            Ok(request_line):
                val parsed = _parse_request_line(request_line)
                val method = parsed.0
                val raw_path = parsed.1
                var content_length = 0
                var headers_raw = ""
                loop:
                    match stream.read_line():
                        Ok(header_line):
                            if header_line.trim() == "":
                                break
                            headers_raw = headers_raw + header_line + "\n"
                            if header_line.lower().starts_with("content-length:"):
                                val parts = header_line.split(":")
                                if parts.length() >= 2:
                                    content_length = (parts[1].trim().to_i64() ?? 0)
                        Err(_):
                            break
                var body = ""
                if content_length > 0 and content_length <= 16384:
                    match stream.read_bytes(content_length):
                        Ok(data):
                            body = data
                        Err(_):
                            body = ""
                val response = self.route_request(method, raw_path, body, headers_raw)
                val _ = stream.write_text(response)
                val _ = stream.close()

    fn route_request(method: text, raw_path: text, body: text, headers: text) -> text:
        val normalized = _normalize_path(raw_path)
        if normalized.2 != "":
            return _finalize(_error_response(400, "Bad Request", normalized.2))
        val clean_path = normalized.0
        val query = normalized.1

        if method != "GET" and method != "HEAD":
            return _finalize(_error_response(405, "Method Not Allowed", "Only GET is supported on this path."))

        if clean_path.starts_with("/css/") or clean_path.starts_with("/js/"):
            return _finalize(self._serve_static(clean_path))

        if clean_path == "/":
            return _finalize(build_html(render_home_page()))

        if clean_path == "/repos":
            val repos = list_repos(self.repo_root)
            return _finalize(build_html(render_layout("Repositories", render_repos_index(repos, self.repo_root))))

        if clean_path.starts_with("/repos/"):
            return _finalize(self._route_repo(clean_path, query))

        _finalize(_error_response(404, "Not Found", "No such page: {clean_path}"))

    fn _serve_static(clean_path: text) -> HttpResponseData:
        val full_path = "{PUBLIC_ROOT}{clean_path}"
        if not rt_file_exists(full_path):
            return _error_response(404, "Not Found", "No such asset: {clean_path}")
        val mime = if clean_path.ends_with(".css"): "text/css" else: "application/javascript"
        _html_ok(rt_file_read_text(full_path), mime)

    fn _route_repo(clean_path: text, query: text) -> HttpResponseData:
        val segments = clean_path[1:].split("/")
        if segments.len() < 2 or segments[1] == "":
            return _error_response(404, "Not Found", "No repository name given.")

        val name_result = sanitize_repo_name(segments[1])
        match name_result:
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(name):
                val repo_opt = find_repo(self.repo_root, name)
                if repo_opt == nil:
                    return _error_response(404, "Not Found", "Unknown repository: {name}")
                val repo = repo_opt ?? RepoInfo(name: name, path: "", git_dir: "", bare: false)

                if segments.len() == 2:
                    return self._repo_landing(repo)

                val kind = segments[2]
                if kind == "tree":
                    return self._repo_tree(repo, segments)
                elif kind == "blob":
                    return self._repo_blob(repo, segments)
                elif kind == "raw":
                    return self._repo_raw(repo, segments)
                elif kind == "commits":
                    return self._repo_commits(repo, segments, query)
                elif kind == "commit":
                    return self._repo_commit(repo, segments)
                else:
                    return _error_response(404, "Not Found", "Unknown repository view: {kind}")

    fn _repo_landing(repo: RepoInfo) -> HttpResponseData:
        val ref = repo_default_ref(repo)
        val readme_result = git_show_blob(repo, ref, "README.md")
        match readme_result:
            Err(_):
                _html_ok(render_layout(repo.name, render_repo_landing(repo, ref, "", false)), "text/html; charset=utf-8")
            Ok(content):
                _html_ok(render_layout(repo.name, render_repo_landing(repo, ref, _render_readme(content), true)), "text/html; charset=utf-8")

    fn _repo_tree(repo: RepoInfo, segments: [text]) -> HttpResponseData:
        val ref = if segments.len() > 3: segments[3] else: repo_default_ref(repo)
        match sanitize_ref(ref):
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(safe_ref):
                val raw_path = _join_from(segments, 4)
                match sanitize_path(raw_path):
                    Err(msg):
                        return _error_response(400, "Bad Request", msg)
                    Ok(safe_path):
                        match git_ls_tree(repo, safe_ref, safe_path):
                            Err(msg):
                                return _error_response(404, "Not Found", msg)
                            Ok(entries):
                                return _html_ok(
                                    render_layout(repo.name, render_tree(repo, safe_ref, safe_path, entries)),
                                    "text/html; charset=utf-8"
                                )

    fn _repo_blob(repo: RepoInfo, segments: [text]) -> HttpResponseData:
        if segments.len() < 5:
            return _error_response(400, "Bad Request", "Missing ref/path for blob view.")
        match sanitize_ref(segments[3]):
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(safe_ref):
                val raw_path = _join_from(segments, 4)
                match sanitize_path(raw_path):
                    Err(msg):
                        return _error_response(400, "Bad Request", msg)
                    Ok(safe_path):
                        match git_show_blob(repo, safe_ref, safe_path):
                            Err(msg):
                                return _error_response(404, "Not Found", msg)
                            Ok(content):
                                val is_binary = content.contains("\0")
                                return _html_ok(
                                    render_layout(repo.name, render_blob(repo, safe_ref, safe_path, content, is_binary)),
                                    "text/html; charset=utf-8"
                                )

    fn _repo_raw(repo: RepoInfo, segments: [text]) -> HttpResponseData:
        if segments.len() < 5:
            return _error_response(400, "Bad Request", "Missing ref/path for raw download.")
        match sanitize_ref(segments[3]):
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(safe_ref):
                val raw_path = _join_from(segments, 4)
                match sanitize_path(raw_path):
                    Err(msg):
                        return _error_response(400, "Bad Request", msg)
                    Ok(safe_path):
                        match git_show_blob(repo, safe_ref, safe_path):
                            Err(msg):
                                return _error_response(404, "Not Found", msg)
                            Ok(content):
                                return _raw_response(content, _basename_of(safe_path))

    fn _repo_commits(repo: RepoInfo, segments: [text], query: text) -> HttpResponseData:
        val ref = if segments.len() > 3: segments[3] else: repo_default_ref(repo)
        match sanitize_ref(ref):
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(safe_ref):
                val page = _parse_page(query)
                val skip_count = (page - 1) * COMMITS_PAGE_SIZE
                match git_log(repo, safe_ref, skip_count, COMMITS_PAGE_SIZE + 1):
                    Err(msg):
                        return _error_response(404, "Not Found", msg)
                    Ok(entries):
                        val has_more = entries.len() > COMMITS_PAGE_SIZE
                        val page_entries = if has_more: _take(entries, COMMITS_PAGE_SIZE) else: entries
                        return _html_ok(
                            render_layout(repo.name, render_commits(repo, safe_ref, page_entries, page, has_more)),
                            "text/html; charset=utf-8"
                        )

    fn _repo_commit(repo: RepoInfo, segments: [text]) -> HttpResponseData:
        if segments.len() < 4:
            return _error_response(400, "Bad Request", "Missing commit sha.")
        match sanitize_ref(segments[3]):
            Err(msg):
                return _error_response(400, "Bad Request", msg)
            Ok(sha):
                match git_show_commit(repo, sha):
                    Err(msg):
                        return _error_response(404, "Not Found", msg)
                    Ok(raw_diff):
                        return _html_ok(
                            render_layout(repo.name, render_commit_diff(repo, sha, raw_diff)),
                            "text/html; charset=utf-8"
                        )

# ============================================================================
# Helpers
# ============================================================================

fn _render_readme(content: text) -> text:
    var out = ""
    var in_code = false
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("```"):
            in_code = not in_code
            continue
        if in_code:
            out = out + "<pre class=\"readme-code\">" + html_escape(line) + "</pre>"
        else:
            out = out + render_markdown_line_html(line)
    out

fn _take(items: [CommitEntry], n: i64) -> [CommitEntry]:
    var out: [CommitEntry] = []
    var i = 0
    while i < n and i < items.len():
        out.push(items[i])
        i = i + 1
    out

fn _join_from(segments: [text], start: i64) -> text:
    var out = ""
    var i = start
    while i < segments.len():
        if out == "":
            out = segments[i]
        else:
            out = out + "/" + segments[i]
        i = i + 1
    out

fn _basename_of(path: text) -> text:
    val parts = path.split("/")
    if parts.len() == 0:
        return "download"
    val last = parts[parts.len() - 1]
    if last == "":
        "download"
    else:
        last

fn _parse_page(query: text) -> i64:
    if query == "":
        return 1
    for pair in query.split("&"):
        if pair.starts_with("page="):
            val v = pair[5:].trim().to_i64() ?? 1
            return if v < 1: 1 else: v
    1

fn _parse_request_line(request_line: text) -> (text, text):
    var method = ""
    var path = ""
    var idx = 0
    for part in request_line.split(" "):
        if idx == 0:
            method = part
        elif idx == 1:
            path = part
            break
        idx = idx + 1
    (method, path)

fn _normalize_path(path: text) -> (text, text, text):
    """Returns (clean_path, query_string, error). error is "" on success."""
    if path == "":
        return ("", "", "Empty path")
    var clean = path
    var query = ""
    if clean.contains("?"):
        val qidx = clean.index_of("?") ?? clean.length()
        query = clean[qidx + 1:]
        clean = clean[0:qidx]
    clean = clean.replace("%2F", "/")
    clean = clean.replace("%2f", "/")
    clean = clean.replace("%5C", "\\")
    clean = clean.replace("%5c", "\\")
    while clean.contains("//"):
        clean = clean.replace("//", "/")
    if not clean.starts_with("/"):
        clean = "/" + clean
    if clean.length() > 1 and clean.ends_with("/"):
        clean = clean[0:clean.length() - 1]
    if clean.contains("..") or clean.contains("\\") or clean.contains("\0") or clean.contains("%00"):
        return ("", "", "Bad request path")
    (clean, query, "")

fn _html_ok(body: text, content_type: text) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [("Content-Type", content_type), ("Server", "SimplePortal")],
        body: body,
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _raw_response(content: text, filename: text) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [
            ("Content-Type", "application/octet-stream"),
            ("Content-Disposition", "attachment; filename=\"{filename}\""),
            ("Server", "SimplePortal")
        ],
        body: content,
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _error_response(status: i64, title: text, message: text) -> HttpResponseData:
    val reason = _status_reason(status)
    HttpResponseData(
        status: status,
        reason: reason,
        headers: [("Content-Type", "text/html; charset=utf-8"), ("Server", "SimplePortal")],
        body: render_error_page(status, title, message),
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _status_reason(status: i64) -> text:
    if status == 200: return "OK"
    if status == 400: return "Bad Request"
    if status == 404: return "Not Found"
    if status == 405: return "Method Not Allowed"
    if status == 500: return "Internal Server Error"
    "Error"

fn _finalize(resp: HttpResponseData) -> text:
    var out = resp
    out = _add_header(out, "Connection", "close")
    out = _add_header(out, "Content-Security-Policy",
        "default-src 'self'; base-uri 'none'; frame-ancestors 'none'; img-src 'self' data:; " +
        "script-src 'self'; style-src 'self'; connect-src 'self'")
    out = _add_header(out, "X-Content-Type-Options", "nosniff")
    out = _add_header(out, "X-Frame-Options", "DENY")
    out = _add_header(out, "Referrer-Policy", "strict-origin-when-cross-origin")
    serialize_response(out)

fn _add_header(resp: HttpResponseData, name: text, value: text) -> HttpResponseData:
    HttpResponseData(
        status: resp.status,
        reason: resp.reason,
        headers: resp.headers + [(name, value)],
        body: resp.body,
        body_bytes: resp.body_bytes,
        body_file: resp.body_file,
        body_offset: resp.body_offset,
        body_length: resp.body_length,
        chunked: resp.chunked
    )
