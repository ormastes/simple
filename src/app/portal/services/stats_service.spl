"""
# Stats Service

Download statistics aggregation and reporting.
"""

use std.database.sql.connection.{Database}
use std.database.sql.types.{DbValue, DbError}

# ============================================================================
# Stats Data
# ============================================================================

class DailyDownloads:
    """Download count for a single day."""
    date: text
    count: i64

class PackageStats:
    """Aggregate statistics for a package."""
    package_name: text
    total_downloads: i64
    daily: [DailyDownloads]

class PortalStats:
    """Overall portal statistics."""
    total_packages: i64
    total_downloads: i64
    total_users: i64
    total_versions: i64

# ============================================================================
# Stats Queries
# ============================================================================

fn get_portal_stats(db: Database) -> Result<PortalStats, text>:
    """Get overall portal statistics.

    Returns:
        Ok(PortalStats) with aggregate counts
    """
    var stats = PortalStats(
        total_packages: 0,
        total_downloads: 0,
        total_users: 0,
        total_versions: 0
    )

    # Total packages
    val pkg_result = db.query("SELECT COUNT(*) as cnt FROM packages", [])
    match pkg_result:
        Ok(rows):
            if rows.len() > 0:
                stats.total_packages = rows[0].get_int("cnt") ?? 0
        Err(e): pass_do_nothing

    # Total downloads
    val dl_result = db.query("SELECT COALESCE(SUM(downloads), 0) as cnt FROM packages", [])
    match dl_result:
        Ok(rows):
            if rows.len() > 0:
                stats.total_downloads = rows[0].get_int("cnt") ?? 0
        Err(e): pass_do_nothing

    # Total users
    val user_result = db.query("SELECT COUNT(*) as cnt FROM users", [])
    match user_result:
        Ok(rows):
            if rows.len() > 0:
                stats.total_users = rows[0].get_int("cnt") ?? 0
        Err(e): pass_do_nothing

    # Total versions
    val ver_result = db.query("SELECT COUNT(*) as cnt FROM package_versions", [])
    match ver_result:
        Ok(rows):
            if rows.len() > 0:
                stats.total_versions = rows[0].get_int("cnt") ?? 0
        Err(e): pass_do_nothing

    Ok(stats)

fn get_package_download_stats(db: Database, package_id: i64, days: i64) -> Result<PackageStats, text>:
    """Get download statistics for a specific package.

    Args:
        db: Database connection
        package_id: Package to get stats for
        days: Number of days of history to return

    Returns:
        Ok(PackageStats) with daily breakdown
    """
    # Get package name and total downloads
    val pkg_sql = "SELECT name, downloads FROM packages WHERE id = ? LIMIT 1"
    val pkg_params: [DbValue] = [DbValue.Integer(value: package_id)]
    val pkg_result = db.query(pkg_sql, pkg_params)

    var pkg_name = ""
    var total_dl = 0
    match pkg_result:
        Ok(rows):
            if rows.len() == 0:
                return Err("Package not found")
            pkg_name = rows[0].get_text("name") ?? ""
            total_dl = rows[0].get_int("downloads") ?? 0
        Err(e):
            return Err("Database error fetching package stats")

    # Get daily download counts
    val daily_sql = "SELECT date, SUM(count) as total FROM download_stats WHERE package_id = ? GROUP BY date ORDER BY date DESC LIMIT ?"
    val daily_params: [DbValue] = [
        DbValue.Integer(value: package_id),
        DbValue.Integer(value: days)
    ]
    val daily_result = db.query(daily_sql, daily_params)

    var daily: [DailyDownloads] = []
    match daily_result:
        Ok(rows):
            for row in rows:
                val date = row.get_text("date") ?? ""
                val count = row.get_int("total") ?? 0
                daily.push(DailyDownloads(date: date, count: count))
        Err(e):
            pass_do_nothing

    Ok(PackageStats(
        package_name: pkg_name,
        total_downloads: total_dl,
        daily: daily
    ))

fn get_top_downloaded(db: Database, limit: i64) -> Result<[PackageStats], text>:
    """Get the top downloaded packages with basic stats.

    Args:
        db: Database connection
        limit: Maximum packages to return

    Returns:
        Ok(stats) for top downloaded packages
    """
    val sql = "SELECT id, name, downloads FROM packages ORDER BY downloads DESC LIMIT ?"
    val params: [DbValue] = [DbValue.Integer(value: limit)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            var stats: [PackageStats] = []
            for row in rows:
                val name = row.get_text("name") ?? ""
                val downloads = row.get_int("downloads") ?? 0
                stats.push(PackageStats(
                    package_name: name,
                    total_downloads: downloads,
                    daily: []
                ))
            Ok(stats)
        Err(e):
            Err("Database error fetching top downloads")

fn get_total_downloads_json(db: Database, days: i64) -> Result<text, text>:
    """Get aggregated daily download counts as JSON.

    Args:
        db: Database connection
        days: Number of days to aggregate

    Returns:
        Ok(json) with download data
    """
    val sql = "SELECT date, SUM(count) as total FROM download_stats GROUP BY date ORDER BY date DESC LIMIT ?"
    val params: [DbValue] = [DbValue.Integer(value: days)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            var entries: [text] = []
            for row in rows:
                val date = row.get_text("date") ?? ""
                val count = row.get_int("total") ?? 0
                entries.push("{\"date\": \"{date}\", \"downloads\": {count}}")
            val json = "[" + entries.join(", ") + "]"
            Ok(json)
        Err(e):
            Err("Database error fetching download stats")
