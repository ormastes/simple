"""
# Simple Language Portal Server

Community portal for the Simple programming language.
Provides package browsing, search, user accounts, documentation,
and download statistics.

## Usage

```bash
bin/simple run src/app/portal/main.spl
```
"""

use std.web_framework.app.{WebApp}
use std.web_framework.controller.{ControllerContext, render_page, render_json, render_redirect, render_error}
use std.http_server.types.{HttpResponseData}

# Import controllers
use portal.controllers.home_controller.{action_home_index}
use portal.controllers.packages_controller.{
    action_packages_index, action_packages_show, action_packages_versions
}
use portal.controllers.auth_controller.{
    action_login_form, action_login, action_register_form, action_register, action_logout
}
use portal.controllers.users_controller.{
    action_user_show, action_user_edit, action_user_update
}
use portal.controllers.docs_controller.{action_docs_index, action_docs_show}
use portal.controllers.dashboard_controller.{action_dashboard_index}
use portal.controllers.api.packages_controller.{
    action_api_packages_index, action_api_packages_show, action_api_packages_publish
}
use portal.controllers.api.stats_controller.{action_api_stats_downloads}

# Import database setup
use portal.db.migrations.{run_portal_migrations}

fn main():
    """Start the Simple Language Portal server."""
    val app_result = WebApp.create("src/app/portal/app.sdn")
    var app = match app_result:
        Ok(a): a
        Err(e):
            print "[Portal] Failed to create app: {e}"
            return

    # Run database migrations
    if app.db != nil:
        val db = app.db ?? return
        val migrate_result = run_portal_migrations(db)
        match migrate_result:
            Ok(count):
                if count > 0:
                    print "[Portal] Applied {count} migrations"
            Err(e):
                print "[Portal] Migration error: {e}"
                return

    # Mount routes from SDN file
    val mount_result = app.mount_routes("src/app/portal/routes.sdn")
    app = match mount_result:
        Ok(a): a
        Err(e):
            print "[Portal] Failed to mount routes: {e}"
            return

    # Register public page handlers
    app = app.register_action("home", "index", action_home_index)
    app = app.register_action("packages", "index", action_packages_index)
    app = app.register_action("packages", "show", action_packages_show)
    app = app.register_action("packages", "versions", action_packages_versions)
    app = app.register_action("docs", "index", action_docs_index)
    app = app.register_action("docs", "show", action_docs_show)

    # Register auth handlers
    app = app.register_action("auth", "login_form", action_login_form)
    app = app.register_action("auth", "login", action_login)
    app = app.register_action("auth", "register_form", action_register_form)
    app = app.register_action("auth", "register", action_register)
    app = app.register_action("auth", "logout", action_logout)

    # Register user profile handlers
    app = app.register_action("users", "show", action_user_show)
    app = app.register_action("users", "edit", action_user_edit)
    app = app.register_action("users", "update", action_user_update)

    # Register dashboard handler
    app = app.register_action("dashboard", "index", action_dashboard_index)

    # Register API handlers
    app = app.register_action("api_packages", "index", action_api_packages_index)
    app = app.register_action("api_packages", "show", action_api_packages_show)
    app = app.register_action("api_packages", "publish", action_api_packages_publish)
    app = app.register_action("api_stats", "downloads", action_api_stats_downloads)

    # Start the server
    val start_result = app.start()
    match start_result:
        Ok(_):
            print "[Portal] Running at http://localhost:3000"
            print "[Portal] Press Ctrl+C to stop"
            app.wait()
        Err(e):
            print "[Portal] Failed to start: {e}"
