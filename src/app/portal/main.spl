# Simple Language Portal entrypoint.
# Startup-light surface for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.portal.server.{PortalServer}

val TOOL_NAME = "Simple Language Portal"
val TOOL_VERSION = "0.1.0"
val DEFAULT_HOST = "127.0.0.1"
val DEFAULT_PORT = "3000"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("portal", log_opts.error)
        return 1

    val args = portal_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"portal\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val host = portal_option_value(args, "--host", DEFAULT_HOST)
    val port = portal_option_value(args, "--port", DEFAULT_PORT)
    val migrate = portal_has_option(args, "--migrate")
    if portal_has_unknown_option(args):
        val message = "Unknown portal option: {portal_first_unknown_option(args)}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"portal\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("portal", message)
        return 1

    if log_opts.log_mode == "json":
        print "{\"command\":\"portal\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\",\"host\":\"{host}\",\"port\":{port},\"migrate\":{portal_bool_json(migrate)}}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "portal")
        if progress != "":
            print progress
        print "{TOOL_NAME} v{TOOL_VERSION}"
        val server = PortalServer.new(host, port)
        server.start()
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple portal [options]"
    print ""
    print "Options:"
    print "  -h, --help          Show this help message"
    print "  -v, --version       Show version information"
    print "  --host <HOST>       Bind host (default: {DEFAULT_HOST})"
    print "  --port <PORT>       Bind port (default: {DEFAULT_PORT})"
    print "  --migrate           Plan database migrations before startup"
    print ""
    print "Environment:"
    print "  PORTAL_REPO_ROOT      Directory to browse for git repos (default: .)"
    print "  PORTAL_AUTH           Set to 1 to require login for all pages (default: off)"
    print "  PORTAL_AUTH_USER      Admin username when PORTAL_AUTH=1 (default: admin)"
    print "  PORTAL_AUTH_PASSWORD  Admin password when PORTAL_AUTH=1 (default: admin)"
    print "  PORTAL_AUTH_SECRET    Session-cookie signing secret (default: a fixed"
    print "                        built-in value — override in any real deployment)"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn portal_option_value(args: [text], name: text, fallback: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with(name + "="):
            return arg.substring(name.len() + 1)
        i = i + 1
    fallback

fn portal_has_option(args: [text], name: text) -> bool:
    for arg in args:
        if arg == name:
            return true
    false

fn portal_bool_json(value: bool) -> text:
    if value:
        "true"
    else:
        "false"

fn portal_has_unknown_option(args: [text]) -> bool:
    portal_first_unknown_option(args) != ""

fn portal_first_unknown_option(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--host" or arg == "--port":
            i = i + 2
        elif arg == "--migrate" or arg.starts_with("--host=") or arg.starts_with("--port="):
            i = i + 1
        elif arg.starts_with("-"):
            return arg
        else:
            i = i + 1
    ""

fn portal_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn portal_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if portal_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
