"""
# Home Controller

Landing page for the Simple Language Portal.
Shows featured packages, recent packages, and portal statistics.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_page, render_error, get_param
}

# ============================================================================
# Actions
# ============================================================================

@public
fn action_home_index(ctx: ControllerContext) -> HttpResponseData:
    """Render the portal landing page.

    Shows a hero section, featured packages grid, recent packages,
    and aggregate statistics counters.
    """
    var data: Dict<text, text> = {}
    data["title"] = "Simple Language Portal"
    data["page_title"] = "Discover Simple Packages"
    data["page_description"] = "Browse, search, and publish packages for the Simple programming language."

    # In a full implementation, these would come from the database
    data["total_packages"] = "0"
    data["total_downloads"] = "0"
    data["total_users"] = "0"

    # Featured packages placeholder
    data["featured_html"] = build_featured_html()

    # Recent packages placeholder
    data["recent_html"] = build_recent_html()

    render_page(ctx, "src/app/portal/views/home/index.html", data)

# ============================================================================
# Helpers
# ============================================================================

fn build_featured_html() -> text:
    """Build HTML for the featured packages section."""
    var parts: [text] = []
    parts.push("<div class=\"package-grid\">")
    parts.push("  <div class=\"package-card\">")
    parts.push("    <h3><a href=\"/packages/std\">std</a></h3>")
    parts.push("    <p>Standard library for Simple</p>")
    parts.push("    <span class=\"version\">v1.0.0</span>")
    parts.push("  </div>")
    parts.push("  <div class=\"package-card\">")
    parts.push("    <h3><a href=\"/packages/web\">web</a></h3>")
    parts.push("    <p>Web framework and HTTP server</p>")
    parts.push("    <span class=\"version\">v0.5.0</span>")
    parts.push("  </div>")
    parts.push("  <div class=\"package-card\">")
    parts.push("    <h3><a href=\"/packages/crypto\">crypto</a></h3>")
    parts.push("    <p>Cryptographic primitives</p>")
    parts.push("    <span class=\"version\">v0.3.0</span>")
    parts.push("  </div>")
    parts.push("</div>")
    parts.join("\n")

fn build_recent_html() -> text:
    """Build HTML for the recent packages section."""
    var parts: [text] = []
    parts.push("<div class=\"package-list\">")
    parts.push("  <p class=\"empty-state\">No packages published yet. Be the first!</p>")
    parts.push("</div>")
    parts.join("\n")
