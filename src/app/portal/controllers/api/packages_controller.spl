"""
# API Packages Controller

JSON API for package operations: listing, detail, and publishing.
Part of the /api/v1 namespace.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_json, render_error, render_created,
    render_not_found, render_forbidden, get_param, get_param_or,
    get_param_i64
}

# ============================================================================
# Actions
# ============================================================================

@public
fn action_api_packages_index(ctx: ControllerContext) -> HttpResponseData:
    """List packages as JSON with optional search and pagination.

    Query params:
    - q: Search query (optional)
    - page: Page number (default 1)
    - per_page: Items per page (default 20, max 100)
    """
    val query = get_param_or(ctx, "q", "")
    val page = get_param_i64(ctx, "page")
    val current_page = if page > 0: page else: 1

    # In production, query database via package_service.search_packages()
    # For now, return empty result
    val json = "{" +
        "\"packages\": [], " +
        "\"total\": 0, " +
        "\"page\": {current_page}, " +
        "\"per_page\": 20" +
        "}"
    render_json(json)

@public
fn action_api_packages_show(ctx: ControllerContext) -> HttpResponseData:
    """Get package details as JSON.

    Route param: :name (package name)
    """
    val name = get_param(ctx, "name")
    if name.len() == 0:
        return render_error(400, "{\"error\": \"Package name is required\"}")

    # In production, query database via package_service.get_package()
    # For now, return not found
    val json = "{" +
        "\"error\": \"Package not found\", " +
        "\"name\": \"{name}\"" +
        "}"
    render_error(404, json)

@requires_auth
fn action_api_packages_publish(ctx: ControllerContext) -> HttpResponseData:
    """Publish a new package or version.

    Requires authentication via API token.

    Request body (JSON):
    - name: Package name
    - version: Version string
    - description: Package description
    - readme: README content
    """
    val user_id = ctx.current_user_id
    if user_id == nil:
        return render_error(401, "{\"error\": \"Authentication required\"}")

    val name = get_param(ctx, "name")
    val version = get_param(ctx, "version")
    val description = get_param_or(ctx, "description", "")
    val readme = get_param_or(ctx, "readme", "")

    # Validate required fields
    if name.len() == 0:
        return render_error(400, "{\"error\": \"Package name is required\"}")
    if version.len() == 0:
        return render_error(400, "{\"error\": \"Version is required\"}")

    # Validate package name format
    if not is_valid_package_name(name):
        return render_error(400, "{\"error\": \"Invalid package name. Use lowercase letters, numbers, and hyphens.\"}")

    # In production, call package_service.publish_package()
    # val uid = (user_id ?? "0").to_i64() ?? 0
    # val pkg_id = publish_package(db, name, description, version, uid, readme)?

    val json = "{" +
        "\"message\": \"Package published successfully\", " +
        "\"name\": \"{name}\", " +
        "\"version\": \"{version}\"" +
        "}"
    render_created(json)

# ============================================================================
# Helpers
# ============================================================================

fn is_valid_package_name(name: text) -> bool:
    """Validate a package name.

    Rules:
    - 1-64 characters
    - Lowercase letters, numbers, hyphens, underscores
    - Must start with a letter
    - No consecutive hyphens
    """
    if name.len() == 0 or name.len() > 64:
        return false

    # Must start with a letter
    val first = name[0:1]
    if not is_lowercase_letter(first):
        return false

    # Check each character
    var prev_hyphen = false
    var i = 0
    while i < name.len():
        val c = name[i:i + 1]
        if is_lowercase_letter(c) or is_digit(c) or c == "_":
            prev_hyphen = false
        elif c == "-":
            if prev_hyphen:
                return false
            prev_hyphen = true
        else:
            return false
        i = i + 1

    # Must not end with hyphen
    if name.ends_with("-"):
        return false

    true

fn is_lowercase_letter(c: text) -> bool:
    """Check if a single character is a lowercase letter."""
    c >= "a" and c <= "z"

fn is_digit(c: text) -> bool:
    """Check if a single character is a digit."""
    c >= "0" and c <= "9"
