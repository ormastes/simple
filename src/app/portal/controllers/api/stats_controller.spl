"""
# API Stats Controller

JSON API for download statistics and analytics.
Part of the /api/v1 namespace.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_json, render_error,
    get_param, get_param_or, get_param_i64
}

# ============================================================================
# Actions
# ============================================================================

@public
fn action_api_stats_downloads(ctx: ControllerContext) -> HttpResponseData:
    """Get download statistics as JSON.

    Query params:
    - package: Package name (optional, all packages if omitted)
    - days: Number of days of history (default 30, max 365)

    Returns JSON with:
    - total_downloads: Total download count
    - daily: Array of {date, downloads} objects
    - top_packages: Array of {name, downloads} objects (if no package filter)
    """
    val package_name = get_param_or(ctx, "package", "")
    var days = get_param_i64(ctx, "days")
    if days <= 0:
        days = 30
    if days > 365:
        days = 365

    # In production, query database via stats_service
    if package_name.len() > 0:
        # Package-specific stats
        val json = "{" +
            "\"package\": \"{package_name}\", " +
            "\"total_downloads\": 0, " +
            "\"daily\": [], " +
            "\"days\": {days}" +
            "}"
        return render_json(json)

    # Overall portal stats
    val json = "{" +
        "\"total_downloads\": 0, " +
        "\"total_packages\": 0, " +
        "\"daily\": [], " +
        "\"top_packages\": [], " +
        "\"days\": {days}" +
        "}"
    render_json(json)
