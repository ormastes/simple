#![allow(unknown_decorator)]
"""
# Dashboard Controller

Authenticated user dashboard showing owned packages,
API tokens, and download statistics.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_page, render_forbidden, get_param
}

# ============================================================================
# Actions
# ============================================================================

@requires_auth
fn action_dashboard_index(ctx: ControllerContext) -> HttpResponseData:
    """Render the user dashboard.

    Shows:
    - Owned packages with download stats
    - API tokens
    - Recent activity
    """
    val user_id = ctx.current_user_id
    if user_id == nil:
        return render_forbidden()

    var data: Dict<text, text> = {}
    data["title"] = "Dashboard"
    data["username"] = ""

    # Package stats section
    data["packages_count"] = "0"
    data["total_downloads"] = "0"
    data["packages_html"] = build_dashboard_packages_html()

    # API tokens section
    data["tokens_html"] = build_dashboard_tokens_html()

    # Activity section
    data["activity_html"] = build_dashboard_activity_html()

    render_page(ctx, "src/app/portal/views/dashboard/index.html", data)

# ============================================================================
# Helpers
# ============================================================================

fn build_dashboard_packages_html() -> text:
    """Build HTML for the dashboard packages section."""
    var parts: [text] = []
    parts.push("<div class=\"dashboard-packages\">")
    parts.push("  <h3>Your Packages</h3>")
    parts.push("  <p class=\"empty-state\">You have not published any packages yet.</p>")
    parts.push("  <a href=\"/docs/publishing\" class=\"btn btn-primary\">Learn How to Publish</a>")
    parts.push("</div>")
    parts.join("\n")

fn build_dashboard_tokens_html() -> text:
    """Build HTML for the API tokens section."""
    var parts: [text] = []
    parts.push("<div class=\"dashboard-tokens\">")
    parts.push("  <h3>API Tokens</h3>")
    parts.push("  <p>Use API tokens to publish packages from the command line.</p>")
    parts.push("  <p class=\"empty-state\">No tokens created yet.</p>")
    parts.push("  <button class=\"btn btn-secondary\">Create New Token</button>")
    parts.push("</div>")
    parts.join("\n")

fn build_dashboard_activity_html() -> text:
    """Build HTML for the recent activity section."""
    var parts: [text] = []
    parts.push("<div class=\"dashboard-activity\">")
    parts.push("  <h3>Recent Activity</h3>")
    parts.push("  <p class=\"empty-state\">No recent activity.</p>")
    parts.push("</div>")
    parts.join("\n")
