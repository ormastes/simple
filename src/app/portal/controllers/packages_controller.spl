"""
# Packages Controller

Package browsing, search, and detail pages.
All actions are public (no authentication required).
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_page, render_error, render_not_found,
    get_param, get_param_or, get_param_i64
}
use std.web_framework.pagination.{paginator_to_html}

# ============================================================================
# Actions
# ============================================================================

@public
fn action_packages_index(ctx: ControllerContext) -> HttpResponseData:
    """List packages with search and pagination.

    Query params:
    - q: Search query
    - page: Page number (default 1)
    """
    val query = get_param_or(ctx, "q", "")
    val page = get_param_i64(ctx, "page")
    val current_page = if page > 0: page else: 1

    var data: Dict<text, text> = {}
    data["title"] = "Packages"

    if query.len() > 0:
        data["title"] = "Search: {query}"
        data["search_query"] = query

    # Package listing will be populated via database in production
    data["packages_html"] = build_packages_list_html(query)
    data["pagination_html"] = ""
    data["result_count"] = "0"

    render_page(ctx, "src/app/portal/views/packages/index.html", data)

@public
fn action_packages_show(ctx: ControllerContext) -> HttpResponseData:
    """Show package detail page.

    Route param: :name (package name)
    """
    val name = get_param(ctx, "name")
    if name.len() == 0:
        return render_not_found()

    var data: Dict<text, text> = {}
    data["title"] = name
    data["package_name"] = name
    data["package_description"] = "A Simple language package"
    data["package_version"] = "0.0.0"
    data["package_downloads"] = "0"
    data["package_owner"] = "unknown"
    data["package_license"] = ""
    data["package_homepage"] = ""
    data["package_repository"] = ""
    data["package_created_at"] = ""
    data["install_command"] = "simple add {name}"
    data["readme_html"] = "<p>No README available.</p>"
    data["versions_html"] = ""

    render_page(ctx, "src/app/portal/views/packages/show.html", data)

@public
fn action_packages_versions(ctx: ControllerContext) -> HttpResponseData:
    """Show version history for a package.

    Route param: :name (package name)
    """
    val name = get_param(ctx, "name")
    if name.len() == 0:
        return render_not_found()

    var data: Dict<text, text> = {}
    data["title"] = "{name} - Versions"
    data["package_name"] = name
    data["versions_html"] = "<p>No versions published yet.</p>"

    render_page(ctx, "src/app/portal/views/packages/show.html", data)

# ============================================================================
# Helpers
# ============================================================================

fn build_packages_list_html(query: text) -> text:
    """Build HTML for the package listing."""
    var parts: [text] = []
    if query.len() > 0:
        parts.push("<div class=\"search-info\">")
        parts.push("  <p>Search results for: <strong>{query}</strong></p>")
        parts.push("</div>")
    parts.push("<div class=\"package-list\">")
    parts.push("  <p class=\"empty-state\">No packages found. Try a different search term.</p>")
    parts.push("</div>")
    parts.join("\n")
