# Simple Language Portal - Application Configuration

app:
  name: "simple-portal"
  env: "development"
  secret_key: "${PORTAL_SECRET_KEY}"

server:
  listen_addr: "0.0.0.0:3000"
  worker_count: 0

database:
  db_path: "portal.db"

session:
  session_store_type: "db"
  session_ttl: 86400
  session_cookie_name: "_portal_session"

assets:
  assets_path: "src/app/portal/public"
  assets_fingerprint: false
