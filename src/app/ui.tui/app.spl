# TUI Application Main Loop
#
# Runs the TUI mode: loads .ui.sdn, renders to terminal,
# polls for stdin input and file changes, re-renders on update.

use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use common.ui.parse.sdn.{parse_ui_file}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state, init_state_with_mode, update_state, update_tree, is_quit_event}
use common.ui.event.{process_event}
use app.ui.tui.screen.{Screen, get_terminal_size, ansi_clear_screen, ansi_cursor_home,
    ansi_hide_cursor, ansi_show_cursor, ansi_enable_alt_screen, ansi_disable_alt_screen}
use app.ui.tui.input.{parse_input_line, format_input_prompt, read_user_input}
use app.ui.render.widgets.{render_tui_tree}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# TUI App
# =========================================================================

class TuiApp:
    file_path: text
    state: UIState
    running: bool
    last_file_content: text

    static fn new(file_path: text) -> Result<TuiApp, text>:
        val tree_result = parse_ui_file(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                # Check for initial mode in the SDN
                val state = init_state(tree)
                val content = if rt_file_exists(file_path):
                    rt_file_read_text(file_path)
                else:
                    ""
                return Ok(TuiApp(
                    file_path: file_path,
                    state: state,
                    running: true,
                    last_file_content: content
                ))

    me run():
        """Main TUI loop."""
        print ansi_enable_alt_screen()
        print ansi_hide_cursor()

        # Initial render
        self.render_frame()

        while self.running:
            # Show input prompt
            val prompt = format_input_prompt(self.state.mode_name())
            val user_input = read_user_input()

            if user_input == "":
                # Check for file changes
                self.check_file_changes()
                self.render_frame()
            else:
                val event = parse_input_line(user_input)

                match event:
                    UIEvent.Quit:
                        self.running = false
                    _:
                        self.state = update_state(self.state, event)
                        # Check for quit command
                        self.check_file_changes()
                        self.render_frame()

        # Cleanup
        print ansi_show_cursor()
        print ansi_disable_alt_screen()
        print "UI closed."

    fn render_frame():
        """Render a single frame to the terminal."""
        val size = get_terminal_size()
        val width = size.0
        val height = size.1 - 1  # Reserve one line for input

        var screen = Screen.new(width, height)

        # Compute layout
        val rects = compute_layout(self.state.tree.root_node(), 0, 0, width, height)

        # Render widget tree
        screen = render_tui_tree(screen, self.state.tree.root_node(), rects, self.state)

        # Output
        print screen.render()

    me check_file_changes():
        """Check if the .ui.sdn file has changed and reload if so."""
        if not rt_file_exists(self.file_path):
            return

        val current_content = rt_file_read_text(self.file_path)
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_file(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.state = update_tree(self.state, new_tree)
                Err(e):
                    # Keep old state on parse error
                    print "Warning: UI parse error: {e}"

# =========================================================================
# Entry Point
# =========================================================================

fn run_tui(file_path: text) -> i64:
    """Start TUI mode for a .ui.sdn file."""
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val app_result = TuiApp.new(file_path)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            app.run()
            return 0
