# TUI Screen Buffer
#
# Manages an ANSI terminal screen buffer for cursor positioning,
# region clearing, and text drawing.

use app.ui.render.ansi.{ESC, RESET, BOLD, DIM, CYAN, WHITE, BLUE, YELLOW, GREEN, RED,
    fg_256, bg_256, fg_rgb, bg_rgb}

# =========================================================================
# Cursor and Screen Control
# =========================================================================

fn ansi_clear_screen() -> text:
    return "{ESC}[2J"

fn ansi_cursor_home() -> text:
    return "{ESC}[H"

fn ansi_cursor_move(row: i32, col: i32) -> text:
    return "{ESC}[{row};{col}H"

fn ansi_clear_line() -> text:
    return "{ESC}[2K"

fn ansi_hide_cursor() -> text:
    return "{ESC}[?25l"

fn ansi_show_cursor() -> text:
    return "{ESC}[?25h"

fn ansi_enable_alt_screen() -> text:
    return "{ESC}[?1049h"

fn ansi_disable_alt_screen() -> text:
    return "{ESC}[?1049l"

fn ansi_set_bg(color_code: i32) -> text:
    return "{ESC}[48;5;{color_code}m"

fn ansi_reset_bg() -> text:
    return "{ESC}[49m"

# =========================================================================
# 256-Color and True Color Helpers (delegates to shared ansi module)
# =========================================================================

fn ansi_fg_256(n: i32) -> text:
    """Set foreground to 256-color palette index (0-255)."""
    return fg_256(n)

fn ansi_bg_256(n: i32) -> text:
    """Set background to 256-color palette index (0-255)."""
    return bg_256(n)

fn ansi_fg_rgb(r: i32, g: i32, b: i32) -> text:
    """Set foreground to 24-bit true color RGB."""
    return fg_rgb(r, g, b)

fn ansi_bg_rgb(r: i32, g: i32, b: i32) -> text:
    """Set background to 24-bit true color RGB."""
    return bg_rgb(r, g, b)

# =========================================================================
# Screen Buffer
# =========================================================================

class Screen:
    width: i32
    height: i32
    buffer: [text]

    static fn new(width: i32, height: i32) -> Screen:
        var buf: [text] = []
        var i = 0
        while i < height:
            var line = ""
            var j = 0
            while j < width:
                line = "{line} "
                j = j + 1
            buf.push(line)
            i = i + 1
        return Screen(width: width, height: height, buffer: buf)

    fn clear() -> Screen:
        return Screen.new(self.width, self.height)

    fn put_text(row: i32, col: i32, text_content: text) -> Screen:
        """Write text at row,col position (0-based)."""
        if row < 0 or row >= self.height:
            return self
        if col < 0 or col >= self.width:
            return self

        var new_buffer = self.buffer
        val line = new_buffer[row]

        # Build new line with text inserted
        var new_line = ""
        var char_idx = 0
        var text_idx = 0
        val text_len = text_content.len()

        while char_idx < self.width:
            if char_idx >= col and text_idx < text_len:
                # Insert character from text_content
                new_line = "{new_line}{text_content[text_idx]}"
                text_idx = text_idx + 1
            elif char_idx < line.len():
                new_line = "{new_line}{line[char_idx]}"
            else:
                new_line = "{new_line} "
            char_idx = char_idx + 1

        new_buffer[row] = new_line
        return Screen(width: self.width, height: self.height, buffer: new_buffer)

    fn put_styled(row: i32, col: i32, text_content: text, style: text) -> Screen:
        """Write styled text at row,col. Style is ANSI prefix."""
        val styled = "{style}{text_content}{RESET}"
        return self.put_text(row, col, styled)

    fn put_bg(row: i32, col: i32, width: i32, bg_color: text) -> Screen:
        """Fill a region on a row with a background color.
        Writes bg_color + spaces + RESET for the given width."""
        if row < 0 or row >= self.height:
            return self
        if col < 0 or col >= self.width:
            return self
        var fill = "{bg_color}"
        var i = 0
        val actual_width = if col + width > self.width: self.width - col else: width
        while i < actual_width:
            fill = "{fill} "
            i = i + 1
        fill = "{fill}{RESET}"
        return self.put_text(row, col, fill)

    fn fill_row(row: i32, ch: text) -> Screen:
        """Fill an entire row with a character."""
        if row < 0 or row >= self.height:
            return self
        var line = ""
        var i = 0
        while i < self.width:
            line = "{line}{ch}"
            i = i + 1
        var new_buffer = self.buffer
        new_buffer[row] = line
        return Screen(width: self.width, height: self.height, buffer: new_buffer)

    fn draw_hline(row: i32, col: i32, length: i32, ch: text) -> Screen:
        """Draw a horizontal line."""
        var s = self
        var i = 0
        while i < length:
            val c = col + i
            if c < self.width:
                s = s.put_text(row, c, ch)
            i = i + 1
        return s

    fn draw_vline(row: i32, col: i32, length: i32, ch: text) -> Screen:
        """Draw a vertical line."""
        var s = self
        var i = 0
        while i < length:
            val r = row + i
            if r < self.height:
                s = s.put_text(r, col, ch)
            i = i + 1
        return s

    fn draw_box(row: i32, col: i32, w: i32, h: i32, title: text) -> Screen:
        """Draw a box with optional title using Unicode box-drawing chars."""
        var s = self
        if w < 2 or h < 2:
            return s
        # Top border: ┌───┐
        var top = "\u{250c}"
        var i = 0
        while i < w - 2:
            top = "{top}\u{2500}"
            i = i + 1
        top = "{top}\u{2510}"
        s = s.put_text(row, col, top)

        # Title overlay if provided
        if title != "":
            val title_str = " {title} "
            s = s.put_styled(row, col + 2, title_str, BOLD)

        # Sides: │  │
        i = 1
        while i < h - 1:
            s = s.put_text(row + i, col, "\u{2502}")
            s = s.put_text(row + i, col + w - 1, "\u{2502}")
            i = i + 1

        # Bottom border: └───┘
        var bottom = "\u{2514}"
        i = 0
        while i < w - 2:
            bottom = "{bottom}\u{2500}"
            i = i + 1
        bottom = "{bottom}\u{2518}"
        s = s.put_text(row + h - 1, col, bottom)

        return s

    fn draw_box_double(row: i32, col: i32, w: i32, h: i32, title: text) -> Screen:
        """Draw a box with double-line Unicode border chars (for dialogs)."""
        var s = self
        if w < 2 or h < 2:
            return s
        # Top border: ╔═══╗
        var top = "\u{2554}"
        var i = 0
        while i < w - 2:
            top = "{top}\u{2550}"
            i = i + 1
        top = "{top}\u{2557}"
        s = s.put_text(row, col, top)

        # Title overlay
        if title != "":
            val title_str = " {title} "
            s = s.put_styled(row, col + 2, title_str, BOLD)

        # Sides: ║  ║
        i = 1
        while i < h - 1:
            s = s.put_text(row + i, col, "\u{2551}")
            s = s.put_text(row + i, col + w - 1, "\u{2551}")
            i = i + 1

        # Bottom border: ╚═══╝
        var bottom = "\u{255a}"
        i = 0
        while i < w - 2:
            bottom = "{bottom}\u{2550}"
            i = i + 1
        bottom = "{bottom}\u{255d}"
        s = s.put_text(row + h - 1, col, bottom)

        return s

    fn draw_box_rounded(row: i32, col: i32, w: i32, h: i32, title: text) -> Screen:
        """Draw a box with rounded corner Unicode chars (for tooltips)."""
        var s = self
        if w < 2 or h < 2:
            return s
        # Top border: ╭───╮
        var top = "\u{256d}"
        var i = 0
        while i < w - 2:
            top = "{top}\u{2500}"
            i = i + 1
        top = "{top}\u{256e}"
        s = s.put_text(row, col, top)

        if title != "":
            val title_str = " {title} "
            s = s.put_styled(row, col + 2, title_str, BOLD)

        # Sides: │  │
        i = 1
        while i < h - 1:
            s = s.put_text(row + i, col, "\u{2502}")
            s = s.put_text(row + i, col + w - 1, "\u{2502}")
            i = i + 1

        # Bottom border: ╰───╯
        var bottom = "\u{2570}"
        i = 0
        while i < w - 2:
            bottom = "{bottom}\u{2500}"
            i = i + 1
        bottom = "{bottom}\u{256f}"
        s = s.put_text(row + h - 1, col, bottom)

        return s

    fn render() -> text:
        """Render the screen buffer to a string for output."""
        var output = ansi_hide_cursor()
        output = "{output}{ansi_cursor_home()}"

        var row = 0
        while row < self.height:
            output = "{output}{ansi_cursor_move(row + 1, 1)}{ansi_clear_line()}{self.buffer[row]}"
            row = row + 1

        return output

# =========================================================================
# Terminal Size Detection
# =========================================================================

extern fn rt_env_get(key: text) -> text
extern fn rt_term_get_size() -> (i32, i32)
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_platform_name() -> text

fn get_terminal_size() -> (i32, i32):
    """Get terminal width and height. Returns (width, height).
    Tries native rt_term_get_size first, then env vars, then platform-specific fallback."""
    # Try native FFI first
    val native_size = rt_term_get_size()
    if native_size.0 > 0 and native_size.1 > 0:
        return (native_size.0, native_size.1)
    # Try environment variables
    val cols = rt_env_get("COLUMNS")
    val rows = rt_env_get("LINES")
    var w = 80
    var h = 24
    if cols != "" and cols != nil:
        w = cols.to_int()
    if rows != "" and rows != nil:
        h = rows.to_int()
    if w > 0 and h > 0:
        return (w, h)
    # Platform-specific fallback
    if rt_platform_name() == "windows":
        val (stdout, stderr, code) = rt_process_run("cmd", ["/c", "mode con 2>nul"])
        if code == 0 and stdout.trim() != "":
            val parsed_w = parse_mode_con_value(stdout, "columns")
            val parsed_h = parse_mode_con_value(stdout, "lines")
            if parsed_w > 0:
                w = parsed_w
            if parsed_h > 0:
                h = parsed_h
    else:
        # Unix: Try stty fallback
        val (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", "stty size 2>/dev/null"])
        if code == 0 and stdout.trim() != "":
            val parts = stdout.trim().split(" ")
            if parts.len() == 2:
                h = parts[0].to_int()
                w = parts[1].to_int()
    if w <= 0:
        w = 80
    if h <= 0:
        h = 24
    return (w, h)

fn parse_mode_con_value(output: text, key: text) -> i32:
    """Parse 'mode con' output for a key like 'Columns' or 'Lines'.
    Format: '    Columns:      120' — extract the number after ':'."""
    val key_lower = key.to_lower()
    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.contains(":"):
            val parts = trimmed.split(":")
            if parts.len() >= 2:
                val label = parts[0].trim().to_lower()
                if label.contains(key_lower):
                    val num_str = parts[1].trim()
                    if num_str != "":
                        return num_str.to_int()
    return 0
