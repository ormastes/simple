# TUI Input Parser
#
# Parses stdin input into UIEvent values.
# Uses line-based input mode (reads full lines) since the Simple runtime
# only provides rt_stdin_read_line(). Raw mode can be added later.

use common.ui.widget.{UIEvent}

# =========================================================================
# Line-based Input Parsing
# =========================================================================

fn parse_input_line(line: text) -> UIEvent:
    """Parse a line of input into a UIEvent."""
    val trimmed = line.trim()

    if trimmed == "":
        return UIEvent.KeyPress(key: "enter")

    # Command-mode commands (prefixed with :)
    if trimmed.starts_with(":"):
        val cmd = trimmed[1:]
        return parse_command(cmd)

    # Named keys
    match trimmed:
        "quit" | "exit" =>
            return UIEvent.Quit
        "q" =>
            return UIEvent.Quit
        "j" | "down" =>
            return UIEvent.FocusNext
        "k" | "up" =>
            return UIEvent.FocusPrev
        "tab" =>
            return UIEvent.FocusNext
        "enter" =>
            return UIEvent.KeyPress(key: "enter")
        "escape" | "esc" =>
            return UIEvent.NormalMode
        _ =>
            if trimmed.len() == 1:
                return UIEvent.KeyPress(key: trimmed)
            return UIEvent.KeyPress(key: trimmed)

fn parse_command(cmd: text) -> UIEvent:
    """Parse a command string (after : prefix)."""
    val trimmed = cmd.trim()

    match trimmed:
        "q" | "quit" =>
            return UIEvent.Quit
        "w" | "write" =>
            return UIEvent.Action(name: "write")
        "wq" =>
            return UIEvent.Action(name: "write_quit")
        "normal" =>
            return UIEvent.NormalMode
        "insert" =>
            return UIEvent.InsertMode
        "command" =>
            return UIEvent.CommandMode
        _ =>
            return UIEvent.Action(name: trimmed)

# =========================================================================
# Input Prompt
# =========================================================================

fn format_input_prompt(mode_name: text) -> text:
    """Generate the input prompt based on current mode."""
    match mode_name:
        "COMMAND" =>
            return ":"
        "INSERT" =>
            return ">> "
        _ =>
            return "> "

fn read_user_input() -> text:
    """Read a line from stdin. Returns the trimmed input."""
    val line = input("")
    if line == nil:
        return ""
    return line.trim()

# =========================================================================
# Raw Mode Input Support
# =========================================================================

extern fn rt_term_read_timeout(max_len: i64, timeout_ms: i64) -> text
extern fn rt_term_poll(timeout_ms: i64) -> bool

fn poll_raw_input(timeout_ms: i64) -> text:
    """Poll for raw input data. Returns empty string if no input within timeout."""
    val has_data = rt_term_poll(timeout_ms)
    if not has_data:
        return ""
    return rt_term_read_timeout(4096, timeout_ms)

fn parse_raw_key(data: text) -> UIEvent:
    """Parse a single raw input byte/sequence into a UIEvent.
    For use with raw mode terminal input."""
    if data == "" or data == nil:
        return UIEvent.KeyPress(key: "")

    val first = data[0]

    # Ctrl+C or Ctrl+Q
    if first == "\x03" or first == "\x11":
        return UIEvent.Quit

    # Escape
    if first == "\u{001b}":
        if data.len() == 1:
            return UIEvent.NormalMode
        # CSI sequence
        if data.len() >= 3 and data[1] == "[":
            val third = data[2]
            match third:
                "A" => return UIEvent.FocusPrev
                "B" => return UIEvent.FocusNext
                _ => return UIEvent.KeyPress(key: data)
        return UIEvent.KeyPress(key: data)

    # Enter
    if first == "\r" or first == "\n":
        return UIEvent.KeyPress(key: "enter")

    # Tab
    if first == "\t":
        return UIEvent.FocusNext

    # Regular key
    return UIEvent.KeyPress(key: first)
