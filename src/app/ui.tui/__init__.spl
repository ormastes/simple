# UI TUI - Re-exports
# Screen buffer
export Screen, get_terminal_size
export ansi_clear_screen, ansi_cursor_home, ansi_cursor_move
export ansi_clear_line, ansi_hide_cursor, ansi_show_cursor
export ansi_enable_alt_screen, ansi_disable_alt_screen

# Input
export parse_input_line, format_input_prompt, read_user_input

# App (sync)
export TuiApp, run_tui

# Narrow generated native TUI lane
export run_standalone_tui, run_standalone_tui_native_smoke

fn run_standalone_tui(file_path: text) -> i64:
    print ansi_enable_alt_screen()
    print ansi_hide_cursor()
    print "Simple TUI"
    print ansi_show_cursor()
    print ansi_disable_alt_screen()
    print "UI closed."
    return 0

fn run_standalone_tui_native_smoke(file_path: text) -> i64:
    print ansi_enable_alt_screen()
    print ansi_hide_cursor()
    print ansi_show_cursor()
    print ansi_disable_alt_screen()
    print "UI closed."
    return 0

# App (async)
export AsyncTuiApp, run_async_tui

# Async input helpers
export start_input_reader, start_raw_input_reader

# Backend
export TuiBackend
