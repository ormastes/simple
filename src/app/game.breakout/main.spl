# bin/simple run src/app/game.breakout/main.spl — Breakout entry point (W5b, G3.2).
#
# Real-window loop via SdlBackend (rt_winit_* surface) unless
# SIMPLE_GAME_HEADLESS=1, which runs a fixed 600-frame headless session
# (CI-safe smoke). Menu -> Playing -> GameOver loop lives in game.spl.
#
# KNOWN BLOCKERS on this host (recorded, not skipped):
# - `bin/simple run` JIT SIGSEGVs on LoopDriver.step:
#   doc/08_tracking/bug/jit_game2d_backend_method_dispatch_sigsegv_2026-07-02.md
# - no window externs in the available binaries:
#   doc/08_tracking/bug/game2d_no_window_externs_in_host_binaries_2026-07-03.md
# The playable-game gates run through test/03_system/game2d/breakout_*_spec.spl
# (interpreter spec runner) until those land.

use app.game.breakout.game.{Game}
use std.nogc_sync_mut.game2d.backend.trait.{WindowConfig, Event}
use std.nogc_sync_mut.game2d.backend.sdl_backend.{SdlBackend}
use std.nogc_sync_mut.game2d.backend.headless.{HeadlessBackend}
use std.nogc_sync_mut.game2d.loop.driver.{LoopDriver}
use std.nogc_sync_mut.game2d.input.snapshot.{InputSnapshot}
use app.io.mod.{env_get}

fn main():
    var app = Game.new_game()
    var driver = LoopDriver.new(60)
    if env_get("SIMPLE_GAME_HEADLESS") == "1":
        # 320x240 smoke: interpreted 800x600 costs ~14s/frame (tracked gap);
        # this stays a seconds-scale CI smoke. Full 800x600 evidence lives in
        # test/03_system/game2d/breakout_*_spec.spl.
        var backend = HeadlessBackend.create(320, 240)
        val snap = InputSnapshot.create()
        var i: i64 = 0
        while i < 120:
            driver.step(app, backend, snap, 16_666_667)
            i = i + 1
        print "headless session done: frames={app.frame_count} state={app.state}"
    else:
        var backend = SdlBackend.create()
        var cfg = WindowConfig.default()
        cfg.title = "Simple Breakout"
        val win = backend.gb_create_window(cfg)
        if win.raw == 0:
            print "error: could not create a window (see game2d_no_window_externs_in_host_binaries bug)"
        else:
            var events: [Event] = []
            var running = true
            while running:
                val _ = backend.poll_native_events(events)
                driver.step(app, backend, backend.gb_current_input(), 16_666_667)
                if backend.window_should_close():
                    running = false
            backend.gb_shutdown()
