use common.wine_process_session.{
    wine_process_execute_controlled_hello,
    wine_process_launch_handoff,
    wine_process_session_plan,
    wine_process_session_request_new
}

extern fn stdout_write(data: text)

fn _hello_gates() -> text:
    "process=verified exec_env=verified vm=verified host=verified posix=verified " +
        "pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"

fn main() -> i64:
    val request = wine_process_session_request_new("hello.exe", [], "C:\\")
    val plan = wine_process_session_plan(request, _hello_gates())
    val handoff = wine_process_launch_handoff(plan, true)
    if handoff.ok:
        val execution = wine_process_execute_controlled_hello(plan)
        if not execution.ok:
            print "wine-process-session-plan failed: {execution.error}"
            return 1
        stdout_write("command={handoff.command}\n")
        stdout_write("readiness={handoff.substrate_readiness}\n")
        stdout_write("handoff={handoff.status}\n")
        stdout_write("execution={execution.status}\n")
        stdout_write("stdout={execution.stdout}")
        return 0
    print "wine-process-session-plan failed: {handoff.error}"
    1
