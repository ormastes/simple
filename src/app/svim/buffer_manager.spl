# SVIM Buffer Manager
#
# Multi-buffer management: switch by name, by index, next/prev, list.
# Delegates to EditSession for actual buffer storage.
#
# Provides: buffer_switch_by_name, buffer_switch_by_index,
#           buffer_next, buffer_prev, buffer_list_info.

use std.editor.core.session.{EditSession}


fn buffer_switch_by_name(session: EditSession, name: text) -> bool:
    """Switch to buffer whose path contains `name`. Returns true if found."""
    session.switch_to_name(name)


fn buffer_switch_by_index(session: EditSession, index: i64) -> bool:
    """Switch to buffer at 0-based index. Returns true if valid."""
    if index < 0 or index >= session.document_count():
        return false
    session.switch_to_index(index)
    true


fn buffer_next(session: EditSession):
    """Switch to next buffer (wraps around)."""
    session.switch_tab(1)


fn buffer_prev(session: EditSession):
    """Switch to previous buffer (wraps around)."""
    session.switch_tab(-1)


fn buffer_list_info(session: EditSession) -> text:
    """Return a text summary of all open buffers with active marker."""
    var out = ""
    val count = session.document_count()
    var i = 0
    while i < count:
        val doc = session.documents[i]
        val marker = if i == session.active_index then "*" else: " "
        val path = doc.path()
        val label = if path == "" then "[No Name]" else: path
        val mod_flag = if session.buffers[i].modified then " [+]" else: ""
        out = out + "  {marker} {i + 1}: {label}{mod_flag}\n"
        i = i + 1
    out
