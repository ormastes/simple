# svim search repeat helpers
#
# Lightweight helpers for repeating the last search forward/backward.
# These operate on plain text; the session-level execute_named wires them in.

fn svim_search_find_next(content: text, start_col: i64, pattern: text) -> i64:
    """Return col of first match at or after start_col, or -1 if not found."""
    val plen = pattern.len()
    if plen == 0:
        return -1
    val clen = content.len()
    var i = start_col
    while i <= clen - plen:
        val slice = content.slice(i, i + plen)
        if slice == pattern:
            return i
        i = i + 1
    -1

fn svim_search_find_prev(content: text, before_col: i64, pattern: text) -> i64:
    """Return col of last match strictly before before_col, or -1 if not found."""
    val plen = pattern.len()
    if plen == 0:
        return -1
    var i = before_col - 1
    while i >= 0:
        if i + plen <= content.len():
            val slice = content.slice(i, i + plen)
            if slice == pattern:
                return i
        i = i - 1
    -1

fn svim_search_next(content: text, current_col: i64, pattern: text) -> i64:
    """Advance to the next occurrence, wrapping around if needed."""
    val after = svim_search_find_next(content, current_col + 1, pattern)
    if after >= 0:
        return after
    svim_search_find_next(content, 0, pattern)

fn svim_search_prev(content: text, current_col: i64, pattern: text) -> i64:
    """Move to the previous occurrence, wrapping around if needed."""
    val before = svim_search_find_prev(content, current_col, pattern)
    if before >= 0:
        return before
    val clen = content.len()
    svim_search_find_prev(content, clen, pattern)
