# svim text-object helpers
#
# Inner/around word and inner/around line text-object range computation.
# All functions return (start_col, end_col) as a two-element [i64] tuple.

fn svim_is_word_char(ch: text) -> bool:
    """Return true if ch is a word character (alphanumeric or underscore)."""
    if ch == "_":
        return true
    val code = ch.char_code_at(0)
    if code >= 48 and code <= 57:
        return true
    if code >= 65 and code <= 90:
        return true
    if code >= 97 and code <= 122:
        return true
    false

fn svim_inner_word(line: text, col: i64) -> [i64]:
    """Return [start, end] of the word under col (exclusive end)."""
    val llen = line.len()
    if llen == 0:
        return [0, 0]
    var safe_col = col
    if safe_col >= llen:
        safe_col = llen - 1
    var start = safe_col
    while start > 0 and svim_is_word_char(line.slice(start - 1, start)):
        start = start - 1
    var end = safe_col
    while end < llen and svim_is_word_char(line.slice(end, end + 1)):
        end = end + 1
    [start, end]

fn svim_around_word(line: text, col: i64) -> [i64]:
    """Return [start, end] of word + trailing spaces (around-word)."""
    val inner = svim_inner_word(line, col)
    val llen = line.len()
    var end = inner[1]
    while end < llen and line.slice(end, end + 1) == " ":
        end = end + 1
    [inner[0], end]

fn svim_inner_line(line: text) -> [i64]:
    """Return [start, end] of non-whitespace content on a line."""
    val llen = line.len()
    var start = 0
    while start < llen and line.slice(start, start + 1) == " ":
        start = start + 1
    var end = llen
    while end > start and line.slice(end - 1, end) == " ":
        end = end - 1
    [start, end]

fn svim_around_line(line: text) -> [i64]:
    """Return [0, len] — the full line including leading/trailing space."""
    [0, line.len()]
