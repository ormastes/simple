# SVIM Split Pane Renderer
#
# Renders split pane boundaries and per-pane content for the TUI shell.
# Uses SplitTree to determine layout regions and draws separators.
#
# Provides: render_split_layout, render_pane_status.

use std.editor.core.session.{EditSession, Pane}
use std.editor.view.split_tree.{SplitTree, SplitNode, SplitDirection}


# PaneRegion — computed screen rectangle for a pane.
class PaneRegion:
    pane_id: i64
    row: i64
    col: i64
    width: i64
    height: i64


fn compute_pane_regions(tree: SplitTree, total_width: i64, total_height: i64) -> [PaneRegion]:
    """Walk the SplitTree and compute rectangular regions for each leaf pane."""
    var regions: [PaneRegion] = []
    _compute_node(tree.root, 0, 0, total_width, total_height, regions)
    regions


fn _compute_node(node: SplitNode, row: i64, col: i64, width: i64, height: i64, out: [PaneRegion]):
    """Recursively compute regions for a split node."""
    match node:
        SplitNode.Leaf(pane_id):
            out.push(PaneRegion(pane_id: pane_id, row: row, col: col, width: width, height: height))
        SplitNode.Split(direction, ratio, left, right):
            if direction == SplitDirection.Vertical:
                # Split left/right with a 1-char vertical separator
                val left_w = (width - 1) / 2
                val right_w = width - left_w - 1
                _compute_node(left, row, col, left_w, height, out)
                _compute_node(right, row, col + left_w + 1, right_w, height, out)
            else:
                # Split top/bottom with a 1-char horizontal separator
                val top_h = (height - 1) / 2
                val bottom_h = height - top_h - 1
                _compute_node(left, row, col, width, top_h, out)
                _compute_node(right, row + top_h + 1, col, width, bottom_h, out)


fn render_split_layout(session: EditSession, width: i64, height: i64) -> text:
    """Render the full split layout with pane boundaries as text.
    Returns a multi-line text block with separators and per-pane content."""
    val regions = compute_pane_regions(session.split_tree(), width, height)
    if regions.len() <= 1:
        return ""
    # Build separator description lines
    var out = ""
    var i = 0
    while i < regions.len():
        val r = regions[i]
        val active = if r.pane_id == session.active_pane_id() then "*" else: " "
        val buf_label = _pane_buffer_label(session, r.pane_id)
        out = out + "{active}pane {r.pane_id}: {buf_label} ({r.width}x{r.height} at {r.row},{r.col})\n"
        i = i + 1
    out


fn render_split_separators(session: EditSession, width: i64, height: i64) -> text:
    """Render separator characters between split panes."""
    val tree = session.split_tree()
    var lines: [text] = []
    _render_sep_node(tree.root, 0, 0, width, height, lines)
    var out = ""
    var i = 0
    while i < lines.len():
        out = out + lines[i] + "\n"
        i = i + 1
    out


fn _render_sep_node(node: SplitNode, row: i64, col: i64, width: i64, height: i64, out: [text]):
    """Collect separator descriptions."""
    match node:
        SplitNode.Leaf(pane_id):
            pass_do_nothing
        SplitNode.Split(direction, ratio, left, right):
            if direction == SplitDirection.Vertical:
                val left_w = (width - 1) / 2
                out.push("vsep col={col + left_w} rows={row}..{row + height}")
                _render_sep_node(left, row, col, left_w, height, out)
                _render_sep_node(right, row, col + left_w + 1, width - left_w - 1, height, out)
            else:
                val top_h = (height - 1) / 2
                out.push("hsep row={row + top_h} cols={col}..{col + width}")
                _render_sep_node(left, row, col, width, top_h, out)
                _render_sep_node(right, row + top_h + 1, col, width, height - top_h - 1, out)


fn render_pane_status(session: EditSession) -> text:
    """Render status bar info: [buffer i/N] [pane x/y] [modified]."""
    val buf_idx = session.active_index + 1
    val buf_count = session.document_count()
    val pane_idx = session.active_pane_index() + 1
    val pane_total = session.pane_count()
    val doc = session.active_document()
    val buf = session.active_buffer()
    val mod_flag = if buf.modified then " [+]" else: ""
    val path = doc.path()
    val label = if path == "" then "[No Name]" else: path
    "{label}{mod_flag} [buf {buf_idx}/{buf_count}] [pane {pane_idx}/{pane_total}]"


fn _pane_buffer_label(session: EditSession, pane_id: i64) -> text:
    """Get the buffer label for a specific pane."""
    var i = 0
    while i < session.panes.len():
        if session.panes[i].pane_id == pane_id:
            val bi = session.panes[i].buffer_index
            if bi >= 0 and bi < session.document_count():
                val p = session.documents[bi].path()
                if p == "":
                    return "[No Name]"
                return p
            return "[No Name]"
        i = i + 1
    "[No Name]"
