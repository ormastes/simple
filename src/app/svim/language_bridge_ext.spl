# svim language bridge extension
#
# Converts parser diagnostics (row/col/severity/message tuples) into
# DiagnosticItem records and QuickfixEntry records for the shared session.

class ParseDiagnostic:
    row: i64
    col: i64
    severity: text
    message: text
    source: text

class BridgeDiagnostic:
    row: i64
    col: i64
    severity: text
    message: text

class BridgeQuickfixEntry:
    row: i64
    col: i64
    severity: text
    message: text
    label: text

fn svim_bridge_diagnostic(pd: ParseDiagnostic) -> BridgeDiagnostic:
    """Convert a ParseDiagnostic to a BridgeDiagnostic."""
    BridgeDiagnostic(row: pd.row, col: pd.col, severity: pd.severity, message: pd.message)

fn svim_bridge_quickfix_entry(pd: ParseDiagnostic) -> BridgeQuickfixEntry:
    """Convert a ParseDiagnostic to a BridgeQuickfixEntry."""
    val label = "{pd.source}:{pd.row + 1}:{pd.col + 1}: {pd.severity}"
    BridgeQuickfixEntry(row: pd.row, col: pd.col, severity: pd.severity, message: pd.message, label: label)

fn svim_bridge_all_diagnostics(pds: [ParseDiagnostic]) -> [BridgeDiagnostic]:
    """Batch-convert ParseDiagnostic list to BridgeDiagnostic list."""
    var out: [BridgeDiagnostic] = []
    for pd in pds:
        out.push(svim_bridge_diagnostic(pd))
    out

fn svim_bridge_all_quickfix(pds: [ParseDiagnostic]) -> [BridgeQuickfixEntry]:
    """Batch-convert ParseDiagnostic list to BridgeQuickfixEntry list."""
    var out: [BridgeQuickfixEntry] = []
    for pd in pds:
        out.push(svim_bridge_quickfix_entry(pd))
    out

fn svim_bridge_filter_errors(pds: [ParseDiagnostic]) -> [ParseDiagnostic]:
    """Return only error-severity diagnostics."""
    var out: [ParseDiagnostic] = []
    for pd in pds:
        if pd.severity == "error":
            out.push(pd)
    out

fn svim_bridge_has_errors(pds: [ParseDiagnostic]) -> bool:
    svim_bridge_filter_errors(pds).len() > 0
