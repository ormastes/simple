# Simple CLI - process command
#
# Host process-management gateway: list | spawn | kill | wait.
#
# Backed by std process ops (process_spawn_async/wait/is_running/kill) and a
# small persistent SDN registry under the user cache dir. `list` reports only
# gateway-spawned (gateway-managed) processes — it deliberately does NOT scrape
# /proc, which has no portable owner/command mapping. Output/error shape reuses
# the shared access CLI grammar so the host gateway matches the SimpleOS guest
# process gateway.

use std.cli.cli_util (get_cli_args)
use app.io.mod.{process_spawn_async, process_wait, process_is_running, process_kill}
use app.process.registry.{registry_load, registry_add, registry_remove}
use common.ui.access.*

# ---------------------------------------------------------------------------
# Output helpers (shared access grammar)
# ---------------------------------------------------------------------------

fn _emit(result: AccessResult, as_json: bool) -> i64:
    if as_json:
        print access_render_json(result)
    else:
        print access_render_human(result)
    0

fn _emit_err(operation: text, err: AccessError, as_json: bool) -> i64:
    if as_json:
        print access_error_to_json(operation, "", err)
    else:
        print "error: " + err.message
    1

fn _rest(a: [text], from: i64) -> [text]:
    var out: [text] = []
    var i = from
    while i < a.len():
        out = out.push(a[i])
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Subcommand handlers
# ---------------------------------------------------------------------------

fn handle_list(as_json: bool) -> i64:
    val entries = registry_load()
    var rows: [[text]] = [["PID", "STATE", "COMMAND"]]
    for e in entries:
        val state = if process_is_running(e.pid): "running" else: "exited"
        rows = rows.push([e.pid.to_text(), state, e.cmd])
    _emit(AccessResult.table("Gateway processes", rows), as_json)

fn handle_spawn(pos: [text], as_json: bool) -> i64:
    if pos.len() == 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.detailed("invalid_argument", "missing command", "", "Usage: simple process spawn <cmd> [args...]", false, false), as_json)
    val cmd = pos[0]
    val cmd_args = _rest(pos, 1)
    val pid = process_spawn_async(cmd, cmd_args)
    if pid <= 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.create("spawn_failed", "failed to spawn '" + cmd + "'"), as_json)
    val full = if cmd_args.len() > 0: cmd + " " + cmd_args.join(" ") else: cmd
    registry_add(pid, full)
    var result = AccessResult.status([["pid", pid.to_text()], ["command", full], ["status", "spawned"]], "")
    _emit(result, as_json)

fn handle_kill(pos: [text], as_json: bool) -> i64:
    if pos.len() == 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.detailed("invalid_argument", "missing PID", "", "Usage: simple process kill <pid>", false, false), as_json)
    val pid = pos[0].to_i64() ?? -1
    if pid <= 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.create("invalid_argument", "invalid PID: " + pos[0]), as_json)
    val ok = process_kill(pid)
    registry_remove(pid)
    if not ok:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.create("kill_failed", "failed to kill pid " + pid.to_text()), as_json)
    _emit(AccessResult.status([["pid", pid.to_text()], ["action", "kill"], ["status", "ok"]], ""), as_json)

fn handle_wait(pos: [text], as_json: bool) -> i64:
    if pos.len() == 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.detailed("invalid_argument", "missing PID", "", "Usage: simple process wait <pid> [timeout_ms]", false, false), as_json)
    val pid = pos[0].to_i64() ?? -1
    if pid <= 0:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.create("invalid_argument", "invalid PID: " + pos[0]), as_json)
    val timeout = if pos.len() > 1: pos[1].to_i64() ?? 0 else: 0
    val code = process_wait(pid, timeout)
    if code == -2:
        return _emit_err(ACCESS_OPERATION_ACT, AccessError.detailed("timeout", "wait timed out for pid " + pid.to_text(), "", "Increase the timeout or check the process", true, false), as_json)
    registry_remove(pid)
    _emit(AccessResult.scalar_titled("exit_code", code.to_text()), as_json)

fn print_help():
    print "Usage: simple process <subcommand> [args]"
    print ""
    print "Manage host processes spawned through the gateway."
    print ""
    print "Subcommands:"
    print "  list                    List gateway-managed processes"
    print "  spawn <cmd> [args...]   Spawn a process and register it"
    print "  kill <pid>              Terminate a process"
    print "  wait <pid> [timeout_ms] Wait for a process to exit"
    print ""
    print "Options:"
    print "  --json                  Output as JSON (shared access grammar)"
    print "  -h, --help              Show this help"

fn main() -> i64:
    val args = get_cli_args()
    var as_json = false
    var subcommand = ""
    var pos: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif subcommand == "":
            subcommand = arg
        else:
            pos = pos.push(arg)
        i = i + 1

    if subcommand == "":
        print_help()
        return 0

    match subcommand:
        case "list":
            return handle_list(as_json)
        case "spawn":
            return handle_spawn(pos, as_json)
        case "kill":
            return handle_kill(pos, as_json)
        case "wait":
            return handle_wait(pos, as_json)
        case _:
            print "error: unknown subcommand '" + subcommand + "'"
            print ""
            print_help()
            return 1
