# RenderDoc frame-capture of the generated GUI widget HTML fixture on Vulkan.
#
# This is the Simple-side widget proof for the GUI/web/2D RenderDoc goal. It
# renders the generated widget HTML fixture through the Simple Web layout
# pipeline, then presents the resulting pixel runs on a Vulkan Engine2D surface
# inside an in-application RenderDoc frame capture.

use app.io.mod.{env_get, file_read}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.browser_engine.web_render_backend.{web_render_backend}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_uses_legacy_widget_chrome
}
use app.test.renderdoc_runtime_ops.{
    renderdoc_available, renderdoc_capture_file_path_template_from_env,
    renderdoc_configure_capture_file_path_template_from_env,
    renderdoc_is_frame_capturing, renderdoc_start_capture_for_device,
    renderdoc_end_capture_for_device, renderdoc_num_captures,
    vulkan_renderdoc_device_pointer
}

fn env_text(name: text, fallback: text) -> text:
    env_get(name) ?? fallback

fn draw_pixel_runs(engine: Engine2D, pixels: [u32], width: i32, height: i32):
    var y = 0
    while y < height:
        var x = 0
        while x < width:
            val color = pixels[y * width + x]
            var run_w = 1
            while x + run_w < width and pixels[y * width + x + run_w] == color:
                run_w = run_w + 1
            engine.draw_rect_filled(x, y, run_w, 1, color)
            x = x + run_w
        y = y + 1

fn main():
    val html_path = env_text("RDOC_HTML_PATH", "test/fixtures/html_css/generated_gui_vulkan_renderdoc_fixture.html")
    val width = env_text("RDOC_SIMPLE_WIDGET_WIDTH", "320").to_i32()
    val height = env_text("RDOC_SIMPLE_WIDGET_HEIGHT", "240").to_i32()
    val html = file_read(html_path) ?? ""
    print("widget_html_path=" + html_path + "\n")
    print("widget_html_bytes=" + html.len().to_text() + "\n")
    print("widget_width=" + width.to_text() + "\n")
    print("widget_height=" + height.to_text() + "\n")
    if html == "":
        print("renderdoc_capture: EMPTY_WIDGET_HTML\n")
        return

    val avail = renderdoc_available()
    print("renderdoc_available=" + avail.to_text() + "\n")

    val capture_template = renderdoc_capture_file_path_template_from_env()
    if capture_template != "":
        val template_set = renderdoc_configure_capture_file_path_template_from_env()
        print("renderdoc_capture_template=" + capture_template + "\n")
        print("renderdoc_capture_template_set=" + template_set.to_text() + "\n")

    val software_pixels = web_render_backend("pure_simple", width, height).render_html_software_pixels(html)
    val requested = Engine2D.create_requested_backend(width, height, "vulkan")
    var engine = match requested:
        Ok(value): value
        Err(message):
            print("renderdoc_capture: BACKEND_UNAVAILABLE " + message + "\n")
            return
    print("backend=" + engine.backend_name() + "\n")

    val device = vulkan_renderdoc_device_pointer()
    print("renderdoc_device=" + device.to_text() + "\n")

    val started = renderdoc_start_capture_for_device(device)
    print("renderdoc_start=" + started.to_text() + "\n")
    var use_wildcard_capture = false
    var capturing_after_start = renderdoc_is_frame_capturing()
    print("renderdoc_capturing_after_start=" + capturing_after_start.to_text() + "\n")
    if capturing_after_start == 0:
        val wildcard_started = renderdoc_start_capture()
        print("renderdoc_wildcard_start=" + wildcard_started.to_text() + "\n")
        val wildcard_capturing = renderdoc_is_frame_capturing()
        print("renderdoc_wildcard_capturing_after_start=" + wildcard_capturing.to_text() + "\n")
        if wildcard_capturing != 0:
            use_wildcard_capture = true
            capturing_after_start = wildcard_capturing

    val base = if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32
    engine.clear(base)
    draw_pixel_runs(engine, software_pixels, width, height)
    val pixels = engine.read_pixels()
    engine.present()

    val capturing_before_end = renderdoc_is_frame_capturing()
    var ended = 0
    if use_wildcard_capture:
        ended = renderdoc_end_capture()
    else:
        ended = renderdoc_end_capture_for_device(device)
    print("renderdoc_capturing_before_end=" + capturing_before_end.to_text() + "\n")
    print("renderdoc_end=" + ended.to_text() + " pixels=" + pixels.len().to_text() + " num_captures=" + renderdoc_num_captures().to_text() + "\n")
    engine.shutdown()
