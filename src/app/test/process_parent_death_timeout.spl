use std.io_runtime.{env_get}
use app.io.process_ops.{process_run_timeout}

fn main() -> i64:
    val run_dir = env_get("SIMPLE_PARENT_DEATH_DIR")
    if run_dir == "":
        return 2
    val payload = "echo $$ > '{run_dir}/wrapper.pid'; /bin/sh -c 'echo $$ > \"{run_dir}/child.pid\"; while :; do sleep 1; done' & wait"
    val (_, _, code) = process_run_timeout("/bin/sh", ["-c", payload], 600000)
    code
