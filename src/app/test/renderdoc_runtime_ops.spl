#[runtime_intrinsics]
extern fn rt_renderdoc_available() -> i64
extern fn rt_renderdoc_set_capture_file_path_template(path: text) -> i64
extern fn rt_renderdoc_capture_file_path_template_from_env() -> text
extern fn rt_renderdoc_configure_capture_file_path_template_from_env() -> i64
extern fn rt_renderdoc_is_frame_capturing() -> i64
extern fn rt_renderdoc_start_capture() -> i64
extern fn rt_renderdoc_start_capture_for_device(device: i64) -> i64
extern fn rt_renderdoc_end_capture() -> i64
extern fn rt_renderdoc_end_capture_for_device(device: i64) -> i64
extern fn rt_renderdoc_num_captures() -> i64
extern fn rt_vulkan_get_renderdoc_device_pointer() -> i64

pub fn renderdoc_available() -> i64:
    rt_renderdoc_available()

pub fn renderdoc_set_capture_file_path_template(path: text) -> i64:
    rt_renderdoc_set_capture_file_path_template(path)

pub fn renderdoc_capture_file_path_template_from_env() -> text:
    rt_renderdoc_capture_file_path_template_from_env()

pub fn renderdoc_configure_capture_file_path_template_from_env() -> i64:
    rt_renderdoc_configure_capture_file_path_template_from_env()

pub fn renderdoc_is_frame_capturing() -> i64:
    rt_renderdoc_is_frame_capturing()

pub fn renderdoc_start_capture() -> i64:
    rt_renderdoc_start_capture()

pub fn renderdoc_start_capture_for_device(device: i64) -> i64:
    rt_renderdoc_start_capture_for_device(device)

pub fn renderdoc_end_capture() -> i64:
    rt_renderdoc_end_capture()

pub fn renderdoc_end_capture_for_device(device: i64) -> i64:
    rt_renderdoc_end_capture_for_device(device)

pub fn renderdoc_num_captures() -> i64:
    rt_renderdoc_num_captures()

pub fn vulkan_renderdoc_device_pointer() -> i64:
    rt_vulkan_get_renderdoc_device_pointer()
