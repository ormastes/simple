# cross_app_glyph_capture.spl — Cross-app glyph-consistency evidence for the
# production readiness master plan gate G2.5 ("the browser and the GUI
# showcase render shared UI chrome ... with identical glyph rasterization").
#
# Renders the SAME characters via two independent text paths, offscreen only:
#   (a) GUI showcase text path: std.gpu.engine2d.backend_software.SoftwareBackend
#       .draw_text(), backed by std.gpu.engine2d.glyph.glyph_data() (a 5x7
#       bitmap table).
#   (b) Browser text paint path: the pure-Simple web layout renderer
#       (simple_web_html_layout_renderer.spl), backed by its OWN, separately
#       authored 5x7 bitmap table (FONT_ROWS_PACKED).
#
# Both tables target the same 5x7 glyph cell and the same font-size->scale
# formula (scale = font_size/8 rounded down; scale=2 at font-size 16), but
# their per-character advance formulas differ (Engine2D: 6*scale=12px;
# browser: 5*scale=10px — see style_text_advance()/text_advance() in
# simple_web_html_layout_renderer.spl vs glyph_advance() in glyph.spl). A
# joint multi-character render is captured for visual evidence, but the pixel
# comparison renders ONE character at a time (own canvas per app per char) so
# the advance-formula difference cannot confound the glyph-shape comparison:
# each character's own tight ink bounding box is the crop region.
#
# Prints key=value evidence lines; exits 0 when the capture+compare
# infrastructure itself succeeds (every test character produced ink in both
# apps and a comparison was computed) — independent of whether the glyphs
# actually match. The verdict is reported separately as
# glyph_consistency_status, matching the honest-gap convention used by
# browser_interaction_capture.spl's link_click_status.
#
# Usage: bin/simple run src/app/test/cross_app_glyph_capture.spl [out_dir]

use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gpu.engine2d.glyph.{glyph_data, glyph_advance}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels_with_engine2d_backend}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{text_advance}
use common.ui.glyph_bitmap_5x7.{FONT_CHARSET, glyph_row_bits, glyph_index_for_char_code}
use common.image.ppm_decode.{encode_ppm_p6}
use std.nogc_sync_mut.sffi.io.{file_write_bytes}
use std.sffi.cli.{cli_get_args}

val TEST_CHARS: text = "AEFHSVXYZ"
val FONT_SIZE: i32 = 16
val EVIDENCE_W: i32 = 160
val EVIDENCE_H: i32 = 40
val CHAR_CANVAS: i32 = 24
val BLACK: u32 = 0xFF000000u32
val WHITE: u32 = 0xFFFFFFFFu32

# @step: Render the GUI showcase text path (multi-char, for visual evidence)
fn render_gui_evidence() -> [u32]:
    var b = SoftwareBackend.create()
    if not b.init(EVIDENCE_W, EVIDENCE_H):
        return []
    b.clear(WHITE)
    b.draw_text(4, 4, TEST_CHARS, BLACK, FONT_SIZE)
    b.present()
    b.read_pixels()

# @step: Render the browser text paint path (multi-char, for visual evidence)
fn render_browser_evidence() -> [u32]:
    var html = "<html><head><style>"
    html = html + "body{margin:0;padding:0;background-color:#ffffff;} "
    html = html + ".t{margin:0;padding:0;font-size:16px;color:#000000;white-space:nowrap;}"
    html = html + "</style></head><body><div class='t'>{TEST_CHARS}</div></body></html>"
    simple_web_render_html_to_pixels_with_engine2d_backend(html, EVIDENCE_W, EVIDENCE_H, "cpu_simd")

# @step: Render a single character via the GUI showcase text path
fn render_gui_char(ch: text) -> [u32]:
    var b = SoftwareBackend.create()
    if not b.init(CHAR_CANVAS, CHAR_CANVAS):
        return []
    b.clear(WHITE)
    b.draw_text(4, 4, ch, BLACK, FONT_SIZE)
    b.present()
    b.read_pixels()

# @step: Render a single character via the browser text paint path
fn render_browser_char(ch: text) -> [u32]:
    var html = "<html><head><style>"
    html = html + "body{margin:0;padding:0;background-color:#ffffff;} "
    html = html + ".t{margin:0;padding:0;font-size:16px;color:#000000;white-space:nowrap;}"
    html = html + "</style></head><body><div class='t'>{ch}</div></body></html>"
    simple_web_render_html_to_pixels_with_engine2d_backend(html, CHAR_CANVAS, CHAR_CANVAS, "cpu_simd")

# @step: Write ARGB pixels as binary P6 PPM
fn write_ppm(path: text, pixels: [u32], width: i32, height: i32) -> bool:
    val bytes = encode_ppm_p6(width.to_u32(), height.to_u32(), pixels)
    file_write_bytes(path, bytes)

# @step: Find the ink bounding box (pixels != bg) in a rendered buffer
fn ink_bbox(pixels: [u32], w: i32, h: i32, bg: u32) -> (i32, i32, i32, i32, bool):
    var minx = w
    var miny = h
    var maxx = -1
    var maxy = -1
    var y = 0
    while y < h:
        var x = 0
        while x < w:
            if pixels[y * w + x] != bg:
                if x < minx: minx = x
                if x > maxx: maxx = x
                if y < miny: miny = y
                if y > maxy: maxy = y
            x = x + 1
        y = y + 1
    (minx, miny, maxx, maxy, maxx >= 0)

# @step: Is pixel (dx, dy) inside the given local bbox, and is it ink there?
fn ink_at(pixels: [u32], w: i32, bg: u32, bx: i32, by: i32, bw: i32, bh: i32, dx: i32, dy: i32) -> bool:
    if dx >= bw or dy >= bh:
        return false
    pixels[(by + dy) * w + (bx + dx)] != bg

# @step: Source-level strict comparison over the full 88-char charset.
# Compares the Engine2D paint lookup (glyph_data) against the browser paint
# lookup (glyph_row_bits o glyph_index_for_char_code) row-by-row, bit-by-bit.
# Returns (chars_compared, mismatched_chars, mismatched_pixels).
fn strict_table_compare() -> (i32, i32, i32):
    var chars = 0
    var bad_chars = 0
    var bad_px = 0
    var i = 0
    while i < FONT_CHARSET.len():
        val ch = FONT_CHARSET.char_at(i)
        val e2d = glyph_data(ch)
        val gi = glyph_index_for_char_code(ch.char_code_at(0))
        var char_bad = false
        var row = 0
        while row < 7:
            val browser_row = glyph_row_bits(gi, row)
            val e2d_row = e2d[row]
            var col = 0
            while col < 5:
                val bb = (browser_row >> (4 - col)) & 1
                val eb = (e2d_row >> (4 - col)) & 1
                if bb != eb:
                    bad_px = bad_px + 1
                    char_bad = true
                col = col + 1
            row = row + 1
        if char_bad:
            bad_chars = bad_chars + 1
        chars = chars + 1
        i = i + 1
    (chars, bad_chars, bad_px)

fn main() -> i64:
    val args = cli_get_args()
    var out_dir = "build/cross-app-glyph-consistency"
    if args.len() >= 1 and args[0] != "":
        out_dir = args[0]

    var all_pass = true

    # ---- Whole-string evidence captures (visual proof, not the oracle) ---
    val gui_evidence_px = render_gui_evidence()
    val browser_evidence_px = render_browser_evidence()
    if gui_evidence_px.len() != EVIDENCE_W * EVIDENCE_H or browser_evidence_px.len() != EVIDENCE_W * EVIDENCE_H:
        print "capture_overall=fail"
        print "capture_reason=evidence_framebuffer_not_canvas_sized"
        return 1
    val gui_ppm_path = "{out_dir}/gui_glyphs.ppm"
    val browser_ppm_path = "{out_dir}/browser_glyphs.ppm"
    if write_ppm(gui_ppm_path, gui_evidence_px, EVIDENCE_W, EVIDENCE_H):
        print "gui_ppm={gui_ppm_path}"
    else:
        all_pass = false
        print "gui_ppm="
    if write_ppm(browser_ppm_path, browser_evidence_px, EVIDENCE_W, EVIDENCE_H):
        print "browser_ppm={browser_ppm_path}"
    else:
        all_pass = false
        print "browser_ppm="

    # ---- Per-character glyph-region pixel oracle --------------------------
    # One character per canvas per app avoids the advance/spacing-formula
    # difference between the two engines (see header) from confounding the
    # glyph-shape comparison: each crop is that character's own tight ink box.
    var i = 0
    var total_pixels: i64 = 0
    var total_mismatched: i64 = 0
    var diverging_chars = 0
    while i < TEST_CHARS.len():
        val ch = TEST_CHARS.char_at(i)
        val gui_px = render_gui_char(ch)
        val browser_px = render_browser_char(ch)
        if gui_px.len() != CHAR_CANVAS * CHAR_CANVAS or browser_px.len() != CHAR_CANVAS * CHAR_CANVAS:
            all_pass = false
            print "char_{i}_glyph={ch}"
            print "char_{i}_status=render_failed"
            i = i + 1
            continue

        val (gminx, gminy, gmaxx, gmaxy, gfound) = ink_bbox(gui_px, CHAR_CANVAS, CHAR_CANVAS, WHITE)
        val (bminx, bminy, bmaxx, bmaxy, bfound) = ink_bbox(browser_px, CHAR_CANVAS, CHAR_CANVAS, WHITE)
        if not gfound or not bfound:
            all_pass = false
            print "char_{i}_glyph={ch}"
            print "char_{i}_status=no_ink_found"
            i = i + 1
            continue

        val gw = gmaxx - gminx + 1
        val gh = gmaxy - gminy + 1
        val bw = bmaxx - bminx + 1
        val bh = bmaxy - bminy + 1
        val union_w = if gw > bw: gw else: bw
        val union_h = if gh > bh: gh else: bh

        var cell_mismatch: i64 = 0
        var dy = 0
        while dy < union_h:
            var dx = 0
            while dx < union_w:
                val g_ink = ink_at(gui_px, CHAR_CANVAS, WHITE, gminx, gminy, gw, gh, dx, dy)
                val b_ink = ink_at(browser_px, CHAR_CANVAS, WHITE, bminx, bminy, bw, bh, dx, dy)
                if g_ink != b_ink:
                    cell_mismatch = cell_mismatch + 1
                dx = dx + 1
            dy = dy + 1

        val cell_total: i64 = (union_w * union_h) as i64
        total_pixels = total_pixels + cell_total
        total_mismatched = total_mismatched + cell_mismatch
        val status = if cell_mismatch == 0: "match" else: "diverge"
        if cell_mismatch != 0:
            diverging_chars = diverging_chars + 1
        print "char_{i}_glyph={ch}"
        print "char_{i}_gui_bbox={gw}x{gh}"
        print "char_{i}_browser_bbox={bw}x{bh}"
        print "char_{i}_mismatch_px={cell_mismatch}"
        print "char_{i}_status={status}"
        i = i + 1

    print "diverging_chars={diverging_chars}"
    print "total_pixels_compared={total_pixels}"
    print "total_mismatched_pixels={total_mismatched}"
    if total_pixels > 0:
        val matching_pct = ((total_pixels - total_mismatched) as f64) / (total_pixels as f64) * 100.0
        print "matching_pct={matching_pct}"

    # ---- Full-charset source-level strict identity + advance check ---------
    val (strict_chars, strict_bad_chars, strict_bad_px) = strict_table_compare()
    print "strict_charset_count={strict_chars}"
    print "strict_mismatched_chars={strict_bad_chars}"
    print "strict_mismatched_pixels={strict_bad_px}"
    val adv_e2d = glyph_advance(2)
    val adv_browser = text_advance(16)
    print "advance_engine2d={adv_e2d}"
    print "advance_browser={adv_browser}"
    val advance_match = if adv_e2d == adv_browser: "true" else: "false"
    print "advance_match={advance_match}"

    val tables_identical = strict_bad_px == 0 and adv_e2d == adv_browser
    val glyph_consistency_status = if total_mismatched == 0 and tables_identical: "identical" else: "diverges"
    print "glyph_consistency_status={glyph_consistency_status}"

    if all_pass:
        print "capture_overall=pass"
        return 0
    print "capture_overall=fail"
    1
