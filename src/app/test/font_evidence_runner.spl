# Pure-Simple runner for focused font evidence specs.

use std.nogc_sync_mut.sffi.cli (cli_get_args)
use std.nogc_sync_mut.io.file_ops.{file_delete, file_exists}
use std.nogc_sync_mut.test_runner.test_result_wrapper.{build_interpreter_result_wrapper}
use app.io.process_ops.{process_run_timeout}

fn main() -> i64:
    val args = cli_get_args()
    if args.len() != 3:
        print "usage: font_evidence_runner <pure-simple-bin> <spec.spl>"
        return 2

    val runtime = args[1]
    if not file_exists(runtime):
        print "font-evidence-runner: pure-Simple runtime not found: {runtime}"
        return 1
    val (wrapped, cleanup_path) = build_interpreter_result_wrapper(args[2])
    if wrapped == "":
        print "font-evidence-runner: cannot wrap spec: {args[2]}"
        return 1
    val (stdout, stderr, code) = process_run_timeout(runtime, ["run", wrapped], 120000)
    if stdout != "":
        print stdout
    if stderr != "":
        eprint stderr
    if cleanup_path != "" and not file_delete(cleanup_path):
        print "font-evidence-runner: cannot delete wrapper: {cleanup_path}"
        return 1
    if code == -1:
        if stderr.contains("[TIMEOUT:") or stderr.contains("Process timed out"):
            return 124
        return 1
    code as i64
