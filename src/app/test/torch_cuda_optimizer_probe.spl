use std.gc_async_mut.torch.mod.{Tensor, torch_available, cuda_available}
use std.gc_async_mut.torch.optim.{SGDOptimizer}
use std.torch.sffi.{
    rt_torch_tensor_from_data,
    rt_torch_torchtensor_cuda,
    rt_torch_torchtensor_is_cuda,
    rt_torch_torchtensor_sum,
    rt_torch_autograd_set_requires_grad,
    rt_torch_autograd_grad
}

fn emit(key: text, value: text):
    print(key + "=" + value + "\n")

fn emit_bool(key: text, value: bool):
    emit(key, value.to_text())

fn emit_i64(key: text, value: i64):
    emit(key, value.to_text())

fn emit_f64(key: text, value: f64):
    emit(key, value.to_text())

fn main() -> i64:
    emit("torch_cuda_optimizer_probe_phase", "running")
    emit("torch_cuda_optimizer_probe_required_gates", "libtorch,cuda,parameter_cuda,autograd_gradient,optimizer_step_decreases_parameter_sum")

    if not torch_available():
        emit_bool("torch_cuda_optimizer_probe_torch_available", false)
        emit_bool("torch_cuda_optimizer_probe_cuda_available", false)
        emit("torch_cuda_optimizer_probe_blocked_gate", "libtorch")
        emit("torch_cuda_optimizer_probe_status", "unavailable")
        emit("torch_cuda_optimizer_probe_reason", "libtorch_unavailable")
        return 0

    emit_bool("torch_cuda_optimizer_probe_torch_available", true)

    if not cuda_available():
        emit_bool("torch_cuda_optimizer_probe_cuda_available", false)
        emit("torch_cuda_optimizer_probe_blocked_gate", "cuda")
        emit("torch_cuda_optimizer_probe_status", "unavailable")
        emit("torch_cuda_optimizer_probe_reason", "cuda_unavailable")
        return 0

    emit_bool("torch_cuda_optimizer_probe_cuda_available", true)

    val parameter_handle = rt_torch_tensor_from_data([2.0], [1])
    val parameter = Tensor.from_handle(parameter_handle)
    emit_i64("torch_cuda_optimizer_probe_parameter_handle", parameter_handle)
    if parameter_handle == 0:
        emit("torch_cuda_optimizer_probe_blocked_gate", "tensor_creation")
        emit("torch_cuda_optimizer_probe_status", "fail")
        emit("torch_cuda_optimizer_probe_reason", "tensor_creation_returned_null_handle")
        return 1

    val parameter_cuda_handle = rt_torch_torchtensor_cuda(parameter_handle, 0)
    val parameter_cuda = Tensor.from_handle(parameter_cuda_handle)
    rt_torch_autograd_set_requires_grad(parameter_cuda_handle, true)
    val parameter_is_cuda = rt_torch_torchtensor_is_cuda(parameter_cuda_handle)
    emit_bool("torch_cuda_optimizer_probe_parameter_is_cuda", parameter_is_cuda)

    if not parameter_is_cuda:
        emit("torch_cuda_optimizer_probe_blocked_gate", "parameter_cuda")
        emit("torch_cuda_optimizer_probe_status", "fail")
        emit("torch_cuda_optimizer_probe_reason", "parameter_not_cuda")
        return 1

    val before = rt_torch_torchtensor_sum(parameter_cuda_handle)
    emit_f64("torch_cuda_optimizer_probe_before_sum", before)

    val loss = parameter_cuda.mul(parameter_cuda)
    loss.backward()

    val grad_handle = rt_torch_autograd_grad(parameter_cuda_handle)
    emit_i64("torch_cuda_optimizer_probe_grad_handle", grad_handle)
    if grad_handle == 0:
        emit("torch_cuda_optimizer_probe_blocked_gate", "autograd_gradient")
        emit("torch_cuda_optimizer_probe_status", "fail")
        emit("torch_cuda_optimizer_probe_reason", "missing_gradient")
        return 1

    val grad_sum = rt_torch_torchtensor_sum(grad_handle)
    emit_f64("torch_cuda_optimizer_probe_grad_sum", grad_sum)

    val optimizer = SGDOptimizer.create([parameter_cuda_handle], 1.0, 0.0)
    emit_bool("torch_cuda_optimizer_probe_optimizer_step_attempted", true)
    val updated_params = optimizer.step()

    val after = rt_torch_torchtensor_sum(updated_params[0])
    emit_f64("torch_cuda_optimizer_probe_after_sum", after)

    if after < before:
        emit("torch_cuda_optimizer_probe_status", "pass")
        emit("torch_cuda_optimizer_probe_reason", "optimizer_step_decreased_parameter_sum")
        return 0

    emit("torch_cuda_optimizer_probe_blocked_gate", "optimizer_step_decreases_parameter_sum")
    emit("torch_cuda_optimizer_probe_status", "fail")
    emit("torch_cuda_optimizer_probe_reason", "optimizer_step_did_not_decrease_parameter_sum")
    1
