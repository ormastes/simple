use compiler.frontend.core.parser.{parse_module}
use app.io.mod.{env_get}

extern fn rt_file_read_text(path: text) -> text

fn main() -> i64:
    # PARSE_LIST overrides the list file — lets the driver run the set in
    # chunks (fresh process per chunk) to stay under the memory cap; the
    # seed interpreter accumulates ~30MB/file across parse_module calls.
    var list_path = env_get("PARSE_LIST")
    if list_path == "" or list_path == nil:
        list_path = "parse_set.txt"
    val list_text = rt_file_read_text(list_path)
    val files = list_text.split("\n")
    for f in files:
        val path = f.trim()
        if path.len() == 0:
            continue
        print "FILE {path}"
        val src = rt_file_read_text(path)
        parse_module(src, path)
    print "PROBE_DONE"
    return 0
