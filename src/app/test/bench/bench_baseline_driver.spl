# bench_baseline_driver.spl — Runnable baseline benchmark driver.
#
# Measures REAL workloads entirely in-module (avoids cross-module BenchResult
# struct bug: interp_cross_module_struct_return_unit_2026-06-13).
# Timing uses rt_time_now_unix_micros() declared locally.
# Results are accumulated as primitive arrays and written via bench_emit_rows.
#
# Run:  bin/simple run src/app/test/bench/bench_baseline_driver.spl
#
# Writes:
#   doc/09_report/perf/perf_baseline_2026-06-13.md   — dated run report
#   doc/10_metrics/perf/perf_baseline_table.md        — persistent table

use app.test.bench.bench_report.{bench_emit_rows}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

# ============================================================================
# Workload functions — top-level (no closures to avoid capture limitations)
# ============================================================================

fn fib(n: i64) -> i64:
    if n <= 1:
        n
    else:
        fib(n - 1) + fib(n - 2)

fn fib_iter(n: i64) -> i64:
    # Iterative fib — much faster, used for ops/sec throughput measurement.
    if n <= 1:
        return n
    var a: i64 = 0
    var b: i64 = 1
    var i: i64 = 2
    while i <= n:
        val c = a + b
        a = b
        b = c
        i = i + 1
    b

fn sum_loop(n: i64) -> i64:
    # Simple integer accumulation loop — pure ALU throughput.
    var s: i64 = 0
    var i: i64 = 0
    while i < n:
        s = s + i
        i = i + 1
    s

fn string_concat_loop(n: i64) -> i64:
    # String allocation / concatenation — measures allocator + GC pressure.
    # Returns character count to prevent optimisation elision.
    var total: i64 = 0
    var i: i64 = 0
    while i < n:
        val s = "hello" + "_" + "world"
        total = total + s.len()
        i = i + 1
    total

# ============================================================================
# Inline timing helper — measures elapsed_us for N calls to a named workload.
# Returns elapsed_us as i64.  All in-module: no struct crosses boundary.
# ============================================================================

fn _time_fib30(iters: i64) -> i64:
    # Warmup
    val _w = fib(30)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = fib(30)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_fib_iter(n_fib: i64, iters: i64) -> i64:
    val _w = fib_iter(n_fib)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = fib_iter(n_fib)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_sum_loop(n: i64, iters: i64) -> i64:
    val _w = sum_loop(n)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = sum_loop(n)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_string_concat(n: i64, iters: i64) -> i64:
    val _w = string_concat_loop(n)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = string_concat_loop(n)
        i = i + 1
    rt_time_now_unix_micros() - t0

# ============================================================================
# Integer-to-text helper (no import to avoid cycle)
# ============================================================================

fn _i64_to_text_local(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var v = n
    val negative = v < 0
    if negative:
        v = 0 - v
    while v > 0:
        val d = v % 10
        val ch: text = if d == 0: "0"
            elif d == 1: "1"
            elif d == 2: "2"
            elif d == 3: "3"
            elif d == 4: "4"
            elif d == 5: "5"
            elif d == 6: "6"
            elif d == 7: "7"
            elif d == 8: "8"
            else: "9"
        digits.push(ch)
        v = v / 10
    var result = if negative: "-" else: ""
    var di: i64 = digits.len() - 1
    while di >= 0:
        result = result + digits[di]
        di = di - 1
    result

# ============================================================================
# main
# ============================================================================

fn main():
    val date_str = "2026-06-13"
    val arch = "x86_64"
    val mode = "script"  # interpreter mode (bin/simple run)

    val report_path = "doc/09_report/perf/perf_baseline_2026-06-13.md"
    val table_path  = "doc/10_metrics/perf/perf_baseline_table.md"

    # --- Benchmark 1: fib(30) recursive --- small iters, expensive
    val fib30_iters: i64 = 5
    print("Running fib(30) x" + _i64_to_text_local(fib30_iters) + " ...")
    val fib30_us = _time_fib30(fib30_iters)
    val fib30_ns_per_op: i64 = if fib30_us > 0 and fib30_iters > 0:
        (fib30_us * 1000) / fib30_iters
    else:
        0
    print("  fib30 elapsed_us=" + _i64_to_text_local(fib30_us) + "  ns/op=" + _i64_to_text_local(fib30_ns_per_op))

    # --- Benchmark 2: fib_iter(35) iterative --- many iters
    val fib_iter_iters: i64 = 10000
    print("Running fib_iter(35) x" + _i64_to_text_local(fib_iter_iters) + " ...")
    val fib_iter_us = _time_fib_iter(35, fib_iter_iters)
    val fib_iter_ns: i64 = if fib_iter_us > 0 and fib_iter_iters > 0:
        (fib_iter_us * 1000) / fib_iter_iters
    else:
        0
    val fib_iter_ops: i64 = if fib_iter_us > 0:
        (fib_iter_iters * 1000000) / fib_iter_us
    else:
        0
    print("  fib_iter elapsed_us=" + _i64_to_text_local(fib_iter_us) + "  ops/sec=" + _i64_to_text_local(fib_iter_ops))

    # --- Benchmark 3: sum_loop(10000) --- integer ALU
    val sum_iters: i64 = 1000
    print("Running sum_loop(10000) x" + _i64_to_text_local(sum_iters) + " ...")
    val sum_us = _time_sum_loop(10000, sum_iters)
    val sum_ns: i64 = if sum_us > 0 and sum_iters > 0:
        (sum_us * 1000) / sum_iters
    else:
        0
    val sum_ops: i64 = if sum_us > 0:
        (sum_iters * 1000000) / sum_us
    else:
        0
    print("  sum_loop elapsed_us=" + _i64_to_text_local(sum_us) + "  ops/sec=" + _i64_to_text_local(sum_ops))

    # --- Benchmark 4: string_concat_loop(100) --- allocator pressure
    val str_iters: i64 = 500
    print("Running string_concat_loop(100) x" + _i64_to_text_local(str_iters) + " ...")
    val str_us = _time_string_concat(100, str_iters)
    val str_ns: i64 = if str_us > 0 and str_iters > 0:
        (str_us * 1000) / str_iters
    else:
        0
    val str_ops: i64 = if str_us > 0:
        (str_iters * 1000000) / str_us
    else:
        0
    print("  string_concat elapsed_us=" + _i64_to_text_local(str_us) + "  ops/sec=" + _i64_to_text_local(str_ops))

    # --- Accumulate primitive arrays ---
    # Each workload contributes one ns/op row and one ops/sec row where applicable.
    var names:   [text] = []
    var modes:   [text] = []
    var metrics: [text] = []
    var values:  [i64]  = []
    var units:   [text] = []

    # fib30 — ns/op only (too slow for ops/sec to be meaningful at 5 iters)
    names.push("fib_recursive(30)")
    modes.push(mode)
    metrics.push("ns/op")
    values.push(fib30_ns_per_op)
    units.push("ns/op")

    # fib_iter — ops/sec + ns/op
    names.push("fib_iterative(35)")
    modes.push(mode)
    metrics.push("ops/sec")
    values.push(fib_iter_ops)
    units.push("ops/sec")

    names.push("fib_iterative(35)")
    modes.push(mode)
    metrics.push("ns/op")
    values.push(fib_iter_ns)
    units.push("ns/op")

    # sum_loop — ops/sec + ns/op
    names.push("sum_loop(10000)")
    modes.push(mode)
    metrics.push("ops/sec")
    values.push(sum_ops)
    units.push("ops/sec")

    names.push("sum_loop(10000)")
    modes.push(mode)
    metrics.push("ns/op")
    values.push(sum_ns)
    units.push("ns/op")

    # string_concat — ops/sec + ns/op
    names.push("string_concat_loop(100)")
    modes.push(mode)
    metrics.push("ops/sec")
    values.push(str_ops)
    units.push("ops/sec")

    names.push("string_concat_loop(100)")
    modes.push(mode)
    metrics.push("ns/op")
    values.push(str_ns)
    units.push("ns/op")

    print("Writing benchmark docs ...")
    val ok = bench_emit_rows(names, modes, metrics, values, units, arch, date_str, report_path, table_path)
    if ok:
        print("Done. Both docs written.")
    else:
        print("ERROR: one or both docs failed to write.")
