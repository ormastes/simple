# Benchmark Harness — reusable timing and measurement primitives.
#
# Two measurement planes:
#   warm    — in-process closure timing via rt_time_now_unix_micros (works in
#             interpreter AND native; segfault risk is in SMF loader only, so
#             avoid calling bench_run_warm from SMF context).
#   process — cold-start wall-clock + peak RSS by launching a child process
#             via /usr/bin/time -v; mirrors the methodology of
#             scripts/check/check-cross-language-perf.shs.
#
# Usage:
#   use app.test.bench.bench_harness.{BenchCase, BenchResult, bench_run_warm,
#       bench_run_process, make_bench_case, make_bench_result}

use app.io.mod.{process_run}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_exists(path: text) -> bool

# ============================================================================
# BenchCase — descriptor for one benchmark configuration
# ============================================================================

struct BenchCase:
    # Human-readable name for this benchmark row.
    name: text
    # Architecture tags, e.g. ["x86_64"]. arm/riscv rows plug in later via tag.
    arch_tags: [text]
    # Execution mode: "script" | "smf" | "native"  (lang plane)
    #                 "ram"    | "persistent" | "wal" (db plane)
    mode: text
    # Measurement plane: "warm" (in-process) | "process" (cold/RSS/size)
    plane: text
    # Number of iterations for warm plane; ignored by process plane.
    iters: i64

fn make_bench_case(name: text, mode: text, plane: text, iters: i64) -> BenchCase:
    BenchCase(
        name: name,
        arch_tags: ["x86_64"],
        mode: mode,
        plane: plane,
        iters: iters,
    )

# ============================================================================
# BenchResult — one measured row
# ============================================================================

struct BenchResult:
    # Matches BenchCase.name
    name: text
    # Matches BenchCase.mode
    mode: text
    # Matches BenchCase.plane
    plane: text
    # e.g. "ops/sec" | "ns/op" | "wall_ms" | "rss_kb"
    metric_name: text
    # Measured value (integer; use fixed-point × 1000 for sub-ms precision)
    value: i64
    # Human unit string stored alongside value
    # NOTE: named `unit_label` not `unit` — a bare `unit` identifier collides with
    # the Unit keyword token in the seed parser (see bug
    # interp_unit_param_keyword_collision_2026-06-13.md).
    unit_label: text
    # Architecture string, e.g. "x86_64"
    arch: text

fn make_bench_result(name: text, mode: text, plane: text, metric: text, value: i64, unit_label: text) -> BenchResult:
    BenchResult(
        name: name,
        mode: mode,
        plane: plane,
        metric_name: metric,
        value: value,
        unit_label: unit_label,
        arch: "x86_64",
    )

# ============================================================================
# bench_run_warm — in-process closure timing
# ============================================================================

fn bench_run_warm(bc: BenchCase, body: fn() -> ()) -> BenchResult:
    # Warmup: run body once before timing to prime caches.
    body()
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < bc.iters:
        body()
        i = i + 1
    val elapsed_us = rt_time_now_unix_micros() - t0
    val iters = bc.iters
    # Avoid divide-by-zero if iters or elapsed is 0.
    val ns_per_op: i64 = if elapsed_us > 0 and iters > 0:
        (elapsed_us * 1000) / iters
    else:
        0
    val ops_per_sec: i64 = if elapsed_us > 0:
        (iters * 1000000) / elapsed_us
    else:
        0
    # Emit both ns/op and ops/sec as separate rows; return ops/sec as primary.
    make_bench_result(bc.name, bc.mode, bc.plane, "ops/sec", ops_per_sec, "ops/sec")

# ============================================================================
# bench_run_warm_ns — same but returns ns/op row
# ============================================================================

fn bench_run_warm_ns(bc: BenchCase, body: fn() -> ()) -> BenchResult:
    body()
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < bc.iters:
        body()
        i = i + 1
    val elapsed_us = rt_time_now_unix_micros() - t0
    val iters = bc.iters
    val ns_per_op: i64 = if elapsed_us > 0 and iters > 0:
        (elapsed_us * 1000) / iters
    else:
        0
    make_bench_result(bc.name, bc.mode, bc.plane, "ns/op", ns_per_op, "ns/op")

# ============================================================================
# bench_run_process — cold-start wall-clock + RSS via /usr/bin/time -v
#
# Delegates to the same /usr/bin/time -v pattern used by
# scripts/check/check-cross-language-perf.shs.
#
# argv[0] is the executable; argv[1..] are its arguments.
# Returns a wall_ms row.  RSS is extracted from stderr and emitted by
# bench_run_process_rss().
#
# TODO(process-rss): On systems where /usr/bin/time -v is unavailable,
# RSS measurement falls back to 0 with unit "rss_kb(unavailable)".
# A cross-platform implementation would use /proc/<pid>/status on Linux
# or `ps -o rss=` on macOS — record as bug if needed.
# ============================================================================

fn _time_bin() -> text:
    if rt_file_exists("/usr/bin/time"):
        "/usr/bin/time"
    else:
        ""

fn bench_run_process(bc: BenchCase, argv: [text]) -> BenchResult:
    val timecmd = _time_bin()
    if timecmd == "" or argv.len() == 0:
        return make_bench_result(bc.name, bc.mode, bc.plane, "wall_ms", 0, "wall_ms(unavailable)")
    # Build args: ["-v", executable, arg1, arg2, ...]
    var full_args: [text] = ["-v"]
    var ai: i64 = 0
    while ai < argv.len():
        full_args.push(argv[ai])
        ai = ai + 1
    val (out, err, code) = process_run(timecmd, full_args)
    # Parse "Elapsed (wall clock) time (h:mm:ss or m:ss): M:SS.ss" from stderr
    val wall_ms = _parse_wall_ms(err)
    make_bench_result(bc.name, bc.mode, bc.plane, "wall_ms", wall_ms, "ms")

fn bench_run_process_rss(bc: BenchCase, argv: [text]) -> BenchResult:
    val timecmd = _time_bin()
    if timecmd == "" or argv.len() == 0:
        return make_bench_result(bc.name, bc.mode, bc.plane, "rss_kb", 0, "rss_kb(unavailable)")
    var full_args: [text] = ["-v"]
    var ai: i64 = 0
    while ai < argv.len():
        full_args.push(argv[ai])
        ai = ai + 1
    val (out, err, code) = process_run(timecmd, full_args)
    val rss_kb = _parse_rss_kb(err)
    make_bench_result(bc.name, bc.mode, bc.plane, "rss_kb", rss_kb, "KB")

# ============================================================================
# Parsing helpers for /usr/bin/time -v output
# ============================================================================

fn _parse_wall_ms(time_stderr: text) -> i64:
    # Look for "Elapsed (wall clock) time (h:mm:ss or m:ss): " line.
    # Format is either M:SS.ss  or  H:MM:SS.ss
    val lines = time_stderr.split("\n")
    var i: i64 = 0
    while i < lines.len():
        val line = lines[i]
        if line.contains("Elapsed (wall clock)"):
            val colon_idx = _last_colon_idx(line)
            if colon_idx >= 0:
                val raw_str = line.slice(colon_idx + 1, line.len())
                val time_str = raw_str.trim()
                return _parse_time_str_to_ms(time_str)
        i = i + 1
    0

fn _parse_rss_kb(time_stderr: text) -> i64:
    val lines = time_stderr.split("\n")
    var i: i64 = 0
    while i < lines.len():
        val line = lines[i]
        if line.contains("Maximum resident set size"):
            val colon_idx = _last_colon_idx(line)
            if colon_idx >= 0:
                val raw_str = line.slice(colon_idx + 1, line.len())
                val num_str = raw_str.trim()
                return _parse_i64(num_str)
        i = i + 1
    0

fn _last_colon_idx(s: text) -> i64:
    var idx: i64 = -1
    var ci: i64 = 0
    while ci < s.len():
        if s.char_at(ci) == ":":
            idx = ci
        ci = ci + 1
    idx

fn _parse_time_str_to_ms(s: text) -> i64:
    # Handles "M:SS.ss" and "H:MM:SS.ss" formats. Returns whole milliseconds.
    val trimmed = s.trim()
    val parts = trimmed.split(":")
    val n = parts.len()
    if n == 2:
        # M:SS.ss
        val p0 = parts[0]
        val p0t = p0.trim()
        val minutes = _parse_i64(p0t)
        val p1 = parts[1]
        val sec_frac = p1.trim()
        val secs_ms = _parse_sec_frac_to_ms(sec_frac)
        (minutes * 60 * 1000) + secs_ms
    elif n == 3:
        # H:MM:SS.ss
        val p0 = parts[0]
        val p0t = p0.trim()
        val hours = _parse_i64(p0t)
        val p1 = parts[1]
        val p1t = p1.trim()
        val minutes = _parse_i64(p1t)
        val p2 = parts[2]
        val sec_frac = p2.trim()
        val secs_ms = _parse_sec_frac_to_ms(sec_frac)
        (hours * 3600 * 1000) + (minutes * 60 * 1000) + secs_ms
    else:
        0

fn _parse_sec_frac_to_ms(s: text) -> i64:
    # "SS.ss" -> whole milliseconds: SS*1000 + ss*10
    val dot_parts = s.split(".")
    if dot_parts.len() == 2:
        val dp0 = dot_parts[0]
        val dp0t = dp0.trim()
        val secs = _parse_i64(dp0t)
        val dp1 = dot_parts[1]
        val frac_str = dp1.trim()
        val frac: i64 = if frac_str.len() >= 2:
            val frac_sub = frac_str.slice(0, 2)
            _parse_i64(frac_sub) * 10
        else:
            0
        secs * 1000 + frac
    else:
        _parse_i64(s) * 1000

fn _char_digit(ch: text) -> i64:
    # Returns 0-9 for digit chars, -1 for non-digits.
    if ch == "0": 0
    elif ch == "1": 1
    elif ch == "2": 2
    elif ch == "3": 3
    elif ch == "4": 4
    elif ch == "5": 5
    elif ch == "6": 6
    elif ch == "7": 7
    elif ch == "8": 8
    elif ch == "9": 9
    else: -1

fn _parse_i64(s: text) -> i64:
    var result: i64 = 0
    var idx: i64 = 0
    while idx < s.len():
        val d = _char_digit(s.char_at(idx))
        if d >= 0:
            result = result * 10 + d
        idx = idx + 1
    result

export BenchCase, BenchResult
export make_bench_case, make_bench_result
export bench_run_warm, bench_run_warm_ns, bench_run_process, bench_run_process_rss
