# bench_smf_workload.spl — standalone benchmark workload, runnable in any mode.
#
# Self-times the SAME four workloads as bench_baseline_driver and prints one
# machine-parseable line per workload:
#     RESULT|<name>|<elapsed_us>|<iters>
# Timing is INTERNAL (rt_time_now_unix_micros around the workload loop), so it
# measures pure workload execution regardless of how the program was launched —
# making `bin/simple run <this>` (interpreter) and `bin/simple run <this>.smf`
# (compiled SMF) directly comparable. bench_baseline_driver compiles this to SMF,
# runs it, and parses these lines into mode="smf" rows.
#
# Run:  bin/simple run src/app/test/bench/bench_smf_workload.spl
#   or: bin/simple compile <this> -o w.smf && bin/simple run w.smf

extern fn rt_time_now_unix_micros() -> i64

fn fib(n: i64) -> i64:
    if n <= 1:
        n
    else:
        fib(n - 1) + fib(n - 2)

fn fib_iter(n: i64) -> i64:
    if n <= 1:
        return n
    var a: i64 = 0
    var b: i64 = 1
    var i: i64 = 2
    while i <= n:
        val c = a + b
        a = b
        b = c
        i = i + 1
    b

fn sum_loop(n: i64) -> i64:
    var s: i64 = 0
    var i: i64 = 0
    while i < n:
        s = s + i
        i = i + 1
    s

fn string_concat_loop(n: i64) -> i64:
    var total: i64 = 0
    var i: i64 = 0
    while i < n:
        val s = "hello" + "_" + "world"
        total = total + s.len()
        i = i + 1
    total

fn _time_fib30(iters: i64) -> i64:
    val _w = fib(30)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = fib(30)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_fib_iter(n_fib: i64, iters: i64) -> i64:
    val _w = fib_iter(n_fib)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = fib_iter(n_fib)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_sum_loop(n: i64, iters: i64) -> i64:
    val _w = sum_loop(n)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = sum_loop(n)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn _time_string_concat(n: i64, iters: i64) -> i64:
    val _w = string_concat_loop(n)
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    while i < iters:
        val _r = string_concat_loop(n)
        i = i + 1
    rt_time_now_unix_micros() - t0

fn main():
    val fib30 = _time_fib30(5)
    val fibiter = _time_fib_iter(35, 10000)
    val sumv = _time_sum_loop(10000, 1000)
    val strv = _time_string_concat(100, 500)
    print("RESULT|fib_recursive(30)|{fib30}|5")
    print("RESULT|fib_iterative(35)|{fibiter}|10000")
    print("RESULT|sum_loop(10000)|{sumv}|1000")
    print("RESULT|string_concat_loop(100)|{strv}|500")
