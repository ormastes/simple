"""Host-side Engine2D and ProcessingIR executor for SimpleOS QEMU ivshmem."""

use std.common.gpu.simpleos_host_gpu_protocol.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{
    Engine2dResolvedDrawIrImage,
    engine2d_draw_ir_adv_fresh_device_composition_with_images,
    engine2d_resolved_draw_ir_image
}
use std.common.gpu.simpleos_host_gpu_draw_ir.{
    SimpleOsHostGpuImageResource,
    SimpleOsHostGpuImageResourceEntry,
    simpleos_host_gpu_draw_ir_encode,
    simpleos_host_gpu_draw_ir_decode,
    simpleos_host_gpu_image_resource_coverage_reason,
    simpleos_host_gpu_image_resources_decode,
    simpleos_host_gpu_image_resources_decode_retained,
    simpleos_host_gpu_resolve_retained_images
}
use std.common.processing.processing_ir.{processing_ir_fill_u32, processing_ir_validate, processing_ir_cpu_execute, processing_ir_outputs_equal}
use std.gc_async_mut.processing.vulkan_fill_u32.{processing_ir_execute_vulkan, processing_vulkan_device_identity}
use std.gc_async_mut.processing.cuda_fill_u32.{processing_ir_execute_cuda}
use std.gc_async_mut.processing.metal_fill_u32.{processing_ir_execute_metal, processing_metal_device_identity}
use std.gc_async_mut.gpu.engine2d.sffi_vulkan.{vulkan_sffi_selected_device_driver_identity}
use std.nogc_sync_mut.io.metal_sffi.{metal_device_info}
use std.nogc_sync_mut.gpu.engine2d.sffi_directx.{directx_hardware_adapter_identity}
use app.io.file_ops.{file_exists, file_size, file_mmap, file_munmap}
use app.io.volatile_ops.{volatile_read_u64_required, volatile_write_u64_required, memory_barrier_required}
use app.io.time_ops.{time_now_nanos}
use app.io.args_ops.{get_args}
use app.io.thread.{thread_sleep_ms}

# Per-connection loop state: the request-processed flag `main()` already
# used to decide whether to sleep, plus the retained image-resource table
# (revision-keyed, session-scoped). The table is cleared to [] on every
# HELLO the daemon processes (success or failure) so ids never leak across
# a guest reboot on a reused backing file, and left untouched on the plain
# (non-retention, non-hello) path so that path's behavior is unaffected.
struct SimpleOsGpuHostLoopState:
    processed: i64
    retained: [SimpleOsHostGpuImageResource]

fn _loop_state(processed: i64, retained: [SimpleOsHostGpuImageResource]) -> SimpleOsGpuHostLoopState:
    SimpleOsGpuHostLoopState(processed: processed, retained: retained)

# ponytail: retention scope stops at image resources for this slice. Scene/
# DrawScene retention (CREATE_DRAW_SCENE/APPLY_DRAW_PATCH from the adopted
# host-GPU persistent protocol model) and retained-table eviction/bounding
# for very long sessions with many distinct never-repeating image ids are
# later phases — see doc/03_plan/ui/unified_2d_engine/web_wm_gpu_3d_review_2026-07-20.md
# item 8 and the "Rendering optimization ladder" section.

@cfg(linux)
fn _create_render_backend(width: i32, height: i32, backend: text) -> Result<Engine2D, text>:
    if backend != "vulkan":
        return Err("linux-host-daemon-requires-vulkan")
    Engine2D.create_vulkan_backend(width, height)

@cfg(not(linux))
fn _create_render_backend(width: i32, height: i32, backend: text) -> Result<Engine2D, text>:
    Engine2D.create_requested_backend(width, height, backend)

fn _read(base: i64, offset: i64) -> i64:
    volatile_read_u64_required(base + offset)

fn _write(base: i64, offset: i64, value: i64):
    volatile_write_u64_required(base + offset, value)

fn _elapsed_us_since(started_nanos: i64) -> i64:
    val elapsed_nanos = time_now_nanos() - started_nanos
    if elapsed_nanos <= 0:
        return 0
    val whole_us = elapsed_nanos / 1000
    if elapsed_nanos % 1000 == 0:
        return whole_us
    whole_us + 1

fn _processing_preference(cpu_us: i64, device_us: i64) -> text:
    if cpu_us <= 0 or device_us <= 0:
        return "unmeasured"
    if cpu_us >= device_us and cpu_us - device_us >= device_us / 2 + device_us % 2:
        return "preferred"
    "available-not-preferred"

fn _finish(base: i64, generation: i64, status: i64, reason: i64, handle: i64, output_bytes: i64, checksum: i64, elapsed_us: i64, source: i64, identity: i64):
    if _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION) != generation:
        return
    _write(base, SIMPLEOS_HOST_GPU_WIRE_STATUS, status)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_REASON, reason)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NATIVE_HANDLE, handle)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_OUTPUT_BYTES, output_bytes)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_OUTPUT_CHECKSUM, checksum)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_ELAPSED_US, elapsed_us)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_READBACK_SOURCE, source)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_DEVICE_IDENTITY, identity)
    memory_barrier_required()
    _write(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION, generation)

fn _payload_words(base: i64, payload_bytes: i64) -> [i64]:
    var words: [i64] = []
    var offset: i64 = 0
    while offset < payload_bytes:
        words.push(_read(base, simpleos_host_gpu_wire_payload_offset() + offset))
        offset = offset + 8
    words

fn _wire_bytes(base: i64, wire_offset: i64, byte_count: i64) -> [u8]:
    var bytes: [u8] = []
    var offset: i64 = 0
    while offset < byte_count:
        val packed = _read(base, wire_offset + (offset / 8) * 8).to_u64()
        bytes.push(((packed >> ((offset % 8).to_u32() * 8u32)) & 0xFFu64).to_u8())
        offset = offset + 1
    bytes

fn _payload_bytes(base: i64, payload_bytes: i64) -> [u8]:
    _wire_bytes(base, simpleos_host_gpu_wire_payload_offset(), payload_bytes)

fn _request_generation_matches(base: i64, generation: i64) -> bool:
    _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION) == generation

fn _write_pixels(base: i64, pixels: [u32], count: i64) -> i64:
    var checksum: i64 = 0
    var i: i64 = 0
    while i < count:
        val low = pixels[i].to_u64()
        var high: u64 = 0u64
        if i + 1 < count:
            high = pixels[i + 1].to_u64()
        _write(base, simpleos_host_gpu_wire_readback_offset() + i * 4, (low | (high << 32u32)).to_i64())
        checksum = simpleos_host_gpu_readback_checksum_step(checksum, low.to_u32())
        if i + 1 < count:
            checksum = simpleos_host_gpu_readback_checksum_step(checksum, high.to_u32())
        i = i + 2
    simpleos_host_gpu_readback_checksum_finalize(checksum)

fn _render_device_identity(backend: text) -> i64:
    if backend == "vulkan":
        return processing_vulkan_device_identity(vulkan_sffi_selected_device_driver_identity())
    if backend == "metal":
        val info = metal_device_info(0)
        if info.name == "" or info.total_memory <= 0:
            return 0
        return processing_metal_device_identity(info.name, info.total_memory)
    if backend == "directx":
        return directx_hardware_adapter_identity()
    0

fn _render_backend_available(code: i64) -> bool:
    val name = simpleos_host_gpu_backend_name(code)
    match _create_render_backend(1, 1, name):
        Err(reason):
            print("HOST_GPU_DAEMON_RENDER_UNAVAILABLE backend={name} reason={reason}\n")
            false
        Ok(engine):
            val available = engine.backend_name() == name and _render_device_identity(name) > 0
            engine.shutdown()
            available

@cfg(linux)
fn _processing_backend_mask(requested: i64, selector: text) -> i64:
    val selected = if selector == "vulkan": requested & SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN else: requested & (SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN | SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA)
    _processing_backend_mask_supported(selected)

@cfg(not(linux))
fn _processing_backend_mask(requested: i64, selector: text) -> i64:
    val selected = if selector == "vulkan": requested & SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN else: requested
    _processing_backend_mask_supported(selected)

fn _processing_backend_mask_supported(selected: i64) -> i64:
    var available: i64 = 0
    if (selected & SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN) != 0:
        val probe_ir = processing_ir_fill_u32(1, 1u32)
        val probe = processing_ir_execute_vulkan(probe_ir)
        if probe.completed and probe.backend_handle > 0 and probe.device_identity > 0 and processing_ir_outputs_equal(probe.values, processing_ir_cpu_execute(probe_ir)):
            available = available | SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN
    if (selected & SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA) != 0:
        val probe_ir = processing_ir_fill_u32(1, 1u32)
        val probe = processing_ir_execute_cuda(probe_ir)
        if probe.completed and probe.backend_handle > 0 and probe.device_identity > 0 and processing_ir_outputs_equal(probe.values, processing_ir_cpu_execute(probe_ir)):
            available = available | SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA
    if (selected & SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL) != 0:
        val probe_ir = processing_ir_fill_u32(1, 1u32)
        val probe = processing_ir_execute_metal(probe_ir)
        if probe.completed and probe.backend_handle > 0 and probe.device_identity > 0 and processing_ir_outputs_equal(probe.values, processing_ir_cpu_execute(probe_ir)):
            available = available | SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL
    available

fn _process_hello(base: i64, generation: i64, version: i64, guest_isa_code: i64, render_mask: i64, processing_mask: i64, render_code: i64, processing_selector: text, requested_capability_mask: i64) -> i64:
    val started = time_now_nanos()
    val negotiated_processing_mask = _processing_backend_mask(processing_mask, processing_selector)
    val hello = SimpleOsHostGpuHello(
        version: version,
        guest_isa: simpleos_host_gpu_guest_isa_name(guest_isa_code),
        region_bytes: SIMPLEOS_HOST_GPU_REGION_BYTES,
        max_payload_bytes: SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES,
        max_readback_bytes: simpleos_host_gpu_max_readback_bytes(),
        render_backend: simpleos_host_gpu_backend_name(render_code),
        processing_backend: if (negotiated_processing_mask & SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA) != 0: "cuda" elif (negotiated_processing_mask & SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL) != 0: "metal" elif negotiated_processing_mask == 0: "cpu" else: "vulkan"
    )
    val valid = simpleos_host_gpu_validate_hello(hello)
    val negotiated_render_mask = render_mask & simpleos_host_gpu_backend_mask(render_code)
    if valid.status != "pass":
        print("HOST_GPU_DAEMON_HELLO_INVALID reason={valid.reason} readback={hello.max_readback_bytes} max={simpleos_host_gpu_max_readback_bytes()}\n")
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO, 0, 0, 0, _elapsed_us_since(started), 0, 0)
        return 1
    if negotiated_render_mask == 0 or not _render_backend_available(render_code):
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO, 0, 0, 0, _elapsed_us_since(started), 0, 0)
        return 1
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_RENDER_MASK, negotiated_render_mask)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK, negotiated_processing_mask)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_PAYLOAD, SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_READBACK, simpleos_host_gpu_max_readback_bytes())
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION, SIMPLEOS_HOST_GPU_PROTOCOL_VERSION)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_CAPABILITY_MASK, requested_capability_mask & SIMPLEOS_HOST_GPU_CAPABILITY_SUPPORTED_MASK)
    # HELLO proves availability only; device provenance belongs to render readback.
    _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_PASS, 0, 0, 0, 0, _elapsed_us_since(started), 0, 0)
    1

fn _process_request(base: i64, processing_selector: text, retained: [SimpleOsHostGpuImageResource]) -> SimpleOsGpuHostLoopState:
    val generation = _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION)
    val completion = _read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if not simpleos_host_gpu_generation_is_fresh(generation, completion):
        return _loop_state(0, retained)
    memory_barrier_required()
    val request_magic = _read(base, SIMPLEOS_HOST_GPU_WIRE_MAGIC)
    val request_version = _read(base, SIMPLEOS_HOST_GPU_WIRE_VERSION)
    val kind = _read(base, SIMPLEOS_HOST_GPU_WIRE_KIND)
    val backend_code = _read(base, SIMPLEOS_HOST_GPU_WIRE_BACKEND)
    val width = _read(base, SIMPLEOS_HOST_GPU_WIRE_WIDTH)
    val height = _read(base, SIMPLEOS_HOST_GPU_WIRE_HEIGHT)
    val element_count = _read(base, SIMPLEOS_HOST_GPU_WIRE_ELEMENT_COUNT)
    val payload_bytes = _read(base, SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_BYTES)
    val expected_checksum = _read(base, SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_CHECKSUM)
    val frame_id = _read(base, SIMPLEOS_HOST_GPU_WIRE_FRAME_ID)
    val run_id_hash = _read(base, SIMPLEOS_HOST_GPU_WIRE_RUN_ID_HASH)
    val guest_isa_code = _read(base, SIMPLEOS_HOST_GPU_WIRE_GUEST_ISA)
    val requested_render_mask = _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_RENDER_MASK)
    val requested_processing_mask = _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_PROCESSING_MASK)
    val image_resource_count = _read(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_COUNT)
    val image_resource_bytes = _read(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_BYTES)
    val image_resource_checksum = _read(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM)
    # Read-then-clear: the requested capability slot is single-use. This
    # keeps a guest build that predates capability negotiation (and so
    # never writes this field) from ever handing us a byte a DIFFERENT,
    # newer guest left behind in an earlier session on a reused backing
    # file — see the staleness note on the wire offsets in the protocol.
    val requested_capability_mask = _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_CAPABILITY_MASK)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_CAPABILITY_MASK, 0)
    # Snapshot correlation fields under the same acquire fence as the request.
    # Completion publishes this snapshot rather than rereading mutable request memory.
    _write(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_RUN_ID_HASH, run_id_hash)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_FRAME_ID, frame_id)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_BACKEND, backend_code)
    if request_magic != SIMPLEOS_HOST_GPU_PROTOCOL_MAGIC or request_version != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)
    if kind != SIMPLEOS_HOST_GPU_KIND_DRAW_IR and (image_resource_count != 0 or image_resource_bytes != 0 or image_resource_checksum != 0):
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)

    if kind == SIMPLEOS_HOST_GPU_KIND_HELLO:
        if _read(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION) != generation:
            return _loop_state(0, retained)
        # Any hello processed (accepted or not) starts a fresh retention
        # session: bound stale ids to a single guest session, never let
        # them leak across a reboot on a reused backing file.
        return _loop_state(_process_hello(base, generation, request_version, guest_isa_code, requested_render_mask, requested_processing_mask, backend_code, processing_selector, requested_capability_mask), [])
    if not simpleos_host_gpu_wire_correlation_valid(run_id_hash, frame_id):
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)
    if _read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION) != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_HELLO_REQUIRED, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)
    val backend = simpleos_host_gpu_backend_name(backend_code)
    val kind_name = if kind == SIMPLEOS_HOST_GPU_KIND_RENDER: "render" elif kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR: "draw_ir" elif kind == SIMPLEOS_HOST_GPU_KIND_PROCESSING: "processing" else: "unsupported"
    val batch = SimpleOsHostGpuBatch(version: SIMPLEOS_HOST_GPU_PROTOCOL_VERSION, generation: generation, run_id: run_id_hash.to_text(), frame_id: frame_id, kind: kind_name, backend: backend, width: width, height: height, element_count: element_count, payload_bytes: payload_bytes, payload_checksum: expected_checksum)
    val valid = simpleos_host_gpu_validate_batch(batch)
    if valid.status != "pass" or (kind != SIMPLEOS_HOST_GPU_KIND_DRAW_IR and payload_bytes % 8 != 0):
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)
    var words: [i64] = []
    var draw_ir_bytes: [u8] = []
    var image_resource_wire_bytes: [u8] = []
    if kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR:
        val negotiated_max_readback = _read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_READBACK)
        val empty_resources = image_resource_count == 0 and image_resource_bytes == 0 and image_resource_checksum == 0
        val populated_resources = image_resource_count > 0 and image_resource_count <= SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS and image_resource_bytes > 0 and image_resource_bytes <= negotiated_max_readback and image_resource_bytes <= simpleos_host_gpu_max_readback_bytes() and image_resource_checksum > 0
        if not empty_resources and not populated_resources:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        draw_ir_bytes = _payload_bytes(base, payload_bytes)
        image_resource_wire_bytes = _wire_bytes(base, simpleos_host_gpu_wire_readback_offset(), image_resource_bytes)
    else:
        words = _payload_words(base, payload_bytes)
        if simpleos_host_gpu_wire_checksum_words(words) != expected_checksum:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_CHECKSUM_MISMATCH, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)

    if not _request_generation_matches(base, generation):
        return _loop_state(0, retained)
    val requested_backend_mask = simpleos_host_gpu_backend_mask(backend_code)
    val negotiated_mask = if kind == SIMPLEOS_HOST_GPU_KIND_RENDER or kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR:
        _read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_RENDER_MASK)
    elif kind == SIMPLEOS_HOST_GPU_KIND_PROCESSING:
        _read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK)
    else:
        0
    if (negotiated_mask & requested_backend_mask) == 0 or (kind == SIMPLEOS_HOST_GPU_KIND_RENDER and backend != "vulkan" and backend != "metal" and backend != "directx"):
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND, 0, 0, 0, 1, 0, 0)
        return _loop_state(1, retained)

    if kind == SIMPLEOS_HOST_GPU_KIND_PROCESSING:
        if words.len() != 6 or words[0] != SIMPLEOS_HOST_GPU_COMMAND_FILL_U32:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_COMMAND, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        val ir = processing_ir_fill_u32(element_count, words[5].to_u32())
        if not processing_ir_validate(ir).valid:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        val cpu_started = time_now_nanos()
        val oracle = processing_ir_cpu_execute(ir)
        val cpu_elapsed_us = _elapsed_us_since(cpu_started)
        val device_started = time_now_nanos()
        var completed = false
        var values: [u32] = []
        var backend_handle: i64 = 0
        var device_identity: i64 = 0
        if backend == "cuda":
            val result = processing_ir_execute_cuda(ir)
            completed = result.completed
            values = result.values
            backend_handle = result.backend_handle
            device_identity = result.device_identity
        elif backend == "vulkan":
            val result = processing_ir_execute_vulkan(ir)
            completed = result.completed
            values = result.values
            backend_handle = result.backend_handle
            device_identity = result.device_identity
        elif backend == "metal":
            val result = processing_ir_execute_metal(ir)
            completed = result.completed
            values = result.values
            backend_handle = result.backend_handle
            device_identity = result.device_identity
        val device_elapsed_us = _elapsed_us_since(device_started)
        if not completed or backend_handle <= 0 or device_identity <= 0:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_NON_DEVICE_READBACK, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        if not processing_ir_outputs_equal(values, oracle):
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_CHECKSUM_MISMATCH, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        if not _request_generation_matches(base, generation):
            return _loop_state(0, retained)
        val checksum = _write_pixels(base, values, element_count)
        val preference = _processing_preference(cpu_elapsed_us, device_elapsed_us)
        print("HOST_GPU_PROCESS_PERF isa={simpleos_host_gpu_guest_isa_name(guest_isa_code)} backend={backend} generation={generation} run={run_id_hash} frame={frame_id} cpu_us={cpu_elapsed_us} device_us={device_elapsed_us} preference={preference}\n")
        _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_PASS, 0, backend_handle, element_count * 4, checksum, device_elapsed_us, SIMPLEOS_HOST_GPU_READBACK_DEVICE, device_identity)
        return _loop_state(1, retained)

    if kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR:
        val decoded = simpleos_host_gpu_draw_ir_decode(draw_ir_bytes, SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES, SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
        if not decoded.ok:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        val canonical = simpleos_host_gpu_draw_ir_encode(decoded.composition, SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES, SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
        if not canonical.ok or canonical.checksum != expected_checksum or canonical.command_count != element_count:
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_CHECKSUM_MISMATCH, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        # Retention is honored only when THIS request's session negotiated
        # it (re-read from the wire, never cached) — a plain/legacy session
        # keeps using the untouched full-resource decode below, so its
        # wire behavior is unaffected byte-for-byte.
        val retention_negotiated = (_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_CAPABILITY_MASK) & SIMPLEOS_HOST_GPU_CAPABILITY_IMAGE_RESOURCE_RETENTION) != 0
        var resolved_resources: [SimpleOsHostGpuImageResource] = []
        var next_retained = retained
        if retention_negotiated:
            val decoded_entries = simpleos_host_gpu_image_resources_decode_retained(image_resource_wire_bytes, image_resource_count, image_resource_checksum, simpleos_host_gpu_max_readback_bytes(), SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
            if not decoded_entries.ok:
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            val resolution = simpleos_host_gpu_resolve_retained_images(decoded_entries.entries, retained)
            if not resolution.ok:
                # Unknown id or stale checksum: fail closed, never render
                # with a missing/mismatched resource. The guest reads this
                # as a non-PASS receipt and resubmits full next frame.
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_UNKNOWN_IMAGE_RESOURCE, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            if simpleos_host_gpu_image_resource_coverage_reason(decoded.composition, resolution.resolved) != "":
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            resolved_resources = resolution.resolved
            next_retained = resolution.retained
        else:
            val decoded_resources = simpleos_host_gpu_image_resources_decode(image_resource_wire_bytes, image_resource_count, image_resource_checksum, simpleos_host_gpu_max_readback_bytes(), SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
            if not decoded_resources.ok or simpleos_host_gpu_image_resource_coverage_reason(decoded.composition, decoded_resources.resources) != "":
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            resolved_resources = decoded_resources.resources
        var resolved_images: [Engine2dResolvedDrawIrImage] = []
        for image in resolved_resources:
            resolved_images.push(engine2d_resolved_draw_ir_image(image.image_uri, image.width, image.height, image.pixels))
        if not _request_generation_matches(base, generation):
            return _loop_state(0, retained)
        match _create_render_backend(width.to_i32(), height.to_i32(), backend):
            Err(_):
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            Ok(draw_engine):
                if draw_engine.backend_name() != backend:
                    draw_engine.shutdown()
                    _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_BACKEND_MISMATCH, 0, 0, 0, 1, 0, 0)
                    return _loop_state(1, retained)
                val started = time_now_nanos()
                val result = engine2d_draw_ir_adv_fresh_device_composition_with_images(draw_engine, decoded.composition, resolved_images)
                val output_count = width * height
                val device_identity = if backend == "directx": result.device_identity else: _render_device_identity(backend)
                val device_backed = result.selected_backend == "gpu" and not result.fallback_required and result.skipped_command_count == 0 and result.rendered_command_count.to_i64() == element_count and result.readback_source == "device_readback" and result.backend_handle > 0 and result.readback_checksum > 0 and device_identity > 0 and result.pixels.len().to_i64() >= output_count
                draw_engine.shutdown()
                if not device_backed:
                    _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_NON_DEVICE_READBACK, 0, 0, 0, 1, 0, 0)
                    return _loop_state(1, retained)
                if not _request_generation_matches(base, generation):
                    return _loop_state(0, retained)
                val checksum = _write_pixels(base, result.pixels, output_count)
                val elapsed = _elapsed_us_since(started)
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_PASS, 0, result.backend_handle, output_count * 4, checksum, elapsed, SIMPLEOS_HOST_GPU_READBACK_DEVICE, device_identity)
                return _loop_state(1, next_retained)

    match _create_render_backend(width.to_i32(), height.to_i32(), backend):
        Err(_):
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND, 0, 0, 0, 1, 0, 0)
            return _loop_state(1, retained)
        Ok(engine):
            if engine.backend_name() != backend:
                engine.shutdown()
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_BACKEND_MISMATCH, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            val started = time_now_nanos()
            var command_ok = true
            var pos: i64 = 0
            while pos + 5 < words.len() and command_ok:
                val op = words[pos]
                if op == SIMPLEOS_HOST_GPU_COMMAND_CLEAR:
                    engine.clear(words[pos + 5].to_u32())
                elif op == SIMPLEOS_HOST_GPU_COMMAND_FILL_RECT and kind == SIMPLEOS_HOST_GPU_KIND_RENDER:
                    engine.draw_rect_filled(words[pos + 1].to_i32(), words[pos + 2].to_i32(), words[pos + 3].to_i32(), words[pos + 4].to_i32(), words[pos + 5].to_u32())
                else:
                    command_ok = false
                pos = pos + 6
            if not command_ok or pos != words.len():
                engine.shutdown()
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_COMMAND, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)

            val readback = engine.read_pixels_with_source()
            val output_count = width * height
            val device_identity = if backend == "directx": readback.device_identity else: _render_device_identity(backend)
            if readback.source != "device_readback" or readback.backend_handle <= 0 or device_identity <= 0 or readback.pixels.len().to_i64() < output_count:
                engine.shutdown()
                _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_NON_DEVICE_READBACK, 0, 0, 0, 1, 0, 0)
                return _loop_state(1, retained)
            if not _request_generation_matches(base, generation):
                engine.shutdown()
                return _loop_state(0, retained)
            val checksum = _write_pixels(base, readback.pixels, output_count)
            val elapsed = _elapsed_us_since(started)
            engine.shutdown()
            _finish(base, generation, SIMPLEOS_HOST_GPU_STATUS_PASS, 0, readback.backend_handle, output_count * 4, checksum, elapsed, SIMPLEOS_HOST_GPU_READBACK_DEVICE, device_identity)
            return _loop_state(1, retained)

fn _arg_value(args: [text], prefix: text) -> text:
    for arg in args:
        if arg.starts_with(prefix):
            return arg[prefix.len():]
    ""

fn main() -> i64:
    val args = get_args()
    val path = _arg_value(args, "--shm=")
    val requested_processing_selector = _arg_value(args, "--processing-backend=")
    val processing_selector = if requested_processing_selector == "": "auto" else: requested_processing_selector
    val once = args.contains("--once")
    if processing_selector != "auto" and processing_selector != "vulkan":
        print("simpleos_gpu_host: --processing-backend must be auto or vulkan\n")
        return 2
    if path == "" or not file_exists(path) or file_size(path) < SIMPLEOS_HOST_GPU_REGION_BYTES:
        print("simpleos_gpu_host: --shm=<8MiB backing file> required\n")
        return 2
    val base = file_mmap(path, SIMPLEOS_HOST_GPU_REGION_BYTES, 0, false)
    if base <= 0:
        print("simpleos_gpu_host: mmap failed\n")
        return 3
    print("HOST_GPU_DAEMON_SELECTOR processing_backend={processing_selector}\n")
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION, 0)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_CAPABILITY_MASK, 0)
    _write(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_CAPABILITY_MASK, 0)
    if once:
        val state = _process_request(base, processing_selector, [])
        file_munmap(base, SIMPLEOS_HOST_GPU_REGION_BYTES)
        return if state.processed > 0: 0 else: 4
    var retained: [SimpleOsHostGpuImageResource] = []
    while true:
        val state = _process_request(base, processing_selector, retained)
        retained = state.retained
        if state.processed == 0:
            thread_sleep_ms(1)
    0
