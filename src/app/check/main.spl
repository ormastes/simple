# Simple CLI - check command
# Uses new type inference system

use app.cli.check (run_check)
use app.io.cli_ops (cli_get_args)
use std.cli.log_modes.{parse_log_options}
use std.log.{error}

fn get_cli_args() -> [text]:
    val raw_args = cli_get_args()
    var all_args: [text] = []
    if raw_args != nil:
        all_args = raw_args
    var args = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("main.spl"):
            start_idx = scan_idx + 1
        scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("check", log_opts.error)
        return 1
    run_check(args)
