# Check target expansion shared by the public entry and isolated worker.

use app.io.source_discovery.{discover_spl_files}

extern fn rt_dir_exists(path: text) -> bool
extern fn rt_path_absolute(path: text) -> text

fn expand_check_targets(targets: [text]) -> ([text], [text]):
    var files: [text] = []
    var empty_directories: [text] = []
    var seen_targets: [text] = []
    var seen_files: [text] = []
    for target in targets:
        val target_identity = rt_path_absolute(target).replace("\\", "/")
        if seen_targets.contains(target_identity):
            continue
        seen_targets.push(target_identity)
        if not rt_dir_exists(target):
            if not seen_files.contains(target_identity):
                files.push(target)
                seen_files.push(target_identity)
            continue
        val discovered = discover_spl_files(target)
        if discovered.len() == 0:
            empty_directories.push(target)
            continue
        for file in discovered:
            val file_identity = rt_path_absolute(file).replace("\\", "/")
            if not seen_files.contains(file_identity):
                files.push(file)
                seen_files.push(file_identity)
    (files, empty_directories)
