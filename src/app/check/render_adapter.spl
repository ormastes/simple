# Check Render Adapter
#
# Bridges quality check results (lint + format + test + policy) to the
# shared ui.render contract.  Produces text (pass/fail summary) and
# html (quality gate dashboard with metric cards and progress bars).

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_metric_card, html_badge, html_progress_bar,
    html_section, html_grid, html_escape,
    css_reset, css_dark_theme, css_light_theme}
use app.ui.render.fmt.{fmt_number}
use app.ui.render.ansi.{RESET, BOLD, DIM, RED, YELLOW, GREEN, colorize}
use app.build.quality.{CheckResult, QualityResult}

# =========================================================================
# Render Entry Point
# =========================================================================

fn render_check(config: RenderConfig, result: CheckResult) -> RenderResult:
    """Render quality check results via the shared render contract."""
    match config.format:
        "html":
            return render_check_html(result, config)
        "both":
            val text_out = render_check_text(result, config)
            val html_out = render_check_html(result, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_check_text(result, config)

# =========================================================================
# Text Rendering
# =========================================================================

fn render_check_text(result: CheckResult, config: RenderConfig) -> RenderResult:
    """Render check results as colored terminal text."""
    var lines: [text] = []

    lines.push("{BOLD}Quality Check Results{RESET}")
    lines.push("")

    # Lint status
    val lint_icon = if result.lint.success: "{GREEN}PASS{RESET}" else: "{RED}FAIL{RESET}"
    lines.push("  Lint:    {lint_icon}  {result.lint.summary()}")

    # Format status
    val fmt_icon = if result.format.success: "{GREEN}PASS{RESET}" else: "{RED}FAIL{RESET}"
    lines.push("  Format:  {fmt_icon}  {result.format.summary()}")

    # Tests status
    val test_icon = if result.test_passed: "{GREEN}PASS{RESET}" else: "{RED}FAIL{RESET}"
    val test_msg = if result.test_passed: "All tests passed" else: "Tests failed"
    lines.push("  Tests:   {test_icon}  {test_msg}")

    # Policy status
    val policy_icon = if result.policy_passed: "{GREEN}PASS{RESET}" else: "{RED}FAIL{RESET}"
    val policy_msg = if result.policy_passed: "MCP perf policy passed" else: "MCP perf policy failed"
    lines.push("  Policy:  {policy_icon}  {policy_msg}")

    lines.push("")

    # Overall
    val overall_icon = if result.overall_success: "{GREEN}PASS{RESET}" else: "{RED}FAIL{RESET}"
    lines.push("{BOLD}Overall: {overall_icon}{RESET}")

    var text_out = ""
    var first = true
    for line in lines:
        if not first:
            text_out = "{text_out}\n"
        text_out = "{text_out}{line}"
        first = false

    RenderResult.text(text_out)

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_check_html(result: CheckResult, config: RenderConfig) -> RenderResult:
    """Render check results as HTML quality gate dashboard."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val css = "{css_reset()}\n{theme_css}\n{check_css()}"

    var body = "<h1>Quality Gate Dashboard</h1>\n"

    # Overall status badge
    val overall_badge = if result.overall_success:
        html_badge("ALL CHECKS PASSED", "#3fb950")
    else:
        html_badge("CHECKS FAILED", "#f85149")
    body = "{body}<div style=\"margin-bottom:16px\">{overall_badge}</div>\n"

    # Count passed/total
    var passed = 0
    var total = 4
    if result.lint.success:
        passed = passed + 1
    if result.format.success:
        passed = passed + 1
    if result.test_passed:
        passed = passed + 1
    if result.policy_passed:
        passed = passed + 1

    # Progress bar
    val percent = (passed * 100) / total
    body = "{body}<div style=\"margin-bottom:16px\">{html_progress_bar(percent)}</div>\n"

    # Metric cards grid
    val lint_trend = "{result.lint.warnings} warnings, {result.lint.errors} errors"
    val lint_card = html_metric_card("Lint", check_status_label(result.lint.success), lint_trend)

    val fmt_trend = result.format.summary()
    val fmt_card = html_metric_card("Format", check_status_label(result.format.success), fmt_trend)

    val test_label = if result.test_passed: "PASS" else: "FAIL"
    val test_card = html_metric_card("Tests", test_label, "")

    val policy_label = if result.policy_passed: "PASS" else: "FAIL"
    val policy_card = html_metric_card("MCP Policy", policy_label, "")

    body = "{body}{html_grid(4, \"12px\", [lint_card, fmt_card, test_card, policy_card])}\n"

    # Detail section with badges
    var detail_items: [text] = []
    detail_items.push(check_badge("Lint", result.lint.success))
    detail_items.push(check_badge("Format", result.format.success))
    detail_items.push(check_badge("Tests", result.test_passed))
    detail_items.push(check_badge("MCP Policy", result.policy_passed))
    val detail_body = detail_items.join(" ")
    body = "{body}{html_section(\"Check Status\", detail_body)}\n"

    RenderResult.html(html_page("Quality Gate Dashboard", css, body))

fn check_status_label(success: bool) -> text:
    if success: "PASS" else: "FAIL"

fn check_badge(name: text, passed: bool) -> text:
    val color = if passed: "#3fb950" else: "#f85149"
    val label = if passed: "{name}: PASS" else: "{name}: FAIL"
    html_badge(label, color)

fn check_css() -> text:
    """Additional CSS for check dashboard."""
    var s = ""
    s = "{s}.card { background:var(--bg-card); border:1px solid var(--border); border-radius:8px; padding:16px; }\n"
    s = "{s}.card h3 { font-size:12px; color:var(--text-dim); margin-bottom:4px; text-transform:uppercase; }\n"
    s = "{s}.card .value { font-size:24px; font-weight:700; margin:4px 0; }\n"
    s = "{s}.card .sub { font-size:12px; color:var(--text-dim); }\n"
    s
