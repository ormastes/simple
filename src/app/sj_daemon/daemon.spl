"""
# sj daemon — top-level daemon capsule
"""

use std.io_runtime
use std.service.lifecycle
use std.service.daemon_base
use app.sj_daemon.request_handler

struct SjDaemon:
    base: DaemonBase
    handler: SjRequestHandler

fn sj_daemon_new(repo_path: text, max_hold_ms: i64) -> SjDaemon:
    val config = daemon_config_new("{repo_path}/.sj/daemon.pid", "{repo_path}/.sj/daemon.sock", max_hold_ms)
    SjDaemon(
        base: daemon_base_new(config),
        handler: sj_request_handler_new(repo_path, max_hold_ms)
    )

fn sj_daemon_start(daemon: SjDaemon) -> bool:
    daemon_base_start(daemon.base)

fn sj_daemon_stop(daemon: SjDaemon):
    daemon_base_stop(daemon.base)
