# Dependency Tracker - Extract and track import relationships
#
# Parses `use X.Y.Z` statements from .spl files to build a dependency graph.
# When a file changes, finds all files that depend on it (reverse deps).

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# A single dependency: file -> list of modules it imports
struct FileDeps:
    path: text
    imports: [text]

# The full dependency graph
struct DepGraph:
    deps: [FileDeps]

fn dep_graph_new() -> DepGraph:
    DepGraph(deps: [])

# Extract module names from `use` statements in a source file
# Handles: use foo.bar.baz, use foo.bar.{a, b}, use foo.bar (name)
fn extract_imports(path: text) -> [text]:
    if not rt_file_exists(path):
        return []

    val content = rt_file_read_text(path) ?? ""
    if content == "":
        return []

    var imports: [text] = []
    val lines = content.split("\n")

    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("use "):
            val rest = trimmed[4:]
            # Extract the module path (up to first space, brace, or paren)
            var module_path = ""
            var i = 0
            while i < rest.len():
                val ch = rest[i:i+1]
                if ch == "." or ch == "_" or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                    module_path = module_path + ch
                else:
                    i = rest.len()  # break
                i = i + 1
            if module_path != "":
                imports.push(module_path)

    imports

# Convert a module path like "std.io.file_ops" to a potential file path
# Returns the module prefix (e.g., "io.file_ops" from "std.io.file_ops")
fn module_to_prefix(module_path: text) -> text:
    # Strip std. or lib. prefix
    if module_path.starts_with("std."):
        return module_path[4:]
    elif module_path.starts_with("lib."):
        return module_path[4:]
    elif module_path.starts_with("app."):
        return module_path[4:]
    elif module_path.starts_with("compiler."):
        return module_path[9:]
    module_path

# Build dependency graph from a list of files
fn build_dep_graph(files: [text]) -> DepGraph:
    var deps: [FileDeps] = []
    for file in files:
        val imports = extract_imports(file)
        if imports.len() > 0:
            deps.push(FileDeps(path: file, imports: imports))
    DepGraph(deps: deps)

# Check if a file's module path matches a given import prefix
fn file_matches_import(file_path: text, import_path: text) -> bool:
    # Convert file path to module-like path
    # e.g., src/lib/nogc_sync_mut/io/file_ops.spl -> nogc_sync_mut.io.file_ops
    val normalized = file_path.replace("/", ".").replace("\\", ".")

    # Check the import prefix (stripped of std/lib/app/compiler)
    val prefix = module_to_prefix(import_path)

    # Check if the file path contains the module path segments
    normalized.contains(prefix.replace(".", "/")) or normalized.contains(prefix)

# Find all files that depend on the changed files (reverse dependency lookup)
fn find_dependents(graph: DepGraph, changed_files: [text]) -> [text]:
    var dependents: [text] = []

    for file_dep in graph.deps:
        var dominated = false
        for changed in changed_files:
            if file_dep.path == changed:
                dominated = true

            if not dominated:
                # Check if any of this file's imports match the changed file
                for imp in file_dep.imports:
                    if file_matches_import(changed, imp):
                        # This file depends on the changed file
                        var already_added = false
                        for d in dependents:
                            if d == file_dep.path:
                                already_added = true
                        if not already_added:
                            dependents.push(file_dep.path)

    dependents
