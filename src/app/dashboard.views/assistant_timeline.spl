#![allow(unnamed_duplicate_typed_args)]
# Assistant Dashboard Timeline Subview

use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.dashboard.views.assistant_common.{
    assistant_render_limit, assistant_short_text
}
use app.ui.render.table.{render_html_table_limited}
use app.ui.render.types.{RenderConfig}

fn assistant_timeline_text(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var out = "{BOLD}Recent Timeline{RESET}\n"
    if snapshot.timeline.len() == 0:
        out = "{out}  No timeline events available for the selected session.\n"
        return out

    val limit = assistant_render_limit(config, snapshot.timeline.len())
    var i = 0
    for event in snapshot.timeline:
        if i >= limit:
            break
        out = "{out}  - {assistant_short_text(event.timestamp, 12)} | {assistant_short_text(event.kind, 14)} | {assistant_short_text(event.severity, 10)} | {assistant_short_text(event.title, 30)} | {assistant_short_text(event.detail, 40)}\n"
        i = i + 1

    out

fn assistant_timeline_html(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    if snapshot.timeline.len() == 0:
        return "<div class=\"card\" style=\"margin-top:12px\"><div class=\"section-title\">Recent Timeline</div><div class=\"empty-state\">No timeline events available for the selected session.</div></div>"

    var rows: [[text]] = []
    val limit = assistant_render_limit(config, snapshot.timeline.len())
    var i = 0
    for event in snapshot.timeline:
        if i >= limit:
            break
        rows.push([
            assistant_short_text(event.timestamp, 12),
            assistant_short_text(event.kind, 16),
            assistant_short_text(event.severity, 10),
            assistant_short_text(event.title, 42),
            assistant_short_text(event.detail, 56)
        ])
        i = i + 1

    var h = "<div class=\"card\" style=\"margin-top:12px\">"
    h = "{h}<div class=\"section-title\">Recent Timeline <span class=\"count\">{snapshot.timeline.len()}</span></div>"
    h = "{h}{render_html_table_limited([\"Time\", \"Kind\", \"Severity\", \"Title\", \"Detail\"], rows, 24)}"
    h = "{h}</div>"
    h
