#![allow(unnamed_duplicate_typed_args)]
# Assistant Dashboard Views
#
# Thin composition layer for the KAIROS-like assistant surface. The actual
# section rendering lives in focused submodules so the dashboard can evolve
# status, sessions, timeline, and task-tree views independently.

use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.dashboard.views.assistant_common.{assistant_html_head}
use app.dashboard.views.assistant_status.{assistant_status_text, assistant_status_html}
use app.dashboard.views.assistant_sessions.{assistant_sessions_text, assistant_sessions_html}
use app.dashboard.views.assistant_timeline.{assistant_timeline_text, assistant_timeline_html}
use app.dashboard.views.assistant_tasks.{assistant_tasks_text, assistant_tasks_html}
use app.ui.render.types.{RenderConfig}

fn render_assistant_text(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var out = ""
    out = "{out}{assistant_status_text(snapshot, config)}\n\n"
    out = "{out}{assistant_sessions_text(snapshot, config)}\n\n"
    out = "{out}{assistant_timeline_text(snapshot, config)}\n\n"
    out = "{out}{assistant_tasks_text(snapshot, config)}\n"
    out

fn render_assistant_html(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var h = assistant_html_head("Assistant Dashboard")
    h = "{h}<body>\n<div class=\"container\">\n"
    h = "{h}{assistant_status_html(snapshot, config)}"
    h = "{h}{assistant_sessions_html(snapshot, config)}"
    h = "{h}{assistant_timeline_html(snapshot, config)}"
    h = "{h}{assistant_tasks_html(snapshot, config)}"
    h = "{h}</div>\n</body>\n</html>\n"
    h
