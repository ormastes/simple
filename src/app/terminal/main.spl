# Terminal CLI Subcommand
#
# Provides terminal management from the command line:
#   simple terminal connect <name>     - Connect to a terminal from config
#   simple terminal exec <name> <cmd>  - Execute command on terminal
#   simple terminal list               - List configured terminals
#   simple terminal disconnect <name>  - Disconnect active terminal
#
# Loads terminal configuration from config/t32/t32_terminal.sdn by default.
#
# Depends on:
#   - std.terminal.types (TerminalConfig, TerminalConnection, etc.)
#   - std.terminal.connection (terminal_connect, terminal_execute, etc.)
#   - std.terminal.credential.config_parser (parse_terminal_config, find_terminal_by_name)

use std.terminal.types.{TerminalConfig, TerminalConnection, TerminalExecResult, term_kind_name}
use std.terminal.connection.{terminal_connect, terminal_execute, terminal_close, terminal_is_connected}
use std.terminal.credential.config_parser.{parse_terminal_config, find_terminal_by_name}

extern fn rt_cli_get_args() -> [text]

# ============================================================================
# Constants
# ============================================================================

val DEFAULT_CONFIG_PATH: text = "config/t32/t32_terminal.sdn"

# ============================================================================
# Main Entry Point
# ============================================================================

fn main() -> i64:
    """Terminal CLI entry point.

    Parses command-line arguments and dispatches to the appropriate
    terminal subcommand handler.

    Returns:
        0 on success, 1 on error
    """
    val args = rt_cli_get_args()

    if args.len() < 2:
        print_terminal_usage()
        return 1

    # args[0] = "simple", args[1] = "terminal", args[2] = subcommand
    val subcmd = args[1]

    if subcmd == "connect":
        return cmd_connect(args)
    if subcmd == "exec":
        return cmd_exec(args)
    if subcmd == "list":
        return cmd_list(args)
    if subcmd == "disconnect":
        return cmd_disconnect(args)

    print "error: unknown terminal subcommand '{subcmd}'"
    print_terminal_usage()
    1

# ============================================================================
# Subcommand: connect
# ============================================================================

fn cmd_connect(args: [text]) -> i64:
    """Connect to a terminal by name.

    Usage: simple terminal connect <name>

    Loads the terminal config from SDN, looks up the named entry,
    and attempts a connection. Prints connection status.

    Args:
        args: CLI argument list

    Returns:
        0 on success, 1 on failure
    """
    if args.len() < 3:
        print "usage: simple terminal connect <name>"
        return 1

    val name = args[2]
    val configs = parse_terminal_config(DEFAULT_CONFIG_PATH)
    val found = find_terminal_by_name(configs, name)

    if not found.?:
        print "error: terminal '{name}' not found in {DEFAULT_CONFIG_PATH}"
        return 1

    val config = found
    print "Connecting to '{name}' ({term_kind_name(config.kind)})..."
    val conn = terminal_connect(config)

    if conn.connected:
        print "Connected successfully (id={conn.id})"
        return 0

    print "error: failed to connect to '{name}'"
    1

# ============================================================================
# Subcommand: exec
# ============================================================================

fn cmd_exec(args: [text]) -> i64:
    """Execute a command on a terminal.

    Usage: simple terminal exec <name> <command...>

    Connects to the named terminal, executes the command, prints
    stdout/stderr, then disconnects.

    Args:
        args: CLI argument list

    Returns:
        The remote command's exit code, or 1 on connection failure
    """
    if args.len() < 4:
        print "usage: simple terminal exec <name> <command...>"
        return 1

    val name = args[2]

    # Join remaining args as the command
    var command = ""
    var i = 3
    while i < args.len():
        if command != "":
            command = "{command} {args[i]}"
        else:
            command = args[i]
        i = i + 1

    val configs = parse_terminal_config(DEFAULT_CONFIG_PATH)
    val found = find_terminal_by_name(configs, name)

    if not found.?:
        print "error: terminal '{name}' not found in {DEFAULT_CONFIG_PATH}"
        return 1

    val config = found
    print "Connecting to '{name}'..."
    val conn = terminal_connect(config)

    if not conn.connected:
        print "error: failed to connect to '{name}'"
        return 1

    print "Executing: {command}"
    val result = terminal_execute(conn, command)

    if result.stdout.len() > 0:
        print result.stdout

    if result.stderr.len() > 0:
        print "STDERR: {result.stderr}"

    print "Exit code: {result.exit_code} (duration: {result.duration_ms}ms)"

    terminal_close(conn)
    result.exit_code

# ============================================================================
# Subcommand: list
# ============================================================================

fn cmd_list(args: [text]) -> i64:
    """List all configured terminals.

    Usage: simple terminal list

    Parses the SDN config and prints each terminal entry with its
    kind, host, and port information.

    Args:
        args: CLI argument list (unused beyond validation)

    Returns:
        0 always
    """
    val configs = parse_terminal_config(DEFAULT_CONFIG_PATH)

    if configs.len() == 0:
        print "No terminals configured in {DEFAULT_CONFIG_PATH}"
        return 0

    print "Configured terminals ({configs.len()}):"
    print "---"

    var i = 0
    while i < configs.len():
        val config = configs[i]
        val kind = term_kind_name(config.kind)
        val host = format_terminal_host(config)
        print "  {config.name}  [{kind}]  {host}"
        i = i + 1

    0

# ============================================================================
# Subcommand: disconnect
# ============================================================================

fn cmd_disconnect(args: [text]) -> i64:
    """Disconnect an active terminal.

    Usage: simple terminal disconnect <name>

    Note: In the current implementation, connections are not persisted
    between CLI invocations. This command connects and immediately
    closes the terminal to verify connectivity.

    Args:
        args: CLI argument list

    Returns:
        0 on success, 1 on failure
    """
    if args.len() < 3:
        print "usage: simple terminal disconnect <name>"
        return 1

    val name = args[2]
    val configs = parse_terminal_config(DEFAULT_CONFIG_PATH)
    val found = find_terminal_by_name(configs, name)

    if not found.?:
        print "error: terminal '{name}' not found in {DEFAULT_CONFIG_PATH}"
        return 1

    val config = found
    print "Connecting to '{name}' for disconnect..."
    val conn = terminal_connect(config)

    if conn.connected:
        val closed = terminal_close(conn)
        if closed:
            print "Disconnected '{name}' successfully"
            return 0
        print "error: failed to close connection to '{name}'"
        return 1

    print "Terminal '{name}' was not connected"
    0

# ============================================================================
# Helpers
# ============================================================================

fn format_terminal_host(config: TerminalConfig) -> text:
    """Format the host information for display.

    Shows the relevant host/port for the terminal kind:
    - SSH/Telnet: host:port
    - T32 SWD: t32_host:t32_port (channel)
    - Relay: script_path

    Args:
        config: Terminal configuration

    Returns:
        Formatted host string
    """
    if config.kind == 0 or config.kind == 1:
        # SSH or Telnet
        return "{config.host}:{config.port}"
    if config.kind == 2:
        # T32 SWD
        return "{config.t32_host}:{config.t32_port} ({config.channel})"
    if config.kind == 3:
        # Relay
        return config.script_path
    "unknown"

fn print_terminal_usage():
    """Print terminal subcommand usage information."""
    print "Usage: simple terminal <subcommand> [args...]"
    print ""
    print "Subcommands:"
    print "  connect <name>           Connect to a configured terminal"
    print "  exec <name> <command>    Execute command on terminal"
    print "  list                     List configured terminals"
    print "  disconnect <name>        Disconnect active terminal"
    print ""
    print "Config: {DEFAULT_CONFIG_PATH}"
