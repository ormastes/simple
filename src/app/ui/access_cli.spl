# codex-impl
# Live `simple ui` access adapter. Shared grammar/rendering lives in common;
# this module owns only CLI-to-/api/test/ui/* translation and bounded I/O.

use common.text_advanced.{escape_json}
use common.ui.access.{
    AccessCommandDescriptor,
    AccessError,
    AccessRequest,
    AccessResult,
    AccessSafety,
    UiAccessNode,
    UiAccessProp,
    UiAccessSurface,
    UiAccessSnapshot,
    ACCESS_OPERATION_ACT,
    ACCESS_OPERATION_FIND,
    ACCESS_OPERATION_HISTORY,
    ACCESS_OPERATION_LIST,
    ACCESS_OPERATION_SNAPSHOT,
    ACCESS_OPERATION_SURFACE,
    ACCESS_OUTPUT_HUMAN,
    ACCESS_OUTPUT_JSON,
    access_error_to_json,
    access_find_descriptor,
    access_result_from_snapshot,
    access_render_human,
    access_render_json,
    access_validate_request,
    ui_access_events_to_json,
    ui_access_find_node,
    ui_access_find_nodes_filtered,
    ui_access_query_result,
    ui_access_query_to_json,
    ui_access_snapshot_to_json,
    ui_access_surface_to_json
}
use std.nogc_sync_mut.io.http_sffi.{
    HttpMethod,
    HttpResponse,
    http_client_destroy,
    http_client_new,
    http_client_request,
    http_client_set_timeout
}
use std.log.{error}
use std.nogc_sync_mut.io_runtime.{file_exists, getpid, time_now_unix_micros}
use nogc_sync_mut.ui.access_store.{UiAccessStore}
use std.database.sql.types.{DbError}
use std.common.json.parser.{json_parse}
use std.common.json.object_ops.{json_object_get, json_object_keys}
use std.common.json.array_ops.{json_array_get, json_array_length}
use std.common.json.types.{json_get_type, json_to_boolean, json_to_number, json_to_string}

val UI_ACCESS_SOURCE = "simple_ui"
val UI_ACCESS_DEFAULT_TIMEOUT_MS: i64 = 2000
val UI_ACCESS_MAX_TIMEOUT_MS: i64 = 30000
val UI_ACCESS_DEFAULT_LIMIT: i64 = 50
val UI_ACCESS_MAX_LIMIT: i64 = 1000
val UI_ACCESS_DEFAULT_HISTORY: i64 = 20
val UI_ACCESS_MAX_HISTORY: i64 = 64

fn ui_access_cli_descriptors() -> [AccessCommandDescriptor]:
    val read = AccessSafety.read(UI_ACCESS_DEFAULT_TIMEOUT_MS)
    [
        AccessCommandDescriptor.create("windows", "", "ui.windows", ACCESS_OPERATION_LIST, "simple ui windows [--json] [--port N]", "simple ui windows --json", 0, "List live UI surfaces", [], read),
        AccessCommandDescriptor.create("snapshot", "", "ui.snapshot", ACCESS_OPERATION_SNAPSHOT, "simple ui snapshot [--json] [--port N]", "simple ui snapshot --json", 0, "Capture the live semantic UI", [], read),
        AccessCommandDescriptor.create("surface", "", "ui.surface", ACCESS_OPERATION_SURFACE, "simple ui surface <id> [--json] [--port N]", "simple ui surface main --json", 1, "Inspect one live UI surface", [], read),
        AccessCommandDescriptor.create("find", "", "ui.find", ACCESS_OPERATION_FIND, "simple ui find [--surface ID] [--kind KIND] [--text TEXT] [--limit N]", "simple ui find --surface main --kind button --text build", 0, "Find live semantic nodes", [], read),
        AccessCommandDescriptor.create("act", "", "ui.act", ACCESS_OPERATION_ACT, "simple ui act --canonical ID --action ACTION --revision N [--timeout MS]", "simple ui act --canonical main#build --action click --revision 42", 0, "Run one advertised semantic action", [], AccessSafety.action(UI_ACCESS_DEFAULT_TIMEOUT_MS, false, false, false)),
        AccessCommandDescriptor.create("history", "", "ui.history", ACCESS_OPERATION_HISTORY, "simple ui history [--surface ID] [--count N]", "simple ui history --surface main --count 10", 0, "Read bounded access history", [], read)
    ]

fn ui_access_cli_parse_request(args: [text]) -> Result<AccessRequest, AccessError>:
    if args.len() == 0:
        return Err(AccessError.detailed("invalid_argument", "missing UI access command", "", "Use windows, snapshot, surface, find, act, or history", false, false))
    val descriptor = access_find_descriptor(args[0], "", ui_access_cli_descriptors())
    if descriptor == nil:
        return Err(AccessError.detailed("invalid_argument", "unknown UI access command '" + args[0] + "'", "", "Use windows, snapshot, surface, find, act, or history", false, false))
    val command_args = _ui_access_tail(args)
    val timeout_result = _ui_access_positive_option(command_args, "--timeout", descriptor.safety.timeout_ms, UI_ACCESS_MAX_TIMEOUT_MS)
    match timeout_result:
        Err(e): return Err(e)
        Ok(timeout_ms):
            val output_mode = if _ui_access_has_flag(command_args, "--json"): ACCESS_OUTPUT_JSON else: ACCESS_OUTPUT_HUMAN
            val request = AccessRequest.create(descriptor, output_mode, UI_ACCESS_SOURCE, "", "", command_args, timeout_ms, _ui_access_has_flag(command_args, "--confirm"))
            if val Err(e) = access_validate_request(request):
                return Err(e)
            if val Err(e) = _ui_access_validate_command(request):
                return Err(e)
            Ok(request)

fn ui_access_cli_route(request: AccessRequest) -> Result<text, AccessError>:
    val operation = request.descriptor.operation
    if operation == ACCESS_OPERATION_LIST or operation == ACCESS_OPERATION_SNAPSHOT:
        return Ok("/api/test/ui/snapshot")
    if operation == ACCESS_OPERATION_SURFACE:
        val surface_id = _ui_access_first_positional(request.args)
        return Ok("/api/test/ui/surface?id=" + _ui_url_encode(surface_id))
    if operation == ACCESS_OPERATION_FIND:
        return Ok(_ui_access_find_route(request.args))
    if operation == ACCESS_OPERATION_HISTORY:
        return Ok(_ui_access_history_route(request.args))
    if operation == ACCESS_OPERATION_ACT:
        return Ok("/api/test/ui/act")
    Err(AccessError.create("invalid_argument", "unsupported UI access operation"))

fn ui_access_cli_action_body(request: AccessRequest, request_id: text) -> text:
    val canonical_id = _ui_access_option(request.args, "--canonical")
    val surface_id = _ui_access_option(request.args, "--surface")
    val action = _ui_access_option(request.args, "--action")
    val expected_revision = _ui_access_option_number(request.args, "--revision", 0)
    var parts: [text] = [
        "\"surface_id\":\"{escape_json(surface_id)}\"",
        "\"canonical_id\":\"{escape_json(canonical_id)}\"",
        "\"action\":\"{escape_json(action)}\"",
        "\"request_id\":\"{escape_json(request_id)}\"",
        "\"expected_revision\":{expected_revision}"
    ]
    "{" + parts.join(",") + "}"

fn _ui_url_encode(value: text) -> text:
    var out = value.replace("%", "%25")
    out = out.replace(" ", "%20")
    out = out.replace("#", "%23")
    out = out.replace("?", "%3F")
    out = out.replace("&", "%26")
    out = out.replace("=", "%3D")
    out = out.replace("+", "%2B")
    out

fn ui_access_cli_db_error(operation: text, path: text) -> AccessError:
    val action_note = if operation == ACCESS_OPERATION_ACT: "Database access is read-only; act requires a live UI service" else: "Persisted UI access is unavailable"
    AccessError.detailed("source_unavailable", action_note, "", "Start the UI test API or inspect the existing store at --ui-access-db=" + path, false, false)

fn run_ui_access_cli(args: [text], port: i32, access_db_path: text) -> i64:
    val parsed = ui_access_cli_parse_request(args)
    match parsed:
        Err(e):
            return _ui_access_emit_error(_ui_access_output_mode(args), "", e, 2)
        Ok(request):
            if access_db_path != "":
                val db_result = _ui_access_execute_db(request, access_db_path)
                match db_result:
                    Err(e): return _ui_access_emit_error(request.output_mode, request.descriptor.operation, e, 1)
                    Ok(access_result):
                        if request.output_mode == ACCESS_OUTPUT_JSON:
                            print access_render_json(access_result)
                        else:
                            print access_render_human(access_result)
                        return 0
            val result = _ui_access_execute_live(request, port)
            match result:
                Err(e): return _ui_access_emit_error(request.output_mode, request.descriptor.operation, e, 1)
                Ok(access_result):
                    if request.output_mode == ACCESS_OUTPUT_JSON:
                        print access_render_json(access_result)
                    else:
                        print access_render_human(access_result)
                    0

fn _ui_access_execute_db(request: AccessRequest, path: text) -> Result<AccessResult, AccessError>:
    if request.descriptor.operation == ACCESS_OPERATION_ACT:
        return Err(ui_access_cli_db_error(request.descriptor.operation, path))
    if not file_exists(path):
        return Err(AccessError.create("source_unavailable", "UI access database does not exist: " + path))
    var store = match UiAccessStore.open_existing(path):
        Err(e): return Err(_ui_access_store_error(e))
        Ok(opened): opened
    val operation = request.descriptor.operation
    var result = if operation == ACCESS_OPERATION_HISTORY:
        val count = _ui_access_option_number(request.args, "--count", UI_ACCESS_DEFAULT_HISTORY)
        val surface_id = _ui_access_option(request.args, "--surface")
        match store.list_events(surface_id, count):
            Err(e):
                store.close()
                return Err(_ui_access_store_error(e))
            Ok(events):
                var history_result = _ui_access_read_result(operation, ui_access_events_to_json(events))?
                history_result.session_id = "persisted"
                history_result
    elif operation == ACCESS_OPERATION_FIND:
        val limit = _ui_access_option_number(request.args, "--limit", UI_ACCESS_DEFAULT_LIMIT)
        val canonical_id = _ui_access_option(request.args, "--canonical")
        val loaded = match store.read_snapshot(UI_ACCESS_MAX_LIMIT + 1):
            Err(e):
                store.close()
                return Err(_ui_access_store_error(e))
            Ok(snapshot): snapshot
        val candidates = if canonical_id != "":
            val node = ui_access_find_node(loaded, canonical_id)
            if node == nil: [] else: [node]
        else:
            ui_access_find_nodes_filtered(
                loaded,
                _ui_access_option(request.args, "--surface"),
                _ui_access_option(request.args, "--kind"),
                _ui_access_option(request.args, "--text"),
                _ui_access_has_flag(request.args, "--focused-only"),
                (limit + 1).to_i32()
            )
        _ui_access_db_find_result(candidates, request.args, limit)
    else:
        val limit = _ui_access_option_number(request.args, "--limit", UI_ACCESS_MAX_LIMIT)
        val loaded_snapshot = match store.read_snapshot(limit + 1):
            Err(e):
                store.close()
                return Err(_ui_access_store_error(e))
            Ok(value): value
        val snapshot_truncated = loaded_snapshot.nodes.len().to_i64() > limit
        val snapshot = _ui_access_limit_snapshot(loaded_snapshot, limit)
        if operation == ACCESS_OPERATION_LIST:
            access_result_from_snapshot(operation, UI_ACCESS_SOURCE, "persisted", snapshot, limit)
        elif operation == ACCESS_OPERATION_SURFACE:
            val surface_id = _ui_access_first_positional(request.args)
            var payload = ""
            for surface in snapshot.surfaces:
                if surface.surface_id == surface_id:
                    val surface_json = ui_access_surface_to_json(surface)
                    val candidates = ui_access_find_nodes_filtered(loaded_snapshot, surface_id, "", "", false, (limit + 1).to_i32())
                    val content_truncated = candidates.len().to_i64() > limit
                    val nodes = if content_truncated: candidates[0:limit.to_i32()] else: candidates
                    val content_base = ui_access_query_to_json(ui_access_query_result(nodes))
                    val content_json = content_base.slice(0, content_base.len() - 1) + ",\"truncated\":" + (if content_truncated: "true" else: "false") + "}"
                    payload = surface_json.slice(0, surface_json.len() - 1) + ",\"content\":" + content_json + ",\"snapshot_revision\":" + snapshot.snapshot_revision.to_text() + "}"
            if payload == "":
                store.close()
                return Err(AccessError.create("target_not_found", "surface '" + surface_id + "' was not found"))
            var surface_result = _ui_access_read_result(operation, payload)?
            surface_result.session_id = "persisted"
            surface_result
        else:
            var snapshot_result = _ui_access_read_result(operation, ui_access_snapshot_to_json(snapshot))?
            snapshot_result.session_id = "persisted"
            snapshot_result.truncated = snapshot_truncated
            snapshot_result
    match store.close():
        Err(e): return Err(_ui_access_store_error(e))
        Ok(_): ()
    Ok(result)

fn _ui_access_store_error(db_error: DbError) -> AccessError:
    AccessError.create("source_unavailable", db_error.message())

fn _ui_access_limit_snapshot(snapshot: UiAccessSnapshot, limit: i64) -> UiAccessSnapshot:
    if snapshot.nodes.len().to_i64() <= limit:
        return snapshot
    UiAccessSnapshot(
        protocol_version: snapshot.protocol_version,
        snapshot_revision: snapshot.snapshot_revision,
        mode: snapshot.mode,
        active_surface: snapshot.active_surface,
        surfaces: snapshot.surfaces,
        nodes: snapshot.nodes[0:limit.to_i32()],
        recent_events: snapshot.recent_events
    )

fn _ui_access_db_find_result(nodes: [UiAccessNode], args: [text], limit: i64) -> AccessResult:
    val canonical_id = _ui_access_option(args, "--canonical")
    val focused_only = _ui_access_has_flag(args, "--focused-only")
    var filtered: [UiAccessNode] = []
    var truncated = false
    for node in nodes:
        if (canonical_id == "" or node.canonical_id == canonical_id) and (not focused_only or node.focused):
            if filtered.len().to_i64() < limit:
                filtered = filtered.push(node)
            else:
                truncated = true
    var rows: [[text]] = [["CANONICAL ID", "KIND", "TEXT", "FOCUSED", "ENABLED", "ACTIONS"]]
    for node in filtered:
        rows = rows + [[node.canonical_id, node.kind, node.text_value, if node.focused: "true" else: "false", if node.enabled: "true" else: "false", node.action_names.join(",")]]
    var result = AccessResult.table("UI find", rows)
    result.set_context(ACCESS_OPERATION_FIND, UI_ACCESS_SOURCE, "persisted", 0, "", ui_access_query_to_json(ui_access_query_result(filtered)), truncated)
    result.returned_count = filtered.len().to_i64()
    result

fn _ui_access_execute_live(request: AccessRequest, port: i32) -> Result<AccessResult, AccessError>:
    val route = ui_access_cli_route(request)?
    val base_url = "http://127.0.0.1:{port}"
    if request.descriptor.operation != ACCESS_OPERATION_ACT:
        val body = _ui_access_http_once(HttpMethod.GET, base_url + route, "", request.timeout_ms)?
        if request.descriptor.operation == ACCESS_OPERATION_LIST:
            return ui_access_window_result_from_snapshot_json(body)
        return _ui_access_read_result(request.descriptor.operation, body)

    val request_id = "ui-act-" + getpid().to_text() + "-" + time_now_unix_micros().to_text()
    val action_body = ui_access_cli_action_body(request, request_id)
    val started_at_us = time_now_unix_micros()
    val action_result = match _ui_access_http_once(HttpMethod.POST, base_url + route, action_body, _ui_access_remaining_timeout(started_at_us, request.timeout_ms)?):
        Err(e):
            e.set_request_id(request_id)
            return Err(e)
        Ok(body): body
    val canonical_id = _ui_access_option(request.args, "--canonical")
    val surface_id = if _ui_access_option(request.args, "--surface") != "": _ui_access_option(request.args, "--surface") else: _ui_access_surface_from_canonical(canonical_id)
    val observation_route = if surface_id == "": "/api/test/ui/history?count=1" else: "/api/test/ui/surface?id=" + _ui_url_encode(surface_id)
    val observation_timeout = match _ui_access_remaining_timeout(started_at_us, request.timeout_ms):
        Err(e): return Err(ui_access_post_dispatch_error(e, request_id))
        Ok(remaining): remaining
    val observed = _ui_access_http_once(HttpMethod.GET, base_url + observation_route, "", observation_timeout)
    val observation = match observed:
        Err(e): return Err(ui_access_post_dispatch_error(e, request_id))
        Ok(body): body
    val payload = "{\"action\":" + action_result + ",\"observation\":" + observation + "}"
    var result = AccessResult.document(ACCESS_OPERATION_ACT, UI_ACCESS_SOURCE, "", 0, payload, 1, false)
    result.correlation_id = request_id
    Ok(result)

fn _ui_access_remaining_timeout(started_at_us: i64, budget_ms: i64) -> Result<i64, AccessError>:
    val elapsed_ms = (time_now_unix_micros() - started_at_us) / 1000
    val remaining = budget_ms - elapsed_ms
    if remaining <= 0:
        return Err(AccessError.detailed("timeout", "UI access request exhausted its aggregate timeout", "", "Inspect history before retrying", true, false))
    Ok(remaining)

pub fn ui_access_post_dispatch_error(error: AccessError, request_id: text) -> AccessError:
    val hint = "Action may have dispatched; inspect history with request_id '" + request_id + "' before retrying."
    var correlated = AccessError.detailed(error.code, "post-action observation failed after dispatch", error.source_code, hint, error.retryable, error.interaction_required)
    correlated.set_request_id(request_id)
    correlated

fn _ui_access_http_once(method: HttpMethod, url: text, body: text, timeout_ms: i64) -> Result<text, AccessError>:
    val client = http_client_new()
    if not client.is_valid:
        return Err(AccessError.detailed("source_unavailable", "failed to create HTTP client", "", "Start a live GUI/web or TUI-web session", true, false))
    if not http_client_set_timeout(client, timeout_ms):
        http_client_destroy(client)
        return Err(AccessError.create("invalid_argument", "failed to configure finite HTTP timeout"))
    val headers = if method == HttpMethod.POST: ["Content-Type: application/json", "Accept: application/json"] else: ["Accept: application/json"]
    val response: HttpResponse = http_client_request(client, method, url, headers, body)
    http_client_destroy(client)
    if response.is_ok:
        return Ok(response.body)
    Err(ui_access_cli_http_error(response.status_code, response.error, response.body))

pub fn ui_access_cli_http_error(status: i64, transport_error: text, body: text) -> AccessError:
    val detail = if body != "": body else: transport_error
    if transport_error.lower().contains("timeout") or status == 408 or status == 504:
        return AccessError.detailed("timeout", "UI access request timed out", "", detail, true, false)
    if status == 400 or status == 409:
        val lowered = detail.lower()
        if lowered.contains("unsupported"):
            return AccessError.detailed("unsupported_action", "UI action is not supported", "", detail, false, false)
        if lowered.contains("disabled"):
            return AccessError.detailed("target_disabled", "UI target is disabled", "", detail, false, false)
        if lowered.contains("busy"):
            return AccessError.detailed("target_busy", "UI target is busy", "", detail, true, false)
        if lowered.contains("interaction") or lowered.contains("prompt"):
            return AccessError.detailed("interaction_required", "UI action requires interaction", "", detail, false, true)
        if lowered.contains("stale"):
            return AccessError.detailed("stale_target", "UI target is stale", "", detail, false, false)
        return AccessError.detailed("invalid_argument", "UI service rejected the request", "", detail, false, false)
    if status == 403:
        return AccessError.detailed("permission_denied", "UI service denied the request", "", detail, false, false)
    if status == 404:
        return AccessError.detailed("target_not_found", "UI target was not found", "", detail, false, false)
    AccessError.detailed("source_unavailable", "live UI access service is unavailable", "", detail, true, false)

fn ui_access_window_result_from_snapshot_json(body: text) -> Result<AccessResult, AccessError>:
    val snapshot = _ui_access_list_snapshot_from_json(body)?
    Ok(access_result_from_snapshot(ACCESS_OPERATION_LIST, UI_ACCESS_SOURCE, "", snapshot, UI_ACCESS_MAX_LIMIT))

fn _ui_access_list_snapshot_from_json(body: text) -> Result<UiAccessSnapshot, AccessError>:
    val parsed = json_parse(body)
    if parsed == nil:
        return Err(AccessError.create("invalid_response", "UI service returned invalid snapshot JSON"))
    val protocol_version = _ui_access_json_i64(parsed, "protocol_version")
    if protocol_version != 1:
        return Err(AccessError.create("invalid_response", "UI snapshot has an unsupported protocol version"))
    val surfaces = json_object_get(parsed, "surfaces")
    val nodes = json_object_get(parsed, "nodes")
    if json_get_type(surfaces) != "array":
        return Err(AccessError.create("invalid_response", "UI snapshot is missing the surfaces array"))
    if json_get_type(nodes) != "array":
        return Err(AccessError.create("invalid_response", "UI snapshot is missing the nodes array"))

    var decoded_surfaces: [UiAccessSurface] = []
    var index = 0
    while index < json_array_length(surfaces):
        val surface = json_array_get(surfaces, index)
        val surface_id = _ui_access_json_text(surface, "surface_id")
        val root_canonical_id = _ui_access_json_text(surface, "root_canonical_id")
        if surface_id == "" or root_canonical_id == "":
            return Err(AccessError.create("invalid_response", "UI snapshot contains an invalid surface"))
        decoded_surfaces = decoded_surfaces.push(UiAccessSurface(
            surface_id: surface_id,
            title: _ui_access_json_text(surface, "title"),
            active: _ui_access_required_bool(surface, "active")?,
            window_id: _ui_access_json_text(surface, "window_id"),
            app_id: _ui_access_json_text(surface, "app_id"),
            root_canonical_id: root_canonical_id
        ))
        index = index + 1

    var decoded_nodes: [UiAccessNode] = []
    index = 0
    while index < json_array_length(nodes):
        val node = json_array_get(nodes, index)
        val canonical_id = _ui_access_json_text(node, "canonical_id")
        val surface_id = _ui_access_json_text(node, "surface_id")
        val widget_id = _ui_access_json_text(node, "widget_id")
        if canonical_id == "" or surface_id == "" or widget_id == "":
            return Err(AccessError.create("invalid_response", "UI snapshot contains an invalid node"))
        decoded_nodes = decoded_nodes.push(UiAccessNode(
            canonical_id: canonical_id,
            surface_id: surface_id,
            widget_id: widget_id,
            kind: _ui_access_json_text(node, "kind"),
            visible: _ui_access_required_bool(node, "visible")?,
            focused: _ui_access_required_bool(node, "focused")?,
            enabled: _ui_access_required_bool(node, "enabled")?,
            selected: _ui_access_required_bool(node, "selected")?,
            text_value: _ui_access_json_text(node, "text"),
            props: _ui_access_decode_props(json_object_get(node, "props"))?,
            child_ids: _ui_access_decode_text_array(json_object_get(node, "child_ids"), "child_ids")?,
            action_names: _ui_access_decode_text_array(json_object_get(node, "action_names"), "action_names")?
        ))
        index = index + 1

    Ok(UiAccessSnapshot(
        protocol_version: protocol_version.to_i32(),
        snapshot_revision: _ui_access_json_i64(parsed, "snapshot_revision"),
        mode: _ui_access_json_text(parsed, "mode"),
        active_surface: _ui_access_json_text(parsed, "active_surface"),
        surfaces: decoded_surfaces,
        nodes: decoded_nodes,
        recent_events: []
    ))

fn _ui_access_required_bool(object: any, key: text) -> Result<bool, AccessError>:
    val value = json_to_boolean(json_object_get(object, key))
    if value == nil:
        return Err(AccessError.create("invalid_response", "UI snapshot field '" + key + "' is not boolean"))
    Ok(value)

fn _ui_access_decode_props(object: any) -> Result<[UiAccessProp], AccessError>:
    if json_get_type(object) != "object":
        return Err(AccessError.create("invalid_response", "UI snapshot node props are not an object"))
    var props: [UiAccessProp] = []
    for key in json_object_keys(object):
        val value = json_to_string(json_object_get(object, key))
        if value == nil:
            return Err(AccessError.create("invalid_response", "UI snapshot node prop '" + key + "' is not text"))
        props = props.push(UiAccessProp(key: key, value: value))
    Ok(props)

fn _ui_access_decode_text_array(array: any, field: text) -> Result<[text], AccessError>:
    if json_get_type(array) != "array":
        return Err(AccessError.create("invalid_response", "UI snapshot field '" + field + "' is not an array"))
    var values: [text] = []
    var index = 0
    while index < json_array_length(array):
        val value = json_to_string(json_array_get(array, index))
        if value == nil:
            return Err(AccessError.create("invalid_response", "UI snapshot field '" + field + "' contains a non-text value"))
        values = values.push(value)
        index = index + 1
    Ok(values)

fn _ui_access_read_result(operation: text, body: text) -> Result<AccessResult, AccessError>:
    val parsed = json_parse(body)
    if parsed == nil:
        return Err(AccessError.create("invalid_response", "UI service returned invalid JSON"))
    var revision: i64 = 0
    var returned: i64 = 0
    var truncated = false
    if operation == ACCESS_OPERATION_SNAPSHOT:
        revision = _ui_access_json_i64(parsed, "snapshot_revision")
        val nodes = json_object_get(parsed, "nodes")
        if json_get_type(nodes) != "array":
            return Err(AccessError.create("invalid_response", "UI snapshot is missing the nodes array"))
        returned = json_array_length(nodes)
    elif operation == ACCESS_OPERATION_FIND:
        returned = _ui_access_json_i64(parsed, "match_count")
        truncated = _ui_access_json_bool(parsed, "truncated") == "true"
        val nested = json_object_get(parsed, "snapshot")
        revision = _ui_access_json_i64(nested, "snapshot_revision")
    elif operation == ACCESS_OPERATION_SURFACE:
        revision = _ui_access_json_i64(parsed, "snapshot_revision")
        val content = json_object_get(parsed, "content")
        returned = _ui_access_json_i64(content, "count")
        truncated = _ui_access_json_bool(content, "truncated") == "true"
    elif operation == ACCESS_OPERATION_HISTORY:
        if json_get_type(parsed) != "array":
            return Err(AccessError.create("invalid_response", "UI history response is not an array"))
        returned = json_array_length(parsed)
    var result = if operation == ACCESS_OPERATION_SNAPSHOT:
        AccessResult.kv("UI snapshot", [["revision", revision.to_text()], ["mode", _ui_access_json_text(parsed, "mode")], ["active surface", _ui_access_json_text(parsed, "active_surface")], ["surfaces", json_array_length(json_object_get(parsed, "surfaces")).to_text()], ["nodes", returned.to_text()]])
    elif operation == ACCESS_OPERATION_SURFACE:
        AccessResult.kv("UI surface", [["id", _ui_access_json_text(parsed, "surface_id")], ["title", _ui_access_json_text(parsed, "title")], ["active", _ui_access_json_bool(parsed, "active")], ["app", _ui_access_json_text(parsed, "app_id")], ["root", _ui_access_json_text(parsed, "root_canonical_id")], ["nodes", returned.to_text()]])
    elif operation == ACCESS_OPERATION_FIND:
        _ui_access_find_table(parsed)
    else:
        _ui_access_history_table(parsed)
    result.set_context(operation, UI_ACCESS_SOURCE, "", revision, "", body, truncated)
    result.returned_count = returned
    Ok(result)

fn _ui_access_find_table(parsed: any) -> AccessResult:
    val snapshot = json_object_get(parsed, "snapshot")
    val nodes = json_object_get(snapshot, "nodes")
    var rows: [[text]] = [["CANONICAL ID", "KIND", "TEXT", "FOCUSED", "ENABLED", "ACTIONS"]]
    var index = 0
    while index < json_array_length(nodes):
        val node = json_array_get(nodes, index)
        rows = rows + [[_ui_access_json_text(node, "canonical_id"), _ui_access_json_text(node, "kind"), _ui_access_json_text(node, "text"), _ui_access_json_bool(node, "focused"), _ui_access_json_bool(node, "enabled"), _ui_access_json_text_array_join(node, "action_names")]]
        index = index + 1
    AccessResult.table("UI find", rows)

fn _ui_access_history_table(parsed: any) -> AccessResult:
    var rows: [[text]] = [["SEQUENCE", "SURFACE", "TARGET", "EVENT", "PAYLOAD"]]
    var index = 0
    while index < json_array_length(parsed):
        val event = json_array_get(parsed, index)
        rows = rows + [[_ui_access_json_i64(event, "sequence").to_text(), _ui_access_json_text(event, "surface_id"), _ui_access_json_text(event, "canonical_id"), _ui_access_json_text(event, "event_kind"), _ui_access_json_text(event, "payload")]]
        index = index + 1
    AccessResult.table("UI history", rows)

fn _ui_access_json_text(object: any, key: text) -> text:
    val value = json_to_string(json_object_get(object, key))
    if value == nil: "" else: value

fn _ui_access_json_i64(object: any, key: text) -> i64:
    val value = json_to_number(json_object_get(object, key))
    if value == nil: 0 else: value as i64

fn _ui_access_json_bool(object: any, key: text) -> text:
    if object == nil:
        return "null"
    val value = json_to_boolean(json_object_get(object, key))
    if value == nil: "null" else: if value: "true" else: "false"

fn _ui_access_json_text_array_join(object: any, key: text) -> text:
    if object == nil:
        return ""
    val values = json_object_get(object, key)
    var items: [text] = []
    var index = 0
    while index < json_array_length(values):
        val value = json_to_string(json_array_get(values, index))
        if value != nil:
            items = items + [value]
        index = index + 1
    items.join(",")

fn _ui_access_validate_command(request: AccessRequest) -> Result<(), AccessError>:
    val operation = request.descriptor.operation
    if val Err(e) = _ui_access_validate_args_shape(operation, request.args):
        return Err(e)
    if operation == ACCESS_OPERATION_SURFACE and _ui_access_first_positional(request.args) == "":
        return Err(AccessError.detailed("invalid_argument", "surface requires an id", "", "Usage: " + request.descriptor.usage, false, false))
    if operation == ACCESS_OPERATION_ACT:
        val canonical_id = _ui_access_option(request.args, "--canonical")
        val action = _ui_access_option(request.args, "--action")
        val revision = _ui_access_option(request.args, "--revision")
        if not _ui_access_canonical_valid(canonical_id):
            return Err(AccessError.detailed("invalid_argument", "act requires a canonical surface#widget id", "", "Usage: " + request.descriptor.usage, false, false))
        if action == "":
            return Err(AccessError.detailed("invalid_argument", "act requires --action", "", "Usage: " + request.descriptor.usage, false, false))
        val parsed_revision = revision.to_int()
        if revision == "" or parsed_revision == nil or parsed_revision < 0:
            return Err(AccessError.detailed("invalid_argument", "act requires a non-negative --revision from the observed snapshot", "", "Usage: " + request.descriptor.usage, false, false))
        if canonical_id.len() > 1024 or action.len() > 128:
            return Err(AccessError.create("invalid_argument", "act target or action exceeds the bounded input limit"))
    if operation == ACCESS_OPERATION_FIND:
        if val Err(e) = _ui_access_positive_option(request.args, "--limit", UI_ACCESS_DEFAULT_LIMIT, UI_ACCESS_MAX_LIMIT):
            return Err(e)
        if _ui_access_option(request.args, "--text").len() > 1024 or _ui_access_option(request.args, "--surface").len() > 256 or _ui_access_option(request.args, "--kind").len() > 128:
            return Err(AccessError.create("invalid_argument", "find selector exceeds the bounded input limit"))
    if operation == ACCESS_OPERATION_HISTORY:
        if val Err(e) = _ui_access_positive_option(request.args, "--count", UI_ACCESS_DEFAULT_HISTORY, UI_ACCESS_MAX_HISTORY):
            return Err(e)
    Ok(())

fn _ui_access_validate_args_shape(operation: text, args: [text]) -> Result<(), AccessError>:
    var positional_count = 0
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--"):
            if not _ui_access_option_allowed(operation, arg):
                return Err(AccessError.create("invalid_argument", "unsupported option '" + arg + "'"))
            if _ui_access_option_takes_value(arg) and not arg.contains("="):
                if i + 1 >= args.len() or args[i + 1].starts_with("--"):
                    return Err(AccessError.create("invalid_argument", "missing value for '" + arg + "'"))
                i = i + 1
        else:
            positional_count = positional_count + 1
        i = i + 1
    if operation == ACCESS_OPERATION_SURFACE and positional_count != 1:
        return Err(AccessError.create("invalid_argument", "surface requires exactly one id"))
    if operation != ACCESS_OPERATION_SURFACE and positional_count != 0:
        return Err(AccessError.create("invalid_argument", "unexpected positional argument"))
    Ok(())

fn _ui_access_option_allowed(operation: text, arg: text) -> bool:
    if arg == "--json" or _ui_access_arg_matches(arg, "--port") or _ui_access_arg_matches(arg, "--ui-access-db") or _ui_access_arg_matches(arg, "--timeout"):
        return true
    if operation == ACCESS_OPERATION_FIND:
        return _ui_access_arg_matches(arg, "--surface") or _ui_access_arg_matches(arg, "--canonical") or _ui_access_arg_matches(arg, "--kind") or _ui_access_arg_matches(arg, "--text") or _ui_access_arg_matches(arg, "--limit") or arg == "--focused-only"
    if operation == ACCESS_OPERATION_ACT:
        return _ui_access_arg_matches(arg, "--surface") or _ui_access_arg_matches(arg, "--canonical") or _ui_access_arg_matches(arg, "--action") or _ui_access_arg_matches(arg, "--revision") or arg == "--confirm"
    if operation == ACCESS_OPERATION_HISTORY:
        return _ui_access_arg_matches(arg, "--surface") or _ui_access_arg_matches(arg, "--count")
    false

fn _ui_access_arg_matches(arg: text, name: text) -> bool:
    arg == name or arg.starts_with(name + "=")

fn _ui_access_find_route(args: [text]) -> text:
    var parts: [text] = []
    parts = _ui_access_add_query(parts, "surface_id", _ui_access_option(args, "--surface"))
    parts = _ui_access_add_query(parts, "canonical_id", _ui_access_option(args, "--canonical"))
    parts = _ui_access_add_query(parts, "kind", _ui_access_option(args, "--kind"))
    parts = _ui_access_add_query(parts, "text", _ui_access_option(args, "--text"))
    if _ui_access_has_flag(args, "--focused-only"):
        parts = parts.push("focused_only=true")
    val limit = _ui_access_option_number(args, "--limit", UI_ACCESS_DEFAULT_LIMIT)
    parts = parts.push("limit=" + limit.to_text())
    "/api/test/ui/query?" + parts.join("&")

fn _ui_access_history_route(args: [text]) -> text:
    var parts: [text] = []
    parts = _ui_access_add_query(parts, "surface_id", _ui_access_option(args, "--surface"))
    val count = _ui_access_option_number(args, "--count", UI_ACCESS_DEFAULT_HISTORY)
    parts = parts.push("count=" + count.to_text())
    "/api/test/ui/history?" + parts.join("&")

fn _ui_access_add_query(parts: [text], key: text, value: text) -> [text]:
    if value != "":
        return parts.push(key + "=" + _ui_url_encode(value))
    parts

fn _ui_access_positive_option(args: [text], name: text, default_value: i64, max_value: i64) -> Result<i64, AccessError>:
    val raw = _ui_access_option(args, name)
    if raw == "":
        return Ok(default_value)
    val parsed = raw.to_int()
    if parsed == nil or parsed <= 0 or parsed > max_value:
        return Err(AccessError.create("invalid_argument", name + " must be between 1 and " + max_value.to_text()))
    Ok(parsed)

fn _ui_access_option_number(args: [text], name: text, default_value: i64) -> i64:
    val raw = _ui_access_option(args, name)
    if raw == "": default_value else: raw.to_int() ?? default_value

fn _ui_access_option(args: [text], name: text) -> text:
    var i = 0
    while i < args.len():
        if args[i] == name and i + 1 < args.len():
            return args[i + 1]
        if args[i].starts_with(name + "="):
            return args[i][name.len() + 1:]
        i = i + 1
    ""

fn _ui_access_has_flag(args: [text], name: text) -> bool:
    for arg in args:
        if arg == name:
            return true
    false

fn _ui_access_first_positional(args: [text]) -> text:
    var skip_value = false
    for arg in args:
        if skip_value:
            skip_value = false
        elif _ui_access_option_takes_value(arg):
            skip_value = not arg.contains("=")
        elif not arg.starts_with("-"):
            return arg
    ""

fn _ui_access_option_takes_value(arg: text) -> bool:
    arg == "--port" or arg.starts_with("--port=") or arg == "--ui-access-db" or arg.starts_with("--ui-access-db=") or arg == "--timeout" or arg.starts_with("--timeout=") or arg == "--surface" or arg.starts_with("--surface=") or arg == "--canonical" or arg.starts_with("--canonical=") or arg == "--action" or arg.starts_with("--action=") or arg == "--revision" or arg.starts_with("--revision=") or arg == "--kind" or arg.starts_with("--kind=") or arg == "--text" or arg.starts_with("--text=") or arg == "--limit" or arg.starts_with("--limit=") or arg == "--count" or arg.starts_with("--count=")

fn _ui_access_tail(args: [text]) -> [text]:
    var result: [text] = []
    var i = 1
    while i < args.len():
        result = result.push(args[i])
        i = i + 1
    result

fn _ui_access_surface_from_canonical(canonical_id: text) -> text:
    val parts = canonical_id.split("#")
    if parts.len() < 2: "" else: parts[0]

fn _ui_access_canonical_valid(canonical_id: text) -> bool:
    val parts = canonical_id.split("#")
    parts.len() == 2 and parts[0] != "" and parts[1] != ""

fn _ui_access_output_mode(args: [text]) -> text:
    if _ui_access_has_flag(args, "--json"): ACCESS_OUTPUT_JSON else: ACCESS_OUTPUT_HUMAN

fn _ui_access_emit_error(output_mode: text, operation: text, access_error: AccessError, exit_code: i64) -> i64:
    if output_mode == ACCESS_OUTPUT_JSON:
        print access_error_to_json(operation, access_error.request_id, access_error)
    else:
        val hint = if access_error.hint != "": " (" + access_error.hint + ")" else: ""
        error("ui.access", access_error.code + ": " + access_error.message + hint)
    exit_code

export ui_access_cli_descriptors, ui_access_cli_parse_request, ui_access_cli_route
export ui_access_cli_action_body, ui_access_cli_db_error, ui_access_window_result_from_snapshot_json, run_ui_access_cli
