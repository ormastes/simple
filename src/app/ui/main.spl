# Simple UI - Main Entry Point
#
# CLI entry for the UI rendering system.
# Usage:
#   simple ui <file.ui.sdn>                  - Auto-detect best backend
#   simple ui tui <file.ui.sdn>              - TUI mode
#   simple ui tauri <file.ui.sdn> [--port N] - Tauri desktop mode
#   simple ui web <file.ui.sdn> [--port N]   - Web GUI mode

use app.ui.tui.app.{run_tui}
use app.ui.web.server.{run_web}
use app.ui.electron.app.{run_electron}
use app.ui.tauri.app.{run_tauri}
use app.ui.none.app.{run_headless}
use app.ui.tui_web.app.{run_tui_web}
use app.ui.cli.{run_cli_observer}
use app.ui.detect.{detect_gui_backend}
use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.parser.{parse_render_args}
use app.ui.render.config.{resolve_config}
use app.ui.render.session.{create_session}
use app.ui.render.core.{execute_render}
use app.ui.render.export.{export_text, export_html, export_to_file}

extern fn rt_file_exists(path: text) -> bool

# =========================================================================
# Main
# =========================================================================

fn main() -> i64:
    val cli_args = get_args()

    if cli_args.len() == 0:
        print_usage()
        return 1

    val mode = cli_args[0]

    match mode:
        "tui" =>
            if cli_args.len() < 2:
                print "Error: tui mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            return run_tui(file_path)

        "web" =>
            if cli_args.len() < 2:
                print "Error: web mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            val port = parse_port(cli_args)
            return run_web(file_path, port)

        "tauri" =>
            if cli_args.len() < 2:
                print "Error: tauri mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            val port = parse_port(cli_args)
            return run_tauri(file_path, port)

        "electron" =>
            if cli_args.len() < 2:
                print "Error: electron mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            val port = parse_port(cli_args)
            return run_electron(file_path, port)

        "tui_web" =>
            if cli_args.len() < 2:
                print "Error: tui_web mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            val port = parse_port(cli_args)
            return run_tui_web(file_path, port)

        "cli" =>
            if cli_args.len() < 2:
                print "Error: cli mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            var sub_args: [text] = []
            var j = 2
            while j < cli_args.len():
                sub_args = sub_args.push(cli_args[j])
                j = j + 1
            return run_cli_observer(file_path, sub_args)

        "gui" | "desktop" =>
            if cli_args.len() < 2:
                print "Error: gui mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            val port = parse_port(cli_args)
            val backend = detect_gui_backend()
            return run_detected_backend(backend, file_path, port)

        "render" =>
            val parsed_cfg = parse_render_args(cli_args)
            val resolved_cfg = resolve_config(parsed_cfg)
            val session = create_session(resolved_cfg)
            val result = execute_render(session)
            if resolved_cfg.format == "html" or resolved_cfg.format == "both":
                val html = export_html(result)
                if html.len() > 0:
                    print html
            if resolved_cfg.format == "text" or resolved_cfg.format == "both":
                val txt = export_text(result)
                if txt.len() > 0:
                    print txt
            if result.warnings.len() > 0:
                for w in result.warnings:
                    print "Warning: {w}"
            return 0

        "headless" | "none" =>
            if cli_args.len() < 2:
                print "Error: headless mode requires a .ui.sdn file path"
                return 1
            val file_path = cli_args[1]
            return run_headless(file_path)

        "-h" | "--help" =>
            print_usage()
            return 0

        _ =>
            # If first arg is a file, auto-detect best backend
            if rt_file_exists(mode):
                val backend = detect_gui_backend()
                return run_detected_backend(backend, mode, 3000)
            print "Error: Unknown mode '{mode}'. Use 'tui', 'web', 'cli', 'tui_web', 'tauri', 'electron', or 'headless'."
            print_usage()
            return 1

fn run_detected_backend(backend: text, file_path: text, port: i32) -> i64:
    """Run the auto-detected or specified backend."""
    match backend:
        "tauri" =>
            return run_tauri(file_path, port)
        "electron" =>
            return run_electron(file_path, port)
        "web" =>
            return run_web(file_path, port)
        "tui" =>
            return run_tui(file_path)
        "tui_web" =>
            return run_tui_web(file_path, port)
        "headless" =>
            return run_headless(file_path)
        _ =>
            print "Error: Unknown detected backend '{backend}', falling back to TUI"
            return run_tui(file_path)


fn print_usage():
    print "Simple UI Renderer"
    print ""
    print "Usage:"
    print "  simple ui <file.ui.sdn>                      Auto-detect backend (default)"
    print "  simple ui tui <file.ui.sdn>                  TUI mode (terminal)"
    print "  simple ui tauri <file.ui.sdn> [--port N]     Tauri desktop mode"
    print "  simple ui web <file.ui.sdn> [--port N]       Web GUI mode"
    print "  simple ui electron <file.ui.sdn> [--port N]  Electron desktop mode"
    print "  simple ui cli <file.ui.sdn> [subcmd]          CLI observer mode"
    print "  simple ui gui <file.ui.sdn> [--port N]       Auto-detect GUI backend"
    print "  simple ui tui_web <file.ui.sdn> [--port N]   TUI + web hybrid mode"
    print "  simple ui headless <file.ui.sdn>             Headless mode (testing/CI)"
    print "  simple ui none <file.ui.sdn>                 Alias for headless"
    print "  simple ui render [file] [options]             Export render (text/html)"
    print ""
    print "Render options:"
    print "  --format text|html|both   Output format (default: text)"
    print "  --adapter NAME            App adapter (dashboard, llm_dashboard, word, sheets, ...)"
    print "  --mode MODE               Adapter-specific mode"
    print "  --theme NAME              Theme name (default: dark)"
    print "  --width N                 Viewport width (default: 80)"
    print "  --height N                Viewport height (default: 24)"
    print "  --demo                    Use built-in demo asset"
    print ""
    print "Options:"
    print "  --port N    Port for web/tauri/electron server (default: 3000)"
    print "  -h, --help  Show this help"
    print ""
    print "Environment:"
    print "  SIMPLE_GUI_BACKEND   Override auto-detection (tauri/web/tui/tui_web/headless)"

fn parse_port(port_args: [text]) -> i32:
    """Parse --port from args, defaulting to 3000."""
    var i = 0
    while i < port_args.len():
        val arg = port_args[i]
        if arg == "--port" and i + 1 < port_args.len():
            return port_args[i + 1].to_int()
        elif arg.starts_with("--port="):
            val port_str = arg[7:]
            return port_str.to_int()
        i = i + 1
    return 3000

fn get_args() -> [text]:
    """Get CLI args passed to this module.

    Supports both:
    - `simple ui ...` command dispatch, where `ui` appears in argv
    - direct script execution, where argv looks like `<runtime> <script> ...`
    """
    val raw_args = rt_cli_get_args()

    # Command dispatch path: return everything after the `ui` subcommand
    var ui_args: [text] = []
    var found_ui = false
    for arg in raw_args:
        if found_ui:
            ui_args.push(arg)
        elif arg == "ui":
            found_ui = true
    if ui_args.len() > 0:
        return ui_args

    # Direct script execution path: skip everything through the script path.
    var direct_args: [text] = []
    var skip_until_script = true
    for arg in raw_args:
        if skip_until_script:
            if arg.ends_with(".spl") or arg.ends_with(".simple") or arg.ends_with(".sscript") or arg.ends_with(".shs"):
                skip_until_script = false
        else:
            direct_args.push(arg)
    if direct_args.len() > 0:
        return direct_args

    # Fallback: if the first non-runtime arg is already a .ui.sdn file, pass it through.
    for arg in raw_args:
        if arg.ends_with(".spl") or arg.ends_with(".simple") or arg.ends_with(".sscript") or arg.ends_with(".shs"):
            continue
        if arg.ends_with(".ui.sdn"):
            return [arg]

    return ui_args

extern fn rt_cli_get_args() -> [text]
