use app.ui.detect.{detect_gui_backend}
use app.io.cli_ops.{cli_current_exe_path}
use std.nogc_sync_mut.io.process_ops.{process_run}
use std.log.{error}

pub fn ui_backend_binary_for_runtime(simple_bin: text) -> text:
    val slash = simple_bin.last_index_of("/") ?? -1
    val backslash = simple_bin.last_index_of("\\") ?? -1
    val separator = if slash > backslash: slash else: backslash
    val suffix = if simple_bin.ends_with(".exe"): ".exe" else: ""
    if separator < 0:
        return "simple_ui_backend" + suffix
    simple_bin.substring(0, separator + 1) + "simple_ui_backend" + suffix

fn _require_ui_backend_binary() -> text:
    val current_exe = cli_current_exe_path()
    if current_exe == "":
        error("ui.backend", "cannot resolve the installed Simple executable")
        return ""
    ui_backend_binary_for_runtime(current_exe)

fn _print_child_output(stdout: text, stderr: text):
    if stdout.len() > 0:
        print stdout
    if stderr.len() > 0:
        print stderr

pub fn run_ui_backend_dyn(backend: text, file_path: text, port: i32, access_db_path: text) -> i64:
    val resolved = if backend == "gui" or backend == "desktop" or backend == "auto": detect_gui_backend() else: backend
    val backend_bin = _require_ui_backend_binary()
    if backend_bin == "": return 1
    val result = process_run(backend_bin, [
        resolved,
        file_path,
        "--port", "{port}",
        "--ui-access-db", access_db_path
    ])
    _print_child_output(result.0, result.1)
    result.2

pub fn run_ui_cli_backend_dyn(file_path: text, port: i32, access_db_path: text, sub_args: [text]) -> i64:
    val backend_bin = _require_ui_backend_binary()
    if backend_bin == "": return 1
    var args: [text] = [
        "cli", file_path,
        "--ui-access-db", access_db_path
    ]
    for arg in sub_args:
        args = args.push(arg)
    val result = process_run(backend_bin, args)
    _print_child_output(result.0, result.1)
    result.2

pub fn run_ui_render_dyn(render_args: [text]) -> i64:
    val backend_bin = _require_ui_backend_binary()
    if backend_bin == "": return 1
    var args: [text] = []
    for arg in render_args:
        args = args.push(arg)
    val result = process_run(backend_bin, args)
    _print_child_output(result.0, result.1)
    result.2
