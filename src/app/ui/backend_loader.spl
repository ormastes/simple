use app.ui.detect.{detect_gui_backend}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text

fn _simple_binary() -> text:
    val env_binary = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_binary != "":
        return env_binary
    val env_bin = rt_env_get("SIMPLE_BIN") ?? ""
    if env_bin != "":
        return env_bin
    "src/compiler_rust/target/release/simple"

fn _backend_entry_path(backend: text) -> text:
    if backend == "tauri":
        return "src/app/ui/backend_entry_tauri.spl"
    if backend == "electron":
        return "src/app/ui/backend_entry_electron.spl"
    if backend == "browser":
        return "src/app/ui/backend_entry_browser.spl"
    if backend == "web":
        return "src/app/ui/backend_entry_web.spl"
    if backend == "tui_web":
        return "src/app/ui/backend_entry_tui_web.spl"
    if backend == "headless" or backend == "none":
        return "src/app/ui/backend_entry_headless.spl"
    if backend == "cli":
        return "src/app/ui/backend_entry_cli.spl"
    "src/app/ui/backend_entry_tui.spl"

fn _print_child_output(stdout: text, stderr: text):
    if stdout.len() > 0:
        print stdout
    if stderr.len() > 0:
        print stderr

pub fn run_ui_backend_dyn(backend: text, file_path: text, port: i32, access_db_path: text) -> i64:
    val resolved = if backend == "gui" or backend == "desktop" or backend == "auto": detect_gui_backend() else: backend
    val simple_bin = _simple_binary()
    val entry_path = _backend_entry_path(resolved)
    val result = rt_process_run(simple_bin, [
        "run", entry_path,
        "--file", file_path,
        "--port", "{port}",
        "--ui-access-db", access_db_path
    ])
    _print_child_output(result.0, result.1)
    result.2

pub fn run_ui_cli_backend_dyn(file_path: text, port: i32, access_db_path: text, sub_args: [text]) -> i64:
    val simple_bin = _simple_binary()
    var args: [text] = [
        "run", "src/app/ui/backend_entry_cli.spl",
        "--file", file_path,
        "--port", "{port}",
        "--ui-access-db", access_db_path,
        "--"
    ]
    for arg in sub_args:
        args = args.push(arg)
    val result = rt_process_run(simple_bin, args)
    _print_child_output(result.0, result.1)
    result.2

pub fn run_ui_render_dyn(render_args: [text]) -> i64:
    val simple_bin = _simple_binary()
    var args: [text] = ["run", "src/app/ui/backend_entry_render.spl"]
    for arg in render_args:
        args = args.push(arg)
    val result = rt_process_run(simple_bin, args)
    _print_child_output(result.0, result.1)
    result.2
