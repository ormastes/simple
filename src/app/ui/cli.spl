# CLI UI Adapter — re-export from the canonical ui.cli directory module.
#
# app.ui.cli (dot-path) resolves to src/app/ui.cli/__init__.spl.
# This file (src/app/ui/cli.spl) provides the same surface via slash-path
# so that both resolutions expose the same interface.

use app.ui.cli.observer.{CLIObserver}
use app.ui.cli.{run_cli_observer, run_cli_observer_with_access_store}

export CLIObserver, run_cli_observer, run_cli_observer_with_access_store
