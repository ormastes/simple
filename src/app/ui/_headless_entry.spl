use common.ui.parse.sdn.{parse_ui_file}
extern fn rt_file_exists(path: text) -> bool

fn main() -> i64:
    val file_path = "examples/ui/minimal.ui.sdn"
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1
    val tree_result = parse_ui_file(file_path)
    match tree_result:
        Err(e) =>
            print "Error: {e}"
            return 1
        Ok(tree) =>
            print "Headless UI completed."
            return 0