# Simple JS — JavaScript Runtime CLI
# Run JavaScript files, evaluate expressions, or test conformance.
#
# Usage:
#   simple js <file.js>              — Run a JavaScript file
#   simple js -e "code"              — Evaluate JS expression
#   simple js --conformance          — Run conformance test suite
#   simple js --repl                 — Interactive JS REPL
#   simple js --version              — Show JS engine version

use std.js.types.js_types.{JsValue}
use std.js.types.ast_types.{Statement, Expression}
use std.js.engine.js_error.{Logger, LogLevel, script_error, BrowserResult}
use std.js.engine.lexer.{JsLexer}
use std.js.engine.parser.{JsParser}
use std.js.engine.interpreter.{JsInterpreter}
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.module_loader.{JsModuleLoader}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_cli_get_args() -> [text]

fn main() -> i64:
    val args = _get_args()

    if args.len() == 0:
        _print_usage()
        return 0

    val first = args[0]

    if first == "--version" or first == "-v":
        print "Simple JS Engine v0.9.5"
        print "ECMAScript 2015+ (partial)"
        return 0

    if first == "--help" or first == "-h":
        _print_usage()
        return 0

    if first == "-e":
        if args.len() < 2:
            print "js: missing expression after -e"
            return
        val code = args[1]
        val result = _eval_js(code)
        print result
        return 0

    if first == "--conformance":
        print "Running ECMAScript conformance tests..."
        _run_conformance()
        return 0

    if first == "--repl":
        _run_repl()
        return 0

    # Default: run file
    if not rt_file_exists(first):
        print "js: file not found: {first}"
        return
    val source = rt_file_read_text(first)
    if source == nil or source == "":
        print "js: empty file: {first}"
        return
    val result = _eval_js(source)
    if result != "undefined" and result != "":
        print result

fn _eval_js(source: text) -> text:
    """Parse and execute JavaScript source, return string result."""
    val logger = Logger.new("js", LogLevel.Warn)
    val parser = JsParser.new(source, logger)
    val program = parser.parse_program()
    match program:
        Ok(stmts):
            var interp = JsInterpreter.new(logger)
            interp.setup_globals()
            val result = interp.execute(stmts)
            match result:
                Ok(value):
                    return _js_value_to_display(value)
                Err(error):
                    return "Error: {error.message}"
        Err(error):
            return "SyntaxError: {error.message}"

fn _js_value_to_display(value: JsValue) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(v):
            if v: "true" else: "false"
        JsValue.Number(v):
            var s = "{v}"
            val slen = s.len()
            if slen >= 3 and s[slen - 2] == "." and s[slen - 1] == "0":
                var result = ""
                var ci = 0
                while ci < slen - 2:
                    result = result + s[ci]
                    ci = ci + 1
                return result
            s
        JsValue.String(v): v
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

fn _run_conformance():
    """Run basic conformance checks."""
    var pass_count = 0
    var fail_count = 0
    var r = 0

    # ── ES5 basics ──
    r = _check("typeof undefined", "undefined")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("typeof null", "object")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("1 + 2", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello' + ' world'", "hello world")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("true ? 'a' : 'b'", "a")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var x = 5; x", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var x = 10; x > 5", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("!false", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("null == undefined", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Operators ──
    r = _check("5 % 3", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("2 ** 3", "8")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("true && false", "false")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("false || true", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("1 === 1", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("1 !== 2", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Control flow ──
    r = _check(r"var i=0; while(i<3){i=i+1;} i", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var s=0; for(var i=0;i<5;i=i+1){s=s+i;} s", "10")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var x; if(true){x='yes';}else{x='no';} x", "yes")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var i=0; do{i=i+1;}while(i<3); i", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var r=''; switch(2){case 1: r='one'; break; case 2: r='two'; break; default: r='other';} r", "two")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── for-in / for-of ──
    r = _check(r"var o={a:1}; var r=''; for(var k in o){r=r+k;} r", "a")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var s=''; for(var v of ['a','b','c']){s=s+v;} s", "abc")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var s=0; for(var v of [10,20,30]){s=s+v;} s", "60")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Functions ──
    r = _check(r"function f(x){return x*2;} f(5)", "10")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"function f(){var x=10; return function(){return x;}; } f()()", "10")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var f = function(x){return x*3;}; f(4)", "12")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Arrow functions ──
    r = _check("var f = x => x + 1; f(5)", "6")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var f = (a,b) => a + b; f(2,3)", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Closures ──
    r = _check(r"function outer(){var x=5; function inner(){return x;} return inner();} outer()", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"function make(){var n=0; return function(){n=n+1; return n;};} var c=make(); c(); c(); c()", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── let / const ──
    r = _check("let x = 42; x", "42")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("const x = 99; x", "99")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Objects and arrays ──
    r = _check(r"var o = {a:1,b:2}; o.a + o.b", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a = [1,2,3]; a.length", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var o={a:1}; o.b=2; o.b", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[10,20,30]; a[1]", "20")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Compound assignment ──
    r = _check("var x=10; x+=5; x", "15")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var x=10; x-=3; x", "7")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var x=2; x*=3; x", "6")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── String properties and subscript ──
    r = _check("'hello'.length", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'[1]", "e")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── String methods ──
    r = _check("'HELLO'.toLowerCase()", "hello")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.toUpperCase()", "HELLO")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.indexOf('ll')", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("' hi '.trim()", "hi")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.startsWith('he')", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.endsWith('lo')", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.replace('ll','r')", "hero")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.includes('ell')", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.charAt(1)", "e")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.slice(1,3)", "el")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello'.substring(1,3)", "el")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'abcdef'.slice(2,4)", "cd")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'ab'.repeat(3)", "ababab")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'5'.padStart(3,'0')", "005")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("'hello world'.split(' ').length", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Array methods ──
    r = _check("var a=[1,2,3]; a.push(4); a.length", "4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[1,2,3]; a.pop()", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[1,2,3]; a.join('-')", "1-2-3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("[1,2,3].join('')", "123")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[3,1,2]; a.indexOf(2)", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("[1,2,3].includes(2)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[5,3,1]; a.reverse(); a[0]", "1")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("var a=[1,2]; a.concat([3,4]).length", "4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Array higher-order methods ──
    r = _check("[1,2,3].reduce((a,b) => a+b, 0)", "6")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"var r=0; [1,2,3].forEach(x => { r = r + x; }); r", "6")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("[1,2,3].find(x => x > 1)", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("[1,2,3].some(x => x > 2)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("[1,2,3].every(x => x > 0)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Global builtins ──
    r = _check("parseInt('42')", "42")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("parseFloat('3.14')", "3.14")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("isNaN(NaN)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("isFinite(42)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("isFinite(1/0)", "false")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Math builtins ──
    r = _check("Math.floor(3.7)", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.ceil(3.2)", "4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.round(3.5)", "4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.abs(-5)", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.max(1,5,3)", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.min(5,2,8)", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.sqrt(16)", "4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.pow(2,10)", "1024")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Math.PI", "3.141592653589793")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Try/catch ── (use raw strings to avoid Simple interpolation of {e})
    r = _check(r"try{throw 'err';}catch(e){e}", "err")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── typeof ──
    r = _check("typeof 42", "number")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("typeof 'hi'", "string")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("typeof true", "boolean")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"typeof function(){}", "function")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check(r"typeof {}", "object")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Class constructors ──
    r = _check(r"function Foo(x){this.x=x} var f=new Foo(42); f.x", "42")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Class methods ──
    r = _check(r"class C{constructor(v){this.v=v} get(){return this.v}} var c=new C(5); c.get()", "5")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Recursion ──
    r = _check(r"function fib(n){if(n<=1)return n; return fib(n-1)+fib(n-2);} fib(10)", "55")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Chained higher-order methods ──
    r = _check(r"[1,2,3,4,5].map(x=>x*x).filter(x=>x>4).reduce((a,b)=>a+b,0)", "50")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Spread destructuring ──
    r = _check(r"var [x,...rest]=[1,2,3]; rest.length", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── String reverse ──
    r = _check(r"'hello'.split('').reverse().join('')", "olleh")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Nullish coalescing ──
    r = _check("null ?? 'default'", "default")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── In operator ──
    r = _check(r"var o={a:1}; 'a' in o", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Postfix increment ──
    r = _check(r"var x=0; x++; x++; x", "2")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Closure counter ──
    r = _check(r"function make(){var n=0; return function(){n=n+1; return n;};} var c=make(); c(); c(); c()", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Sort with comparator ──
    r = _check(r"var a=[4,2,7,1]; a.sort((a,b)=>a-b); a.join(',')", "1,2,4,7")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── String slice (single arg) ──
    r = _check("'hello world'.slice(6)", "world")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── replaceAll ──
    r = _check("'hello'.replaceAll('l','r')", "herro")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Array.at ──
    r = _check("var a=[1,2,3]; a.at(-1)", "3")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Array.flat ──
    r = _check(r"[1,[2,3],[4]].flat().join(',')", "1,2,3,4")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── String.at ──
    r = _check("'hello'.at(-1)", "o")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Object.assign ──
    r = _check(r"Object.assign({},{a:1}).a", "1")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Number.isInteger ──
    r = _check("Number.isInteger(5)", "true")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("Number.isInteger(5.5)", "false")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── parseInt hex ──
    r = _check("parseInt('0xFF', 16)", "255")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)
    r = _check("parseInt('10', 16)", "16")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Error constructor ──
    r = _check(r"try{throw new Error('oops')}catch(e){'caught'}", "caught")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── undefined property access throws ──
    r = _check(r"try{undefined.x}catch(e){'caught'}", "caught")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    # ── Object.freeze (stub) ──
    r = _check(r"var o=Object.freeze({a:1}); o.a", "1")
    pass_count = pass_count + r
    fail_count = fail_count + (1 - r)

    val total = pass_count + fail_count
    print ""
    print "ECMAScript Conformance Report"
    print "=============================="
    print "Passed: {pass_count}/{total}"
    if fail_count > 0:
        print "Failed: {fail_count}/{total}"
    print ""

fn _check(code: text, expected: text) -> i32:
    val result = _eval_js(code)
    # Normalize float display (3.0 -> 3)
    var actual = result
    if actual.ends_with(".0"):
        actual = actual.slice(0, actual.len() - 2)
    if actual == expected:
        print "  PASS: {code}"
        return 1
    else:
        print "  FAIL: {code}"
        print "    expected: {expected}"
        print "    got:      {actual}"
        return 0

fn _run_repl():
    print "Simple JS REPL (type 'exit' to quit)"
    print "> "
    # REPL requires interactive input — stub for now
    print "REPL not yet available in non-interactive mode"

fn _print_usage():
    print "Usage: simple js [options] [file.js]"
    print ""
    print "Options:"
    print "  <file.js>        Run a JavaScript file"
    print "  -e <code>        Evaluate JavaScript expression"
    print "  --conformance    Run ECMAScript conformance tests"
    print "  --repl           Interactive JS REPL"
    print "  --version        Show JS engine version"
    print "  --help           Show this help"

fn _get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_js = false
    var i = 0
    while i < all_args.len():
        if found_js:
            args.push(all_args[i])
        elif all_args[i] == "js":
            found_js = true
        i = i + 1
    if not found_js:
        var start_idx = 1
        if all_args.len() > 1 and all_args[1].ends_with("main.spl"):
            start_idx = 2
        i = start_idx
        while i < all_args.len():
            args.push(all_args[i])
            i = i + 1
    args
