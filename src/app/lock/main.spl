# Simple CLI - lock command
# Lockfile operations: generate, validate, check

use std.cli.cli_util (get_cli_args, find_manifest_path, parse_deps_section)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, file_write, cwd)
use std.log.{error}

fn print_help():
    print "Usage: simple lock [subcommand] [options]"
    print ""
    print "Manage the lockfile (simple.lock)."
    print ""
    print "Subcommands:"
    print "  generate     Generate lockfile from manifest (default)"
    print "  validate     Validate lockfile integrity"
    print "  check        Check if lockfile is up to date with manifest"
    print ""
    print "Options:"
    print "  --json       Output as JSON"
    print "  --force      Overwrite existing lockfile"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn handle_generate(force: bool, as_json: bool, progress: text) -> i64:
    val manifest_path = find_manifest_path()
    if manifest_path == "":
        print "lock: no simple.sdn or simple.toml found"
        return 1

    val current_dir = cwd()
    val lockfile_path = "{current_dir}/simple.lock"

    if file_exists(lockfile_path) and not force:
        print "lock: simple.lock already exists (use --force to overwrite)"
        return 1

    val content = file_read(manifest_path)
    val deps = parse_deps_section(content, "dependencies") + parse_deps_section(content, "dev_dependencies")

    if deps.len() == 0:
        if as_json:
            print "{\"command\":\"generate\",\"status\":\"empty\",\"count\":0}"
            return 0
        print "No dependencies found. Lockfile not generated."
        return 0

    if progress != "summary":
        val progress_line = render_progress(progress, deps.len(), deps.len(), "lock")
        if progress_line != "":
            print progress_line

    var lock_content = "lockfile_version: 1\n"
    lock_content = lock_content + "generated: simple lock generate\n"
    lock_content = lock_content + "packages:\n"
    for name in deps:
        lock_content = lock_content + "  {name}: *\n"
    if not file_write(lockfile_path, lock_content):
        print "lock: failed to write simple.lock"
        return 1

    if as_json:
        print "{\"command\":\"generate\",\"status\":\"ok\",\"count\":{deps.len()}}"
        return 0

    print "Generated simple.lock with {deps.len()} packages"
    0

fn handle_validate(as_json: bool) -> i64:
    val current_dir = cwd()
    val lockfile_path = "{current_dir}/simple.lock"

    if not file_exists(lockfile_path):
        print "lock: simple.lock not found"
        return 1

    val content = file_read(lockfile_path)
    val lines = content.split("\n")

    # Check version
    var has_version = false
    var has_packages = false
    for line in lines:
        if line.starts_with("lockfile_version:"):
            has_version = true
        if line.starts_with("packages:") or line.starts_with("packages "):
            has_packages = true

    if not has_version:
        print "lock: lockfile missing version field"
        return 1

    if not has_packages:
        print "lock: lockfile missing packages table"
        return 1

    if as_json:
        print "{\"command\":\"validate\",\"status\":\"ok\"}"
        return 0

    print "Lockfile is valid."
    0

fn handle_check(as_json: bool) -> i64:
    val manifest_path = find_manifest_path()
    if manifest_path == "":
        print "lock: no simple.sdn or simple.toml found"
        return 1

    val current_dir = cwd()
    val lockfile_path = "{current_dir}/simple.lock"

    if not file_exists(lockfile_path):
        print "Lockfile missing. Run 'simple lock generate' to create it."
        return 1

    val manifest_content = file_read(manifest_path)
    val manifest_deps = parse_deps_section(manifest_content, "dependencies") + parse_deps_section(manifest_content, "dev_dependencies")

    val lock_content = file_read(lockfile_path)
    # Count packages in lockfile
    var lock_count = 0
    val lines = lock_content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed != "" and not trimmed.starts_with("#") and not trimmed.starts_with("lockfile_version") and not trimmed.starts_with("generated") and not trimmed.starts_with("packages"):
            lock_count = lock_count + 1

    if manifest_deps.len() == lock_count:
        if as_json:
            print "{\"command\":\"check\",\"status\":\"ok\",\"manifest_count\":{manifest_deps.len()},\"lock_count\":{lock_count}}"
            return 0
        print "Lockfile is up to date."
    else:
        if as_json:
            print "{\"command\":\"check\",\"status\":\"out_of_date\",\"manifest_count\":{manifest_deps.len()},\"lock_count\":{lock_count}}"
            return 1
        print "Lockfile is out of date."
        print "  manifest: {manifest_deps.len()} dependencies"
        print "  lockfile: {lock_count} packages"
        print ""
        print "Run 'simple lock generate --force' to update."
        return 1
    0

fn main() -> i64:
    val args = get_cli_args()

    var force = false
    var subcommand = "generate"
    var as_json = false
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("lock", log_opts.error)
        return 1

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--force":
            force = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif not arg.starts_with("-"):
            subcommand = arg
        ai = ai + 1

    if log_opts.log_mode == "json":
        as_json = true

    if subcommand == "generate":
        return handle_generate(force, as_json, log_opts.progress)
    if subcommand == "validate":
        return handle_validate(as_json)
    if subcommand == "check":
        return handle_check(as_json)

    print "lock: unknown subcommand '{subcommand}'"
    print_help()
    return 1
