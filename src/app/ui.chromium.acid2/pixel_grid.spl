# Chromium Shell Acid2 — Pixel Grid (V3 simple_browser shell — M12)
#
# Small fixed-size pixel buffer used by the Acid2 reftest harness. The
# harness rasterises both the reference image and the chromium shell
# output into a `PixelGrid`, then compares them cell-by-cell. The grid
# is intentionally tiny — Acid2 is a reference-pixel test, not a photo
# comparison, so an 8-bit indexed colour palette on a 16x16 coarse grid
# is enough to prove "same visual answer" without touching the real GPU
# rasteriser (real backend is out of scope, SFFI placeholder).
#
# The grid is the only data structure the reftest runner needs from this
# module; everything else is helpers.

# =========================================================================
# Grid dimensions + palette constants
# =========================================================================

val ACID2_GRID_WIDTH:  i32 = 16
val ACID2_GRID_HEIGHT: i32 = 16
val ACID2_GRID_CELLS:  i32 = 256          # width * height

val ACID2_PIXEL_TRANSPARENT: i32 = 0
val ACID2_PIXEL_WHITE:       i32 = 1
val ACID2_PIXEL_BLACK:       i32 = 2
val ACID2_PIXEL_RED:         i32 = 3
val ACID2_PIXEL_GREEN:       i32 = 4
val ACID2_PIXEL_BLUE:        i32 = 5
val ACID2_PIXEL_YELLOW:      i32 = 6
val ACID2_PIXEL_SKIN:        i32 = 7      # "acid face" flesh tone

# =========================================================================
# PixelGrid
# =========================================================================

class PixelGrid:
    """Flat row-major pixel buffer backed by a single `[i32]` array.

    The buffer stores palette indices, not RGBA values — the harness only
    needs equality checks, so collapsing colours to a tiny enum keeps the
    comparator cache-friendly and makes spec-side fixtures trivial to
    construct."""
    width:  i32
    height: i32
    cells:  [i32]

impl PixelGrid:

    static fn new() -> PixelGrid:
        """Allocate a fresh Acid2-sized grid filled with TRANSPARENT."""
        var buf: [i32] = []
        var i: i32 = 0
        while i < ACID2_GRID_CELLS:
            buf.push(ACID2_PIXEL_TRANSPARENT)
            i = i + 1
        PixelGrid(
            width:  ACID2_GRID_WIDTH,
            height: ACID2_GRID_HEIGHT,
            cells:  buf
        )

    static fn filled(colour: i32) -> PixelGrid:
        """Allocate a grid flat-filled with a single palette index."""
        var buf: [i32] = []
        var i: i32 = 0
        while i < ACID2_GRID_CELLS:
            buf.push(colour)
            i = i + 1
        PixelGrid(
            width:  ACID2_GRID_WIDTH,
            height: ACID2_GRID_HEIGHT,
            cells:  buf
        )

    fn width_of() -> i32:
        self.width

    fn height_of() -> i32:
        self.height

    fn cell_count() -> i32:
        self.width * self.height

    fn in_bounds(x: i32, y: i32) -> bool:
        if x < 0:
            return false
        if y < 0:
            return false
        if x >= self.width:
            return false
        if y >= self.height:
            return false
        true

    fn index_of(x: i32, y: i32) -> i32:
        """Row-major offset into `cells`. Callers must pre-check bounds."""
        (y * self.width) + x

    fn get(x: i32, y: i32) -> i32:
        """Read a pixel; out-of-bounds reads return TRANSPARENT."""
        if not self.in_bounds(x, y):
            return ACID2_PIXEL_TRANSPARENT
        val idx = self.index_of(x, y)
        self.cells[idx]

    me set(x: i32, y: i32, colour: i32) -> bool:
        """Write a pixel; returns false if the coordinate is out of bounds."""
        if not self.in_bounds(x, y):
            return false
        val idx = self.index_of(x, y)
        self.cells[idx] = colour
        true

    me fill(colour: i32):
        """Overwrite every cell with one palette entry."""
        var i: i32 = 0
        val n = self.cell_count()
        while i < n:
            self.cells[i] = colour
            i = i + 1

    me stroke_rect(x0: i32, y0: i32, x1: i32, y1: i32, colour: i32) -> i32:
        """Paint the border of an axis-aligned rectangle. Returns the
        number of cells actually written (so the runner can confirm the
        rectangle was at least partly in-frame)."""
        var touched: i32 = 0
        var x: i32 = x0
        while x <= x1:
            if self.set(x, y0, colour):
                touched = touched + 1
            if self.set(x, y1, colour):
                touched = touched + 1
            x = x + 1
        var y: i32 = y0 + 1
        while y < y1:
            if self.set(x0, y, colour):
                touched = touched + 1
            if self.set(x1, y, colour):
                touched = touched + 1
            y = y + 1
        touched

    me fill_rect(x0: i32, y0: i32, x1: i32, y1: i32, colour: i32) -> i32:
        """Fill an axis-aligned rectangle. Returns the number of cells
        written (clipped to the grid)."""
        var touched: i32 = 0
        var y: i32 = y0
        while y <= y1:
            var x: i32 = x0
            while x <= x1:
                if self.set(x, y, colour):
                    touched = touched + 1
                x = x + 1
            y = y + 1
        touched

    fn count_colour(colour: i32) -> i32:
        """Count how many cells hold a given palette index."""
        var c: i32 = 0
        var i: i32 = 0
        val n = self.cell_count()
        while i < n:
            if self.cells[i] == colour:
                c = c + 1
            i = i + 1
        c

    fn equals(other: PixelGrid) -> bool:
        """True if both grids have the same dimensions and identical
        cells — the core comparator the reftest runner relies on."""
        if self.width != other.width_of():
            return false
        if self.height != other.height_of():
            return false
        var i: i32 = 0
        val n = self.cell_count()
        while i < n:
            if self.cells[i] != other.cells[i]:
                return false
            i = i + 1
        true

    fn diff_count(other: PixelGrid) -> i32:
        """Return the number of cells that differ between the two grids.
        Mismatched sizes collapse to a max sentinel (the cell count of
        the bigger grid) so the runner never silently under-reports."""
        if self.width != other.width_of():
            return self.cell_count() + other.cell_count()
        if self.height != other.height_of():
            return self.cell_count() + other.cell_count()
        var diff: i32 = 0
        var i: i32 = 0
        val n = self.cell_count()
        while i < n:
            if self.cells[i] != other.cells[i]:
                diff = diff + 1
            i = i + 1
        diff
