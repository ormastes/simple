# Short-lived launcher that detaches the full test daemon from its client.

use app.io.mod.{process_spawn_async}
use app.test_daemon.binary.{test_daemon_simple_binary}

fn main() -> i64:
    val pid = process_spawn_async(
        test_daemon_simple_binary(),
        ["run", "src/app/test_daemon/daemon_main.spl"]
    )
    if pid > 0: 0 else: 1
