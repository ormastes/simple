# Canonical executable selection for daemon launch and child test runs.

use std.sffi.cli.{cli_get_args}
use app.io.mod.{env_get, file_exists}

fn test_daemon_simple_binary() -> text:
    val configured = env_get("SIMPLE_BINARY") ?? ""
    if configured != "" and file_exists(configured):
        return configured
    val raw = cli_get_args()
    if raw.len() > 0 and (raw[0].ends_with("/simple") or raw[0].ends_with("simple.exe")) and file_exists(raw[0]):
        return raw[0]
    if file_exists("bin/simple"):
        return "bin/simple"
    if file_exists("/proc/self/exe"):
        return "/proc/self/exe"
    "./bin/simple"
