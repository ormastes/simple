# Test Daemon Resource Snapshot — live host sampling

use std.test_runner.system_monitor.{get_system_resources}
use std.io.sysinfo_ops.{cpu_count}
use app.test_daemon.resource_policy.{TestDaemonResourceSnapshot}

fn test_daemon_resource_snapshot(active_clients: i64, active_qemu_sessions: i64, idle_qemu_sessions: i64) -> TestDaemonResourceSnapshot:
    val res = get_system_resources()
    TestDaemonResourceSnapshot(
        cpu_percent: res.cpu_percent,
        memory_percent: res.memory_percent,
        memory_total_mb: res.memory_total_mb,
        active_clients: active_clients,
        active_qemu_sessions: active_qemu_sessions,
        idle_qemu_sessions: idle_qemu_sessions,
        cpu_count: cpu_count()
    )
