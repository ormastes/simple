# Test Daemon Service Adapter — Manages long-lived service processes
#
# Handles HTTP servers, mock backends, and other service processes that
# tests connect to. Services are started once and shared across tests
# using read-only or soft-reset reuse semantics.

use app.test_daemon.session_types.{
    SessionKey, SessionDescriptor, SessionLease, TestSessionMeta,
    SESSION_KIND_SERVICE, LEASE_IDLE, LEASE_ACTIVE,
    REUSE_SHARED_READ_ONLY,
    RESET_NONE, RESET_SOFT,
    session_key_to_id, session_lease_new
}
use app.test_daemon.session_adapter.{SessionAdapter, session_adapter_new}
use app.test_daemon.types.{TestResult, TRESP_COMPLETED, TRESP_FAILED}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_process_spawn_async(cmd: text, args: [text], env: {text: text}) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_process_is_alive(pid: i64) -> bool
extern fn rt_http_get(url: text) -> {text: text}
extern fn rt_sleep_ms(ms: i64)
extern fn rt_shell_exec(cmd: text) -> text
extern fn rt_shell_exit_code() -> i64

# ============================================================================
# Service Adapter
# ============================================================================

class ServiceAdapter:
    base: SessionAdapter
    healthcheck_retries: i64
    healthcheck_interval_ms: i64

fn service_adapter_new() -> ServiceAdapter:
    ServiceAdapter(
        base: session_adapter_new(SESSION_KIND_SERVICE, "service"),
        healthcheck_retries: 30,
        healthcheck_interval_ms: 500
    )

impl ServiceAdapter:
    fn can_handle(meta: TestSessionMeta) -> bool:
        self.base.kind == meta.session_kind

    fn session_key(meta: TestSessionMeta) -> SessionKey:
        """
        Computes session key from test metadata. Services with the same
        startup command and target share a session.
        """
        SessionKey(
            kind: SESSION_KIND_SERVICE,
            target: meta.target,
            artifact_hash: meta.startup_cmd,
            env_profile: "",
            reuse_mode: meta.reuse_mode,
            reset_policy: meta.reset_policy
        )

    me start(desc: SessionDescriptor) -> SessionLease:
        """
        Spawns the service process and waits for its healthcheck URL to
        return HTTP 200. Returns an active lease on success.
        """
        var lease = session_lease_new(desc.key)

        val startup_cmd = desc.config["startup_cmd"] ?? ""
        val healthcheck_url = desc.config["healthcheck"] ?? ""

        if startup_cmd == "":
            # No startup command — return idle lease
            return lease

        # Parse command: first word is the binary, rest are args
        val parts = startup_cmd.split(" ")
        if parts.len() == 0:
            return lease

        val cmd = parts[0]
        var args: [text] = []
        var i = 1
        while i < parts.len():
            args.push(parts[i])
            i = i + 1

        # Spawn service process
        val env: {text: text} = {}
        val pid = rt_process_spawn_async(cmd, args, env)

        if pid <= 0:
            return lease

        # Wait for healthcheck if URL is provided
        var healthy = false
        if healthcheck_url != "":
            healthy = self.wait_for_health(healthcheck_url)
        else:
            # No healthcheck — assume ready after short delay
            rt_sleep_ms(200)
            healthy = rt_process_is_alive(pid)

        if not healthy:
            rt_process_kill(pid)
            return lease

        # Build active lease
        val now = rt_time_now_unix_micros()
        SessionLease(
            session_id: session_key_to_id(desc.key),
            key: desc.key,
            pid: pid,
            qmp_socket: healthcheck_url,
            status: LEASE_ACTIVE,
            snapshot_name: "",
            created_at: now,
            last_used_at: now,
            test_count: 0
        )

    fn health(lease: SessionLease) -> bool:
        """
        Checks service health via HTTP GET to the healthcheck URL.
        Falls back to PID liveness if no URL is configured.
        """
        if lease.pid <= 0:
            return false

        if not rt_process_is_alive(lease.pid):
            return false

        # qmp_socket field stores the healthcheck URL for services
        val healthcheck_url = lease.qmp_socket
        if healthcheck_url == "":
            return true

        val resp = rt_http_get(healthcheck_url)
        val status = resp["status"] ?? ""
        status == "200"

    me reset(lease: SessionLease, policy: i64) -> bool:
        """
        Resets the service session.
        RESET_NONE: no-op (service stays as-is)
        RESET_SOFT: restart the service process
        """
        if policy == RESET_NONE:
            return true

        if policy == RESET_SOFT:
            # Kill and restart the process
            if lease.pid > 0:
                rt_process_kill(lease.pid)
                rt_sleep_ms(200)

            # Re-spawn via the startup command stored in the session key
            val startup_cmd = lease.key.artifact_hash
            if startup_cmd == "":
                return false

            val parts = startup_cmd.split(" ")
            if parts.len() == 0:
                return false

            val cmd = parts[0]
            var args: [text] = []
            var i = 1
            while i < parts.len():
                args.push(parts[i])
                i = i + 1

            val env: {text: text} = {}
            val new_pid = rt_process_spawn_async(cmd, args, env)
            if new_pid <= 0:
                return false

            # Wait for health
            val healthcheck_url = lease.qmp_socket
            if healthcheck_url != "":
                return self.wait_for_health(healthcheck_url)
            rt_sleep_ms(200)
            return rt_process_is_alive(new_pid)

        false

    me execute(lease: SessionLease, test_path: text, timeout_ms: i64) -> TestResult:
        """
        Executes a test with the SERVICE_URL environment variable pointing
        to the running service.
        """
        val service_url = lease.qmp_socket
        val cmd = "SERVICE_URL={service_url} bin/simple test {test_path} 2>&1"

        val start = rt_time_now_unix_micros()
        val output = rt_shell_exec(cmd)
        val exit_code = rt_shell_exit_code()
        val duration_ms = (rt_time_now_unix_micros() - start) / 1000

        val status = if exit_code == 0: TRESP_COMPLETED else: TRESP_FAILED
        val passed = if exit_code == 0: 1 else: 0
        val failed = if exit_code != 0: 1 else: 0

        TestResult(
            test_path: test_path,
            status: status,
            passed: passed,
            failed: failed,
            skipped: 0,
            duration_ms: duration_ms,
            output: output,
            cached: false
        )

    me stop(lease: SessionLease) -> bool:
        """
        Kills the service process.
        """
        if lease.pid <= 0:
            return true
        rt_process_kill(lease.pid)

    # --- Private helpers ---

    fn wait_for_health(url: text) -> bool:
        """
        Polls the healthcheck URL until it returns 200 or retries are exhausted.
        """
        var attempt = 0
        while attempt < self.healthcheck_retries:
            val resp = rt_http_get(url)
            val status = resp["status"] ?? ""
            if status == "200":
                return true
            rt_sleep_ms(self.healthcheck_interval_ms)
            attempt = attempt + 1
        false
