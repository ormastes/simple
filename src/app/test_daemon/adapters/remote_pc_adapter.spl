# Test Daemon Remote PC Adapter — SSH/Telnet remote test execution
#
# Opens an SSH or telnet terminal to a remote host and executes tests there.
# Follows the SessionAdapter pattern from hardware_adapter.spl.
# The adapter uses the terminal abstraction layer for connection management.

use app.test_daemon.session_types.{
    SessionKey, SessionDescriptor, SessionLease, TestSessionMeta,
    session_key_to_id, session_lease_new
}
use app.test_daemon.{
    SESSION_KIND_REMOTE_PC, LEASE_IDLE, LEASE_ACTIVE,
    REUSE_SHARED_WITH_RESET, RESET_SOFT,
    TRESP_FAILED
}
use app.test_daemon.session_adapter.{SessionAdapter, session_adapter_new, test_result_from_child_output}
use app.test_daemon.types.{TestResult}
use std.terminal.types.{TerminalConfig, TerminalConnection, TerminalExecResult}
use std.terminal.connection.{terminal_connect, terminal_execute_timeout, terminal_close, terminal_is_connected}

extern fn rt_time_now_unix_micros() -> i64

fn remote_shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

fn remote_test_path_is_valid(test_path: text) -> bool:
    test_path.starts_with("test/") and test_path.ends_with(".spl") and
        not test_path.contains("/../") and not test_path.ends_with("/..") and
        not test_path.contains("\\") and not test_path.contains("\n") and
        not test_path.contains("\r") and not test_path.contains("\u0000")

fn remote_test_command(test_path: text) -> text:
    "bin/simple test " + remote_shell_quote(test_path) + " --no-session-daemon --sequential 2>&1"

# ============================================================================
# Remote PC Adapter
# ============================================================================

class RemotePcAdapter:
    base: SessionAdapter
    terminal_config: TerminalConfig
    connection: TerminalConnection?

fn remote_pc_adapter_new(config: TerminalConfig) -> RemotePcAdapter:
    """Create a new RemotePcAdapter with the given terminal configuration.

    Args:
        config: TerminalConfig describing the SSH or telnet connection

    Returns:
        RemotePcAdapter ready for use with the session broker
    """
    RemotePcAdapter(
        base: session_adapter_new(SESSION_KIND_REMOTE_PC, "remote_pc"),
        terminal_config: config,
        connection: nil
    )

impl RemotePcAdapter:
    fn can_handle(meta: TestSessionMeta) -> bool:
        """Returns true if this adapter handles the given test metadata.

        Checks that the session kind matches SESSION_KIND_REMOTE_PC.

        Args:
            meta: Test session metadata parsed from test file markers

        Returns:
            true if meta.session_kind == SESSION_KIND_REMOTE_PC
        """
        self.base.kind == meta.session_kind

    fn session_key(meta: TestSessionMeta) -> SessionKey:
        """Computes a session key from test metadata.

        Remote PC sessions are keyed by target host. Multiple tests
        targeting the same host can share a session.

        Args:
            meta: Test session metadata

        Returns:
            SessionKey for session matching
        """
        SessionKey(
            kind: SESSION_KIND_REMOTE_PC,
            target: meta.target,
            artifact_hash: meta.artifact,
            env_profile: "",
            reuse_mode: REUSE_SHARED_WITH_RESET,
            reset_policy: RESET_SOFT
        )

    me start(desc: SessionDescriptor) -> SessionLease:
        """Starts a remote PC session by connecting via terminal.

        Opens an SSH or telnet connection to the configured remote host.
        Returns a lease with LEASE_ACTIVE status on success.

        Args:
            desc: Session descriptor with key and config

        Returns:
            SessionLease with active status, or idle status on failure
        """
        var lease = session_lease_new(desc.key)

        val conn = terminal_connect(self.terminal_config)
        if conn.? and conn.connected:
            self.connection = conn
            val now = rt_time_now_unix_micros()
            return SessionLease(
                session_id: session_key_to_id(desc.key),
                key: desc.key,
                pid: 0,
                qmp_socket: "{self.terminal_config.host}:{self.terminal_config.port}",
                status: LEASE_ACTIVE,
                snapshot_name: "",
                created_at: now,
                last_used_at: now,
                test_count: 0
            )

        lease

    fn health(lease: SessionLease) -> bool:
        """Checks if the remote PC session is still connected.

        Args:
            lease: Current session lease

        Returns:
            true if the terminal connection is active
        """
        if self.connection.?:
            return terminal_is_connected(self.connection)
        false

    me reset(lease: SessionLease, policy: i64) -> bool:
        """Resets the remote PC session by disconnecting and reconnecting.

        Closes the current terminal connection and opens a fresh one.
        This provides a clean state for the next test execution.

        Args:
            lease: Current session lease
            policy: Reset policy (ignored — always does disconnect + reconnect)

        Returns:
            true if reconnection succeeds
        """
        # Close existing connection
        if self.connection.?:
            terminal_close(self.connection)
            self.connection = nil

        # Reconnect
        val conn = terminal_connect(self.terminal_config)
        if conn.? and conn.connected:
            self.connection = conn
            return true
        false

    me execute(lease: SessionLease, test_path: text, timeout_ms: i64) -> TestResult:
        """Executes a test on the remote PC via terminal.

        Runs `bin/simple test <test_path>` on the remote host and parses
        the exit code and output to produce a TestResult.

        Args:
            lease: Current session lease
            test_path: Path to the test file (relative to project root on remote)
            timeout_ms: Maximum execution time in milliseconds

        Returns:
            TestResult with pass/fail status, output, and duration
        """
        if not remote_test_path_is_valid(test_path):
            return TestResult(
                test_path: test_path,
                status: TRESP_FAILED,
                passed: 0,
                failed: 1,
                skipped: 0,
                duration_ms: 0,
                output: "error: remote test path must be a repo-relative test/*.spl path",
                cached: false
            )

        if not self.connection.?:
            return TestResult(
                test_path: test_path,
                status: TRESP_FAILED,
                passed: 0,
                failed: 1,
                skipped: 0,
                duration_ms: 0,
                output: "error: no active terminal connection",
                cached: false
            )

        val cmd = remote_test_command(test_path)
        val start = rt_time_now_unix_micros()
        val result = terminal_execute_timeout(self.connection, cmd, timeout_ms)
        val duration_ms = (rt_time_now_unix_micros() - start) / 1000

        test_result_from_child_output(
            test_path, result.stdout, result.stderr, result.exit_code, duration_ms, timeout_ms
        )

    me stop(lease: SessionLease) -> bool:
        """Stops the remote PC session by closing the terminal connection.

        Args:
            lease: Current session lease

        Returns:
            true (always succeeds, even if already disconnected)
        """
        if self.connection.?:
            terminal_close(self.connection)
            self.connection = nil
        true
