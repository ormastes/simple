# Container Adapter — Docker/Podman session adapter for test daemon
#
# Manages container lifecycle for running tests inside Docker or Podman
# containers. Auto-detects which runtime is available. Uses `docker create`
# + `docker start` (NOT `docker run --rm`) so containers persist across
# reset/health-check cycles.

use app.test_daemon.session_types.{
    SessionKey, SessionDescriptor, SessionLease, TestSessionMeta,
    session_key_to_id, session_lease_new
}
use app.test_daemon.{
    SESSION_KIND_CONTAINER, LEASE_IDLE, LEASE_ACTIVE,
    REUSE_EXCLUSIVE_REUSED, REUSE_FRESH_PER_TEST,
    RESET_RECREATE, RESET_SOFT, RESET_HARD,
    TRESP_FAILED
}
use app.test_daemon.session_adapter.{SessionAdapter, session_adapter_new, test_result_from_child_output}
use app.test_daemon.types.{TestResult}
use app.io.mod.{process_run_timeout}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_hash_text(s: text) -> i64

# ============================================================================
# Container Adapter
# ============================================================================

class ContainerAdapter:
    base: SessionAdapter
    runtime: text          # "docker" or "podman"
    default_image: text    # e.g. "simple-test:latest"

fn detect_container_runtime() -> text:
    """
    Detects which container runtime is available on the system.
    Prefers docker over podman. Returns "none" if neither is found.
    """
    val (_docker_out, _docker_err, docker_code) = process_run_timeout("docker", ["--version"], 5000)
    if docker_code == 0:
        return "docker"
    val (_podman_out, _podman_err, podman_code) = process_run_timeout("podman", ["--version"], 5000)
    if podman_code == 0:
        return "podman"
    "none"

fn container_adapter_new() -> ContainerAdapter:
    val runtime = detect_container_runtime()
    ContainerAdapter(
        base: session_adapter_new(SESSION_KIND_CONTAINER, "container"),
        runtime: runtime,
        default_image: "simple-test:latest"
    )

fn container_image(target: text, fallback: text) -> text:
    val separator = target.find(":")
    if separator < 0: return fallback
    target.slice(separator + 1, target.len())

fn container_create_args(name: text, image: text) -> [text]:
    [
        "create", "--name", name,
        "--memory=4g", "--memory-swap=4g", "--pids-limit=512", "--cpus=4.0",
        "-v", ".:/workspace", "-w", "/workspace", image, "sleep", "infinity"
    ]

# ============================================================================
# Impl
# ============================================================================

impl ContainerAdapter:
    fn can_handle(meta: TestSessionMeta) -> bool:
        """
        Returns true if this adapter handles the given test metadata.
        Only handles SESSION_KIND_CONTAINER and requires a working runtime.
        """
        meta.session_kind == SESSION_KIND_CONTAINER and self.runtime != "none"

    fn session_key(meta: TestSessionMeta) -> SessionKey:
        """
        Computes a session key from test metadata. The key is derived from
        the container image (from meta.target or default_image) and runtime.
        """
        val image = if meta.target != "": meta.target else: self.default_image
        val artifact_hash = if meta.artifact != "":
            "{rt_hash_text(meta.artifact)}"
        else:
            "{rt_hash_text(image)}"
        SessionKey(
            kind: SESSION_KIND_CONTAINER,
            target: "{self.runtime}:{image}",
            artifact_hash: artifact_hash,
            env_profile: "",
            reuse_mode: meta.reuse_mode,
            reset_policy: meta.reset_policy
        )

    me start(desc: SessionDescriptor) -> SessionLease:
        """
        Starts a new container session.
        Uses `docker create` to create the container, then `docker start`
        to start it. This two-step approach lets us manage the lifecycle
        (restart, inspect, rm) without losing the container on exit.
        """
        val rt = self.runtime
        if rt == "none":
            return session_lease_new(desc.key)

        val image = desc.key.target
        val session_id = desc.config["session_id"] ?? session_key_to_id(desc.key)
        val container_name = session_id

        val actual_image = container_image(image, self.default_image)
        val create_args = container_create_args(container_name, actual_image)
        val (_create_out, _create_err, create_exit) = process_run_timeout(rt, create_args, 30000)

        if create_exit != 0:
            # Container may already exist from a previous run — remove and retry
            val _removed = process_run_timeout(rt, ["rm", "-f", container_name], 30000)
            val (_retry_out, _retry_err, retry_exit) = process_run_timeout(rt, create_args, 30000)
            if retry_exit != 0:
                return session_lease_new(desc.key)

        # Start the container
        val (_start_out, _start_err, start_exit) = process_run_timeout(rt, ["start", container_name], 30000)
        if start_exit != 0:
            val _removed = process_run_timeout(rt, ["rm", "-f", container_name], 30000)
            return session_lease_new(desc.key)

        # Get container PID
        val (pid_stdout, _pid_stderr, _pid_exit) = process_run_timeout(
            rt, ["inspect", "--format={{{{.State.Pid}}}}", container_name], 30000
        )
        val pid_output = pid_stdout.trim()
        val pid = pid_output.to_i64() ?? 0

        val now = rt_time_now_unix_micros()
        SessionLease(
            session_id: container_name,
            key: desc.key,
            pid: pid,
            qmp_socket: "",
            status: LEASE_ACTIVE,
            snapshot_name: "",
            created_at: now,
            last_used_at: now,
            test_count: 0
        )

    fn health(lease: SessionLease) -> bool:
        """
        Checks if the container is still running by inspecting its state.
        """
        val rt = self.runtime
        if rt == "none":
            return false
        val (stdout, _stderr, _exit_code) = process_run_timeout(
            rt, ["inspect", "--format={{{{.State.Running}}}}", lease.session_id], 10000
        )
        val output = stdout.trim()
        output == "true"

    me reset(lease: SessionLease, policy: i64) -> bool:
        """
        Resets the container session according to the given policy.
        - RESET_SOFT / RESET_HARD: restart the container
        - RESET_RECREATE: remove and recreate from scratch
        """
        val rt = self.runtime
        if rt == "none":
            return false

        if policy == RESET_SOFT or policy == RESET_HARD:
            # Restart the running container
            val (_stdout, _stderr, exit_code) = process_run_timeout(rt, ["restart", lease.session_id], 30000)
            return exit_code == 0

        if policy == RESET_RECREATE:
            # Full teardown and rebuild
            val _removed = process_run_timeout(rt, ["rm", "-f", lease.session_id], 30000)

            # Extract image from key target
            val image = lease.key.target
            val actual_image = container_image(image, self.default_image)

            # Recreate
            val create_args = container_create_args(lease.session_id, actual_image)
            val (_create_out, _create_err, create_exit) = process_run_timeout(rt, create_args, 30000)
            if create_exit != 0:
                return false

            # Start
            val (_start_out, _start_err, start_exit) = process_run_timeout(rt, ["start", lease.session_id], 30000)
            return start_exit == 0

        false

    me execute(lease: SessionLease, test_path: text, timeout_ms: i64) -> TestResult:
        """
        Executes a test inside the container using `docker exec`.
        Runs `bin/simple test <test_path>` inside the container workspace.
        """
        val rt = self.runtime
        val start_time = rt_time_now_unix_micros()

        if rt == "none":
            return TestResult(
                test_path: test_path,
                status: TRESP_FAILED,
                passed: 0,
                failed: 1,
                skipped: 0,
                duration_ms: 0,
                output: "no container runtime available",
                cached: false
            )

        val (stdout, stderr, exit_code) = process_run_timeout(
            rt,
            [
                "exec", lease.session_id, "bin/simple", "test", test_path,
                "--no-session-daemon", "--sequential"
            ],
            timeout_ms
        )
        val end_time = rt_time_now_unix_micros()
        val duration_ms = (end_time - start_time) / 1000
        test_result_from_child_output(test_path, stdout, stderr, exit_code as i64, duration_ms, timeout_ms)

    me stop(lease: SessionLease) -> bool:
        """
        Stops and removes the container forcefully.
        """
        val rt = self.runtime
        if rt == "none":
            return false
        val (_stdout, _stderr, exit_code) = process_run_timeout(rt, ["rm", "-f", lease.session_id], 30000)
        exit_code == 0
