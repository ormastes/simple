# Test daemon CLI — one protocol and one full daemon owner.

use std.sffi.cli.{cli_get_args}
use std.daemon_sdk.lock.{is_daemon_running}
use app.test_daemon.client.{
    test_daemon_ensure_responsive, test_submit_and_wait,
    test_daemon_status, test_daemon_stop
}
use app.test_daemon.types.{test_daemon_config_default, TRESP_COMPLETED, TRESP_CACHED}

extern fn rt_file_exists(path: text) -> bool

fn test_daemon_args() -> [text]:
    val raw = cli_get_args()
    var args: [text] = []
    var found_command = false
    var i = 0
    while i < raw.len():
        if found_command:
            args.push(raw[i])
        elif raw[i] == "test-daemon":
            found_command = true
        i = i + 1
    if found_command:
        return args

    var start_idx = 1
    i = 0
    while i < raw.len():
        if raw[i].ends_with("/app/test_daemon/main.spl") or raw[i] == "src/app/test_daemon/main.spl":
            start_idx = i + 1
        i = i + 1
    raw[start_idx:]

fn print_usage():
    print "Usage:"
    print "  simple test-daemon start"
    print "  simple test-daemon stop"
    print "  simple test-daemon status"
    print "  simple test-daemon run <path>"
    print "  simple test-daemon clean <path>"

fn cli_test_daemon_run(args: [text], clean: bool) -> i64:
    if args.len() == 0:
        print "Usage: simple test-daemon run <path>"
        return 1
    val path = args[0]
    if not path.ends_with(".spl") or not rt_file_exists(path):
        print "error: test file not found: {path}"
        return 1
    val result = test_submit_and_wait(path, test_daemon_config_default(), clean, 600000)
    if result.output != "":
        print result.output
    if result.status == TRESP_COMPLETED or result.status == TRESP_CACHED: 0 else: 1

fn cli_test_daemon(args: [text]) -> i64:
    if args.len() == 0:
        print_usage()
        return 1

    val config = test_daemon_config_default()
    val subcmd = args[0]
    if subcmd == "start":
        if test_daemon_ensure_responsive(config):
            print "Test daemon: running"
            return 0
        print "Failed to start test daemon"
        return 1
    if subcmd == "stop":
        if not is_daemon_running(config.daemon.lock_path):
            print "Test daemon: not running"
            return 0
        if test_daemon_stop(config):
            print "Test daemon stopped"
            return 0
        print "Failed to stop test daemon"
        return 1
    if subcmd == "status":
        if not is_daemon_running(config.daemon.lock_path):
            print "Test daemon: not running"
            return 0
        val status = test_daemon_status(config)
        if status.status == TRESP_COMPLETED:
            print "Test daemon: running"
            return 0
        print "Test daemon: unresponsive"
        return 1
    if subcmd == "run":
        return cli_test_daemon_run(args[1:], false)
    if subcmd == "clean":
        return cli_test_daemon_run(args[1:], true)

    print "Unknown test-daemon subcommand: {subcmd}"
    1

fn main() -> i64:
    cli_test_daemon(test_daemon_args())
