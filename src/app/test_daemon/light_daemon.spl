# Lightweight test daemon for explicit single-file test requests.

use app.io.process_ops.{process_run_timeout}
use app.io.mod.{env_get, env_set}
use app.test_incremental_state_shared.{IncrementalTestState, incremental_test_state_new}
use app.test_daemon.binary.{test_daemon_simple_binary}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_rename(from: text, to: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_sleep_ms(ms: i64)

# Atomic write: tmp + rename (see test_runner_client.spl for the race this
# closes — #98: a plain rt_file_write_text response could be observed
# 0-byte/partial by the polling client between this daemon's open(truncate)
# and its write()).
fn atomic_write_text(path: text, content: text) -> bool:
    val tmp_path = "{path}.tmp"
    if rt_file_write_text(tmp_path, content):
        if rt_file_rename(tmp_path, path):
            return true
        rt_file_delete(tmp_path)
    false

val LIGHT_DAEMON_DIR: text = ".build/test_daemon_light"
val LIGHT_REQ_DIR: text = ".build/test_daemon_light/requests"
val LIGHT_RESP_DIR: text = ".build/test_daemon_light/responses"
val LIGHT_LOCK: text = ".build/test_daemon_light/daemon.lock"
val LIGHT_STOP: text = ".build/test_daemon_light/stop"
val LIGHT_DEP_GRAPH: text = ".build/test_daemon_light/dep_graph.sdn"

fn ensure_dirs():
    rt_dir_create_all(LIGHT_DAEMON_DIR)
    rt_dir_create_all(LIGHT_REQ_DIR)
    rt_dir_create_all(LIGHT_RESP_DIR)

fn response_path(name: text) -> text:
    "{LIGHT_RESP_DIR}/{basename(name)}.resp"

fn basename(path: text) -> text:
    val parts = path.split("/")
    if parts.len() == 0:
        return path
    parts[parts.len() - 1]

fn handle_request(binary: text, name: text, state: IncrementalTestState):
    if not name.ends_with(".req"):
        return
    val req_path = if name.contains("/"): name else: "{LIGHT_REQ_DIR}/{name}"
    val request = (rt_file_read_text(req_path) ?? "").trim()
    val lines = request.split("\n")
    val clean = lines.len() > 1 and lines[0] == "clean"
    val test_path = if lines.len() > 1: lines[1].trim() else: request
    if test_path == "":
        atomic_write_text(response_path(name), "1\nmissing test path")
        rt_file_delete(req_path)
        return
    if not clean:
        val cached = state.check_freshness(test_path)
        if cached.result_status != -1:
            atomic_write_text(response_path(name), "{cached.result_status}\n{cached.output}\ntest_daemon_cache=hit")
            rt_file_delete(req_path)
            return
    val previous_child_marker = env_get("SIMPLE_TEST_DAEMON_CHILD") ?? ""
    env_set("SIMPLE_TEST_DAEMON_CHILD", "1")
    val (stdout, stderr, code) = process_run_timeout(
        binary,
        ["run", "src/app/test_runner_new/test_runner_single.spl", test_path, "--no-session-daemon", "--sequential"],
        600000
    )
    env_set("SIMPLE_TEST_DAEMON_CHILD", previous_child_marker)
    var body = stdout
    if stderr != "":
        body = body + stderr
    state.record_daemon_result(test_path, code as i64, 0, if code == 0: 0 else: 1, 0, 0, body)
    state.save()
    val cache_state = if clean: "clean" else: "miss"
    atomic_write_text(response_path(name), "{code}\n{body}\ntest_daemon_cache={cache_state}")
    rt_file_delete(req_path)

fn main() -> i64:
    ensure_dirs()
    rt_file_write_text(LIGHT_LOCK, "{rt_getpid()}")
    val binary = test_daemon_simple_binary()
    val state = incremental_test_state_new("", LIGHT_DEP_GRAPH, true)
    var idle = 0
    while idle < 240:
        if rt_file_exists(LIGHT_STOP):
            rt_file_delete(LIGHT_STOP)
            rt_file_delete(LIGHT_LOCK)
            return 0
        val entries = rt_dir_list(LIGHT_REQ_DIR)
        if entries.len() == 0:
            idle = idle + 1
            rt_sleep_ms(250)
            continue
        idle = 0
        var i = 0
        while i < entries.len():
            handle_request(binary, entries[i], state)
            i = i + 1
    rt_file_delete(LIGHT_LOCK)
    0
