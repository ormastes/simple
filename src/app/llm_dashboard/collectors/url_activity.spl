# URL Activity Collector
#
# Extracts and aggregates URL/domain activity from web fetches and searches.
# Provides domain grouping and per-agent URL views.

use app.llm_dashboard.data.types.{URLActivity, extract_domain_and_page}

# =========================================================================
# URL Activity Collector
# =========================================================================

class URLActivityCollector:
    activities: [URLActivity]
    max_entries: i32

    static fn new() -> URLActivityCollector:
        return URLActivityCollector(activities: [], max_entries: 300)

impl URLActivityCollector:

    me add(activity: URLActivity):
        """Add a URL activity entry."""
        self.activities.push(activity)
        if self.activities.len() > self.max_entries:
            self.activities = self.activities.slice(self.activities.len() - self.max_entries)

    fn recent(count: i32) -> [URLActivity]:
        """Get most recent URL activities."""
        if count >= self.activities.len():
            return self.activities
        return self.activities.slice(self.activities.len() - count)

    fn for_agent(agent_id: text) -> [URLActivity]:
        """Get URL activities for a specific agent."""
        var result: [URLActivity] = []
        for a in self.activities:
            if a.agent_id == agent_id:
                result.push(a)
        return result

    fn unique_domains() -> [text]:
        """Get unique domains across all activities."""
        var seen: [text] = []
        for a in self.activities:
            var found = false
            for s in seen:
                if s == a.domain:
                    found = true
            if not found:
                seen.push(a.domain)
        return seen

    fn count_by_domain(domain: text) -> i32:
        """Count activities for a specific domain."""
        var count = 0
        for a in self.activities:
            if a.domain == domain:
                count = count + 1
        return count

    fn format_for_room(max_lines: i32) -> [text]:
        """Format recent URL activities as display lines for the Research room."""
        val recent_items = self.recent(max_lines)
        var lines: [text] = []
        for a in recent_items:
            val display = "{a.domain}{a.page_name}"
            if display.len() > 45:
                lines.push("  {display.slice(0, 42)}...")
            else:
                lines.push("  {display}")
        return lines

    fn domain_summary() -> [text]:
        """Summary of domains with access counts."""
        val domains = self.unique_domains()
        var lines: [text] = []
        for d in domains:
            val count = self.count_by_domain(d)
            lines.push("  {d} ({count})")
        return lines
