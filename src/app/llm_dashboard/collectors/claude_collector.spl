# Claude Collector
#
# Collects Claude LLM status from JSONL transcripts.
# Primary data source: ~/.claude/projects/ JSONL file watching.
# Secondary: Claude CLI session query, API health check.

use app.llm_dashboard.data.types.{LLMStatus, LLMProvider, AgentNode}
use app.llm_dashboard.data.agent_tree.{AgentTree}

# =========================================================================
# Claude Collector
# =========================================================================

class ClaudeCollector:
    last_check: i64

    static fn new() -> ClaudeCollector:
        return ClaudeCollector(last_check: 0)

fn collect_claude_status(tree: AgentTree) -> LLMStatus:
    """Derive Claude status from the agent tree state."""
    var connected = false
    var model = ""
    var total_tokens: i64 = 0
    var active_count: i64 = 0
    var last_heartbeat: i64 = 0

    for agent in tree.all_agents():
        match agent.provider:
            LLMProvider.Claude:
                connected = true
                if agent.model != "" and model == "":
                    model = agent.model
                total_tokens = total_tokens + agent.token_count
                match agent.activity:
                    AgentActivity.Finished: pass_dn
                    AgentActivity.Idle: pass_dn
                    _: active_count = active_count + 1
                if agent.last_active > last_heartbeat:
                    last_heartbeat = agent.last_active
            _: pass_dn

    val cost_cents = estimate_claude_cost(total_tokens, model)

    return LLMStatus(
        provider: LLMProvider.Claude,
        connected: connected,
        model: model,
        tokens_used: total_tokens,
        estimated_cost_cents: cost_cents,
        active_agents: active_count,
        last_heartbeat: last_heartbeat
    )

# =========================================================================
# Cost Estimation
# =========================================================================

fn estimate_claude_cost(tokens: i64, model: text) -> i64:
    """Estimate cost in cents based on token count and model.
    Uses approximate blended (input+output) rates."""
    val lower = model.to_lower()
    # Approximate cents per 1K tokens (blended input/output)
    var cents_per_1k: i64 = 0
    if lower.contains("opus"):
        cents_per_1k = 5     # ~$15/M input, ~$75/M output blended
    elif lower.contains("sonnet"):
        cents_per_1k = 2     # ~$3/M input, ~$15/M output blended
    elif lower.contains("haiku"):
        cents_per_1k = 1     # ~$0.25/M input, ~$1.25/M output blended
    else:
        cents_per_1k = 2     # default to sonnet-like

    return (tokens * cents_per_1k) / 1000
