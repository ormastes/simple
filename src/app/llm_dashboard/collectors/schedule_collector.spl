#![allow(unnamed_duplicate_typed_args)]
# Schedule Collector
#
# Discovers active Claude Code schedules, /loop tasks, remote-control sessions,
# and Simple-native daemon processes, mapping them to ManagedTask entries.

use app.llm_dashboard.data.types.{ManagedTask, TaskKind, TaskState}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_time_now_unix_micros() -> i64

# =========================================================================
# Claude Code Schedule Detection
# =========================================================================

fn collect_schedules() -> [ManagedTask]:
    """Scan for Claude Code scheduled tasks and active loops."""
    var tasks: [ManagedTask] = []
    val now_ms = rt_time_now_unix_micros() / 1000

    val sched_dir = _expand_home("~/.claude/schedules")
    if rt_file_exists(sched_dir):
        val files = rt_dir_list(sched_dir)
        for fname in files:
            if fname.ends_with(".json") or fname.ends_with(".sdn"):
                val path = "{sched_dir}/{fname}"
                val content = rt_file_read_text(path)
                val task = _parse_schedule_file(fname, content, now_ms)
                if task.id != "":
                    tasks.push(task)

    return tasks

fn _parse_schedule_file(fname: text, content: text, now_ms: i64) -> ManagedTask:
    """Parse a schedule definition file into a ManagedTask."""
    val id = fname.slice(0, fname.len() - 5)   # strip .json/.sdn
    val name = _extract_field(content, "name")
    val command = _extract_field(content, "prompt")
    val cron_expr = _extract_field(content, "cron")
    val interval_str = _extract_field(content, "interval_seconds")
    val interval: i64 = if interval_str != "": interval_str.to_i64() ?? 0 else: 0

    if id == "" and name == "" and command == "":
        return ManagedTask.new("", TaskKind.Schedule, "", "")

    var task = ManagedTask.new(id, TaskKind.Schedule, name, command)
    task.cron_expr = cron_expr
    task.interval_seconds = interval
    task.created_at = now_ms
    return task

# =========================================================================
# Simple-Native Daemon Detection
# =========================================================================

fn collect_daemons() -> [ManagedTask]:
    """Detect running Simple-native daemon processes via their lock files."""
    var tasks: [ManagedTask] = []
    val now_ms = rt_time_now_unix_micros() / 1000

    val d1 = _check_daemon(".build/daemon/test_daemon/lock", "test_daemon", "Test Daemon", now_ms)
    if d1.id != "":
        tasks.push(d1)
    val d2 = _check_daemon(".build/daemon/watcher/lock", "watcher_daemon", "Watcher Daemon", now_ms)
    if d2.id != "":
        tasks.push(d2)
    val d3 = _check_daemon(".build/llm_dashboard/scheduler/lock", "llm_scheduler", "LLM Scheduler", now_ms)
    if d3.id != "":
        tasks.push(d3)

    return tasks

fn _check_daemon(lock_path: text, daemon_id: text, daemon_name: text, now_ms: i64) -> ManagedTask:
    if not rt_file_exists(lock_path):
        return ManagedTask.new("", TaskKind.Daemon, "", "")
    val pid_str = rt_file_read_text(lock_path).trim()
    var task = ManagedTask.new(daemon_id, TaskKind.Daemon, daemon_name, "")
    task.agent_id = pid_str
    task.state = TaskState.Active
    task.created_at = now_ms
    return task

# =========================================================================
# Helpers
# =========================================================================

fn _expand_home(path: text) -> text:
    if path.starts_with("~/"):
        val home = _get_home_dir()
        return "{home}/{path.slice(2)}"
    return path

fn _get_home_dir() -> text:
    if rt_file_exists("/Users"):
        val entries = rt_dir_list("/Users")
        if entries.len() > 0:
            return "/Users/{entries[0]}"
    return "/root"

fn _extract_field(content: text, key: text) -> text:
    """Extract a value from key=value or "key":"value" formatted content."""
    val eq_needle = "{key}="
    val json_needle = "\"{key}\":"
    var idx = content.index_of(json_needle)
    if idx >= 0:
        val after = content.slice(idx + json_needle.len()).trim()
        if after.starts_with("\""):
            val end = after.slice(1).index_of("\"")
            if end >= 0:
                return after.slice(1, end + 1)
        return ""
    idx = content.index_of(eq_needle)
    if idx >= 0:
        val after = content.slice(idx + eq_needle.len())
        val end = after.index_of("\n")
        if end >= 0:
            return after.slice(0, end).trim()
        return after.trim()
    return ""
