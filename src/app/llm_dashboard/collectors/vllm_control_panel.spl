use app.llm_runtime.manifest.{llm_runtime_manifest_from_text}
use app.llm_runtime.dashboard_live_control.{LlmRuntimeDashboardControlExecution, llm_runtime_execute_dashboard_control}
use app.mcp.main_lazy_json.{LB, RB, jp, js}

pub class LlmDashboardVllmControlPanel:
    action: text
    status: text
    reason: text
    pid: i64
    running_status: text
    endpoint_status: text
    models_status: text
    models_reason: text
    http_status: i64
    requires_runtime_executor: bool
    controls: [text]
    evidence_jsonl: text

pub fn collect_llm_dashboard_vllm_control_preflight(manifest_text: text) -> LlmDashboardVllmControlPanel:
    collect_llm_dashboard_vllm_control_action(manifest_text, "preflight", -1)

pub fn collect_llm_dashboard_vllm_control_action(manifest_text: text, action: text, pid: i64) -> LlmDashboardVllmControlPanel:
    collect_llm_dashboard_vllm_control_action_with_resources(manifest_text, action, pid, true, true)

pub fn collect_llm_dashboard_vllm_control_action_with_resources(manifest_text: text, action: text, pid: i64, vllm_available: bool, gpu_available: bool) -> LlmDashboardVllmControlPanel:
    val manifest = llm_runtime_manifest_from_text(manifest_text)
    val selected = action.trim()
    if selected == "" or selected == "preflight":
        return _panel_from_runtime(llm_runtime_execute_dashboard_control(manifest, "preflight", -1, vllm_available, gpu_available))
    _panel_from_runtime(llm_runtime_execute_dashboard_control(manifest, selected, pid, vllm_available, gpu_available))

pub fn collect_llm_dashboard_vllm_control_action_with_overrides(manifest_text: text, action: text, pid: i64, base_model: text, endpoint: text, vllm_available: bool, gpu_available: bool) -> LlmDashboardVllmControlPanel:
    collect_llm_dashboard_vllm_control_action_with_resources(_manifest_text_with_overrides(manifest_text, base_model, endpoint), action, pid, vllm_available, gpu_available)

pub fn render_llm_dashboard_vllm_control_panel_text(panel: LlmDashboardVllmControlPanel) -> text:
    "vLLM Controls action=" + _public_absence(panel.action) +
        " status=" + _public_absence(panel.status) +
        " reason=" + _public_absence(panel.reason) +
        " pid=" + _public_pid(panel.pid).to_text() +
        " running=" + _public_absence(panel.running_status) +
        " endpoint=" + _public_absence(panel.endpoint_status) +
        " models=" + _public_absence(panel.models_status) +
        " executor=" + _bool_text(panel.requires_runtime_executor) +
        " controls=" + panel.controls.join(",")

pub fn render_llm_dashboard_vllm_control_panel_html(panel: LlmDashboardVllmControlPanel) -> text:
    "<section id=\"llm-vllm-control-panel\"><h2>vLLM Controls</h2><p>action=" +
        _html_escape(_public_absence(panel.action)) + "</p><p>status=" +
        _html_escape(_public_absence(panel.status)) + "</p><p>reason=" +
        _html_escape(_public_absence(panel.reason)) + "</p><p>pid=" +
        _public_pid(panel.pid).to_text() + "</p><p>running=" +
        _html_escape(_public_absence(panel.running_status)) + "</p><p>endpoint=" +
        _html_escape(_public_absence(panel.endpoint_status)) + "</p><p>models=" +
        _html_escape(_public_absence(panel.models_status)) + "</p><p>executor=" +
        _html_escape(_bool_text(panel.requires_runtime_executor)) + "</p>" +
        _render_controls(panel.controls) + "</section>"

pub fn llm_dashboard_vllm_control_panel_jsonl_event(panel: LlmDashboardVllmControlPanel) -> text:
    LB() +
    jp("event", js("llm_dashboard_vllm_control_panel")) +
    "," + jp("action", js(panel.action)) +
    "," + jp("status", js(panel.status)) +
    "," + jp("reason", js(panel.reason)) +
    "," + jp("pid", str(_public_pid(panel.pid))) +
    "," + jp("running", js(panel.running_status)) +
    "," + jp("endpoint", js(panel.endpoint_status)) +
    "," + jp("models_status", js(panel.models_status)) +
    "," + jp("models_reason", js(panel.models_reason)) +
    "," + jp("http_status", str(panel.http_status)) +
    "," + jp("requires_runtime_executor", _json_bool(panel.requires_runtime_executor)) +
    RB() + "\n"

fn _panel(action: text, status: text, reason: text, pid: i64, running_status: text, endpoint_status: text, models_status: text, models_reason: text, http_status: i64, requires_runtime_executor: bool) -> LlmDashboardVllmControlPanel:
    val panel = LlmDashboardVllmControlPanel(
        action: action,
        status: status,
        reason: reason,
        pid: pid,
        running_status: running_status,
        endpoint_status: endpoint_status,
        models_status: models_status,
        models_reason: models_reason,
        http_status: http_status,
        requires_runtime_executor: requires_runtime_executor,
        controls: _controls_for(status, pid),
        evidence_jsonl: ""
    )
    panel.evidence_jsonl = llm_dashboard_vllm_control_panel_jsonl_event(panel)
    panel

fn _panel_from_runtime(result: LlmRuntimeDashboardControlExecution) -> LlmDashboardVllmControlPanel:
    _panel(result.action, result.status, result.reason, result.pid, result.running_status, result.endpoint_status, result.models_status, result.models_reason, result.http_status, result.requires_runtime_executor)

fn _controls_for(status: text, pid: i64) -> [text]:
    var controls = ["preflight", "start"]
    if pid > 0:
        controls.push("poll")
        controls.push("probe")
        controls.push("stop")
    else if status == "planned" or status == "not_ready" or status == "skipped":
        controls.push("poll")
        controls.push("probe")
        controls.push("stop")
    controls

fn _render_controls(controls: [text]) -> text:
    var html = "<form id=\"llm-vllm-controls\" method=\"get\" action=\"/api/vllm/control\">"
    for control in controls:
        html = html + "<button name=\"action\" value=\"" + _html_escape(control) + "\">" + _html_escape(control) + "</button>"
    html + "</form>"

fn _public_absence(value: text) -> text:
    if value == "":
        return "none"
    value

fn _public_pid(pid: i64) -> i64:
    if pid <= 0:
        return 0
    pid

fn _bool_text(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _json_bool(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _manifest_text_with_overrides(manifest_text: text, base_model: text, endpoint: text) -> text:
    var out = manifest_text
    if base_model.trim() != "":
        out = out + "\nbase_model=" + base_model.trim()
    if endpoint.trim() != "":
        out = out + "\nendpoint=" + endpoint.trim()
    out

fn _html_escape(value: text) -> text:
    var escaped = value.split("&").join("&amp;")
    escaped = escaped.split("<").join("&lt;")
    escaped = escaped.split(">").join("&gt;")
    escaped.split("\"").join("&quot;")

export LlmDashboardVllmControlPanel
export collect_llm_dashboard_vllm_control_preflight, collect_llm_dashboard_vllm_control_action, collect_llm_dashboard_vllm_control_action_with_resources, collect_llm_dashboard_vllm_control_action_with_overrides
export render_llm_dashboard_vllm_control_panel_text, render_llm_dashboard_vllm_control_panel_html, llm_dashboard_vllm_control_panel_jsonl_event
