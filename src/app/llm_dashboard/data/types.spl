pub enum TaskKind:
    Loop
    Schedule
    Daemon
    RemoteControl
    Job

pub enum TaskState:
    Pending
    Active
    Completed
    Failed
    Cancelled

pub enum LLMProvider:
    Claude
    Codex
    Gemini
    Unknown(text)

pub enum AgentActivity:
    Idle
    Thinking
    Finished
    Error(text)
    Reading(text)
    Writing(text)
    Searching(text)
    WebFetch(text)
    ToolUse(text)
    SubAgentSpawn(text)

pub enum RoomKind:
    Research
    Code
    Chat

pub struct ManagedTask:
    id: text
    kind: TaskKind
    title: text
    command: text
    state: TaskState
    pid: i64
    exit_code: i64
    start_time: text

    fn new(id: text, kind: TaskKind, title: text, command: text) -> ManagedTask:
        ManagedTask(
            id: id,
            kind: kind,
            title: title,
            command: command,
            state: TaskState.Pending,
            pid: -1,
            exit_code: -1,
            start_time: ""
        )

pub struct AgentNode:
    id: text
    provider: LLMProvider
    model: text
    activity: AgentActivity
    parent_id: text

    static fn new(id: text, provider: LLMProvider, model: text) -> AgentNode:
        AgentNode(
            id: id,
            provider: provider,
            model: model,
            activity: AgentActivity.Idle,
            parent_id: ""
        )

pub fn task_kind_name(kind: TaskKind) -> text:
    match kind:
        case TaskKind.Loop:
            "loop"
        case TaskKind.Schedule:
            "schedule"
        case TaskKind.Daemon:
            "daemon"
        case TaskKind.RemoteControl:
            "remote"
        case TaskKind.Job:
            "job"

pub fn task_state_name(state: TaskState) -> text:
    match state:
        case TaskState.Pending:
            "pending"
        case TaskState.Active:
            "active"
        case TaskState.Completed:
            "done"
        case TaskState.Failed:
            "failed"
        case TaskState.Cancelled:
            "cancelled"

export TaskKind, TaskState, ManagedTask
export LLMProvider, AgentActivity, RoomKind, AgentNode
export task_kind_name, task_state_name
