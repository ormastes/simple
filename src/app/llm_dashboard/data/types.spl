# LLM Dashboard Types
#
# Core type definitions for agent monitoring: activities, providers,
# agent nodes, status, rooms, and activity tracking.

# =========================================================================
# Agent Activity States
# =========================================================================

enum AgentActivity:
    Idle
    Thinking
    Reading(path: text)
    Writing(path: text)
    Searching(query: text)
    WebFetch(url: text)
    ToolUse(tool: text)
    SubAgentSpawn(child_id: text)
    Error(msg: text)
    Finished

fn activity_label(activity: AgentActivity) -> text:
    """Short label for display."""
    match activity:
        AgentActivity.Idle: "idle"
        AgentActivity.Thinking: "thinking"
        AgentActivity.Reading(p): "reading {p}"
        AgentActivity.Writing(p): "writing {p}"
        AgentActivity.Searching(q): "searching"
        AgentActivity.WebFetch(u): "web_fetch"
        AgentActivity.ToolUse(t): "tool: {t}"
        AgentActivity.SubAgentSpawn(c): "spawning"
        AgentActivity.Error(m): "error"
        AgentActivity.Finished: "done"

fn activity_short(activity: AgentActivity) -> text:
    """Minimal label for status bar."""
    match activity:
        AgentActivity.Idle: "."
        AgentActivity.Thinking: "*"
        AgentActivity.Reading(_): "R"
        AgentActivity.Writing(_): "W"
        AgentActivity.Searching(_): "S"
        AgentActivity.WebFetch(_): "F"
        AgentActivity.ToolUse(_): "T"
        AgentActivity.SubAgentSpawn(_): "+"
        AgentActivity.Error(_): "!"
        AgentActivity.Finished: "D"

# =========================================================================
# LLM Providers
# =========================================================================

enum LLMProvider:
    Claude
    Codex
    Gemini
    Unknown(name: text)

fn provider_name(provider: LLMProvider) -> text:
    match provider:
        LLMProvider.Claude: "Claude"
        LLMProvider.Codex: "Codex"
        LLMProvider.Gemini: "Gemini"
        LLMProvider.Unknown(n): n

fn provider_from_text(name: text) -> LLMProvider:
    val lower = name.to_lower()
    if lower.contains("claude") or lower.contains("anthropic"):
        return LLMProvider.Claude
    if lower.contains("codex") or lower.contains("openai") or lower.contains("gpt"):
        return LLMProvider.Codex
    if lower.contains("gemini") or lower.contains("google"):
        return LLMProvider.Gemini
    return LLMProvider.Unknown(name: name)

# =========================================================================
# Agent Node
# =========================================================================

class AgentNode:
    id: text
    provider: LLMProvider
    model: text
    activity: AgentActivity
    parent_id: text?
    children: [text]
    files_read: [text]
    files_written: [text]
    urls_fetched: [text]
    tools_used: [text]
    token_count: i64
    start_time: i64
    last_active: i64

    static fn new(id: text, provider: LLMProvider, model: text) -> AgentNode:
        return AgentNode(
            id: id,
            provider: provider,
            model: model,
            activity: AgentActivity.Idle,
            parent_id: nil,
            children: [],
            files_read: [],
            files_written: [],
            urls_fetched: [],
            tools_used: [],
            token_count: 0,
            start_time: 0,
            last_active: 0
        )

# =========================================================================
# LLM Status
# =========================================================================

class LLMStatus:
    provider: LLMProvider
    connected: bool
    model: text
    tokens_used: i64
    estimated_cost_cents: i64
    active_agents: i64
    last_heartbeat: i64

    static fn disconnected(provider: LLMProvider) -> LLMStatus:
        return LLMStatus(
            provider: provider,
            connected: false,
            model: "",
            tokens_used: 0,
            estimated_cost_cents: 0,
            active_agents: 0,
            last_heartbeat: 0
        )

# =========================================================================
# Rooms
# =========================================================================

enum RoomKind:
    Research
    Code
    Skills
    Server
    Chat
    TestLab

fn room_name(room: RoomKind) -> text:
    match room:
        RoomKind.Research: "Research"
        RoomKind.Code: "Code"
        RoomKind.Skills: "Skills"
        RoomKind.Server: "Servers"
        RoomKind.Chat: "Chat"
        RoomKind.TestLab: "TestLab"

fn tool_to_room(tool_name: text) -> RoomKind:
    """Map a tool name to the room it belongs in."""
    match tool_name:
        "Read" => RoomKind.Code
        "Write" => RoomKind.Code
        "Edit" => RoomKind.Code
        "Glob" => RoomKind.Code
        "Grep" => RoomKind.Code
        "WebFetch" => RoomKind.Research
        "WebSearch" => RoomKind.Research
        "Bash" => RoomKind.Code
        "Agent" => RoomKind.Chat
        "Skill" => RoomKind.Skills
        "LSP" => RoomKind.Server
        "NotebookEdit" => RoomKind.Code
        "TaskCreate" => RoomKind.Skills
        "TaskUpdate" => RoomKind.Skills
        _ =>
            if tool_name.starts_with("mcp__"):
                RoomKind.Server
            elif tool_name.contains("test") or tool_name.contains("Test"):
                RoomKind.TestLab
            else:
                RoomKind.Code

# =========================================================================
# Activity Tracking
# =========================================================================

class FileActivity:
    agent_id: text
    path: text
    operation: text
    timestamp: i64

    static fn new(agent_id: text, path: text, operation: text, timestamp: i64) -> FileActivity:
        return FileActivity(
            agent_id: agent_id,
            path: path,
            operation: operation,
            timestamp: timestamp
        )

class URLActivity:
    agent_id: text
    url: text
    domain: text
    page_name: text
    timestamp: i64

    static fn new(agent_id: text, url: text, timestamp: i64) -> URLActivity:
        val parts = extract_domain_and_page(url)
        return URLActivity(
            agent_id: agent_id,
            url: url,
            domain: parts.0,
            page_name: parts.1,
            timestamp: timestamp
        )

class ActivityEntry:
    agent_id: text
    room: RoomKind
    tool_name: text
    summary: text
    timestamp: i64
    duration_ms: i64

    static fn new(agent_id: text, room: RoomKind, tool_name: text, summary: text, timestamp: i64) -> ActivityEntry:
        return ActivityEntry(
            agent_id: agent_id,
            room: room,
            tool_name: tool_name,
            summary: summary,
            timestamp: timestamp,
            duration_ms: 0
        )

# =========================================================================
# Helpers
# =========================================================================

fn extract_domain_and_page(url: text) -> (text, text):
    """Extract domain and page name from a URL."""
    var work = url
    # Strip protocol
    if work.starts_with("https://"):
        work = work.slice(8)
    elif work.starts_with("http://"):
        work = work.slice(7)
    # Split at first /
    val slash_idx = work.index_of("/")
    if slash_idx < 0:
        return (work, "/")
    val domain = work.slice(0, slash_idx)
    var page = work.slice(slash_idx)
    # Truncate long pages
    if page.len() > 40:
        page = "{page.slice(0, 37)}..."
    return (domain, page)

fn format_timestamp(ts: i64) -> text:
    """Format a unix timestamp as HH:MM:SS."""
    val seconds = ts % 60
    val minutes = (ts / 60) % 60
    val hours = (ts / 3600) % 24
    val hh = if hours < 10: "0{hours}" else: "{hours}"
    val mm = if minutes < 10: "0{minutes}" else: "{minutes}"
    val ss = if seconds < 10: "0{seconds}" else: "{seconds}"
    return "{hh}:{mm}:{ss}"

fn format_tokens(count: i64) -> text:
    """Format token count with K/M suffix."""
    if count >= 1000000:
        val m = count / 100000
        return "{m / 10}.{m % 10}M"
    if count >= 1000:
        val k = count / 100
        return "{k / 10}.{k % 10}K"
    return "{count}"
