use app.llm_dashboard.data.types.{AgentNode, LLMProvider}

pub class AgentTree:
    agents: {text: AgentNode}

    static fn new() -> AgentTree:
        AgentTree(agents: {})

    fn agent_count() -> i64:
        var count = 0
        val keys = self.agents.keys()
        var i = 0
        while i < keys.len():
            val agent = self.agents[keys[i]]
            if agent.?:
                count = count + 1
            i = i + 1
        count

    fn get_agent(agent_id: text) -> AgentNode?:
        self.agents[agent_id]

    fn all_agents() -> [AgentNode]:
        var result: [AgentNode] = []
        val keys = self.agents.keys()
        var i = 0
        while i < keys.len():
            val agent = self.agents[keys[i]]
            if agent.?:
                result.push(agent)
            i = i + 1
        result

    fn root_agents() -> [AgentNode]:
        var result: [AgentNode] = []
        for agent in self.all_agents():
            if agent.parent_id == "":
                result.push(agent)
        result

    fn children_of(parent_id: text) -> [AgentNode]:
        var result: [AgentNode] = []
        for agent in self.all_agents():
            if agent.parent_id == parent_id:
                result.push(agent)
        result

    fn depth_of(agent_id: text) -> i64:
        var current = self.agents[agent_id]
        if not current.?:
            return 0
        var depth = 0
        var guard = 0
        while current.? and current.parent_id != "" and guard < 64:
            val parent = self.agents[current.parent_id]
            if not parent.?:
                return depth
            depth = depth + 1
            current = parent
            guard = guard + 1
        depth

    me ensure_agent(agent_id: text, provider: LLMProvider, model: text) -> AgentNode:
        val existing = self.agents[agent_id]
        if existing.?:
            return existing
        val node = AgentNode.new(agent_id, provider, model)
        self.agents[agent_id] = node
        node

export AgentTree
