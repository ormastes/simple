# JSONL Parser
#
# Parses Claude Code JSONL transcript lines into typed dashboard events.
# Each line in a transcript is a JSON object with type, name, and content fields.

use std.json.{parse_json, JsonValue}
use app.llm_dashboard.data.types.{
    AgentActivity, LLMProvider, RoomKind, FileActivity, URLActivity, ActivityEntry,
    tool_to_room, provider_from_text
}

# =========================================================================
# Parsed Event
# =========================================================================

enum DashboardEvent:
    ToolCall(agent_id: text, tool_name: text, args: [text], timestamp: i64)
    AgentSpawn(parent_id: text, child_id: text, description: text, timestamp: i64)
    AssistantMessage(agent_id: text, token_count: i64, timestamp: i64)
    UserMessage(agent_id: text, timestamp: i64)
    SessionStart(session_id: text, model: text, provider: text, timestamp: i64)
    SessionEnd(session_id: text, timestamp: i64)
    Error(agent_id: text, message: text, timestamp: i64)
    Unknown

# =========================================================================
# Parser
# =========================================================================

class JsonlParser:
    session_id: text

    static fn new(session_id: text) -> JsonlParser:
        return JsonlParser(session_id: session_id)

fn parse_line(parser: JsonlParser, line: text) -> DashboardEvent:
    """Parse a single JSONL line into a DashboardEvent."""
    val trimmed = line.trim()
    if trimmed == "" or trimmed.starts_with("#"):
        return DashboardEvent.Unknown

    val json_result = parse_json(trimmed)
    match json_result:
        Err(_): return DashboardEvent.Unknown
        Ok(json): return classify_event(parser.session_id, json)

fn parse_lines(parser: JsonlParser, lines: [text]) -> [DashboardEvent]:
    """Parse multiple JSONL lines, filtering out Unknown events."""
    var events: [DashboardEvent] = []
    for line in lines:
        val event = parse_line(parser, line)
        match event:
            DashboardEvent.Unknown: pass_dn
            _: events.push(event)
    return events

# =========================================================================
# Event Classification
# =========================================================================

fn classify_event(agent_id: text, json: JsonValue) -> DashboardEvent:
    """Classify a JSON object into a dashboard event type."""
    val msg_type = json_text(json, "type")
    val timestamp = json_int(json, "timestamp")

    match msg_type:
        "tool_use" => classify_tool_use(agent_id, json, timestamp)
        "tool_result" => DashboardEvent.Unknown  # we track tool_use, not result
        "assistant" => classify_assistant(agent_id, json, timestamp)
        "human" => DashboardEvent.UserMessage(agent_id: agent_id, timestamp: timestamp)
        "user" => DashboardEvent.UserMessage(agent_id: agent_id, timestamp: timestamp)
        "system" => classify_system(agent_id, json, timestamp)
        "error" =>
            val msg = json_text(json, "message")
            DashboardEvent.Error(agent_id: agent_id, message: msg, timestamp: timestamp)
        _ => DashboardEvent.Unknown

fn classify_tool_use(agent_id: text, json: JsonValue, timestamp: i64) -> DashboardEvent:
    """Classify a tool_use message."""
    val tool_name = json_text(json, "name")
    var args: [text] = []

    # Extract key arguments based on tool
    val input_obj = json_get(json, "input")
    match tool_name:
        "Read" =>
            val path = json_text(input_obj, "file_path")
            args.push(path)
        "Write" =>
            val path = json_text(input_obj, "file_path")
            args.push(path)
        "Edit" =>
            val path = json_text(input_obj, "file_path")
            args.push(path)
        "Grep" =>
            val pattern = json_text(input_obj, "pattern")
            args.push(pattern)
        "Glob" =>
            val pattern = json_text(input_obj, "pattern")
            args.push(pattern)
        "WebFetch" =>
            val url = json_text(input_obj, "url")
            args.push(url)
        "WebSearch" =>
            val query = json_text(input_obj, "query")
            args.push(query)
        "Bash" =>
            val cmd = json_text(input_obj, "command")
            # Truncate long commands
            if cmd.len() > 60:
                args.push("{cmd.slice(0, 57)}...")
            else:
                args.push(cmd)
        "Agent" =>
            val desc = json_text(input_obj, "description")
            val child_type = json_text(input_obj, "subagent_type")
            return DashboardEvent.AgentSpawn(
                parent_id: agent_id,
                child_id: "{agent_id}#{desc}",
                description: desc,
                timestamp: timestamp
            )
        "Skill" =>
            val skill = json_text(input_obj, "skill")
            args.push(skill)
        _ =>
            pass_dn

    return DashboardEvent.ToolCall(
        agent_id: agent_id,
        tool_name: tool_name,
        args: args,
        timestamp: timestamp
    )

fn classify_assistant(agent_id: text, json: JsonValue, timestamp: i64) -> DashboardEvent:
    """Classify an assistant message — extract token usage."""
    val usage = json_get(json, "usage")
    var tokens: i64 = 0
    if usage != nil:
        val output_tokens = json_int(usage, "output_tokens")
        val input_tokens = json_int(usage, "input_tokens")
        tokens = output_tokens + input_tokens

    val model = json_text(json, "model")
    if model != "":
        return DashboardEvent.SessionStart(
            session_id: agent_id,
            model: model,
            provider: model,
            timestamp: timestamp
        )

    return DashboardEvent.AssistantMessage(
        agent_id: agent_id,
        token_count: tokens,
        timestamp: timestamp
    )

fn classify_system(agent_id: text, json: JsonValue, timestamp: i64) -> DashboardEvent:
    """Classify system messages — detect session start/end."""
    val content = json_text(json, "content")
    if content.contains("session started") or content.contains("init"):
        val model = json_text(json, "model")
        return DashboardEvent.SessionStart(
            session_id: agent_id,
            model: model,
            provider: model,
            timestamp: timestamp
        )
    if content.contains("session ended") or content.contains("goodbye"):
        return DashboardEvent.SessionEnd(
            session_id: agent_id,
            timestamp: timestamp
        )
    return DashboardEvent.Unknown

# =========================================================================
# JSON Helpers
# =========================================================================

fn json_text(json: JsonValue, key: text) -> text:
    """Safely extract a text field from a JSON object."""
    if json == nil:
        return ""
    val val_node = json_get(json, key)
    if val_node == nil:
        return ""
    match val_node:
        JsonValue.String(s): return s
        _: return "{val_node}"

fn json_int(json: JsonValue, key: text) -> i64:
    """Safely extract an integer field from a JSON object."""
    if json == nil:
        return 0
    val val_node = json_get(json, key)
    if val_node == nil:
        return 0
    match val_node:
        JsonValue.Number(n): return n.to_i64()
        JsonValue.String(s): return s.to_i64()
        _: return 0

fn json_get(json: JsonValue, key: text) -> JsonValue?:
    """Safely get a field from a JSON object."""
    if json == nil:
        return nil
    match json:
        JsonValue.Object(fields):
            for (k, v) in fields:
                if k == key:
                    return v
            return nil
        _: return nil

# =========================================================================
# Activity Mapping
# =========================================================================

fn event_to_activity(event: DashboardEvent) -> AgentActivity:
    """Convert a dashboard event to an agent activity state."""
    match event:
        DashboardEvent.ToolCall(_, tool_name, args, _):
            match tool_name:
                "Read" =>
                    val path = if args.len() > 0: args[0] else: ""
                    AgentActivity.Reading(path: path)
                "Write" =>
                    val path = if args.len() > 0: args[0] else: ""
                    AgentActivity.Writing(path: path)
                "Edit" =>
                    val path = if args.len() > 0: args[0] else: ""
                    AgentActivity.Writing(path: path)
                "Grep" =>
                    val query = if args.len() > 0: args[0] else: ""
                    AgentActivity.Searching(query: query)
                "Glob" =>
                    val query = if args.len() > 0: args[0] else: ""
                    AgentActivity.Searching(query: query)
                "WebFetch" =>
                    val url = if args.len() > 0: args[0] else: ""
                    AgentActivity.WebFetch(url: url)
                "WebSearch" =>
                    val query = if args.len() > 0: args[0] else: ""
                    AgentActivity.Searching(query: query)
                _ => AgentActivity.ToolUse(tool: tool_name)
        DashboardEvent.AgentSpawn(_, child_id, _, _):
            AgentActivity.SubAgentSpawn(child_id: child_id)
        DashboardEvent.AssistantMessage(_, _, _):
            AgentActivity.Thinking
        DashboardEvent.Error(_, msg, _):
            AgentActivity.Error(msg: msg)
        DashboardEvent.SessionEnd(_, _):
            AgentActivity.Finished
        _:
            AgentActivity.Idle

fn event_to_activity_entry(event: DashboardEvent) -> ActivityEntry?:
    """Convert a dashboard event to an activity feed entry."""
    match event:
        DashboardEvent.ToolCall(agent_id, tool_name, args, timestamp):
            val room = tool_to_room(tool_name)
            val summary = if args.len() > 0: "{tool_name} {args[0]}" else: tool_name
            return ActivityEntry.new(
                agent_id: agent_id,
                room: room,
                tool_name: tool_name,
                summary: summary,
                timestamp: timestamp
            )
        DashboardEvent.AgentSpawn(parent_id, child_id, description, timestamp):
            return ActivityEntry.new(
                agent_id: parent_id,
                room: RoomKind.Chat,
                tool_name: "Agent",
                summary: "spawn -> {description}",
                timestamp: timestamp
            )
        DashboardEvent.Error(agent_id, message, timestamp):
            return ActivityEntry.new(
                agent_id: agent_id,
                room: RoomKind.Code,
                tool_name: "error",
                summary: message,
                timestamp: timestamp
            )
        _: return nil
