    h.push("<p>This dashboard now enters through a reusable login pack boundary: UI submits credentials, the auth service verifies identity, storage persists sessions, and authority checks gate sensitive surfaces.</p>")
    h.push("<ul>")
    h.push("<li>Persistent session cookies for the web dashboard</li>")
    h.push("<li>Capability gates for tmux and terminal access</li>")
