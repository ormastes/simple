    h.push("@media (max-width: 820px) { .shell { grid-template-columns: 1fr; } .hero { padding: 28px; } .panel { padding: 28px; } }")
    h.push("</style>")
    h.push("</head>")
    h.push("<body>")
    h.push("<div class=\"shell\">")
