# LLM Dashboard Web Login
#
# File-backed multi-user login/session support for the web dashboard.
# Uses bcrypt password verification and persistent session files under
# `.build/llm_dashboard/auth`.

use std.nogc_sync_mut.io.file_ops.{file_exists, file_read, file_write, file_remove}
use std.nogc_sync_mut.io.dir_ops.{dir_create_all, dir_list}
use std.nogc_sync_mut.io.env_ops.{env_get}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.common.bcrypt.hash.{bcrypt_hash}
use std.common.bcrypt.verify.{bcrypt_verify}
use std.nogc_sync_mut.io.crypto_ffi.{random_hex}
use std.web_framework.form_parser.{parse_url_encoded}

val DASHBOARD_AUTH_ROOT = ".build/llm_dashboard/auth"
val DASHBOARD_USERS_DIR = DASHBOARD_AUTH_ROOT + "/users"
val DASHBOARD_SESSIONS_DIR = DASHBOARD_AUTH_ROOT + "/sessions"
val DASHBOARD_SESSION_COOKIE = "llm_dashboard_session"
val DASHBOARD_SESSION_TTL_MS: i64 = 12 * 60 * 60 * 1000

class DashboardAuthUser:
    username: text
    password_hash: text
    role: text
    capabilities: [text]
    created_at_ms: i64
    last_login_ms: i64

class DashboardAuthSession:
    session_id: text
    username: text
    role: text
    capabilities: [text]
    created_at_ms: i64
    expires_at_ms: i64
    last_seen_ms: i64

fn auth_ensure_bootstrap():
    _ensure_auth_dirs()
    val entries = dir_list(DASHBOARD_USERS_DIR)
    if entries.len() > 0:
        return

    val env_user = env_get("SIMPLE_LLM_DASHBOARD_ADMIN_USER") ?? ""
    val env_password = env_get("SIMPLE_LLM_DASHBOARD_ADMIN_PASSWORD") ?? ""
    val username = _first_non_empty([
        env_user,
        "admin"
    ])
    val password = _first_non_empty([
        env_password,
        "llm-dashboard"
    ])
    val now = current_time_ms()
    val user = DashboardAuthUser(
        username: username,
        password_hash: bcrypt_hash(password, 12),
        role: "admin",
        capabilities: _default_admin_capabilities(),
        created_at_ms: now,
        last_login_ms: 0
    )
    val _ = _save_user(user)
    print "LLM dashboard bootstrap user created: {username}"
    print "LLM dashboard bootstrap password: {password}"
    if env_password == "":
        print "WARNING: using default bootstrap password for local development only."

fn auth_authenticate_form(body: text) -> (DashboardAuthSession?, text, text):
    auth_ensure_bootstrap()
    val params = parse_url_encoded(body)
    val username = params.get("username") ?? ""
    val password = params.get("password") ?? ""

    if username.trim() == "" or password.trim() == "":
        return (nil, "Enter your username and password.", username)

    if val user = _load_user(username.trim()):
        if bcrypt_verify(password, user.password_hash):
            val session = _issue_session(user)
            return (session, "", user.username)
    return (nil, "Invalid username or password.", username)

fn auth_session_from_headers(headers: text) -> DashboardAuthSession?:
    val session_id = _extract_cookie(headers, DASHBOARD_SESSION_COOKIE)
    if session_id == "":
        return nil
    if val session = _load_session(session_id):
        if session.expires_at_ms <= current_time_ms():
            auth_delete_session(session.session_id)
            return nil
        var refreshed = session
        refreshed.last_seen_ms = current_time_ms()
        val _ = _save_session(refreshed)
        return refreshed
    nil

fn auth_delete_session(session_id: text):
    if session_id.trim() == "":
        return
    val _ = file_remove(_session_path(session_id))

fn auth_has_capability(session: DashboardAuthSession, capability: text) -> bool:
    if session.role == "admin":
        return true
    session.capabilities.contains(capability)

