    h.push(".hero p { margin: 0 0 22px; color: #d7e3ee; line-height: 1.6; }")
    h.push(".hero ul { margin: 0; padding-left: 18px; color: #bdd0e0; line-height: 1.7; }")
    h.push(".panel { padding: 42px 34px; background: rgba(9, 12, 16, 0.92); }")
    h.push(".eyebrow { color: #7aa2c9; text-transform: uppercase; letter-spacing: 0.18em; font-size: 11px; margin-bottom: 10px; }")
