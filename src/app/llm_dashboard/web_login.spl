    var h: [text] = []
    h.push("<!DOCTYPE html>")
    h.push("<html lang=\"en\">")
    h.push("<head>")
    h.push("<meta charset=\"utf-8\">")
    h.push("<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">")
    h.push("<title>LLM Dashboard Login</title>")
    h.push("<style>")
    h.push("body { margin: 0; min-height: 100vh; font-family: 'Segoe UI', Helvetica, Arial, sans-serif; background: radial-gradient(circle at top, #16324a 0%, #0d1117 42%, #090c10 100%); color: #e6edf3; display: flex; align-items: center; justify-content: center; }")
    h.push(".shell { width: min(960px, calc(100vw - 32px)); display: grid; grid-template-columns: 1.15fr 0.85fr; background: rgba(14, 20, 27, 0.92); border: 1px solid rgba(122, 162, 201, 0.18); border-radius: 18px; overflow: hidden; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45); }")
