    h.push("input { width: 100%; padding: 12px 13px; margin-bottom: 14px; border-radius: 10px; border: 1px solid #29445c; background: #0f1821; color: #e6edf3; font-size: 14px; }")
    h.push("input:focus { outline: none; border-color: #7aa2c9; box-shadow: 0 0 0 3px rgba(122, 162, 201, 0.16); }")
    h.push("button { width: 100%; padding: 12px 14px; border: none; border-radius: 10px; background: linear-gradient(135deg, #7aa2c9, #3f6d97); color: #071019; font-size: 14px; font-weight: 700; cursor: pointer; }")
    h.push("button:hover { filter: brightness(1.05); }")
