fn auth_login_page(message: text) -> text:
    var html = "<!DOCTYPE html><html><head><title>LLM Dashboard Login</title></head><body>"
    html = html + "<h1>LLM Dashboard Login</h1>"
    if message != "":
        html = html + "<p class=\"error\">" + message + "</p>"
    html = html + "<form method=\"POST\" action=\"/login\">"
    html = html + "<input name=\"username\" autocomplete=\"username\">"
    html = html + "<input name=\"password\" type=\"password\" autocomplete=\"current-password\">"
    html = html + "<button type=\"submit\">Log in</button>"
    html = html + "</form></body></html>"
    html
