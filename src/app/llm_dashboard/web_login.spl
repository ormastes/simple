    h.join("\n")

fn auth_login_cookie_header(session: DashboardAuthSession) -> text:
    val max_age = (session.expires_at_ms - current_time_ms()) / 1000
    "Set-Cookie: {DASHBOARD_SESSION_COOKIE}={session.session_id}; Path=/; Max-Age={max_age}; HttpOnly; SameSite=Lax"

fn auth_clear_cookie_header() -> text:
    "Set-Cookie: {DASHBOARD_SESSION_COOKIE}=; Path=/; Max-Age=0; HttpOnly; SameSite=Lax"

fn auth_identity_html(session: DashboardAuthSession) -> text:
    "<span>{_html_escape(session.username)}</span><a href=\"/logout\">Log out</a>"

fn _issue_session(user: DashboardAuthUser) -> DashboardAuthSession:
    var updated_user = user
    updated_user.last_login_ms = current_time_ms()
    val _ = _save_user(updated_user)

    val now = current_time_ms()
    val session = DashboardAuthSession(
        session_id: random_hex(24),
        username: user.username,
        role: user.role,
        capabilities: user.capabilities,
        created_at_ms: now,
        expires_at_ms: now + DASHBOARD_SESSION_TTL_MS,
        last_seen_ms: now
    )
    val _ = _save_session(session)
    session

fn _load_user(username: text) -> DashboardAuthUser?:
    val path = _user_path(username)
    if not file_exists(path):
        return nil
    val record = _parse_record(file_read(path))
    if record.get("username") == nil:
        return nil
    DashboardAuthUser(
        username: record.get("username") ?? username,
        password_hash: record.get("password_hash") ?? "",
        role: record.get("role") ?? "viewer",
        capabilities: _parse_csv(record.get("capabilities") ?? ""),
        created_at_ms: (record.get("created_at_ms") ?? "0").to_i64() ?? 0,
        last_login_ms: (record.get("last_login_ms") ?? "0").to_i64() ?? 0
    )

fn _save_user(user: DashboardAuthUser) -> bool:
    _ensure_auth_dirs()
    var content: [text] = []
    content.push("username={user.username}")
    content.push("password_hash={user.password_hash}")
    content.push("role={user.role}")
    content.push("capabilities={user.capabilities.join(\",\")}")
    content.push("created_at_ms={user.created_at_ms}")
    content.push("last_login_ms={user.last_login_ms}")
    file_write(_user_path(user.username), content.join("\n") + "\n")

fn _load_session(session_id: text) -> DashboardAuthSession?:
    val path = _session_path(session_id)
    if not file_exists(path):
        return nil
    val record = _parse_record(file_read(path))
    if record.get("session_id") == nil:
        return nil
    DashboardAuthSession(
        session_id: record.get("session_id") ?? session_id,
        username: record.get("username") ?? "",
        role: record.get("role") ?? "viewer",
        capabilities: _parse_csv(record.get("capabilities") ?? ""),
        created_at_ms: (record.get("created_at_ms") ?? "0").to_i64() ?? 0,
        expires_at_ms: (record.get("expires_at_ms") ?? "0").to_i64() ?? 0,
        last_seen_ms: (record.get("last_seen_ms") ?? "0").to_i64() ?? 0
    )

fn _save_session(session: DashboardAuthSession) -> bool:
    _ensure_auth_dirs()
    var content: [text] = []
    content.push("session_id={session.session_id}")
    content.push("username={session.username}")
    content.push("role={session.role}")
    content.push("capabilities={session.capabilities.join(\",\")}")
    content.push("created_at_ms={session.created_at_ms}")
    content.push("expires_at_ms={session.expires_at_ms}")
    content.push("last_seen_ms={session.last_seen_ms}")
    file_write(_session_path(session.session_id), content.join("\n") + "\n")

fn _ensure_auth_dirs():
    val _ = dir_create_all(DASHBOARD_USERS_DIR)
    val _ = dir_create_all(DASHBOARD_SESSIONS_DIR)

fn _user_path(username: text) -> text:
    "{DASHBOARD_USERS_DIR}/{_safe_key(username)}.sdn"

fn _session_path(session_id: text) -> text:
    "{DASHBOARD_SESSIONS_DIR}/{_safe_key(session_id)}.sdn"

fn _safe_key(input: text) -> text:
    var out = ""
    var i = 0
    while i < input.len():
        val ch = input[i]
        if _is_safe_key_char(ch):
            out = "{out}{ch}"
        else:
            out = "{out}_"
        i = i + 1
    if out == "":
        return "empty"
    out

fn _is_safe_key_char(ch: text) -> bool:
    if ch == "_" or ch == "-" or ch == ".":
        return true
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    false

fn _parse_record(content: text) -> Dict<text, text>:
    var result: Dict<text, text> = {}
    for raw_line in content.split("\n"):
        val line = raw_line.trim()
        if line == "" or line.starts_with("#"):
            pass_dn
        else:
            val pos = line.index_of("=")
            if pos > 0:
                val key = line[0:pos].trim()
                val value = line[pos + 1:].trim()
                result[key] = value
    result

fn _parse_csv(raw: text) -> [text]:
    var out: [text] = []
    if raw.trim() == "":
        return out
    for item in raw.split(","):
        val trimmed = item.trim()
        if trimmed != "":
            out.push(trimmed)
    out

fn _extract_cookie(headers: text, name: text) -> text:
    for raw_line in headers.split("\n"):
        val line = raw_line.trim()
        if line.to_lower().starts_with("cookie:"):
            val cookie_blob = line[7:].trim()
            for part in cookie_blob.split(";"):
                val cookie = part.trim()
                val pos = cookie.index_of("=")
                if pos > 0:
                    val key = cookie[0:pos].trim()
                    val value = cookie[pos + 1:].trim()
                    if key == name:
                        return value
    ""

fn _default_admin_capabilities() -> [text]:
    [
        "dashboard.view",
        "dashboard.agents.view",
        "dashboard.tasks.view",
        "dashboard.terminal.use",
        "dashboard.tmux.use"
    ]

fn _first_non_empty(values: [text]) -> text:
    for value in values:
        if value.trim() != "":
            return value.trim()
    ""

fn _html_escape(input: text) -> text:
    var out = input
    out = out.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out
