# WebSocket Handler
#
# Handles WebSocket connections for real-time dashboard updates.
# Sends refresh events when new JSONL data is detected.

use app.llm_dashboard.data.store.{AgentDashboardStore}
use app.llm_dashboard.data.types.{format_tokens, provider_name}
use std.json.builder.{escape_json}

# =========================================================================
# WebSocket Message Types
# =========================================================================

fn ws_refresh_message() -> text:
    """Generate a WebSocket refresh message."""
    return "{\"type\":\"refresh\"}"

fn ws_status_message(store: AgentDashboardStore) -> text:
    """Generate a WebSocket status update message with current state."""
    var providers = "["
    var first = true
    for status in store.llm_statuses:
        if not first:
            providers = "{providers},"
        val pname = escape_json(provider_name(status.provider))
        val model = escape_json(status.model)
        val tokens = status.tokens_used
        val connected = if status.connected: "true" else: "false"
        providers = "{providers}{\"name\":\"{pname}\",\"connected\":{connected},\"model\":\"{model}\",\"tokens\":{tokens}}"
        first = false
    providers = "{providers}]"

    val agents = store.tree.agent_count()
    val files_r = store.total_files_read()
    val files_w = store.total_files_written()
    val urls = store.total_urls()

    return "{\"type\":\"status\",\"providers\":{providers},\"agents\":{agents},\"files_read\":{files_r},\"files_written\":{files_w},\"urls\":{urls}}"

# =========================================================================
# Agent WebSocket Handler
# =========================================================================

class AgentWsHandler:
    store: AgentDashboardStore
    last_event_count: i64

    static fn new(store: AgentDashboardStore) -> AgentWsHandler:
        return AgentWsHandler(
            store: store,
            last_event_count: 0
        )

impl AgentWsHandler:

    fn has_updates() -> bool:
        """Check if there are new events since last check."""
        return self.store.total_events > self.last_event_count

    me check_and_get_message() -> text?:
        """Poll for updates and return a WebSocket message if new data exists."""
        self.store.poll()

        if self.store.total_events > self.last_event_count:
            self.last_event_count = self.store.total_events
            return ws_status_message(self.store)

        return nil

    fn get_full_status() -> text:
        """Get full status message for initial WebSocket connection."""
        return ws_status_message(self.store)
