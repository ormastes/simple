# HTML Views
#
# Full HTML page generation for the LLM Agent Dashboard GUI.
# Combines room grid, agent tree, activity feed, and status bar.

use app.llm_dashboard.data.store.{AgentDashboardStore}
use app.llm_dashboard.data.env_collector.{env_collect, detect_project_dir}
use app.llm_dashboard.gui.css_sprites.{generate_agent_css, generate_room_css}
use app.llm_dashboard.gui.room_layout_html.{generate_room_grid, generate_agent_tree_html,
    generate_status_bar_html, generate_feed_html}
use app.llm_dashboard.gui.terminal_panel.{generate_terminal_panel_html, generate_terminal_css, generate_terminal_js}
use app.llm_dashboard.gui.tmux_panel.{handle_tmux_api}
use app.llm_dashboard.gui.env_panel_html.{generate_env_panel_html, generate_env_panel_css}

# =========================================================================
# Full Page HTML
# =========================================================================

fn generate_agents_html(store: AgentDashboardStore) -> text:
    """Generate the full HTML page for the agent dashboard.

    Includes three tabs: Agents (room grid + tree + feed), Terminal, and Tmux.
    Terminal and Tmux panels are ported from the former web_dashboard app.
    """
    val css = generate_agents_css()
    val room_grid = generate_room_grid(store)
    val agent_tree = generate_agent_tree_html(store)
    val feed = generate_feed_html(store, 50)
    val status_bar = generate_status_bar_html(store)
    val term_html = generate_terminal_panel_html()
    val term_js = generate_terminal_js()
    val env_data = env_collect(detect_project_dir())
    val env_html = generate_env_panel_html(env_data)

    val html_head = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LLM Agent Dashboard</title>
<style>"""
    val html_mid = """</style>
</head>
<body>
<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>LLM Agent Dashboard</h1>
        <nav class="tab-bar">
            <button class="tab-btn active" onclick="switchTab('agents', this)">Agents</button>
            <button class="tab-btn" onclick="switchTab('environment', this)">Environment</button>
            <button class="tab-btn" onclick="switchTab('terminal', this)">Terminal</button>
        </nav>
        <div id="refresh-status" class="refresh-status">Auto-refresh: 2s</div>
    </header>

    <div id="tab-agents" class="tab-content active">
    <div class="main-content">
        <div class="left-panel">
"""
    val html_right = """        </div>
        <div class="right-panel">
            <h3>Agent Hierarchy</h3>
"""
    val html_bottom = """        </div>
    </div>

    <div class="bottom-panel">
        <h3>Activity Feed</h3>
"""
    val html_tail = """    </div>

"""
    val html_agents_close = """    </div>

    <div id="tab-environment" class="tab-content">
"""
    val html_env_close = """    </div>

    <div id="tab-terminal" class="tab-content">
"""
    val html_terminal_close = """    </div>
"""

    val html_script = """</div>

<script>
// Tab switching
function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    if (btn) btn.classList.add('active');
    if (name === 'terminal') loadTmuxSessions();
}

// Auto-refresh via WebSocket or polling
(function() {
    var ws = null;
    var wsUrl = 'ws://' + window.location.host + '/ws/agents';

    function connectWs() {
        try {
            ws = new WebSocket(wsUrl);
            ws.onmessage = function(e) {
                var data = JSON.parse(e.data);
                if (data.type === 'refresh') {
                    window.location.reload();
                }
            };
            ws.onclose = function() {
                setTimeout(connectWs, 3000);
            };
        } catch(e) {
            // Fallback to polling
            setTimeout(function() { window.location.reload(); }, 2000);
        }
    }

    connectWs();

    // Fallback polling
    setTimeout(function() {
        if (!ws || ws.readyState !== WebSocket.OPEN) {
            setInterval(function() { window.location.reload(); }, 2000);
        }
    }, 5000);
})();

"""
    val html_end = """</script>
</body>
</html>"""
    return html_head + css + html_mid + room_grid + html_right + agent_tree + html_bottom + feed + html_tail + status_bar + html_agents_close + env_html + html_env_close + term_html + html_terminal_close + html_script + term_js + html_end

fn generate_agents_css() -> text:
    """Generate combined CSS for the agent dashboard."""
    val sprite_css = generate_agent_css()
    val room_css = generate_room_css()

    val base_css = """
/* Base Styles */
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace;
    background: #0d1117;
    color: #c9d1d9;
    padding-bottom: 40px;
    min-height: 100vh;
}

.dashboard-container { padding: 8px; }

.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    border-bottom: 1px solid #30363d;
    margin-bottom: 8px;
}

.dashboard-header h1 {
    font-size: 18px;
    color: #58a6ff;
}

.refresh-status {
    font-size: 12px;
    color: #8b949e;
}

.main-content {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
    align-items: flex-start;
}

.left-panel { flex: 2; }
.right-panel { flex: 1; }
.left-panel, .right-panel { min-width: 0; }

.right-panel h3, .bottom-panel h3 {
    font-size: 14px;
    color: #8b949e;
    margin-bottom: 4px;
}

.bottom-panel {
    margin-bottom: 48px;
    min-width: 0;
}

@media (max-width: 1100px) {
    .main-content {
        flex-direction: column;
    }

    .left-panel, .right-panel {
        width: 100%;
    }
}

@media (max-width: 720px) {
    .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
        padding: 8px 12px;
    }

    .dashboard-header h1 {
        font-size: 16px;
    }
}
"""
    val tab_css = """
/* Tab Bar */
.tab-bar { display: flex; gap: 4px; }
.tab-btn {
    background: transparent;
    border: 1px solid #30363d;
    color: #8b949e;
    padding: 4px 14px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
}
.tab-btn:hover { color: #c9d1d9; border-color: #58a6ff; }
.tab-btn.active { background: #58a6ff; color: #fff; border-color: #58a6ff; }
.tab-content { display: none; }
.tab-content.active { display: block; }
"""
    val term_css = generate_terminal_css()
    val env_css = generate_env_panel_css()
    return base_css + sprite_css + room_css + tab_css + term_css + env_css
