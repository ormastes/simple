# Panel Common CSS
#
# Shared design tokens and utility classes used by every gui/*_panel_html
# generator (stats/cache/message/mcp/tasks/env panels). Centralizes card
# style, spacing, and status colors (ok/warn/critical) so panels share one
# look instead of each hardcoding its own hex values, plus the toolbar and
# empty/error states used by per-panel fragment refresh (/api/panel/<name>).

fn generate_panel_common_css() -> text:
    """Shared CSS tokens + utility classes used by every gui/*_panel_html generator."""
    """
:root {
  --panel-bg: #161b22;
  --panel-bg-alt: #0d1117;
  --panel-border: #30363d;
  --panel-border-alt: #21262d;
  --panel-text: #e6edf3;
  --panel-text-dim: #8b949e;
  --panel-accent: #58a6ff;
  --panel-ok: #3fb950;
  --panel-warn: #d29922;
  --panel-critical: #f85149;
}

.panel-card {
  background: var(--panel-bg);
  border: 1px solid var(--panel-border);
  border-radius: 8px;
}

.status-ok { color: var(--panel-ok); }
.status-warn { color: var(--panel-warn); }
.status-critical { color: var(--panel-critical); }

.panel-wrap { margin-bottom: 4px; }

.panel-toolbar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 2px 2px 8px;
  font-size: 0.75rem;
  color: var(--panel-text-dim);
}
.panel-refresh-btn {
  background: transparent;
  border: 1px solid var(--panel-border);
  color: var(--panel-text-dim);
  border-radius: 4px;
  padding: 2px 10px;
  cursor: pointer;
  font-size: 0.75rem;
}
.panel-refresh-btn:hover {
  border-color: var(--panel-accent);
  color: var(--panel-text);
}
.panel-updated {
  font-size: 0.72rem;
  color: var(--panel-text-dim);
}

.panel-empty {
  color: var(--panel-text-dim);
  font-size: 0.85rem;
  padding: 16px;
  text-align: center;
  border: 1px dashed var(--panel-border);
  border-radius: 8px;
}
.panel-error {
  color: var(--panel-critical);
  font-size: 0.85rem;
  padding: 12px 16px;
  border: 1px solid var(--panel-critical);
  border-radius: 8px;
  background: rgba(248, 81, 73, 0.08);
}

/* Responsive: stack to a single column at narrow (mobile) widths. */
@media (max-width: 700px) {
  .main-content { flex-direction: column; }
  .left-panel, .right-panel { width: 100%; box-sizing: border-box; }
  .stats-grid, .env-grid, .cache-gauge-row { grid-template-columns: 1fr !important; }
  .obs-layout { flex-direction: column; }
  .form-row { flex-direction: column; align-items: stretch; }
  .task-card { flex-direction: column; gap: 8px; }
  .panel-toolbar { justify-content: space-between; }
  .tab-bar { flex-wrap: wrap; }
}
"""

export generate_panel_common_css
