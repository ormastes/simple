# Panel Common HTML
#
# Shared fragment-refresh chrome for gui/*_panel_html generators: a toolbar
# (manual refresh button + "updated Ns ago" stamp) plus styled empty/error
# states, so every panel served by /api/panel/<name> looks and behaves the
# same way instead of each panel inventing its own "no data" markup.

fn panel_html_escape(value: text) -> text:
    var escaped = value.split("&").join("&amp;")
    escaped = escaped.split("<").join("&lt;")
    escaped = escaped.split(">").join("&gt;")
    escaped.split("\"").join("&quot;")

fn panel_toolbar_html(name: text) -> text:
    """Manual refresh button + 'updated Ns ago' stamp for one named panel."""
    val safe_name = panel_html_escape(name)
    "<div class=\"panel-toolbar\"><span class=\"panel-updated\" data-panel-updated=\"{safe_name}\">updated just now</span><button class=\"panel-refresh-btn\" type=\"button\" onclick=\"refreshPanel('{safe_name}')\">Refresh</button></div>"

fn panel_wrap_html(name: text, body: text) -> text:
    """Wrap a panel body with the shared toolbar + a stable #panel-<name> mount
    point that /api/panel/<name> fragment responses get swapped into."""
    val safe_name = panel_html_escape(name)
    "<div class=\"panel-wrap\" data-panel-wrap=\"{safe_name}\">{panel_toolbar_html(name)}<div id=\"panel-{safe_name}\">{body}</div></div>"

fn panel_empty_html(message: text) -> text:
    """Styled empty state, e.g. 'No MCP server calls captured yet.'"""
    "<div class=\"panel-empty\">{message}</div>"

fn panel_error_html(reason: text) -> text:
    """Styled 'collector unavailable' state for a panel that could not be rendered."""
    "<div class=\"panel-error\">collector unavailable: {panel_html_escape(reason)}</div>"

export panel_html_escape, panel_toolbar_html, panel_wrap_html, panel_empty_html, panel_error_html
