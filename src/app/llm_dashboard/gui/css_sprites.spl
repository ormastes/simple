fn llm_dashboard_responsive_css() -> text:
    """
@media (max-width: 1100px) {
  .agent-grid { grid-template-columns: 1fr 1fr 1fr; }
}
@media (max-width: 720px) {
  .agent-grid { grid-template-columns: 1fr 1fr; }
  .agent-detail { grid-template-columns: 1fr; }
}
"""

fn generate_agent_css() -> text:
    llm_dashboard_responsive_css()

fn generate_room_css() -> text:
    """
.room-grid { display: grid; gap: 12px; }
.room-card { border: 1px solid var(--border, rgba(255,255,255,0.10)); border-radius: 8px; }
.agent-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
"""

export llm_dashboard_responsive_css, generate_agent_css, generate_room_css
