# Room Definitions
#
# Defines room types, tool-to-room routing, and room content rendering.
# Each room displays contextually relevant agent activity.

use app.llm_dashboard.data.types.{RoomKind, room_name, tool_to_room, ActivityEntry, format_timestamp, truncate_text}
use app.llm_dashboard.tui.colors.{room_color}
use app.ui.render.ansi.{RESET, DIM, BOLD}

# =========================================================================
# Room State
# =========================================================================

class RoomState:
    kind: RoomKind
    title: text
    content_lines: [text]
    agent_count: i32
    active: bool

    static fn new(kind: RoomKind) -> RoomState:
        return RoomState(
            kind: kind,
            title: room_name(kind),
            content_lines: [],
            agent_count: 0,
            active: false
        )

# =========================================================================
# Room Rendering
# =========================================================================

fn render_room_content(room: RoomState, max_lines: i32) -> [text]:
    """Get room content limited to max_lines."""
    if room.content_lines.len() <= max_lines:
        return room.content_lines
    return room.content_lines.slice(room.content_lines.len() - max_lines)

fn render_room_header(room: RoomState) -> text:
    """Render room title with color and agent count."""
    val color = room_color(room.kind)
    val count_str = if room.agent_count > 0: " ({room.agent_count})" else: ""
    return "{color}{BOLD}{room.title}{RESET}{DIM}{count_str}{RESET}"

# =========================================================================
# Room Content Builders
# =========================================================================

fn build_room_content(kind: RoomKind, entries: [ActivityEntry], max_lines: i32) -> [text]:
    """Build content lines for any room, filtering entries and formatting per room type."""
    val target = room_name(kind)
    var lines: [text] = []
    var count = 0
    var i = entries.len() - 1
    while i >= 0 and count < max_lines:
        val e = entries[i]
        if room_name(e.room) == target:
            lines.push(format_room_entry(kind, e))
            count = count + 1
        i = i - 1
    return lines

fn format_room_entry(kind: RoomKind, e: ActivityEntry) -> text:
    """Format an activity entry for display in its room."""
    match kind:
        RoomKind.Research:
            val time = format_timestamp(e.timestamp)
            val s = truncate_text(e.summary, 40)
            return "{DIM}{time}{RESET} {s}"
        RoomKind.Code:
            val icon = match e.tool_name:
                "Read" => "R"
                "Write" => "W"
                "Edit" => "E"
                "Grep" => "?"
                "Glob" => "G"
                _ => ">"
            return " {icon} {truncate_text(e.summary, 38)}"
        RoomKind.Skills:
            return " /{e.summary}"
        _:
            return " {truncate_text(e.summary, 38)}"

# truncate_text imported from data.types

# Backward-compatible wrappers (used by tui/app.spl)
fn build_research_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    return build_room_content(RoomKind.Research, entries, max_lines)

fn build_code_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    return build_room_content(RoomKind.Code, entries, max_lines)

fn build_skills_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    return build_room_content(RoomKind.Skills, entries, max_lines)

fn build_server_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    return build_room_content(RoomKind.Server, entries, max_lines)

# =========================================================================
# Room Set
# =========================================================================

fn create_room_set() -> [RoomState]:
    """Create the default set of rooms."""
    var rooms: [RoomState] = []
    rooms.push(RoomState.new(RoomKind.Research))
    rooms.push(RoomState.new(RoomKind.Code))
    rooms.push(RoomState.new(RoomKind.Skills))
    rooms.push(RoomState.new(RoomKind.Server))
    rooms.push(RoomState.new(RoomKind.Chat))
    rooms.push(RoomState.new(RoomKind.TestLab))
    return rooms
