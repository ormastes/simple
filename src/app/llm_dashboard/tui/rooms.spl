# Room Definitions
#
# Defines room types, tool-to-room routing, and room content rendering.
# Each room displays contextually relevant agent activity.

use app.llm_dashboard.data.types.{RoomKind, room_name, tool_to_room, ActivityEntry, format_timestamp}
use app.llm_dashboard.tui.colors.{room_color}
use dashboard.render.colors.{RESET, DIM, BOLD}

# =========================================================================
# Room State
# =========================================================================

class RoomState:
    kind: RoomKind
    title: text
    content_lines: [text]
    agent_count: i32
    active: bool

    static fn new(kind: RoomKind) -> RoomState:
        return RoomState(
            kind: kind,
            title: room_name(kind),
            content_lines: [],
            agent_count: 0,
            active: false
        )

# =========================================================================
# Room Rendering
# =========================================================================

fn render_room_content(room: RoomState, max_lines: i32) -> [text]:
    """Get room content limited to max_lines."""
    if room.content_lines.len() <= max_lines:
        return room.content_lines
    return room.content_lines.slice(room.content_lines.len() - max_lines)

fn render_room_header(room: RoomState) -> text:
    """Render room title with color and agent count."""
    val color = room_color(room.kind)
    val count_str = if room.agent_count > 0: " ({room.agent_count})" else: ""
    return "{color}{BOLD}{room.title}{RESET}{DIM}{count_str}{RESET}"

# =========================================================================
# Room Content Builders
# =========================================================================

fn build_research_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    """Build content lines for the Research room."""
    var lines: [text] = []
    var count = 0
    var i = entries.len() - 1
    while i >= 0 and count < max_lines:
        val e = entries[i]
        match e.room:
            RoomKind.Research:
                val time = format_timestamp(e.timestamp)
                if e.summary.len() > 40:
                    lines.push("{DIM}{time}{RESET} {e.summary.slice(0, 37)}...")
                else:
                    lines.push("{DIM}{time}{RESET} {e.summary}")
                count = count + 1
            _: pass_dn
        i = i - 1
    return lines

fn build_code_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    """Build content lines for the Code room."""
    var lines: [text] = []
    var count = 0
    var i = entries.len() - 1
    while i >= 0 and count < max_lines:
        val e = entries[i]
        match e.room:
            RoomKind.Code:
                val icon = match e.tool_name:
                    "Read" => "R"
                    "Write" => "W"
                    "Edit" => "E"
                    "Grep" => "?"
                    "Glob" => "G"
                    _ => ">"
                if e.summary.len() > 38:
                    lines.push(" {icon} {e.summary.slice(0, 35)}...")
                else:
                    lines.push(" {icon} {e.summary}")
                count = count + 1
            _: pass_dn
        i = i - 1
    return lines

fn build_skills_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    """Build content lines for the Skills room."""
    var lines: [text] = []
    var count = 0
    var i = entries.len() - 1
    while i >= 0 and count < max_lines:
        val e = entries[i]
        match e.room:
            RoomKind.Skills:
                lines.push(" /{e.summary}")
                count = count + 1
            _: pass_dn
        i = i - 1
    return lines

fn build_server_content(entries: [ActivityEntry], max_lines: i32) -> [text]:
    """Build content lines for the Servers room."""
    var lines: [text] = []
    var count = 0
    var i = entries.len() - 1
    while i >= 0 and count < max_lines:
        val e = entries[i]
        match e.room:
            RoomKind.Server:
                var display = e.summary
                if display.len() > 38:
                    display = "{display.slice(0, 35)}..."
                lines.push(" {display}")
                count = count + 1
            _: pass_dn
        i = i - 1
    return lines

# =========================================================================
# Room Set
# =========================================================================

fn create_room_set() -> [RoomState]:
    """Create the default set of rooms."""
    var rooms: [RoomState] = []
    rooms.push(RoomState.new(RoomKind.Research))
    rooms.push(RoomState.new(RoomKind.Code))
    rooms.push(RoomState.new(RoomKind.Skills))
    rooms.push(RoomState.new(RoomKind.Server))
    rooms.push(RoomState.new(RoomKind.Chat))
    rooms.push(RoomState.new(RoomKind.TestLab))
    return rooms
