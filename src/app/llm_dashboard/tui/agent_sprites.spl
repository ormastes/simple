use app.llm_dashboard.data.types.{AgentActivity, LLMProvider}

pub fn provider_head(provider: LLMProvider) -> text:
    match provider:
        case LLMProvider.Claude:
            "C"
        case LLMProvider.Codex:
            "X"
        case LLMProvider.Gemini:
            "G"
        case LLMProvider.Unknown(_):
            "?"

pub fn agent_indicator(provider: LLMProvider, activity: AgentActivity) -> text:
    match activity:
        case AgentActivity.Idle:
            "."
        case AgentActivity.Thinking:
            "*"
        case AgentActivity.Finished:
            "+"
        case AgentActivity.Error(_):
            "!"
        case AgentActivity.Reading(_):
            "R"
        case AgentActivity.Writing(_):
            "W"
        case AgentActivity.Searching(_):
            "S"
        case AgentActivity.WebFetch(_):
            "F"
        case AgentActivity.ToolUse(_):
            "T"
        case AgentActivity.SubAgentSpawn(_):
            "A"

pub fn agent_sprite(provider: LLMProvider, activity: AgentActivity) -> [text]:
    val head = provider_head(provider)
    val mark = agent_indicator(provider, activity)
    ["[" + head + "]", " " + mark + " ", "/|\\"]

export agent_sprite, agent_indicator, provider_head
