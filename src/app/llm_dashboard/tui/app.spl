# TUI Application
#
# Main event loop for the TUI LLM Agent Dashboard.
# Handles keyboard input, polling, and screen refresh.

use app.ui.tui.screen.{Screen, get_terminal_size, ansi_enable_alt_screen,
    ansi_disable_alt_screen, ansi_show_cursor, ansi_hide_cursor}
use app.llm_dashboard.data.store.{AgentDashboardStore}
use app.llm_dashboard.data.types.{RoomKind, room_name, format_timestamp}
use app.llm_dashboard.tui.layout.{LayoutDims, LayoutMode, compute_layout,
    render_full_layout, render_compact_layout}
use app.llm_dashboard.tui.rooms.{RoomState, create_room_set,
    build_research_content, build_code_content, build_skills_content, build_server_content,
    build_chat_content, build_server_content_with_mcp, build_tasks_content}
use app.llm_dashboard.tui.agent_panel.{render_agent_tree}
use app.llm_dashboard.tui.activity_feed.{FeedState, render_feed}
use app.llm_dashboard.tui.status_bar.{render_status_bar, render_availability_banner}
extern fn rt_env_get(key: text) -> text

fn detect_project_dir() -> text:
    val pwd = rt_env_get("PWD")
    if pwd.len() > 0:
        return pwd
    "."
use app.ui.render.ansi.{RESET, BOLD, DIM}

extern fn rt_time_now_unix_micros() -> i64
extern fn native_enable_raw_mode() -> bool
extern fn native_disable_raw_mode() -> bool
extern fn stdin_read_char() -> text

fn current_time_secs() -> i64:
    rt_time_now_unix_micros() / 1_000_000

fn setup_raw_terminal():
    """Enter raw terminal mode for single-key input."""
    native_enable_raw_mode()

fn restore_terminal():
    """Restore normal terminal mode."""
    native_disable_raw_mode()

# =========================================================================
# TUI App State
# =========================================================================

class TuiAppState:
    store: AgentDashboardStore
    active_tab: i32
    feed_state: FeedState
    running: bool
    last_poll: i64
    poll_interval_ms: i64
    refresh_count: i64

    static fn new(store: AgentDashboardStore) -> TuiAppState:
        return TuiAppState(
            store: store,
            active_tab: 0,
            feed_state: FeedState.new(),
            running: true,
            last_poll: 0,
            poll_interval_ms: 2000,
            refresh_count: 0
        )

# =========================================================================
# Main Entry Point
# =========================================================================

fn run_tui_dashboard(store: AgentDashboardStore):
    """Run the TUI dashboard main loop."""
    var state = TuiAppState.new(store)

    # Enter raw mode + alternate screen
    setup_raw_terminal()
    print ansi_enable_alt_screen()
    print ansi_hide_cursor()

    # Initial poll
    state.store.poll()

    # Render initial frame before waiting for input
    render_frame(state)

    while state.running:
        val key = stdin_read_char()
        # Exit on EOF or quit key
        if key == "" or key == "q" or key == "Q":
            state.running = false
            break
        handle_key(state, key)

        # Poll for new data on each keypress
        val now = current_time_secs()
        if (now - state.last_poll) * 1000 >= state.poll_interval_ms:
            state.store.poll()
            state.last_poll = now

        # Re-render after input
        render_frame(state)
        state.refresh_count = state.refresh_count + 1

    # Restore terminal
    print ansi_show_cursor()
    print ansi_disable_alt_screen()
    restore_terminal()
    print "Dashboard closed."

# =========================================================================
# Frame Rendering
# =========================================================================

fn render_frame(state: TuiAppState):
    """Render a single frame of the dashboard."""
    val (width, height) = get_terminal_size()
    val dims = compute_layout(width, height)
    var screen = Screen.new(width, height)

    # Check availability
    if not state.store.is_available():
        val banner = render_availability_banner(false)
        var row = 2
        for line in banner:
            screen = screen.put_text(row, 2, line)
            row = row + 1
        print screen.render()
        return

    # Build room content
    var rooms = build_rooms(state)

    # Build tree lines
    val tree_lines = render_agent_tree(state.store.tree, dims.tree_h)

    # Build feed lines
    val feed_entries = state.store.get_feed(100)
    val feed_lines = render_feed(feed_entries, state.feed_state, dims.feed_h - 2)

    # Build status bar
    val status = render_status_bar(state.store)

    match dims.mode:
        LayoutMode.Full:
            screen = render_full_layout(screen, dims, rooms, tree_lines, feed_lines, status)
        LayoutMode.Compact:
            val active_room = if state.active_tab < rooms.len(): rooms[state.active_tab]
                else: rooms[0]
            screen = render_compact_layout(screen, dims, active_room, state.active_tab, status)

    print screen.render()

fn _set_room(rooms: [RoomState], idx: i32, lines: [text], active: bool):
    """Set room content using intermediate var to avoid indexed field assignment."""
    var room = rooms[idx]
    room.content_lines = lines
    room.active = active
    rooms[idx] = room

fn build_rooms(state: TuiAppState) -> [RoomState]:
    """Build room states with current content."""
    var rooms = create_room_set()
    val feed = state.store.activity_feed

    if rooms.len() > 0:
        _set_room(rooms, 0, build_research_content(feed, 8), state.active_tab == 0)
    if rooms.len() > 1:
        _set_room(rooms, 1, build_code_content(feed, 8), state.active_tab == 1)
    if rooms.len() > 2:
        _set_room(rooms, 2, build_skills_content(feed, 8), state.active_tab == 2)
    if rooms.len() > 3:
        _set_room(rooms, 3, build_server_content_with_mcp(feed, state.store.get_mcp_stats(), 8), state.active_tab == 3)
    if rooms.len() > 4:
        _set_room(rooms, 4, build_chat_content(feed, state.store.get_agent_messages(20), 8), state.active_tab == 4)
    if rooms.len() > 5:
        # env_collect uses env_scanner which has interpreter compat issues;
        # provide lightweight fallback content instead.
        val env_lines = ["  Environment: {detect_project_dir()}", "  (env scanner unavailable in interpreter mode)"]
        _set_room(rooms, 5, env_lines, state.active_tab == 5)
    if rooms.len() > 6:
        val tasks = state.store.get_managed_tasks()
        _set_room(rooms, 6, build_tasks_content(tasks, 8), state.active_tab == 6)

    return rooms

# =========================================================================
# Input Handling
# =========================================================================

fn handle_key(state: TuiAppState, key: text):
    """Handle a keyboard input."""
    if key == "":
        return

    match key:
        "q" => state.running = false
        "Q" => state.running = false

        # Tab switching
        "1" => state.active_tab = 0
        "2" => state.active_tab = 1
        "3" => state.active_tab = 2
        "4" => state.active_tab = 3
        "5" => state.active_tab = 4
        "6" => state.active_tab = 5
        "7" => state.active_tab = 6

        # Tab key cycles
        "\t" =>
            state.active_tab = (state.active_tab + 1) % 7

        # Scroll feed
        "j" => state.feed_state.scroll_down(1)
        "k" => state.feed_state.scroll_up(1)

        # Refresh
        "r" =>
            state.store.poll()
            state.last_poll = current_time_secs()

        # Clear filters
        "c" => state.feed_state.clear_filters()

        _ => pass_dn
