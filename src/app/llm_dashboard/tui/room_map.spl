#![allow(unnamed_duplicate_typed_args)]
# Room Map — TUI Renderer
#
# Virtual office with desks, monitors, bookshelves, and agents sitting at desks.
#
# Layout (2×3 grid):
#   ╭─ Research ─────────╮ ╭─ Code ──────────────╮ ╭─ Skills ────────────╮
#   │ ┌┬┐     C*         │ │      C>        X*   │ │ ╔═══╗    C]         │
#   │ ├┼┤    /|\         │ │     /|\       /|\   │ │ ║   ║   /|\         │
#   │ └┴┘    ┌─┐         │ │     ┌─┐       ┌─┐   │ │ ╚═══╝   ┌─┐        │
#   │        └┬┘    ·    │ │     └┬┘       └┬┘   │ │         └┬┘        │
#   │        ═══         │ │     ═══       ═══   │ │         ═══        │
#   ╰────────────────────╯ ╰─────────────────────╯ ╰────────────────────╯

use app.ui.tui.screen.{Screen}
use app.ui.render.ansi.{RESET, BOLD, DIM, FG_BLUE, FG_WHITE, FG_CYAN, FG_YELLOW, FG_GREEN}
use app.llm_dashboard.data.types.{RoomKind, AgentNode, LLMProvider, AgentActivity,
    room_name, activity_label}
use app.llm_dashboard.data.agent_position.{AgentPos, pos_agents_in_room, pos_update_from_nodes}
use app.llm_dashboard.tui.agent_sprites.{agent_sprite, SPRITE_HEIGHT, SPRITE_WIDTH}
use app.llm_dashboard.tui.office_furniture.{
    desk_with_monitor, desk_with_monitor_active,
    agent_at_desk_lines, AGENT_AT_DESK_HEIGHT, AGENT_AT_DESK_WIDTH,
    DESK_WIDTH, DESK_HEIGHT,
    FurniturePlacement,
    research_room_furniture, code_room_furniture, skills_room_furniture,
    server_room_furniture, chat_room_furniture, testlab_room_furniture,
    room_floor_char
}
use app.llm_dashboard.tui.colors.{provider_color}

# =========================================================================
# Constants
# =========================================================================

val MAP_COLS: i32 = 3
val MAP_ROWS: i32 = 2
val DESK_SLOT_W: i32 = 8     # width per desk slot (sprite + desk + gap)
val DESK_SLOT_H: i32 = 7     # height per desk slot (bubble + sprite + desk)

# =========================================================================
# Room Map Renderer
# =========================================================================

fn render_room_map(screen: Screen, start_row: i32, start_col: i32,
                   map_width: i32, map_height: i32,
                   agents: [AgentNode]) -> Screen:
    """Render the full 2×3 virtual office with desks and furniture."""
    pos_update_from_nodes(agents)

    var s = screen
    val rooms_row1 = [RoomKind.Research, RoomKind.Code, RoomKind.Skills]
    val rooms_row2 = [RoomKind.Server, RoomKind.Chat, RoomKind.TestLab]

    val room_w = map_width / MAP_COLS
    val room_h = map_height / MAP_ROWS

    # Row 1
    var col_offset = start_col
    for room in rooms_row1:
        s = render_office_room(s, start_row, col_offset, room_w, room_h, room, agents)
        col_offset = col_offset + room_w

    # Row 2
    col_offset = start_col
    for room in rooms_row2:
        s = render_office_room(s, start_row + room_h, col_offset, room_w, room_h, room, agents)
        col_offset = col_offset + room_w

    s

# =========================================================================
# Single Room Renderer (with furniture + agents at desks)
# =========================================================================

fn render_office_room(screen: Screen, row: i32, col: i32, w: i32, h: i32,
                      room: RoomKind, agents: [AgentNode]) -> Screen:
    """Render one room with rounded border, furniture, and agents at desks."""
    var s = screen
    val name = room_name(room)
    val agents_in = pos_agents_in_room(room)
    val count = agents_in.len()
    val room_color = room_accent_color(room)

    # Draw rounded border
    s = draw_rounded_border(s, row, col, w, h, name, count, room_color)

    # Draw floor dots for empty space
    s = draw_floor(s, row + 1, col + 1, w - 2, h - 2)

    # Draw room-specific static furniture
    val inner_w = w - 4
    val furniture = get_room_furniture(room, inner_w)
    for piece in furniture:
        var line_idx = 0
        for line in piece.lines:
            val frow = row + 1 + piece.row_offset + line_idx
            val fcol = col + 2 + piece.col_offset
            if frow < row + h - 1 and fcol < col + w - 1:
                s = s.put_text(frow, fcol, line)
            line_idx = line_idx + 1

    # Place agents at desk slots
    val slots_per_row = if inner_w > 0: inner_w / DESK_SLOT_W else: 1
    if slots_per_row < 1:
        return s

    var slot_idx = 0
    for pos in agents_in:
        val agent = find_agent_by_id(agents, pos.agent_id)
        if agent.id == "":
            slot_idx = slot_idx + 1
            continue

        val slot_col = (slot_idx % slots_per_row) * DESK_SLOT_W
        val slot_row_base = (slot_idx / slots_per_row) * DESK_SLOT_H

        val desk_col = col + 2 + slot_col
        val desk_row = row + 1 + slot_row_base

        # Only render if fits
        if desk_row + DESK_SLOT_H <= row + h - 1 and desk_col + DESK_SLOT_W <= col + w - 1:
            # Activity bubble (line 0)
            if pos.activity_label.len() > 0:
                val bubble = DIM + "[" + pos.activity_label + "]" + RESET
                val bubble_trunc = if pos.activity_label.len() > 6:
                    DIM + "[" + pos.activity_label.slice(0, 6) + "]" + RESET
                else:
                    bubble
                s = s.put_text(desk_row, desk_col, bubble_trunc)

            # Agent sprite (lines 1-3)
            val sprite_lines = agent_sprite(agent.provider, agent.activity)
            var line_idx = 0
            for line in sprite_lines:
                s = s.put_text(desk_row + 1 + line_idx, desk_col + 1, line)
                line_idx = line_idx + 1

            # Desk with monitor (lines 4-6)
            val is_active = not is_idle_or_done(agent.activity)
            val desk_lines = if is_active: desk_with_monitor_active() else: desk_with_monitor()
            line_idx = 0
            for line in desk_lines:
                s = s.put_text(desk_row + 4 + line_idx, desk_col + 1, line)
                line_idx = line_idx + 1

        slot_idx = slot_idx + 1

    # Draw empty desk slots for unoccupied positions
    val total_slots = if slots_per_row > 0: slots_per_row * 2 else: 2
    var empty_slot = count as i32
    while empty_slot < total_slots and empty_slot < 4:
        val slot_col = (empty_slot % slots_per_row) * DESK_SLOT_W
        val slot_row_base = (empty_slot / slots_per_row) * DESK_SLOT_H
        val desk_col = col + 2 + slot_col
        val desk_row = row + 1 + slot_row_base

        if desk_row + DESK_HEIGHT + 1 <= row + h - 1 and desk_col + DESK_WIDTH <= col + w - 1:
            val desk_lines = desk_with_monitor()
            var line_idx = 0
            for line in desk_lines:
                s = s.put_text(desk_row + 3 + line_idx, desk_col + 1, line)
                line_idx = line_idx + 1

        empty_slot = empty_slot + 1

    s

# =========================================================================
# Rounded Border (╭─╮ style)
# =========================================================================

fn draw_rounded_border(screen: Screen, row: i32, col: i32, w: i32, h: i32,
                       title: text, agent_count: i64, color: text) -> Screen:
    var s = screen
    val count_str = if agent_count > 0: " " + agent_count.to_text() else: ""
    val full_title = " " + title + count_str + " "

    # Top: ╭─ Title N ────╮
    var top: [text] = []
    top.push(color + "╭" + RESET)
    top.push(color + "─" + RESET)
    top.push(BOLD + full_title + RESET)
    val remaining = w - 3 - full_title.len()
    var r = 0
    while r < remaining:
        top.push(color + "─" + RESET)
        r = r + 1
    top.push(color + "╮" + RESET)
    s = s.put_text(row, col, top.join(""))

    # Sides
    var y = 1
    while y < h - 1:
        s = s.put_text(row + y, col, color + "│" + RESET)
        s = s.put_text(row + y, col + w - 1, color + "│" + RESET)
        y = y + 1

    # Bottom: ╰────────────╯
    var bottom: [text] = []
    bottom.push(color + "╰" + RESET)
    var b = 0
    while b < w - 2:
        bottom.push(color + "─" + RESET)
        b = b + 1
    bottom.push(color + "╯" + RESET)
    s = s.put_text(row + h - 1, col, bottom.join(""))

    s

# =========================================================================
# Floor Pattern
# =========================================================================

fn draw_floor(screen: Screen, row: i32, col: i32, w: i32, h: i32) -> Screen:
    """Draw subtle dot pattern for floor."""
    var s = screen
    var y = 0
    while y < h:
        var x = 0
        while x < w:
            # Sparse dots every 4 chars
            if (x + y) % 4 == 0:
                s = s.put_text(row + y, col + x, room_floor_char(true))
            x = x + 1
        y = y + 1
    s

# =========================================================================
# Helpers
# =========================================================================

fn room_accent_color(room: RoomKind) -> text:
    match room:
        RoomKind.Research: FG_BLUE
        RoomKind.Code: FG_GREEN
        RoomKind.Skills: FG_YELLOW
        RoomKind.Server: "\x1b[35m"    # magenta
        RoomKind.Chat: FG_YELLOW
        RoomKind.TestLab: "\x1b[35m"   # magenta

fn get_room_furniture(room: RoomKind, inner_w: i32) -> [FurniturePlacement]:
    match room:
        RoomKind.Research: research_room_furniture(inner_w)
        RoomKind.Code: code_room_furniture(inner_w)
        RoomKind.Skills: skills_room_furniture(inner_w)
        RoomKind.Server: server_room_furniture(inner_w)
        RoomKind.Chat: chat_room_furniture(inner_w)
        RoomKind.TestLab: testlab_room_furniture(inner_w)

fn is_idle_or_done(activity: AgentActivity) -> bool:
    match activity:
        AgentActivity.Idle: true
        AgentActivity.Finished: true
        _: false

fn find_agent_by_id(agents: [AgentNode], id: text) -> AgentNode:
    for agent in agents:
        if agent.id == id:
            return agent
    AgentNode.new("", LLMProvider.Unknown(name: ""), "")
