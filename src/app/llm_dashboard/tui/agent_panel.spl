# Agent Panel
#
# Renders the agent hierarchy tree panel showing parent-child
# relationships, states, and resource usage.

use app.llm_dashboard.data.types.{AgentNode, LLMProvider, AgentActivity,
    provider_name, activity_label, format_tokens}
use app.llm_dashboard.data.agent_tree.{AgentTree}
use app.llm_dashboard.tui.colors.{provider_color, activity_color}
use app.llm_dashboard.tui.agent_sprites.{agent_tree_label, agent_indicator}
use dashboard.render.colors.{RESET, BOLD, DIM}

# =========================================================================
# Tree Rendering
# =========================================================================

fn render_agent_tree(tree: AgentTree, max_lines: i32) -> [text]:
    """Render the full agent tree as indented text lines."""
    var lines: [text] = []
    val roots = tree.root_agents()

    if roots.len() == 0:
        lines.push("{DIM} No agents detected{RESET}")
        lines.push("{DIM} Waiting for JSONL transcripts...{RESET}")
        return lines

    for root in roots:
        render_agent_subtree(tree, root, 0, lines, max_lines)

    return lines

fn render_agent_subtree(tree: AgentTree, agent: AgentNode, depth: i32,
                        lines: [text], max_lines: i32):
    """Recursively render an agent and its children."""
    if lines.len() >= max_lines:
        return

    # Build indentation
    var indent = ""
    var d = 0
    while d < depth:
        indent = "{indent}  "
        d = d + 1

    # Tree connector
    val connector = if depth == 0: ">" else: "|-"

    # Agent label
    val label = agent_tree_label(agent.provider, agent.model, agent.activity, agent.id)
    val indicator = agent_indicator(agent.provider, agent.activity)

    # Resource summary
    val tokens = format_tokens(agent.token_count)
    val files_r = agent.files_read.len()
    val files_w = agent.files_written.len()
    var resource_str = ""
    if agent.token_count > 0 or files_r > 0 or files_w > 0:
        resource_str = " {DIM}{tokens} tok, {files_r}R/{files_w}W{RESET}"

    lines.push("{indent}{connector} {indicator} {label}{resource_str}")

    # File details (expandable)
    if files_r > 0 or files_w > 0:
        val file_indent = "{indent}    "
        # Show last 3 files
        var shown = 0
        var i = agent.files_read.len() - 1
        while i >= 0 and shown < 2:
            val path = agent.files_read[i]
            val short = shorten_file(path, 35)
            lines.push("{file_indent}{DIM}R {short}{RESET}")
            shown = shown + 1
            i = i - 1
        shown = 0
        i = agent.files_written.len() - 1
        while i >= 0 and shown < 2:
            val path = agent.files_written[i]
            val short = shorten_file(path, 35)
            lines.push("{file_indent}{DIM}W {short}{RESET}")
            shown = shown + 1
            i = i - 1

    # Recurse into children
    val children = tree.children_of(agent.id)
    for child in children:
        render_agent_subtree(tree, child, depth + 1, lines, max_lines)

# =========================================================================
# Helpers
# =========================================================================

fn shorten_file(path: text, max_len: i32) -> text:
    """Shorten a file path for tree display."""
    if path.len() <= max_len:
        return path
    val parts = path.split("/")
    if parts.len() <= 1:
        return "{path.slice(0, max_len - 3)}..."
    val filename = parts[parts.len() - 1]
    if filename.len() > max_len - 4:
        return "...{filename.slice(filename.len() - max_len + 6)}"
    return ".../{filename}"

fn render_agent_summary(tree: AgentTree) -> text:
    """One-line summary of all agents."""
    val agents = tree.all_agents()
    if agents.len() == 0:
        return "{DIM}No agents{RESET}"

    var parts: [text] = []
    for agent in agents:
        val ind = agent_indicator(agent.provider, agent.activity)
        parts.push(ind)

    var summary = ""
    for p in parts:
        summary = "{summary}{p}"
    return "Agents: {summary} ({agents.len()} total)"
