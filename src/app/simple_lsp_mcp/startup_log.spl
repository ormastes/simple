# MCP Startup Log Library
# Writes startup diagnostics to .simple/logs/<server>_startup.log

use std.io_runtime.{env_get, cwd, time_now_unix_micros, dir_create_all}
use std.file_system.{file_append_text}

fn mcp_startup_log(server_name: text, server_version: text):
    val cwd_val = cwd() ?? ""
    val simple_lib = env_get("SIMPLE_LIB") ?? ""
    val simple_binary = env_get("SIMPLE_BINARY") ?? ""
    val memory_limit = env_get("SIMPLE_MEMORY_LIMIT_MB") ?? "unset"
    val timeout_s = env_get("SIMPLE_TIMEOUT_SECONDS") ?? "unset"
    val log_level = env_get("SIMPLE_LOG") ?? "unset"
    val now = time_now_unix_micros() ?? 0

    val nl = "\n"
    var entry = "=== MCP Startup ===" + nl
    entry = entry + "server: " + server_name + nl
    entry = entry + "version: " + server_version + nl
    entry = entry + "timestamp_us: " + str(now) + nl
    entry = entry + "cwd: " + cwd_val + nl
    entry = entry + "simple_lib: " + simple_lib + nl
    entry = entry + "simple_binary: " + simple_binary + nl
    entry = entry + "memory_limit_mb: " + memory_limit + nl
    entry = entry + "timeout_s: " + timeout_s + nl
    entry = entry + "log_level: " + log_level + nl
    entry = entry + "==================" + nl + nl

    val log_dir = ".simple/logs"
    dir_create_all(log_dir)
    val log_path = log_dir + "/" + server_name + "_startup.log"
    file_append_text(log_path, entry)
