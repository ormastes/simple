# Simple LSP MCP Server - Simple-native replacement for the Python shim
#
# Migrated to McpServer facade (Wave C2).
# Apps own only tool handlers + wiring (design rule D5).

use .json_helpers.{LB, RB, SB_L, SB_R, jp, js, jo1, jo2}
use .tools.{
    arg_field,
    run_lsp_query, run_visibility_query, run_visibility_symbols,
    run_lsp_diagnostics, format_lsp_diagnostics_block
}
use std.mcp_sdk.server.app.{mcp_server_init, mcp_server_tool, mcp_serve}
use std.mcp_sdk.transport.transport.{StdioTransport}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use std.io_runtime.{get_args, exit}

val SERVER_NAME = "simple-lsp-mcp"
val SERVER_VERSION = "0.9.8"

fn print_usage():
    print "{SERVER_NAME} {SERVER_VERSION}"
    print ""
    print "Usage: simple_lsp_mcp_server [options]"
    print ""
    print "Runs the Simple LSP MCP JSON-RPC server over stdin/stdout."
    print ""
    print "Options:"
    print "  -v, --version         Show version"
    print "  -h, --help            Show this help"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn simple_lsp_mcp_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn simple_lsp_mcp_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if simple_lsp_mcp_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn simple_lsp_mcp_get_args() -> [text]:
    val all_args = get_args()
    var args: [text] = []
    var found = false
    var i = 0
    while i < all_args.len():
        if found:
            args.push(all_args[i])
        elif all_args[i] == "simple-lsp-mcp" or all_args[i] == "simple_lsp_mcp" or all_args[i] == "simple_lsp_mcp_server":
            found = true
        i = i + 1
    if found:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/simple_lsp_mcp/main.spl") or all_args[i] == "src/app/simple_lsp_mcp/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn make_position_schema() -> text:
    var p = LB()
    p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Path to the source file"))))
    p = p + "," + jp("line", jo2(jp("type", js("integer")), jp("description", js("0-indexed line number"))))
    p = p + "," + jp("character", jo2(jp("type", js("integer")), jp("description", js("0-indexed character offset"))))
    p = p + RB()
    var req = SB_L() + js("file") + "," + js("line") + "," + js("character") + SB_R()
    var schema = LB()
    schema = schema + jp("type", js("object"))
    schema = schema + "," + jp("properties", p)
    schema = schema + "," + jp("required", req)
    schema = schema + RB()
    schema

fn make_file_schema() -> text:
    val props = jo1(jp("file", jo2(jp("type", js("string")), jp("description", js("Path to the source file")))))
    val req = SB_L() + js("file") + SB_R()
    var schema = LB()
    schema = schema + jp("type", js("object"))
    schema = schema + "," + jp("properties", props)
    schema = schema + "," + jp("required", req)
    schema = schema + RB()
    schema

fn handle_position_tool(subcmd: text, is_visibility: bool, a: text) -> text:
    val file = arg_field(a, "file")
    val line_raw = arg_field(a, "line")
    val char_raw = arg_field(a, "character")
    if file == "" or line_raw == "" or char_raw == "":
        return "Missing required argument: file/line/character"
    val line0 = line_raw.to_int()
    val char0 = char_raw.to_int()
    if is_visibility:
        run_visibility_query(subcmd, file, line0, char0)
    else:
        run_lsp_query(subcmd, file, line0, char0)

fn main() -> i64:
    val raw_args = simple_lsp_mcp_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("simple-lsp-mcp", log_opts.error)
        return 1

    val args = simple_lsp_mcp_clean_args(raw_args)
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"simple-lsp-mcp\",\"status\":\"ready\"}"
            return 0
    else:
        val arg = args[0]
        if arg == "--version" or arg == "-v":
            if log_opts.log_mode == "json":
                print "{\"command\":\"simple-lsp-mcp\",\"status\":\"version\",\"version\":\"{SERVER_VERSION}\"}"
            else:
                print "{SERVER_NAME} {SERVER_VERSION}"
            return 0
        if arg == "--help" or arg == "-h":
            val progress = render_progress(log_opts.progress, 0, 1, "usage")
            if progress != "":
                print progress
            print_usage()
            return 0
        if arg.starts_with("-"):
            if log_opts.log_mode == "json":
                print "{\"command\":\"simple-lsp-mcp\",\"status\":\"error\",\"error\":\"unknown option\"}"
                return 1
            print "Error: Unknown option: {arg}"
            print_usage()
            return 1

    mcp_server_init(SERVER_NAME, SERVER_VERSION)

    mcp_server_tool(
        "lsp_definition",
        "Find where a symbol is defined in a Simple source file.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("definition", false, a)
    )
    mcp_server_tool(
        "lsp_references",
        "Find symbol references in Simple source.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("references", false, a)
    )
    mcp_server_tool(
        "lsp_hover",
        "Get hover information for a symbol in Simple source.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("hover", true, a)
    )
    mcp_server_tool(
        "lsp_symbols",
        "List symbols in a Simple source file.",
        fn() -> text: make_file_schema(),
        fn(a: text) -> text:
            val file = arg_field(a, "file")
            if file == "":
                return "Missing required argument: file"
            run_visibility_symbols(file)
    )
    mcp_server_tool(
        "lsp_diagnostics",
        "Run lightweight diagnostics via simple check.",
        fn() -> text: make_file_schema(),
        fn(a: text) -> text:
            val file = arg_field(a, "file")
            if file == "":
                return "Missing required argument: file"
            val raw = run_lsp_diagnostics(file)
            val diag_block = format_lsp_diagnostics_block(file, raw)
            if diag_block != "":
                raw + "\n" + diag_block
            else:
                raw
    )
    mcp_server_tool(
        "lsp_completion",
        "Get code completions at a position in a Simple source file.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("completions", true, a)
    )
    mcp_server_tool(
        "lsp_type_at",
        "Get the inferred type of a symbol at a position.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("type-at", false, a)
    )
    mcp_server_tool(
        "lsp_signature_help",
        "Get function signature information at a call site.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("signature-help", false, a)
    )
    mcp_server_tool(
        "lsp_implementation",
        "Go to implementation of a trait or interface.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("implementation", false, a)
    )
    mcp_server_tool(
        "lsp_document_highlight",
        "Highlight all occurrences of a symbol in the same file.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("document-highlight", false, a)
    )
    mcp_server_tool(
        "lsp_type_definition",
        "Navigate to the type definition of a symbol.",
        fn() -> text: make_position_schema(),
        fn(a: text) -> text: handle_position_tool("type-definition", false, a)
    )

    val t = StdioTransport.new()
    mcp_serve(t)
    0
