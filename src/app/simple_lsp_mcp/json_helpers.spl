@allow(unnamed_duplicate_typed_args)
# Simple LSP MCP Server — JSON, protocol, and transport helpers
#
# Inlined implementations that work in interpreter mode.
# The std.mcp_sdk.* imports hang in interpreter mode because the
# std/common/lib module loader blocks on stdin during resolution.
# This file provides equivalent functions using only inline code
# and extern fn declarations.

extern fn rt_stdin_read_line() -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn stdin_read_char() -> text

# --- JSON building helpers ---

fn Q() -> text:
    "\""

fn LB() -> text:
    (123 as char).to_string()

fn RB() -> text:
    (125 as char).to_string()

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

fn escape_json(s: text) -> text:
    var out = s
    out = out.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    out

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

# --- JSON parsing helpers ---

fn extract_field(json: text, key: text) -> text:
    val search = Q() + key + Q() + ":"
    val idx_opt = json.index_of(search)
    var idx = -1
    match idx_opt:
        Some(i): idx = i
        nil: return ""
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if after.starts_with(Q()):
        val rest = after.substring(1)
        val end_opt = rest.index_of(Q())
        var end_idx = -1
        match end_opt:
            Some(i): end_idx = i
            nil: return ""
        if end_idx >= 0:
            return rest.substring(0, end_idx)
    # Non-string values
    var parts: [text] = []
    for ch in after:
        if ch == "," or ch == RB() or ch == "]" or ch == " " or ch == "\n" or ch == "\r":
            break
        parts.push(ch)
    parts.join("")

fn extract_id(json: text) -> text:
    val search = Q() + "id" + Q() + ":"
    val idx_opt = json.index_of(search)
    var idx = -1
    match idx_opt:
        Some(i): idx = i
        nil: return "null"
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if after.starts_with(Q()):
        val rest = after.substring(1)
        val end_opt = rest.index_of(Q())
        var end_idx = -1
        match end_opt:
            Some(i): end_idx = i
            nil: return "null"
        if end_idx >= 0:
            return Q() + rest.substring(0, end_idx) + Q()
    # Numeric id
    var parts: [text] = []
    for ch in after:
        if ch == "," or ch == RB() or ch == "]" or ch == " " or ch == "\n" or ch == "\r":
            break
        parts.push(ch)
    parts.join("")

# --- JSON-RPC builders ---

fn jsonrpc_result(id: text, result: text) -> text:
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn jsonrpc_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", code.to_string()), jp("message", js(escape_json(message))))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

# --- Tool result helpers ---

fn make_tool_result(id: text, content: text) -> text:
    val text_obj = jo2(jp("type", js("text")), jp("text", js(escape_json(content))))
    val result = jo1(jp("content", "[" + text_obj + "]"))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn make_tool_error(id: text, message: text) -> text:
    val text_obj = jo2(jp("type", js("text")), jp("text", js(escape_json(message))))
    var result = LB()
    result = result + jp("content", "[" + text_obj + "]")
    result = result + "," + jp("isError", "true")
    result = result + RB()
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

# --- Method detection ---

fn has_method(msg: text, name: text) -> bool:
    msg.contains("\"method\":\"" + name + "\"") or msg.contains("\"method\": \"" + name + "\"")

# --- Shell helpers ---

fn find_simple_binary() -> text:
    val env_val = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_val != "":
        return env_val
    val os_env = rt_env_get("OS") ?? ""
    if os_env.contains("Windows"):
        if rt_file_exists("bin/release/simple.exe"):
            return "bin/release/simple.exe"
        return "bin/simple.exe"
    if rt_file_exists("bin/release/simple"):
        return "bin/release/simple"
    "bin/simple"

fn strip_ansi(s: text) -> text:
    var parts: [text] = []
    var in_escape = false
    for ch in s:
        if in_escape:
            if ch == "m":
                in_escape = false
            continue
        if ch == "\033" or ch == "\x1b":
            in_escape = true
            continue
        parts.push(ch)
    parts.join("")

fn clean_command_output(stdout: text) -> text:
    val lines = stdout.split("\n")
    var kept: [text] = []
    var i = 0
    while i < lines.len():
        if not lines[i].starts_with("[DEBUG] "):
            kept.push(lines[i])
        i = i + 1
    var joined = kept.join("\n")
    while joined.ends_with("\n"):
        joined = joined.substring(0, joined.len() - 1)
    joined

fn run_command_text(binary: text, args: [text]) -> text:
    val (stdout, stderr, code) = rt_process_run(binary, args)
    val clean = clean_command_output(stdout)
    if code == 0:
        return clean
    if stderr.trim() != "":
        return stderr.trim()
    if clean != "":
        return clean
    "command failed with exit code " + str(code)

# --- Stdio transport ---

# Protocol auto-detection
var _USE_JSON_LINES = false

fn _read_line() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            if result == "":
                return ""
            return result
        result = result + ch
        if ch == "\n":
            return result

fn _read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn _strip_line_end(line: text) -> text:
    if line.ends_with("\r\n"):
        return line.substring(0, line.len() - 2)
    if line.ends_with("\n"):
        return line.substring(0, line.len() - 1)
    if line.ends_with("\r"):
        return line.substring(0, line.len() - 1)
    line

fn read_stdin_message() -> text:
    var content_length = 0
    while true:
        var line = _read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        line = _strip_line_end(line)
        if line.starts_with(LB()):
            _USE_JSON_LINES = true
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = int(len_str)
    if content_length <= 0:
        return ""
    _read_chars(content_length)

fn write_stdout_message(body: text):
    val nl = "\n"
    if _USE_JSON_LINES:
        print_raw(body + nl)
    else:
        var header = "Content-Length: " + str(body.len()) + "\r" + nl + "\r" + nl
        print_raw(header)
        print_raw(body)
