@allow(unnamed_duplicate_typed_args)
# Simple LSP MCP — tool implementations

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_file_exists(path: text) -> bool

fn lsp_find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    val os_env = rt_env_get("OS") ?? ""
    if os_env.contains("Windows"):
        if rt_file_exists("bin/release/simple.exe"):
            return "bin/release/simple.exe"
        if rt_file_exists("bin/simple.exe"):
            return "bin/simple.exe"
    if rt_file_exists("bin/release/simple"):
        return "bin/release/simple"
    "bin/simple"

fn lsp_query_path() -> text:
    "src/lib/nogc_sync_mut/lsp/lsp_query.spl"

fn clean_command_output(stdout: text) -> text:
    val lines = stdout.split("\n")
    var kept: [text] = []
    var i = 0
    while i < lines.len():
        if not lines[i].starts_with("[DEBUG] "):
            kept.push(lines[i])
        i = i + 1
    var joined = kept.join("\n")
    while joined.ends_with("\n"):
        joined = joined.substring(0, joined.len() - 1)
    joined

fn run_command_text(args: [text]) -> text:
    val simple_bin = lsp_find_simple_binary()
    val (stdout, stderr, code) = rt_process_run(simple_bin, args)
    val clean = clean_command_output(stdout)
    if code == 0:
        return clean
    if stderr.trim() != "":
        return stderr.trim()
    if clean != "":
        return clean
    "command failed with exit code " + str(code)

fn run_lsp_query(subcmd: text, file: text, line0: i64, char0: i64) -> text:
    run_command_text([lsp_query_path(), subcmd, file, str(line0 + 1), str(char0 + 1)])

fn run_lsp_symbols(file: text) -> text:
    run_command_text([lsp_query_path(), "symbols", file])

fn run_lsp_diagnostics(file: text) -> text:
    run_command_text(["lint", file])

fn lsp_strip_ansi(s: text) -> text:
    var parts: [text] = []
    var in_escape = false
    for ch in s:
        if in_escape:
            if ch == "m":
                in_escape = false
            continue
        if ch == "\033" or ch == "\x1b":
            in_escape = true
            continue
        parts.push(ch)
    parts.join("")

fn lsp_parse_diag_line(line: text) -> text:
    # Parses: path:line:col: error/warning: message
    val clean = lsp_strip_ansi(line)
    val trimmed = clean.trim()
    if trimmed == "":
        return ""

    var colon1 = -1
    var colon2 = -1
    var colon3 = -1
    var pos = 0
    for ch in trimmed:
        if ch == ":":
            if colon1 < 0:
                colon1 = pos
            elif colon2 < 0:
                colon2 = pos
            elif colon3 < 0:
                colon3 = pos
                break
        pos = pos + 1

    if colon3 < 0:
        return ""

    val line_str = trimmed.substring(colon1 + 1, colon2).trim()
    val col_str = trimmed.substring(colon2 + 1, colon3).trim()
    val line_num = line_str.to_int()
    if line_num == 0 and line_str != "0":
        return ""

    val after = trimmed.substring(colon3 + 1, trimmed.len()).trim()
    var severity = "Error"
    var message = after
    if after.starts_with("error"):
        severity = "Error"
        message = after.substring(5, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("warning"):
        severity = "Warning"
        message = after.substring(7, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("info"):
        severity = "Information"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("hint"):
        severity = "Hint"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    else:
        return ""

    if message == "":
        message = after
    "  " + severity + " (line " + line_str + ", col " + col_str + "): " + message + " (simple-lint)"

fn format_lsp_diagnostics_block(file: text, raw: text) -> text:
    val lines = raw.split("\n")
    var entries: [text] = []
    var i = 0
    while i < lines.len():
        val formatted = lsp_parse_diag_line(lines[i])
        if formatted != "":
            entries.push(formatted)
        i = i + 1
    if entries.len() == 0:
        return ""
    "<new-diagnostics>\n" + file + ":\n" + entries.join("\n") + "\n</new-diagnostics>"

fn make_empty_list_result(id: text, key: text) -> text:
    lsp_result_ok(id, lsp_jo1(lsp_jp(key, "[]")))

fn handle_resources_list(id: text) -> text:
    make_empty_list_result(id, "resources")

fn handle_resource_templates_list(id: text) -> text:
    make_empty_list_result(id, "resourceTemplates")

fn handle_prompts_list(id: text) -> text:
    make_empty_list_result(id, "prompts")

fn handle_roots_list(id: text) -> text:
    val cwd = lsp_get_cwd()
    val root = lsp_jo2(
        lsp_jp("uri", lsp_js("file://" + cwd)),
        lsp_jp("name", lsp_js("workspace"))
    )
    lsp_result_ok(id, lsp_jo1(lsp_jp("roots", "[" + root + "]")))

fn handle_logging_set_level(id: text, body: text) -> text:
    var level = "info"
    if body.contains("\"level\":\"debug\"") or body.contains("\"level\": \"debug\""):
        level = "debug"
    elif body.contains("\"level\":\"info\"") or body.contains("\"level\": \"info\""):
        level = "info"
    elif body.contains("\"level\":\"warn\"") or body.contains("\"level\": \"warn\""):
        level = "warn"
    elif body.contains("\"level\":\"error\"") or body.contains("\"level\": \"error\""):
        level = "error"
    lsp_result_ok(id, lsp_jo1(lsp_jp("level", lsp_js(level))))

fn arg_field(args: text, key: text) -> text:
    val search1 = "\"" + key + "\":\""
    val search2 = "\"" + key + "\": \""
    val idx1 = args.index_of(search1)
    match idx1:
        Some(i):
            val start = i + search1.len()
            var parts: [text] = []
            var pos = start
            while pos < args.len():
                val ch = args.substring(pos, pos + 1)
                if ch == "\"":
                    return parts.join("")
                parts.push(ch)
                pos = pos + 1
        nil: pass_dn
    val idx2 = args.index_of(search2)
    match idx2:
        Some(i):
            val start = i + search2.len()
            var parts: [text] = []
            var pos = start
            while pos < args.len():
                val ch = args.substring(pos, pos + 1)
                if ch == "\"":
                    return parts.join("")
                parts.push(ch)
                pos = pos + 1
        nil: pass_dn
    val value = lsp_extract_field(args, key)
    if value != "":
        return value
    val raw = lsp_extract_field_raw(args, key)
    if raw == "null":
        return ""
    if raw.starts_with(lsp_Q()) and raw.ends_with(lsp_Q()) and raw.len() >= 2:
        return lsp_unquote_json_string(raw)
    raw

fn body_arg_field(body: text, key: text) -> text:
    arg_field(body, key)

fn detect_tool_name(body: text) -> text:
    if body.contains("\"name\":\"lsp_definition\"") or body.contains("\"name\": \"lsp_definition\""):
        return "lsp_definition"
    if body.contains("\"name\":\"lsp_references\"") or body.contains("\"name\": \"lsp_references\""):
        return "lsp_references"
    if body.contains("\"name\":\"lsp_hover\"") or body.contains("\"name\": \"lsp_hover\""):
        return "lsp_hover"
    if body.contains("\"name\":\"lsp_symbols\"") or body.contains("\"name\": \"lsp_symbols\""):
        return "lsp_symbols"
    if body.contains("\"name\":\"lsp_diagnostics\"") or body.contains("\"name\": \"lsp_diagnostics\""):
        return "lsp_diagnostics"
    ""

fn require_arg(id: text, args: text, name: text) -> text:
    val value = arg_field(args, name)
    if value == "":
        return lsp_make_tool_error(id, -32602, "Missing required argument: " + name)
    ""

fn handle_tool_call(id: text, body: text) -> text:
    val params = lsp_extract_field_raw(body, "params")
    if params == "null":
        return lsp_make_tool_error(id, -32602, "Missing params")

    val tool_name = detect_tool_name(body)
    val args = lsp_extract_field_raw(params, "arguments")
    if tool_name == "":
        return lsp_make_tool_error(id, -32602, "Missing tool name")

    if tool_name == "lsp_definition" or tool_name == "lsp_references" or tool_name == "lsp_hover":
        val file = body_arg_field(body, "file")
        val line_raw = body_arg_field(body, "line")
        val char_raw = body_arg_field(body, "character")
        if file == "" or line_raw == "" or char_raw == "":
            return lsp_make_tool_error(id, -32602, "Missing required argument: file/line/character")
        val line0 = line_raw.to_int()
        val char0 = char_raw.to_int()

        if tool_name == "lsp_definition":
            return lsp_make_tool_result(id, run_lsp_query("definition", file, line0, char0))
        if tool_name == "lsp_references":
            return lsp_make_tool_result(id, run_lsp_query("references", file, line0, char0))
        return lsp_make_tool_result(id, run_lsp_query("hover", file, line0, char0))

    if tool_name == "lsp_symbols" or tool_name == "lsp_diagnostics":
        val file = body_arg_field(body, "file")
        if file == "":
            return lsp_make_tool_error(id, -32602, "Missing required argument: file")
        if tool_name == "lsp_symbols":
            return lsp_make_tool_result(id, run_lsp_symbols(file))
        val raw = run_lsp_diagnostics(file)
        val diag_block = format_lsp_diagnostics_block(file, raw)
        if diag_block != "":
            return lsp_make_tool_result(id, raw + "\n" + diag_block)
        return lsp_make_tool_result(id, raw)

    lsp_result_error(id, -32602, "Unknown tool: " + tool_name)
fn lsp_get_cwd() -> text:
    val (stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", "pwd"])
    if code == 0 and stdout.trim() != "":
        return stdout.trim()
    "."
