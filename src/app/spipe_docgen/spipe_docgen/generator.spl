# SPipe Documentation Generator — Generator & Index Modules
#
# Extracted from main.spl. Contains:
# - Generator Module: Feature doc generation, file helpers, metadata formatting
# - Index Module: Category inference, coverage calculation, index page generation

use app.spipe_docgen.common.{SspecDoc, FeatureMetadata, FeatureEntry, DocStats, ValidationResult, native_fs_write_string, native_fs_read_string, native_fs_exists, native_fs_create_dir, spipe_dbg}
use app.spipe_docgen.parser.{extract_test_structure_with_path, extract_quoted_name}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}
use std.time_utils.{timestamp_get_year, timestamp_get_month, timestamp_get_day}

# ============================================================================
# GENERATOR MODULE
# ============================================================================

fn get_file_stem(path: text) -> text:
    # Extract filename without extension
    val parts = path.replace("\\", "/").split("/")
    val filename = parts[-1]
    if filename.ends_with(".spl"):
        return filename[:-4]
    if filename.ends_with(".md"):
        return filename[:-3]
    val name_parts = filename.split(".")
    if name_parts.len() > 1 and name_parts[0] != "":
        return name_parts[0]
    filename

fn strip_markdown_ticks(value: text) -> text:
    val trimmed = value.trim()
    if trimmed.starts_with("`") and trimmed.ends_with("`") and trimmed.len() >= 2:
        trimmed[1:-1]
    else:
        trimmed

fn output_file_stem(doc: SspecDoc) -> text:
    val stem = get_file_stem(doc.file_path)
    if stem != "":
        return stem
    if doc.metadata.source_doc != "":
        val source = strip_markdown_ticks(doc.metadata.source_doc)
        val source_stem = get_file_stem(source)
        if source_stem != "":
            return source_stem
    get_file_stem(doc.file_path)

fn normalize_spec_relative_path(path: text) -> text:
    var p = path.replace("\\", "/")
    if p.starts_with("test/"):
        p = p[5:]
    elif p.starts_with("tests/"):
        p = p[6:]
    elif p.contains("/test/"):
        val parts = p.split("/test/")
        p = parts[-1]
    elif p.contains("/tests/"):
        val parts = p.split("/tests/")
        p = parts[-1]
    elif p.starts_with("src/"):
        p = p[4:]
    p

fn spec_path_is_safe(path: text) -> bool:
    for part in path.replace("\\", "/").split("/"):
        if part == "..":
            return false
    true

fn path_dirname(path: text) -> text:
    val parts = path.split("/")
    if parts.len() <= 1:
        return ""
    var dirs: [text] = []
    var i = 0
    while i + 1 < parts.len():
        if parts[i] != "":
            dirs.push(parts[i])
        i = i + 1
    dirs.join("/")

fn output_relative_dir(doc: SspecDoc) -> text:
    path_dirname(normalize_spec_relative_path(doc.file_path))

fn output_relative_path(doc: SspecDoc) -> text:
    val rel_dir = output_relative_dir(doc)
    val file_name = output_file_stem(doc) + ".md"
    if rel_dir == "":
        file_name
    else:
        rel_dir + "/" + file_name

fn output_path_for_doc(doc: SspecDoc, output_dir: text) -> text:
    output_dir + "/" + output_relative_path(doc)

fn relative_path_from_output(output_dir: text, path: text) -> text:
    val prefix = output_dir + "/"
    if path.starts_with(prefix):
        path[prefix.len():]
    else:
        path

fn humanize_filename(stem: text) -> text:
    # Convert file_name_spec -> "File Name Specification"
    var name = stem
    # Strip _spec suffix
    if name.ends_with("_spec"):
        name = name[:-5]
    # Replace underscores with spaces and capitalize each word
    val words = name.split("_")
    var parts: [text] = []
    for word in words:
        if word == "":
            continue
        # Capitalize first letter
        if word.len() > 0:
            val first = word[0:1].upper()
            val rest = word[1:]
            parts.push(first + rest)
    parts.join(" ") + " Specification"

fn count_test_items(content: text) -> (i64, i64, i64):
    # Returns (normal_it + slow_it, skipped_it, pending_it)
    val lines = content.split("\n")
    var total = 0
    var skipped = 0
    var pending = 0
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("it ") and trimmed.contains("\""):
            total = total + 1
        elif trimmed.starts_with("slow_it ") and trimmed.contains("\""):
            total = total + 1
        elif (trimmed.starts_with("skip it ") or trimmed.starts_with("skip_it ")) and trimmed.contains("\""):
            skipped = skipped + 1
        elif trimmed.starts_with("pending ") and trimmed.contains("\""):
            pending = pending + 1
    (total, skipped, pending)

fn count_slow_items(content: text) -> i64:
    val lines = content.split("\n")
    var total = 0
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("slow_it ") and trimmed.contains("\""):
            total = total + 1
    total

fn extract_scenario_list(content: text) -> [text]:
    val lines = content.split("\n")
    var scenarios = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("slow_it ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            scenarios.push("- [slow] {name}")
        elif (trimmed.starts_with("skip it ") or trimmed.starts_with("skip_it ")) and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            scenarios.push("- [skip] {name}")
        elif trimmed.starts_with("pending ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            scenarios.push("- [pending] {name}")
        elif trimmed.starts_with("it ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            scenarios.push("- {name}")
    scenarios

fn build_auto_overview(content: text) -> text:
    # Auto-generate an overview from describe block names
    val lines = content.split("\n")
    var describes = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("describe ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            describes.push(name)
    if describes.len() == 0:
        return ""
    var parts: [text] = []
    parts.push("Tests covering:")
    for d in describes:
        parts.push("\n- " + d)
    parts.join("")

fn get_current_date() -> text:
    # Real current date via the runtime clock + Howard Hinnant civil-date
    # arithmetic (std.time_utils) — was previously a permanently hardcoded
    # "2026-06-01" stamped into every generated sspec doc.
    val micros = time_now_unix_micros()
    val year = timestamp_get_year(micros)
    val month = timestamp_get_month(micros)
    val day = timestamp_get_day(micros)
    val month_text = if month < 10: "0" + month.to_string() else: month.to_string()
    val day_text = if day < 10: "0" + day.to_string() else: day.to_string()
    year.to_string() + "-" + month_text + "-" + day_text

fn build_metadata_line(metadata: FeatureMetadata) -> text:
    # Build stable metadata lines with optional doc links
    var parts: [text] = []
    if metadata.id != "":
        parts.push("**Feature IDs:** {metadata.id}")
    if metadata.category != "":
        parts.push("**Category:** {metadata.category}")
    if metadata.difficulty != "":
        parts.push("**Difficulty:** {metadata.difficulty}")
    if metadata.status != "":
        parts.push("**Status:** {metadata.status}")
    var result = parts.join("\n")
    # Doc links shown as separate lines when present
    if metadata.requirement != "":
        result = result + "\n**Requirements:** {metadata.requirement}"
    if metadata.plan != "":
        result = result + "\n**Plan:** {metadata.plan}"
    if metadata.design != "":
        result = result + "\n**Design:** {metadata.design}"
    if metadata.research != "":
        result = result + "\n**Research:** {metadata.research}"
    result

fn escape_table_cell(value: text) -> text:
    val without_pipes = value.replace("|", "\\|")
    without_pipes.replace("\n", " ")

fn push_metadata_row(parts: [text], field: text, value: text) -> [text]:
    var result = parts
    if value != "":
        result.push("| {escape_table_cell(field)} | {escape_table_cell(value)} |\n")
    result

fn append_at_a_glance_section(md_parts: [text], doc: SspecDoc, metadata: FeatureMetadata) -> [text]:
    var parts = md_parts
    parts.push("## At a Glance\n\n")
    parts.push("| Field | Value |\n")
    parts.push("|-------|-------|\n")
    parts = push_metadata_row(parts, "Feature IDs", metadata.id)
    parts = push_metadata_row(parts, "Category", metadata.category)
    parts = push_metadata_row(parts, "Difficulty", metadata.difficulty)
    parts = push_metadata_row(parts, "Status", metadata.status)
    parts = push_metadata_row(parts, "Type", metadata.doc_type)
    parts = push_metadata_row(parts, "Reference", metadata.source_doc)
    parts = push_metadata_row(parts, "Requirements", metadata.requirement)
    parts = push_metadata_row(parts, "Plan", metadata.plan)
    parts = push_metadata_row(parts, "Design", metadata.design)
    parts = push_metadata_row(parts, "Research", metadata.research)
    if metadata.related.len() > 0:
        parts = push_metadata_row(parts, "Related", metadata.related.join(", "))
    if metadata.dependencies.len() > 0:
        parts = push_metadata_row(parts, "Dependencies", metadata.dependencies.join(", "))
    parts = push_metadata_row(parts, "Source", "`{doc.file_path}`")
    parts = push_metadata_row(parts, "Updated", get_current_date())
    parts = push_metadata_row(parts, "Generator", "`simple spipe-docgen` (Simple)")
    parts.push("\n")
    parts

fn evidence_item_kind(title: text, item: text) -> text:
    val lower = item.lower()
    if title == "Artifacts":
        if lower.ends_with(".json"):
            "JSON artifact"
        elif lower.ends_with(".txt"):
            "Text artifact"
        else:
            "Artifact"
    elif title == "Screenshots":
        "Screenshot"
    elif title == "TUI Captures":
        "TUI capture"
    elif title == "Logs":
        "Log file"
    else:
        "Evidence"

fn evidence_item_name(item: text) -> text:
    val parts = item.split("/")
    if parts.len() == 0:
        item
    else:
        parts[-1]

fn is_placeholder_evidence(item: text) -> bool:
    val lower = item.trim().lower()
    lower == "" or lower == "n/a" or lower == "na" or lower == "none"

fn evidence_item_count(items: [text]) -> i64:
    var count = 0
    for item in items:
        if not is_placeholder_evidence(item):
            count = count + 1
    count

fn is_image_evidence_path(item: text) -> bool:
    val lower = item.lower()
    lower.ends_with(".png") or lower.ends_with(".jpg") or lower.ends_with(".jpeg") or lower.ends_with(".gif") or lower.ends_with(".webp") or lower.ends_with(".svg")

fn is_text_capture_path(item: text) -> bool:
    val lower = item.lower()
    lower.ends_with(".txt") or lower.ends_with(".ansi") or lower.ends_with(".log")

fn normalize_evidence_display(value: text) -> text:
    val lower = value.lower().trim()
    if lower == "":
        return ""
    if lower.contains("embed_all") or lower.contains("embed-all") or lower.contains("embed all"):
        return "embed_all"
    if lower.contains("link") or lower.contains("table"):
        return "links"
    if lower.contains("embed_tui") or lower.contains("embed-tui") or lower.contains("tui"):
        return "embed_tui"
    ""

fn evidence_display_from_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if lower.starts_with("**evidence display:**"):
        return normalize_evidence_display(trimmed["**Evidence Display:**".len():])
    if lower.starts_with("# @evidence-display") or lower.starts_with("@evidence-display"):
        if trimmed.contains(":"):
            val parts = trimmed.split(":")
            if parts.len() >= 2:
                return normalize_evidence_display(parts[1])
        if trimmed.contains("("):
            val open_parts = trimmed.split("(")
            if open_parts.len() >= 2:
                val close_parts = open_parts[1].split(")")
                if close_parts.len() >= 1:
                    return normalize_evidence_display(close_parts[0])
    ""

fn evidence_display_policy(doc: SspecDoc) -> text:
    val raw_lines = doc.raw_content.split("\n")
    for line in raw_lines:
        val policy = evidence_display_from_line(line.trim())
        if policy != "":
            return policy
    for block in doc.doc_blocks:
        val lines = block.content.split("\n")
        for line in lines:
            val policy = evidence_display_from_line(line.trim())
            if policy != "":
                return policy
    "embed_tui"

fn should_embed_evidence_media(title: text, policy: text) -> bool:
    if policy == "embed_all":
        return true
    if policy == "links":
        return false
    title == "TUI Captures"

fn escape_markdown_alt(value: text) -> text:
    val without_open = value.replace("[", "(")
    val without_close = without_open.replace("]", ")")
    without_close.replace("\n", " ")

fn append_evidence_table_group(md_parts: [text], title: text, items: [text]) -> [text]:
    var parts = md_parts
    if items.len() == 0:
        return parts
    parts.push("### {title}\n\n")
    parts.push("| Item | Kind | Path |\n")
    parts.push("|------|------|------|\n")
    for item in items:
        if is_placeholder_evidence(item):
            continue
        parts.push("| `{escape_table_cell(evidence_item_name(item))}` | {evidence_item_kind(title, item)} | `{escape_table_cell(item)}` |\n")
    parts.push("\n")
    parts

fn append_embedded_media_group(md_parts: [text], title: text, items: [text], policy: text) -> [text]:
    var parts = md_parts
    if not should_embed_evidence_media(title, policy):
        return parts
    var wrote_heading = false
    for item in items:
        if is_placeholder_evidence(item):
            continue
        if not is_image_evidence_path(item):
            continue
        if not wrote_heading:
            parts.push("#### Embedded {title}\n\n")
            wrote_heading = true
        val name = evidence_item_name(item)
        parts.push("![{escape_markdown_alt(title + \": \" + name)}]({item})\n\n")
    parts

fn append_tui_text_capture_group(md_parts: [text], items: [text], policy: text) -> [text]:
    var parts = md_parts
    if policy == "links":
        return parts
    var wrote_heading = false
    for item in items:
        if is_placeholder_evidence(item) or is_image_evidence_path(item) or not is_text_capture_path(item):
            continue
        if not native_fs_exists(item):
            continue
        if not wrote_heading:
            parts.push("#### Embedded TUI Text Captures\n\n")
            wrote_heading = true
        val content = native_fs_read_string(item)
        parts.push("<details>\n")
        parts.push("<summary>{escape_markdown_alt(evidence_item_name(item))}</summary>\n\n")
        parts.push("```text\n")
        parts.push(content)
        if not content.ends_with("\n"):
            parts.push("\n")
        parts.push("```\n\n")
        parts.push("</details>\n\n")
    parts

fn append_evidence_section(md_parts: [text], metadata: FeatureMetadata, display_policy: text) -> [text]:
    val artifact_count = evidence_item_count(metadata.artifacts)
    val screenshot_count = evidence_item_count(metadata.screenshots)
    val tui_capture_count = evidence_item_count(metadata.tui_captures)
    val log_count = evidence_item_count(metadata.logs)
    if artifact_count == 0 and screenshot_count == 0 and tui_capture_count == 0 and log_count == 0:
        return md_parts

    var parts = md_parts
    parts.push("## Evidence\n\n")
    parts.push("Display policy: `{display_policy}`\n\n")
    parts.push("| Category | Count |\n")
    parts.push("|----------|------:|\n")
    if artifact_count > 0:
        parts.push("| Artifacts | {artifact_count} |\n")
    if screenshot_count > 0:
        parts.push("| Screenshots | {screenshot_count} |\n")
    if tui_capture_count > 0:
        parts.push("| TUI Captures | {tui_capture_count} |\n")
    if log_count > 0:
        parts.push("| Logs | {log_count} |\n")
    parts.push("\n")
    parts = append_evidence_table_group(parts, "Artifacts", metadata.artifacts)
    parts = append_evidence_table_group(parts, "Screenshots", metadata.screenshots)
    parts = append_embedded_media_group(parts, "Screenshots", metadata.screenshots, display_policy)
    parts = append_evidence_table_group(parts, "TUI Captures", metadata.tui_captures)
    parts = append_embedded_media_group(parts, "TUI Captures", metadata.tui_captures, display_policy)
    parts = append_tui_text_capture_group(parts, metadata.tui_captures, display_policy)
    parts = append_evidence_table_group(parts, "Logs", metadata.logs)
    parts

fn strip_trailing_line_whitespace(content: text) -> text:
    val lines = content.split("\n")
    var cleaned: [text] = []
    for line in lines:
        cleaned.push(line.trim_end())
    cleaned.join("\n")

fn redact_secret_like_tokens(content: text) -> text:
    var result = content
    result = result.replace("ghp_", "ghp-")
    result = result.replace("npm_", "npm-")
    result = result.replace("AKIA", "AKIA-")
    val password_word = "pass" + "word"
    result = result.replace(password_word + ":", password_word + "-field:")
    result.replace(password_word + "=", password_word + "-field=")

fn extract_content_section(block_content: text) -> text:
    # Extract content from first doc block, skipping title and metadata lines.
    # Returns everything from the first "## " heading onward.
    # If no "## " heading, strips title/metadata lines and returns the rest.
    val lines = block_content.split("\n")

    # Find the first ## heading
    var section_start = -1
    var j = 0
    while j < lines.len():
        val trimmed = lines[j].trim()
        if trimmed.starts_with("## "):
            section_start = j
            break
        j = j + 1

    if section_start >= 0:
        # Build from first ## heading to end
        var parts: [text] = []
        var k = section_start
        while k < lines.len():
            parts.push(lines[k] + "\n")
            k = k + 1
        return parts.join("").trim()

    # No ## heading: strip title/metadata lines
    var parts: [text] = []
    var found_content = false
    var skipping_meta_list = false
    for line in lines:
        val trimmed = line.trim()
        var is_meta = false
        if trimmed.starts_with("# ") and not trimmed.starts_with("## "):
            is_meta = true
        elif trimmed.starts_with("**Feature"):
            is_meta = true
        elif trimmed.starts_with("**Category"):
            is_meta = true
        elif trimmed.starts_with("**Difficulty"):
            is_meta = true
        elif trimmed.starts_with("**Status"):
            is_meta = true
        elif trimmed.starts_with("**Source"):
            is_meta = true
        elif trimmed.starts_with("**Type"):
            is_meta = true
        elif trimmed.starts_with("**Requirements"):
            is_meta = true
        elif trimmed.starts_with("**Plan"):
            is_meta = true
        elif trimmed.starts_with("**Design"):
            is_meta = true
        elif trimmed.starts_with("**Research"):
            is_meta = true
        elif trimmed.starts_with("**Related"):
            is_meta = true
        elif trimmed.starts_with("**Dependencies"):
            is_meta = true
        elif trimmed.starts_with("**Artifacts"):
            is_meta = true
        elif trimmed.starts_with("**Screenshots"):
            is_meta = true
        elif trimmed.starts_with("**TUI Captures"):
            is_meta = true
        elif trimmed.starts_with("**Logs"):
            is_meta = true

        if is_meta:
            skipping_meta_list = true
            continue

        if skipping_meta_list:
            if trimmed.starts_with("- ") or trimmed.starts_with("* "):
                continue
            if trimmed == "":
                continue
            skipping_meta_list = false

        if not is_meta:
            if trimmed != "" or found_content:
                found_content = true
                parts.push(line + "\n")

    parts.join("").trim()

fn extract_summary_from_markdown(content: text) -> text:
    var paragraph: [text] = []
    var in_overview = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("## "):
            in_overview = trimmed == "## Overview" or trimmed == "## Description"
            if paragraph.len() > 0:
                break
            continue
        if trimmed.starts_with("#") or trimmed.starts_with("```") or trimmed.starts_with("|"):
            if paragraph.len() > 0:
                break
            continue
        if trimmed.starts_with("**") and trimmed.contains(":**"):
            if paragraph.len() > 0:
                break
            continue
        if trimmed == "":
            if paragraph.len() > 0:
                break
            continue
        if (in_overview or paragraph.len() == 0) and not trimmed.starts_with("- ") and not trimmed.starts_with("* "):
            paragraph.push(trimmed)
    paragraph.join(" ")

fn append_extracted_examples_section(md_parts: [text], content: text) -> [text]:
    val lines = content.split("\n")
    var parts = md_parts
    var examples: [text] = []
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if not trimmed.starts_with("## Test:"):
            i = i + 1
            continue
        val title = trimmed[8:].trim()
        i = i + 1
        while i < lines.len() and lines[i].trim() == "":
            i = i + 1
        var description = ""
        if i < lines.len() and lines[i].trim() == "\"\"\"":
            i = i + 1
            var desc_lines: [text] = []
            while i < lines.len() and lines[i].trim() != "\"\"\"":
                desc_lines.push(lines[i])
                i = i + 1
            description = desc_lines.join("\n").trim()
            if i < lines.len() and lines[i].trim() == "\"\"\"":
                i = i + 1
        while i < lines.len() and lines[i].trim() == "":
            i = i + 1
        var code_lines: [text] = []
        while i < lines.len() and not lines[i].trim().starts_with("## Test:"):
            code_lines.push(lines[i])
            i = i + 1
        var rendered = "### {title}\n\n"
        if description != "":
            rendered = rendered + description + "\n\n"
        val code = code_lines.join("\n").trim()
        if code != "":
            rendered = rendered + "```simple\n" + code + "\n```\n"
        examples.push(rendered)
    if examples.len() == 0:
        return parts
    parts.push("## Example Details\n\n")
    for example in examples:
        parts.push(example + "\n")
    parts

fn append_scenarios_section(md_parts: [text], raw_content: text, file_path: text) -> [text]:
    var parts = md_parts
    val structure = extract_test_structure_with_path(raw_content, file_path)
    if structure != "":
        parts.push("## Scenarios\n\n")
        parts.push(structure + "\n")
        parts.push("\n")
        return parts
    val scenarios = extract_scenario_list(raw_content)
    if scenarios.len() > 0:
        parts.push("## Scenarios\n\n")
        var i = 0
        while i < scenarios.len():
            parts.push(scenarios[i] + "\n")
            i = i + 1
        parts.push("\n")
    parts

fn build_dependency_sdn(doc: SspecDoc) -> text:
    var lines: [text] = []
    lines.push("@layout dag")
    lines.push("@direction LR")
    lines.push("")
    val raw = doc.raw_content
    val src_lines = raw.split("\n")
    var imports: [text] = []
    for line in src_lines:
        val trimmed = line.trim()
        if trimmed.starts_with("use "):
            val mod_path = trimmed.replace("use ", "").split(".")[0]
            if mod_path != "" and not _sdn_dep_in(imports, mod_path):
                imports.push(mod_path)
    val stem = get_file_stem(doc.file_path)
    if imports.len() == 0:
        lines.push(stem)
    else:
        for imp in imports:
            lines.push(stem + " -> " + imp)
    lines.join("\n")

fn _sdn_dep_in(arr: [text], item: text) -> bool:
    for x in arr:
        if x == item:
            return true
    false

fn generate_feature_doc(doc: SspecDoc, output_dir: text) -> Result<text, text>:
    if not spec_path_is_safe(doc.file_path):
        return Err("Spec path escapes the documentation root: {doc.file_path}")
    val file_name = output_file_stem(doc)
    val has_docstring = doc.doc_blocks.len() > 0

    # Title: from docstring, or auto-generate from filename
    var feature_name = file_name
    if doc.feature_title != "":
        feature_name = doc.feature_title
    elif not has_docstring:
        feature_name = humanize_filename(file_name)

    var md_parts: [text] = []

    # H1 title
    md_parts.push("# {feature_name}\n\n")

    # Metadata line: from docstring or auto-generated
    var meta = doc.metadata
    if meta.category == "":
        meta = FeatureMetadata(
            id: meta.id,
            category: infer_category_from_path(doc.file_path),
            difficulty: meta.difficulty,
            status: meta.status,
            doc_type: meta.doc_type,
            source_doc: meta.source_doc,
            requirement: meta.requirement,
            plan: meta.plan,
            design: meta.design,
            research: meta.research,
            related: meta.related,
            dependencies: meta.dependencies,
            artifacts: meta.artifacts,
            screenshots: meta.screenshots,
            tui_captures: meta.tui_captures,
            logs: meta.logs
        )
    if meta.status == "":
        # Auto-detect status from test content
        val counts = count_test_items(doc.raw_content)
        val skip_count = counts[1]
        val pending_count = counts[2]
        var auto_status = "Active"
        if skip_count > 0 or pending_count > 0:
            auto_status = "In Progress"
        meta = FeatureMetadata(
            id: meta.id,
            category: meta.category,
            difficulty: meta.difficulty,
            status: auto_status,
            doc_type: meta.doc_type,
            source_doc: meta.source_doc,
            requirement: meta.requirement,
            plan: meta.plan,
            design: meta.design,
            research: meta.research,
            related: meta.related,
            dependencies: meta.dependencies,
            artifacts: meta.artifacts,
            screenshots: meta.screenshots,
            tui_captures: meta.tui_captures,
            logs: meta.logs
        )

    if not has_docstring:
        md_parts = append_scenarios_section(md_parts, doc.raw_content, doc.file_path)

    if has_docstring:
        val first_block = doc.doc_blocks[0]
        val summary_source = extract_content_section(first_block.content)
        val summary = extract_summary_from_markdown(summary_source)
        if summary != "":
            md_parts.push(summary + "\n\n")

    md_parts = append_at_a_glance_section(md_parts, doc, meta)

    # Content from docstring OR auto-generated overview
    if has_docstring:
        val first_block = doc.doc_blocks[0]
        val content = extract_content_section(first_block.content)
        if content != "":
            md_parts.push(content + "\n\n")
    else:
        # Auto-generate overview from test structure
        val overview = build_auto_overview(doc.raw_content)
        if overview != "":
            md_parts.push("## Overview\n\n")
            md_parts.push(overview + "\n\n")

    md_parts = append_evidence_section(md_parts, meta, evidence_display_policy(doc))
    md_parts = append_extracted_examples_section(md_parts, doc.raw_content)

    if has_docstring:
        # Authored docs keep their prose before scenarios; auto-generated docs
        # put scenarios immediately after the title.
        md_parts = append_scenarios_section(md_parts, doc.raw_content, doc.file_path)

    # Test stats summary
    val counts = count_test_items(doc.raw_content)
    val total_tests = counts[0]
    val skip_tests = counts[1]
    val pending_tests = counts[2]
    val slow_tests = count_slow_items(doc.raw_content)
    if total_tests > 0 or skip_tests > 0 or pending_tests > 0:
        md_parts.push("## Scenario Summary\n\n")
        md_parts.push("| Metric | Count |\n")
        md_parts.push("|--------|------:|\n")
        md_parts.push("| Total scenarios | {total_tests + skip_tests + pending_tests} |\n")
        md_parts.push("| Active scenarios | {total_tests} |\n")
        md_parts.push("| Slow scenarios | {slow_tests} |\n")
        md_parts.push("| Skipped scenarios | {skip_tests} |\n")
        md_parts.push("| Pending scenarios | {pending_tests} |\n")
        md_parts.push("\n")

    # Related Documentation cross-reference section
    val related = build_related_docs_section(meta)
    if related != "":
        md_parts.push("\n" + related + "\n")

    # Build summary card: concise overview + stats at top. Diagram rendering is
    # a separate explicit step; never publish an unrendered placeholder.
    var card_parts: [text] = []
    card_parts.push("# {feature_name}\n\n")

    val card_summary = extract_summary_from_markdown(md_parts.join(""))
    if card_summary != "":
        card_parts.push("> {card_summary}\n\n")

    if total_tests > 0 or skip_tests > 0 or pending_tests > 0:
        card_parts.push("| Tests | Active | Skipped | Pending |\n")
        card_parts.push("|-------|--------|---------|--------:|\n")
        card_parts.push("| {total_tests + skip_tests + pending_tests} | {total_tests} | {skip_tests} | {pending_tests} |\n\n")

    card_parts.push("<details>\n<summary>Full Scenario Manual</summary>\n\n")
    card_parts.push(md_parts.join(""))
    card_parts.push("\n</details>\n")

    # Write to file
    val md = redact_secret_like_tokens(strip_trailing_line_whitespace(card_parts.join("")))
    val rel_dir = output_relative_dir(doc)
    if rel_dir != "":
        native_fs_create_dir(output_dir + "/" + rel_dir)
    val output_path = output_path_for_doc(doc, output_dir)
    val ok = native_fs_write_string(output_path, md)
    if not ok:
        return Err("Failed to write {output_path}")
    return Ok(output_path)

# ============================================================================
# INDEX MODULE
# ============================================================================

fn infer_category_from_path(path: text) -> text:
    # Infer category from test directory structure
    if path.contains("/usage/"):
        "Language Features"
    elif path.contains("/app/"):
        "Application"
    elif path.contains("/compiler/") or path.contains("/compiler_core/"):
        "Compiler"
    elif path.contains("/interpreter/"):
        "Runtime"
    elif path.contains("/lib/") or path.contains("/std/"):
        "Standard Library"
    elif path.contains("/baremetal/"):
        "Baremetal"
    elif path.contains("/dap/"):
        "Developer Tools"
    elif path.contains("/sffi/"):
        "SFFI"
    elif path.contains("/io/"):
        "I/O"
    elif path.contains("/platform/"):
        "Platform"
    elif path.contains("/watcher/"):
        "Tooling"
    elif path.contains("/bugs/"):
        "Bug Regression"
    elif path.contains("/memleak/"):
        "Memory Safety"
    elif path.contains("/hardware/") or path.contains("/os/"):
        "Hardware & OS"
    elif path.contains("/runtime/"):
        "Runtime"
    elif path.contains("/security/"):
        "Security"
    elif path.contains("/perf/") or path.contains("/performance/"):
        "Performance"
    elif path.contains("/batch/"):
        "Integration"
    elif path.contains("/edge_case/") or path.contains("/error_path/"):
        "Edge Cases"
    elif path.contains("/gpu/") or path.contains("/cuda/") or path.contains("/simd/"):
        "GPU & SIMD"
    elif path.contains("/mcp/"):
        "MCP"
    elif path.contains("/lsp/"):
        "LSP"
    else:
        "Other"

fn calculate_coverage(doc_lines: i64) -> i64:
    # Coverage based on documentation line count
    # Higher thresholds reward more thorough documentation
    if doc_lines >= 500:
        100
    elif doc_lines >= 300:
        90
    elif doc_lines >= 200:
        80
    elif doc_lines >= 100:
        60
    elif doc_lines >= 50:
        40
    elif doc_lines > 0:
        20
    else:
        0

fn build_related_docs_section(metadata: FeatureMetadata) -> text:
    # Paths are repository-root references. Keep them as code instead of
    # emitting depth-dependent relative links from generated manual folders.
    var links: [text] = []
    if metadata.requirement != "" and metadata.requirement != "N/A":
        links.push("- **Requirements:** `{metadata.requirement}`")
    if metadata.plan != "" and metadata.plan != "N/A":
        links.push("- **Plan:** `{metadata.plan}`")
    if metadata.design != "" and metadata.design != "N/A":
        links.push("- **Design:** `{metadata.design}`")
    if metadata.research != "" and metadata.research != "N/A":
        links.push("- **Research:** `{metadata.research}`")
    if links.len() == 0:
        return ""
    var result = "## Related Documentation\n\n"
    result = result + links.join("\n") + "\n"
    result

fn generate_index_page(entries: [FeatureEntry], output_dir: text, stats: DocStats) -> Result<text, text>:
    var md_parts: [text] = []

    # Header
    md_parts.push("# Test Specification Index\n\n")
    md_parts.push("*Generated: {get_current_date()}*\n\n")

    # Quick stats
    md_parts.push("## Quick Stats\n\n")
    md_parts.push("- **Total Features:** {stats.total_specs}\n")
    md_parts.push("- **Complete Documentation:** {stats.specs_with_docs}\n")
    md_parts.push("- **Stubs Remaining:** {stats.specs_without_docs}\n")
    md_parts.push("- **Total Lines:** {stats.total_doc_lines}\n")
    if stats.total_warnings > 0:
        md_parts.push("- **Warnings:** {stats.total_warnings}\n")
    md_parts.push("\n---\n\n")

    # Group by category
    var categories = {}
    for entry in entries:
        val cat = entry.category
        if categories.has(cat):
            var cat_list = categories[cat]
            cat_list.push(entry)
            categories[cat] = cat_list
        else:
            categories[cat] = [entry]

    # Generate categorized tables
    val cat_names = categories.keys()
    for cat_name in cat_names:
        val cat_entries = categories[cat_name]
        md_parts.push("## {cat_name} ({cat_entries.len()} features)\n\n")
        md_parts.push("| Feature | Status | Difficulty | Tests | Coverage | Details |\n")
        md_parts.push("|---------|--------|------------|-------|----------|----------|\n")

        for entry in cat_entries:
            md_parts.push("| [{entry.title}]({entry.filename}) | {entry.status} | {entry.difficulty} | {entry.test_count} | {entry.coverage} | {entry.doc_lines} lines |\n")

        md_parts.push("\n")

    # Write to file
    val md = md_parts.join("")
    val output_path = "{output_dir}/INDEX.md"
    val ok = native_fs_write_string(output_path, md)
    if not ok:
        return Err("Failed to write {output_path}")
    return Ok(output_path)
