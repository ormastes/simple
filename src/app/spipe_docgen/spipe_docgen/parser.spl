# SPipe Documentation Generator — Parser, Metadata, Validation & Test Structure
#
# Extracted from main.spl. Contains:
# - Parser: parse_id_attr, parse_spipe_file (incl. comment-doc extraction)
# - Metadata: extract_field_value, split_metadata_list, extract_metadata
# - Validation: validate_spec
# - Test Structure: extract_quoted_name, extract_inline_docstring, extract_test_structure

use app.spipe_docgen.spipe_docgen.common.{DocBlock, FeatureMetadata, SspecDoc, ValidationResult, spipe_dbg, native_fs_read_string, native_fs_exists}
use std.math_repr.{to_text, render_latex_raw}

# ============================================================================
# PARSER MODULE
# ============================================================================

fn parse_id_attr(line: text) -> text:
    # Parse @id("...") attribute to extract ID
    val trimmed = line.trim()
    if not trimmed.starts_with("#[id("):
        return ""

    # Extract content between quotes
    val after_prefix = trimmed[5:]  # Remove "#[id("
    val without_suffix = after_prefix.trim_end_matches(")]")
    val inner = without_suffix.trim()

    if inner.starts_with("\"") and inner.ends_with("\"") and inner.len() >= 2:
        inner[1:-1]  # Remove quotes
    else:
        ""

fn parse_spipe_file(path: text) -> Result<SspecDoc, text>:
    spipe_dbg("reading file: {path}")
    val content = native_fs_read_string(path)
    spipe_dbg("file read, splitting lines")
    val lines = content.split("\n")
    val lines_len = lines.len()
    spipe_dbg("got {lines_len} lines")
    var doc_blocks = []
    var feature_title = ""
    var feature_ids = []

    # Pre-scan: Extract comment-based documentation (# ## Section pattern)
    # Many feature specs use comment-based docs instead of """ blocks.
    # Lines starting with "# " contain doc content; lines that are just "#" are blank lines.
    var comment_doc_lines: [text] = []
    var comment_scan_i = 0
    # Skip leading blank lines
    while comment_scan_i < lines.len() and lines[comment_scan_i].trim() == "":
        comment_scan_i = comment_scan_i + 1
    # Collect consecutive comment lines
    while comment_scan_i < lines.len():
        val cline = lines[comment_scan_i]
        val ctrimmed = cline.trim()
        if ctrimmed.starts_with("# ") and not ctrimmed.starts_with("#["):
            comment_doc_lines.push(ctrimmed[2:])
        elif ctrimmed == "#":
            comment_doc_lines.push("")
        else:
            break
        comment_scan_i = comment_scan_i + 1

    # If comment docs contain markdown structure, synthesize a DocBlock
    if comment_doc_lines.len() > 0:
        val comment_content = comment_doc_lines.join("\n").trim()
        if comment_content.contains("## ") or comment_content.contains("**Category:**"):
            # Extract feature title from "# Title" pattern
            for cl in comment_doc_lines:
                val cl_trimmed = cl.trim()
                if cl_trimmed.starts_with("# "):
                    feature_title = cl_trimmed[2:].trim()
                    break

            doc_blocks.push(DocBlock(
                content: comment_content,
                line_start: 0,
                line_end: comment_scan_i
            ))
            spipe_dbg("extracted comment-based doc block: {comment_doc_lines.len()} lines")

    var i = 0
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()

        # Extract feature IDs from @id(...) attributes
        if trimmed.starts_with("#[id("):
            val id = parse_id_attr(trimmed)
            if id != "":
                feature_ids.push(id)

        # Check for doc block start (standalone """ on its own line)
        if trimmed == "\"\"\"":
            val start_line = i
            i = i + 1

            var block_lines: [text] = []
            var found_end = false

            # Collect lines until closing """
            while i < lines.len():
                val block_line = lines[i]

                if block_line.trim() == "\"\"\"":
                    found_end = true
                    break

                block_lines.push(block_line)
                i = i + 1

            val block_content = block_lines.join("\n") + "\n"

            if found_end:
                # Extract feature title from first doc block if present
                if feature_title == "" and block_content.contains("# "):
                    val block_lines = block_content.split("\n")
                    for bl in block_lines:
                        val bl_trimmed = bl.trim()
                        if bl_trimmed.starts_with("# "):
                            feature_title = bl_trimmed[2:].trim()
                            break

                doc_blocks.push(DocBlock(
                    content: block_content.trim(),
                    line_start: start_line,
                    line_end: i
                ))

        i = i + 1

    val doc = SspecDoc(
        file_path: path,
        raw_content: content,
        doc_blocks: doc_blocks,
        feature_title: feature_title,
        feature_ids: feature_ids,
        metadata: FeatureMetadata.empty()
    )
    spipe_dbg("parse_spipe_file done: {doc_blocks.len()} doc blocks, title={feature_title}")
    return Ok(doc)

# ============================================================================
# METADATA MODULE
# ============================================================================

fn extract_field_value(line: text, prefix: text) -> text:
    # Extract value from a metadata field line
    if not line.starts_with(prefix):
        return ""

    val value_part = line[prefix.len():]
    value_part.trim()

fn split_metadata_list(value: text) -> [text]:
    var items: [text] = []
    for semi_part in value.split(";"):
        for comma_part in semi_part.split(","):
            val trimmed = comma_part.trim()
            if trimmed != "":
                items.push(trimmed)
    items

fn extract_metadata(doc: SspecDoc) -> FeatureMetadata:
    var metadata = FeatureMetadata.empty()

    # Concatenate all doc blocks for metadata extraction
    var content_parts: [text] = []
    for block in doc.doc_blocks:
        content_parts.push(block.content)
    val full_content = content_parts.join("\n") + "\n"

    # Extract metadata fields from markdown
    val lines = full_content.split("\n")
    for line in lines:
        val trimmed = line.trim()

        # Match patterns like "**Feature ID:** #20" or "**Feature IDs:** #20"
        if trimmed.starts_with("**Feature ID:**"):
            val value = extract_field_value(trimmed, "**Feature ID:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: value, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Feature IDs:**"):
            val value = extract_field_value(trimmed, "**Feature IDs:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: value, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Category:**"):
            val value = extract_field_value(trimmed, "**Category:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: value, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Difficulty:**"):
            val value = extract_field_value(trimmed, "**Difficulty:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: value,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Status:**"):
            val value = extract_field_value(trimmed, "**Status:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: value, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Type:**"):
            val value = extract_field_value(trimmed, "**Type:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: value, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Source:**"):
            val value = extract_field_value(trimmed, "**Source:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: value,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Requirements:**"):
            val value = extract_field_value(trimmed, "**Requirements:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: value, plan: metadata.plan,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Plan:**"):
            val value = extract_field_value(trimmed, "**Plan:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: value,
                    design: metadata.design, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Design:**"):
            val value = extract_field_value(trimmed, "**Design:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: value, research: metadata.research,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Research:**"):
            val value = extract_field_value(trimmed, "**Research:**")
            if value != "":
                metadata = FeatureMetadata(
                    id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                    status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                    requirement: metadata.requirement, plan: metadata.plan,
                    design: metadata.design, research: value,
                    related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                    screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Related:**"):
            val value = extract_field_value(trimmed, "**Related:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: split_metadata_list(value), dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Dependencies:**"):
            val value = extract_field_value(trimmed, "**Dependencies:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: metadata.related, dependencies: split_metadata_list(value), artifacts: metadata.artifacts,
                screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Artifacts:**"):
            val value = extract_field_value(trimmed, "**Artifacts:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: metadata.related, dependencies: metadata.dependencies, artifacts: split_metadata_list(value),
                screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**Screenshots:**"):
            val value = extract_field_value(trimmed, "**Screenshots:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                screenshots: split_metadata_list(value), tui_captures: metadata.tui_captures, logs: metadata.logs)
        elif trimmed.starts_with("**TUI Captures:**"):
            val value = extract_field_value(trimmed, "**TUI Captures:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                screenshots: metadata.screenshots, tui_captures: split_metadata_list(value), logs: metadata.logs)
        elif trimmed.starts_with("**Logs:**"):
            val value = extract_field_value(trimmed, "**Logs:**")
            metadata = FeatureMetadata(
                id: metadata.id, category: metadata.category, difficulty: metadata.difficulty,
                status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
                requirement: metadata.requirement, plan: metadata.plan,
                design: metadata.design, research: metadata.research,
                related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
                screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: split_metadata_list(value))

    # Extract feature ID from feature_ids if metadata.id is not set
    if metadata.id == "" and doc.feature_ids.len() > 0:
        metadata = FeatureMetadata(
            id: doc.feature_ids[0], category: metadata.category, difficulty: metadata.difficulty,
            status: metadata.status, doc_type: metadata.doc_type, source_doc: metadata.source_doc,
            requirement: metadata.requirement, plan: metadata.plan,
            design: metadata.design, research: metadata.research,
            related: metadata.related, dependencies: metadata.dependencies, artifacts: metadata.artifacts,
            screenshots: metadata.screenshots, tui_captures: metadata.tui_captures, logs: metadata.logs)

    metadata

# ============================================================================
# VALIDATION MODULE
# ============================================================================

fn validate_spec(doc: SspecDoc) -> ValidationResult:
    var warnings = []
    val docs_present = doc.doc_blocks.len() > 0

    var doc_lines = 0
    for block in doc.doc_blocks:
        doc_lines = doc_lines + block.content.split("\n").len()

    # Check if doc blocks exist
    if not docs_present:
        warnings.push("No documentation blocks found (stub generated)")
    else:
        # Check total documentation length
        if doc_lines < 100:
            warnings.push("Only {doc_lines} lines of documentation (recommended: 100+)")

        # Concatenate all docs to check for sections
        var validate_parts: [text] = []
        for block in doc.doc_blocks:
            validate_parts.push(block.content)
        val full_content = validate_parts.join("\n") + "\n"

        var has_overview = false
        var has_syntax = false

        val lines = full_content.split("\n")
        for line in lines:
            val trimmed = line.trim()
            if trimmed.starts_with("## Overview") or trimmed.starts_with("## Description"):
                has_overview = true
            if trimmed.starts_with("## Syntax") or trimmed.starts_with("## Examples"):
                has_syntax = true

        # Warn about missing important sections
        if not has_overview:
            warnings.push("Missing '## Overview' or '## Description' section")
        if not has_syntax:
            warnings.push("Missing '## Syntax' or '## Examples' section")

        # Doc-link validation: check presence and file existence
        # Use "N/A" as the value to suppress a warning for links genuinely not applicable
        val req_link = doc.metadata.requirement
        if req_link == "":
            warnings.push("Missing '**Requirements:**' link (use doc/requirement/xxx.md or N/A)")
        elif req_link != "N/A" and not native_fs_exists(req_link):
            warnings.push("Requirements link not found: '{req_link}'")

        val plan_link = doc.metadata.plan
        if plan_link == "":
            warnings.push("Missing '**Plan:**' link (use doc/03_plan/xxx.md or N/A)")
        elif plan_link != "N/A" and not native_fs_exists(plan_link):
            warnings.push("Plan link not found: '{plan_link}'")

        val design_link = doc.metadata.design
        if design_link == "":
            warnings.push("Missing '**Design:**' link (use doc/05_design/xxx.md or N/A)")
        elif design_link != "N/A" and not native_fs_exists(design_link):
            warnings.push("Design link not found: '{design_link}'")

        val research_link = doc.metadata.research
        if research_link == "":
            warnings.push("Missing '**Research:**' link (use doc/01_research/xxx.md or N/A)")
        elif research_link != "N/A" and not native_fs_exists(research_link):
            warnings.push("Research link not found: '{research_link}'")

    ValidationResult(
        file_path: doc.file_path,
        docs_present: docs_present,
        doc_lines: doc_lines,
        warnings: warnings
    )

# ============================================================================
# TEST STRUCTURE EXTRACTION
# ============================================================================

fn extract_quoted_name(line: text) -> text:
    # Extract text between first and last double-quote in a line
    # e.g. describe "Null Coalescing (??)"": -> "Null Coalescing (??)"
    if not line.contains("\""):
        return line
    val parts = line.split("\"")
    if parts.len() >= 2:
        parts[1]
    else:
        line

fn extract_inline_docstring(trimmed: text) -> text:
    # Extract content from """single line content""" (both open and close on same line)
    if trimmed.starts_with("\"\"\"") and trimmed.ends_with("\"\"\"") and trimmed.len() > 6:
        trimmed[3:-3].trim()
    else:
        ""

fn count_leading_indent(line: text) -> i64:
    var count = 0
    while count < line.len():
        val ch = line[count:count + 1]
        if ch == " " or ch == "\t":
            count = count + 1
        else:
            break
    count

fn strip_indent(line: text, indent: i64) -> text:
    if line.trim() == "":
        return ""
    if line.len() <= indent:
        return ""
    line[indent:]

fn trim_trailing_blank_lines(lines: [text]) -> [text]:
    var end = lines.len()
    while end > 0 and lines[end - 1].trim() == "":
        end = end - 1
    var result: [text] = []
    var i = 0
    while i < end:
        result.push(lines[i])
        i = i + 1
    result

fn strip_leading_docstring(lines: [text]) -> [text]:
    var first = 0
    while first < lines.len() and lines[first].trim() == "":
        first = first + 1
    if first >= lines.len():
        return lines

    val trimmed = lines[first].trim()
    if not trimmed.starts_with("\"\"\""):
        return lines

    var after = first + 1
    if trimmed.ends_with("\"\"\"") and trimmed.len() > 3:
        after = first + 1
    else:
        while after < lines.len():
            val cur = lines[after].trim()
            after = after + 1
            if cur == "\"\"\"" or cur.ends_with("\"\"\""):
                break

    var result: [text] = []
    var i = 0
    while i < first:
        result.push(lines[i])
        i = i + 1
    i = after
    while i < lines.len():
        result.push(lines[i])
        i = i + 1
    result

fn dedent_lines(lines: [text]) -> [text]:
    var min_indent = -1
    for line in lines:
        if line.trim() == "":
            continue
        val indent = count_leading_indent(line)
        if min_indent < 0 or indent < min_indent:
            min_indent = indent

    if min_indent <= 0:
        return lines

    var result: [text] = []
    for line in lines:
        result.push(strip_indent(line, min_indent))
    result

struct CustomBlockRender:
    block_name: text
    raw: text
    rendered_text: text
    rendered_latex: text

fn render_scenario_body(lines: [text]) -> text:
    val without_docstring = strip_leading_docstring(lines)
    val trimmed = trim_trailing_blank_lines(without_docstring)
    if trimmed.len() == 0:
        return ""
    val dedented = dedent_lines(trimmed)
    if dedented.len() == 0:
        return ""
    val rendered = render_custom_block_examples(dedented)
    if rendered != "":
        "\n```simple\n" + dedented.join("\n") + "\n```\n\n" + rendered
    else:
        "\n```simple\n" + dedented.join("\n") + "\n```\n\n"

fn normalize_manual_visibility(value: text) -> text:
    val lower = value.lower().trim()
    if lower.contains("skip") or lower.contains("hidden"):
        "skip"
    elif lower.contains("fold") or lower.contains("advanced") or lower.contains("edge"):
        "folded"
    elif lower.contains("detail"):
        "detail"
    elif lower.contains("show") or lower.contains("visible"):
        "show"
    else:
        ""

fn manual_visibility_from_metadata_line(trimmed: text) -> text:
    if trimmed == "# @inline" or trimmed == "@inline":
        return "skip"
    if trimmed.starts_with("# @manual") or trimmed.starts_with("@manual"):
        return normalize_manual_visibility(trimmed)
    ""

fn manual_visibility_warning_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if not (lower.starts_with("# @manual") or lower.starts_with("@manual")):
        return ""
    if lower.starts_with("# @manual-file") or lower.starts_with("# @manual_file"):
        return ""
    if lower.starts_with("# @manual-default") or lower.starts_with("# @manual_default"):
        return ""
    if lower.starts_with("@manual-file") or lower.starts_with("@manual_file"):
        return ""
    if lower.starts_with("@manual-default") or lower.starts_with("@manual_default"):
        return ""
    if normalize_manual_visibility(lower) != "":
        return ""
    "invalid manual visibility metadata: " + trimmed + " (expected show, folded, detail, or skip)"

fn file_manual_visibility_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if lower.starts_with("# @manual-file") or lower.starts_with("# @manual_file"):
        return normalize_manual_visibility(lower)
    if lower.starts_with("# @manual-default") or lower.starts_with("# @manual_default"):
        return normalize_manual_visibility(lower)
    if lower.starts_with("@manual-file") or lower.starts_with("@manual_file"):
        return normalize_manual_visibility(lower)
    if lower.starts_with("@manual-default") or lower.starts_with("@manual_default"):
        return normalize_manual_visibility(lower)
    ""

fn file_manual_visibility(lines: [text]) -> text:
    for line in lines:
        val trimmed = line.trim()
        val visibility = file_manual_visibility_from_metadata_line(trimmed)
        if visibility != "":
            return visibility
    ""

fn config_manual_visibility_from_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    val from_annotation = file_manual_visibility_from_metadata_line(lower)
    if from_annotation != "":
        return from_annotation
    if lower.starts_with("manual:"):
        return normalize_manual_visibility(lower)
    if lower.starts_with("visibility:"):
        return normalize_manual_visibility(lower)
    ""

fn config_manual_visibility(path: text) -> text:
    if path == "":
        return ""
    if not native_fs_exists(path):
        return ""
    val content = native_fs_read_string(path)
    val lines = content.split("\n")
    for line in lines:
        val visibility = config_manual_visibility_from_line(line.trim())
        if visibility != "":
            return visibility
    ""

fn local_path_dirname(path: text) -> text:
    val parts = path.split("/")
    if parts.len() <= 1:
        return ""
    var dirs: [text] = []
    var i = 0
    while i + 1 < parts.len():
        if parts[i] != "":
            dirs.push(parts[i])
        i = i + 1
    dirs.join("/")

fn parent_dirname(path: text) -> text:
    local_path_dirname(path)

fn folder_manual_visibility_for_dir(dir: text) -> text:
    var current = dir
    var searching = true
    while searching:
        var config_path = if current == "": ".sspec-manual" else: current + "/.sspec-manual"
        var visibility = config_manual_visibility(config_path)
        if visibility != "":
            return visibility
        config_path = if current == "": "sspec-manual.sdn" else: current + "/sspec-manual.sdn"
        visibility = config_manual_visibility(config_path)
        if visibility != "":
            return visibility
        if current == "":
            break
        val parent = parent_dirname(current)
        if parent == current:
            break
        current = parent
    ""

fn path_manual_visibility(path: text) -> text:
    if path == "":
        return ""
    folder_manual_visibility_for_dir(local_path_dirname(path))

fn manual_default(file_visibility: text, fallback: text) -> text:
    if file_visibility != "":
        return file_visibility
    fallback

fn is_capture_metadata_line(trimmed: text) -> bool:
    val lower = trimmed.lower().trim()
    lower.starts_with("# @capture") or lower.starts_with("@capture")

fn capture_args_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if not lower.contains("("):
        return ""
    val open_parts = lower.split("(")
    if open_parts.len() < 2:
        return ""
    val close_parts = open_parts[1].split(")")
    close_parts[0].trim()

fn is_capture_metadata_token(token: text) -> bool:
    val value = token.trim()
    value == "tui" or value == "gui" or value == "text" or
        value == "api" or value == "protocol" or value == "exec" or
        value == "binary" or value == "log" or value == "artifact" or
        value == "off" or value == "after_step" or
        value == "after_scenario" or value == "on_failure" or
        value == "on_fail"

fn capture_warning_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if not is_capture_metadata_line(lower):
        return ""
    if not lower.contains("("):
        return ""
    val args = capture_args_from_metadata_line(lower)
    if args == "":
        return "invalid capture metadata value: empty (expected kind tui|gui|text|api|protocol|exec|binary|log|artifact and mode after_step|after_scenario|on_failure|off)"
    for raw_token in args.split(","):
        val token = raw_token.trim()
        if not is_capture_metadata_token(token):
            return "invalid capture metadata value: " + token + " (expected kind tui|gui|text|api|protocol|exec|binary|log|artifact and mode after_step|after_scenario|on_failure|off)"
    ""

fn capture_kind_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if not is_capture_metadata_line(lower):
        return ""
    if capture_warning_from_metadata_line(trimmed) != "":
        return ""
    if lower.contains("gui"):
        return "gui"
    if lower.contains("api"):
        return "api"
    if lower.contains("protocol"):
        return "protocol"
    if lower.contains("text"):
        return "text"
    if lower.contains("exec"):
        return "exec"
    if lower.contains("binary"):
        return "binary"
    if lower.contains("log"):
        return "log"
    if lower.contains("artifact"):
        return "artifact"
    "tui"

fn capture_mode_from_metadata_line(trimmed: text) -> text:
    val lower = trimmed.lower().trim()
    if not is_capture_metadata_line(lower):
        return ""
    if capture_warning_from_metadata_line(trimmed) != "":
        return ""
    if lower.contains("off"):
        return "off"
    if lower.contains("after_scenario"):
        return "after_scenario"
    if lower.contains("on_failure") or lower.contains("on_fail"):
        return "on_failure"
    "after_step"

fn capture_policy_from_metadata_line(trimmed: text) -> text:
    val kind = capture_kind_from_metadata_line(trimmed)
    if kind == "":
        return ""
    val mode = capture_mode_from_metadata_line(trimmed)
    if mode == "off":
        return "off"
    kind + " " + mode

fn scenario_capture_policy(lines: [text], scenario_index: i64) -> text:
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if trimmed == "":
            j = j - 1
            continue
        val capture = capture_policy_from_metadata_line(trimmed)
        if capture != "":
            return capture
        if trimmed.starts_with("#") or trimmed.starts_with("@"):
            j = j - 1
            continue
        break
    ""

fn prev_title_from_metadata_line(trimmed: text) -> text:
    if not (trimmed.starts_with("# @prev") or trimmed.starts_with("@prev")):
        return ""
    if trimmed.contains("\""):
        return extract_quoted_name(trimmed)
    "__previous__"

fn include_title_from_metadata_line(trimmed: text) -> text:
    if not (trimmed.starts_with("# @include") or trimmed.starts_with("@include")):
        return ""
    if trimmed.contains("\""):
        return extract_quoted_name(trimmed)
    ""

fn scenario_prev_title(lines: [text], scenario_index: i64) -> text:
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if trimmed == "":
            j = j - 1
            continue
        val prev_title = prev_title_from_metadata_line(trimmed)
        if prev_title != "":
            return prev_title
        if trimmed.starts_with("#") or trimmed.starts_with("@"):
            j = j - 1
            continue
        break
    ""

fn is_scenario_line(trimmed: text) -> bool:
    if not trimmed.contains("\""):
        return false
    trimmed.starts_with("it ") or trimmed.starts_with("slow_it ") or
        trimmed.starts_with("pending ") or trimmed.starts_with("skip_it ") or
        trimmed.starts_with("skip it ")

fn scenario_title_at(lines: [text], scenario_index: i64) -> text:
    if scenario_index < 0 or scenario_index >= lines.len():
        return ""
    val trimmed = lines[scenario_index].trim()
    if not is_scenario_line(trimmed):
        return ""
    extract_quoted_name(trimmed)

fn previous_scenario_title(lines: [text], scenario_index: i64) -> text:
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if is_scenario_line(trimmed):
            return extract_quoted_name(trimmed)
        j = j - 1
    ""

fn scenario_index_by_title(lines: [text], title: text, excluded_index: i64) -> i64:
    var j = 0
    while j < lines.len():
        val trimmed = lines[j].trim()
        if j != excluded_index and is_scenario_line(trimmed):
            val name = extract_quoted_name(trimmed)
            if name == title:
                return j
        j = j + 1
    -1

fn scenario_body_by_index(lines: [text], scenario_index: i64) -> [text]:
    if scenario_index < 0 or scenario_index >= lines.len():
        return []
    val end_index = find_scenario_body_end(lines, scenario_index + 1, count_leading_indent(lines[scenario_index]))
    collect_scenario_body(lines, scenario_index + 1, end_index)

fn scenario_references_title(lines: [text], scenario_index: i64, title: text) -> bool:
    if title == "":
        return false
    val prev_title = scenario_prev_title(lines, scenario_index)
    if prev_title == title:
        return true
    if prev_title == "__previous__" and previous_scenario_title(lines, scenario_index) == title:
        return true
    val body = scenario_body_by_index(lines, scenario_index)
    for line in body:
        val include_title = include_title_from_metadata_line(line.trim())
        if include_title == title:
            return true
    false

fn scenario_cycle_warning(kind: text, from_title: text, to_title: text) -> text:
    "# @manual-warning: cycle detected in " + kind + " expansion: " + from_title + " -> " + to_title

fn find_previous_scenario_body(lines: [text], scenario_index: i64) -> [text]:
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if is_scenario_line(trimmed):
            val end_index = find_scenario_body_end(lines, j + 1, count_leading_indent(lines[j]))
            return collect_scenario_body(lines, j + 1, end_index)
        j = j - 1
    []

fn find_scenario_body_by_title(lines: [text], title: text, scenario_index: i64) -> [text]:
    if title == "__previous__":
        return find_previous_scenario_body(lines, scenario_index)
    scenario_body_by_index(lines, scenario_index_by_title(lines, title, scenario_index))

fn expand_prev_scenario_body(lines: [text], scenario_index: i64, body: [text]) -> [text]:
    val prev_title = scenario_prev_title(lines, scenario_index)
    if prev_title == "":
        return body
    val current_title = scenario_title_at(lines, scenario_index)
    val target_title = if prev_title == "__previous__": previous_scenario_title(lines, scenario_index) else: prev_title
    val target_index = scenario_index_by_title(lines, target_title, scenario_index)
    if target_title == current_title or scenario_references_title(lines, target_index, current_title):
        var cycle_body: [text] = []
        cycle_body.push(scenario_cycle_warning("prev", current_title, target_title))
        for line in body:
            cycle_body.push(line)
        return cycle_body
    val prev_body = find_scenario_body_by_title(lines, prev_title, scenario_index)
    if prev_body.len() == 0:
        var missing_prev: [text] = []
        val label = if prev_title == "__previous__": "previous scenario" else: prev_title
        missing_prev.push("# @manual-warning: missing prev scenario: " + label)
        for line in body:
            missing_prev.push(line)
        return missing_prev
    var expanded: [text] = []
    for line in prev_body:
        expanded.push(line)
    for line in body:
        expanded.push(line)
    expanded

fn expand_include_scenario_body(lines: [text], scenario_index: i64, body: [text]) -> [text]:
    var expanded: [text] = []
    for line in body:
        val trimmed = line.trim()
        val include_title = include_title_from_metadata_line(trimmed)
        if include_title != "":
            val current_title = scenario_title_at(lines, scenario_index)
            val include_index = scenario_index_by_title(lines, include_title, scenario_index)
            if include_title == current_title or scenario_references_title(lines, include_index, current_title):
                expanded.push(scenario_cycle_warning("include", current_title, include_title))
                continue
            val include_body = find_scenario_body_by_title(lines, include_title, scenario_index)
            if include_body.len() > 0:
                for include_line in include_body:
                    expanded.push(include_line)
            else:
                expanded.push("# @manual-warning: missing include scenario: " + include_title)
        else:
            expanded.push(line)
    expanded

fn scenario_manual_visibility(lines: [text], scenario_index: i64, default_visibility: text) -> text:
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if trimmed == "":
            j = j - 1
            continue
        val visibility = manual_visibility_from_metadata_line(trimmed)
        if visibility != "":
            return visibility
        if trimmed.starts_with("#") or trimmed.starts_with("@"):
            j = j - 1
            continue
        break
    default_visibility

fn scenario_metadata_warnings(lines: [text], scenario_index: i64) -> [text]:
    var warnings: [text] = []
    var j = scenario_index - 1
    while j >= 0:
        val trimmed = lines[j].trim()
        if trimmed == "":
            j = j - 1
            continue
        val manual_warning = manual_visibility_warning_from_metadata_line(trimmed)
        if manual_warning != "":
            warnings.push(manual_warning)
        val capture_warning = capture_warning_from_metadata_line(trimmed)
        if capture_warning != "":
            warnings.push(capture_warning)
        if trimmed.starts_with("#") or trimmed.starts_with("@"):
            j = j - 1
            continue
        break
    warnings

fn add_scenario_metadata_warnings(lines: [text], scenario_index: i64, body: [text]) -> [text]:
    val warnings = scenario_metadata_warnings(lines, scenario_index)
    if warnings.len() == 0:
        return body
    var result: [text] = []
    for warning in warnings:
        result.push("# @manual-warning: " + warning)
    for line in body:
        result.push(line)
    result

fn next_manual_step_label(lines: [text], start_index: i64) -> text:
    var i = start_index
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed == "":
            i = i + 1
            continue
        if trimmed.starts_with("# @") or trimmed.starts_with("@"):
            i = i + 1
            continue
        return trimmed
    ""

fn manual_warning_from_metadata_line(trimmed: text) -> text:
    if trimmed.starts_with("# @manual-warning:"):
        return trimmed["# @manual-warning:".len():].trim()
    if trimmed.starts_with("@manual-warning:"):
        return trimmed["@manual-warning:".len():].trim()
    ""

fn render_manual_warnings(lines: [text]) -> text:
    var warnings: [text] = []
    for line in lines:
        val warning = manual_warning_from_metadata_line(line.trim())
        if warning != "":
            warnings.push("- " + warning)
        val capture_warning = capture_warning_from_metadata_line(line.trim())
        if capture_warning != "":
            warnings.push("- " + capture_warning)
    if warnings.len() == 0:
        return ""
    "\n**Manual warnings:**\n" + warnings.join("\n") + "\n\n"

fn strip_manual_metadata_lines(lines: [text]) -> [text]:
    var result: [text] = []
    for line in lines:
        val trimmed = line.trim()
        val is_capture = is_capture_metadata_line(trimmed)
        val is_include = include_title_from_metadata_line(trimmed) != ""
        val is_warning = manual_warning_from_metadata_line(trimmed) != ""
        if not is_capture and not is_include and not is_warning:
            result.push(line)
    result

fn render_capture_evidence_summary(scenario_capture: text, lines: [text]) -> text:
    var parts: [text] = []
    if scenario_capture != "":
        if scenario_capture == "off":
            parts.push("**Scenario capture:** off")
        else:
            parts.push("**Scenario capture:** " + scenario_capture)
    var step_parts: [text] = []
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        val capture = capture_policy_from_metadata_line(trimmed)
        if capture != "":
            val step_label = next_manual_step_label(lines, i + 1)
            if step_label != "":
                step_parts.push("- " + capture + " before `" + step_label + "`")
            else:
                step_parts.push("- " + capture)
        i = i + 1
    if step_parts.len() > 0:
        parts.push("**Step captures:**\n" + step_parts.join("\n"))
    if parts.len() == 0:
        return ""
    "\n" + parts.join("\n\n") + "\n\n"

fn render_scenario_body_with_capture(lines: [text], scenario_capture: text) -> text:
    val evidence = render_capture_evidence_summary(scenario_capture, lines)
    val warnings = render_manual_warnings(lines)
    val without_metadata = strip_manual_metadata_lines(lines)
    evidence + warnings + render_scenario_body(without_metadata)

fn render_manual_scenario(name: text, suffix: text, body: [text], visibility: text, capture_policy: text) -> text:
    if visibility == "skip":
        return ""
    val heading = "#### " + name + suffix + "\n"
    val rendered_body = render_scenario_body_with_capture(body, capture_policy)
    if visibility == "folded" or visibility == "detail":
        val label = if visibility == "detail": "Details: " else: "Advanced: "
        "<details>\n<summary>" + label + name + "</summary>\n\n" + heading + rendered_body + "\n</details>\n\n"
    else:
        heading + rendered_body

fn render_rendered_scenario_toggle(lines: [text]) -> text:
    var quoted: [text] = []
    var i = 0
    while i < lines.len():
        val suffix = if i + 1 < lines.len(): "<br>" else: ""
        quoted.push("> " + lines[i] + suffix)
        i = i + 1
    "<details>\n<summary>Rendered scenario source</summary>\n\n" + quoted.join("\n") + "\n\n</details>\n\n"

fn extract_custom_block_exprs(line: text, block_name: text) -> [text]:
    var exprs: [text] = []
    var i = 0
    val opener = block_name + "{"
    while i + 1 < line.len():
        if i + opener.len() <= line.len() and line[i:i + opener.len()] == opener:
            var depth = 1
            var j = i + opener.len()
            var expr_parts: [text] = []
            while j < line.len() and depth > 0:
                val ch = line[j:j + 1]
                if ch == "{":
                    depth = depth + 1
                    expr_parts.push(ch)
                elif ch == "}":
                    depth = depth - 1
                    if depth > 0:
                        expr_parts.push(ch)
                else:
                    expr_parts.push(ch)
                j = j + 1
            if depth == 0:
                exprs.push(expr_parts.join("").trim())
                i = j
            else:
                i = i + 1
        else:
                i = i + 1
    exprs

fn render_math_block(expr: text) -> CustomBlockRender:
    CustomBlockRender(
        block_name: "m",
        raw: "m{ " + expr + " }",
        rendered_text: to_text(expr),
        rendered_latex: render_latex_raw(expr)
    )

fn render_registered_custom_blocks(line: text) -> [CustomBlockRender]:
    # Registry: add custom block renderers here as blocks gain markdown renderers.
    var rendered: [CustomBlockRender] = []
    val math_exprs = extract_custom_block_exprs(line, "m")
    for expr in math_exprs:
        if expr != "":
            rendered.push(render_math_block(expr))
    rendered

fn render_line_with_custom_blocks(line: text) -> text:
    var parts: [text] = []
    var i = 0
    val opener = "m{"
    while i < line.len():
        if i + opener.len() <= line.len() and line[i:i + opener.len()] == opener:
            var depth = 1
            var j = i + opener.len()
            var expr_parts: [text] = []
            while j < line.len() and depth > 0:
                val ch = line[j:j + 1]
                if ch == "{":
                    depth = depth + 1
                    expr_parts.push(ch)
                elif ch == "}":
                    depth = depth - 1
                    if depth > 0:
                        expr_parts.push(ch)
                else:
                    expr_parts.push(ch)
                j = j + 1
            if depth == 0:
                parts.push("$" + render_latex_raw(expr_parts.join("").trim()) + "$")
                i = j
            else:
                parts.push(line[i:i + 1])
                i = i + 1
        else:
            parts.push(line[i:i + 1])
            i = i + 1
    parts.join("")

fn render_custom_block_examples(lines: [text]) -> text:
    var has_rendered_block = false
    var rendered_lines: [text] = []
    for line in lines:
        val blocks = render_registered_custom_blocks(line)
        if blocks.len() > 0:
            has_rendered_block = true
        rendered_lines.push(render_line_with_custom_blocks(line))
    if has_rendered_block:
        render_rendered_scenario_toggle(rendered_lines)
    else:
        ""

fn find_scenario_body_end(lines: [text], start: i64, scenario_indent: i64) -> i64:
    var k = start
    while k < lines.len():
        val cur = lines[k]
        if cur.trim() == "":
            k = k + 1
            continue
        if count_leading_indent(cur) <= scenario_indent:
            break
        k = k + 1
    k

fn collect_scenario_body(lines: [text], start: i64, end_index: i64) -> [text]:
    var body: [text] = []
    var k = start
    while k < end_index:
        body.push(lines[k])
        k = k + 1
    body

fn extract_test_structure_with_default(content: text, default_visibility: text) -> text:
    val lines = content.split("\n")
    val file_visibility = file_manual_visibility(lines)
    val resolved_file_visibility = manual_default(file_visibility, default_visibility)
    var result_parts: [text] = []
    var i = 0
    var in_docstring = false

    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()

        # Handle multi-line docstring content — skip until closing """
        if in_docstring:
            if trimmed == "\"\"\"" or trimmed.ends_with("\"\"\""):
                in_docstring = false
            i = i + 1
            continue

        # Detect standalone """ opening (multi-line block)
        if trimmed == "\"\"\"":
            in_docstring = true
            i = i + 1
            continue

        # Detect inline multi-line start: """text (no closing """ on same line)
        if trimmed.starts_with("\"\"\"") and not (trimmed.ends_with("\"\"\"") and trimmed.len() > 6):
            in_docstring = true
            i = i + 1
            continue

        # describe block -> H3
        if trimmed.starts_with("describe ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            result_parts.push("### {name}\n")

            # Check next line for single-line docstring
            if i + 1 < lines.len():
                val next_trimmed = lines[i + 1].trim()
                val doc = extract_inline_docstring(next_trimmed)
                if doc != "":
                    result_parts.push("_{doc}_\n")
                    i = i + 1

            result_parts.push("\n")

        # skip context block -> H4 with skipped marker
        elif trimmed.starts_with("skip context ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            result_parts.push("#### {name} _(skipped)_\n")

        # regular context block -> H4
        elif trimmed.starts_with("context ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            result_parts.push("#### {name}\n")

            # Check next line for single-line docstring
            if i + 1 < lines.len():
                val next_trimmed = lines[i + 1].trim()
                val doc = extract_inline_docstring(next_trimmed)
                if doc != "":
                    result_parts.push("_{doc}_\n")
                    i = i + 1

            result_parts.push("\n")

        # skip it / skip_it -> skipped scenario
        elif (trimmed.starts_with("skip it ") or trimmed.starts_with("skip_it ")) and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            val next_index = find_scenario_body_end(lines, i + 1, count_leading_indent(line))
            val body = collect_scenario_body(lines, i + 1, next_index)
            val expanded_body = expand_prev_scenario_body(lines, i, body)
            val included_body = expand_include_scenario_body(lines, i, expanded_body)
            val final_body = add_scenario_metadata_warnings(lines, i, included_body)
            val visibility = scenario_manual_visibility(lines, i, manual_default(resolved_file_visibility, "show"))
            val capture = scenario_capture_policy(lines, i)
            result_parts.push(render_manual_scenario(name, " _(skipped)_", final_body, visibility, capture))
            i = next_index - 1

        # pending -> pending bullet
        elif trimmed.starts_with("pending ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            val next_index = find_scenario_body_end(lines, i + 1, count_leading_indent(line))
            val body = collect_scenario_body(lines, i + 1, next_index)
            val expanded_body = expand_prev_scenario_body(lines, i, body)
            val included_body = expand_include_scenario_body(lines, i, expanded_body)
            val final_body = add_scenario_metadata_warnings(lines, i, included_body)
            val visibility = scenario_manual_visibility(lines, i, manual_default(resolved_file_visibility, "show"))
            val capture = scenario_capture_policy(lines, i)
            result_parts.push(render_manual_scenario(name, " _(pending)_", final_body, visibility, capture))
            i = next_index - 1

        # slow it -> slow bullet
        elif trimmed.starts_with("slow_it ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            val next_index = find_scenario_body_end(lines, i + 1, count_leading_indent(line))
            val body = collect_scenario_body(lines, i + 1, next_index)
            val expanded_body = expand_prev_scenario_body(lines, i, body)
            val included_body = expand_include_scenario_body(lines, i, expanded_body)
            val final_body = add_scenario_metadata_warnings(lines, i, included_body)
            val visibility = scenario_manual_visibility(lines, i, manual_default(resolved_file_visibility, "folded"))
            val capture = scenario_capture_policy(lines, i)
            result_parts.push(render_manual_scenario(name, " _(slow)_", final_body, visibility, capture))
            i = next_index - 1

        # regular it -> check bullet
        elif trimmed.starts_with("it ") and trimmed.contains("\""):
            val name = extract_quoted_name(trimmed)
            val next_index = find_scenario_body_end(lines, i + 1, count_leading_indent(line))
            val body = collect_scenario_body(lines, i + 1, next_index)
            val expanded_body = expand_prev_scenario_body(lines, i, body)
            val included_body = expand_include_scenario_body(lines, i, expanded_body)
            val final_body = add_scenario_metadata_warnings(lines, i, included_body)
            val visibility = scenario_manual_visibility(lines, i, manual_default(resolved_file_visibility, "show"))
            val capture = scenario_capture_policy(lines, i)
            result_parts.push(render_manual_scenario(name, "", final_body, visibility, capture))
            i = next_index - 1

        i = i + 1

    result_parts.join("").trim()

fn extract_test_structure_with_path(content: text, path: text) -> text:
    extract_test_structure_with_default(content, path_manual_visibility(path))

fn extract_test_structure(content: text) -> text:
    extract_test_structure_with_default(content, "")
