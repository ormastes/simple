# SPipe Documentation Generator — Common Types & Utilities
#
# Shared struct definitions, log helpers, and filesystem compatibility aliases.
# Imported by parser.spl, generator.spl, and main.spl.

use app.io.mod (file_read, file_write, file_exists, dir_create, env_get)

# Local log helpers — std.log.debug/info/warn/error are broken in interpreter mode
# (GLOBAL_LOG_LEVEL undefined due to type annotation issue, causes crash at runtime).
# Per log.spl docs, use inline env_get pattern for CLI-mode files.
# Using prefixed names (spipe_*) to avoid conflict with std.log transitively imported.
fn spipe_dbg(msg: text):
    val level = env_get("SIMPLE_LOG")
    if level == "debug" or level == "trace" or level == "all":
        print "[DEBUG] [spipe_docgen] {msg}"

fn spipe_info(msg: text):
    val level = env_get("SIMPLE_LOG")
    if level == "info" or level == "debug" or level == "trace" or level == "all":
        print "[INFO] [spipe_docgen] {msg}"

fn spipe_warn(msg: text):
    val level = env_get("SIMPLE_LOG")
    if level != "" and level != "off" and level != "error":
        print "[WARN] [spipe_docgen] {msg}"

fn spipe_err(msg: text):
    val level = env_get("SIMPLE_LOG")
    if level != "" and level != "off":
        print "[ERROR] [spipe_docgen] {msg}"

# Compatibility aliases for native_fs_* -> io module
fn native_fs_read_string(path: text) -> text:
    val result = file_read(path)
    result ?? ""

fn native_fs_write_string(path: text, content: text) -> bool:
    file_write(path, content)

fn native_fs_exists(path: text) -> bool:
    file_exists(path)

fn native_fs_create_dir(path: text):
    dir_create(path, true)

# ============================================================================
# TYPE DEFINITIONS
# ============================================================================

# Documentation block extracted from spipe file
struct DocBlock:
    content: text
    line_start: i64
    line_end: i64

# Feature metadata extracted from documentation
struct FeatureMetadata:
    id: text
    category: text
    difficulty: text
    status: text
    requirement: text   # link to requirement doc
    plan: text          # link to plan doc
    design: text        # link to design/architecture doc
    research: text      # link to research doc
    artifacts: [text]
    screenshots: [text]
    tui_captures: [text]
    logs: [text]

    static fn empty() -> FeatureMetadata:
        FeatureMetadata(id: "", category: "", difficulty: "", status: "",
                        requirement: "", plan: "", design: "", research: "",
                        artifacts: [], screenshots: [], tui_captures: [], logs: [])

# Parsed spipe file with documentation and test structure
struct SspecDoc:
    file_path: text
    raw_content: text
    doc_blocks: [DocBlock]
    feature_title: text
    feature_ids: [text]
    metadata: FeatureMetadata

# Validation result for a spec file
struct ValidationResult:
    file_path: text
    docs_present: bool
    doc_lines: i64
    warnings: [text]

# Statistics for documentation generation
struct DocStats:
    total_specs: i64
    specs_with_docs: i64
    specs_without_docs: i64
    total_doc_lines: i64
    total_warnings: i64

    static fn empty() -> DocStats:
        DocStats(
            total_specs: 0,
            specs_with_docs: 0,
            specs_without_docs: 0,
            total_doc_lines: 0,
            total_warnings: 0
        )

    fn coverage_percent(self) -> f64:
        if self.total_specs == 0:
            0.0
        else:
            (self.specs_with_docs * 100) / self.total_specs

# Feature entry for INDEX generation
struct FeatureEntry:
    title: text
    filename: text
    status: text
    difficulty: text
    coverage: text
    doc_lines: i64
    category: text
    test_count: i64
