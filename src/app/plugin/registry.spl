# Plugin manifest registry helpers for SFFI dynamic plugins.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_env_get(key: text) -> text
extern fn rt_env_home() -> text

fn file_exists(path: text) -> bool:
    rt_file_exists(path)

fn file_read(path: text) -> text:
    rt_file_read_text(path)

fn file_write(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn dir_create_all(path: text) -> bool:
    rt_dir_create_all(path)

fn env_get(key: text) -> text:
    rt_env_get(key)

fn home() -> text:
    rt_env_home()

struct PluginMethodEntry:
    name: text
    symbol: text
    params: [text]
    return_type: text

struct PluginClassEntry:
    name: text
    constructor_symbol: text
    destructor_symbol: text
    methods: [PluginMethodEntry]

struct PluginEntry:
    name: text
    library: text
    version: text
    functions: [text]
    classes: [PluginClassEntry]

fn plugin_entry_new(name: text, library: text, version: text, functions: [text]) -> PluginEntry:
    PluginEntry(name: name, library: library, version: version, functions: functions, classes: [])

fn plugin_entry_new_with_classes(name: text, library: text, version: text, functions: [text], classes: [PluginClassEntry]) -> PluginEntry:
    PluginEntry(name: name, library: library, version: version, functions: functions, classes: classes)

fn plugin_manifest_path() -> text:
    val override_path = env_get("SIMPLE_PLUGIN_MANIFEST") ?? ""
    if override_path != "":
        return override_path
    val home_dir = home() ?? ""
    if home_dir == "":
        return ".simple/plugins/manifest.sdn"
    home_dir + "/.simple/plugins/manifest.sdn"

fn parse_functions_line(line: text) -> [text]:
    val start = line.find("[")
    val end = line.rfind("]")
    if start < 0 or end <= start:
        return []
    val inner = line.substring(start + 1, end).trim()
    if inner == "":
        return []
    val parts = inner.split(",")
    var functions: [text] = []
    for part in parts:
        val function_name = strip_quotes(part.trim())
        if function_name != "":
            functions.push(function_name)
    functions

fn strip_quotes(value: text) -> text:
    var result = value.trim()
    if result.starts_with("\"") and result.ends_with("\"") and result.len() >= 2:
        result = result.substring(1, result.len() - 1)
    result

fn flush_current_plugin(entries: [PluginEntry], current_name: text, current_library: text, current_version: text, current_functions: [text], current_classes: [PluginClassEntry]) -> [PluginEntry]:
    if current_name == "":
        return entries
    var updated = entries
    updated.push(plugin_entry_new_with_classes(current_name, current_library, current_version, current_functions, current_classes))
    updated

fn parse_method_params_line(line: text) -> [text]:
    val start = line.find("[")
    val end = line.rfind("]")
    if start < 0 or end <= start:
        return []
    val inner = line.substring(start + 1, end).trim()
    if inner == "":
        return []
    val parts = inner.split(",")
    var params: [text] = []
    for part in parts:
        val param = strip_quotes(part.trim())
        if param != "":
            params.push(param)
    params

fn parse_plugin_manifest_text(content: text) -> [PluginEntry]:
    if content.trim() == "":
        return []

    val lines = content.split("\n")
    var entries: [PluginEntry] = []
    var current_name = ""
    var current_library = ""
    var current_version = ""
    var current_functions: [text] = []
    var current_classes: [PluginClassEntry] = []
    var in_plugin = false

    # Class parsing state
    var in_classes_block = false
    var class_name = ""
    var class_constructor = ""
    var class_destructor = ""
    var class_methods: [PluginMethodEntry] = []
    var in_methods_block = false
    var method_name = ""
    var method_symbol = ""
    var method_params: [text] = []
    var method_return_type = ""

    for raw_line in lines:
        val line = raw_line.trim()
        if line == "" or line.starts_with("#") or line == "plugins:":
            continue

        val indent = raw_line.len() - raw_line.trim_start().len()

        if line == "-":
            # Flush in-progress method
            if method_name != "":
                class_methods.push(PluginMethodEntry(name: method_name, symbol: method_symbol, params: method_params, return_type: method_return_type))
                method_name = ""
                method_symbol = ""
                method_params = []
                method_return_type = ""
            # Flush in-progress class
            if class_name != "":
                current_classes.push(PluginClassEntry(name: class_name, constructor_symbol: class_constructor, destructor_symbol: class_destructor, methods: class_methods))
                class_name = ""
                class_constructor = ""
                class_destructor = ""
                class_methods = []
            in_classes_block = false
            in_methods_block = false

            if in_plugin:
                entries = flush_current_plugin(entries, current_name, current_library, current_version, current_functions, current_classes)
            in_plugin = true
            current_name = ""
            current_library = ""
            current_version = ""
            current_functions = []
            current_classes = []
            continue

        # Inside methods block - method properties (deeply indented)
        if in_methods_block and indent >= 20:
            if line.starts_with("symbol:"):
                method_symbol = strip_quotes(line.substring(7).trim())
                continue
            if line.starts_with("params:"):
                method_params = parse_method_params_line(line)
                continue
            if line.starts_with("return:"):
                method_return_type = strip_quotes(line.substring(7).trim())
                continue

        # Inside methods block - new method name
        if in_methods_block and indent >= 16 and line.ends_with(":") and not line.starts_with("symbol:") and not line.starts_with("params:") and not line.starts_with("return:"):
            if method_name != "":
                class_methods.push(PluginMethodEntry(name: method_name, symbol: method_symbol, params: method_params, return_type: method_return_type))
            method_name = line.substring(0, line.len() - 1).trim()
            method_symbol = ""
            method_params = []
            method_return_type = ""
            continue

        # Inside classes block - class properties
        if in_classes_block and indent >= 12:
            if line.starts_with("constructor:"):
                class_constructor = strip_quotes(line.substring(12).trim())
                continue
            if line.starts_with("destructor:"):
                class_destructor = strip_quotes(line.substring(11).trim())
                continue
            if line == "methods:":
                in_methods_block = true
                continue

        # Inside classes block - new class name
        if in_classes_block and indent >= 8 and line.ends_with(":") and not line.starts_with("constructor:") and not line.starts_with("destructor:") and not line.starts_with("methods:"):
            if method_name != "":
                class_methods.push(PluginMethodEntry(name: method_name, symbol: method_symbol, params: method_params, return_type: method_return_type))
                method_name = ""
                method_symbol = ""
                method_params = []
                method_return_type = ""
            if class_name != "":
                current_classes.push(PluginClassEntry(name: class_name, constructor_symbol: class_constructor, destructor_symbol: class_destructor, methods: class_methods))
            class_name = line.substring(0, line.len() - 1).trim()
            class_constructor = ""
            class_destructor = ""
            class_methods = []
            in_methods_block = false
            continue

        if line == "classes:":
            in_classes_block = true
            in_methods_block = false
            continue

        # Top-level entry fields
        if line.starts_with("name:"):
            in_classes_block = false
            in_methods_block = false
            current_name = strip_quotes(line.substring(5).trim())
        elif line.starts_with("library:"):
            in_classes_block = false
            in_methods_block = false
            current_library = strip_quotes(line.substring(8).trim())
        elif line.starts_with("version:"):
            in_classes_block = false
            in_methods_block = false
            current_version = strip_quotes(line.substring(8).trim())
        elif line.starts_with("functions:"):
            in_classes_block = false
            in_methods_block = false
            current_functions = parse_functions_line(line)

    # Final flush
    if method_name != "":
        class_methods.push(PluginMethodEntry(name: method_name, symbol: method_symbol, params: method_params, return_type: method_return_type))
    if class_name != "":
        current_classes.push(PluginClassEntry(name: class_name, constructor_symbol: class_constructor, destructor_symbol: class_destructor, methods: class_methods))
    if in_plugin:
        entries = flush_current_plugin(entries, current_name, current_library, current_version, current_functions, current_classes)
    entries

fn load_plugin_manifest(path: text) -> [PluginEntry]:
    if not file_exists(path):
        return []
    val content = file_read(path) ?? ""
    parse_plugin_manifest_text(content)

fn functions_to_sdn(functions: [text]) -> text:
    if functions.len() == 0:
        return "[]"
    var rendered: [text] = []
    for function_name in functions:
        rendered.push(function_name)
    "[" + rendered.join(", ") + "]"

fn plugin_manifest_to_text(entries: [PluginEntry]) -> text:
    var lines: [text] = ["plugins:"]
    for entry in entries:
        lines.push("    -")
        lines.push("        name: " + entry.name)
        lines.push("        library: " + entry.library)
        if entry.version != "":
            lines.push("        version: \"" + entry.version + "\"")
        if entry.functions.len() > 0:
            lines.push("        functions: " + functions_to_sdn(entry.functions))
        if entry.classes.len() > 0:
            lines.push("        classes:")
            for cls in entry.classes:
                lines.push("            " + cls.name + ":")
                lines.push("                constructor: " + cls.constructor_symbol)
                lines.push("                destructor: " + cls.destructor_symbol)
                if cls.methods.len() > 0:
                    lines.push("                methods:")
                    for method in cls.methods:
                        lines.push("                    " + method.name + ":")
                        lines.push("                        symbol: " + method.symbol)
                        lines.push("                        params: " + functions_to_sdn(method.params))
                        lines.push("                        return: " + method.return_type)
    lines.join("\n") + "\n"

fn validate_unique_symbols(entries: [PluginEntry]) -> text:
    var seen: Dict<text, text> = {}
    for entry in entries:
        for function_name in entry.functions:
            if seen.contains(function_name):
                return "duplicate extern symbol '" + function_name + "' in plugins '" + seen[function_name] + "' and '" + entry.name + "'"
            seen[function_name] = entry.name
        for cls in entry.classes:
            if cls.constructor_symbol != "":
                if seen.contains(cls.constructor_symbol):
                    return "duplicate extern symbol '" + cls.constructor_symbol + "' in plugins '" + seen[cls.constructor_symbol] + "' and '" + entry.name + "'"
                seen[cls.constructor_symbol] = entry.name
            if cls.destructor_symbol != "":
                if seen.contains(cls.destructor_symbol):
                    return "duplicate extern symbol '" + cls.destructor_symbol + "' in plugins '" + seen[cls.destructor_symbol] + "' and '" + entry.name + "'"
                seen[cls.destructor_symbol] = entry.name
            for method in cls.methods:
                if method.symbol != "":
                    if seen.contains(method.symbol):
                        return "duplicate extern symbol '" + method.symbol + "' in plugins '" + seen[method.symbol] + "' and '" + entry.name + "'"
                    seen[method.symbol] = entry.name
    ""

fn save_plugin_manifest(path: text, entries: [PluginEntry]) -> bool:
    val duplicate_error = validate_unique_symbols(entries)
    if duplicate_error != "":
        print duplicate_error
        return false
    val last_slash = path.rfind("/")
    if last_slash > 0:
        val dir_path = path.substring(0, last_slash)
        if not dir_create_all(dir_path):
            return false
    file_write(path, plugin_manifest_to_text(entries))

fn merge_plugin_entries(existing: [PluginEntry], incoming: [PluginEntry]) -> [PluginEntry]:
    var merged = existing
    for new_entry in incoming:
        var replaced = false
        var i = 0
        while i < merged.len():
            if merged[i].name == new_entry.name:
                merged[i] = new_entry
                replaced = true
            i = i + 1
        if not replaced:
            merged.push(new_entry)
    merged

fn remove_plugin_entry(entries: [PluginEntry], name: text) -> [PluginEntry]:
    var filtered: [PluginEntry] = []
    for entry in entries:
        if entry.name != name:
            filtered.push(entry)
    filtered

fn find_plugin_entry(entries: [PluginEntry], name: text) -> PluginEntry?:
    for entry in entries:
        if entry.name == name:
            return entry
    nil
