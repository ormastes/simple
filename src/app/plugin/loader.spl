# Minimal plugin loader helpers for manifest-managed SFFI libraries.

use app.plugin.registry.{PluginEntry}

extern fn rt_file_exists(path: text) -> bool

fn file_exists(path: text) -> bool:
    rt_file_exists(path)

fn plugin_library_exists(entry: PluginEntry) -> bool:
    if entry.library == "":
        return false
    file_exists(entry.library)
