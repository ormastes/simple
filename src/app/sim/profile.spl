# Simple simulator/oracle profile helpers
#
# This module prints the shared RISC-V machine profiles and delegates
# simulator-oracle runs to the existing `simple os` QEMU-backed path.

use os.machine_profile.{MachineProfile, machine_arch_name, machine_profile_name,
    get_riscv_machine_profiles, get_riscv_machine_profile}
use os.qemu_runner.{build_os, run_os, get_target}

fn print_sim_help():
    print "Simple simulation/oracle surface"
    print ""
    print "Usage:"
    print "  simple sim targets"
    print "  simple sim show --arch=riscv64"
    print "  simple sim run --arch=riscv64"
    print "  simple sim boot-linux --arch=riscv64"
    print ""
    print "Commands:"
    print "  targets        List shared RISC-V machine profiles"
    print "  show           Show one shared machine profile"
    print "  run            Route to the existing OS/QEMU oracle path"
    print "  boot-linux     Reserve the future Linux simulator entrypoint"
    print ""
    print "Options:"
    print "  --arch=<name>  Target architecture (riscv64, riscv32, simple-rv64, simple-rv32)"
    print ""
    print "Note:"
    print "  This is an oracle-backed surface. The repo-native simulator is"
    print "  not implemented yet."

fn print_profile(profile: MachineProfile):
    print "Profile: {machine_profile_name(profile)}"
    print "  arch: {machine_arch_name(profile.arch)}"
    print "  xlen: {profile.xlen}"
    print "  isa: {profile.isa}"
    print "  abi: {profile.abi}"
    print "  boot_protocol: {profile.boot_protocol}"
    print "  target_triple: {profile.target_triple}"
    print "  entry: {profile.entry}"
    print "  linker_script: {profile.linker_script}"
    print "  output: {profile.output}"
    print "  qemu_system: {profile.qemu_system}"
    print "  qemu_machine: {profile.qemu_machine}"
    print "  qemu_cpu: {profile.qemu_cpu}"
    print "  qemu_memory: {profile.qemu_memory}"
    print "  qemu_bios: {profile.qemu_bios}"
    print "  console: {profile.console}"
    print "  oracle_path: {profile.oracle_path}"
    print "  notes: {profile.notes}"

fn print_targets():
    print "Shared RISC-V machine profiles:"
    print ""
    val profiles = get_riscv_machine_profiles()
    for profile in profiles:
        print "  {machine_profile_name(profile)} -> {machine_arch_name(profile.arch)} ({profile.isa})"
    print ""
    print "Use `simple sim show --arch=riscv64` for details."

fn show_profile_by_arch(arch_name: text) -> bool:
    val profile = get_riscv_machine_profile(arch_name)
    if val Some(p) = profile:
        print_profile(p)
        true
    else:
        false

fn run_oracle_by_arch(arch_name: text) -> i64:
    val profile = get_riscv_machine_profile(arch_name)
    if val Some(p) = profile:
        print "[sim] oracle: {p.oracle_path}"
        print "[sim] delegating to existing OS/QEMU path"
        val target = get_target(p.arch)
        if not build_os(target):
            return 1
        if run_os(target):
            0
        else:
            1
    print "Error: unknown shared machine profile '{arch_name}'"
    print "Run 'simple sim targets' for supported profiles."
    1

fn boot_linux_by_arch(arch_name: text) -> i64:
    val profile = get_riscv_machine_profile(arch_name)
    if val Some(p) = profile:
        if p.arch != Architecture.Riscv64:
            print "Error: Linux boot is only planned for RV64 in this program"
            return 1
        print "[sim] boot-linux reserved for {machine_profile_name(p)}"
        print "[sim] repo-native Linux simulator boot is not wired yet"
        return 1
    print "Error: unknown shared machine profile '{arch_name}'"
    print "Run 'simple sim targets' for supported profiles."
    1
