# Simple simulator/oracle CLI
#
# This is a thin entrypoint that exposes shared RISC-V machine profile data
# and delegates simulator-oracle runs to the existing `simple os` path.

use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.sim.profile.{print_sim_help, print_targets, show_profile_by_arch, run_oracle_by_arch, boot_linux_by_arch}

extern fn rt_cli_get_args() -> [text]

fn get_cli_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var start_idx = 0
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/sim/main.spl") or all_args[i] == "src/app/sim/main.spl" or all_args[i] == "sim":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn parse_arch_arg(args: [text]) -> text:
    for arg in args:
        if arg.starts_with("--arch="):
            return arg[7:]
        if arg.starts_with("--target="):
            return arg[9:]
    var i = 0
    while i < args.len() - 1:
        if args[i] == "--arch" or args[i] == "--target":
            return args[i + 1]
        i = i + 1
    "riscv64"

fn print_help():
    print_sim_help()
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn handle_show(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    if show_profile_by_arch(arch_name):
        0
    else:
        error("sim", "unknown shared machine profile '{arch_name}'")
        print "Run 'simple sim targets' for supported profiles."
        1

fn handle_run(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    run_oracle_by_arch(arch_name)

fn handle_boot_linux(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    boot_linux_by_arch(arch_name)

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("sim", log_opts.error)
        return 1

    val args = clean_log_args(raw_args)

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"sim\",\"status\":\"usage\"}"
            return 0
        print_help()
        return 0

    val subcommand = args[0]
    val rest = if args.len() > 1: args[1:] else: []

    match subcommand:
        case "targets" | "list":
            print_targets()
            0
        case "show" | "profile":
            handle_show(rest)
        case "run":
            handle_run(rest)
        case "boot-linux":
            handle_boot_linux(rest)
        case "-h":
            print_help_with_progress(log_opts.progress)
            0
        case "--help":
            print_help_with_progress(log_opts.progress)
            0
        case "help":
            print_help_with_progress(log_opts.progress)
            0
        case _:
            if log_opts.log_mode == "json":
                print "{\"command\":\"sim\",\"status\":\"error\",\"error\":\"unknown command\"}"
                return 1
            error("sim", "unknown subcommand '{subcommand}'")
            print ""
            print_help()
            1
