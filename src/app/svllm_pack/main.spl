# svllm_pack — CLI: safetensors → tensor_pack converter
#
# Phase A1: prints help + version, exits 0. Real conversion lands in A2.
#
# Usage (target):
#   svllm_pack convert <in.safetensors> <out_pack_root>
#   svllm_pack inspect <pack_root>
#   svllm_pack verify  <pack_root>

fn print_help() -> ():
    print("svllm_pack — convert upstream safetensors into a sealed tensor_pack")
    print("")
    print("usage:")
    print("  svllm_pack convert <in.safetensors> <out_pack_root>")
    print("  svllm_pack inspect <pack_root>")
    print("  svllm_pack verify  <pack_root>")
    print("  svllm_pack --help")

fn main() -> ():
    print_help()
    print("")
    print("(A1 stub — convert/inspect/verify land in A2)")
