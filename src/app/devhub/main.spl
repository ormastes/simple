# ITF CLI — Main dispatcher
#
# gh-like CLI for Jira + Confluence
# Usage: bin/simple itf <command> [flags]

use app.devhub.cmd_wiki.{handle_wiki}
use app.devhub.cmd_jira.{handle_jira}
use app.devhub.cmd_api.{handle_api}
use app.devhub.cmd_auth.{handle_auth}
use app.devhub.cmd_bb.{handle_bb}
use app.devhub.cmd_minio.{handle_minio}
use app.devhub.cmd_outlook.{handle_outlook}
use app.devhub.cmd_github.{handle_github}
use app.devhub.cmd_storage.{handle_storage}
use app.devhub.cmd_email.{handle_email}
use app.devhub.cmd_tasks.{handle_tasks}
use app.devhub.cmd_daily_debug.{run_daily_debug}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_cli_get_args() -> [text]


val ITF_VERSION = "0.1.0"

fn main() -> i64:
    val raw_args = _itf_get_args()
    val global_args = _itf_global_log_args(raw_args)
    val log_opts = parse_log_options(global_args)
    if not log_opts.valid:
        error("itf", log_opts.error)
        return 1

    val args = _itf_clean_global_log_args(raw_args)
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"itf\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        _print_help()
        return 0

    if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        _print_help()
        return 0

    if log_opts.log_mode == "json" and (args[0] == "--version" or args[0] == "version"):
        print "{\"command\":\"itf\",\"status\":\"ok\",\"version\":\"{ITF_VERSION}\"}"
        return 0

    handle_itf(args)

fn handle_itf(args: [text]) -> i64:
    """Main entry point for itf CLI.

    Dispatches to subcommands: wiki, jira, api, auth, bb, minio, outlook, daily-debug
    """
    if args.len() == 0:
        _print_help()
        return 0

    val subcmd = args[0]
    val sub_args = if args.len() > 1: args[1:] else: []

    match subcmd:
        "wiki" | "w":
            handle_wiki(sub_args)
        "jira" | "j":
            handle_jira(sub_args)
        "api":
            handle_api(sub_args)
        "auth":
            handle_auth(sub_args)
        "bb" | "b":
            handle_bb(sub_args)
        "minio" | "mio":
            handle_minio(sub_args)
        "outlook" | "ol":
            handle_outlook(sub_args)
        "github" | "gh":
            handle_github(sub_args)
        "storage" | "web_storage":
            handle_storage(sub_args)
        "email":
            handle_email(sub_args)
        "tasks" | "task_manager":
            handle_tasks(sub_args)
        "daily-debug" | "dd":
            run_daily_debug(sub_args)
        "-h" | "--help" | "help":
            _print_help()
            0
        "--version" | "version":
            print "devhub {ITF_VERSION}"
            0
        _:
            print "Unknown command: {subcmd}"
            print ""
            _print_help()
            1


fn _print_help():
    """Print top-level help matching gh CLI style."""
    print "devhub — famous-CLI ergonomics over your configured backends"
    print ""
    print "Usage: devhub <command> [flags]"
    print ""
    print "Facades (one UX, several backends — pick with --backend):"
    print "  tasks, task_manager  gh-issue UX over Jira + GitHub (list, view, create, edit, close)"
    print "  github, gh           gh UX over GitHub (issue, pr, repo) via the system gh CLI"
    print "  bb, b                gh-shaped UX over Bitbucket Cloud (pr, comment, approve, merge)"
    print "  wiki, w              gh-like UX over Confluence + GitHub wiki (list, view, edit, create)"
    print "  storage, web_storage mc UX over MinIO/S3 (ls, cp, cat, stat, mirror, presign, rm, mb)"
    print "  email                Gmail UX over Gmail/IMAP + MS Graph (inbox, read, search, send)"
    print ""
    print "Direct backend commands:"
    print "  jira, j           Jira issues (view, search, create)"
    print "  minio, mio        MinIO/S3 (ls, get, put, stat, presign, health)"
    print "  outlook, ol       Microsoft Graph mail (folders, messages, get, move, mark)"
    print "  api               Raw REST API calls"
    print "  auth              Authentication (login, status, logout)"
    print "  daily-debug, dd   Daily debug-analysis pipeline (mail → jira → minio → triage)"
    print ""
    print "Flags:"
    print "  --json       Output as JSON (with optional field selection)"
    print "  --jq EXPR    Filter JSON output (e.g. .[].title)"
    print "  --web        Open in browser"
    print "  --no-pager   Never page long listing output (jira search, github list, minio ls)"
    print "  --help, -h   Show help"
    print "  --version    Show version"
    print ""
    print "Examples:"
    print "  devhub auth login --confluence --url https://company.atlassian.net/wiki --user email --token TOKEN"
    print "  devhub tasks list --backend jira --assignee @me --state open"
    print "  devhub tasks create --title \"fix login\" --body \"steps...\""
    print "  devhub storage ls myminio/backups --bytes"
    print "  devhub storage mirror ./dist myminio/site --dry-run"
    print "  devhub email search \"from:alerts is:unread\" --limit 20"
    print "  devhub wiki list --space ENG"
    print "  devhub jira search \"project = PROJ\" --limit 10"
    print ""
    print "Environment:"
    print "  ITF_EDITOR       Editor override"
    print "  ITF_PAGER        Pager override"
    print "  ITF_FORCE_COLOR  Force color output (1/0)"
    print "  NO_COLOR         Disable color output"
    print ""
    print "Config: ~/.config/itf/config.sdn"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn _itf_is_global_log_arg(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _itf_global_log_args(args: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _itf_is_global_log_arg(arg):
            out.push(arg)
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                if i + 1 < args.len():
                    i = i + 1
                    out.push(args[i])
        else:
            return out
        i = i + 1
    out

fn _itf_clean_global_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    var in_global_prefix = true
    while i < args.len():
        val arg = args[i]
        if in_global_prefix and _itf_is_global_log_arg(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            in_global_prefix = false
            cleaned.push(arg)
        i = i + 1
    cleaned

fn _itf_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_itf = false
    var i = 0
    while i < all_args.len():
        if found_itf:
            args.push(all_args[i])
        elif all_args[i] == "itf":
            found_itf = true
        i = i + 1
    if found_itf:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/devhub/main.spl") or all_args[i] == "src/app/devhub/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
