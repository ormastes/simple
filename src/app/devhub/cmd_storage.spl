# cmd_storage.spl — `devhub storage` / `itf storage` (`mc`-shaped facade over
# the existing MinIO/S3 adapter).
#
# Reference: doc/05_design/app/devhub/facade_storage.md — verb→adapter
# mapping table (§3), alias/config model (§4), error/exit-code convention
# (§6). This module is a thin dispatcher: every actual S3 call goes through
# `adapter_minio.spl` (imported read-only, never edited by this worker).
# Addressing/parsing lives in storage_addr.spl (also new, same worker).
#
# Exit codes mirror cmd_minio.spl's existing convention (facade_storage.md
# §6): 0 success, 1 failure — no other codes in use anywhere in itf/storage.

use std.io_runtime.{time_now_unix_micros, file_read, file_size, file_exists, file_delete, dir_walk, dir_create_all, is_dir}
use app.devhub.storage_addr.{StorageAddr, parse_storage_addr, infer_cp_direction, resolve_alias_config, is_known_alias}
use app.devhub.adapter_minio.{
    load_minio_config, ObjectInfo,
    minio_list_buckets, minio_list_objects, minio_get_object, minio_stat_object,
    minio_put_text, minio_presign_get, minio_presign_put, minio_health_live,
    minio_download, minio_create_bucket, minio_delete_bucket, minio_delete_object
}
use app.devhub.flags.{_extract_flag, _has_flag, _positional_args}
use app.devhub.output.{print_error, print_success, print_info, print_dim, print_table_dynamic, format_json_output, wants_json, format_size, format_transfer_summary, set_no_pager}


fn handle_storage(args: [text]) -> i64:
    """Dispatch `storage`/`web_storage` subcommands (devhub_overview.md §2)."""
    if args.len() == 0:
        _print_storage_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "ls":
            _storage_ls(action_args)
        "cp":
            _storage_cp(action_args)
        "cat":
            _storage_cat(action_args)
        "stat":
            _storage_stat(action_args)
        "mb":
            _storage_mb(action_args)
        "rb":
            _storage_rb(action_args)
        "rm":
            _storage_rm(action_args)
        "presign":
            _storage_presign(action_args)
        "presign-put":
            _storage_presign_put(action_args)
        "du":
            _storage_du(action_args)
        "mirror":
            _storage_mirror(action_args)
        "health":
            _storage_health(action_args)
        "-h" | "--help" | "help":
            _print_storage_help()
            0
        _:
            print_error("unknown storage command: {action}")
            _print_storage_help()
            1


fn _parse_int(s: text, default_val: i64) -> i64:
    var n: i64 = 0
    var i = 0
    var any = false
    while i < s.len():
        val c = s.char_code_at(i)
        if c >= 48 and c <= 57:
            n = n * 10 + (c - 48)
            any = true
        i = i + 1
    if any: n else: default_val


# ---------------------------------------------------------------------------
# ls
# ---------------------------------------------------------------------------

fn _storage_ls(args: [text]) -> i64:
    """`storage ls [alias[/bucket[/prefix]]] [-r|--recursive] [--bytes] [--json] [--no-pager]`

    No TARGET defaults to the bare `minio` alias (bucket listing).
    """
    set_no_pager(_has_flag(args, "--no-pager"))
    val pos = _positional_args(args)
    val target = if pos.len() > 0: pos[0] else: "minio"
    val addr = parse_storage_addr(target)
    if not addr.valid or not addr.is_remote:
        print_error("usage: storage ls [alias[/bucket[/prefix]]] — TARGET must be alias/bucket[/prefix], not a local path (got '{target}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1

    if addr.bucket == "":
        val (ok, buckets, raw) = minio_list_buckets(cfg)
        if not ok:
            print_error(raw)
            return 1
        if wants_json(args):
            print format_json_output(raw, args)
            return 0
        if buckets.len() == 0:
            print "No buckets found."
            return 0
        var bucket_rows: [[text]] = []
        for b in buckets:
            bucket_rows.push([b.name, b.creation_date])
        print_table_dynamic(["NAME", "CREATED"], bucket_rows)
        return 0

    if not _has_flag(args, "-r") and not _has_flag(args, "--recursive"):
        print_dim("note: storage ls always lists the full prefix recursively today (no folder-collapsed non-recursive mode yet) — see facade_storage.md §3 ls row")
    val (ok, objects, raw) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print format_json_output(raw, args)
        return 0
    if objects.len() == 0:
        val suffix = if addr.key != "": "/{addr.key}" else: ""
        print "No objects found under {addr.alias}/{addr.bucket}{suffix}. Try a different prefix."
        return 0
    val raw_bytes = _has_flag(args, "--bytes")
    var object_rows: [[text]] = []
    for o in objects:
        val size_text = if raw_bytes: "{o.size}" else: format_size(o.size)
        object_rows.push([o.key, size_text, o.last_modified])
    print_table_dynamic(["KEY", "SIZE", "MODIFIED"], object_rows)
    0


# ---------------------------------------------------------------------------
# cat
# ---------------------------------------------------------------------------

fn _storage_cat(args: [text]) -> i64:
    """`storage cat alias/bucket/key [--range R]`"""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage cat alias/bucket/key [--range R]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage cat alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val range_h = _extract_flag(args, "--range", "")
    val (ok, result, raw) = minio_get_object(cfg, addr.bucket, addr.key, range_h)
    if not ok:
        print_error(raw)
        return 1
    print result.body
    0


# ---------------------------------------------------------------------------
# stat
# ---------------------------------------------------------------------------

fn _storage_stat(args: [text]) -> i64:
    """`storage stat alias/bucket/key [--bytes] [--json]`

    Same HEAD-via-ListObjectsV2 fidelity caveat as `itf minio stat`
    (adapter_minio.minio_stat_object's docstring): the underlying HTTP
    transport exposes no response headers, so this is not a real HEAD.
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage stat alias/bucket/key [--bytes] [--json]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage stat alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, head, raw) = minio_stat_object(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print "{{\"key\":\"{addr.key}\",\"size\":{head.content_length},\"etag\":\"{head.etag}\",\"last_modified\":\"{head.last_modified}\"}}"
        return 0
    val size_text = if _has_flag(args, "--bytes"): "{head.content_length}" else: format_size(head.content_length)
    print_info("Size", size_text)
    print_info("ETag", head.etag)
    print_info("Last-Modified", head.last_modified)
    0


# ---------------------------------------------------------------------------
# mb / rb
# ---------------------------------------------------------------------------

fn _storage_mb(args: [text]) -> i64:
    """`storage mb alias/bucket`"""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage mb alias/bucket")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage mb alias/bucket — TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_create_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket created: {addr.alias}/{addr.bucket}")
    0


fn _storage_rb(args: [text]) -> i64:
    """`storage rb alias/bucket [--force]`

    `--force`: list every object under the bucket and delete each one before
    deleting the bucket itself (mirrors mc's `rb --force` recursive
    empty-then-delete). Bounded: refuses with a clear message — no partial
    delete attempted — if the bucket holds more than 1000 objects, since
    adapter_minio.spl has no batch DeleteObjects call, only single-object
    DELETE (minio_delete_object), so --force is a plain per-object loop.
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rb alias/bucket [--force]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage rb alias/bucket — TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    if _has_flag(args, "--force"):
        val (list_ok, objects, list_err) = minio_list_objects(cfg, addr.bucket, "")
        if not list_ok:
            print_error(list_err)
            return 1
        if objects.len() > 1000:
            print_error("storage rb --force: refusing — {addr.alias}/{addr.bucket} has {objects.len()} objects, over the 1000-object safety cap for per-object delete (adapter_minio.spl has no batch DeleteObjects call). Empty it with the real `mc rm --recursive` CLI first, then retry `storage rb`.")
            return 1
        for o in objects:
            val (del_ok, del_err) = minio_delete_object(cfg, addr.bucket, o.key)
            if not del_ok:
                print_error("storage rb --force: failed deleting {addr.alias}/{addr.bucket}/{o.key}: {del_err}")
                return 1
    val (ok, err) = minio_delete_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket deleted: {addr.alias}/{addr.bucket}")
    0


# ---------------------------------------------------------------------------
# rm — confirmation-free single-object delete (mirrors mc's default
# non-interactive `rm`). `--recursive`/`-r` deletes every object under a
# required, non-empty alias/bucket/prefix: list via minio_list_objects, then
# a bounded per-object-DELETE loop with the same 1000-object safety cap and
# message shape as `rb --force` (adapter_minio.spl has no batch
# DeleteObjects call, only single-object DELETE). A bare `alias/bucket` (no
# prefix) is refused outright — `rm -r` must never mass-delete a whole
# bucket; that's `rb --force`'s job. See
# doc/05_design/app/devhub/facade_storage.md §3 (rm row).
# ---------------------------------------------------------------------------

fn _storage_rm(args: [text]) -> i64:
    """`storage rm alias/bucket/key [-r|--recursive]`

    Plain form deletes one object. `-r`/`--recursive` deletes every object
    under alias/bucket/prefix — the prefix is required; a bare alias/bucket
    is refused (use `rb --force` to remove a whole bucket).
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rm alias/bucket/key [-r|--recursive]")
        return 1
    if _has_flag(args, "-r") or _has_flag(args, "--recursive"):
        return _storage_rm_recursive(pos[0])
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage rm alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_delete_object(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(err)
        return 1
    print_success("deleted {addr.alias}/{addr.bucket}/{addr.key}")
    0


fn _storage_rm_recursive(target: text) -> i64:
    """`storage rm -r alias/bucket/prefix` — list+delete-many over a
    required, non-empty prefix.

    Same 1000-object safety cap and message shape as `rb --force`
    (facade_storage.md §3 rb row): adapter_minio.spl has no batch
    DeleteObjects call, only single-object DELETE (minio_delete_object), so
    this is a plain per-object loop — refused outright rather than run
    partially over a huge listing. A bare alias/bucket (empty prefix) is
    refused before any config/network access; use `rb --force` instead.
    """
    val addr = parse_storage_addr(target)
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage rm -r alias/bucket/prefix — TARGET must be alias/bucket/prefix (got '{target}')")
        return 1
    if addr.key == "":
        print_error("storage rm --recursive: '{target}' has no prefix — rm -r never mass-deletes a whole bucket; use rb --force to remove a whole bucket, or give a prefix like alias/bucket/prefix.")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (list_ok, objects, list_err) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not list_ok:
        print_error(list_err)
        return 1
    if objects.len() > 1000:
        print_error("storage rm --recursive: refusing — {addr.alias}/{addr.bucket}/{addr.key} has {objects.len()} objects, over the 1000-object safety cap for per-object delete (adapter_minio.spl has no batch DeleteObjects call). Empty it with the real `mc rm --recursive` CLI first, then retry, or narrow the prefix.")
        return 1
    if objects.len() == 0:
        print "No objects found under {addr.alias}/{addr.bucket}/{addr.key}. Nothing to delete."
        return 0
    var deleted = 0
    for o in objects:
        val (del_ok, del_err) = minio_delete_object(cfg, addr.bucket, o.key)
        if not del_ok:
            print_error("storage rm --recursive: failed deleting {addr.alias}/{addr.bucket}/{o.key}: {del_err}")
            return 1
        print_dim("deleted {addr.alias}/{addr.bucket}/{o.key}")
        deleted = deleted + 1
    print_success("deleted {deleted} objects under {addr.alias}/{addr.bucket}/{addr.key}")
    0


