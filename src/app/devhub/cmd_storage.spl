# cmd_storage.spl — `devhub storage` / `itf storage` (`mc`-shaped facade over
# the existing MinIO/S3 adapter).
#
# Reference: doc/05_design/app/devhub/facade_storage.md — verb→adapter
# mapping table (§3), alias/config model (§4), error/exit-code convention
# (§6). This module is a thin dispatcher: every actual S3 call goes through
# `adapter_minio.spl` (imported read-only, never edited by this worker).
# Addressing/parsing lives in storage_addr.spl (also new, same worker).
#
# Exit codes mirror cmd_minio.spl's existing convention (facade_storage.md
# §6): 0 success, 1 failure — no other codes in use anywhere in itf/storage.

use std.nogc_sync_mut.file_system.file_ops.{file_read_text}
use std.io_runtime.{time_now_unix_micros}
use app.devhub.storage_addr.{StorageAddr, parse_storage_addr, infer_cp_direction, resolve_alias_config, is_known_alias}
use app.devhub.adapter_minio.{
    load_minio_config,
    minio_list_buckets, minio_list_objects, minio_get_object, minio_stat_object,
    minio_put_text, minio_presign_get, minio_presign_put, minio_health_live,
    minio_download, minio_create_bucket, minio_delete_bucket, minio_delete_object
}
use app.devhub.flags.{_extract_flag, _has_flag, _positional_args}
use app.devhub.output.{print_error, print_success, print_info, print_dim, print_table_dynamic, format_json_output, wants_json, format_size, format_transfer_summary, set_no_pager}


fn handle_storage(args: [text]) -> i64:
    """Dispatch `storage`/`web_storage` subcommands (devhub_overview.md §2)."""
    if args.len() == 0:
        _print_storage_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "ls":
            _storage_ls(action_args)
        "cp":
            _storage_cp(action_args)
        "cat":
            _storage_cat(action_args)
        "stat":
            _storage_stat(action_args)
        "mb":
            _storage_mb(action_args)
        "rb":
            _storage_rb(action_args)
        "rm":
            _storage_rm(action_args)
        "presign":
            _storage_presign(action_args)
        "presign-put":
            _storage_presign_put(action_args)
        "du":
            _storage_du(action_args)
        "mirror":
            _storage_mirror(action_args)
        "health":
            _storage_health(action_args)
        "-h" | "--help" | "help":
            _print_storage_help()
            0
        _:
            print_error("unknown storage command: {action}")
            _print_storage_help()
            1


fn _parse_int(s: text, default_val: i64) -> i64:
    var n: i64 = 0
    var i = 0
    var any = false
    while i < s.len():
        val c = s.char_code_at(i)
        if c >= 48 and c <= 57:
            n = n * 10 + (c - 48)
            any = true
        i = i + 1
    if any: n else: default_val


# ---------------------------------------------------------------------------
# ls
# ---------------------------------------------------------------------------

fn _storage_ls(args: [text]) -> i64:
    """`storage ls [alias[/bucket[/prefix]]] [-r|--recursive] [--bytes] [--json] [--no-pager]`

    No TARGET defaults to the bare `minio` alias (bucket listing).
    """
    set_no_pager(_has_flag(args, "--no-pager"))
    val pos = _positional_args(args)
    val target = if pos.len() > 0: pos[0] else: "minio"
    val addr = parse_storage_addr(target)
    if not addr.valid or not addr.is_remote:
        print_error("usage: storage ls [alias[/bucket[/prefix]]] — TARGET must be alias/bucket[/prefix], not a local path (got '{target}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1

    if addr.bucket == "":
        val (ok, buckets, raw) = minio_list_buckets(cfg)
        if not ok:
            print_error(raw)
            return 1
        if wants_json(args):
            print format_json_output(raw, args)
            return 0
        if buckets.len() == 0:
            print "No buckets found."
            return 0
        var bucket_rows: [[text]] = []
        for b in buckets:
            bucket_rows.push([b.name, b.creation_date])
        print_table_dynamic(["NAME", "CREATED"], bucket_rows)
        return 0

    if not _has_flag(args, "-r") and not _has_flag(args, "--recursive"):
        print_dim("note: storage ls always lists the full prefix recursively today (no folder-collapsed non-recursive mode yet) — see facade_storage.md §3 ls row")
    val (ok, objects, raw) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print format_json_output(raw, args)
        return 0
    if objects.len() == 0:
        val suffix = if addr.key != "": "/{addr.key}" else: ""
        print "No objects found under {addr.alias}/{addr.bucket}{suffix}. Try a different prefix."
        return 0
    val raw_bytes = _has_flag(args, "--bytes")
    var object_rows: [[text]] = []
    for o in objects:
        val size_text = if raw_bytes: "{o.size}" else: format_size(o.size)
        object_rows.push([o.key, size_text, o.last_modified])
    print_table_dynamic(["KEY", "SIZE", "MODIFIED"], object_rows)
    0


# ---------------------------------------------------------------------------
# cat
# ---------------------------------------------------------------------------

fn _storage_cat(args: [text]) -> i64:
    """`storage cat alias/bucket/key [--range R]`"""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage cat alias/bucket/key [--range R]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage cat alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val range_h = _extract_flag(args, "--range", "")
    val (ok, result, raw) = minio_get_object(cfg, addr.bucket, addr.key, range_h)
    if not ok:
        print_error(raw)
        return 1
    print result.body
    0


# ---------------------------------------------------------------------------
# stat
# ---------------------------------------------------------------------------

fn _storage_stat(args: [text]) -> i64:
    """`storage stat alias/bucket/key [--bytes] [--json]`

    Same HEAD-via-ListObjectsV2 fidelity caveat as `itf minio stat`
    (adapter_minio.minio_stat_object's docstring): the underlying HTTP
    transport exposes no response headers, so this is not a real HEAD.
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage stat alias/bucket/key [--bytes] [--json]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage stat alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, head, raw) = minio_stat_object(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print "{{\"key\":\"{addr.key}\",\"size\":{head.content_length},\"etag\":\"{head.etag}\",\"last_modified\":\"{head.last_modified}\"}}"
        return 0
    val size_text = if _has_flag(args, "--bytes"): "{head.content_length}" else: format_size(head.content_length)
    print_info("Size", size_text)
    print_info("ETag", head.etag)
    print_info("Last-Modified", head.last_modified)
    0


# ---------------------------------------------------------------------------
# mb / rb
# ---------------------------------------------------------------------------

fn _storage_mb(args: [text]) -> i64:
    """`storage mb alias/bucket`"""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage mb alias/bucket")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage mb alias/bucket — TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_create_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket created: {addr.alias}/{addr.bucket}")
    0


fn _storage_rb(args: [text]) -> i64:
    """`storage rb alias/bucket [--force]`

    `--force`: list every object under the bucket and delete each one before
    deleting the bucket itself (mirrors mc's `rb --force` recursive
    empty-then-delete). Bounded: refuses with a clear message — no partial
    delete attempted — if the bucket holds more than 1000 objects, since
    adapter_minio.spl has no batch DeleteObjects call, only single-object
    DELETE (minio_delete_object), so --force is a plain per-object loop.
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rb alias/bucket [--force]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage rb alias/bucket — TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    if _has_flag(args, "--force"):
        val (list_ok, objects, list_err) = minio_list_objects(cfg, addr.bucket, "")
        if not list_ok:
            print_error(list_err)
            return 1
        if objects.len() > 1000:
            print_error("storage rb --force: refusing — {addr.alias}/{addr.bucket} has {objects.len()} objects, over the 1000-object safety cap for per-object delete (adapter_minio.spl has no batch DeleteObjects call). Empty it with the real `mc rm --recursive` CLI first, then retry `storage rb`.")
            return 1
        for o in objects:
            val (del_ok, del_err) = minio_delete_object(cfg, addr.bucket, o.key)
            if not del_ok:
                print_error("storage rb --force: failed deleting {addr.alias}/{addr.bucket}/{o.key}: {del_err}")
                return 1
    val (ok, err) = minio_delete_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket deleted: {addr.alias}/{addr.bucket}")
    0


# ---------------------------------------------------------------------------
# rm — confirmation-free single-object delete (mirrors mc's default
# non-interactive `rm`). `--recursive`/`-r` deletes every object under a
# required, non-empty alias/bucket/prefix: list via minio_list_objects, then
# a bounded per-object-DELETE loop with the same 1000-object safety cap and
# message shape as `rb --force` (adapter_minio.spl has no batch
# DeleteObjects call, only single-object DELETE). A bare `alias/bucket` (no
# prefix) is refused outright — `rm -r` must never mass-delete a whole
# bucket; that's `rb --force`'s job. See
# doc/05_design/app/devhub/facade_storage.md §3 (rm row).
# ---------------------------------------------------------------------------

fn _storage_rm(args: [text]) -> i64:
    """`storage rm alias/bucket/key [-r|--recursive]`

    Plain form deletes one object. `-r`/`--recursive` deletes every object
    under alias/bucket/prefix — the prefix is required; a bare alias/bucket
    is refused (use `rb --force` to remove a whole bucket).
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rm alias/bucket/key [-r|--recursive]")
        return 1
    if _has_flag(args, "-r") or _has_flag(args, "--recursive"):
        return _storage_rm_recursive(pos[0])
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage rm alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_delete_object(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(err)
        return 1
    print_success("deleted {addr.alias}/{addr.bucket}/{addr.key}")
    0


fn _storage_rm_recursive(target: text) -> i64:
    """`storage rm -r alias/bucket/prefix` — list+delete-many over a
    required, non-empty prefix.

    Same 1000-object safety cap and message shape as `rb --force`
    (facade_storage.md §3 rb row): adapter_minio.spl has no batch
    DeleteObjects call, only single-object DELETE (minio_delete_object), so
    this is a plain per-object loop — refused outright rather than run
    partially over a huge listing. A bare alias/bucket (empty prefix) is
    refused before any config/network access; use `rb --force` instead.
    """
    val addr = parse_storage_addr(target)
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage rm -r alias/bucket/prefix — TARGET must be alias/bucket/prefix (got '{target}')")
        return 1
    if addr.key == "":
        print_error("storage rm --recursive: '{target}' has no prefix — rm -r never mass-deletes a whole bucket; use rb --force to remove a whole bucket, or give a prefix like alias/bucket/prefix.")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (list_ok, objects, list_err) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not list_ok:
        print_error(list_err)
        return 1
    if objects.len() > 1000:
        print_error("storage rm --recursive: refusing — {addr.alias}/{addr.bucket}/{addr.key} has {objects.len()} objects, over the 1000-object safety cap for per-object delete (adapter_minio.spl has no batch DeleteObjects call). Empty it with the real `mc rm --recursive` CLI first, then retry, or narrow the prefix.")
        return 1
    if objects.len() == 0:
        print "No objects found under {addr.alias}/{addr.bucket}/{addr.key}. Nothing to delete."
        return 0
    var deleted = 0
    for o in objects:
        val (del_ok, del_err) = minio_delete_object(cfg, addr.bucket, o.key)
        if not del_ok:
            print_error("storage rm --recursive: failed deleting {addr.alias}/{addr.bucket}/{o.key}: {del_err}")
            return 1
        print_dim("deleted {addr.alias}/{addr.bucket}/{o.key}")
        deleted = deleted + 1
    print_success("deleted {deleted} objects under {addr.alias}/{addr.bucket}/{addr.key}")
    0


# ---------------------------------------------------------------------------
# presign / presign-put
# ---------------------------------------------------------------------------

fn _storage_presign(args: [text]) -> i64:
    """`storage presign alias/bucket/key [--expires SECONDS]` (mc: `share download`)."""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage presign alias/bucket/key [--expires SECONDS]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage presign alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val expires = _parse_int(_extract_flag(args, "--expires", "86400"), 86400)
    val (ok, url, err) = minio_presign_get(cfg, addr.bucket, addr.key, expires)
    if not ok:
        print_error(err)
        return 1
    print url
    0


fn _storage_presign_put(args: [text]) -> i64:
    """`storage presign-put alias/bucket/key [--expires SECONDS]` (mc: `share upload`,
    deliberately simpler than mc's multi-field POST-policy form — a bare
    presigned PUT URL, per facade_storage.md §1/§3)."""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage presign-put alias/bucket/key [--expires SECONDS]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage presign-put alias/bucket/key — TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val expires = _parse_int(_extract_flag(args, "--expires", "86400"), 86400)
    val (ok, url, err) = minio_presign_put(cfg, addr.bucket, addr.key, expires)
    if not ok:
        print_error(err)
        return 1
    print url
    0


# ---------------------------------------------------------------------------
# du — client-side aggregation over minio_list_objects (facade_storage.md §3
# du row: "pure aggregation over existing minio_list_objects, no new SFFI").
# ---------------------------------------------------------------------------

fn _index_of(items: [text], value: text) -> i64:
    var i = 0
    while i < items.len():
        if items[i] == value:
            return i
        i = i + 1
    -1


fn _truncate_to_depth(key: text, depth: i64) -> text:
    """First `depth` "/"-separated segments of `key`, joined back with "/"
    and a trailing "/" (mc's own `du --depth` truncates the same way).
    Returns `key` unchanged if it has `depth` or fewer segments."""
    val parts = key.split("/")
    if parts.len() <= depth:
        return key
    var out: [text] = []
    var i = 0
    while i < depth:
        out.push(parts[i])
        i = i + 1
    out.join("/") + "/"


fn _storage_du(args: [text]) -> i64:
    """`storage du alias/bucket[/prefix] [--depth N] [--bytes] [--json]`

    No `--depth` (or `--depth 0`): one aggregate total-size + object-count
    line. `--depth N`: group by the first N "/"-segments under the prefix
    and print one row per group (mirrors mc's `du --depth` truncation).
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage du alias/bucket[/prefix] [--depth N]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage du alias/bucket[/prefix] — TARGET must be alias/bucket[/prefix] (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, objects, raw) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    val raw_bytes = _has_flag(args, "--bytes")
    val depth = _parse_int(_extract_flag(args, "--depth", "0"), 0)

    if depth <= 0:
        var total: i64 = 0
        for o in objects:
            total = total + o.size
        if wants_json(args):
            print "{{\"alias\":\"{addr.alias}\",\"bucket\":\"{addr.bucket}\",\"prefix\":\"{addr.key}\",\"total_size\":{total},\"object_count\":{objects.len()}}}"
            return 0
        val size_text = if raw_bytes: "{total}" else: format_size(total)
        print_success("{size_text}  {objects.len()} objects  {addr.alias}/{addr.bucket}/{addr.key}")
        return 0

    var group_names: [text] = []
    var group_sizes: [i64] = []
    for o in objects:
        val group = _truncate_to_depth(o.key, depth)
        val idx = _index_of(group_names, group)
        if idx < 0:
            group_names.push(group)
            group_sizes.push(o.size)
        else:
            group_sizes[idx] = group_sizes[idx] + o.size
    if objects.len() == 0:
        print "No objects found under {addr.alias}/{addr.bucket}/{addr.key}."
        return 0
    var rows: [[text]] = []
    var i = 0
    while i < group_names.len():
        val size_text = if raw_bytes: "{group_sizes[i]}" else: format_size(group_sizes[i])
        rows.push([size_text, group_names[i]])
        i = i + 1
    print_table_dynamic(["SIZE", "PATH"], rows)
    0


# ---------------------------------------------------------------------------
# mirror — GAP, explicitly out of scope for this pass (facade_storage.md §3
# mirror row + §7): needs either a new ls+cp loop in the facade layer or an
# `mc mirror` argv wrapper, neither of which is implemented here.
# ---------------------------------------------------------------------------

fn _storage_mirror(args: [text]) -> i64:
    """`storage mirror SRC TARGET [--dry-run]` — not yet implemented, see docstring above."""
    print_error("storage mirror: not yet implemented — needs a new ls+cp loop or an `mc mirror` wrapper (out of scope for this pass); see doc/05_design/app/devhub/facade_storage.md §3/§7. Workaround: run `storage cp` per object, or use the real `mc mirror` CLI if installed.")
    1


# ---------------------------------------------------------------------------
# cp
# ---------------------------------------------------------------------------

fn _storage_cp(args: [text]) -> i64:
    """`storage cp SRC DST [--content-type CT]`

    Direction is inferred purely from which side is local vs. alias/bucket/key
    (facade_storage.md §1/§3, infer_cp_direction()) — no --upload/--download flag.
    """
    val pos = _positional_args(args)
    if pos.len() < 2:
        print_error("usage: storage cp SRC DST [--content-type CT]")
        return 1
    val src = parse_storage_addr(pos[0])
    val dst = parse_storage_addr(pos[1])
    if not src.valid:
        print_error("storage cp: invalid SRC '{pos[0]}': {src.error}")
        return 1
    if not dst.valid:
        print_error("storage cp: invalid DST '{pos[1]}': {dst.error}")
        return 1
    val direction = infer_cp_direction(src, dst)
    if direction == "error_remote_remote":
        print_error("storage cp: remote→remote copy is not supported by this facade — download then upload as two steps, or use `mc mirror`/`mc cp` directly if installed.")
        return 1
    if direction == "error_local_local":
        print_error("storage cp: both SRC and DST are local paths — the storage facade only handles local↔remote transfers; use a plain filesystem copy for local→local.")
        return 1
    if direction == "upload":
        return _storage_cp_upload(src, dst, args)
    _storage_cp_download(src, dst, args)


fn _storage_cp_upload(src: StorageAddr, dst: StorageAddr, args: [text]) -> i64:
    """local→remote. Text bodies (UTF-8 decodable) go through minio_put_text
    directly; binary bodies get a real, ready-to-run presigned-PUT curl
    command (the actual working escape hatch — see adapter_minio.minio_put_object's
    docstring for why a direct binary PUT isn't supported yet)."""
    if dst.bucket == "" or dst.key == "":
        print_error("storage cp: upload DST must be a full alias/bucket/key (got '{dst.raw}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(dst.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val ct = _extract_flag(args, "--content-type", "")
    val content = file_read_text(src.local_path)
    if content != nil:
        val started = time_now_unix_micros()
        val (ok, _etag, raw) = minio_put_text(cfg, dst.bucket, dst.key, content, ct)
        val elapsed_ms = (time_now_unix_micros() - started) / 1000
        if not ok:
            print_error(raw)
            return 1
        print_success("uploaded {dst.alias}/{dst.bucket}/{dst.key} ({content.len()} bytes, text path)")
        print_dim(format_transfer_summary("uploaded", content.len(), elapsed_ms))
        return 0
    val (ok, url, err) = minio_presign_put(cfg, dst.bucket, dst.key, 86400)
    if not ok:
        print_error("storage cp: binary upload needs the presign-put escape hatch, and generating it failed: {err}")
        return 1
    print_error("storage cp: '{src.local_path}' isn't valid UTF-8 (binary body) — direct binary PUT isn't supported yet (needs a raw-bytes HTTP SFFI; see adapter_minio.minio_put_object). Run this instead:")
    print "  curl -X PUT --data-binary @{src.local_path} \"{url}\""
    1


fn _storage_cp_download(src: StorageAddr, dst: StorageAddr, args: [text]) -> i64:
    """remote→local, via the streaming presigned-download path (minio_download)
    so binary objects round-trip correctly (unlike the text-only get path)."""
    if src.bucket == "" or src.key == "":
        print_error("storage cp: download SRC must be a full alias/bucket/key (got '{src.raw}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(src.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val started = time_now_unix_micros()
    val (ok, bytes, err) = minio_download(cfg, src.bucket, src.key, dst.local_path, 3600)
    val elapsed_ms = (time_now_unix_micros() - started) / 1000
    if not ok:
        print_error(err)
        return 1
    print_success("wrote {bytes} bytes to {dst.local_path}")
    print_dim(format_transfer_summary("downloaded", bytes, elapsed_ms))
    0


# ---------------------------------------------------------------------------
# health
# ---------------------------------------------------------------------------

fn _storage_health(args: [text]) -> i64:
    """`storage health [alias] [--json]` — no TARGET defaults to `minio`."""
    val pos = _positional_args(args)
    val alias = if pos.len() > 0: pos[0] else: "minio"
    if not is_known_alias(alias):
        print_error("unknown alias '{alias}' — only the single-endpoint 'minio' alias is supported today; see doc/05_design/app/devhub/facade_storage.md §4")
        return 1
    val cfg = load_minio_config()
    if cfg.tls_skip_verify:
        print_error("tls_skip_verify is not supported by the pure-Simple HTTP transport (no TLS-verify override in the underlying HTTP SFFI). Remove tls_skip_verify from ~/.config/itf/auth.sdn.")
        return 1
    if cfg.url == "":
        print_error("MinIO URL not configured for alias '{alias}'")
        return 1
    val (ok, alive, latency_ms, raw) = minio_health_live(cfg)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print "{{\"alias\":\"{alias}\",\"alive\":{alive},\"status\":\"{raw}\",\"latency_ms\":{latency_ms},\"endpoint\":\"{cfg.url}\"}}"
        return 0
    if alive:
        print_success("OK — {alias} ({cfg.url}, {latency_ms}ms, {raw})")
        return 0
    print_error("FAIL — {alias} ({cfg.url}, {latency_ms}ms): {raw}")
    1


# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

fn _print_storage_help():
    """Print `storage`/`web_storage` help text (mc-shaped facade — see
    doc/05_design/app/devhub/facade_storage.md)."""
    print "storage (web_storage) — mc-style facade over S3-compatible object storage"
    print ""
    print "Usage: storage <command> [alias/][bucket[/key...]] [flags]"
    print ""
    print "Commands:"
    print "  ls [alias[/bucket[/prefix]]]     List buckets, or objects under a bucket/prefix"
    print "  cp SRC DST                       Copy — direction inferred from local vs alias/bucket/key"
    print "  cat alias/bucket/key             Print object body to stdout (--range R)"
    print "  stat alias/bucket/key            Size/etag/last-modified (via ListObjectsV2 — see NOTE)"
    print "  mb alias/bucket                  Create a bucket"
    print "  rb alias/bucket                  Delete a bucket (--force: delete objects first, bounded to 1000)"
    print "  rm alias/bucket/key              Delete an object (--recursive/-r: delete every object under a prefix, bounded to 1000)"
    print "  presign alias/bucket/key         Generate a presigned GET URL (--expires SECONDS)"
    print "  presign-put alias/bucket/key     Generate a presigned PUT URL (binary-upload workaround)"
    print "  du alias/bucket[/prefix]         Aggregate object sizes under a prefix (--depth N)"
    print "  mirror SRC DST                   NOT YET IMPLEMENTED (see below)"
    print "  health [alias]                   Probe /minio/health/live"
    print ""
    print "Flags:"
    print "  --json            Output as JSON"
    print "  --range R         For `cat`: HTTP Range header value (e.g. bytes=0-1023)"
    print "  --bytes           For `ls`/`stat`/`du`: raw byte counts instead of KiB/MiB/GiB"
    print "  --expires N       For `presign`/`presign-put`: URL validity in seconds (default 86400)"
    print "  --depth N         For `du`: truncate the grouped summary to N path segments"
    print "  --content-type CT For `cp` (upload): response Content-Type"
    print "  --no-pager        Never page long `ls` output"
    print ""
    print "Addressing: every TARGET is either a local filesystem path, or"
    print "  alias/bucket[/key...] — bare `minio` is the only alias today (single-endpoint"
    print "  fallback onto the existing [minio] section; see facade_storage.md §4)."
    print ""
    print "NOTE: `stat`/`ls` cannot use a real HEAD for size/etag/last-modified — the"
    print "  underlying HTTP transport exposes no response headers, so these fall back"
    print "  to ListObjectsV2. `mirror` is a documented gap, not a silent no-op."
    print ""
    print "Config: ~/.config/itf/auth.sdn"
    print "  [minio]"
    print "  url = https://minio.example.com:9000"
    print "  region = us-east-1"
    print "  access_key = AKIA..."
    print "  secret_key = ..."
    print "  tls_skip_verify = false"
