# SReplay — simple qemu CLI
#
# Usage:
#   simple qemu record --arch x86_64 --kernel boot.elf --trace boot.srrq
#   simple qemu replay --arch x86_64 --kernel boot.elf --trace boot.srrq
#   simple qemu checkpoint save <name>
#   simple qemu checkpoint restore <name>
#   simple qemu checkpoint list
#   simple qemu status

use std.io.{shell}
use app.qemu.commands.{cmd_record, cmd_replay, cmd_checkpoint, cmd_status}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_cli_get_args() -> [text]

fn main() -> i64:
    val raw_args = qemu_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("qemu", log_opts.error)
        return 1

    val args = qemu_clean_args(raw_args)
    if args.len() < 1:
        if log_opts.log_mode == "json":
            print "{\"command\":\"qemu\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_usage()
        return 0

    val subcmd = args[0]
    var rest: [text] = []
    var i = 1
    while i < args.len():
        rest.push(args[i])
        i = i + 1

    match subcmd:
        "record":
            cmd_record(rest)
        "replay":
            cmd_replay(rest)
        "checkpoint":
            cmd_checkpoint(rest)
        "status":
            cmd_status(rest)
        "help":
            print_usage()
        _:
            if log_opts.log_mode == "json":
                print "{\"command\":\"qemu\",\"status\":\"error\",\"error\":\"unknown subcommand\"}"
                return 1
            print "[sreplay] Unknown subcommand: {subcmd}"
            print_usage()
            return 1
    0

fn print_usage():
    print "SReplay — QEMU deterministic replay debugger"
    print ""
    print "Usage:"
    print "  simple qemu record   --arch <arch> --kernel <elf> --trace <file>"
    print "  simple qemu replay   --arch <arch> --kernel <elf> --trace <file>"
    print "  simple qemu checkpoint save|restore|list <name>"
    print "  simple qemu status"
    print ""
    print "Architectures: x86_64, i386, riscv32, riscv64, aarch64, arm32"
    print ""
    print "Record captures a deterministic execution trace."
    print "Replay replays it with GDB reverse-debug support."
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn qemu_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn qemu_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if qemu_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn qemu_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_qemu = false
    var i = 0
    while i < all_args.len():
        if found_qemu:
            args.push(all_args[i])
        elif all_args[i] == "qemu":
            found_qemu = true
        i = i + 1
    if found_qemu:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/qemu/main.spl") or all_args[i] == "src/app/qemu/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
