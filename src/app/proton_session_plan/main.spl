use common.proton_runtime_subsystems.{proton_fixture_non_wine_runtime_evidence}
use common.proton_session.{proton_session_launch_handoff, proton_session_plan, proton_session_request_new}

extern fn stdout_write(data: text)

fn main() -> i64:
    val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
    val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
    val handoff = proton_session_launch_handoff(plan, true)
    if handoff.ok:
        stdout_write("app_id={handoff.app_id}\n")
        stdout_write("prefix={handoff.compat_prefix}\n")
        stdout_write("command={handoff.launch_command}\n")
        stdout_write("status={handoff.status}\n")
        stdout_write("container={handoff.container_profile}\n")
        stdout_write("features={handoff.runtime_features}\n")
        return 0
    print "proton-session-plan failed: {handoff.error}"
    1
