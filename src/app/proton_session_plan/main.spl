use common.proton_runtime_subsystems.{proton_fixture_non_wine_runtime_evidence}
use common.proton_session.{proton_session_plan, proton_session_request_new}

extern fn stdout_write(data: text)

fn main() -> i64:
    val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
    val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
    if plan.ok:
        stdout_write("app_id={plan.app_id}\n")
        stdout_write("prefix={plan.compat_prefix}\n")
        stdout_write("command={plan.launch_command}\n")
        stdout_write("status={plan.status}\n")
        stdout_write("features={plan.runtime_features}\n")
        return 0
    print "proton-session-plan failed: {plan.error}"
    1
