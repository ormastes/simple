# Chromium Shell JS Engine Maturity Audit — Pass-Rate Report (M9)
#
# Per §M9 acceptance criterion #2, the pass-rate report is checked into
# the tree so readers of this repo get the honest state of
# `examples/browser/feature/script/engine/` without having to run
# anything.
#
# The numbers below are for the M9 baseline subset exposed by
# `js_audit.spl::js_audit_default_subset()`. Real test262 corpus
# numbers go in a follow-up ticket; see `KnownCrash::TEST262_NOT_WIRED`
# in `js_audit_crash_list.spl`.
#
# **All numbers are "interpreter backend, M9 baseline subset."**
# The JIT backend is covered by `Test262Report::jit_today()` and is
# not run today (see `KnownCrash::JIT_BACKEND_DISABLED`).

class Test262Report:
    """An immutable snapshot of a test262 run against one backend.

    Matches the tally shape of `Test262Runner`: pass / fail / crash /
    skip plus a descriptive `backend` tag and a short `subset` id so
    two reports in the same file don't conflict."""

    backend: text
    subset: text
    pass_count: i64
    fail_count: i64
    crash_count: i64
    skip_count: i64

    static fn new(
        backend: text,
        subset: text,
        pass_count: i64,
        fail_count: i64,
        crash_count: i64,
        skip_count: i64
    ) -> Test262Report:
        Test262Report(
            backend: backend,
            subset: subset,
            pass_count: pass_count,
            fail_count: fail_count,
            crash_count: crash_count,
            skip_count: skip_count
        )

    me total() -> i64:
        self.pass_count + self.fail_count + self.crash_count + self.skip_count

    me pass_rate_pct() -> i64:
        """Integer percentage 0..100."""
        val total = self.total()
        if total <= 0:
            return 0
        return (self.pass_count * 100) / total

    # ── Canonical checked-in snapshots ──────────────────────────────
    #
    # These factory constructors freeze the numbers the audit reports.
    # When the M9 follow-up wires the real test262 corpus, bump them.

    static fn canonical() -> Test262Report:
        """Interpreter backend, M9 baseline subset (5 cases).

        All 5 synthetic cases in `js_audit_default_subset` pass under
        the tree-walking interpreter as of 2026-04-14. This is the
        "honest current state" the plan doc asks for."""
        Test262Report.new("interpreter", "m9-baseline", 5, 0, 0, 0)

    static fn jit_today() -> Test262Report:
        """JIT backend, M9 baseline subset.

        Not run today. The JIT backend is listed in
        `js_audit_crash_list.spl` as `JIT_BACKEND_DISABLED`. The
        report records 0/0/0/5 skipped so downstream dashboards see a
        non-empty row rather than "missing data"."""
        Test262Report.new("jit", "m9-baseline", 0, 0, 0, 5)

    static fn full_corpus_today() -> Test262Report:
        """Real test262 corpus — not wired yet.

        All counts are 0. This is the "we haven't run it" sentinel
        that answers the plan doc's §M9 criterion #2 honestly without
        implying a fake score."""
        Test262Report.new("interpreter", "test262-full", 0, 0, 0, 0)
