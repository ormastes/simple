# Chromium Shell JS Engine Maturity Audit — Crash List (M9)
#
# Per §M9 acceptance criterion #3, this module enumerates "things V3
# apps will hit and crash on." V3 itself does not run JS, so this
# list is forward-looking — it answers "what would break first if a
# V3-class app started running JS against the current
# `examples/browser/feature/script/engine/`."
#
# Each entry is a `KnownCrash` record. The list is deliberately short
# (one line per category) so readers of this file get the whole
# picture in ~30 lines. Expanding the list is part of the M9
# follow-up ticket.

class KnownCrash:
    """A single known-bad category in the current JS engine.

    `id` is a stable, SHOUTY_SNAKE tag so other files can reference
    a specific entry (e.g. `js_audit_report.spl` cites
    `JIT_BACKEND_DISABLED`). `summary` is a one-line explanation.
    `severity` is `"crash"`, `"wrong-result"`, or `"unsupported"`.
    `workaround` is a short hint or the literal text `"none"`."""

    id: text
    summary: text
    severity: text
    workaround: text

    static fn new(
        id: text,
        summary: text,
        severity: text,
        workaround: text
    ) -> KnownCrash:
        KnownCrash(
            id: id,
            summary: summary,
            severity: severity,
            workaround: workaround
        )

fn js_audit_known_crashes() -> [KnownCrash]:
    """The canonical M9 crash list. Ordered by how early a V3-class
    app would hit the issue: parser gaps first, then runtime holes,
    then tooling / harness gaps."""
    val crashes = [KnownCrash]()

    crashes.push(KnownCrash.new(
        "PARSER_ES2015_CLASSES",
        "`class` declarations not parsed end-to-end",
        "unsupported",
        "write prototype-style constructors"
    ))

    crashes.push(KnownCrash.new(
        "PARSER_TEMPLATE_LITERALS",
        "backtick template literals tokenize but do not interpolate",
        "wrong-result",
        "use string concatenation"
    ))

    crashes.push(KnownCrash.new(
        "RUNTIME_REGEXP",
        "no RegExp support; `/foo/` throws at eval time",
        "crash",
        "none"
    ))

    crashes.push(KnownCrash.new(
        "RUNTIME_PROMISE",
        "no Promise / microtask queue; `await` is a syntax error",
        "unsupported",
        "use callbacks"
    ))

    crashes.push(KnownCrash.new(
        "RUNTIME_TYPED_ARRAYS",
        "Int8Array / Uint8Array and friends are missing",
        "unsupported",
        "use plain arrays of numbers"
    ))

    crashes.push(KnownCrash.new(
        "RUNTIME_JSON",
        "JSON.parse / JSON.stringify not exposed as globals",
        "crash",
        "parse manually"
    ))

    crashes.push(KnownCrash.new(
        "RUNTIME_DATE",
        "Date global is a stub; arithmetic on Date instances NaNs out",
        "wrong-result",
        "store epoch millis as i64"
    ))

    crashes.push(KnownCrash.new(
        "JIT_BACKEND_DISABLED",
        "JIT backend compiles but is not wired into the dispatch path",
        "unsupported",
        "run the interpreter"
    ))

    crashes.push(KnownCrash.new(
        "TEST262_NOT_WIRED",
        "real test262 corpus loader (rt_test262_load_corpus) is a stub",
        "unsupported",
        "run M9 baseline subset via js_audit.spl"
    ))

    return crashes

fn js_audit_crash_count() -> i64:
    """Convenience for the unit spec. Mirrors `len` without pulling
    std into this tiny module."""
    js_audit_known_crashes().len()
