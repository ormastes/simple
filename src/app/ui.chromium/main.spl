# Chromium UI CLI entrypoint.
# Startup-light command planner for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple UI Chromium"
val TOOL_VERSION = "0.1.0"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("ui.chromium", log_opts.error)
        return 1

    val args = chromium_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"ui.chromium\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val unknown = chromium_first_unknown_option(args)
    if unknown != "":
        val message = "Unknown ui.chromium option: {unknown}"
        chromium_print_error(log_opts.log_mode, message)
        return 1

    val backend = chromium_option_value(args, "--backend", "chromium")
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"ui.chromium\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\",\"backend\":\"{backend}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "ui.chromium")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for Chromium UI command planning."
        return 0

    if log_opts.log_mode == "json":
        print "{\"command\":\"ui.chromium\",\"status\":\"planned\",\"backend\":\"{backend}\"}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "ui.chromium-plan")
        if progress != "":
            print progress
        print "Chromium UI backend: {backend}"
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple ui.chromium [options]"
    print ""
    print "Options:"
    print "  -h, --help          Show this help message"
    print "  -v, --version       Show version information"
    print "  --backend <NAME>    Backend selector (default: chromium)"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn chromium_print_error(log_mode: text, message: text):
    if log_mode == "json":
        print "{\"command\":\"ui.chromium\",\"status\":\"error\",\"message\":\"{message}\"}"
    else:
        error("ui.chromium", message)

fn chromium_option_value(args: [text], name: text, fallback: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with(name + "="):
            return arg.substring(name.len() + 1)
        i = i + 1
    fallback

fn chromium_first_unknown_option(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--backend":
            i = i + 2
        elif arg.starts_with("--backend="):
            i = i + 1
        elif arg.starts_with("-"):
            return arg
        else:
            return arg
    ""

fn chromium_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn chromium_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if chromium_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
