# Chromium Shell Entry Point (V3 simple_browser shell — M1)
#
# `bin/simple run examples/simple_os/desktop_shell --backend chromium` ends
# up here. The module exposes:
#
#   - `chromium_main()`         — the ChromiumApp entry to call from
#                                  `examples/simple_os/desktop_shell.spl`.
#   - `parse_chromium_backend()` — picks up the `--backend` flag.
#
# M1 explicitly defers all interactivity, multi-window, input bridging,
# and DesktopShell integration to later milestones (M2+).

use app.ui.chromium.app.{ChromiumApp}

extern fn rt_cli_get_args() -> [text]

fn parse_chromium_backend(args: [text]) -> text:
    """Return the value of `--backend` / `--backend=NAME`, or "" if absent."""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--backend" and i + 1 < args.len():
            return args[i + 1]
        elif arg.starts_with("--backend="):
            return arg[10:]
        i = i + 1
    return ""

fn chromium_main() -> i64:
    """V3 chromium shell entry point.

    Returns 0 on clean shutdown, 1 if the host window or event loop
    failed to come up.
    """
    val app_result = ChromiumApp.new()
    match app_result:
        Err(e):
            print "[chromium] Error: {e}"
            return 1
        Ok(app):
            print "[chromium] V3 simple_browser shell ready (M1 skeleton)"
            app.run()
            print "[chromium] shutdown clean"
            return 0

fn main() -> i64:
    val args = rt_cli_get_args()
    val backend = parse_chromium_backend(args)
    if backend != "" and backend != "chromium":
        print "[chromium] note: --backend={backend} ignored; M1 only supports 'chromium'"
    return chromium_main()
