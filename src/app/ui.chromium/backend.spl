# Chromium Compositor Backend Adapter (V3 simple_browser shell — M1)
#
# Wraps `BrowserCompositorBackend` from `os.compositor.browser_compositor_backend`
# so the compositor can render through the in-tree browser engine pipeline,
# and exposes a thin helper for blitting the produced [u32] pixel buffer
# into a winit window via the typed `winit_present_rgba` owner.
#
# Pixel path (M1 acceptance criterion):
#   compositor.render_all() -> BrowserCompositorBackend.[u32] pixel_buffer
#                           -> pack to [i64]
#                           -> winit_present_rgba(window, w, h, [i64])
#
# No new Rust SFFI is introduced. Presentation routes through the canonical
# typed owner so runtime failure remains observable.

use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use std.nogc_sync_mut.io.window_winit.{WinitWindow, winit_present_rgba}

# ============================================================================
# ChromiumBackend
# ============================================================================

class ChromiumBackend:
    """V3 chromium shell backend adapter.

    Owns a `BrowserCompositorBackend` and the winit window handle, and
    knows how to push the pixel buffer to the host window.
    """
    inner: BrowserCompositorBackend
    window_id: i64
    w: i32
    h: i32

impl ChromiumBackend:

    static fn new(window_id: i64, width: i32, height: i32) -> ChromiumBackend:
        """Create a new chromium backend bound to an existing winit window.

        The pixel buffer starts black (0xFF000000). The compositor will
        clear it on the first `render_all()` call.
        """
        val inner = BrowserCompositorBackend.new(width, height)
        ChromiumBackend(
            inner: inner,
            window_id: window_id,
            w: width,
            h: height
        )

    fn display_backend() -> BrowserCompositorBackend:
        """Return the underlying `BrowserCompositorBackend` for use as the
        compositor's `CompositorBackend` trait object."""
        self.inner

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me present_to_window() -> bool:
        """Pack the inner [u32] pixel buffer into [i64] and present it
        to the winit window through the typed presentation owner.

        This is the only place in the chromium shell that touches the
        host pixel surface — keeping the SFFI footprint to a single call.
        """
        val src = self.inner.get_pixel_buffer()
        val total = self.w * self.h
        var packed: [i64] = []
        var i: i32 = 0
        while i < total:
            packed = packed + [src[i].to_i64()]
            i = i + 1
        val win = WinitWindow(handle: self.window_id, is_valid: self.window_id > 0)
        winit_present_rgba(
            win,
            self.w.to_i64(),
            self.h.to_i64(),
            packed
        )
