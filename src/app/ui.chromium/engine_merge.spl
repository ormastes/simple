# Chromium Shell Engine Merge (V3 simple_browser shell — M4)
#
# Collapses the V3 chromium shell onto a single browser engine import
# graph so V3 has exactly one DOM type, one StyleProps, one
# BeLayoutBox, and one paint pipeline.
#
# Per ADR-002 (doc/04_architecture/adr/ADR-002-canonical-browser-engine.md)
# the canonical engine is `src/lib/gc_async_mut/gpu/browser_engine/`.
#
# This module is the **only** place the chromium shell reaches into the
# canonical engine directly. `app.spl` holds a `ChromiumEngine` and calls
# its `render_dom_to_scene` / `render_html_to_scene` methods; `backend.spl`
# continues to own the pixel push via `ChromiumBackend.present_to_window`.
#
# Pipeline:
#
#     HTML text ──(html_string_to_dom)──▶ BeDomNode
#                                             │
#                                             ▼
#                                   layout_to_scene(root, w, h)
#                                             │
#                                             ▼
#                                        RenderScene
#
# `layout_to_scene` inlines `layout_tree` + paint generation in a
# single module to avoid the Cranelift cross-module FieldGet bug —
# see `src/lib/gc_async_mut/gpu/browser_engine/layout.spl:712`.
#
# M4 owns this file. Do not cross into `examples/browser/feature/...`.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_set_style,
    be_dom_add_child, be_dom_get_children}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_tree,
    layout_to_scene, layout_get_width, layout_get_height}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{html_string_to_dom}
use common.render_scene.scene.{RenderScene}

# ============================================================================
# ChromiumEngine
# ============================================================================

class ChromiumEngine:
    """V3 chromium shell's merged browser engine entry point.

    Wraps the canonical `std.gc_async_mut.gpu.browser_engine` pipeline
    behind a single class so the chromium shell never reaches directly
    into DOM/layout/paint modules scattered across the engine — and so
    a future swap (e.g. M7 WebGPU `engine2d` path) only touches this
    file.

    Fields:
        viewport_w - viewport width in pixels
        viewport_h - viewport height in pixels
    """
    viewport_w: i32
    viewport_h: i32

impl ChromiumEngine:

    static fn new(w: i32, h: i32) -> ChromiumEngine:
        """Create a chromium engine for the given viewport size."""
        ChromiumEngine(viewport_w: w, viewport_h: h)

    fn width() -> i32:
        self.viewport_w

    fn height() -> i32:
        self.viewport_h

    fn layout_dom(root: BeDomNode) -> BeLayoutBox:
        """Run the canonical layout pass on a DOM tree and return the
        root layout box. Used by the smoke spec to assert that the merge
        actually routes through `layout_tree`, not a stub.
        """
        layout_tree(root, self.viewport_w, self.viewport_h)

    fn render_dom_to_scene(root: BeDomNode) -> RenderScene:
        """Run DOM → layout → paint → scene in one call against the
        canonical engine. This is the pixel path the chromium shell
        uses for every frame that isn't a pure compositor blit.
        """
        layout_to_scene(root, self.viewport_w, self.viewport_h)

    fn render_html_to_scene(html: text) -> RenderScene:
        """Convenience: parse an HTML string via the canonical
        `html_string_to_dom` and render it to a RenderScene. The M5
        `wm_compare` gate uses this shape when diffing golden frames.
        """
        val root = html_string_to_dom(html)
        layout_to_scene(root, self.viewport_w, self.viewport_h)

# ============================================================================
# Minimal DOM builders (used by the engine_merge smoke spec)
# ============================================================================
# These live next to `ChromiumEngine` rather than in `dom.spl` because
# they encode the shell-specific convention (viewport-sized root with a
# single child) rather than a general DOM construction helper.

fn engine_merge_root(bg_color: text) -> BeDomNode:
    """Build a viewport-rooted `<div>` with a background color applied
    through the canonical `be_dom_set_style` codepath. Used by the
    merge smoke spec to prove that set_style → layout → scene is
    end-to-end reachable from the chromium shell's own module.
    """
    var root = BeDomNode.element("div")
    be_dom_set_style(root, "display", "block")
    be_dom_set_style(root, "background-color", bg_color)
    root

fn engine_merge_panel(w_px: text, h_px: text, bg_color: text) -> BeDomNode:
    """Build a sized `<div>` panel. Mirrors the DesktopShell taskbar
    surface the M1 shell already renders, but expressed entirely in
    canonical DOM primitives so the merge spec can assert the pipeline
    survives a real CSS subset."""
    var panel = BeDomNode.element("div")
    be_dom_set_style(panel, "display", "block")
    be_dom_set_style(panel, "width", w_px)
    be_dom_set_style(panel, "height", h_px)
    be_dom_set_style(panel, "background-color", bg_color)
    panel
