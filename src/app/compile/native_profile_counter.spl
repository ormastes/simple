# Native profile counter contract helpers.

struct NativeProfileCounterSlot:
    slot_index: i64
    counter_kind: text
    stable_key: text
    initial_value: i64

struct NativeProfileSectionSummary:
    section_name: text
    enabled: bool
    slot_count: i64
    valid_slot_count: i64
    invalid_slot_count: i64
    cold_path_policy: text

struct NativeProfileCounterEmissionRecord:
    slot_index: i64
    counter_kind: text
    stable_key: text
    initial_value: i64
    section_label: text
    counter_symbol: text
    serialization_line: text

struct NativeProfileCounterIncrementOperation:
    slot_index: i64
    counter_kind: text
    stable_key: text
    emitted: bool
    operation: text
    reason: text

struct NativeProfileCounterCPrelude:
    counter_symbol: text
    metadata_symbol: text
    slot_count: i64
    c_source: text

struct NativeProfileCounterIncrementRecord:
    slot_index: i64
    counter_kind: text
    stable_key: text
    function_label: text
    block_label: text
    edge_label: text
    call_path_label: text
    placement_label: text
    c_statement: text

struct NativeProfileCounterInstrumentedC:
    enabled: bool
    slot_count: i64
    c_source: text
    metadata_lines: [text]

struct NativeProfileCounterSprofRecord:
    slot_index: i64
    counter_kind: text
    stable_key: text
    record_kind: text
    key: text
    secondary_key: text
    count: i64
    line: text

struct NativeProfileCounterSprofExtraction:
    record_count: i64
    line_count: i64
    diagnostic_count: i64
    records: [NativeProfileCounterSprofRecord]
    lines: [text]
    diagnostics: [text]

struct NativeProfileCounterRuntimeSnapshot:
    status: text
    counter_count: i64
    counters: [i64]
    diagnostic_count: i64
    diagnostics: [text]

struct NativeProfileCounterSprofImportPlan:
    status: text
    output_path: text
    metadata_count: i64
    counter_count: i64
    record_count: i64
    line_count: i64
    diagnostic_count: i64
    write_allowed: bool
    lines: [text]
    diagnostics: [text]

struct NativeProfileCounterBuildAudit:
    profile_build: bool
    counter_symbols_found: bool
    counter_increments_found: bool
    metadata_found: bool
    allowed: bool
    reason: text

fn native_profile_counter_kinds() -> [text]:
    ["function_entry", "basic_block", "edge", "call_path"]

fn native_profile_counter_default_section_name() -> text:
    ".simple.profile.counters"

fn native_profile_counter_metadata_path(output_file: text) -> text:
    output_file + ".simple-profile-counters"

fn native_profile_counter_kind_valid(counter_kind: text) -> bool:
    native_profile_counter_kinds().contains(counter_kind)

fn native_profile_counters_enabled(profile_build: bool) -> bool:
    profile_build

fn native_profile_counter_enabled(profile_build: bool, counter_kind: text) -> bool:
    native_profile_counters_enabled(profile_build) and native_profile_counter_kind_valid(counter_kind)

fn native_profile_counter_identity_matches(interpreter_key: text, native_key: text) -> bool:
    interpreter_key != "" and interpreter_key == native_key

fn native_profile_counter_slot(slot_index: i64, counter_kind: text, stable_key: text, initial_value: i64) -> NativeProfileCounterSlot:
    NativeProfileCounterSlot(
        slot_index: slot_index,
        counter_kind: counter_kind,
        stable_key: stable_key,
        initial_value: initial_value
    )

fn native_profile_counter_slot_valid(slot: NativeProfileCounterSlot) -> bool:
    slot.slot_index >= 0 and
        native_profile_counter_kind_valid(slot.counter_kind) and
        slot.stable_key != "" and
        slot.initial_value >= 0

fn native_profile_counter_slots_valid(slots: [NativeProfileCounterSlot]) -> bool:
    for slot in slots:
        if not native_profile_counter_slot_valid(slot):
            return false
    true

fn native_profile_counter_section_label(section_name: text) -> text:
    val base = if section_name == "": native_profile_counter_default_section_name() else: section_name
    var normalized = base.replace(".", "_")
    normalized = normalized.replace("-", "_")
    normalized = normalized.replace("/", "_")
    normalized = normalized.replace(" ", "_")
    "simple_profile_counter_section_{normalized}"

fn _native_profile_counter_escape(value: text) -> text:
    var escaped = value.replace("\\", "\\\\")
    escaped = escaped.replace("\n", "\\n")
    escaped = escaped.replace("|", "\\p")
    escaped

fn native_profile_counter_symbol(slot: NativeProfileCounterSlot) -> text:
    "__simple_profile_counter_{slot.slot_index}_{slot.counter_kind}"

fn native_profile_counter_serialization_line(section_name: text, slot: NativeProfileCounterSlot) -> text:
    val label = native_profile_counter_section_label(section_name)
    val key = _native_profile_counter_escape(slot.stable_key)
    val symbol = native_profile_counter_symbol(slot)
    "counter|section={label}|slot={slot.slot_index}|kind={slot.counter_kind}|key={key}|initial={slot.initial_value}|symbol={symbol}"

fn native_profile_counter_emission_record(section_name: text, slot: NativeProfileCounterSlot) -> NativeProfileCounterEmissionRecord:
    NativeProfileCounterEmissionRecord(
        slot_index: slot.slot_index,
        counter_kind: slot.counter_kind,
        stable_key: slot.stable_key,
        initial_value: slot.initial_value,
        section_label: native_profile_counter_section_label(section_name),
        counter_symbol: native_profile_counter_symbol(slot),
        serialization_line: native_profile_counter_serialization_line(section_name, slot)
    )

fn _native_profile_counter_slot_precedes(left: NativeProfileCounterSlot, right: NativeProfileCounterSlot) -> bool:
    if left.slot_index != right.slot_index:
        return left.slot_index < right.slot_index
    if left.counter_kind != right.counter_kind:
        return left.counter_kind < right.counter_kind
    left.stable_key < right.stable_key

fn native_profile_counter_sorted_valid_slots(slots: [NativeProfileCounterSlot]) -> [NativeProfileCounterSlot]:
    var sorted: [NativeProfileCounterSlot] = []
    for slot in slots:
        if native_profile_counter_slot_valid(slot):
            sorted.push(slot)

    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and _native_profile_counter_slot_precedes(sorted[j], sorted[j - 1]):
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    sorted

fn native_profile_counter_emission_records(section_name: text, slots: [NativeProfileCounterSlot]) -> [NativeProfileCounterEmissionRecord]:
    val sorted = native_profile_counter_sorted_valid_slots(slots)
    var records: [NativeProfileCounterEmissionRecord] = []
    for slot in sorted:
        records.push(native_profile_counter_emission_record(section_name, slot))
    records

fn native_profile_counter_section_serialization_lines(section_name: text, slots: [NativeProfileCounterSlot]) -> [text]:
    val records = native_profile_counter_emission_records(section_name, slots)
    var lines: [text] = []
    lines.push("section|label={native_profile_counter_section_label(section_name)}|name={_native_profile_counter_escape(if section_name == \"\": native_profile_counter_default_section_name() else: section_name)}|records={records.len()}")
    for record in records:
        lines.push(record.serialization_line)
    lines

fn native_profile_disabled_counter_cold_path_policy() -> text:
    "compile_out_counter_increment"

fn native_profile_counter_cold_path_policy(profile_build: bool, counter_kind: text) -> text:
    if native_profile_counter_enabled(profile_build, counter_kind):
        "emit_counter_increment"
    else:
        native_profile_disabled_counter_cold_path_policy()

fn native_profile_counter_increment_operation(profile_build: bool, slot: NativeProfileCounterSlot) -> NativeProfileCounterIncrementOperation:
    val valid = native_profile_counter_slot_valid(slot)
    val emitted = profile_build and valid
    NativeProfileCounterIncrementOperation(
        slot_index: slot.slot_index,
        counter_kind: slot.counter_kind,
        stable_key: slot.stable_key,
        emitted: emitted,
        operation: if emitted: "emit_counter_increment" else: native_profile_disabled_counter_cold_path_policy(),
        reason: if emitted: "profile_build_enabled" else: if profile_build: "invalid_counter_slot" else: "profile_build_disabled"
    )

fn native_profile_counter_increment_operations(profile_build: bool, slots: [NativeProfileCounterSlot]) -> [NativeProfileCounterIncrementOperation]:
    var operations: [NativeProfileCounterIncrementOperation] = []
    for slot in slots:
        operations.push(native_profile_counter_increment_operation(profile_build, slot))
    operations

fn native_profile_counter_c_declaration(section_name: text, slot: NativeProfileCounterSlot) -> text:
    if not native_profile_counter_slot_valid(slot):
        return ""
    val section = if section_name == "": native_profile_counter_default_section_name() else: section_name
    val symbol = native_profile_counter_symbol(slot)
    "static unsigned long long {symbol} __attribute__((section(\"{section}\"), used)) = {slot.initial_value};"

fn native_profile_counter_c_declarations(section_name: text, slots: [NativeProfileCounterSlot]) -> [text]:
    val sorted = native_profile_counter_sorted_valid_slots(slots)
    var declarations: [text] = []
    for slot in sorted:
        declarations.push(native_profile_counter_c_declaration(section_name, slot))
    declarations

fn native_profile_counter_increment_statement(profile_build: bool, slot: NativeProfileCounterSlot) -> text:
    val operation = native_profile_counter_increment_operation(profile_build, slot)
    if not operation.emitted:
        return ""
    "{native_profile_counter_symbol(slot)} += 1;"

fn native_profile_section_summary(section_name: text, profile_build: bool, slots: [NativeProfileCounterSlot]) -> NativeProfileSectionSummary:
    var valid_count = 0
    for slot in slots:
        if native_profile_counter_slot_valid(slot):
            valid_count = valid_count + 1

    NativeProfileSectionSummary(
        section_name: section_name,
        enabled: native_profile_counters_enabled(profile_build),
        slot_count: slots.len(),
        valid_slot_count: valid_count,
        invalid_slot_count: slots.len() - valid_count,
        cold_path_policy: if native_profile_counters_enabled(profile_build): "emit_counter_increment" else: native_profile_disabled_counter_cold_path_policy()
    )

fn native_profile_call_path_counter_max_depth() -> i64:
    64

fn native_profile_call_path_counter_allowed(profile_build: bool, call_depth: i64) -> bool:
    native_profile_counter_enabled(profile_build, "call_path") and
        call_depth >= 0 and
        call_depth <= native_profile_call_path_counter_max_depth()

fn native_profile_counter_array_symbol() -> text:
    "__simple_profile_counters"

fn native_profile_counter_metadata_symbol() -> text:
    "__simple_profile_counter_metadata"

fn native_profile_counter_c_comment_value(value: text) -> text:
    var escaped = value.replace("*/", "* /")
    escaped = escaped.replace("\n", " ")
    escaped = escaped.replace("\r", " ")
    escaped

fn native_profile_counter_c_initializer(slots: [NativeProfileCounterSlot]) -> text:
    var values = []
    for slot in slots:
        values.push(slot.initial_value.to_string())
    values.join(", ")

fn native_profile_counter_metadata_line(slot: NativeProfileCounterSlot) -> text:
    "/* simple-profile-counter slot=" + slot.slot_index.to_string() +
        " kind=" + native_profile_counter_c_comment_value(slot.counter_kind) +
        " key=" + native_profile_counter_c_comment_value(slot.stable_key) +
        " initial=" + slot.initial_value.to_string() + " */"

fn native_profile_counter_c_prelude(slots: [NativeProfileCounterSlot]) -> NativeProfileCounterCPrelude:
    val counter_symbol = native_profile_counter_array_symbol()
    val metadata_symbol = native_profile_counter_metadata_symbol()
    val initializer = native_profile_counter_c_initializer(slots)
    var lines = [
        "/* simple-profile-counter-prelude-v1 */",
        "#include <stdint.h>",
        "#include <stddef.h>",
        "#include <stdio.h>",
        "#include <stdlib.h>",
        "static uint64_t " + counter_symbol + "[" + slots.len().to_string() + "] = {" + initializer + "};",
        "static const size_t " + counter_symbol + "_count = " + slots.len().to_string() + "u;",
        "static const char * const " + metadata_symbol + "[" + slots.len().to_string() + "] = {" + "0" + "};",
        "static void __simple_profile_write_counter_snapshot(void) {",
        "    const char *path = getenv(\"SIMPLE_PROFILE_COUNTER_SNAPSHOT\");",
        "    if (path == 0 || path[0] == 0) return;",
        "    FILE *f = fopen(path, \"w\");",
        "    if (f == 0) return;",
        "    fprintf(f, \"simple-profile-counter-snapshot-v1\\n\");",
        "    for (size_t i = 0; i < " + counter_symbol + "_count; ++i) {",
        "        fprintf(f, \"count|slot=%zu|value=%llu\\n\", i, (unsigned long long)" + counter_symbol + "[i]);",
        "    }",
        "    fclose(f);",
        "}",
        "static void __simple_profile_register_counter_snapshot(void) __attribute__((constructor));",
        "static void __simple_profile_register_counter_snapshot(void) {",
        "    atexit(__simple_profile_write_counter_snapshot);",
        "}"
    ]
    for slot in slots:
        lines.push(native_profile_counter_metadata_line(slot))

    NativeProfileCounterCPrelude(
        counter_symbol: counter_symbol,
        metadata_symbol: metadata_symbol,
        slot_count: slots.len(),
        c_source: lines.join("\n") + "\n"
    )

fn native_profile_counter_increment_placement_label(function_label: text, block_label: text, edge_label: text, call_path_label: text) -> text:
    "function=" + function_label +
        "|block=" + block_label +
        "|edge=" + edge_label +
        "|call_path=" + call_path_label

fn native_profile_counter_increment_record(
    slot: NativeProfileCounterSlot,
    function_label: text,
    block_label: text,
    edge_label: text,
    call_path_label: text
) -> NativeProfileCounterIncrementRecord:
    val placement_label = native_profile_counter_increment_placement_label(function_label, block_label, edge_label, call_path_label)
    NativeProfileCounterIncrementRecord(
        slot_index: slot.slot_index,
        counter_kind: slot.counter_kind,
        stable_key: slot.stable_key,
        function_label: function_label,
        block_label: block_label,
        edge_label: edge_label,
        call_path_label: call_path_label,
        placement_label: placement_label,
        c_statement: native_profile_counter_array_symbol() + "[" + slot.slot_index.to_string() + "] += 1u;"
    )

fn native_profile_counter_increment_records(
    slots: [NativeProfileCounterSlot],
    function_label: text,
    block_label: text,
    edge_label: text,
    call_path_label: text
) -> [NativeProfileCounterIncrementRecord]:
    var records = []
    for slot in slots:
        records.push(native_profile_counter_increment_record(slot, function_label, block_label, edge_label, call_path_label))
    records

fn _native_profile_c_line_is_function_entry(line: text) -> bool:
    val trimmed = line.trim()
    if not trimmed.contains("(") or not trimmed.contains(")") or not trimmed.contains("{"):
        return false
    if trimmed.starts_with("if ") or trimmed.starts_with("if("):
        return false
    if trimmed.starts_with("for ") or trimmed.starts_with("for("):
        return false
    if trimmed.starts_with("while ") or trimmed.starts_with("while("):
        return false
    if trimmed.starts_with("switch ") or trimmed.starts_with("switch("):
        return false
    if trimmed.starts_with("typedef "):
        return false
    if trimmed.ends_with(";"):
        return false
    trimmed.starts_with("int ") or trimmed.starts_with("void ") or trimmed.starts_with("static ") or trimmed.starts_with("RtVal ")

fn _native_profile_c_function_name(line: text) -> text:
    val before_paren_end = line.index_of("(") ?? -1
    if before_paren_end < 0:
        return ""
    val before_paren = line[0:before_paren_end].trim()
    val parts = before_paren.split(" ")
    if parts.len() == 0:
        return ""
    var name = parts[parts.len() - 1].trim()
    name = name.replace("*", "")
    name

fn native_profile_counter_function_entry_slots_from_c_source(c_source: text) -> [NativeProfileCounterSlot]:
    var slots: [NativeProfileCounterSlot] = []
    val lines = c_source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if _native_profile_c_line_is_function_entry(line):
            val function_name = _native_profile_c_function_name(line)
            if function_name != "":
                slots.push(native_profile_counter_slot(slots.len(), "function_entry", "c:{function_name}:entry", 0))
        i = i + 1
    slots

fn native_profile_counter_instrument_c_source(c_source: text, enabled: bool) -> NativeProfileCounterInstrumentedC:
    if not enabled:
        return NativeProfileCounterInstrumentedC(
            enabled: false,
            slot_count: 0,
            c_source: c_source,
            metadata_lines: []
        )

    val slots = native_profile_counter_function_entry_slots_from_c_source(c_source)
    val prelude = native_profile_counter_c_prelude(slots)
    val metadata_lines = native_profile_counter_section_serialization_lines(native_profile_counter_default_section_name(), slots)
    var instrumented_lines: [text] = []
    val lines = c_source.split("\n")
    var slot_index = 0
    var i = 0
    while i < lines.len():
        val line = lines[i]
        instrumented_lines.push(line)
        if _native_profile_c_line_is_function_entry(line) and slot_index < slots.len():
            instrumented_lines.push("    " + native_profile_counter_array_symbol() + "[" + slot_index.to_string() + "] += 1u;")
            slot_index = slot_index + 1
        i = i + 1

    NativeProfileCounterInstrumentedC(
        enabled: true,
        slot_count: slots.len(),
        c_source: prelude.c_source + instrumented_lines.join("\n"),
        metadata_lines: metadata_lines
    )

fn native_profile_counter_build_audit(c_source: text, profile_build: bool) -> NativeProfileCounterBuildAudit:
    val counter_symbols = c_source.contains("__simple_profile_counters")
    val increments = c_source.contains("__simple_profile_counters[") and c_source.contains("+= 1u")
    val metadata = c_source.contains("simple-profile-counter-prelude-v1") or c_source.contains("__simple_profile_counter_metadata")
    if not profile_build and (counter_symbols or increments or metadata):
        return NativeProfileCounterBuildAudit(
            profile_build: profile_build,
            counter_symbols_found: counter_symbols,
            counter_increments_found: increments,
            metadata_found: metadata,
            allowed: false,
            reason: "counter_artifacts_in_non_profile_build"
        )
    NativeProfileCounterBuildAudit(
        profile_build: profile_build,
        counter_symbols_found: counter_symbols,
        counter_increments_found: increments,
        metadata_found: metadata,
        allowed: true,
        reason: if profile_build: "profile_build_may_contain_counters" else: "non_profile_build_clean"
    )

fn _native_profile_counter_pipe_value(line: text, key: text) -> text:
    val prefix = key + "="
    val parts = line.split("|")
    var i = 0
    while i < parts.len():
        val part = parts[i].trim()
        if part.starts_with(prefix):
            return part[prefix.len():]
        i = i + 1
    ""

fn _native_profile_counter_parse_i64(value: text) -> i64:
    value.trim().to_i64() ?? -1

fn _native_profile_counter_unescape(value: text) -> text:
    var unescaped = value.replace("\\p", "|")
    unescaped = unescaped.replace("\\n", "_")
    unescaped.replace("\\\\", "\\")

fn _native_profile_counter_sprof_token_valid(value: text) -> bool:
    value != "" and not value.contains(";") and not value.contains("\n")

fn _native_profile_counter_function_from_stable_key(stable_key: text) -> text:
    val parts = stable_key.split(":")
    if parts.len() >= 2 and parts[1] != "":
        return parts[1]
    "unknown"

fn _native_profile_counter_edge_source(stable_key: text) -> text:
    val parts = stable_key.split("->")
    if parts.len() >= 2:
        return parts[0]
    stable_key

fn _native_profile_counter_edge_target(stable_key: text) -> text:
    val parts = stable_key.split("->")
    if parts.len() >= 2:
        return parts[1]
    stable_key + ":target"

fn native_profile_counter_sprof_record_line(record_kind: text, key: text, secondary_key: text, count: i64) -> text:
    if record_kind == "function":
        return "function;key=" + key + ";count=" + count.to_string()
    if record_kind == "block":
        return "block;function=" + secondary_key + ";key=" + key + ";count=" + count.to_string()
    if record_kind == "edge":
        return "edge;from=" + key + ";to=" + secondary_key + ";count=" + count.to_string()
    "invalid;kind=" + record_kind + ";count=" + count.to_string()

fn native_profile_counter_sprof_record_valid(record: NativeProfileCounterSprofRecord) -> bool:
    if record.count < 0:
        return false
    if record.record_kind == "function":
        return _native_profile_counter_sprof_token_valid(record.key) and record.secondary_key == ""
    if record.record_kind == "block":
        return _native_profile_counter_sprof_token_valid(record.key) and _native_profile_counter_sprof_token_valid(record.secondary_key)
    if record.record_kind == "edge":
        return _native_profile_counter_sprof_token_valid(record.key) and _native_profile_counter_sprof_token_valid(record.secondary_key)
    false

fn native_profile_counter_sprof_record_from_metadata_line(line: text, final_count: i64) -> NativeProfileCounterSprofRecord:
    val slot_index = _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "slot"))
    val counter_kind = _native_profile_counter_pipe_value(line, "kind")
    val stable_key = _native_profile_counter_unescape(_native_profile_counter_pipe_value(line, "key"))
    var record_kind = "invalid"
    var key = stable_key
    var secondary_key = ""
    if counter_kind == "function_entry":
        record_kind = "function"
    elif counter_kind == "basic_block":
        record_kind = "block"
        secondary_key = _native_profile_counter_function_from_stable_key(stable_key)
    elif counter_kind == "edge":
        record_kind = "edge"
        key = _native_profile_counter_edge_source(stable_key)
        secondary_key = _native_profile_counter_edge_target(stable_key)
    elif counter_kind == "call_path":
        record_kind = "edge"
        secondary_key = "call_path"

    val serialized = native_profile_counter_sprof_record_line(record_kind, key, secondary_key, final_count)
    NativeProfileCounterSprofRecord(
        slot_index: slot_index,
        counter_kind: counter_kind,
        stable_key: stable_key,
        record_kind: record_kind,
        key: key,
        secondary_key: secondary_key,
        count: final_count,
        line: serialized
    )

fn _native_profile_counter_metadata_has_slot(metadata_lines: [text], slot_index: i64) -> bool:
    var i = 0
    while i < metadata_lines.len():
        val line = metadata_lines[i].trim()
        if line.starts_with("counter|"):
            val metadata_slot = _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "slot"))
            if metadata_slot == slot_index:
                return true
        i = i + 1
    false

fn native_profile_counter_extract_sprof_records(metadata_lines: [text], final_counter_values: [i64]) -> NativeProfileCounterSprofExtraction:
    var records: [NativeProfileCounterSprofRecord] = []
    var lines: [text] = []
    var diagnostics: [text] = []
    var i = 0
    while i < metadata_lines.len():
        val line = metadata_lines[i].trim()
        if line == "" or line.starts_with("section|"):
            i = i + 1
            continue
        if not line.starts_with("counter|"):
            diagnostics.push("invalid_metadata_line:" + i.to_string())
            i = i + 1
            continue

        val slot_index = _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "slot"))
        val counter_kind = _native_profile_counter_pipe_value(line, "kind")
        val stable_key = _native_profile_counter_unescape(_native_profile_counter_pipe_value(line, "key"))
        val initial_value = _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "initial"))
        if slot_index < 0 or stable_key == "" or initial_value < 0:
            diagnostics.push("invalid_metadata_slot:" + slot_index.to_string())
            i = i + 1
            continue
        if not native_profile_counter_kind_valid(counter_kind):
            diagnostics.push("invalid_metadata_kind:" + slot_index.to_string() + ":" + counter_kind)
            i = i + 1
            continue
        if slot_index >= final_counter_values.len():
            diagnostics.push("missing_count:" + slot_index.to_string())
            i = i + 1
            continue

        val final_count = final_counter_values[slot_index]
        if final_count < initial_value:
            diagnostics.push("counter_below_initial:" + slot_index.to_string())
            i = i + 1
            continue

        val record = native_profile_counter_sprof_record_from_metadata_line(line, final_count)
        if native_profile_counter_sprof_record_valid(record):
            records.push(record)
            lines.push(record.line)
        else:
            diagnostics.push("invalid_sprof_record:" + slot_index.to_string())
        i = i + 1
    var extra_index = 0
    while extra_index < final_counter_values.len():
        if not _native_profile_counter_metadata_has_slot(metadata_lines, extra_index):
            diagnostics.push("count_without_metadata:" + extra_index.to_string())
        extra_index = extra_index + 1
    NativeProfileCounterSprofExtraction(
        record_count: records.len(),
        line_count: lines.len(),
        diagnostic_count: diagnostics.len(),
        records: records,
        lines: lines,
        diagnostics: diagnostics
    )

fn native_profile_counter_extract_sprof_lines(metadata_lines: [text], final_counter_values: [i64]) -> [text]:
    native_profile_counter_extract_sprof_records(metadata_lines, final_counter_values).lines

fn native_profile_counter_snapshot_header() -> text:
    "simple-profile-counter-snapshot-v1"

fn native_profile_counter_snapshot_line(slot_index: i64, value: i64) -> text:
    "count|slot=" + slot_index.to_string() + "|value=" + value.to_string()

fn _native_profile_counter_snapshot_slot(line: text) -> i64:
    _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "slot"))

fn _native_profile_counter_snapshot_value(line: text) -> i64:
    _native_profile_counter_parse_i64(_native_profile_counter_pipe_value(line, "value"))

fn native_profile_counter_runtime_snapshot_from_text(snapshot_text: text) -> NativeProfileCounterRuntimeSnapshot:
    var diagnostics: [text] = []
    var max_slot: i64 = -1
    var saw_header = false
    val lines = snapshot_text.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line == native_profile_counter_snapshot_header():
            saw_header = true
        elif line.starts_with("count|"):
            val slot = _native_profile_counter_snapshot_slot(line)
            val value = _native_profile_counter_snapshot_value(line)
            if slot < 0:
                diagnostics.push("invalid_snapshot_slot:" + i.to_string())
            elif value < 0:
                diagnostics.push("invalid_snapshot_value:" + slot.to_string())
            elif slot > max_slot:
                max_slot = slot
        elif line != "":
            diagnostics.push("invalid_snapshot_line:" + i.to_string())
        i = i + 1

    if not saw_header:
        diagnostics.push("missing_snapshot_header")

    var counters: [i64] = []
    var slot_index: i64 = 0
    while slot_index <= max_slot:
        counters.push(-1)
        slot_index = slot_index + 1

    i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("count|"):
            val slot = _native_profile_counter_snapshot_slot(line)
            val value = _native_profile_counter_snapshot_value(line)
            if slot >= 0 and value >= 0 and slot < counters.len():
                if counters[slot] >= 0:
                    diagnostics.push("duplicate_snapshot_slot:" + slot.to_string())
                else:
                    counters[slot] = value
        i = i + 1

    slot_index = 0
    while slot_index < counters.len():
        if counters[slot_index] < 0:
            diagnostics.push("missing_snapshot_slot:" + slot_index.to_string())
        slot_index = slot_index + 1

    NativeProfileCounterRuntimeSnapshot(
        status: if diagnostics.len() == 0: "valid" else: "invalid",
        counter_count: counters.len(),
        counters: counters,
        diagnostic_count: diagnostics.len(),
        diagnostics: diagnostics
    )

fn native_profile_counter_sprof_import_plan(
    output_path: text,
    metadata_lines: [text],
    snapshot_text: text
) -> NativeProfileCounterSprofImportPlan:
    val snapshot = native_profile_counter_runtime_snapshot_from_text(snapshot_text)
    if snapshot.diagnostic_count > 0:
        return NativeProfileCounterSprofImportPlan(
            status: "invalid_snapshot",
            output_path: output_path,
            metadata_count: metadata_lines.len(),
            counter_count: snapshot.counter_count,
            record_count: 0,
            line_count: 0,
            diagnostic_count: snapshot.diagnostic_count,
            write_allowed: false,
            lines: [],
            diagnostics: snapshot.diagnostics
        )

    val extraction = native_profile_counter_extract_sprof_records(metadata_lines, snapshot.counters)
    if extraction.diagnostic_count > 0:
        return NativeProfileCounterSprofImportPlan(
            status: "invalid_import",
            output_path: output_path,
            metadata_count: metadata_lines.len(),
            counter_count: snapshot.counter_count,
            record_count: extraction.record_count,
            line_count: extraction.line_count,
            diagnostic_count: extraction.diagnostic_count,
            write_allowed: false,
            lines: extraction.lines,
            diagnostics: extraction.diagnostics
        )

    NativeProfileCounterSprofImportPlan(
        status: if output_path == "": "missing_output_path" else: "ready",
        output_path: output_path,
        metadata_count: metadata_lines.len(),
        counter_count: snapshot.counter_count,
        record_count: extraction.record_count,
        line_count: extraction.line_count,
        diagnostic_count: if output_path == "": 1 else: 0,
        write_allowed: output_path != "",
        lines: extraction.lines,
        diagnostics: if output_path == "": ["missing_output_path"] else: []
    )
