# Compile Module
#
# High-level compilation interface for the Simple compiler.
# Provides simplified APIs for compiling Simple source code.
#
# Public API:
#   - use app.compile.{compile_file, compile_source}
#   - use app.compile.{CompileConfig, CompileResult}

# All submodules are automatically available.

# Re-exported from llvm_direct.spl
export compile_llvm_direct, compile_llvm_direct_opts, CompileOpts, default_compile_opts, merge_pgo_profiles

# Re-exported from native.spl
export compile_native, compile_native_linked, compile_gen_c_only
export find_c_compiler, find_cpp_compiler, detect_platform

# Re-exported from native_profile_counter.spl
export native_profile_counter_kinds, native_profile_counter_kind_valid
export native_profile_counters_enabled, native_profile_counter_enabled
export native_profile_counter_identity_matches
export native_profile_call_path_counter_max_depth, native_profile_call_path_counter_allowed
