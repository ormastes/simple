# Lightweight daemon client for explicit single-file `simple test`.

use std.sffi.cli.{cli_get_args}
use app.io.process_ops.{process_run, process_run_bounded, process_run_timeout}
use std.test_runner.test_runner_args.{parse_test_args}
use std.test_runner.test_config.{load_test_config}
use std.test_runner.test_runner_types.{TEST_OUTPUT_CAPTURE_BYTES}
use std.test_runner.test_runner_modes.{run_spl_doctest_mode}
use app.test_daemon.light_protocol.{LIGHT_REQUEST_RESPONSE_GRACE_MS, light_request_encode, light_request_expiry_micros, light_request_timeout_ms_from_seconds}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_rename(from: text, to: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_sleep_ms(ms: i64)
extern fn rt_time_now_unix_micros() -> i64

# Atomic write: tmp + rename. Plain rt_file_write_text does open(create,
# truncate) then write() as two separate steps, so a concurrent reader that
# lists the directory and opens the file between those steps can observe a
# 0-byte (or partially written) file. The daemon's poll loop lists+reads
# request files this way, so a non-atomic write here races with it and the
# daemon can misread an in-flight request as empty ("missing test path"),
# consuming and discarding the real request (#98).
fn atomic_write_text(path: text, content: text) -> bool:
    val tmp_path = "{path}.tmp"
    if rt_file_write_text(tmp_path, content):
        if rt_file_rename(tmp_path, path):
            return true
        rt_file_delete(tmp_path)
    rt_file_write_text(path, content)

val LIGHT_DAEMON_DIR: text = ".build/test_daemon_light"
val LIGHT_REQ_DIR: text = ".build/test_daemon_light/requests"
val LIGHT_RESP_DIR: text = ".build/test_daemon_light/responses"
val LIGHT_LOCK: text = ".build/test_daemon_light/daemon.lock"

struct ClientRun:
    path: text
    timeout_secs: i64
    valid: bool
    error: text

fn clean_args() -> [text]:
    val raw = cli_get_args()
    var args: [text] = []
    var i = 0
    while i < raw.len():
        val arg = raw[i]
        if arg == "test" or arg == "run":
            i = i + 1
            continue
        if arg.ends_with("/simple") or arg.ends_with("simple.exe") or arg.ends_with("test_runner_client.spl"):
            i = i + 1
            continue
        args.push(arg)
        i = i + 1
    args

fn parse_client_run(args: [text]) -> ClientRun:
    var path = ""
    var timeout_secs = 120
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--timeout" and i + 1 < args.len():
            timeout_secs = to_int(args[i + 1])
            i = i + 2
            continue
        if arg.starts_with("--timeout="):
            timeout_secs = to_int(arg[10:])
            i = i + 1
            continue
        if not arg.starts_with("-") and path == "":
            path = arg
        i = i + 1
    if path == "":
        return ClientRun(path: "", timeout_secs: timeout_secs, valid: false, error: "missing test file")
    if not path.ends_with(".spl"):
        return ClientRun(path: path, timeout_secs: timeout_secs, valid: false, error: "expected .spl test file")
    if not rt_file_exists(path):
        return ClientRun(path: path, timeout_secs: timeout_secs, valid: false, error: "test file not found")
    ClientRun(path: path, timeout_secs: timeout_secs, valid: true, error: "")

fn simple_binary() -> text:
    val raw = cli_get_args()
    # Source-mode argv can begin with this file's own .spl path (when the seed
    # interprets test_runner_client.spl directly). It exists, but it is not
    # executable; passing it to process_run(_timeout) produces a misleading
    # permission-denied failure instead of running the test. Same fix as
    # test_runner_single.spl's simple_binary().
    if raw.len() > 0 and (raw[0].ends_with("/simple") or raw[0].ends_with("simple.exe")) and rt_file_exists(raw[0]):
        return raw[0]
    if rt_file_exists("src/compiler_rust/target/debug/simple"):
        return "src/compiler_rust/target/debug/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("/proc/self/exe"):
        return "/proc/self/exe"
    "./bin/simple"

fn ensure_dirs():
    rt_dir_create_all(LIGHT_DAEMON_DIR)
    rt_dir_create_all(LIGHT_REQ_DIR)
    rt_dir_create_all(LIGHT_RESP_DIR)

fn daemon_lock_alive() -> bool:
    if not rt_file_exists(LIGHT_LOCK):
        return false
    val (_stdout, _stderr, code) = process_run_timeout(
        "/bin/sh",
        ["-c", "pid=$(cat {LIGHT_LOCK} 2>/dev/null); test -n \"$pid\" && kill -0 \"$pid\" 2>/dev/null"],
        1000
    )
    code == 0

fn ensure_daemon() -> bool:
    if daemon_lock_alive():
        return true
    rt_file_delete(LIGHT_LOCK)
    val binary = simple_binary()
    val (_daemon_out, _daemon_err, daemon_code) = process_run(
        "/bin/sh",
        ["-c", "SIMPLE_EXECUTION_MODE=interpret {binary} run src/app/test_daemon/light_daemon.spl >/tmp/simple-test-daemon-light.log 2>&1 &"]
    )
    if daemon_code != 0:
        rt_file_write_text("/tmp/simple-test-daemon-light.log", "failed to spawn light daemon: {daemon_code}\n")
        return false
    var waits = 0
    while waits < 40:
        if rt_file_exists(LIGHT_LOCK):
            return true
        rt_sleep_ms(50)
        waits = waits + 1
    rt_file_write_text("/tmp/simple-test-daemon-light.log", "light daemon shell exited but did not create lock\n")
    false

fn print_response(content: text) -> i64:
    val newline = content.find("\n") ?? -1
    if newline < 0:
        print content
        return 1
    val code = content[0:newline].trim().to_i64() ?? 1
    val body = content[newline + 1:]
    if body != "":
        print body
    code

fn has_spl_doctest_flag(args: [text]) -> bool:
    for a in args:
        if a == "--spl-doctest":
            return true
    false

fn run_scoped_spl_doctest(args: [text]) -> i64:
    """Handle `simple test --spl-doctest <target>` directly, in-process.

    This flag is dropped by the light-daemon request protocol below (it only
    forwards a bare file path — see parse_client_run/atomic_write_text), so a
    file target ending in .spl always matches
    test_should_use_light_daemon_client's routing and would otherwise run as
    a normal spec via the daemon, silently discarding --spl-doctest. Handle it
    here before any daemon/path-only forwarding happens."""
    val options = parse_test_args(args)
    val config = load_test_config()
    print "=== Running SPL Doctests ==="
    print ""
    val result = run_spl_doctest_mode(options, config)
    print "SPL Doctest: {result.passed} passed, {result.failed} failed, {result.skipped} skipped"
    print ""
    if result.is_ok():
        return 0
    1

fn main() -> i64:
    val cleaned = clean_args()
    if has_spl_doctest_flag(cleaned):
        return run_scoped_spl_doctest(cleaned)
    val run = parse_client_run(cleaned)
    if not run.valid:
        print "Simple Test Runner client"
        print "error: {run.error}: {run.path}"
        return 1
    val timeout_ms = light_request_timeout_ms_from_seconds(run.timeout_secs)
    ensure_dirs()
    if not ensure_daemon():
        # The light daemon could not start (e.g. it relies on runtime methods
        # the seed interpreter lacks). Degrade gracefully to direct execution
        # via the single runner instead of refusing — `--no-session-daemon`
        # routes to test_runner_single.spl (no daemon, no recursion).
        print "WARNING: test daemon unavailable; running directly"
        val binary = simple_binary()
        val (out, err, code) = process_run_bounded(
            binary,
            ["test", "--no-session-daemon", run.path],
            timeout_ms,
            TEST_OUTPUT_CAPTURE_BYTES
        )
        if out != "":
            print out
        if err != "":
            print err
        return code
    val id = "{rt_time_now_unix_micros()}-{rt_getpid()}.req"
    val req_path = "{LIGHT_REQ_DIR}/{id}"
    val resp_path = "{LIGHT_RESP_DIR}/{id}.resp"
    val expiry_micros = light_request_expiry_micros(rt_time_now_unix_micros(), timeout_ms)
    rt_file_delete(resp_path)
    atomic_write_text(req_path, light_request_encode(run.path, expiry_micros))
    val deadline = expiry_micros + (LIGHT_REQUEST_RESPONSE_GRACE_MS * 1000)
    while rt_time_now_unix_micros() < deadline:
        if rt_file_exists(resp_path):
            val content = rt_file_read_text(resp_path) ?? ""
            rt_file_delete(resp_path)
            return print_response(content)
        rt_sleep_ms(100)
    print "ERROR: test daemon timed out: {run.path}"
    1
