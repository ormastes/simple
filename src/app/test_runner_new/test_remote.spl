# =========================================================================
# Remote loader execution (minimal infrastructure)
# =========================================================================

fn run_test_remote_loader(file_path: text, target: RemoteTarget, options: TestOptions) -> TestFileResult:
    """Remote loader execution: upload .smf, minimal loader on target runs it.

    The target must have a pre-flashed minimal loader that provides:
      - Semihost I/O (for output collection)
      - Interrupt handler (for fault isolation)
      - SMF module loader (for .smf file loading)
      - test_main() call convention support

    Planned flow:
      1. Compile .spl to .smf on host
      2. Connect to remote target
      3. Upload .smf to target memory
      4. Signal loader to load + call test_main()
      5. Collect semihost output via serial
      6. Parse output for test results

    Pre-loaded initialization:
      - Loader calls target init before loading .smf
      - Init configures: memory allocator, semihost, interrupt vectors
      - Init module can be pre-flashed or uploaded separately

    Startup modes:
      - Standalone: loader is entry point, loads .smf, calls test_main()
      - Called-function: loader calls user_init(), then loads .smf, calls test_main()

    Minimal loader requirements:
      - Total size: < 16KB (fits in most microcontroller boot ROM)
      - Semihost: SYS_WRITEC (0x03), SYS_WRITE0 (0x04), SYS_EXIT (0x18)
      - Interrupt: HardFault handler that reports via semihost then exits
      - SMF: parse SMF trailer, load segments, resolve test_main symbol
    """
    # TODO: implement remote loader execution
    pass_todo

