    pass_todo

# =========================================================================
# Remote native execution
# =========================================================================

fn run_test_remote_native(file_path: text, target: RemoteTarget, options: TestOptions) -> TestFileResult:
    """Remote native execution: cross-compile on host, upload ELF, run on target.

    Planned flow:
      1. Cross-compile .spl to target ELF (using --target=<arch> flag)
         - aot_c_file() with cross-compilation toolchain
         - Link with baremetal runtime + semihost I/O
      2. Connect to remote target
      3. Upload ELF binary to target memory
      4. Signal remote to load + execute ELF
      5. Collect semihost output via serial
      6. Parse output for test results

    Pre-loaded initialization:
      - Init function compiled into the ELF binary
      - Called before test_main() in the generated main() wrapper
      - Target hardware init (clock, peripherals) runs before tests

    Startup modes:
      - Standalone: ELF main() -> init() -> test_main(args)
      - Called-function: user ELF main() -> user_init() -> test_main_with_init()
    """
