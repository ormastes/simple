# =========================================================================
# Universal test entry point
#
# Provides test_main() and test_main_with_init() callable from any context:
#   - Standalone mode: test binary main() calls test_main(args)
#   - Called-function mode: user main() calls test_main_with_init(args, init)
#
# Dispatches to appropriate runner based on --mode flag:
#   - interpreter: run_test_file_interpreter() [existing]
#   - loader/smf: run_test_loader() [new]
#   - native: run_test_native() [new]
#   - all-modes: runs all three sequentially
# =========================================================================

use test_runner_types.*
use test_runner_args.{parse_test_args}
use test_runner_execute.{run_test_file_interpreter, run_test_file_smf}
use test_runner_files.{collect_test_files}
use test_native_runner.{run_test_native}
use test_loader_runner.{run_test_loader}
use test_executor_composite.{run_test_file_composite}
use app.io.time_ops.{time_now_unix_micros}

# =========================================================================
# Public API
# =========================================================================

fn test_main(args: List<text>) -> TestRunResult:
    """Universal test entry point. Parses args and runs tests in selected mode."""
    test_main_with_init(args, test_init_config_default())

fn test_main_with_init(args: List<text>, init_config: TestInitConfig) -> TestRunResult:
    """Universal test entry point with pre-loaded initialization support."""
    # 1. Parse args
    val options = parse_test_args(args)

    # 2. Call init_fn if provided
    if init_config.init_fn.?:
        val f = init_config.init_fn.unwrap()
        f()

    # 3. Load init module if specified
    if init_config.init_module.?:
        val module_path = init_config.init_module.unwrap()
        # TODO: load module and call its init() function
        print "[test_main] init module loading not yet implemented: {module_path}"

    # 4. Dispatch based on mode
    val mode = options.mode
    match mode:
        AllModes:
            val all_result = run_test_all_modes(options)
            print all_result.summary()
            merge_all_modes_result(all_result)
        _:
            run_tests_single_mode(options)

# =========================================================================
# Single-mode execution
# =========================================================================

fn run_tests_single_mode(options: TestOptions) -> TestRunResult:
    """Run all discovered test files in a single execution mode."""
    val files = collect_test_files(options)
    var results: List<TestFileResult> = []

    for file_path in files:
        val result = run_test_file_dispatch(file_path, options)
        results.push(result)
        if options.fail_fast and not result.is_ok():
            break

    aggregate_results(results)

fn run_test_file_dispatch(file_path: text, options: TestOptions) -> TestFileResult:
    """Dispatch a single test file to the appropriate runner based on mode."""
    val mode = options.mode
    match mode:
        Interpreter:
            run_test_file_interpreter(file_path, options)
        Smf:
            run_test_loader(file_path, options)
        Native:
            run_test_native(file_path, options)
        Composite(spec):
            run_test_file_composite(file_path, options, spec)
        AllModes:
            # Fallback: run as interpreter if somehow reached
            run_test_file_interpreter(file_path, options)

# =========================================================================
# All-modes execution
# =========================================================================

fn run_test_all_modes(options: TestOptions) -> TestAllModesResult:
    """Run tests in all three modes: interpreter, loader, native."""
    var mode_results: List<TestModeResult> = []
    var all_passed = true

    # Run interpreter mode
    val interp_result = run_mode_timed(options, TestExecutionMode.Interpreter)
    mode_results.push(interp_result)
    if not interp_result.is_ok():
        all_passed = false

    # Run loader mode
    val loader_result = run_mode_timed(options, TestExecutionMode.Smf)
    mode_results.push(loader_result)
    if not loader_result.is_ok():
        all_passed = false

    # Run native mode
    if not options.fail_fast or all_passed:
        val native_result = run_mode_timed(options, TestExecutionMode.Native)
        mode_results.push(native_result)
        if not native_result.is_ok():
            all_passed = false

    TestAllModesResult(mode_results: mode_results, all_passed: all_passed)

fn run_mode_timed(options: TestOptions, mode: TestExecutionMode) -> TestModeResult:
    """Run tests in a specific mode and time the execution."""
    val start = time_now_unix_micros()

    # Create a copy of options with the specific mode
    var mode_options = options
    mode_options.mode = mode

    val mode_name = execution_mode_to_string(mode)
    print "\n=== {mode_name} Mode ==="

    val result = run_tests_single_mode(mode_options)

    val end = time_now_unix_micros()
    val duration_ms = (end - start) / 1000

    print "  {mode_name}: {result.total_passed} passed, {result.total_failed} failed ({duration_ms}ms)"

    TestModeResult(mode: mode, result: result, duration_ms: duration_ms)

# =========================================================================
# Result aggregation
# =========================================================================

fn aggregate_results(results: List<TestFileResult>) -> TestRunResult:
    """Aggregate per-file results into a single TestRunResult."""
    var total_passed = 0
    var total_failed = 0
    var total_skipped = 0
    var total_pending = 0
    var total_timed_out = 0
    var total_duration_ms: i64 = 0
    var total_setup_ms: i64 = 0

    for r in results:
        total_passed = total_passed + r.passed
        total_failed = total_failed + r.failed
        total_skipped = total_skipped + r.skipped
        total_pending = total_pending + r.pending
        if r.timed_out:
            total_timed_out = total_timed_out + 1
        total_duration_ms = total_duration_ms + r.duration_ms
        total_setup_ms = total_setup_ms + r.setup_ms

    TestRunResult(
        files: results,
        total_passed: total_passed,
        total_failed: total_failed,
        total_skipped: total_skipped,
        total_pending: total_pending,
        total_timed_out: total_timed_out,
        total_duration_ms: total_duration_ms,
        total_setup_ms: total_setup_ms
    )

fn merge_all_modes_result(all_result: TestAllModesResult) -> TestRunResult:
    """Merge per-mode results into a single TestRunResult."""
    var all_files: List<TestFileResult> = []
    var total_passed = 0
    var total_failed = 0
    var total_skipped = 0
    var total_pending = 0
    var total_timed_out = 0
    var total_duration_ms: i64 = 0

    for mr in all_result.mode_results:
        total_passed = total_passed + mr.result.total_passed
        total_failed = total_failed + mr.result.total_failed
        total_skipped = total_skipped + mr.result.total_skipped
        total_pending = total_pending + mr.result.total_pending
        total_timed_out = total_timed_out + mr.result.total_timed_out
        total_duration_ms = total_duration_ms + mr.result.total_duration_ms
        for f in mr.result.files:
            all_files.push(f)

    TestRunResult(
        files: all_files,
        total_passed: total_passed,
        total_failed: total_failed,
        total_skipped: total_skipped,
        total_pending: total_pending,
        total_timed_out: total_timed_out,
        total_duration_ms: total_duration_ms,
        total_setup_ms: 0
    )
