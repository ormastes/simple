# Minimal pure-Simple child test runner.
#
# Used by daemon-owned child runs (`simple test <file> --no-session-daemon`).
# Keep this file independent from std.test_runner.* so child execution does not
# import discovery, cache, fork, composite, QEMU, or daemon modules.
#
# NOTE on zero-executed detection: this file deliberately does NOT use
# std.test_runner.test_result_wrapper.build_interpreter_result_wrapper (the
# usual cross-module "wrap the source + panic on get_executed_test_count()==0"
# contract). That harness generates `use std.spec.{print_summary, ...}`, and in
# this interpreter-mode default-family context `std.spec` resolves to the
# `spec/` package directory (src/lib/<family>/spec/__init__.spl), which does
# NOT re-export print_summary/get_exit_code/get_executed_test_count (only the
# sibling spec.spl FILE does) — every wrapped run, including genuinely green
# ones, hard-fails with "function `print_summary` not found" (verified via
# bin/simple, not just the bootstrap seed). Reusing that wrapper here would
# turn the zero-executed greenwash into a universal false-RED. See
# doc/08_tracking/bug/test_runner_zero_executed_single_file_greenwash_2026-07-17.md
# for the repro and doc/08_tracking/bug/std_spec_package_shadows_file_print_summary_2026-07-17.md
# for the underlying resolution defect (out of scope for the runner layer).
#
# Instead, count REAL executed examples directly from the interpreter's own
# per-example glyph markers (✓ pass / ✗ fail) rather than trusting the
# "N examples, M failures" summary line, which miscounts pending()-only specs
# as 1 executed example with 0 failures (see count_real_examples below).

use std.sffi.cli.{cli_get_args}
use app.io.process_ops.{process_run_bounded}
use app.io.mod.{env_get}
use std.test_runner.test_runner_types.{TEST_OUTPUT_CAPTURE_BYTES}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

# --- Legacy word-infix matcher preprocessing (self-contained; this file is kept
# independent of std.test_runner.* so child runs stay lightweight). Mirrors
# test_runner_execute.preprocess_infix_matchers_only. ---

fn _single_rewrite_infix_expect_line(line: text) -> text:
    val trimmed = line.trim()
    if not trimmed.starts_with("expect ") or trimmed.starts_with("expect("):
        return line
    val matchers: [text] = ["to_equal", "to_be", "to_contain", "to_start_with", "to_end_with", "to_be_greater_than", "to_be_less_than", "to_be_at_least", "to_be_at_most", "to_be_nil", "to_be_truthy", "to_be_falsy", "to_be_true", "to_be_false", "to_have_length", "to_be_empty"]
    var i = 0
    while i < matchers.len():
        val matcher = matchers[i]
        val needle = " " + matcher + " "
        val split_at = trimmed.index_of(needle) ?? -1
        if split_at >= 0:
            val actual_raw = trimmed.substring(7, split_at)
            val actual = actual_raw.trim()
            val expected_raw = trimmed.substring(split_at + needle.len())
            val expected = expected_raw.trim()
            if actual.len() == 0 or expected.len() == 0:
                return line
            val trimmed_line = line.trim_start()
            val indent_len = line.len() - trimmed_line.len()
            val indent = line.substring(0, indent_len)
            return indent + "expect(" + actual + ")." + matcher + "(" + expected + ")"
        i = i + 1
    line

fn _single_last_slash(s: text) -> i64:
    var idx = -1
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == "/":
            idx = i
        i = i + 1
    idx

fn preprocess_infix_for_child(file_path: text) -> text:
    if not file_path.ends_with("_spec.spl"):
        return file_path
    val content = rt_file_read_text(file_path)
    if content == "":
        return file_path
    val lines = content.split("\n")
    var joined = ""
    var first = true
    var changed = false
    for raw_line in lines:
        val rewritten = _single_rewrite_infix_expect_line(raw_line)
        if rewritten != raw_line:
            changed = true
        if first:
            joined = rewritten
            first = false
        else:
            joined = joined + "\n" + rewritten
    if not changed:
        return file_path
    val slash = _single_last_slash(file_path)
    val dir = if slash >= 0: file_path.substring(0, slash + 1) else: ""
    val base = if slash >= 0: file_path.substring(slash + 1) else: file_path
    val tmp = dir + ".spipe_matchers_" + base
    val ok = rt_file_write_text(tmp, joined)
    if not ok:
        return file_path
    tmp

struct ChildRun:
    path: text
    timeout_secs: i64
    list_only: bool
    valid: bool
    error: text

fn clean_args() -> [text]:
    val raw = cli_get_args()
    var args: [text] = []
    var i = 0
    while i < raw.len():
        val arg = raw[i]
        if arg == "test" or arg == "run":
            i = i + 1
            continue
        if arg.ends_with("/simple") or arg.ends_with("simple.exe") or arg.ends_with("test_runner_single.spl"):
            i = i + 1
            continue
        args.push(arg)
        i = i + 1
    args

fn parse_child_run(args: [text]) -> ChildRun:
    var path = ""
    var timeout_secs = 120
    var list_only = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--timeout" and i + 1 < args.len():
            timeout_secs = to_int(args[i + 1])
            i = i + 2
            continue
        if arg.starts_with("--timeout="):
            timeout_secs = to_int(arg[10:])
            i = i + 1
            continue
        if arg == "--list":
            list_only = true
            i = i + 1
            continue
        if not arg.starts_with("-") and path == "":
            path = arg
        i = i + 1
    if path == "":
        return ChildRun(path: "", timeout_secs: timeout_secs, list_only: list_only, valid: false, error: "missing test file")
    if not path.ends_with(".spl"):
        return ChildRun(path: path, timeout_secs: timeout_secs, list_only: list_only, valid: false, error: "expected .spl test file")
    if not rt_file_exists(path):
        return ChildRun(path: path, timeout_secs: timeout_secs, list_only: list_only, valid: false, error: "test file not found")
    ChildRun(path: path, timeout_secs: timeout_secs, list_only: list_only, valid: true, error: "")

fn find_simple_binary() -> text:
    val configured = env_get("SIMPLE_BINARY")
    if configured != nil and configured != "" and rt_file_exists(configured):
        return configured
    val raw = cli_get_args()
    # Source-mode argv can begin with test_runner_single.spl itself. It exists,
    # but it is not executable; passing it to process_run_timeout produces a
    # misleading permission-denied failure instead of running the test.
    if raw.len() > 0 and (raw[0].ends_with("/simple") or raw[0].ends_with("simple.exe")) and rt_file_exists(raw[0]):
        return raw[0]
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    # Reuse the currently-running interpreter binary. In a detached worktree
    # `bin/release/<triple>/simple` (the `bin/simple` symlink target) is
    # gitignored and absent, so the two checks above both miss and the child
    # `simple run` launch fails (code=-1, empty output) — which the caller then
    # mislabels as "no examples executed", false-FAILing every spec. This is the
    # same /proc/self/exe fallback test_runner_client.spl's simple_binary()
    # already carries; the two had drifted (bug: test_runner_single_worktree_no_binary_false_fail).
    if rt_file_exists("/proc/self/exe"):
        return "/proc/self/exe"
    "./bin/simple"

fn file_has_di_test_tag(file_path: text) -> bool:
    """Check if file has # @di_test tag, allowing DI modifications in system tests.

    Mirrors std.test_runner.test_runner_files.file_has_di_test_tag. Duplicated
    here (rather than imported) so this child runner stays independent of
    std.test_runner.* per the file-level design note above."""
    val content = rt_file_read_text(file_path)
    content.contains("# @di_test")

fn print_summary(path: text, passed: i64, failed: i64, skipped: i64, pending: i64, duration_ms: i64):
    print ""
    print "========================================="
    print "Test Summary"
    print "========================================="
    print "Files: 1"
    print "Passed: {passed}"
    print "Failed: {failed}"
    if skipped > 0:
        print "Skipped: {skipped}"
    if pending > 0:
        print "Pending: {pending}"
    print "Duration: {duration_ms}ms"
    if failed == 0:
        print ""
        print "PASS {path}"
    else:
        print ""
        print "FAIL {path}"

fn extract_number_before(s: text, keyword: text) -> i64:
    val idx_opt = s.index_of(keyword)
    val idx = idx_opt ?? -1
    if idx < 0:
        return -1
    val prefix = s[0:idx]
    var current = ""
    var last = ""
    var i = 0
    while i < prefix.len():
        val ch = prefix[i:i + 1]
        if ch >= "0" and ch <= "9":
            current = current + ch
        else:
            if current != "":
                last = current
                current = ""
        i = i + 1
    if current != "":
        last = current
    if last == "":
        return -1
    to_int(last)

fn _count_lines_containing(output: text, marker: text) -> i64:
    var count = 0
    val lines = output.split("\n")
    for line in lines:
        if line.contains(marker):
            count = count + 1
    count

fn count_real_examples(output: text) -> (i64, i64):
    """Count REAL executed `it` blocks from the runner's own per-example
    markers instead of the aggregate "N examples, M failures" summary line.
    Interpreter-mode intrinsic BDD reporting marks each real execution with a
    glyph (✓ pass / ✗ fail); pending()/skip() use a different marker (○ ...
    (skipped) / ... skipped / ... pending) and are never counted here.
    Compiled-mode reporting (std.spec._execute_it) uses the textual
    "it ... ok" / "it ... FAILED" suffixes instead, so both are recognized.
    This is fail-closed against the summary line, which miscounts a
    pending()-only spec as "1 example, 0 failures" (zero-executed greenwash:
    doc/08_tracking/bug/test_runner_zero_executed_single_file_greenwash_2026-07-17.md)."""
    val real_passed = _count_lines_containing(output, "✓") + _count_lines_containing(output, "... ok")
    val real_failed = _count_lines_containing(output, "✗") + _count_lines_containing(output, "... FAILED")
    (real_passed, real_failed)

fn parse_child_example_summary(output: text) -> (i64, i64, i64):
    # Sum across ALL per-describe "N examples, M failures" lines. Last-wins
    # here previously let a passing final describe erase earlier failures
    # (file summary "Failed: 0" + PASS + exit 0 on a red spec).
    var examples = -1
    var failures = -1
    val lines = output.split("\n")
    for line in lines:
        if line.contains("example") and line.contains("failure"):
            val parsed_examples = extract_number_before(line, "example")
            val parsed_failures = extract_number_before(line, "failure")
            if parsed_examples >= 0 and parsed_failures >= 0:
                if examples < 0:
                    examples = 0
                    failures = 0
                examples = examples + parsed_examples
                failures = failures + parsed_failures
    if examples >= 0 and failures >= 0:
        return (examples - failures, failures, 1)
    (0, 0, 0)

fn main() -> i64:
    val run = parse_child_run(clean_args())
    if not run.valid:
        print "Simple Test Runner child"
        print "error: {run.error}: {run.path}"
        return 1
    if run.list_only:
        print run.path
        return 0

    rt_env_set("SIMPLE_RUNTIME_MODE", "interpreter")
    val is_system = run.path.contains("/system/") or run.path.contains("/feature/")
    if is_system:
        rt_env_set("SIMPLE_SYSTEM_TEST", "1")
    else:
        rt_env_set("SIMPLE_SYSTEM_TEST", "0")
    if is_system and file_has_di_test_tag(run.path):
        rt_env_set("SIMPLE_DI_TEST", "1")
    else:
        rt_env_set("SIMPLE_DI_TEST", "0")

    val binary = find_simple_binary()
    val timeout_ms = run.timeout_secs * 1000
    # Rewrite legacy word-infix `expect X to_equal Y` to method form so the
    # interpreter `run` path evaluates the matcher (else it drops it → false-red
    # on falsy calls, silent false-green otherwise).
    val exec_path = preprocess_infix_for_child(run.path)
    val start = rt_time_now_unix_micros()
    val (stdout, stderr, code) = process_run_bounded(binary, ["run", exec_path], timeout_ms, TEST_OUTPUT_CAPTURE_BYTES)
    val duration_ms = (rt_time_now_unix_micros() - start) / 1000
    if exec_path != run.path and rt_file_exists(exec_path):
        val _ = rt_file_delete(exec_path)
    if stdout != "":
        print stdout
    if stderr != "":
        print stderr
    val combined = stdout + "\n" + stderr
    val (real_passed, real_failed) = count_real_examples(combined)
    val real_executed = real_passed + real_failed
    val (summary_passed, summary_failed, has_summary) = parse_child_example_summary(combined)
    var failed = 0
    var passed = 0
    if code == -1 and (stderr.contains("TIMEOUT") or stderr.contains("timed out")):
        # process_run_bounded killed the child at the configured per-file
        # budget: it never got a chance to finish, so nothing it printed
        # (partial summary lines included) can be trusted as a real result.
        # Bug: test_runner_60s_silent_kill_greenwash — a killed file must
        # never read as PASS just because the pre-kill output looked clean.
        failed = 1
        passed = 0
        print "error: test-runner: file timed out"
    elif code == -1 and stdout == "" and stderr == "":
        # The child interpreter never launched (or was killed before emitting
        # anything) for a reason other than the timeout budget above: e.g. the
        # resolved `binary` path is not an executable. Report the launch failure
        # honestly instead of letting the empty output fall through to the
        # zero-executed branch and read as "no examples executed" — that message
        # blames the spec for a runner/environment fault and hides the real
        # cause. Bug: test_runner_single_worktree_no_binary_false_fail.
        failed = 1
        passed = 0
        print "error: test-runner: failed to launch test binary '{binary}' (child code={code}, no output); set SIMPLE_BINARY to a valid simple executable"
    elif real_executed == 0 and (has_summary == 0 or summary_failed == 0):
        # Fail-closed zero-executed check: a spec whose only content is
        # pending()/an orphan describe with no real `it` executions must not
        # read as PASS just because the child process happened to exit 0 and
        # its aggregate "N examples, M failures" summary line looked clean
        # (that line counts pending() as an executed example — bug:
        # zero-executed single-file greenwash). Skipped when the summary
        # line ALREADY reports real failures (has_summary==1 and
        # summary_failed>0): that signal is trustworthy on its own even
        # without a corroborating ✓/✗ glyph (e.g. a non-interpreter child
        # that reports failures as plain text).
        failed = 1
        passed = 0
        print "error: test-runner: no examples executed"
    else:
        passed = if has_summary == 1: summary_passed else: (if code == 0: 1 else: 0)
        failed = if has_summary == 1: summary_failed else: (if code == 0: 0 else: 1)
        # Fail-closed: never let either counting method's LOWER failure count
        # silently win. This is what catches an orphan top-level `it` (bug:
        # test_runner_orphan_it_silently_ignored) — its real ✗ marker prints,
        # but it has no enclosing `describe` to fold it into any "N examples,
        # M failures" summary line, so the summary alone would miss it.
        if real_failed > failed:
            failed = real_failed
            if real_passed < passed:
                passed = real_passed
        if code != 0 and failed == 0:
            failed = 1
        if failed > 0:
            print "error: test-runner: spec failed"
    print_summary(run.path, passed, failed, 0, 0, duration_ms)
    if failed == 0:
        return 0
    1
