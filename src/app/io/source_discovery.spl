# Hosted Simple-source directory discovery shared by CLI tools.

use std.nogc_sync_mut.io.sffi_common.{is_absolute_path}
use std.path.{normalize}

extern fn rt_dir_walk(path: text) -> [text]
extern fn rt_path_absolute(path: text) -> text

fn discover_spl_files(root: text) -> [text]:
    val scan_root = rt_path_absolute(root).replace("\\", "/")
    val relative_root = source_relative_root(root)
    var files: [text] = []
    for physical_path in rt_dir_walk(scan_root):
        val path = source_restore_relative_path(physical_path, scan_root, relative_root)
        if path.ends_with(".spl"):
            files.push(path)
    files.sort()
    files

fn source_path_identity(path: text) -> text:
    normalize(rt_path_absolute(path).replace("\\", "/"))

fn source_relative_root(path: text) -> text:
    if is_absolute_path(path):
        return ""
    var root = path.replace("\\", "/")
    while root.len() > 1 and root.ends_with("/"):
        root = root.substring(0, root.len() - 1)
    root

fn source_restore_relative_path(physical_path: text, scan_root: text, relative_root: text) -> text:
    if relative_root == "":
        return physical_path
    val normalized = physical_path.replace("\\", "/")
    val prefix = scan_root + "/"
    if not normalized.starts_with(prefix):
        return physical_path
    relative_root + "/" + normalized.substring(prefix.len(), normalized.len())
