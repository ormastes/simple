fn cli_run_code(code: text, gc_log: bool, gc_off: bool) -> i64:
    val driver = _cli_driver_binary()
    val result = _cli_process_run(driver, ["-c", code])
    if result.0 != "":
        print_raw(result.0)
    if result.1 != "":
        _cli_eprint(result.1.trim())
    result.2

fn cli_run_file(path: text, args: [text], gc_log: bool, gc_off: bool) -> i64:
    val driver = _cli_driver_binary()
    if driver != "":
        val driver_args = startup_normalize_program_args(path, args)
        val result = _cli_process_run(driver, driver_args)
        if result.0 != "":
            print_raw(result.0)
        if result.1 != "":
            _cli_eprint(result.1.trim())
        return result.2

    val result = interpret_file(path)
    match result:
        case CompileResult.Success(_): 0
        case CompileResult.ParseError(errs):
            _cli_eprint("Parse error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.TypeError(errs):
            _cli_eprint("Type error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BlockError(errs):
            _cli_eprint("Block error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.ResolveError(errs):
            _cli_eprint("Resolve error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BorrowError(errs):
            _cli_eprint("Borrow error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.CodegenError(msg):
            _cli_eprint("Codegen error in {path}: {msg}")
            1
        case CompileResult.RuntimeError(msg):
            _cli_eprint("Runtime error in {path}: {msg}")
            1
        case _:
            _cli_eprint("Error running {path}")
            1

fn cli_watch_file(path: text) -> i64:
    var config: WatchConfig = watch_config_default()
    # If path looks like "test", set up test mode
    if path == "test":
        config.command_args = ["test"]
    elif path.ends_with(".spl"):
        # Specific test file
        config.command_args = ["test", path]
    else:
        # Custom watch path
        config.watch_paths = [path]
    watch_loop(config)

fn cli_run_repl(gc_log: bool, gc_off: bool) -> i64:
    cli_run_file("src/app/repl/main.spl", [], gc_log, gc_off)

fn cli_not_implemented(tool_name: text) -> i64:
    print "{tool_name} not yet implemented in pure Simple"
    1

fn _cli_strip_command(args: [text], cmd: text) -> [text]:
    if args.len() > 0 and args[0] == cmd:
        args.slice(1, args.len())
    else:
        args

fn sffi_gen_entry_path() -> text:
    "src/compiler/90.tools/sffi_gen/main.spl"

fn sffi_gen_force_args(args: [text]) -> text:
    args.join(" ")

extern fn rt_cli_run_tests(args: [text], gc_log: i64, gc_off: i64) -> i64

fn cli_run_tests(args: [text], gc_log: bool, gc_off: bool) -> i64:
    # Use Rust SFFI test runner directly (interpret_file path fails in native binaries)
    var gc_log_flag = 0
    var gc_off_flag = 0
    if gc_log:
        gc_log_flag = 1
    if gc_off:
        gc_off_flag = 1
    return rt_cli_run_tests(args, gc_log_flag, gc_off_flag)

fn cli_run_lint(args: [text]) -> i64:
    # Parse flags from args
    var files: [text] = []
    var run_mcp_perf = false
    var run_simd = false
    for arg in args:
        if arg == "lint":
            # Skip the command name itself
            val _ = 0
        elif arg == "--mcp-perf" or arg == "--all":
            run_mcp_perf = true
        elif arg == "--simd":
            run_simd = true
        elif not arg.starts_with("-"):
            files.push(arg)

    var exit_code = 0
    val root_guard_exit = _cli_run_workspace_root_guard()
    if root_guard_exit != 0:
        exit_code = 1

    if run_mcp_perf:
        val (stdout, stderr, perf_exit) = _cli_process_run("python3", ["scripts/mcp_performance_guard.py", "static-audit", "--strict", "--context", "lint"])
        if stdout.len() > 0:
            print(stdout)
        if stderr.len() > 0:
            _cli_eprint(stderr)
        if files.len() == 0:
            return perf_exit
        if perf_exit != 0:
            exit_code = 1

    if files.len() == 0:
        print "Usage: simple lint <file.spl> [file2.spl ...] [--mcp-perf] [--simd]"
        print ""
        print "Runs lint passes on Simple source files."
        print "Checks for:"
        print "  - Collection performance anti-patterns (COLL001-COLL008)"
        print "  - Duplicate typed arguments (DTYP001)"
        print "  - Bare primitive types in public APIs"
        print "  - MCP wrapper, hot-path, and invalidation regressions (--mcp-perf)"
        print "  - SIMD vectorisation opportunities L-SIMD-001..011 (--simd, info only)"
        return 1

    var total_warnings = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        val source = rt_file_read_text(file_path)
        var linter = Linter.new()
        val results = linter.lint_source(file_path, source)
        var visible_count = 0
        for result in results:
            visible_count = visible_count + 1
            var level_text = "info"
            match result.lint.level:
                case LintLevel.Deny:
                    level_text = "error"
                case LintLevel.Warn:
                    level_text = "warning"
                case LintLevel.Allow:
                    level_text = "info"
            print "{file_path}:{result.line}: {level_text}[{result.lint.code}]: {result.lint.message}"

        # SIMD opportunity pass — info severity, never increments exit code
        if run_simd:
            val simd_fixes = check_simd_opportunities(source, file_path)
            var si = 0
            while si < simd_fixes.len():
                val sf = simd_fixes[si]
                val sf_id = easyfix_id_text(sf)
                val id_parts2 = sf_id.split(":")
                val line_str2 = if id_parts2.len() > 3: id_parts2[3] else: "?"
                val sf_desc = easyfix_description_text(sf)
                print "{file_path}:{line_str2}: info[simd_opportunity]: {sf_desc}"
                si = si + 1

        if visible_count == 0:
            print "lint: {file_path} OK"
        else:
            _cli_eprint("lint: {file_path} has issues")
            exit_code = 1
            total_warnings = total_warnings + 1

    if total_warnings > 0:
        print ""
        print "Lint found issues in {total_warnings} file(s)"
    elif exit_code == 0:
        print ""
        print "Lint passed: all files clean"
    exit_code

fn cli_run_fmt(args: [text]) -> i64:
    # Parse flags from args
    var check_mode = false
    var write_mode = false
    var diff_mode = false
    var files: [text] = []
    for arg in args:
        if arg == "--check":
            check_mode = true
        elif arg == "--write":
            write_mode = true
        elif arg == "--diff":
            diff_mode = true
        elif arg == "fmt":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple fmt <file.spl> [--check] [--write] [--diff]"
        print ""
        print "Options:"
        print "  --check   Check if file is formatted (exit 1 if not)"
        print "  --write   Format file in place"
        print "  --diff    Show formatting diff"
        return 1

    var exit_code = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        if check_mode:
            val result = check_formatting(file_path)
            match result:
                case Ok(is_formatted):
                    if is_formatted:
                        print "OK {file_path} is formatted"
                    else:
                        print "FAIL {file_path} needs formatting"
                        exit_code = 1
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
        elif write_mode:
            val result = format_file_inplace(file_path)
            match result:
                case Ok(_):
                    print "OK Formatted {file_path}"
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
        elif diff_mode:
            val fmt = make_formatter()
            val orig_result = read_file(file_path)
            match orig_result:
                case Err(e):
                    _cli_eprint("Error reading file: {e}")
                    exit_code = 1
                case Ok(original):
                    val fmt_result = fmt.format_source(original)
                    match fmt_result:
                        case Err(e):
                            _cli_eprint("Error: {e}")
                            exit_code = 1
                        case Ok(formatted):
                            if original == formatted:
                                print "OK {file_path} is correctly formatted"
                            else:
                                print_diff(original, formatted, file_path)
                                exit_code = 1
        else:
            # Default: print formatted output to stdout
            val fmt = make_formatter()
            val result = fmt.format_file(file_path)
            match result:
                case Ok(formatted):
                    print formatted
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
    exit_code

fn cli_run_fix(args: [text]) -> i64:
    # Parse flags from args
    var dry_run = false
    var fix_all = false
    var fix_id: text = ""
    var files: [text] = []
    for arg in args:
        if arg == "--dry-run":
            dry_run = true
        elif arg == "--fix-all":
            fix_all = true
        elif arg.starts_with("--fix-id="):
            fix_id = arg.slice(9)
        elif arg == "fix":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple fix <file.spl> [--dry-run] [--fix-all]"
        print ""
        print "Options:"
        print "  --dry-run   Show what would be fixed without applying"
        print "  --fix-all   Apply all fixes regardless of confidence"
        print "  --fix-id=ID Apply only fixes matching ID prefix"
        return 1

    var exit_code = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        val source = rt_file_read_text(file_path) ?? ""
        if source == "":
            _cli_eprint("Error: Could not read file: {file_path}")
            exit_code = 1
            continue

        val fixes = if fix_id.starts_with("L:short_grammar_"):
            check_short_grammar_refactor(source, file_path)
        else:
            collect_fixes_from_source(file_path, source)
        if fixes.len() == 0:
            print "No fixes available for {file_path}"
            continue

        # Filter by confidence unless --fix-all
        var filtered = fixes
        if not fix_all:
            filtered = FixApplicator.filter_by_confidence(filtered, FixConfidence.Safe)
        if fix_id != "":
            filtered = FixApplicator.filter_by_id(filtered, fix_id)

        if filtered.len() == 0:
            print "No applicable fixes found for {file_path}"
            continue

        # Build sources registry for this file
        var sources: Dict<text, text> = {}
        sources[file_path] = source

        val result = FixApplicator.apply_to_disk(filtered, sources, dry_run)
        match result:
            case Ok(report):
                if dry_run:
                    print "Dry run for {file_path}:"
                else:
                    print "Applied fixes to {file_path}:"
                print "  {fixreport_applied(report)} fix(es) applied"
                for detail in fixreport_details(report):
                    print "  {detail}"
            case Err(e):
                _cli_eprint("Error applying fixes to {file_path}: {e}")
                exit_code = 1
    exit_code

fn cli_run_verify(args: [text], gc_log: bool, gc_off: bool) -> i64:
    val simple_path = _find_simple_binary()
    var child_args = ["run", "src/app/verify/main.spl"]
    val forwarded = _cli_strip_command(args, "verify")
    for arg in forwarded:
        child_args.push(arg)
    val (stdout, stderr, exit_code) = _cli_process_run(simple_path, child_args)
    if stdout.len() > 0:
        print(stdout)
    if stderr.len() > 0:
        _cli_eprint(stderr)
    exit_code


