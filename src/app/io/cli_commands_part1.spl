fn cli_run_mcp(args: [text]) -> i64:
    # Single canonical MCP entry via wrapper for fast startup and stable stdio framing.
    var cmd = "./bin/simple_mcp_server"
    var i = 1
    while i < args.len():
        cmd = cmd + " " + args[i]
        i = i + 1

    val result: _CliProcessResult = _cli_shell(cmd)
    if result.stdout.len() > 0:
        print(result.stdout)
    if result.stderr.len() > 0:
        _cli_eprint(result.stderr)
    result.exit_code

