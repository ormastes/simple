extern fn rt_signal_install(signal_num: i64) -> i64
extern fn rt_signal_check(signal_num: i64) -> i64
extern fn rt_atexit_install() -> i64
extern fn rt_atexit_check() -> i64

var _signal_handlers: [(i64, fn())] = []

fn rt_signal_handler_available() -> bool:
    true

fn rt_signal_handler_install(signal: i64, handler: fn()):
    rt_signal_install(signal)
    _signal_handlers.push((signal, handler))

fn rt_atexit_register(handler: fn()):
    rt_atexit_install()
    _signal_handlers.push((-1, handler))

fn signal_dispatch_pending():
    for entry in _signal_handlers:
        val sig = entry.0
        val cb = entry.1
        if sig >= 0 and rt_signal_check(sig) > 0:
            cb()
        elif sig == -1 and rt_atexit_check() > 0:
            cb()
