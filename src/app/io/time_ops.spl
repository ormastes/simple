# Time Functions - Pure Simple I/O
# Extracted from mod.spl for modularity

use common.time_utils.{timestamp_get_year, timestamp_get_month, timestamp_get_day, timestamp_get_hour, timestamp_get_minute, timestamp_get_second}

# Extern fn declarations (runtime resolves at file level)
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_time_now_nanos() -> i64
extern fn rt_time_now_micros() -> i64

# ============================================================================
# Time Functions
# ============================================================================

fn time_now_unix_micros() -> i64:
    rt_time_now_unix_micros()

fn current_time_unix() -> i64:
    time_now_unix_micros() / 1_000_000

fn current_time_ms() -> i64:
    time_now_unix_micros() / 1_000

fn timestamp_year(micros: i64) -> i64:
    timestamp_get_year(micros)

fn timestamp_month(micros: i64) -> i64:
    timestamp_get_month(micros)

fn timestamp_day(micros: i64) -> i64:
    timestamp_get_day(micros)

fn timestamp_hour(micros: i64) -> i64:
    timestamp_get_hour(micros)

fn timestamp_minute(micros: i64) -> i64:
    timestamp_get_minute(micros)

fn timestamp_second(micros: i64) -> i64:
    timestamp_get_second(micros)

# --- High-Resolution Time (Monotonic) ---

fn time_now_nanos() -> i64:
    """
    Get current monotonic time in nanoseconds.

    Uses CLOCK_MONOTONIC_RAW on Unix, QueryPerformanceCounter on Windows.
    Returns 0 on error. Suitable for high-precision benchmarking.
    """
    rt_time_now_nanos()

fn time_now_micros() -> i64:
    """
    Get current monotonic time in microseconds.

    Uses CLOCK_MONOTONIC_RAW on Unix, QueryPerformanceCounter on Windows.
    Returns 0 on error. Suitable for profiling and performance measurement.
    """
    rt_time_now_micros()

# --- Timestamp string helper ---

fn rt_timestamp_now() -> i64:
    time_now_unix_micros()

# --- Sleep ---

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn rt_sleep_ms(milliseconds: i64):
    val seconds = milliseconds / 1000
    val remainder = milliseconds % 1000
    if seconds > 0:
        rt_process_run("/bin/sh", ["-c", "sleep {seconds}"])
    if remainder > 0:
        rt_process_run("/bin/sh", ["-c", "sleep 0.{remainder}"])
