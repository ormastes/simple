# CLI Functions - Pure Simple I/O
# Extracted from mod.spl for modularity

use app.io.env_ops.{cwd}

# Extern fn declarations (runtime resolves at file level)

extern fn sys_get_args() -> [text]
# Call the runtime argv/exit primitives directly. Importing `get_args`/`exit`
# from std.io_runtime here collided with the local `get_args`/`exit` wrappers
# below: the wrapper bodies bound the call to themselves, not the import, so they
# recursed infinitely (Stage 4 SIGSEGV at startup —
# bootstrap_stage4_get_args_infinite_recursion_coredump_2026-06-21).
extern fn rt_cli_get_args() -> [text]
extern fn rt_cli_arg_count() -> i64
extern fn rt_cli_arg_at(index: i64) -> text
extern fn rt_exit(code: i64)
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_cli_run_tests(args: [text], gc_log: bool, gc_off: bool) -> i64
extern fn rt_cli_run_tests_process_args(gc_log: bool, gc_off: bool) -> i64
extern fn rt_cli_handle_compile(args: [text]) -> i64
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_write_text_at(path: text, offset: i64, data: text) -> i64
extern fn rt_compile_to_llvm_ir(source_file: text, target_triple: text, bare_metal: bool) -> (text, text, i64)

# --- Shell/file helpers (local copies to avoid circular imports) ---

fn cli_env_get(key: text) -> text:
    rt_env_get(key)

fn cli_handle_compile(args: [text]) -> i64:
    rt_cli_handle_compile(args)

pub fn cli_run_tests_process_args(gc_log: bool, gc_off: bool) -> i64:
    rt_cli_run_tests_process_args(gc_log, gc_off)

fn _cli_is_windows_platform() -> bool:
    val os_env = cli_env_get("OS")
    if os_env == nil:
        false
    else:
        os_env.lower().contains("windows")

pub struct _CliProcessResult:
    stdout: text
    stderr: text
    exit_code: i64

pub fn _cli_result_stdout(r: _CliProcessResult) -> text:
    r.stdout

pub fn _cli_result_stderr(r: _CliProcessResult) -> text:
    r.stderr

pub fn _cli_result_exit_code(r: _CliProcessResult) -> i64:
    r.exit_code

pub fn _cli_shell(command: text) -> _CliProcessResult:
    val (shell_path, shell_args) = if _cli_is_windows_platform():
        ("cmd.exe", ["/c", command])
    else:
        ("/bin/sh", ["-c", command])
    val (stdout, stderr, code) = rt_process_run(shell_path, shell_args)
    _CliProcessResult(stdout: stdout, stderr: stderr, exit_code: code)

fn _cli_shell_bool(command: text) -> bool:
    val result = _cli_shell(command)
    result.exit_code == 0

fn _cli_file_exists_impl(path: text) -> bool:
    rt_file_exists(path)

# Direct runtime primitives below — no shell-out: rt_process_run drops the
# args array under the deployed binary's Cranelift JIT SFFI arg marshalling
# (seed calls.rs:2550), so every _cli_shell user silently fails under JIT.

fn _cli_file_read_impl(path: text) -> text:
    # Returns "" on failure like the old `cat` path.
    rt_file_read_text(path)

fn _cli_file_write_impl(path: text, content: text) -> bool:
    # rt_file_write_text is also mis-marshalled under the deployed JIT (4-arg
    # spec vs 2-arg C impl, seed runtime_sffi.rs:1548): delete + write-at-0.
    val deleted = rt_file_delete(path)
    if content.len() == 0:
        deleted or true
    else:
        val written = rt_file_write_text_at(path, 0, content)
        written >= 0

fn _cli_file_copy_impl(src: text, dst: text) -> bool:
    # rt_file_copy is mis-marshalled under the deployed JIT
    # (seed runtime_sffi.rs:1557): stage via read + delete + write-at-0.
    if not rt_file_exists(src):
        false
    else:
        val content = rt_file_read_text(src)
        val deleted = rt_file_delete(dst)
        if content.len() == 0:
            deleted or true
        else:
            val written = rt_file_write_text_at(dst, 0, content)
            written >= 0

fn _cli_dir_create_impl(path: text, recursive: bool) -> bool:
    # mkdir -p semantics for both branches via rt_mkdir_p; rt_file_exists
    # fallback accepts a pre-existing directory (verified working under the
    # deployed JIT while the mkdir shell-out reports failure).
    rt_mkdir_p(path) or rt_file_exists(path)

fn _cli_eprint(msg: text):
    eprint(msg)

pub fn _cli_resolve_argv0(cwd_path: text, argv0: text) -> text:
    val drive_absolute = argv0.len() >= 3 and (argv0.substring(1, 3) == ":/" or argv0.substring(1, 3) == ":\\")
    val unc_absolute = argv0.starts_with("//") or argv0.starts_with("\\\\")
    if argv0.starts_with("/") or drive_absolute or unc_absolute:
        return argv0
    if ((argv0.last_index_of("/") ?? -1) >= 0 or (argv0.last_index_of("\\") ?? -1) >= 0) and cwd_path.len() > 0:
        return cwd_path + "/" + argv0
    ""

fn _cli_find_on_path(argv0: text) -> text:
    val command = if _cli_is_windows_platform(): "where" else: "which"
    val found = rt_process_run(command, [argv0])
    if found.2 != 0:
        return ""
    found.0.split("\n")[0].trim()

fn _cli_current_exe_path() -> text:
    if rt_cli_arg_count() > 0:
        val argv0 = rt_cli_arg_at(0)
        var resolved = _cli_resolve_argv0(cwd(), argv0)
        if resolved == "":
            resolved = _cli_find_on_path(argv0)
        return resolved
    ""

pub fn cli_current_exe_path() -> text:
    _cli_current_exe_path()

fn _cli_seed_sibling_path(exe_path: text) -> text:
    val slash = exe_path.last_index_of("/") ?? -1
    if slash < 0:
        return ""
    exe_path.substring(0, slash + 1) + "simple_seed"

fn _cli_is_current_exe(path: text) -> bool:
    if path == "" or _cli_is_windows_platform():
        return false
    val current = _cli_current_exe_path()
    if current.len() == 0:
        # If identity cannot be established, delegation is unsafe: the
        # candidate may be this process and recurse without bound.
        return true
    var resolved = _cli_resolve_argv0(cwd(), path)
    if resolved == "":
        resolved = path
    current == resolved or current == path or current.ends_with("/" + path) or path.ends_with("/" + current)

pub fn _cli_process_run(cmd: text, args: [text]) -> (text, text, i64):
    var resolved_cmd = cmd
    if _cli_is_windows_platform():
        if not cmd.ends_with(".exe") and not cmd.ends_with(".cmd") and not cmd.ends_with(".bat"):
            val check = rt_process_run("where", [cmd + ".exe"])
            if check.2 == 0:
                resolved_cmd = cmd + ".exe"
    else:
        if not cmd.contains("/"):
            val check = rt_process_run("which", [cmd])
            if check.2 == 0 and check.0.trim().len() > 0:
                resolved_cmd = check.0.trim()
    rt_process_run(resolved_cmd, args)

pub fn _cli_run_workspace_root_guard() -> i64:
    val (stdout, stderr, code) = _cli_process_run("sh", ["scripts/check-workspace-root-guard.shs", "audit", "--staged"])
    if stdout.len() > 0:
        print(stdout)
    if stderr.len() > 0:
        _cli_eprint(stderr)
    code

pub fn _cli_driver_binary() -> text:
    val override = cli_env_get("SIMPLE_BOOTSTRAP_DRIVER") ?? ""
    if override.len() > 0:
        # Self-exec guard: an inherited override that points at THIS binary
        # would delegate to ourselves recursively without bound (simple.bak
        # fork bomb OOM-killed the user session, 2026-06-12).
        if _cli_is_current_exe(override):
            return ""
        return override

    # Sibling seed staged next to our own executable (post-deploy layout:
    # bin/release/<triple>/simple is the self-hosted CLI, simple_seed is the
    # Rust seed it delegates to). Absolute path, so this works from any cwd.
    if not _cli_is_windows_platform():
        val exe_path = _cli_current_exe_path()
        if exe_path.len() > 0:
            val seed_sibling = _cli_seed_sibling_path(exe_path)
            if _cli_file_exists_impl(seed_sibling):
                if not _cli_is_current_exe(seed_sibling):
                    return seed_sibling
            else:
                _cli_eprint("simple: seed sibling not found, skipping delegation: {seed_sibling}")

    val ext = if _cli_is_windows_platform(): ".exe" else: ""
    val candidate = "bin/simple{ext}"
    if not _cli_file_exists_impl(candidate):
        return ""
    # Self-exec guard: when this process IS bin/simple (e.g. the stage4 full
    # CLI deployed as the release binary), delegating to the driver spawns
    # ourselves recursively without bound (fork bomb, 2026-06-10). Return ""
    # so callers take their in-process fallback instead.
    if _cli_is_current_exe(candidate):
        return ""
    candidate

pub fn _cli_frontend_delegate_binary() -> text:
    # Loop guard: if we ARE the delegate child, return "" to avoid re-delegating.
    val loop_flag = cli_env_get("SIMPLE_FRONTEND_DELEGATED") ?? ""
    if loop_flag.len() == 1 and loop_flag.starts_with("1"):
        return ""

    # Env override: explicit delegate path.
    val override = cli_env_get("SIMPLE_FRONTEND_DELEGATE") ?? ""
    if override.len() > 0:
        if _cli_file_exists_impl(override):
            if _cli_is_windows_platform() or not _cli_is_current_exe(override):
                return override
        return ""

    # Fall back to _cli_driver_binary() — already self-exec-guarded.
    val driver = _cli_driver_binary()
    if driver.len() > 0:
        return driver

    # Sibling seed: look for simple_seed next to our own executable.
    if not _cli_is_windows_platform():
        val exe_path = _cli_current_exe_path()
        if exe_path.len() > 0:
            val seed_candidate = _cli_seed_sibling_path(exe_path)
            if _cli_file_exists_impl(seed_candidate):
                if not _cli_is_current_exe(seed_candidate):
                    return seed_candidate

    ""

pub fn _cli_run_frontend_delegate(delegate: text, args: [text]) -> i64:
    # Set loop guard so the delegate child does not re-delegate.
    rt_env_set("SIMPLE_FRONTEND_DELEGATED", "1")
    val result = _cli_process_run(delegate, args)
    if result.0.len() > 0:
        print_raw(result.0)
    if result.1.len() > 0:
        _cli_eprint(result.1)
    result.2


# ============================================================================
# CLI Core Functions
# ============================================================================

fn get_args() -> [text]:
    val raw_args = rt_cli_get_args() ?? []
    if raw_args.len() > 0:
        return raw_args

    val sys_args = sys_get_args() ?? []
    if sys_args.len() > 0:
        return sys_args

    []

fn exit(code: i64):
    rt_exit(code)

fn cli_get_args() -> [text]:
    val raw_args = rt_cli_get_args()
    if raw_args != nil and raw_args.len() > 0:
        return raw_args

    val sys_args = sys_get_args()
    if sys_args != nil and sys_args.len() > 0:
        return sys_args

    []

fn cli_exit(code: i64):
    rt_exit(code)

fn env_set(key: text, value: text) -> bool:
    rt_env_set(key, value)

fn cli_file_exists(path: text) -> bool:
    _cli_file_exists_impl(path)

fn cli_read_file(path: text) -> text:
    _cli_file_read_impl(path)

