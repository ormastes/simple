# Shared I/O module for CLI apps.
# Hosted operations delegate to the no-GC sync backend owners instead of
# preserving local false/empty stubs.

use std.nogc_sync_mut.io.file_ops.{
    file_exists as backend_file_exists,
    file_read as backend_file_read,
    file_write as backend_file_write,
    file_copy as backend_file_copy,
    file_delete as backend_file_delete,
    file_atomic_write as backend_file_atomic_write,
    file_append as backend_file_append,
    file_modified_time as backend_file_modified_time,
    file_remove as backend_file_remove,
    file_hash_sha256 as backend_file_hash_sha256,
    file_size as backend_file_size
}
use std.nogc_sync_mut.io.dir_ops.{
    dir_create as backend_dir_create,
    dir_create_all as backend_dir_create_all,
    dir_walk as backend_dir_walk,
    dir_remove_all as backend_dir_remove_all,
    is_dir as backend_is_dir
}
use std.nogc_sync_mut.io.env_ops.{
    cwd as backend_cwd,
    home as backend_home,
    env_get as backend_env_get
}
use std.nogc_sync_mut.io.process_ops.{
    process_run as backend_process_run,
    process_run_timeout as backend_process_run_timeout,
    process_output as backend_process_output
}

# --- File operations (STUBS - not available without Rust runtime) ---

fn file_exists(path: text) -> bool:
    backend_file_exists(path)

fn file_read(path: text) -> text:
    backend_file_read(path)

# reason: positional io mod_stub API
fn file_write(path: text, content: text) -> bool:
    backend_file_write(path, content)

# reason: positional io mod_stub API
fn file_copy(src: text, dst: text) -> bool:
    backend_file_copy(src, dst)

fn file_delete(path: text) -> bool:
    backend_file_delete(path)

# reason: positional io mod_stub API
fn file_atomic_write(path: text, content: text) -> bool:
    backend_file_atomic_write(path, content)

# --- Directory operations (STUBS) ---

fn dir_create(path: text, recursive: bool) -> bool:
    backend_dir_create(path, recursive)

fn dir_create_all(path: text) -> bool:
    backend_dir_create_all(path)

fn dir_walk(path: text) -> [text]:
    backend_dir_walk(path)

fn dir_remove_all(path: text) -> i64:
    backend_dir_remove_all(path) as i64

fn is_dir(path: text) -> bool:
    backend_is_dir(path)

# --- Environment operations (STUBS) ---

fn cwd() -> text:
    backend_cwd()

fn home() -> text:
    backend_home()

fn env_get(key: text) -> text:
    backend_env_get(key)

# --- Process execution (STUBS) ---

fn process_run(cmd: text, args: [text]) -> (text, text, i64):
    backend_process_run(cmd, args)

fn process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    backend_process_run_timeout(cmd, args, timeout_ms)

