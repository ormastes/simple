# Shared closed option validation for both pure-Simple fmt CLI owners.

pub fn fmt_option_error(args: [text]) -> text:
    var help_count = 0
    var other_count = 0
    for arg in args:
        if arg == "fmt":
            continue
        if arg == "--help" or arg == "-h":
            help_count = help_count + 1
            continue
        other_count = other_count + 1
        if arg == "--check" or arg == "--write" or arg == "--diff":
            continue
        if arg.starts_with("-"):
            return "unknown option: {arg}"
    if help_count > 0 and (help_count != 1 or other_count > 0):
        return "help cannot be combined with files or other options"
    ""
