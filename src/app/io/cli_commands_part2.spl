fn cli_handle_linkers() -> i64:
    # Detect available linkers on the system
    print "Available native linkers:"
    print ""
    # Check mold
    val mold_result = _cli_shell("which mold 2>/dev/null")
    if _cli_result_exit_code(mold_result) == 0:
        print "  mold      Modern linker (fastest, recommended)  [installed]"
    else:
        print "  mold      Modern linker (fastest, recommended)  [not found]"
    # Check lld
    val lld_result = _cli_shell("which lld 2>/dev/null || which ld.lld 2>/dev/null")
    if _cli_result_exit_code(lld_result) == 0:
        print "  lld       LLVM linker (fast, widely available)  [installed]"
    else:
        print "  lld       LLVM linker (fast, widely available)  [not found]"
    # Check ld
    val ld_result = _cli_shell("which ld 2>/dev/null")
    if _cli_result_exit_code(ld_result) == 0:
        print "  ld        GNU linker (default, always available)  [installed]"
    else:
        print "  ld        GNU linker (default)  [not found]"
    print ""
    print "Auto-detection preference: mold > lld > ld"
    print ""
    print "Usage:"
    print "  simple compile app.spl --linker mold"
    0

