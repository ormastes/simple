# Native build: compile entire project to native binary
# Supports --backend=llvm-lib for pure Simple LLVM compilation (Stage 3 bootstrap),
# otherwise delegates to Rust NativeProjectBuilder SFFI.
fn _nb_dirname(path: text) -> text:
    val parts = path.split("/")
    if parts.len() <= 1:
        return ""
    var out = ""
    var i = 0
    while i < parts.len() - 1:
        if i > 0:
            out = out + "/"
        out = out + parts[i]
        i = i + 1
    out

fn _nb_resolve_relative(mp: text, importer_file: text) -> text:
    # `.sibling` / `..parent_pkg.mod` resolve against the importing FILE's
    # directory, mirroring the driver's _driver_resolve_relative_entry_import.
    # The dotted-segment resolver below cannot express these (leading dots
    # split to empty segments), which silently dropped sibling modules from
    # the --entry-closure worker input set ("unresolved name" storms in HIR).
    var dots = 0
    while dots < mp.len() and mp.substring(dots, dots + 1) == ".":
        dots = dots + 1
    if dots >= mp.len():
        return ""
    var base_dir = _nb_dirname(importer_file)
    var up = 1
    while up < dots and base_dir != "":
        base_dir = _nb_dirname(base_dir)
        up = up + 1
    val rel = mp.substring(dots).replace(".", "/")
    val base = if base_dir == "": rel else: "{base_dir}/{rel}"
    if rt_file_exists("{base}.spl"):
        return "{base}.spl"
    if rt_file_exists("{base}/mod.spl"):
        return "{base}/mod.spl"
    if rt_file_exists("{base}/__init__.spl"):
        return "{base}/__init__.spl"
    ""

fn _nb_basename(path: text) -> text:
    val parts = path.split("/")
    if parts.len() == 0:
        return path
    parts[parts.len() - 1]

fn _nb_trim_trailing_slashes(path: text) -> text:
    var p = path
    while p.len() > 1 and p.ends_with("/"):
        p = p.substring(0, p.len() - 1)
    p

fn _nb_source_dirs_cover_workspace(source_dirs: [text]) -> bool:
    source_dirs.contains("src/app") and source_dirs.contains("src/lib") and source_dirs.contains("src/compiler")

fn _nb_normalize_source_dirs(source_dirs: [text]) -> [text]:
    # Drop duplicate roots and redundant bare `src` when explicit workspace
    # roots already cover app, lib, and compiler imports.
    var normalized: [text] = []
    for raw_dir in source_dirs:
        val dir = _nb_trim_trailing_slashes(raw_dir)
        if dir == "" or normalized.contains(dir):
            continue
        normalized = normalized.push(dir)
    var result: [text] = []
    val workspace_covered = _nb_source_dirs_cover_workspace(normalized)
    for candidate in normalized:
        if workspace_covered and candidate == "src":
            continue
        result = result.push(candidate)
    result

fn _nb_module_path_from_use(line_in: text) -> text:
    # Dotted module path of a single-line use/import statement, else "".
    val line = line_in.trim()
    var rest = ""
    if line.starts_with("use lazy "):
        rest = line.substring(9)
    elif line.starts_with("export use "):
        rest = line.substring(11)
    elif line.starts_with("use "):
        rest = line.substring(4)
    elif line.starts_with("import "):
        rest = line.substring(7)
    else:
        return ""
    rest = rest.trim()
    # Truncate at the first token-ending delimiter ({, (, *, space, comment).
    # index_of is a single native scan per delimiter (O(len)); the previous
    # char-by-char `rest.substring(ri, ri + 1)` loop re-walked the whole
    # string from scratch on every single-character slice (the interpreter's
    # substring/slice builtin always does a full `chars().collect()` unless
    # the range is the entire string), making this O(len^2) per line.
    var cut = rest.len()
    for delim in [" ", "{", "(", "*", "#"]:
        val idx = rest.index_of(delim)
        if idx >= 0 and idx < cut:
            cut = idx
    var path_text = rest[0:cut]
    # Strip a trailing '.' left by `a.b.c.{...}` / `a.b.c.*`.
    while path_text.ends_with("."):
        path_text = path_text[0:path_text.len() - 1]
    path_text.trim()

fn _nb_resolve_under_root(root: text, segs: [text]) -> text:
    if segs.len() == 0:
        return ""
    val rel = _nb_join_segments(segs)
    val p1 = "{root}/{rel}.spl"
    if rt_file_exists(p1):
        return p1
    val p2 = "{root}/{rel}/mod.spl"
    if rt_file_exists(p2):
        return p2
    val p3 = "{root}/{rel}/__init__.spl"
    if rt_file_exists(p3):
        return p3
    ""

fn _nb_resolve_segs(segs: [text], source_dirs: [text]) -> text:
    # Resolve a module segment list to an .spl file under a --source root.
    # Mirrors the Rust discovery FS-fallback: strip a leading segment matching
    # the root's dir name. Returns "" if unresolved.
    for root in source_dirs:
        val dir_name = _nb_basename(root)
        val public_lib_alias = dir_name == "lib" and segs.len() > 0 and segs[0] == "std"
        if segs.len() > 0 and (segs[0] == dir_name or public_lib_alias):
            var stripped: [text] = []
            var si = 1
            while si < segs.len():
                stripped = stripped.push(segs[si])
                si = si + 1
            val stripped_path = _nb_resolve_under_root(root, stripped)
            if stripped_path != "":
                return stripped_path
        val direct_path = _nb_resolve_under_root(root, segs)
        if direct_path != "":
            return direct_path
    if segs.len() > 0 and not _nb_source_dirs_cover_workspace(source_dirs):
        val src_path = _nb_resolve_under_root("src", segs)
        if src_path != "":
            return src_path
    ""

fn _nb_join_segments(segs: [text]) -> text:
    var result = ""
    var i = 0
    while i < segs.len():
        if i > 0:
            result = result + "/"
        result = result + segs[i]
        i = i + 1
    result

fn _nb_text_bucket_index(key: text, bucket_count: i64) -> i64:
    val raw = rt_hash_text(key) % bucket_count
    if raw < 0:
        raw + bucket_count
    else:
        raw

fn _nb_text_cache_get(buckets: [text], key: text) -> (bool, text):
    if buckets.len() == 0:
        return (false, "")
    val prefix = key + "\t"
    val bucket = buckets[_nb_text_bucket_index(key, buckets.len())]
    for entry in bucket.split("\n"):
        if entry.starts_with(prefix):
            return (true, entry.substring(prefix.len()))
    (false, "")

fn _nb_text_cache_add(buckets: [text], key: text, value: text) -> [text]:
    if buckets.len() == 0:
        return buckets
    val (present, _) = _nb_text_cache_get(buckets, key)
    if present:
        return buckets
    val index = _nb_text_bucket_index(key, buckets.len())
    var updated = buckets
    updated[index] = updated[index] + key + "\t" + value + "\n"
    updated

fn _native_build_entry_closure(entry: text, source_dirs: [text]) -> [text]:
    # BFS the entry's import closure so --entry-closure compiles only reachable
    # modules (one `main`), not every file in the --source dirs. Over-approximates
    # safely: an unresolved `use` is skipped; a genuinely missing import still
    # errors in the compile phase.
    val trace_closure = (rt_env_get("SIMPLE_NATIVE_BUILD_TRACE_CLOSURE") ?? "") == "1"
    var queue: [text] = [entry]
    # ponytail: 256 buckets bound interpreter COW copies; use a mutable set when
    # interpreted collection inserts can update uniquely in place.
    var discovered = _driver_text_bucket_set_new(256)
    discovered = _driver_text_bucket_set_add(discovered, entry)
    var result: [text] = []
    var resolve_cache = _driver_text_bucket_set_new(256)
    val closure_source_dirs = _nb_normalize_source_dirs(source_dirs)
    var qi = 0
    while qi < queue.len():
        val f = queue[qi]
        qi = qi + 1
        result = result.push(f)
        if not rt_file_exists(f):
            if trace_closure and f == entry:
                _cli_eprint("[native-build] closure entry missing {f}")
            continue
        val content = rt_file_read_text(f) ?? ""
        if trace_closure and f == entry:
            _cli_eprint("[native-build] closure entry read len={content.len()}")
        if trace_closure and result.len() % 25 == 0:
            _cli_eprint("[native-build] closure visited {result.len()} queued={queue.len()} file={f}")
        # ROOT-CAUSE FIX (compute-spin hang): split("\n") is a single native
        # O(len) pass. The former manual scan called content.substring(pos, pos+1)
        # once per character to find newlines -- the interpreter's substring/slice
        # builtin always rebuilds a Vec<char> of the WHOLE string per call (unless
        # the requested range is the entire string), so that was O(len) work per
        # character, i.e. O(len^2) per file. On the compiler's own multi-hundred-
        # module import graph this pathologically stalled --entry-closure builds
        # (doc/08_tracking/bug/native_build_entry_closure_quadratic_hang_2026-07-12.md).
        for raw in content.split("\n"):
            val import_line = raw.trim()
            # `mod pkg.member` package-member decls and `export member.*`
            # package re-exports both name SIBLING files that must join the
            # closure (the flat parser lowers `mod` as a sibling import; the
            # HIR sibling-glob pass needs the file present to register it).
            if import_line.starts_with("mod "):
                val mod_tail = import_line.substring(4).trim()
                val mod_segs_bfs = mod_tail.split(".")
                if mod_segs_bfs.len() > 0:
                    val mod_last = mod_segs_bfs[mod_segs_bfs.len() - 1]
                    if mod_last != "":
                        val mod_rp = _nb_resolve_relative("." + mod_last, f)
                        if mod_rp != "" and not _driver_text_bucket_set_has(discovered, mod_rp):
                            queue = queue.push(mod_rp)
                            discovered = _driver_text_bucket_set_add(discovered, mod_rp)
                continue
            if import_line.starts_with("export ") and import_line.ends_with(".*") and not import_line.starts_with("export use "):
                val exp_tail = import_line.substring(7).trim()
                val exp_base = exp_tail[0:exp_tail.len() - 2]
                if not exp_base.contains(" ") and not exp_base.contains(","):
                    val exp_rp = _nb_resolve_relative("." + exp_base, f)
                    if exp_rp != "" and not _driver_text_bucket_set_has(discovered, exp_rp):
                        queue = queue.push(exp_rp)
                        discovered = _driver_text_bucket_set_add(discovered, exp_rp)
                continue
            val mp = _nb_module_path_from_use(import_line)
            if mp == "":
                continue
            if mp.starts_with("."):
                val rel_rp = _nb_resolve_relative(mp, f)
                if rel_rp != "" and not _driver_text_bucket_set_has(discovered, rel_rp):
                    queue = queue.push(rel_rp)
                    discovered = _driver_text_bucket_set_add(discovered, rel_rp)
                continue
            val segs = mp.split(".")
            val seg_key = _nb_join_segments(segs)
            var rp = ""
            val (cached, cached_value) = _nb_text_cache_get(resolve_cache, seg_key)
            if cached:
                rp = cached_value
            else:
                rp = _nb_resolve_segs(segs, closure_source_dirs)
                resolve_cache = _nb_text_cache_add(resolve_cache, seg_key, rp)
            if trace_closure and f == entry:
                _cli_eprint("[native-build] closure import {mp} -> {rp}")
            if rp != "" and not _driver_text_bucket_set_has(discovered, rp):
                queue = queue.push(rp)
                discovered = _driver_text_bucket_set_add(discovered, rp)
            if rp == "" and segs.len() > 1 and not raw.contains("{"):
                var drop: [text] = []
                var di = 0
                while di < segs.len() - 1:
                    drop = drop.push(segs[di])
                    di = di + 1
                val drop_key = _nb_join_segments(drop)
                var drop_rp = ""
                val (drop_cached, drop_cached_value) = _nb_text_cache_get(resolve_cache, drop_key)
                if drop_cached:
                    drop_rp = drop_cached_value
                else:
                    drop_rp = _nb_resolve_segs(drop, closure_source_dirs)
                    resolve_cache = _nb_text_cache_add(resolve_cache, drop_key, drop_rp)
                if drop_rp != "" and not _driver_text_bucket_set_has(discovered, drop_rp):
                    queue = queue.push(drop_rp)
                    discovered = _driver_text_bucket_set_add(discovered, drop_rp)
    result

fn cli_native_build(args: [text]) -> i64:
    # Check for --backend=llvm-lib flag to use pure Simple LLVM pipeline
    var backend = ""
    var backend_explicit = false
    var runtime_bundle = "auto"
    var runtime_bundle_explicit = false
    var log_mode = "on"
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--help" or arg == "-h":
            print "Simple Native Build"
            print ""
            print "Usage: simple native-build [options] [source-dirs...]"
            print ""
            print "Options:"
            print "  --source <dir>       Source directory to compile (repeatable)"
            print "  -o <path>            Output binary path"
            print "  --entry <file>       Entry file"
            print "  --backend <name>     Codegen backend: llvm-lib, llvm, cranelift"
            print "  --mode <name>        Build mode: dynload (default) or one-binary"
            print "  --cache-dir <dir>    Native cache directory (default: build/native_cache)"
            print "  --release            Release build (standard optimization profile)"
            print "  --release-optimized  Max optimization: -O3 + x86-64-v3 + ThinLTO"
            cli_print_shared_opt_level_help()
            print "  --list-optimizations Print implemented optimization groups and levels"
            print "  --strip              Strip symbols from output"
            print "  --emit-object        Emit relocatable object output instead of linking executable"
            print "  --runtime-bundle <mode> Runtime lane: auto, simple-core, core-c-bootstrap"
            print "  --cpu <policy>       CPU policy: default, native, or x86-64-v1..v4"
            print "  --entry-closure      Compile only modules reachable from --entry"
            print "  --threads <n>        Native build workers"
            print "  --jobs <n>, -j <n>   Alias for --threads"
            print "  --log <on|off>       Compile normal SimpleOS logging in or out"
            print "  --no-borrow-check    Skip the borrow-check pass (diagnostic; default runs it)"
            print "  --verbose, -v        Verbose output"
            return 0
        elif arg == "--list-optimizations":
            cli_print_shared_optimization_inventory("native-build")
            return 0
        if arg.starts_with("--backend="):
            backend = arg.substring(10)
            backend_explicit = true
        elif arg == "--backend" and i + 1 < args.len():
            i = i + 1
            backend = args[i]
            backend_explicit = true
        elif arg == "--runtime-bundle" and i + 1 < args.len():
            var bundle = args[i + 1]
            if cli_runtime_bundle_is_rust_or_hosted(bundle):
                _cli_eprint("Error: runtime bundle '{bundle}' was removed; use simple-core or core-c-bootstrap")
                return 1
            if bundle == "simple_core":
                bundle = "simple-core"
            elif bundle == "core_c_bootstrap":
                bundle = "core-c-bootstrap"
            runtime_bundle = bundle
            runtime_bundle_explicit = true
            i = i + 1
        elif arg.starts_with("--runtime-bundle="):
            var bundle = arg.substring(17)
            if cli_runtime_bundle_is_rust_or_hosted(bundle):
                _cli_eprint("Error: runtime bundle '{bundle}' was removed; use simple-core or core-c-bootstrap")
                return 1
            if bundle == "simple_core":
                bundle = "simple-core"
            elif bundle == "core_c_bootstrap":
                bundle = "core-c-bootstrap"
            runtime_bundle = bundle
            runtime_bundle_explicit = true
        elif arg.starts_with("--log="):
            val mode = arg.substring(6)
            if mode == "":
                _cli_eprint("Error: --log requires a value ('on' or 'off')")
                return 1
            if mode != "on" and mode != "off":
                _cli_eprint("Error: invalid --log value '{mode}' (expected 'on' or 'off')")
                return 1
            log_mode = mode
        elif arg == "--log":
            if i + 1 >= args.len():
                _cli_eprint("Error: --log requires a value ('on' or 'off')")
                return 1
            i = i + 1
            val mode = args[i]
            if mode.starts_with("-"):
                _cli_eprint("Error: --log requires a value ('on' or 'off')")
                return 1
            if mode != "on" and mode != "off":
                _cli_eprint("Error: invalid --log value '{mode}' (expected 'on' or 'off')")
                return 1
            log_mode = mode
        elif arg.starts_with("--log"):
            _cli_eprint("Error: invalid log option '{arg}' (expected --log or --log=<on|off>)")
            return 1
        i = i + 1

    if not backend_explicit:
        backend = "llvm"
        backend_explicit = true

    if backend_explicit and (backend == "llvm-lib" or backend == "llvmlib" or backend == "llvm" or backend == "cranelift"):
        # Pure Simple path: use CompilerDriver with LLVM lib backend
        # Parse native-build args: --source, --entry, -o, --strip, --no-mangle, etc.
        var entry_point = ""
        var output = "a.out"
        var verbose = false
        var strip = false
        var emit_smf = false
        var emit_object = false
        var source_dirs: [text] = []
        var entry_closure = false
        var release = true
        var opt_level = cli_native_default_opt_level()
        var native_target = ""
        var native_cpu = ""
        var build_mode = "dynload"
        var cache_dir = "build/native_cache"
        var native_threads = 0
        var optimization_requested = false
        var no_borrow_check = false
        var j = 0
        # Skip "native-build" command name
        if args.len() > 0 and args[0] == "native-build":
            j = 1
        while j < args.len():
            val a = args[j]
            if a == "--entry-closure":
                # Compile only modules reachable from --entry (suppresses the
                # driver's implicit whole-src bulk-load). Must be matched BEFORE
                # the `--entry` prefix check below, or it is mis-read as `--entry`
                # and eats the next token as the entry path.
                entry_closure = true
            elif cli_native_build_is_entry_arg(a):
                if a.contains("="):
                    val eq_idx = a.index_of("=")
                    match eq_idx:
                        Some(idx):
                            entry_point = a.substring(idx + 1)
                        nil:
                            _cli_eprint("Error: --entry requires an argument")
                            return 1
                elif j + 1 < args.len():
                    j = j + 1
                    entry_point = args[j]
            elif a == "--source":
                if j + 1 < args.len():
                    j = j + 1
                    source_dirs = source_dirs.push(args[j])
            elif a.starts_with("--source="):
                source_dirs = source_dirs.push(a.substring(9))
            elif a == "-o":
                if j + 1 < args.len():
                    j = j + 1
                    output = args[j]
            elif a.starts_with("-o"):
                output = a.substring(2)
            elif a == "--output":
                if j + 1 < args.len():
                    j = j + 1
                    output = args[j]
            elif a.starts_with("--output="):
                output = a.substring(9)
            elif a == "--verbose" or a == "-v":
                verbose = true
            elif a == "--strip":
                strip = true
            elif a == "--emit-smf":
                emit_smf = true
            elif a == "--emit-object":
                emit_object = true
            elif a == "--threads" or a == "--jobs" or a == "-j":
                if j + 1 >= args.len():
                    _cli_eprint("Error: {a} requires a positive integer")
                    return 1
                j = j + 1
                native_threads = args[j].to_i64() ?? 0
                if native_threads <= 0:
                    _cli_eprint("Error: {a} requires a positive integer")
                    return 1
            elif a.starts_with("--threads="):
                native_threads = a.substring(10).to_i64() ?? 0
                if native_threads <= 0:
                    _cli_eprint("Error: --threads requires a positive integer")
                    return 1
            elif a.starts_with("--jobs="):
                native_threads = a.substring(7).to_i64() ?? 0
                if native_threads <= 0:
                    _cli_eprint("Error: --jobs requires a positive integer")
                    return 1
            elif a == "--mode" or a == "--build-mode":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --mode requires dynload or one-binary")
                    return 1
                j = j + 1
                build_mode = args[j]
            elif a.starts_with("--mode="):
                build_mode = a.substring(7)
                if build_mode == "":
                    build_mode = "dynload"
            elif a.starts_with("--build-mode="):
                build_mode = a.substring(13)
                if build_mode == "":
                    build_mode = "dynload"
            elif a == "--cache-dir":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --cache-dir requires a path")
                    return 1
                j = j + 1
                cache_dir = args[j]
            elif a.starts_with("--cache-dir="):
                cache_dir = a.substring(12)
                if cache_dir == "":
                    cache_dir = "build/native_cache"
            elif a.starts_with("--target="):
                native_target = a.substring(9)
            elif a == "--target":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --target requires an argument")
                    return 1
                j = j + 1
                native_target = args[j]
            elif a.starts_with("--cpu="):
                native_cpu = a.substring(6)
            elif a == "--cpu":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --cpu requires an argument")
                    return 1
                j = j + 1
                native_cpu = args[j]
            elif a == "--release":
                release = true
                if opt_level < 2:
                    opt_level = 2
                optimization_requested = true
            elif a == "--release-optimized":
                release = true
                opt_level = cli_native_default_opt_level()
                optimization_requested = true
            elif a.starts_with("--opt-level="):
                val opt_text = a.substring(12)
                val parsed_level = cli_parse_opt_level(opt_text)
                if parsed_level.is_none():
                    _cli_eprint("Error: invalid --opt-level value '{opt_text}'")
                    return 1
                match parsed_level:
                    Some(level):
                        opt_level = level
                    nil:
                        _cli_eprint("Error: invalid --opt-level value '{opt_text}'")
                        return 1
                release = opt_level > 0
                optimization_requested = true
            elif a == "--opt-level":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --opt-level requires an argument")
                    return 1
                j = j + 1
                val opt_text = args[j]
                val parsed_level = cli_parse_opt_level(opt_text)
                if parsed_level.is_none():
                    _cli_eprint("Error: invalid --opt-level value '{opt_text}'")
                    return 1
                match parsed_level:
                    Some(level):
                        opt_level = level
                    nil:
                        _cli_eprint("Error: invalid --opt-level value '{opt_text}'")
                        return 1
                release = opt_level > 0
                optimization_requested = true
            elif a == "--no-borrow-check":
                no_borrow_check = true
            elif a == "--no-mangle":
                pass  # Accepted but not used in llvm-lib path
            elif a == "--clean":
                # Ask the driver to wipe this build's cache scope before
                # compiling. The driver consumes (clears) the flag, so it
                # applies to this build only.
                env_set("SIMPLE_NATIVE_BUILD_CLEAN", "1")
            elif a.starts_with("--backend=") or a == "--backend":
                if a == "--backend" and j + 1 < args.len():
                    j = j + 1
                # Already handled above
            elif a.starts_with("--log="):
                val mode = a.substring(6)
                if mode == "":
                    _cli_eprint("Error: --log requires a value ('on' or 'off')")
                    return 1
                if mode != "on" and mode != "off":
                    _cli_eprint("Error: invalid --log value '{mode}' (expected 'on' or 'off')")
                    return 1
            elif a == "--log":
                if j + 1 >= args.len():
                    _cli_eprint("Error: --log requires a value ('on' or 'off')")
                    return 1
                j = j + 1
                val mode = args[j]
                if mode.starts_with("-"):
                    _cli_eprint("Error: --log requires a value ('on' or 'off')")
                    return 1
                if mode != "on" and mode != "off":
                    _cli_eprint("Error: invalid --log value '{mode}' (expected 'on' or 'off')")
                    return 1
            elif a.starts_with("--log"):
                _cli_eprint("Error: invalid log option '{a}' (expected --log or --log=<on|off>)")
                return 1
            elif not a.starts_with("-") and entry_point == "":
                entry_point = a
            j = j + 1

        if build_mode != "dynload" and build_mode != "one-binary":
            _cli_eprint("Error: invalid --mode '{build_mode}' (expected dynload or one-binary)")
            return 1

        if entry_point == "":
            _cli_eprint("Error: No entry point specified for native-build backend")
            _cli_eprint("Usage: simple native-build --backend=llvm --entry <file.spl> -o <output> [--source <dir>]...")
            return 1

        # Build into a private sibling first. A stale requested output must not
        # satisfy the success check when a driver/linker reports Success without
        # writing its artifact; conversely, a failed build must leave the last
        # known-good requested output untouched.
        val staged_output = "{output}.simple-native-build-{getpid()}-{time_now_unix_micros()}.tmp"
        if _cli_file_exists_impl(staged_output) and not _cli_file_remove_impl(staged_output):
            _cli_eprint("Error: could not clear stale native-build staging output {staged_output}")
            return 1

        if verbose:
            _cli_eprint("[native-build] Using pure Simple native backend {backend}")
            _cli_eprint("[native-build] Entry: {entry_point}, Output: {output}")
            if source_dirs.len() > 0:
                _cli_eprint("[native-build] Source dirs: {source_dirs}")
        val old_log_mode = env_get("SIMPLE_OS_LOG_MODE") ?? ""
        val old_emit_object = env_get("SIMPLE_NATIVE_BUILD_EMIT_OBJECT") ?? ""
        val old_native_arena_decls = env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        val old_native_threads = env_get("SIMPLE_NATIVE_BUILD_THREADS") ?? ""
        val old_native_cache_dir = env_get("SIMPLE_NATIVE_BUILD_CACHE_DIR") ?? ""
        val old_native_entry = env_get("SIMPLE_NATIVE_BUILD_ENTRY") ?? ""
        val old_native_entry_closure = env_get("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE") ?? ""
        val old_native_target = env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? ""
        val old_native_cpu = env_get("SIMPLE_NATIVE_CPU") ?? ""
        val old_native_runtime_bundle = env_get("SIMPLE_NATIVE_RUNTIME_BUNDLE") ?? ""
        val set_native_target = native_target != ""
        val set_native_cpu = native_cpu != ""
        if not env_set("SIMPLE_OS_LOG_MODE", log_mode):
            _cli_eprint("Error: could not export SIMPLE_OS_LOG_MODE={log_mode}")
            return 1
        if not _cli_dir_create_impl(cache_dir, true):
            env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
            _cli_eprint("Error: could not create native-build cache directory {cache_dir}")
            return 1
        env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", if emit_object: "1" else: "")
        if not env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", cache_dir):
            env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
            env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
            _cli_eprint("Error: could not export SIMPLE_NATIVE_BUILD_CACHE_DIR={cache_dir}")
            return 1
        if native_threads > 0:
            env_set("SIMPLE_NATIVE_BUILD_THREADS", "{native_threads}")
        env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")
        if not env_set("SIMPLE_NATIVE_BUILD_ENTRY", entry_point):
            env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
            env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
            env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
            env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
            env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
            env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
            if set_native_target:
                env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
            if set_native_cpu:
                env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
            if native_threads > 0:
                env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
            _cli_eprint("Error: could not export SIMPLE_NATIVE_BUILD_ENTRY={entry_point}")
            return 1
        if set_native_target:
            env_set("SIMPLE_NATIVE_BUILD_TARGET", native_target)
        if set_native_cpu:
            env_set("SIMPLE_NATIVE_CPU", native_cpu)
        # --entry-closure: tell the driver to skip its implicit whole-src bulk-load
        # (src/app+lib+compiler+runtime). The explicit --source dirs + entry still
        # load. Gated so the default (bootstrap) path is byte-identical.
        val effective_entry_closure = entry_closure or emit_object
        val nb_closure_env = if effective_entry_closure: "1" else: "0"
        env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", nb_closure_env)
        if runtime_bundle_explicit:
            env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", runtime_bundle)
        if not optimization_requested:
            release = true
            opt_level = cli_native_default_opt_level()

        val _nb_target_opt_ctx = target_opt_context_default()

        val result = if emit_smf:
            # --emit-smf: produce native binary + SMF cache file
            use compiler.driver.driver_types (CompileOptions, CompileMode)
            use compiler.driver.driver (CompilerDriver)
            var options = CompileOptions.default()
            var native_inputs: [text] = []
            if effective_entry_closure:
                for cf in _native_build_entry_closure(entry_point, source_dirs):
                    native_inputs = native_inputs.push(cf)
                    options = cli_native_build_add_bootstrap_input(options, cf)
            else:
                for source_dir in source_dirs:
                    native_inputs = native_inputs.push(source_dir)
                    options = cli_native_build_add_bootstrap_input(options, source_dir)
                native_inputs = native_inputs.push(entry_point)
                options = cli_native_build_add_bootstrap_input(options, entry_point)
            options.input_files = native_inputs
            if verbose and effective_entry_closure:
                _cli_eprint("[native-build] Entry closure files: {native_inputs.len()}")
            options.mode = CompileMode.Aot
            options.output_file = Some(staged_output)
            options.output_format = driver_output_format_both()
            options.backend = backend
            options.release = release
            options.opt_level = opt_level
            options.no_borrow_check = no_borrow_check
            options.target_opt_ctx = _nb_target_opt_ctx
            options = compileoptions_normalize_mir_optimization(options)
            val driver = compiler_driver_create(options)
            if verbose:
                _cli_eprint("[native-build] Driver start: inputs={native_inputs.len()} backend={backend} mode={build_mode}")
            val driver_result = compiler_driver_run_compile(driver)
            if verbose:
                _cli_eprint("[native-build] Driver finished")
            driver_result
        else:
            var options = CompileOptions.default()
            var native_inputs: [text] = []
            if effective_entry_closure:
                for cf in _native_build_entry_closure(entry_point, source_dirs):
                    native_inputs = native_inputs.push(cf)
                    options = cli_native_build_add_bootstrap_input(options, cf)
            else:
                for source_dir in source_dirs:
                    native_inputs = native_inputs.push(source_dir)
                    options = cli_native_build_add_bootstrap_input(options, source_dir)
                native_inputs = native_inputs.push(entry_point)
                options = cli_native_build_add_bootstrap_input(options, entry_point)
            options.input_files = native_inputs
            if verbose and effective_entry_closure:
                _cli_eprint("[native-build] Entry closure files: {native_inputs.len()}")
            options.mode = CompileMode.Aot
            options.output_file = Some(staged_output)
            if build_mode == "dynload" and not emit_object:
                options.output_format = driver_output_format_both()
            else:
                options.output_format = driver_output_format_native()
            options.backend = backend
            options.release = release
            options.opt_level = opt_level
            options.no_borrow_check = no_borrow_check
            options.target_opt_ctx = _nb_target_opt_ctx
            options = compileoptions_normalize_mir_optimization(options)
            val driver = compiler_driver_create(options)
            if verbose:
                _cli_eprint("[native-build] Driver start: inputs={native_inputs.len()} backend={backend} mode={build_mode}")
            val driver_result = compiler_driver_run_compile(driver)
            if verbose:
                _cli_eprint("[native-build] Driver finished")
            driver_result
        match result:
            case CompileResult.Success(_):
                # Root-cause guard for the exit-0-with-no-binary hang
                # (doc/08_tracking/bug/native_build_worker_zombie_parent_hang_2026-07-03.md):
                # the driver/linker pipeline can report Success (e.g. a linker
                # subprocess that silently no-ops) without the output file ever
                # landing on disk. Never let that surface as a quiet success --
                # fail loudly here, at the single funnel all native-build exits
                # pass through, instead of leaving callers to discover a missing
                # binary after trusting exit code 0.
                if not _cli_file_exists_impl(staged_output):
                    env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
                    env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
                    env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
                    env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
                    if runtime_bundle_explicit:
                        env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", old_native_runtime_bundle)
                    if set_native_target:
                        env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
                    if set_native_cpu:
                        env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
                    if native_threads > 0:
                        env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
                    _cli_file_remove_impl(staged_output)
                    _cli_eprint("error: native-build reported success but produced no fresh output binary: {staged_output}")
                    _cli_eprint("  (compiler driver returned Success without writing the expected file -- treating as a hard failure, not a silent success)")
                    return 1
                if not _cli_file_rename_impl(staged_output, output):
                    _cli_file_remove_impl(staged_output)
                    env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
                    env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
                    env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
                    env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
                    if runtime_bundle_explicit:
                        env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", old_native_runtime_bundle)
                    if set_native_target:
                        env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
                    if set_native_cpu:
                        env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
                    if native_threads > 0:
                        env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
                    _cli_eprint("error: native-build produced staging output but could not publish it: {output}")
                    return 1
                val metadata = launch_metadata_for_native_build("host", "", "native")
                val metadata_path = launch_metadata_sidecar_path(output)
                val metadata_text = render_launch_metadata_sidecar(metadata)
                if not _cli_file_write_impl(metadata_path, metadata_text):
                    env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
                    env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
                    env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
                    env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
                    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
                    if runtime_bundle_explicit:
                        env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", old_native_runtime_bundle)
                    if set_native_target:
                        env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
                    if set_native_cpu:
                        env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
                    if native_threads > 0:
                        env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
                    _cli_eprint("Error: failed to write launch metadata sidecar: {metadata_path}")
                    return 1
                env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
                env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
                env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
                env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
                env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
                env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
                if runtime_bundle_explicit:
                    env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", old_native_runtime_bundle)
                if set_native_target:
                    env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
                if set_native_cpu:
                    env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
                if native_threads > 0:
                    env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
                if verbose:
                    _cli_eprint("[native-build] Build successful: {output}")
                    _cli_eprint("[native-build] Launch metadata: {metadata_path}")
                return 0
            case _:
                _cli_file_remove_impl(staged_output)
                env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
                env_set("SIMPLE_NATIVE_BUILD_EMIT_OBJECT", old_emit_object)
                env_set("SIMPLE_NATIVE_BUILD_CACHE_DIR", old_native_cache_dir)
                env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
                env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)
                env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_native_entry_closure)
                if runtime_bundle_explicit:
                    env_set("SIMPLE_NATIVE_RUNTIME_BUNDLE", old_native_runtime_bundle)
                if set_native_target:
                    env_set("SIMPLE_NATIVE_BUILD_TARGET", old_native_target)
                if set_native_cpu:
                    env_set("SIMPLE_NATIVE_CPU", old_native_cpu)
                if native_threads > 0:
                    env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
                if verbose:
                    _cli_eprint("[native-build] failed backend={backend} mode={build_mode} cache-dir={cache_dir} threads={native_threads} entry={entry_point} output={output}")
                val errors = compile_result_errors(result)
                if errors.len() == 0:
                    _cli_eprint("error: native-build failed without diagnostics")
                else:
                    for err in errors:
                        _cli_eprint("error: {err}")
                return 1
    else:
        if backend_explicit:
            _cli_eprint("Error: native-build backend '{backend}' is not available in the pure Simple command path")
        else:
            _cli_eprint("Error: native-build requires --backend=llvm-lib in the pure Simple command path")
        _cli_eprint("The Rust seed is bootstrap-only; native-build no longer falls back to rt_native_build.")
        return 1

fn cli_normalize_runtime_bundle_aliases(args: [text]) -> [text]:
    # Map semantic Simple/C runtime lane names onto legacy driver values.
    # Delegation must not revive the removed Rust-hosted lane or collapse pure
    # Simple and C-bootstrap lanes into the legacy `runtime` value.
    var normalized: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--runtime-bundle" and i + 1 < args.len():
            normalized = normalized.push(arg)
            val value = args[i + 1]
            if value == "simple_core":
                normalized = normalized.push("simple-core")
            elif value == "core_c_bootstrap":
                normalized = normalized.push("core-c-bootstrap")
            else:
                normalized = normalized.push(value)
            i = i + 2
            continue
        elif arg.starts_with("--runtime-bundle="):
            val value = arg.substring(17)
            if value == "simple_core":
                normalized = normalized.push("--runtime-bundle=simple-core")
            elif value == "core_c_bootstrap":
                normalized = normalized.push("--runtime-bundle=core-c-bootstrap")
            else:
                normalized = normalized.push(arg)
            i = i + 1
            continue
        normalized = normalized.push(arg)
        i = i + 1
    return normalized

fn cli_runtime_bundle_is_rust_or_hosted(bundle: text) -> bool:
    bundle == "rust-hosted" or bundle == "rust_hosted" or bundle == "hosted"
