        case _:
            val errors = aot_result.get_errors()
            for err in errors:
                _cli_eprint("error: {err}")
            _cli_eprint("Error: CUDA/PTX compilation failed")
            return 1

fn compile_opencl(source_file: text, output_file: text, verbose: bool) -> i64:
