# CLI Command Handlers - Command dispatch functions
# Extracted from cli_ops.spl for modularity
# Functions here reference helpers in cli_ops.spl (same directory, no imports needed)

use compiler.driver.driver.{interpret_file}
use compiler.driver.driver.{check_file}
use compiler.driver.driver_types.{CompileResult}
use compiler.tools.formatter.main.{Formatter, make_formatter, check_formatting, format_file_inplace, read_file, print_diff}
use compiler.tools.fix.main.{collect_fixes_from_source, FixApplicator}
use std.tooling.easy_fix.{FixConfidence}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# CLI Command Handlers
# ============================================================================

fn cli_run_code(code: text, gc_log: bool, gc_off: bool) -> i64:
    print "=== Simple Code Execution ==="
    print "Code: {code}"
    print "Note: Interpreter would evaluate this code"
    1

fn cli_run_file(path: text, args: [text], gc_log: bool, gc_off: bool) -> i64:
    val result = interpret_file(path)
    match result:
        case CompileResult.Success(_): 0
        case _:
            _cli_eprint("Error running {path}")
            1

fn cli_watch_file(path: text) -> i64:
    print "Watch mode not yet implemented in pure Simple"
    1

fn cli_run_repl(gc_log: bool, gc_off: bool) -> i64:
    print "=== Simple REPL ==="
    print "REPL not yet implemented in pure Simple"
    print ""
    print "For now, use: bin/simple yourfile.spl"
    1

fn cli_not_implemented(tool_name: text) -> i64:
    print "{tool_name} not yet implemented in pure Simple"
    1

fn _cli_strip_command(args: [text], cmd: text) -> [text]:
    if args.len() > 0 and args[0] == cmd:
        args.slice(1, args.len())
    else:
        args

fn cli_run_tests(args: [text], gc_log: bool, gc_off: bool) -> i64:
    val result = interpret_file("src/app/test_runner_new/main.spl")
    match result:
        case CompileResult.Success(_): 0
        case _:
            _cli_eprint("Error running test runner")
            1

fn cli_run_lint(args: [text]) -> i64:
    # Parse flags from args
    var files: [text] = []
    for arg in args:
        if arg == "lint":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple lint <file.spl> [file2.spl ...]"
        print ""
        print "Runs lint passes on Simple source files."
        print "Checks for:"
        print "  - Collection performance anti-patterns (COLL001-COLL008)"
        print "  - Duplicate typed arguments (DTYP001)"
        print "  - Bare primitive types in public APIs"
        return 1

    var exit_code = 0
    var total_warnings = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        # Run type-check pass which includes diagnostics
        val result = check_file(file_path)
        match result:
            case CompileResult.Success(msg):
                print "lint: {file_path} OK"
            case _:
                _cli_eprint("lint: {file_path} has issues")
                exit_code = 1
                total_warnings = total_warnings + 1

    if total_warnings > 0:
        print ""
        print "Lint found issues in {total_warnings} file(s)"
    elif exit_code == 0:
        print ""
        print "Lint passed: all files clean"
    exit_code

fn cli_run_fmt(args: [text]) -> i64:
    # Parse flags from args
    var check_mode = false
    var write_mode = false
    var diff_mode = false
    var files: [text] = []
    for arg in args:
        if arg == "--check":
            check_mode = true
        elif arg == "--write":
            write_mode = true
        elif arg == "--diff":
            diff_mode = true
        elif arg == "fmt":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple fmt <file.spl> [--check] [--write] [--diff]"
        print ""
        print "Options:"
        print "  --check   Check if file is formatted (exit 1 if not)"
        print "  --write   Format file in place"
        print "  --diff    Show formatting diff"
        return 1

    var exit_code = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        if check_mode:
            val result = check_formatting(file_path)
            match result:
                case Ok(is_formatted):
                    if is_formatted:
                        print "OK {file_path} is formatted"
                    else:
                        print "FAIL {file_path} needs formatting"
                        exit_code = 1
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
        elif write_mode:
            val result = format_file_inplace(file_path)
            match result:
                case Ok(_):
                    print "OK Formatted {file_path}"
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
        elif diff_mode:
            val fmt = make_formatter()
            val orig_result = read_file(file_path)
            match orig_result:
                case Err(e):
                    _cli_eprint("Error reading file: {e}")
                    exit_code = 1
                case Ok(original):
                    val fmt_result = fmt.format_source(original)
                    match fmt_result:
                        case Err(e):
                            _cli_eprint("Error: {e}")
                            exit_code = 1
                        case Ok(formatted):
                            if original == formatted:
                                print "OK {file_path} is correctly formatted"
                            else:
                                print_diff(original, formatted, file_path)
                                exit_code = 1
        else:
            # Default: print formatted output to stdout
            val fmt = make_formatter()
            val result = fmt.format_file(file_path)
            match result:
                case Ok(formatted):
                    print formatted
                case Err(e):
                    _cli_eprint("Error: {e}")
                    exit_code = 1
    exit_code

fn cli_run_fix(args: [text]) -> i64:
    # Parse flags from args
    var dry_run = false
    var fix_all = false
    var files: [text] = []
    for arg in args:
        if arg == "--dry-run":
            dry_run = true
        elif arg == "--fix-all":
            fix_all = true
        elif arg == "fix":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple fix <file.spl> [--dry-run] [--fix-all]"
        print ""
        print "Options:"
        print "  --dry-run   Show what would be fixed without applying"
        print "  --fix-all   Apply all fixes regardless of confidence"
        return 1

    var exit_code = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        val source = rt_file_read_text(file_path) ?? ""
        if source == "":
            _cli_eprint("Error: Could not read file: {file_path}")
            exit_code = 1
            continue

        val fixes = collect_fixes_from_source(file_path, source)
        if fixes.len() == 0:
            print "No fixes available for {file_path}"
            continue

        # Filter by confidence unless --fix-all
        var filtered = fixes
        if not fix_all:
            filtered = FixApplicator.filter_by_confidence(filtered, FixConfidence.Safe)

        if filtered.len() == 0:
            print "No applicable fixes found for {file_path}"
            continue

        # Build sources registry for this file
        var sources: Dict<text, text> = {}
        sources[file_path] = source

        val result = FixApplicator.apply_to_disk(filtered, sources, dry_run)
        match result:
            case Ok(report):
                if dry_run:
                    print "Dry run for {file_path}:"
                else:
                    print "Applied fixes to {file_path}:"
                print "  {report.applied} fix(es) applied"
                for detail in report.details:
                    print "  {detail}"
            case Err(e):
                _cli_eprint("Error applying fixes to {file_path}: {e}")
                exit_code = 1
    exit_code

