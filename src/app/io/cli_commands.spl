#![allow(unnamed_duplicate_typed_args)]
# CLI Command Handlers - Command dispatch functions
# Extracted from cli_ops.spl for modularity
# Functions here reference helpers in cli_ops.spl (same directory, no imports needed)

use compiler.driver.driver_api_core.{interpret_file}
use compiler.tools.formatter.main.{Formatter, make_formatter, check_formatting, format_file_inplace, read_file, print_diff}
use compiler.tools.fix.main.{collect_fixes_from_source, FixApplicator}
use compiler.tools.lint.main.{LintConfig, LintLevel, Linter}
use std.tooling.easy_fix.{FixConfidence}
use compiler.core.lexer_struct.{CoreLexer, make_core_lexer, core_lexer_next_token, core_lexer_token_text, core_lexer_token_line, core_lexer_token_col}
use compiler.core.tokens.{TOK_EOF, TOK_ERROR}
use app.io.cli_ops.{_cli_shell, _cli_eprint, _cli_process_run, _cli_driver_binary}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_platform_name() -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool

fn _find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin

    val is_win = rt_platform_name() == "windows"
    val ext = if is_win: ".exe" else: ""

    if rt_file_exists("src/compiler_rust/target/release/simple{ext}"):
        return "src/compiler_rust/target/release/simple{ext}"
    if rt_file_exists("src/compiler_rust/target/bootstrap/simple{ext}"):
        return "src/compiler_rust/target/bootstrap/simple{ext}"
    if rt_file_exists("bin/simple{ext}"):
        return "bin/simple{ext}"
    if not is_win:
        if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
            return "bin/release/aarch64-apple-darwin-macho/simple"
        if rt_file_exists("bin/release/macos-arm64/simple"):
            return "bin/release/macos-arm64/simple"
        if rt_file_exists("bin/release/darwin-aarch64/simple"):
            return "bin/release/darwin-aarch64/simple"
        if rt_file_exists("bin/release/macos-x86_64/simple"):
            return "bin/release/macos-x86_64/simple"
        if rt_file_exists("bin/release/linux-x86_64/simple"):
            return "bin/release/linux-x86_64/simple"
    else:
        if rt_file_exists("bin/release/x86_64-pc-windows-msvc/simple.exe"):
            return "bin/release/x86_64-pc-windows-msvc/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-gnu/simple.exe"):
            return "bin/release/x86_64-pc-windows-gnu/simple.exe"
    "bin/simple{ext}"

# ============================================================================
# CLI Command Handlers
