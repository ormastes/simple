fn cli_check(args: [text]) -> i64:
    # Parse flags from args
    var files: [text] = []
    for arg in args:
        if arg == "check":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple check <file.spl> [file2.spl ...]"
        print ""
        print "Type-checks Simple source files without compiling."
        return 1

    var exit_code = 0
    var error_count = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        val result = check_file(file_path)
        match result:
            case CompileResult.Success(_):
                print "check: {file_path} OK"
            case _:
                _cli_eprint("check: {file_path} FAIL")
                exit_code = 1
                error_count = error_count + 1

    if error_count > 0:
        print ""
        print "Type check failed: {error_count} file(s) with errors"
    elif exit_code == 0:
        print ""
        print "Type check passed: all files OK"
    exit_code

