fn cli_handle_linkers() -> i64:
    # Detect available linkers on the system
    print "Available native linkers:"
    print ""
    # Check mold
    val mold_result = _cli_shell("which mold 2>/dev/null")
    if mold_result.exit_code == 0:
        print "  mold      Modern linker (fastest, recommended)  [installed]"
    else:
        print "  mold      Modern linker (fastest, recommended)  [not found]"
    # Check lld
    val lld_result = _cli_shell("which lld 2>/dev/null || which ld.lld 2>/dev/null")
    if lld_result.exit_code == 0:
        print "  lld       LLVM linker (fast, widely available)  [installed]"
    else:
        print "  lld       LLVM linker (fast, widely available)  [not found]"
    # Check ld
    val ld_result = _cli_shell("which ld 2>/dev/null")
    if ld_result.exit_code == 0:
        print "  ld        GNU linker (default, always available)  [installed]"
    else:
        print "  ld        GNU linker (default)  [not found]"
    print ""
    print "Auto-detection preference: mold > lld > ld"
    print ""
    print "Usage:"
    print "  simple compile app.spl --linker mold"
    0

fn cli_replay(args: [text]) -> i64:
    print "[experimental] Replay tool is not yet implemented"
    1

fn cli_check(args: [text]) -> i64:
    # Parse flags from args
    var files: [text] = []
    for arg in args:
        if arg == "check":
            # Skip the command name itself
            val _ = 0
        elif not arg.starts_with("-"):
            files.push(arg)

    if files.len() == 0:
        print "Usage: simple check <file.spl> [file2.spl ...]"
        print ""
        print "Type-checks Simple source files without compiling."
        return 1

    var exit_code = 0
    var error_count = 0
    for file_path in files:
        if not rt_file_exists(file_path):
            _cli_eprint("Error: File not found: {file_path}")
            exit_code = 1
            continue

        val result = check_file(file_path)
        match result:
            case CompileResult.Success(_):
                print "check: {file_path} OK"
            case _:
                _cli_eprint("check: {file_path} FAIL")
                exit_code = 1
                error_count = error_count + 1

    if error_count > 0:
        print ""
        print "Type check failed: {error_count} file(s) with errors"
    elif exit_code == 0:
        print ""
        print "Type check passed: all files OK"
    exit_code

fn cli_info(args: [text]) -> i64:
    # Print project info from simple.sdn manifest
    var sdn_path = "simple.sdn"
    if not rt_file_exists(sdn_path):
        print "No simple.sdn found in current directory."
        print "Run 'simple init' to create a project."
        return 1
    val content = rt_file_read_text(sdn_path) ?? ""
    if content == "":
        _cli_eprint("Error: Could not read simple.sdn")
        return 1
    # Parse key fields from SDN
    var name = ""
    var version = ""
    var license = ""
    var main_file = ""
    var run_config = ""
    var in_package = false
    var in_execution = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        # Detect top-level sections (no indent, ends with :)
        if not line.starts_with(" ") and not line.starts_with("\t"):
            in_package = trimmed == "package:"
            in_execution = trimmed == "execution:"
            continue
        if in_package:
            if trimmed.starts_with("name:"):
                name = trimmed[5:].trim()
            elif trimmed.starts_with("version:"):
                version = trimmed[8:].trim()
            elif trimmed.starts_with("license:"):
                license = trimmed[8:].trim()
            elif trimmed.starts_with("main:"):
                main_file = trimmed[5:].trim()
        elif in_execution:
            if trimmed.starts_with("run-config:"):
                run_config = trimmed[11:].trim()
    print "Project Info"
    print "============"
    if name != "":
        print "  Name:        {name}"
    if version != "":
        print "  Version:     {version}"
    if license != "":
        print "  License:     {license}"
    if main_file != "":
        print "  Entry:       {main_file}"
    if run_config != "":
        print "  Run Config:  {run_config}"
    print ""
    print "  Manifest:    {sdn_path}"
    0

# ============================================================================
# Test Daemon
# ============================================================================

fn cli_test_daemon(args: [text]) -> i64:
    if args.len() == 0:
        print "Usage:"
        print "  simple test-daemon start       Start test daemon (foreground)"
        print "  simple test-daemon stop        Stop test daemon"
        print "  simple test-daemon status      Show daemon status"
        print "  simple test-daemon run <path>  Run test via daemon (auto-starts)"
        print "  simple test-daemon clean <path> Force-run bypassing cache"
        return 1

    val subcmd = args[0]
    if subcmd == "start":
        return cli_test_daemon_start()
    elif subcmd == "stop":
        return cli_test_daemon_stop()
    elif subcmd == "status":
        return cli_test_daemon_status()
    elif subcmd == "run":
        if args.len() < 2:
            print "Usage: simple test-daemon run <path> [--filter F]"
            return 1
        return cli_test_daemon_run(args[1:], false)
    elif subcmd == "clean":
        if args.len() < 2:
            print "Usage: simple test-daemon clean <path>"
            return 1
        return cli_test_daemon_run(args[1:], true)
    else:
        print "Unknown test-daemon subcommand: {subcmd}"
        return 1

fn cli_test_daemon_start() -> i64:
    # Start the test daemon in foreground
    use app.test_daemon.types.{test_daemon_config_default}
    use app.test_daemon.daemon.{test_daemon_start}

    print "Starting test daemon..."
    val config = test_daemon_config_default()
    val daemon = test_daemon_start(config)
    if not daemon.is_running():
        print "Failed to start test daemon (lock acquisition failed)"
        return 1

    print "Test daemon running (pid in .build/test_daemon/test_daemon.lock)"
    daemon.run()
    print "Test daemon stopped"
    0

fn cli_test_daemon_stop() -> i64:
    use app.test_daemon.client.{test_daemon_stop}
    use app.test_daemon.types.{test_daemon_config_default}

    val config = test_daemon_config_default()
    if test_daemon_stop(config):
        print "Test daemon stopped"
        return 0
    print "Failed to stop test daemon (may not be running)"
    1

fn cli_test_daemon_status() -> i64:
    val lock_path = ".build/test_daemon/test_daemon.lock"
    if not rt_file_exists(lock_path):
        print "Test daemon: not running"
        return 0

    val content = rt_file_read_text(lock_path) ?? ""
    if content == "":
        print "Test daemon: not running (empty lock)"
        return 0

    val lines = content.split("\n")
    val pid_str = lines[0].trim()

    extern fn rt_process_exists(pid: i64) -> bool
    val pid = pid_str.to_i64() ?? 0
    if pid > 0 and rt_process_exists(pid):
        print "Test daemon: running (pid: {pid_str})"
    else:
        print "Test daemon: not running (stale lock, pid: {pid_str})"
    0

fn cli_test_daemon_run(args: [text], clean: bool) -> i64:
    use app.test_daemon.client.{test_daemon_ensure_running, test_submit_and_wait}
    use app.test_daemon.types.{test_daemon_config_default, TestResult}

    val config = test_daemon_config_default()

    # Ensure daemon is running (auto-start if needed)
    if not test_daemon_ensure_running(config):
        print "Failed to start test daemon"
        return 1

    val path = args[0]
    val mode = if clean: "clean" else: "run"
    print "Submitting test ({mode}): {path}"

    # Submit and wait (10 min timeout)
    val result = test_submit_and_wait(path, config, clean, 600000)

    # Print result
    if result.success:
        print "PASS: {path}"
        if result.output != "":
            print result.output
        return 0
    else:
        print "FAIL: {path}"
        if result.output != "":
            print result.output
        return 1

# ============================================================================
# Watch Daemon Commands
# ============================================================================

fn cli_watch_daemon(args: [text]) -> i64:
    if args.len() == 0:
        print "Usage:"
        print "  simple watch-daemon start       Start watch daemon (foreground, SHB+SMF)"
        print "  simple watch-daemon stop        Stop watch daemon"
        print "  simple watch-daemon status      Show daemon status"
        return 1

    val subcmd = args[0]
    if subcmd == "start":
        return cli_watch_daemon_start()
    elif subcmd == "stop":
        return cli_watch_daemon_stop()
    elif subcmd == "status":
        return cli_watch_daemon_status()
    else:
        print "Unknown watch-daemon subcommand: {subcmd}"
        return 1

fn cli_watch_daemon_start() -> i64:
    use compiler.driver.watcher.watcher_types.{watcher_config_default}
    use compiler.driver.watcher.watcher_daemon.{watcher_daemon_start}
    use app.io.{thread_sleep_ms}

    print "Starting watch daemon (SHB+SMF mode, Cranelift default)..."
    var config = watcher_config_default()
    val daemon = watcher_daemon_start(config)
    if not daemon.is_running():
        print "Failed to start watch daemon (lock acquisition failed)"
        return 1

    print "Watch daemon running (pid in {config.lock_path})"
    print "Watching src/ for .spl changes. Press Ctrl+C to stop."
    print ""

    # Run poll loop in foreground
    while daemon.is_running():
        daemon.run_poll_cycle()
        thread_sleep_ms(config.poll_interval_ms)

    print "Watch daemon stopped"
    0

fn cli_watch_daemon_stop() -> i64:
    val lock_path = ".build/watcher/watcher.lock"
    if not rt_file_exists(lock_path):
        print "Watch daemon: not running"
        return 1

    val content = rt_file_read_text(lock_path) ?? ""
    if content == "":
        print "Watch daemon: not running (empty lock)"
        return 1

    val lines = content.split("\n")
    val pid_str = lines[0].trim()
    extern fn rt_process_kill(pid: i64) -> bool
    val pid = pid_str.to_i64() ?? 0
    if pid > 0:
        if rt_process_kill(pid):
            print "Watch daemon stopped (pid: {pid_str})"
            return 0
        else:
            print "Failed to stop watch daemon (pid: {pid_str})"
            return 1
    print "Watch daemon: not running (invalid pid)"
    1

fn cli_watch_daemon_status() -> i64:
    val lock_path = ".build/watcher/watcher.lock"
    if not rt_file_exists(lock_path):
        print "Watch daemon: not running"
        return 0

    val content = rt_file_read_text(lock_path) ?? ""
    if content == "":
        print "Watch daemon: not running (empty lock)"
        return 0

    val lines = content.split("\n")
    val pid_str = lines[0].trim()

    extern fn rt_process_exists(pid: i64) -> bool
    val pid = pid_str.to_i64() ?? 0
    if pid > 0 and rt_process_exists(pid):
        print "Watch daemon: running (pid: {pid_str})"
    else:
        print "Watch daemon: not running (stale lock, pid: {pid_str})"
    0
