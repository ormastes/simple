fn cli_run_lex(args: [text]) -> i64:
    # Parse args: skip "lex" command name, find file path
    var file_path = ""
    for arg in args:
        if arg == "lex":
            val _ = 0
        elif not arg.starts_with("-"):
            if file_path == "":
                file_path = arg
    if file_path == "":
        print "Usage: simple lex <file.spl>"
        print ""
        print "Tokenizes a Simple source file and prints the token stream."
        return 1
    if not rt_file_exists(file_path):
        _cli_eprint("Error: File not found: {file_path}")
        return 1
    val source = rt_file_read_text(file_path) ?? ""
    if source == "":
        _cli_eprint("Error: Could not read file: {file_path}")
        return 1
    # Tokenize using CoreLexer
    var lexer = make_core_lexer(source)
    var token_count = 0
    print "Tokens for {file_path}:"
    print "  Line:Col  Kind  Text"
    print "  ─────────────────────"
    var done = false
    while not done:
        val (next_lexer, kind) = core_lexer_next_token(lexer)
        lexer = next_lexer
        val tok_text = core_lexer_token_text(lexer)
        val tok_line = core_lexer_token_line(lexer)
        val tok_col = core_lexer_token_col(lexer)
        if kind == TOK_EOF:
            done = true
        else:
            token_count = token_count + 1
            print "  {tok_line}:{tok_col}  {kind}  {tok_text}"
    print ""
    print "Total: {token_count} tokens"
    0

fn cli_run_brief(args: [text]) -> i64:
    # Brief project summary: file count, line count, test count
    val file_count_result = _cli_shell("find src -name '*.spl' 2>/dev/null | wc -l")
    val file_count = file_count_result.stdout.trim()
    val line_count_result = _cli_shell("find src -name '*.spl' -not -path '*/release/*' -not -path '*/build/*' 2>/dev/null | xargs wc -l 2>/dev/null | tail -1 | awk '{print $1}'")
    val line_count = line_count_result.stdout.trim()
    val test_count_result = _cli_shell("find test -name '*_spec.spl' 2>/dev/null | wc -l")
    val test_count = test_count_result.stdout.trim()
    print "Simple Project Brief"
    print "  Source files: {file_count}"
    print "  Total lines:  {line_count}"
    print "  Test specs:   {test_count}"
    0

fn cli_run_ffi_gen(args: [text]) -> i64:
    # Route to the real generator implementation in compiler/90.tools.
    val run_args = _cli_strip_command(args, "ffi-gen")
    val previous_force_args = rt_env_get("SIMPLE_FORCE_ARGS")
    rt_env_set("SIMPLE_FORCE_ARGS", ffi_gen_force_args(run_args))

    val result = interpret_file(ffi_gen_entry_path())

    if previous_force_args == nil or previous_force_args == "":
        rt_env_set("SIMPLE_FORCE_ARGS", "")
    else:
        rt_env_set("SIMPLE_FORCE_ARGS", previous_force_args)

    match result:
        case CompileResult.Success(_): 0
        case _:
            _cli_eprint("Error running ffi-gen")
            1

fn cli_run_i18n(args: [text]) -> i64:
    # List available i18n language files and their status
    var subcmd = ""
    for arg in args:
        if arg == "i18n":
            val _ = 0
        elif not arg.starts_with("-"):
            if subcmd == "":
                subcmd = arg
    if subcmd == "" or subcmd == "status":
        # Show i18n status: count .ko.spl files vs .spl files
        val en_result = _cli_shell("find src/i18n -maxdepth 1 -name 'strings_*.spl' -not -name '*.ko.spl' 2>/dev/null | wc -l")
        val ko_result = _cli_shell("find src/i18n -maxdepth 1 -name 'strings_*.ko.spl' 2>/dev/null | wc -l")
        val en_count = en_result.stdout.trim()
        val ko_count = ko_result.stdout.trim()
        print "Internationalization (i18n) Status"
        print "=================================="
        print ""
        print "  String modules (English): {en_count}"
        print "  String modules (Korean):  {ko_count}"
        print ""
        print "  Source directory: src/i18n/"
        print ""
        print "Categories:"
        print "  strings_common       Parser errors (E0001-E0016)"
        print "  strings_semantic     Type checking errors (E1000-E1999)"
        print "  strings_advanced     Advanced features (generics, traits)"
        print "  strings_codegen      Code generation (E2000-E2999)"
        print "  strings_runtime      Runtime errors (E3000+)"
        print "  strings_verification Static analysis"
        print "  strings_lint         Code style warnings"
        print "  strings_explanations Detailed help text"
        print "  strings_extended     Additional diagnostics"
        return 0
    elif subcmd == "list":
        # List all i18n files
        val list_result = _cli_shell("find src/i18n -name '*.spl' -maxdepth 1 | sort")
        print "i18n files:"
        print list_result.stdout
        return 0
    else:
        print "Usage: simple i18n [status|list]"
        print ""
        print "Subcommands:"
        print "  status   Show i18n coverage (default)"
        print "  list     List all i18n files"
        return 1

