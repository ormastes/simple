# ============================================================================
# Test Daemon
# ============================================================================

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn cli_test_daemon(args: [text]) -> i64:
    if args.len() == 0:
        print "Usage:"
        print "  simple test-daemon start       Start test daemon (foreground)"
        print "  simple test-daemon stop        Stop test daemon"
        print "  simple test-daemon status      Show daemon status"
        return 1

    val subcmd = args[0]
    if subcmd == "start":
        return cli_test_daemon_start()
    else if subcmd == "stop":
        return cli_test_daemon_stop()
    else if subcmd == "status":
        return cli_test_daemon_status()
    else:
        print "Unknown test-daemon subcommand: {subcmd}"
        return 1

fn cli_test_daemon_start() -> i64:
    # Start the test daemon in foreground
    use app.test_daemon.types.{test_daemon_config_default}
    use app.test_daemon.daemon.{test_daemon_start}

    print "Starting test daemon..."
    val config = test_daemon_config_default()
    val daemon = test_daemon_start(config)
    if not daemon.is_running():
        print "Failed to start test daemon (lock acquisition failed)"
        return 1

    print "Test daemon running (pid in .build/test_daemon/test_daemon.lock)"
    daemon.run()
    print "Test daemon stopped"
    0

fn cli_test_daemon_stop() -> i64:
    use app.test_daemon.client.{test_daemon_stop}
    use app.test_daemon.types.{test_daemon_config_default}

    val config = test_daemon_config_default()
    if test_daemon_stop(config):
        print "Test daemon stopped"
        return 0
    print "Failed to stop test daemon (may not be running)"
    1

fn cli_test_daemon_status() -> i64:
    val lock_path = ".build/test_daemon/test_daemon.lock"
    if not rt_file_exists(lock_path):
        print "Test daemon: not running"
        return 0

    val content = rt_file_read_text(lock_path) ?? ""
    if content == "":
        print "Test daemon: not running (empty lock)"
        return 0

    val lines = content.split("\n")
    val pid_str = lines[0].trim()

    extern fn rt_process_exists(pid: i64) -> bool
    val pid = pid_str.to_i64() ?? 0
    if pid > 0 and rt_process_exists(pid):
        print "Test daemon: running (pid: {pid_str})"
    else:
        print "Test daemon: not running (stale lock, pid: {pid_str})"
    0

