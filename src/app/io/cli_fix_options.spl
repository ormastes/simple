# Shared closed option validation for both pure-Simple fix CLI owners.

pub fn fix_option_error(args: [text]) -> text:
    var help_count = 0
    var other_count = 0
    for arg in args:
        if arg == "fix":
            continue
        if arg == "--help" or arg == "-h":
            help_count = help_count + 1
            continue
        other_count = other_count + 1
        if arg == "--dry-run" or arg == "--fix-all":
            continue
        if arg.starts_with("--fix-id="):
            if arg.len() == "--fix-id=".len():
                return "--fix-id requires an ID"
            continue
        if arg.starts_with("-"):
            return "unknown option: {arg}"
    if help_count > 0 and (help_count != 1 or other_count > 0):
        return "help cannot be combined with files or other options"
    ""
