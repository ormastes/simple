# Shared closed option validation for both pure-Simple fix CLI owners.

pub fn fix_option_error(args: [text]) -> text:
    for arg in args:
        if arg == "fix" or arg == "--dry-run" or arg == "--fix-all":
            continue
        if arg.starts_with("--fix-id="):
            if arg.len() == "--fix-id=".len():
                return "--fix-id requires an ID"
            continue
        if arg.starts_with("-"):
            return "unknown option: {arg}"
    ""
