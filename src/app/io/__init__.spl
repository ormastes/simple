# I/O Module - CLI Layer
#
# Thin CLI wrappers and command dispatch. SFFI wrappers live in `app.io.mod`
# and are re-exported here for backward compatibility with `use app.io.{...}`.

mod cli_ops
mod cli_commands
mod cli_lint_commands
mod cli_compile
mod rt_compile_stub
mod env_ops
mod jit_ffi
mod jit
mod feature_ports
mod feature_registry

