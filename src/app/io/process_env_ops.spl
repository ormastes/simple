#[runtime_intrinsics]
# Process helpers that need explicit environment maps.

extern fn rt_process_spawn_async(cmd: text, args: [text], env: {text: text}) -> i64
extern fn rt_process_is_alive(pid: i64) -> bool

fn process_spawn_async_env(cmd: text, args: [text], env: {text: text}) -> i64:
    rt_process_spawn_async(cmd, args, env)

fn process_is_alive(pid: i64) -> bool:
    if pid <= 0:
        return false
    rt_process_is_alive(pid)
