# Process Governor - Global Concurrent Process Limit
#
# Caps the total number of child processes the runtime can have alive at once.
# Configure via SIMPLE_MAX_PROCS env var. Default: min(cpu_count * 4, 64).
#
# Usage:
#   proc_slot_acquire()   # call before spawning; blocks until a slot is free
#   proc_slot_release()   # call after process exits/is-killed
#   proc_slot_reset(n)    # call to bulk-release n slots (e.g. after kill-all)

extern fn rt_env_get(key: text) -> text
extern fn rt_thread_sleep(millis: i64)

# ============================================================================
# Module State
# ============================================================================

var _max_procs: i64 = -1   # -1 = not yet initialised
var _active_procs: i64 = 0

# ============================================================================
# CPU Count Helper (inlined so this file has no extra imports)
# ============================================================================

extern fn spl_thread_cpu_count() -> i64

fn _cpu_count() -> i64:
    val n = spl_thread_cpu_count()
    if n < 1: 4 else: n

# ============================================================================
# Initialisation (lazy, called on first acquire)
# ============================================================================

fn _proc_gov_init():
    if _max_procs >= 0:
        return ()
    val env_val = rt_env_get("SIMPLE_MAX_PROCS")
    if env_val != nil and env_val != "":
        val n = int(env_val)
        if n > 0:
            _max_procs = n
            return ()
    # Default: cpu_count * 4, clamped to [4, 64]
    val default_val = _cpu_count() * 4
    _max_procs = if default_val > 64: 64 else: if default_val < 4: 4 else: default_val

# ============================================================================
# Public API
# ============================================================================

fn proc_slot_max() -> i64:
    """Return the configured maximum concurrent processes."""
    _proc_gov_init()
    _max_procs

fn proc_slot_active() -> i64:
    """Return the current number of active (tracked) processes."""
    _active_procs

val _ACQUIRE_MAX_ITERATIONS: i64 = 600

fn proc_slot_acquire():
    """
    Claim a process slot before spawning.

    Blocks (with exponential back-off up to 500 ms) until a slot is free.
    Gives up after ~5 min (600 iterations) to prevent permanent hangs from leaked slots.
    Must be paired with proc_slot_release() after the process exits.
    """
    _proc_gov_init()
    var delay_ms: i64 = 50
    var iteration: i64 = 0
    while _active_procs >= _max_procs:
        if iteration >= _ACQUIRE_MAX_ITERATIONS:
            print "[proc_governor] ERROR: slot wait exceeded {_ACQUIRE_MAX_ITERATIONS} iterations (active={_active_procs}, max={_max_procs}) — forcing acquire to prevent hang"
            _active_procs = _active_procs + 1
            return ()
        rt_thread_sleep(delay_ms)
        iteration = iteration + 1
        if delay_ms < 100:
            delay_ms = 100
        elif delay_ms < 200:
            delay_ms = 200
        elif delay_ms < 500:
            delay_ms = 500
        if iteration % 5 == 0:
            print "[proc_governor] waiting for slot (active={_active_procs}, max={_max_procs}, iter={iteration}/{_ACQUIRE_MAX_ITERATIONS})"
    _active_procs = _active_procs + 1

fn proc_slot_release():
    """
    Free a process slot after the process has exited or been killed.

    Safe to call even when _active_procs is already 0 (no-op).
    """
    if _active_procs > 0:
        _active_procs = _active_procs - 1

fn proc_slot_reset(count: i64):
    """
    Bulk-release `count` slots.

    Use after tracker_kill_all_children() which clears the whole list at once.
    """
    if count <= 0:
        return ()
    _active_procs = if _active_procs > count: _active_procs - count else: 0

# ============================================================================
# Exports
# ============================================================================

export proc_slot_max
export proc_slot_active
export proc_slot_acquire
export proc_slot_release
export proc_slot_reset
