fn cli_run_diff(args: [text]) -> i64:
    # Build diff command: prefer jj, fall back to git
    var revision = ""
    var paths: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "diff":
            val _ = 0
        elif arg == "-r" and i + 1 < args.len():
            i = i + 1
            revision = args[i]
        elif arg.starts_with("-r"):
            revision = arg[2:]
        elif not arg.starts_with("-"):
            paths.push(arg)
        i = i + 1
    # Try jj first
    var cmd = "jj --no-pager --color never diff"
    if revision != "":
        cmd = cmd + " -r " + revision
    for p in paths:
        cmd = cmd + " " + p
    cmd = cmd + " 2>&1"
    val result: _CliProcessResult = _cli_shell(cmd)
    if result.exit_code == 0:
        if result.stdout.len() > 0:
            print result.stdout
        else:
            print "(no changes)"
        return 0
    # Fall back to git diff
    var git_cmd = "git diff"
    for p in paths:
        git_cmd = git_cmd + " " + p
    git_cmd = git_cmd + " 2>&1"
    val git_result: _CliProcessResult = _cli_shell(git_cmd)
    if git_result.stdout.len() > 0:
        print git_result.stdout
    else:
        print "(no changes)"
    git_result.exit_code

