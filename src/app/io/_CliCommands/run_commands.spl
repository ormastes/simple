extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_platform_name() -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn _find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin.len() > 0:
        return env_bin

    val is_win = rt_platform_name() == "windows"
    val ext = if is_win: ".exe" else: ""

    if rt_file_exists("bin/simple{ext}"):
        return "bin/simple{ext}"
    if not is_win:
        if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
            return "bin/release/aarch64-apple-darwin-macho/simple"
        if rt_file_exists("bin/release/macos-arm64/simple"):
            return "bin/release/macos-arm64/simple"
        if rt_file_exists("bin/release/darwin-aarch64/simple"):
            return "bin/release/darwin-aarch64/simple"
        if rt_file_exists("bin/release/macos-x86_64/simple"):
            return "bin/release/macos-x86_64/simple"
        if rt_file_exists("bin/release/linux-x86_64/simple"):
            return "bin/release/linux-x86_64/simple"
    else:
        if rt_file_exists("bin/release/x86_64-pc-windows-msvc/simple.exe"):
            return "bin/release/x86_64-pc-windows-msvc/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-gnu/simple.exe"):
            return "bin/release/x86_64-pc-windows-gnu/simple.exe"
    "bin/simple{ext}"

# ============================================================================
# CLI Command Handlers
# ============================================================================

fn cli_run_code(code: text, gc_log: bool, gc_off: bool) -> i64:
    val driver = _cli_driver_binary()
    if driver.len() > 0:
        val result = _cli_process_run(driver, ["-c", code])
        if result.0.len() > 0:
            print_raw(result.0)
        if result.1.len() > 0:
            _cli_eprint(result.1.trim())
        return result.2

    # Self-exec guard fallback (driver IS this binary): interpret in-process
    # via a staged temp file instead of spawning ourselves recursively.
    # Randomize the private staging directory to avoid predictable /tmp names.
    val pid = rt_getpid()
    val micros = rt_time_now_unix_micros()
    var stage_dir = "/tmp/simple_stage_{pid}_{micros}"
    if not dir_create_all(stage_dir):
        stage_dir = "/tmp/simple_stage_{pid}"
        dir_create_all(stage_dir)
    val tmp_path = "{stage_dir}/run_code_{pid}_{micros}.spl"
    val main_source = "fn main():\n    " + code.replace("\n", "\n    ") + "\n"
    if not file_write(tmp_path, main_source):
        _cli_eprint("error: failed to stage -c snippet at {tmp_path}")
        return 1
    val result = interpret_file(tmp_path)
    file_delete(tmp_path)
    match result:
        case CompileResult.Success(_): 0
        case _:
            _cli_eprint("error: failed to run -c snippet")
            1

fn cli_run_file(path: text, args: [text], gc_log: bool, gc_off: bool) -> i64:
    val driver = _cli_driver_binary()
    if driver.len() > 0:
        # CLI callers pass program arguments without argv[0]. Build an owned
        # vector here instead of forwarding a sliced vector across modules.
        var driver_args: [text] = [path]
        for arg in args:
            driver_args.push(arg)
        val result = _cli_process_run(driver, driver_args)
        if result.0.len() > 0:
            print_raw(result.0)
        if result.1.len() > 0:
            _cli_eprint(result.1.trim())
        return result.2

    val result = interpret_file(path)
    match result:
        case CompileResult.Success(_): 0
        case CompileResult.ParseError(errs):
            _cli_eprint("Parse error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.TypeError(errs):
            _cli_eprint("Type error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BlockError(errs):
            _cli_eprint("Block error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.ResolveError(errs):
            _cli_eprint("Resolve error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BorrowError(errs):
            _cli_eprint("Borrow error in {path}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.CodegenError(msg):
            _cli_eprint("Codegen error in {path}: {msg}")
            1
        case CompileResult.RuntimeError(msg):
            _cli_eprint("Runtime error in {path}: {msg}")
            1
        case _:
            _cli_eprint("Error running {path}")
            1

fn cli_watch_file(path: text) -> i64:
    var config: WatchConfig = watch_config_default()
    # If path looks like "test", set up test mode
    if path == "test":
        config.command_args = ["test"]
    elif path.ends_with(".spl"):
        # Specific test file
        config.command_args = ["test", path]
    else:
        # Custom watch path
        config.watch_paths = [path]
    watch_loop(config)

fn cli_run_repl(gc_log: bool, gc_off: bool) -> i64:
    cli_run_file("src/app/repl/main.spl", [], gc_log, gc_off)

fn cli_not_implemented(tool_name: text) -> i64:
    print "{tool_name} not yet implemented in pure Simple"
    1

fn _cli_strip_command(args: [text], cmd: text) -> [text]:
    if args.len() > 0 and args[0] == cmd:
        args.slice(1, args.len())
    else:
        args

fn sffi_gen_entry_path() -> text:
    "src/compiler/90.tools/sffi_gen/main.spl"

fn sffi_gen_force_args(args: [text]) -> text:
    args.join(" ")

extern fn rt_cli_run_tests(args: [text], gc_log: i64, gc_off: i64) -> i64

fn cli_run_tests(args: [text], gc_log: bool, gc_off: bool) -> i64:
    # Use Rust SFFI test runner directly (interpret_file path fails in native binaries)
    var gc_log_flag = 0
    var gc_off_flag = 0
    if gc_log:
        gc_log_flag = 1
    if gc_off:
        gc_off_flag = 1
    return rt_cli_run_tests(args, gc_log_flag, gc_off_flag)

fn cli_run_verify(args: [text], gc_log: bool, gc_off: bool) -> i64:
    val simple_path = _find_simple_binary()
    var child_args = ["run", "src/app/verify/main.spl"]
    val forwarded = _cli_strip_command(args, "verify")
    for arg in forwarded:
        child_args.push(arg)
    val (stdout, stderr, exit_code) = _cli_process_run(simple_path, child_args)
    if stdout.len() > 0:
        print(stdout)
    if stderr.len() > 0:
        _cli_eprint(stderr)
    exit_code


fn cli_run_migrate(args: [text]) -> i64:
    print "[experimental] Migration tool is not yet implemented"
    1

fn cli_run_mcp(args: [text]) -> i64:
    # Spawn without captured pipes so the MCP child inherits the CLI's stdio.
    # JSON-RPC framing must flow directly between the client and server.
    if args.len() > 1:
        _cli_eprint("error: simple mcp does not accept arguments")
        return 2
    val pid = process_spawn_inherit()
    if pid <= 0:
        _cli_eprint("error: failed to start Simple MCP server")
        return 127
    process_wait(pid, 0)

