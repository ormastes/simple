# UI Test API - JSON Serialization Helpers
#
# Functions for serializing widget state to JSON and parsing
# JSON fields from request bodies.

use common.ui.widget.{UIState, WidgetNode, WidgetProp, widget_props, get_widget_record}

# =========================================================================
# JSON Escaping
# =========================================================================

fn escape_json(s: text) -> text:
    """Escape a string for safe inclusion in a JSON value."""
    var result = ""
    var idx = 0
    while idx < s.len():
        val ch = s[idx]
        if ch == "\"":
            result = "{result}\\\""
        elif ch == "\\":
            result = "{result}\\\\"
        elif ch == "\n":
            result = "{result}\\n"
        elif ch == "\r":
            result = "{result}\\r"
        elif ch == "\t":
            result = "{result}\\t"
        else:
            result = "{result}{ch}"
        idx = idx + 1
    return result

# =========================================================================
# JSON Field Extraction
# =========================================================================

fn extract_json_field(json: text, field: text) -> text:
    """Extract a simple JSON string field value.

    Handles formats like:
        "field": "value"
        "field":"value"
    """
    val search = "\"{field}\""
    val idx = json.find(search)
    if idx < 0:
        return ""

    # Find the colon after the field name
    var pos = idx + search.len()
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1
    if pos >= json.len() or json[pos] != ":":
        return ""
    pos = pos + 1

    # Skip whitespace after colon
    while pos < json.len() and json[pos] == " ":
        pos = pos + 1

    # Expect opening quote
    if pos >= json.len() or json[pos] != "\"":
        return ""
    pos = pos + 1

    # Read until closing quote
    var value = ""
    while pos < json.len() and json[pos] != "\"":
        value = "{value}{json[pos]}"
        pos = pos + 1

    return value

# =========================================================================
# Widget Serialization
# =========================================================================

fn _props_to_json(node_id: text) -> text:
    """Serialize the user-facing props for a node as a JSON object."""
    var result = "{"
    var first = true
    for prop in widget_props():
        if prop.node_id == node_id:
            # Skip internal props (prefixed with ui_)
            if prop.key.starts_with("ui_"):
                pass_do_nothing
            else:
                if not first:
                    result = "{result},"
                result = "{result}\"{escape_json(prop.key)}\":\"{escape_json(prop.value)}\""
                first = false
    result = "{result}}"
    return result

fn element_to_json(node: WidgetNode) -> text:
    """Serialize a WidgetNode to a JSON object with id, kind, visible, focused, enabled, selected, text, props."""
    val record = get_widget_record(node.id)
    if record == nil:
        return "{\"id\":\"{escape_json(node.id)}\",\"kind\":\"panel\",\"visible\":true,\"focused\":false,\"enabled\":true,\"selected\":false,\"text\":\"\",\"props\":{}}"

    val kind = record.kind
    val visible = if record.visible: "true" else: "false"
    val focused = if record.focused: "true" else: "false"
    val enabled = if record.enabled != nil: (if record.enabled: "true" else: "false") else: "true"
    val selected = if record.selected != nil: (if record.selected: "true" else: "false") else: "false"
    val text_val = node.get_prop("text")
    val text_field = if text_val != nil: text_val else: ""
    val props = _props_to_json(node.id)

    return "{\"id\":\"{escape_json(node.id)}\",\"kind\":\"{escape_json(kind)}\",\"visible\":{visible},\"focused\":{focused},\"enabled\":{enabled},\"selected\":{selected},\"text\":\"{escape_json(text_field)}\",\"props\":{props}}"

fn elements_to_json(state: UIState) -> text:
    """Serialize all widgets in the UIState tree as a JSON array."""
    val ids = state.tree.all_widget_ids()
    var result = "["
    var first = true
    for id in ids:
        val record = get_widget_record(id)
        if record != nil:
            if not first:
                result = "{result},"
            val node = WidgetNode(id: id)
            val json = element_to_json(node)
            result = "{result}{json}"
            first = false
    result = "{result}]"
    return result

fn state_to_json(state: UIState) -> text:
    """Serialize the full UI state as a JSON object for the /api/test/state endpoint."""
    val mode = "NORMAL"
    val focused_id = ""
    val title = state.tree.title_text()
    val theme = "default"
    val count = state.tree.all_widget_ids().length()
    return "{\"mode\":\"{escape_json(mode)}\",\"focused_id\":\"{escape_json(focused_id)}\",\"title\":\"{escape_json(title)}\",\"theme\":\"{escape_json(theme)}\",\"element_count\":{count},\"protocol_version\":1}"
