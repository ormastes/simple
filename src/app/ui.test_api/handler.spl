# UI Test API - Request Handler
#
# Shared HTTP request handler for UI test endpoints.
# Used by both web and tui_web backends to expose a test API
# for automated UI testing (click, type, drag, screenshot, etc.).

use common.ui.widget.{UIState, UIEvent, WidgetNode, get_widget_record}
use nogc_sync_mut.ui.session.{UISession}
use common.ui.access.{UiAccessSnapshot, UiAccessNode, UiAccessSurface, ui_access_snapshot_from_state, ui_access_snapshot_to_json, ui_access_surface_to_json, ui_access_events_to_json, ui_access_surface_id_from_canonical, ui_access_widget_id_from_canonical, ui_access_find_node, ui_access_find_nodes, ui_access_node_value, ui_access_resolve_action_name, ui_access_snapshot_to_text, ui_access_supports_value}
use common.ui.access_source.{ui_access_snapshot_envelope_to_json}
use common.ui.access_adapter.{ui_access_default_adapter_registry}
use common.ui.access_vision.{ui_access_vision_capture_to_json}
use common.ui.draw_ir.{
    DRAW_IR_BACKEND_CPU,
    DrawIrCommand,
    DrawIrComposition,
    DrawIrRect,
    draw_ir_batch_with_source,
    draw_ir_box_with_style,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_rect_bounds,
    draw_ir_source_gui_ast,
    draw_ir_style_prop
}
use common.ui.draw_ir_sdn.{draw_ir_to_sdn}
use common.ui.draw_ir_sdn.{sdn_to_draw_ir}
use common.ui.draw_ir_diff.{draw_ir_diff_compositions, draw_ir_diff_report_to_json}
use os.services.llm.ui_access_resolver.{ui_access_resolve_adapter, ui_access_resolve_visual_probe}
use app.ui.test_api.json.{element_to_json, elements_to_json, extract_json_field, escape_json, state_to_json}

val PROTOCOL_VERSION = 1
val DRAW_IR_PROTOCOL_VERSION = 2
val DRAW_IR_CAPABILITY = "draw_ir"
val DRAW_IR_PROTOCOL_VERSION_HEADER = "X-UI-Protocol-Version"

extern fn rt_time_ms() -> u64
extern fn rt_sleep_ms(ms: i64)

# =========================================================================
# Main Handler
# =========================================================================

fn handle_test_request(path: text, method: text, body: text, state: UIState, inject_event: fn(UIEvent), session: UISession?) -> (i32, text, text):
    """Handle an incoming test API request.

    Returns (status_code, content_type, response_body).
    """
    # Strip query string for route matching
    val route = _strip_query(path)

    if method == "POST":
        if route == "/api/test/ui/act":
            return _handle_ui_act(body, inject_event, session)
        elif route == "/api/test/ui/state":
            return _handle_ui_state_post(body, inject_event, session)
        elif route == "/api/test/ui/value":
            return _handle_ui_value_post(body, session)
        elif route == "/api/test/click":
            return _handle_click(body, inject_event)
        elif route == "/api/test/type":
            return _handle_type(body, inject_event)
        elif route == "/api/test/drag":
            return _handle_drag(body, inject_event)
        elif route == "/api/test/submit":
            return _handle_submit(body, inject_event)
        elif route == "/api/test/event":
            return _handle_event(body, inject_event)
        else:
            return (404, "application/json", "{\"error\":\"not_found\",\"message\":\"Route not found\"}")

    elif method == "GET":
        if route == "/api/test/draw-ir":
            val id = _extract_query_param(path, "id")
            return _handle_draw_ir(path, id, state)
        elif route == "/api/test/draw-ir/layout":
            val id = _extract_query_param(path, "id")
            return _handle_draw_ir_layout(path, id, state)
        elif route == "/api/test/draw-ir/diff":
            val from_id = _extract_query_param(path, "from_id")
            val to_id = _extract_query_param(path, "to_id")
            val baseline = _extract_query_param(path, "baseline")
            return _handle_draw_ir_diff(path, from_id, to_id, baseline, state)
        elif route == "/api/test/ui/snapshot":
            return _handle_ui_snapshot(state, session)
        elif route == "/api/test/ui/ensure":
            val surface_id = _extract_query_param(path, "surface_id")
            val canonical_id = _extract_query_param(path, "canonical_id")
            val kind = _extract_query_param(path, "kind")
            val text_query = _extract_query_param(path, "text")
            val focused_only = _extract_query_param(path, "focused_only")
            val expectation = _extract_query_param(path, "expectation")
            val expected_value = _extract_query_param(path, "expected_value")
            val limit_str = _extract_query_param(path, "limit")
            val timeout_str = _extract_query_param(path, "timeout_ms")
            val poll_str = _extract_query_param(path, "poll_ms")
            return _handle_ui_ensure(surface_id, canonical_id, kind, text_query, focused_only, expectation, expected_value, limit_str, timeout_str, poll_str, state, session)
        elif route == "/api/test/ui/query":
            val surface_id = _extract_query_param(path, "surface_id")
            val canonical_id = _extract_query_param(path, "canonical_id")
            val kind = _extract_query_param(path, "kind")
            val text_query = _extract_query_param(path, "text")
            val focused_only = _extract_query_param(path, "focused_only")
            val limit_str = _extract_query_param(path, "limit")
            return _handle_ui_query(surface_id, canonical_id, kind, text_query, focused_only, limit_str, state, session)
        elif route == "/api/test/ui/observe":
            val surface_id = _extract_query_param(path, "surface_id")
            val canonical_id = _extract_query_param(path, "canonical_id")
            val kind = _extract_query_param(path, "kind")
            val text_query = _extract_query_param(path, "text")
            val focused_only = _extract_query_param(path, "focused_only")
            return _handle_ui_observe(surface_id, canonical_id, kind, text_query, focused_only, state, session)
        elif route == "/api/test/ui/surface":
            val id = _extract_query_param(path, "id")
            return _handle_ui_surface(id, state, session)
        elif route == "/api/test/ui/state":
            val surface_id = _extract_query_param(path, "surface_id")
            val canonical_id = _extract_query_param(path, "canonical_id")
            val state_key = _extract_query_param(path, "state_key")
            return _handle_ui_state_get(surface_id, canonical_id, state_key, state, session)
        elif route == "/api/test/ui/adapter_snapshot":
            val surface_id = _extract_query_param(path, "surface_id")
            return _handle_ui_adapter_snapshot(surface_id, session)
        elif route == "/api/test/ui/visual_probe":
            val surface_id = _extract_query_param(path, "surface_id")
            return _handle_ui_visual_probe(surface_id, session)
        elif route == "/api/test/ui/value":
            val canonical_id = _extract_query_param(path, "canonical_id")
            return _handle_ui_value_get(canonical_id, state, session)
        elif route == "/api/test/ui/history":
            val surface_id = _extract_query_param(path, "surface_id")
            val count_str = _extract_query_param(path, "count")
            return _handle_ui_history(surface_id, count_str, session)
        elif route == "/api/test/screenshot":
            return _handle_screenshot(state)
        elif route == "/api/test/element":
            val id = _extract_query_param(path, "id")
            return _handle_element(id, state)
        elif route == "/api/test/elements":
            return _handle_elements(state)
        elif route == "/api/test/state":
            return _handle_state(state)
        elif route == "/api/test/ready":
            return (200, "application/json", "{\"ready\":true,\"protocol_version\":{PROTOCOL_VERSION}}")
        else:
            return (404, "application/json", "{\"error\":\"not_found\",\"message\":\"Route not found\"}")

    else:
        return (405, "application/json", "{\"error\":\"method_not_allowed\",\"message\":\"Method not allowed\"}")

# =========================================================================
# POST Handlers
# =========================================================================

fn _handle_click(body: text, inject_event: fn(UIEvent)) -> (i32, text, text):
    """Handle POST /api/test/click — inject a click action for a widget."""
    val id = extract_json_field(body, "id")
    if id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")
    inject_event(UIEvent.Action(name: "click_{id}"))
    return (200, "application/json", "{\"ok\":true}")

fn _handle_type(body: text, inject_event: fn(UIEvent)) -> (i32, text, text):
    """Handle POST /api/test/type — focus a widget and inject key presses."""
    val id = extract_json_field(body, "id")
    val typed_text = extract_json_field(body, "text")
    if id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")

    # Focus the target widget first
    inject_event(UIEvent.Action(name: "focus_{id}"))

    # Inject a KeyPress for each character
    var idx = 0
    while idx < typed_text.len():
        val ch = typed_text[idx]
        var ch_str = ""
        ch_str = "{ch_str}{ch}"
        inject_event(UIEvent.KeyPress(key: ch_str))
        idx = idx + 1

    return (200, "application/json", "{\"ok\":true}")

fn _handle_drag(body: text, inject_event: fn(UIEvent)) -> (i32, text, text):
    """Handle POST /api/test/drag — focus source, then action to target."""
    val from_id = extract_json_field(body, "from_id")
    val to_id = extract_json_field(body, "to_id")
    if from_id == "" or to_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: from_id or to_id\"}")

    inject_event(UIEvent.Action(name: "focus_{from_id}"))
    inject_event(UIEvent.Action(name: "drag_{from_id}_to_{to_id}"))
    return (200, "application/json", "{\"ok\":true}")

fn _handle_submit(body: text, inject_event: fn(UIEvent)) -> (i32, text, text):
    """Handle POST /api/test/submit — submit a form or dialog."""
    val id = extract_json_field(body, "id")
    if id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")
    inject_event(UIEvent.Action(name: "submit_{id}"))
    return (200, "application/json", "{\"ok\":true}")

fn _handle_event(body: text, inject_event: fn(UIEvent)) -> (i32, text, text):
    """Handle POST /api/test/event — inject a raw UIEvent."""
    val event_type = extract_json_field(body, "event_type")

    match event_type:
        "key":
            var key = extract_json_field(body, "key")
            if key == "":
                key = extract_json_field(body, "text")
            if key == "":
                key = extract_json_field(body, "name")
            if key == "":
                return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: key\"}")
            inject_event(UIEvent.KeyPress(key: key))
            return (200, "application/json", "{\"ok\":true}")
        "action":
            val name = extract_json_field(body, "name")
            if name == "":
                return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: name\"}")
            inject_event(UIEvent.Action(name: name))
            return (200, "application/json", "{\"ok\":true}")
        "quit":
            inject_event(UIEvent.Quit)
            return (200, "application/json", "{\"ok\":true}")
        "focus_next":
            inject_event(UIEvent.FocusNext)
            return (200, "application/json", "{\"ok\":true}")
        "focus_prev":
            inject_event(UIEvent.FocusPrev)
            return (200, "application/json", "{\"ok\":true}")
        "resize":
            val w = extract_json_field(body, "width")
            val h = extract_json_field(body, "height")
            if w == "" or h == "":
                return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: width or height\"}")
            inject_event(UIEvent.Resize(width: w.to_i32(), height: h.to_i32()))
            return (200, "application/json", "{\"ok\":true}")
        _:
            return (400, "application/json", "{\"error\":\"unknown_event_type\",\"message\":\"Unknown event type\"}")

fn _handle_ui_act(body: text, inject_event: fn(UIEvent), session: UISession?) -> (i32, text, text):
    """Handle POST /api/test/ui/act — additive UI access action route."""
    val surface_id = extract_json_field(body, "surface_id")
    val canonical_id = extract_json_field(body, "canonical_id")
    val action = extract_json_field(body, "action")
    val widget_id = ui_access_widget_id_from_canonical(canonical_id)
    var resolved_surface_id = surface_id
    if action == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: action\"}")
    if widget_id == "" and canonical_id != "":
        return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Invalid canonical_id\"}")
    if canonical_id != "":
        resolved_surface_id = ui_access_surface_id_from_canonical(canonical_id)
    if resolved_surface_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: surface_id\"}")
    if session != nil and not session.has_surface(resolved_surface_id):
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {resolved_surface_id}\"}")
    if session != nil:
        session.set_active_surface(resolved_surface_id)
    val action_name = if session != nil and canonical_id != "":
        val node = ui_access_find_node(session.access_snapshot(), canonical_id)
        if node == nil:
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
        ui_access_resolve_action_name(node, action)
    elif widget_id != "":
        "{action}_{widget_id}"
    else:
        action
    inject_event(UIEvent.Action(name: action_name))
    val response_surface_id = if surface_id != "": surface_id else: resolved_surface_id
    return (200, "application/json", "{\"ok\":true,\"surface_id\":\"{escape_json(response_surface_id)}\",\"canonical_id\":\"{escape_json(canonical_id)}\"}")

fn _handle_ui_state_post(body: text, inject_event: fn(UIEvent), session: UISession?) -> (i32, text, text):
    """Handle POST /api/test/ui/state — declarative UI state route."""
    val surface_id = extract_json_field(body, "surface_id")
    val canonical_id = extract_json_field(body, "canonical_id")
    val state_key = extract_json_field(body, "state_key")
    val state_value = extract_json_field(body, "state_value")
    if state_key == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: state_key\"}")
    if session == nil:
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"A live session is required for /api/test/ui/state\"}")

    var resolved_surface_id = surface_id
    if canonical_id != "":
        val widget_id = ui_access_widget_id_from_canonical(canonical_id)
        if widget_id == "":
            return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Invalid canonical_id\"}")
        resolved_surface_id = ui_access_surface_id_from_canonical(canonical_id)
    if state_key == "active":
        if resolved_surface_id == "":
            return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: surface_id\"}")
        if not _is_truthy(state_value):
            return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported state transition: active={escape_json(state_value)}\"}")
        if not session.has_surface(resolved_surface_id):
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {resolved_surface_id}\"}")
        session.set_active_surface(resolved_surface_id)
        return (200, "application/json", "{\"ok\":true,\"surface_id\":\"{escape_json(resolved_surface_id)}\",\"state_key\":\"active\",\"state_value\":\"true\"}")

    if canonical_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: canonical_id\"}")
    if not session.has_surface(resolved_surface_id):
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {resolved_surface_id}\"}")
    val snapshot = session.access_snapshot()
    val node = ui_access_find_node(snapshot, canonical_id)
    if node == nil:
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")

    val action_name = _resolve_ui_state_action(snapshot, node, state_key, state_value)
    if action_name == "":
        return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported state transition: {escape_json(state_key)}={escape_json(state_value)}\"}")
    if action_name == "__noop__":
        return (200, "application/json", "{\"ok\":true,\"surface_id\":\"{escape_json(resolved_surface_id)}\",\"canonical_id\":\"{escape_json(canonical_id)}\",\"state_key\":\"{escape_json(state_key)}\",\"state_value\":\"{escape_json(state_value)}\"}")
    session.set_active_surface(resolved_surface_id)
    inject_event(UIEvent.Action(name: action_name))
    return (200, "application/json", "{\"ok\":true,\"surface_id\":\"{escape_json(resolved_surface_id)}\",\"canonical_id\":\"{escape_json(canonical_id)}\",\"state_key\":\"{escape_json(state_key)}\",\"state_value\":\"{escape_json(state_value)}\",\"action\":\"{escape_json(action_name)}\"}")

fn _handle_ui_value_post(body: text, session: UISession?) -> (i32, text, text):
    """Handle POST /api/test/ui/value — typed value write route."""
    val surface_id = extract_json_field(body, "surface_id")
    val canonical_id = extract_json_field(body, "canonical_id")
    val value = extract_json_field(body, "value")
    if canonical_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: canonical_id\"}")
    if value == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: value\"}")
    if session == nil:
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"A live session is required for /api/test/ui/value\"}")
    val resolved_surface_id = if surface_id != "": surface_id else: ui_access_surface_id_from_canonical(canonical_id)
    if resolved_surface_id == "":
        return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Invalid canonical_id\"}")
    if not session.has_surface(resolved_surface_id):
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {escape_json(resolved_surface_id)}\"}")
    val snapshot = session.access_snapshot()
    val node = ui_access_find_node(snapshot, canonical_id)
    if node == nil:
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
    if not ui_access_supports_value(node):
        return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported value target: {escape_json(canonical_id)}\"}")
    val ok = session.set_surface_widget_value(resolved_surface_id, node.widget_id, value)
    if not ok:
        return (500, "application/json", "{\"error\":\"write_failed\",\"message\":\"Failed to update node value\"}")
    session.set_active_surface(resolved_surface_id)
    val updated = session.access_snapshot()
    val payload = _ui_access_value_response_json(updated, canonical_id)
    return (200, "application/json", "{\"ok\":true," + payload.slice(1, payload.len()))

# =========================================================================
# GET Handlers
# =========================================================================

fn _handle_state(state: UIState) -> (i32, text, text):
    """Handle GET /api/test/state — return application state as JSON."""
    val json = state_to_json(state)
    return (200, "application/json", json)

fn _handle_screenshot(state: UIState) -> (i32, text, text):
    """Handle GET /api/test/screenshot — return full widget tree as HTML snapshot."""
    val root = state.tree.root_node()
    val html = _render_node_html(root, 0)
    val title = state.tree.title_text()
    val page = "<html><head><title>{escape_json(title)}</title></head><body>{html}</body></html>"
    return (200, "text/html", page)

fn _handle_element(id: text, state: UIState) -> (i32, text, text):
    """Handle GET /api/test/element?id=X — return a single element as JSON."""
    if id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")

    val found = state.tree.find_widget(id)
    if found == nil:
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Element not found: {id}\"}")

    val json = element_to_json(found)
    return (200, "application/json", json)

fn _handle_elements(state: UIState) -> (i32, text, text):
    """Handle GET /api/test/elements — return all widgets as JSON array."""
    val json = elements_to_json(state)
    return (200, "application/json", json)

fn _handle_ui_snapshot(state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/snapshot — return canonical access snapshot."""
    val snapshot = _build_access_snapshot(state, session)
    val json = ui_access_snapshot_to_json(snapshot)
    return (200, "application/json", json)

fn _handle_ui_query(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text, limit_str: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/query — structured canonical query route."""
    val snapshot = _build_access_snapshot(state, session)
    if canonical_id != "":
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
    var limit = 50
    if limit_str != "":
        limit = limit_str.to_i32()
    val json = _ui_access_query_response_json(snapshot, surface_id, canonical_id, kind, text_query, _is_truthy(focused_only), limit)
    return (200, "application/json", json)

fn _handle_ui_ensure(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text, expectation: text, expected_value: text, limit_str: text, timeout_str: text, poll_str: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/ensure — semantic goal-state route."""
    var limit = 50
    if limit_str != "":
        limit = limit_str.to_i32()
    var timeout_ms = 0
    if timeout_str != "":
        timeout_ms = timeout_str.to_i64()
    var poll_ms = 25
    if poll_str != "":
        poll_ms = poll_str.to_i64()
    val focused = _is_truthy(focused_only)
    val started = rt_time_ms()
    var snapshot = _build_access_snapshot(state, session)
    var result = _ui_access_ensure_response_json(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value, 0)
    while session != nil and timeout_ms > 0 and not result.contains("\"satisfied\":true") and (rt_time_ms() - started) < timeout_ms:
        if poll_ms > 0:
            rt_sleep_ms(poll_ms)
        snapshot = _build_access_snapshot(state, session)
        result = _ui_access_ensure_response_json(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value, 0)
    val elapsed_ms = rt_time_ms() - started
    val json = _ui_access_ensure_response_json(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value, elapsed_ms.to_i64())
    return (200, "application/json", json)

fn _handle_ui_observe(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/observe — declarative read route."""
    val snapshot = _build_access_snapshot(state, session)
    if canonical_id != "":
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
        var surfaces: [UiAccessSurface] = []
        for surface in snapshot.surfaces:
            if surface.surface_id == node.surface_id:
                surfaces = surfaces.push(surface)
        val filtered = UiAccessSnapshot(
            protocol_version: snapshot.protocol_version,
            mode: snapshot.mode,
            active_surface: snapshot.active_surface,
            surfaces: surfaces,
            nodes: [node],
            recent_events: []
        )
        return (200, "application/json", ui_access_snapshot_to_json(filtered))
    if kind != "" or text_query != "" or focused_only != "":
        val focused = _is_truthy(focused_only)
        val matches = _ui_access_find_nodes(snapshot, surface_id, kind, text_query, focused, 50)
        val filtered = UiAccessSnapshot(
            protocol_version: snapshot.protocol_version,
            mode: snapshot.mode,
            active_surface: snapshot.active_surface,
            surfaces: snapshot.surfaces,
            nodes: matches,
            recent_events: []
        )
        return (200, "text/plain", ui_access_snapshot_to_text(filtered))
    if surface_id != "":
        return _handle_ui_surface(surface_id, state, session)
    return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing selector: surface_id, canonical_id, kind, text, or focused_only\"}")

fn _handle_ui_state_get(surface_id: text, canonical_id: text, state_key: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/state — declarative state read route."""
    val snapshot = _build_access_snapshot(state, session)
    if canonical_id != "":
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
        if state_key == "":
            return _handle_ui_observe(surface_id, canonical_id, "", "", "", state, session)
        val node_value = _node_state_value(node, state_key)
        if node_value == nil:
            return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported state key: {escape_json(state_key)}\"}")
        return (200, "application/json", "{\"canonical_id\":\"{escape_json(canonical_id)}\",\"state_key\":\"{escape_json(state_key)}\",\"state_value\":\"{escape_json(node_value)}\"}")
    if surface_id != "":
        val surface = _find_surface(snapshot, surface_id)
        if surface == nil:
            return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {escape_json(surface_id)}\"}")
        if state_key == "":
            return _handle_ui_surface(surface_id, state, session)
        val surface_value = _surface_state_value(surface, state_key)
        if surface_value == nil:
            return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported state key: {escape_json(state_key)}\"}")
        return (200, "application/json", "{\"surface_id\":\"{escape_json(surface_id)}\",\"state_key\":\"{escape_json(state_key)}\",\"state_value\":\"{escape_json(surface_value)}\"}")
    return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: surface_id or canonical_id\"}")

fn _handle_ui_value_get(canonical_id: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/value — typed value read route."""
    if canonical_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: canonical_id\"}")
    val snapshot = _build_access_snapshot(state, session)
    val node = ui_access_find_node(snapshot, canonical_id)
    if node == nil:
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Canonical node not found: {escape_json(canonical_id)}\"}")
    if not ui_access_supports_value(node):
        return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"Unsupported value target: {escape_json(canonical_id)}\"}")
    return (200, "application/json", _ui_access_value_response_json(snapshot, canonical_id))

fn _handle_ui_adapter_snapshot(surface_id: text, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/adapter_snapshot — additive adapter envelope route."""
    if session == nil:
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"A live session is required for /api/test/ui/adapter_snapshot\"}")
    val registry = ui_access_default_adapter_registry()
    val result = ui_access_resolve_adapter(session, registry, surface_id)
    match result:
        Ok(envelope):
            return (200, "application/json", ui_access_snapshot_envelope_to_json(envelope))
        Err(e):
            return (400, "application/json", "{\"error\":\"invalid_field\",\"message\":\"{escape_json(e)}\"}")

fn _handle_ui_visual_probe(surface_id: text, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/visual_probe — additive vision sidecar route."""
    if session == nil:
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"A live session is required for /api/test/ui/visual_probe\"}")
    val capture = ui_access_resolve_visual_probe(session, surface_id)
    return (200, "application/json", ui_access_vision_capture_to_json(capture))

fn _handle_ui_surface(surface_id: text, state: UIState, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/surface?id=X — return one surface and its nodes."""
    if surface_id == "":
        return (400, "application/json", "{\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")
    val snapshot = _build_access_snapshot(state, session)
    val surface = _find_surface(snapshot, surface_id)
    if surface == nil:
        return (404, "application/json", "{\"error\":\"element_not_found\",\"message\":\"Surface not found: {surface_id}\"}")
    val json = ui_access_surface_to_json(surface)
    return (200, "application/json", json)

fn _handle_ui_history(surface_id: text, count_str: text, session: UISession?) -> (i32, text, text):
    """Handle GET /api/test/ui/history — return recent access events."""
    if session == nil:
        return (200, "application/json", "[]")
    var count = 20
    if count_str != "":
        count = count_str.to_i32()
    val persisted = session.access_persisted_events(surface_id, count.to_i64())
    val events = match persisted:
        Ok(found):
            found
        Err(_):
            if surface_id == "":
                session.access_recent_events(count)
            else:
                session.access_recent_surface_events(surface_id, count)
    val json = ui_access_events_to_json(events)
    return (200, "application/json", json)

fn _handle_draw_ir(path: text, id: text, state: UIState) -> (i32, text, text):
    """Handle GET /api/test/draw-ir — optional Protocol v2 Draw IR extension."""
    if not _draw_ir_capability_enabled(path):
        return _draw_ir_capability_denied()
    val composition = _build_state_draw_ir_composition(state, id)
    val sdn = draw_ir_to_sdn(composition)
    val count = _draw_ir_command_count(composition)
    val json = "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"enabled\":true,\"format\":\"sdn\",\"schema\":\"{escape_json(composition.schema)}\",\"composition_id\":\"{escape_json(composition.composition_id)}\",\"scene_key\":\"{escape_json(composition.scene_key)}\",\"command_count\":{count},\"sdn\":\"{escape_json(sdn)}\"}"
    return (200, "application/vnd.simple.draw-ir+json", json)

fn _handle_draw_ir_layout(path: text, id: text, state: UIState) -> (i32, text, text):
    """Handle GET /api/test/draw-ir/layout?id=X — return layout metadata."""
    if not _draw_ir_capability_enabled(path):
        return _draw_ir_capability_denied()
    if id == "":
        return (400, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"error\":\"missing_field\",\"message\":\"Missing required field: id\"}")
    val composition = _build_state_draw_ir_composition(state, "")
    val command = _draw_ir_find_command(composition, id)
    if command == nil:
        return (404, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"error\":\"element_not_found\",\"message\":\"Draw IR node not found: {escape_json(id)}\"}")
    val json = "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"id\":\"{escape_json(command.component_id)}\",\"kind\":\"{escape_json(command.kind)}\",\"geometry\":{_draw_ir_geometry_json(command)},\"border_rect\":{_draw_ir_rect_json(command.border_rect)},\"content_rect\":{_draw_ir_rect_json(command.content_rect)},\"hit_rect\":{_draw_ir_rect_json(command.hit_rect)},\"clip_rect\":{_draw_ir_rect_json(command.clip_rect)},\"computed_style\":{_draw_ir_style_json(command)}}"
    return (200, "application/vnd.simple.draw-ir+json", json)

fn _handle_draw_ir_diff(path: text, from_id: text, to_id: text, baseline: text, state: UIState) -> (i32, text, text):
    """Handle GET /api/test/draw-ir/diff — compare Draw IR nodes or baselines."""
    if not _draw_ir_capability_enabled(path):
        return _draw_ir_capability_denied()
    val composition = _build_state_draw_ir_composition(state, "")
    if baseline != "":
        val baseline_composition = _draw_ir_baseline_composition(baseline, composition)
        val report = draw_ir_diff_compositions(baseline_composition, composition)
        val report_json = draw_ir_diff_report_to_json(report)
        val json = "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"mode\":\"baseline\",\"diff\":{report_json}}"
        return (200, "application/vnd.simple.draw-ir+json", json)
    if from_id == "" or to_id == "":
        return (400, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"error\":\"missing_field\",\"message\":\"Missing required field: from_id or to_id\"}")
    val from_cmd = _draw_ir_find_command(composition, from_id)
    val to_cmd = _draw_ir_find_command(composition, to_id)
    if from_cmd == nil:
        return (404, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"error\":\"element_not_found\",\"message\":\"Draw IR node not found: {escape_json(from_id)}\"}")
    if to_cmd == nil:
        return (404, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"error\":\"element_not_found\",\"message\":\"Draw IR node not found: {escape_json(to_id)}\"}")
    val style_changed = if _draw_ir_style_json(from_cmd) == _draw_ir_style_json(to_cmd): "false" else: "true"
    val json = "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"from_id\":\"{escape_json(from_id)}\",\"to_id\":\"{escape_json(to_id)}\",\"dx\":{to_cmd.x - from_cmd.x},\"dy\":{to_cmd.y - from_cmd.y},\"dwidth\":{to_cmd.width - from_cmd.width},\"dheight\":{to_cmd.height - from_cmd.height},\"style_changed\":{style_changed}}"
    return (200, "application/vnd.simple.draw-ir+json", json)

fn _draw_ir_baseline_composition(baseline: text, current: DrawIrComposition) -> DrawIrComposition:
    if baseline == "current":
        return current
    if baseline == "empty":
        return draw_ir_composition("empty", current.scene_key, current.backend_target, [])
    sdn_to_draw_ir(_query_percent_decode(baseline))

fn _draw_ir_capability_enabled(path: text) -> bool:
    val capability = _extract_query_param(path, "capability")
    return capability == DRAW_IR_CAPABILITY or capability == "draw-ir"

fn _draw_ir_capability_denied() -> (i32, text, text):
    return (403, "application/vnd.simple.draw-ir+json", "{\"protocol_version\":{DRAW_IR_PROTOCOL_VERSION},\"capability\":\"{DRAW_IR_CAPABILITY}\",\"enabled\":false,\"error\":\"capability_required\",\"message\":\"Draw IR inspection requires capability=draw_ir\"}")

fn _build_state_draw_ir_composition(state: UIState, filter_id: text) -> DrawIrComposition:
    var commands: [DrawIrCommand] = []
    var index = 0
    val ids = state.tree.all_widget_ids()
    for widget_id in ids:
        if filter_id == "" or widget_id == filter_id:
            commands = commands.push(_draw_ir_command_for_widget(state, widget_id, index))
        index = index + 1
    val height = if index > 0: index * 28 + 8 else: 32
    val batch = draw_ir_batch_with_source(
        "ui-test-current",
        DRAW_IR_BACKEND_CPU,
        draw_ir_embedding_config("main", "ui-state", 0, 0, 240, height, 0, 1000, true),
        commands,
        draw_ir_source_gui_ast("ui.test_api", "ui-state", "1")
    )
    draw_ir_composition("ui-test-current", "ui-test-current", DRAW_IR_BACKEND_CPU, [batch])

fn _draw_ir_command_for_widget(state: UIState, widget_id: text, index: i32) -> DrawIrCommand:
    val node = WidgetNode(id: widget_id)
    val record = get_widget_record(widget_id)
    val x = 8
    val y = 8 + index * 28
    val width = 200
    val height = 22
    var kind = "panel"
    var visible = true
    var focused = state.focused_id == widget_id
    if record != nil:
        kind = record.kind
        visible = record.visible
        focused = record.focused or focused
    val text_value = node.get_prop("text")
    val style = [
        draw_ir_style_prop("id", widget_id),
        draw_ir_style_prop("kind", kind),
        draw_ir_style_prop("source", "gui_ast"),
        draw_ir_style_prop("visible", if visible: "true" else: "false"),
        draw_ir_style_prop("focused", if focused: "true" else: "false"),
        draw_ir_style_prop("text", text_value)
    ]
    draw_ir_box_with_style(
        widget_id,
        x,
        y,
        width,
        height,
        0x335577u32,
        draw_ir_rect_bounds(x, y, width, height),
        draw_ir_rect_bounds(x + 2, y + 2, width - 4, height - 4),
        draw_ir_rect_bounds(x, y, width, height),
        draw_ir_rect_bounds(0, 0, 240, 8 + (index + 1) * 28),
        style
    )

fn _draw_ir_command_count(composition: DrawIrComposition) -> i32:
    var count = 0
    for batch in composition.batches:
        count = count + batch.commands.len()
    count

fn _draw_ir_find_command(composition: DrawIrComposition, id: text) -> DrawIrCommand?:
    for batch in composition.batches:
        for command in batch.commands:
            if command.component_id == id:
                return command
    nil

fn _draw_ir_geometry_json(command: DrawIrCommand) -> text:
    "{\"x\":{command.x},\"y\":{command.y},\"width\":{command.width},\"height\":{command.height}}"

fn _draw_ir_rect_json(rect: DrawIrRect) -> text:
    val present = if rect.present: "true" else: "false"
    "{\"present\":{present},\"x\":{rect.x},\"y\":{rect.y},\"width\":{rect.width},\"height\":{rect.height}}"

fn _draw_ir_style_json(command: DrawIrCommand) -> text:
    var json = "{"
    var first = true
    for prop in command.computed_style:
        if first:
            first = false
        else:
            json = "{json},"
        json = "{json}\"{escape_json(prop.key)}\":\"{escape_json(prop.value)}\""
    "{json}}"

# =========================================================================
# Query String Helpers
# =========================================================================

fn _strip_query(path: text) -> text:
    """Strip the query string from a path, returning just the route."""
    val qidx = path.find("?")
    if qidx < 0:
        return path
    return path.slice(0, qidx)

fn _extract_query_param(path: text, param: text) -> text:
    """Extract a query parameter value from a path like /route?key=value&k2=v2."""
    val qidx = path.find("?")
    if qidx < 0:
        return ""

    val query = path.slice(qidx + 1, path.len())
    val search = "{param}="
    val pidx = query.find(search)
    if pidx < 0:
        return ""

    val start = pidx + search.len()
    # Find the end of the value (next & or end of string)
    var end_pos = start
    while end_pos < query.len() and query[end_pos] != "&":
        end_pos = end_pos + 1

    return query.slice(start, end_pos)

fn _query_percent_decode(value: text) -> text:
    var decoded = ""
    var i = 0
    while i < value.len():
        if value[i] == "%" and i + 2 < value.len():
            val code = value.slice(i + 1, i + 3).upper()
            if code == "20":
                decoded = "{decoded} "
                i = i + 3
            elif code == "09":
                decoded = "{decoded}\t"
                i = i + 3
            elif code == "0A":
                decoded = "{decoded}\n"
                i = i + 3
            elif code == "0D":
                decoded = "{decoded}\r"
                i = i + 3
            elif code == "3D":
                decoded = "{decoded}="
                i = i + 3
            elif code == "25":
                decoded = "{decoded}%"
                i = i + 3
            elif code == "26":
                decoded = "{decoded}&"
                i = i + 3
            else:
                decoded = "{decoded}{value[i]}"
                i = i + 1
        elif value[i] == "+":
            decoded = "{decoded} "
            i = i + 1
        else:
            decoded = "{decoded}{value[i]}"
            i = i + 1
    decoded

fn _build_access_snapshot(state: UIState, session: UISession?) -> UiAccessSnapshot:
    if session != nil:
        return session.access_snapshot()
    return ui_access_snapshot_from_state(state, [])

fn _resolve_ui_state_action(snapshot: UiAccessSnapshot, node: UiAccessNode, state_key: text, state_value: text) -> text:
    val lower_key = state_key.lower()
    if lower_key == "focus" or lower_key == "focused":
        if not _is_truthy(state_value):
            return ""
        return ui_access_resolve_action_name(node, "focus")
    if lower_key == "invoke" or lower_key == "invoked" or lower_key == "press" or lower_key == "pressed":
        if not _is_truthy(state_value):
            return ""
        return ui_access_resolve_action_name(node, "invoke")
    if lower_key == "submit" or lower_key == "submitted":
        if not _is_truthy(state_value):
            return ""
        return ui_access_resolve_action_name(node, "submit")
    if lower_key == "select":
        if not _is_truthy(state_value):
            return ""
        if node.selected:
            return "__noop__"
        return ui_access_resolve_action_name(node, "select")
    if lower_key == "selected":
        if _state_matches_toggle_target(node.selected, state_value):
            return "__noop__"
        if _is_truthy(state_value):
            return ui_access_resolve_action_name(node, "select")
        if _is_falsy(state_value):
            return ui_access_resolve_action_name(node, "toggle")
        return ""
    if lower_key == "toggle" or lower_key == "toggled" or lower_key == "checked" or lower_key == "expanded":
        if _state_matches_toggle_target(node.selected, state_value):
            return "__noop__"
        return ui_access_resolve_action_name(node, "toggle")
    if lower_key == "action":
        if state_value == "":
            return ""
        return ui_access_resolve_action_name(node, state_value)
    return ""

fn _is_truthy(value: text) -> bool:
    val lower = value.lower()
    return lower == "true" or lower == "1" or lower == "yes" or lower == "on"

fn _is_falsy(value: text) -> bool:
    val lower = value.lower()
    return lower == "false" or lower == "0" or lower == "no" or lower == "off"

fn _state_matches_toggle_target(selected: bool, desired: text) -> bool:
    if _is_truthy(desired):
        return selected
    if _is_falsy(desired):
        return not selected
    return false

fn _find_surface(snapshot: UiAccessSnapshot, surface_id: text) -> UiAccessSurface?:
    for surface in snapshot.surfaces:
        if surface.surface_id == surface_id:
            return surface
    return nil

fn _ui_access_find_nodes(snapshot: UiAccessSnapshot, surface_id: text, kind: text, text_query: text, focused_only: bool, limit: i32) -> [UiAccessNode]:
    val found = ui_access_find_nodes(snapshot, surface_id, kind, text_query, limit)
    if not focused_only:
        return found
    var filtered: [UiAccessNode] = []
    for node in found:
        if node.focused:
            filtered = filtered.push(node)
    filtered

fn _ui_access_nodes_snapshot(snapshot: UiAccessSnapshot, nodes: [UiAccessNode]) -> UiAccessSnapshot:
    UiAccessSnapshot(
        protocol_version: snapshot.protocol_version,
        snapshot_revision: snapshot.snapshot_revision,
        mode: snapshot.mode,
        active_surface: snapshot.active_surface,
        surfaces: snapshot.surfaces,
        nodes: nodes,
        recent_events: []
    )

fn _ui_access_query_response_json(snapshot: UiAccessSnapshot, surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: bool, limit: i32) -> text:
    var matches: [UiAccessNode] = []
    if canonical_id != "":
        val node = ui_access_find_node(snapshot, canonical_id)
        if node != nil:
            matches = [node]
    else:
        matches = _ui_access_find_nodes(snapshot, surface_id, kind, text_query, focused_only, limit)
    val filtered = _ui_access_nodes_snapshot(snapshot, matches)
    "{\"surface_id\":\"{escape_json(surface_id)}\",\"canonical_id\":\"{escape_json(canonical_id)}\",\"kind\":\"{escape_json(kind)}\",\"text\":\"{escape_json(text_query)}\",\"focused_only\":{_json_bool(focused_only)},\"match_count\":{matches.len()},\"snapshot\":{ui_access_snapshot_to_json(filtered)}}"

fn _ui_access_ensure_response_json(snapshot: UiAccessSnapshot, surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: bool, limit: i32, expectation: text, expected_value: text, elapsed_ms: i64) -> text:
    val matches = _ui_access_find_for_ensure(snapshot, surface_id, canonical_id, kind, text_query, focused_only, limit)
    val effective_expectation = if expectation == "": "exists" else: expectation
    val satisfied = _ui_access_expectation_satisfied(matches, effective_expectation, expected_value)
    val query_json = _ui_access_query_response_json(snapshot, surface_id, canonical_id, kind, text_query, focused_only, limit)
    "{\"surface_id\":\"{escape_json(surface_id)}\",\"canonical_id\":\"{escape_json(canonical_id)}\",\"kind\":\"{escape_json(kind)}\",\"text\":\"{escape_json(text_query)}\",\"focused_only\":{_json_bool(focused_only)},\"expectation\":\"{escape_json(effective_expectation)}\",\"expected_value\":\"{escape_json(expected_value)}\",\"satisfied\":{_json_bool(satisfied)},\"match_count\":{matches.len()},\"elapsed_ms\":{elapsed_ms},\"query\":{query_json}}"

fn _ui_access_find_for_ensure(snapshot: UiAccessSnapshot, surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: bool, limit: i32) -> [UiAccessNode]:
    if canonical_id != "":
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return []
        if focused_only and not node.focused:
            return []
        return [node]
    _ui_access_find_nodes(snapshot, surface_id, kind, text_query, focused_only, limit)

fn _ui_access_expectation_satisfied(matches: [UiAccessNode], expectation: text, expected_value: text) -> bool:
    val count = matches.len()
    val lower = expectation.lower()
    if lower == "absent":
        return count == 0
    if lower == "match_count":
        if expected_value == "":
            return false
        return count == expected_value.to_i32()
    if lower == "focused":
        for node in matches:
            if node.focused:
                return true
        return false
    if lower == "enabled":
        for node in matches:
            if node.enabled:
                return true
        return false
    if lower == "disabled":
        for node in matches:
            if not node.enabled:
                return true
        return false
    if lower == "selected" or lower == "checked" or lower == "expanded":
        for node in matches:
            if node.selected:
                return true
        return false
    if lower == "unselected" or lower == "unchecked" or lower == "collapsed":
        for node in matches:
            if not node.selected:
                return true
        return false
    if lower == "value":
        for node in matches:
            if ui_access_node_value(node) == expected_value:
                return true
        return false
    count > 0

fn _ui_access_value_response_json(snapshot: UiAccessSnapshot, canonical_id: text) -> text:
    val node = ui_access_find_node(snapshot, canonical_id)
    if node == nil:
        return "{}"
    "{\"canonical_id\":\"{escape_json(canonical_id)}\",\"value\":\"{escape_json(ui_access_node_value(node))}\"}"

fn _json_bool(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _node_state_value(node: UiAccessNode, state_key: text) -> text?:
    val lower_key = state_key.lower()
    if lower_key == "canonical_id":
        return node.canonical_id
    if lower_key == "surface_id":
        return node.surface_id
    if lower_key == "widget_id":
        return node.widget_id
    if lower_key == "kind":
        return node.kind
    if lower_key == "visible":
        return if node.visible: "true" else: "false"
    if lower_key == "focused":
        return if node.focused: "true" else: "false"
    if lower_key == "enabled":
        return if node.enabled: "true" else: "false"
    if lower_key == "selected" or lower_key == "checked" or lower_key == "expanded":
        return if node.selected: "true" else: "false"
    if lower_key == "text":
        return node.text_value
    if lower_key == "actions" or lower_key == "action_names":
        return _join_text(node.action_names, ",")
    return nil

fn _surface_state_value(surface: UiAccessSurface, state_key: text) -> text?:
    val lower_key = state_key.lower()
    if lower_key == "surface_id":
        return surface.surface_id
    if lower_key == "title":
        return surface.title
    if lower_key == "active":
        return if surface.active: "true" else: "false"
    if lower_key == "window_id":
        return surface.window_id
    if lower_key == "app_id":
        return surface.app_id
    if lower_key == "root_canonical_id":
        return surface.root_canonical_id
    return nil

fn _join_text(values: [text], separator: text) -> text:
    var out = ""
    var first = true
    for value in values:
        if first:
            out = value
            first = false
        else:
            out = "{out}{separator}{value}"
    return out

# =========================================================================
# HTML Snapshot Rendering
# =========================================================================

fn _render_node_html(node: WidgetNode, depth: i32) -> text:
    """Render a widget node and its children as an HTML snippet for screenshots."""
    val record = get_widget_record(node.id)
    var kind = "panel"
    var visible = true
    if record != nil:
        kind = record.kind
        visible = record.visible

    if not visible:
        return ""

    var indent = ""
    var d = 0
    while d < depth:
        indent = "{indent}  "
        d = d + 1

    # Render children
    var children_html = ""
    val child_nodes = node.children()
    for child in child_nodes:
        val child_html = _render_node_html(child, depth + 1)
        children_html = "{children_html}{child_html}"

    # Get text content prop if present
    val text_content = node.get_prop("text")

    var inner = ""
    if text_content != "":
        inner = "{escape_json(text_content)}"
    inner = "{inner}{children_html}"

    return "{indent}<div data-id=\"{escape_json(node.id)}\" data-kind=\"{escape_json(kind)}\">{inner}</div>\n"
