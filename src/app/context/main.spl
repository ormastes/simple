# Simple Context Pack Generator (Written in Simple)
#
# Extracts minimal context for LLM consumption (#890-893)
#
# Usage:
#   context <file.spl> [target] [options]
#
# Features:
#   - 90% reduction in LLM context tokens
#   - Extracts only symbols used by target
#   - Multiple export formats (JSON, Markdown, Text)

# I/O imports
use app.io.context_ops (context_generate, context_stats, context_index_packs, context_query_index, context_sql_index_packs, context_sql_query_packs, context_sql_query_packs_by_source, context_args_allow_sourceless_sql_query, context_get_args, context_file_exists, context_file_write)
use std.cli.cli_util (has_flag)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}

fn print_help():
    print "Simple Context Pack Generator"
    print ""
    print "Usage:"
    print "  context <file.spl> [target] [options]"
    print ""
    print "Arguments:"
    print "  <file.spl>  Source file to analyze"
    print "  [target]    Target function/module (default: file name)"
    print ""
    print "Options:"
    print "  --format=<fmt>  Output format: json, markdown, text (default: markdown)"
    print "  --json          Shorthand for --format=json"
    print "  --text          Shorthand for --format=text"
    print "  -o <file>       Output to file instead of stdout"
    print "  --stats         Show context reduction statistics"
    print "  --index         Emit a local context-pack index"
    print "  --query=<text>  Query the local context-pack index for this source"
    print "  --sql           Use Simple embedded SQLite for index/query"
    print "  --db=<path>     SQLite index database path (default: in-memory)"
    print "  --source-filter=<text>  Filter SQL query rows by stored source path"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help      Show this help"
    print ""
    print "Examples:"
    print "  context app.spl"
    print "  context app.spl UserService --json"
    print "  context app.spl calculate --format=markdown -o context.md"
    print "  context app.spl --index -o context.index"
    print "  context app.spl --query=handler --text"
    print "  context app.spl --sql --query=handler --db=.cache/context.db"
    print "  context --sql --query=handler --db=.cache/context.db --source-filter=app.spl"
    print ""
    print "Features:"
    print "  - 90% reduction in LLM context tokens"
    print "  - Extracts only symbols used by target"
    print "  - Multiple export formats (JSON, Markdown, Text)"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _get_context_args(all_args: [text]) -> [text]:
    var args: [text] = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("/app/context/main.spl") or all_args[scan_idx] == "src/app/context/main.spl":
            start_idx = scan_idx + 1
        scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    if args.len() > 0 and args[0] == "context":
        var trimmed_args: [text] = []
        var arg_idx = 1
        while arg_idx < args.len():
            trimmed_args.push(args[arg_idx])
            arg_idx = arg_idx + 1
        return trimmed_args
    args

fn get_file_stem(path: text) -> text:
    # Extract filename without extension
    val parts = path.split("/")
    val filename = parts[parts.len() - 1]
    val name_parts = filename.split(".")
    if name_parts.len() > 1:
        name_parts[0]
    else:
        filename

fn main() -> i64:
    val all_args = context_get_args()
    val args = _get_context_args(all_args)
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        print "context: {log_opts.error}"
        return 1

    # Check for help
    if args.len() == 0 or has_flag(args, "-h") or has_flag(args, "--help"):
        print_help()
        if args.len() == 0:
            return 1
        else:
            return 0

    # Parse arguments
    var source_path = ""
    var source_idx = 0
    var scan_arg_idx = 0
    while scan_arg_idx < args.len():
        val arg = args[scan_arg_idx]
        if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            scan_arg_idx = scan_arg_idx + 1
        elif _is_log_option(arg):
            val _unused = 0
        elif not arg.starts_with("-"):
            source_path = arg
            source_idx = scan_arg_idx
            break
        scan_arg_idx = scan_arg_idx + 1

    var sourceless_query = ""
    var sourceless_db_path = ""
    var sourceless_format = "markdown"
    var sourceless_output_file = ""
    var sourceless_source_filter = ""
    if source_path == "" and context_args_allow_sourceless_sql_query(args):
        var source_less_idx = 0
        while source_less_idx < args.len():
            val arg = args[source_less_idx]
            if arg == "--json":
                sourceless_format = "json"
            elif arg == "--text":
                sourceless_format = "text"
            elif arg.starts_with("--format="):
                sourceless_format = arg[9:]
            elif arg.starts_with("--query="):
                sourceless_query = arg[8:]
            elif arg.starts_with("--db="):
                sourceless_db_path = arg[5:]
            elif arg.starts_with("--source-filter="):
                sourceless_source_filter = arg[16:]
            elif arg == "-o":
                if source_less_idx + 1 < args.len():
                    sourceless_output_file = args[source_less_idx + 1]
                    source_less_idx = source_less_idx + 1
            elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                source_less_idx = source_less_idx + 1
            source_less_idx = source_less_idx + 1

        val output = context_sql_query_packs_by_source([], "", sourceless_query, sourceless_source_filter, sourceless_db_path, sourceless_format)
        if output == "":
            if log_opts.log_mode == "json":
                print "{\"command\":\"context\",\"status\":\"error\",\"source\":\"\"}"
            else:
                print "context: failed to query SQL context database"
            return 1
        if sourceless_output_file != "":
            if not context_file_write(sourceless_output_file, output):
                print "context: cannot write {sourceless_output_file}"
                return 1
            if log_opts.progress != "summary":
                val progress_line = render_progress(log_opts.progress, 1, 1, "context")
                if progress_line != "":
                    print progress_line
            print "Context written to {sourceless_output_file}"
            return 0
        if log_opts.progress != "summary" and log_opts.log_mode != "json":
            val progress_line = render_progress(log_opts.progress, 1, 1, "context")
            if progress_line != "":
                print progress_line
        print output
        return 0

    if source_path == "":
        print_help()
        return 1

    # Check file exists
    if not context_file_exists(source_path):
        if log_opts.progress != "summary" and log_opts.log_mode != "json":
            val progress_line = render_progress(log_opts.progress, 0, 1, "context")
            if progress_line != "":
                print progress_line
        if log_opts.log_mode == "json":
            print "{\"command\":\"context\",\"status\":\"error\",\"source\":\"{source_path}\"}"
        else:
            print "context: cannot read {source_path}: file not found"
        return 1

    # Default target is file stem
    var target = get_file_stem(source_path)
    var format = "markdown"
    var output_file = ""
    var show_stats = false
    var show_index = false
    var query = ""
    var use_sql = false
    var db_path = ""
    var source_filter = ""

    # Parse remaining arguments
    var j = source_idx + 1
    while j < args.len():
        val arg = args[j]
        if arg == "--json":
            format = "json"
        elif arg == "--text":
            format = "text"
        elif arg == "--stats":
            show_stats = true
        elif arg == "--index":
            show_index = true
        elif arg.starts_with("--query="):
            query = arg[8:]
        elif arg == "--sql":
            use_sql = true
        elif arg.starts_with("--db="):
            db_path = arg[5:]
        elif arg.starts_with("--source-filter="):
            source_filter = arg[16:]
        elif arg == "-o":
            if j + 1 < args.len():
                output_file = args[j + 1]
                j = j + 1
        elif arg.starts_with("--format="):
            format = arg[9:]
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            j = j + 1
        elif _is_log_option(arg):
            val _unused = 0
        elif not arg.starts_with("-"):
            target = arg
        j = j + 1

    # Show stats if requested
    if show_stats:
        val stats = context_stats(source_path, target)
        if stats != "":
            print "Context Statistics:"
            print stats
            print ""

    # Generate context, index, or query output.
    var output = ""
    if query != "":
        if use_sql:
            output = context_sql_query_packs_by_source([source_path], target, query, source_filter, db_path, format)
        else:
            val index = context_index_packs([source_path], target, "text")
            output = context_query_index(index, query, format)
    elif show_index:
        if use_sql:
            output = context_sql_index_packs([source_path], target, db_path, format)
        else:
            output = context_index_packs([source_path], target, format)
    else:
        output = context_generate(source_path, target, format)
    if output == "":
        if log_opts.log_mode == "json":
            print "{\"command\":\"context\",\"status\":\"error\",\"source\":\"{source_path}\"}"
        else:
            print "context: failed to generate context for {source_path}"
        return 1

    # Write output
    if output_file != "":
        if not context_file_write(output_file, output):
            print "context: cannot write {output_file}"
            return 1
        if log_opts.progress != "summary":
            val progress_line = render_progress(log_opts.progress, 1, 1, "context")
            if progress_line != "":
                print progress_line
        print "Context written to {output_file}"
        return 0

    if log_opts.progress != "summary" and log_opts.log_mode != "json":
        val progress_line = render_progress(log_opts.progress, 1, 1, "context")
        if progress_line != "":
            print progress_line
    print output
    return 0
