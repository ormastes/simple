# Simple Context Pack Generator (Written in Simple)
#
# Extracts minimal context for LLM consumption (#890-893)
#
# Usage:
#   context <file.spl> [target] [options]
#
# Features:
#   - 90% reduction in LLM context tokens
#   - Extracts only symbols used by target
#   - Multiple export formats (JSON, Markdown, Text)

# I/O imports
use app.io.cli_ops (context_generate, context_stats, cli_get_args, cli_file_exists)
use app.io.mod (file_write)
use std.cli.cli_util (has_flag)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

fn print_help():
    print "Simple Context Pack Generator"
    print ""
    print "Usage:"
    print "  context <file.spl> [target] [options]"
    print ""
    print "Arguments:"
    print "  <file.spl>  Source file to analyze"
    print "  [target]    Target function/module (default: file name)"
    print ""
    print "Options:"
    print "  --format=<fmt>  Output format: json, markdown, text (default: markdown)"
    print "  --json          Shorthand for --format=json"
    print "  --text          Shorthand for --format=text"
    print "  -o <file>       Output to file instead of stdout"
    print "  --stats         Show context reduction statistics"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help      Show this help"
    print ""
    print "Examples:"
    print "  context app.spl"
    print "  context app.spl UserService --json"
    print "  context app.spl calculate --format=markdown -o context.md"
    print ""
    print "Features:"
    print "  - 90% reduction in LLM context tokens"
    print "  - Extracts only symbols used by target"
    print "  - Multiple export formats (JSON, Markdown, Text)"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _get_context_args(all_args: [text]) -> [text]:
    var args: [text] = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("main.spl"):
            start_idx = scan_idx + 1
        scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn get_file_stem(path: text) -> text:
    # Extract filename without extension
    val parts = path.split("/")
    val filename = parts[parts.len() - 1]
    val name_parts = filename.split(".")
    if name_parts.len() > 1:
        name_parts[0]
    else:
        filename

fn main() -> i64:
    val all_args = cli_get_args()
    val args = _get_context_args(all_args)
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("context", log_opts.error)
        return 1

    # Check for help
    if args.len() == 0 or has_flag(args, "-h") or has_flag(args, "--help"):
        print_help()
        if args.len() == 0:
            return 1
        else:
            return 0

    # Parse arguments
    var source_path = ""
    var source_idx = 0
    var scan_arg_idx = 0
    while scan_arg_idx < args.len():
        val arg = args[scan_arg_idx]
        if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            scan_arg_idx = scan_arg_idx + 1
        elif _is_log_option(arg):
            val _unused = 0
        elif not arg.starts_with("-"):
            source_path = arg
            source_idx = scan_arg_idx
            break
        scan_arg_idx = scan_arg_idx + 1
    if source_path == "":
        print_help()
        return 1

    # Check file exists
    if not cli_file_exists(source_path):
        if log_opts.progress != "summary" and log_opts.log_mode != "json":
            val progress_line = render_progress(log_opts.progress, 0, 1, "context")
            if progress_line != "":
                print progress_line
        if log_opts.log_mode == "json":
            print "{\"command\":\"context\",\"status\":\"error\",\"source\":\"{source_path}\"}"
        else:
            print "context: cannot read {source_path}: file not found"
        return 1

    # Default target is file stem
    var target = get_file_stem(source_path)
    var format = "markdown"
    var output_file = ""
    var show_stats = false

    # Parse remaining arguments
    var j = source_idx + 1
    while j < args.len():
        val arg = args[j]
        if arg == "--json":
            format = "json"
        elif arg == "--text":
            format = "text"
        elif arg == "--stats":
            show_stats = true
        elif arg == "-o":
            if j + 1 < args.len():
                output_file = args[j + 1]
                j = j + 1
        elif arg.starts_with("--format="):
            format = arg[9:]
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            j = j + 1
        elif _is_log_option(arg):
            val _unused = 0
        elif not arg.starts_with("-"):
            target = arg
        j = j + 1

    # Show stats if requested
    if show_stats:
        val stats = context_stats(source_path, target)
        if stats != "":
            print "Context Statistics:"
            print stats
            print ""

    # Generate context
    val output = context_generate(source_path, target, format)
    if output == "":
        if log_opts.log_mode == "json":
            print "{\"command\":\"context\",\"status\":\"error\",\"source\":\"{source_path}\"}"
        else:
            print "context: failed to generate context for {source_path}"
        return 1

    # Write output
    if output_file != "":
        if not file_write(output_file, output):
            print "context: cannot write {output_file}"
            return 1
        if log_opts.progress != "summary":
            val progress_line = render_progress(log_opts.progress, 1, 1, "context")
            if progress_line != "":
                print progress_line
        print "Context written to {output_file}"
        return 0

    if log_opts.progress != "summary" and log_opts.log_mode != "json":
        val progress_line = render_progress(log_opts.progress, 1, 1, "context")
        if progress_line != "":
            print progress_line
    print output
    return 0
