# Package Signing
# Ed25519 / HMAC-SHA256 signature types and hex helpers for .spk packages.

# Signature metadata stored in the registry index.
class PackageSignature:
    signer_fingerprint: text
    signature: text
    algorithm: text
    signed_at: text

fn hex_to_bytes(hex: text) -> [u8]:
    pass_todo

fn bytes_to_hex(data: [u8]) -> text:
    pass_todo

fn hex_digit_value(ch: i64) -> i64:
    if ch >= 48 and ch <= 57:
        return ch - 48
    if ch >= 65 and ch <= 70:
        return ch - 55
    if ch >= 97 and ch <= 102:
        return ch - 87
    -1
