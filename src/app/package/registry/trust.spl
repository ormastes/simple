# Trust Chain
# Trusted signer database and trust level definitions.

# Trust level for a package signer.
enum TrustLevel:
    RegistryTrusted
    UserTrusted
    Untrusted
    Revoked

# A single trusted signer entry.
class TrustedSigner:
    fingerprint: text
    name: text
    trust_level: TrustLevel
    revoked: bool

# Database of trusted signers.
class TrustStore:
    signers: [TrustedSigner]

impl TrustStore:
    static fn empty() -> TrustStore:
        TrustStore(signers: [])

    static fn default() -> TrustStore:
        pass_todo

    fn get_trust_level(fingerprint: text) -> TrustLevel:
        for signer in self.signers:
            if signer.fingerprint == fingerprint:
                return signer.trust_level
        TrustLevel.Untrusted

    fn is_revoked(fingerprint: text) -> bool:
        for signer in self.signers:
            if signer.fingerprint == fingerprint:
                return signer.revoked
        false

    fn add_signer(signer: TrustedSigner):
        self.signers.push(signer)
