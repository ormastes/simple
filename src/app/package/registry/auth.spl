# Registry Authentication
# GitHub PAT token management for GHCR access.

use app.package.registry.types (Credentials)
use app.package.registry.config (default_config)

fn has_credentials() -> bool:
    val creds = resolve_credentials()
    creds.token != ""

fn print_auth_error():
    print "Error: not authenticated with the Simple package registry."
    print "Run 'simple login' to authenticate, or set SIMPLE_TOKEN env var."

fn get_token() -> text:
    val creds = resolve_credentials()
    creds.token

fn resolve_credentials() -> Credentials:
    val token = std.env.get("SIMPLE_TOKEN") ?? ""
    Credentials(token: token, token_type: "Bearer")

fn save_token(token: text) -> bool:
    # Token persistence requires filesystem access; return false as stub
    false
