# Simple CLI — `var` command: inspect the variants/ resolver overlay.
#
# Pure-Simple front-end over the resolver's variant logic
# (compiler.module_resolver.var_resolution). Reads config/var.sdn (active profile,
# overridable with --var-profile) and variants/__init__.spl, then:
#   simple var list              groups + selectable values + select_default
#   simple var check             validate manifest+selections (E-VAR001..004)
#   simple var roots             active candidate roots (selected before default)
#   simple var resolve a.b.c     candidate files for a stable import + first hit
# Options: --var-profile <name>  override the active config profile.

use std.cli.cli_util (get_cli_args)
use app.io.mod (file_read, file_exists, cwd)
use compiler.module_resolver.var_resolution.{
    VarManifest, VarSelection,
    var_parse_manifest, var_config_selections, var_candidate_roots,
    var_module_candidates, var_validate
}

fn print_help():
    print "Usage: simple var <subcommand> [options]"
    print ""
    print "Subcommands:"
    print "  list                 Show variant groups, values, and select_default"
    print "  check                Validate the manifest against active selections"
    print "  roots                Show active candidate roots (selected before default)"
    print "  resolve <module>     Show candidate files for a stable import (dotted)"
    print ""
    print "Options:"
    print "  --var-profile <name> Override the active config/var.sdn profile"
    print "  -h, --help           Show this help"

fn flag_value(args: [text], flag: text) -> text:
    var i = 0
    while i < args.len() - 1:
        if args[i] == flag:
            return args[i + 1]
        i = i + 1
    ""

fn first_non_flag(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if a == "var":
            i = i + 1
            continue
        if a.starts_with("-"):
            if a == "--var-profile":
                i = i + 2
                continue
            i = i + 1
            continue
        return a
    ""

fn load_manifest(root: text) -> VarManifest?:
    val path = "{root}/variants/__init__.spl"
    if not file_exists(path):
        return nil
    Some(var_parse_manifest(file_read(path)))

fn load_selections(root: text, manifest: VarManifest, profile_override: text) -> [VarSelection]:
    val cfg = "{root}/config/var.sdn"
    if not file_exists(cfg):
        return []
    var_config_selections(file_read(cfg), profile_override)

fn cmd_list(manifest: VarManifest):
    print "variant groups (order = highest precedence first):"
    for g in manifest.groups:
        print "  {g.name}: values={g.values.join(\", \")} select_default={g.select_default}"

fn cmd_check(manifest: VarManifest, selections: [VarSelection]) -> i64:
    # `auto` is a select_default sentinel resolved at build time (host detection),
    # not a concrete group value — exclude it from static validation.
    var concrete: [VarSelection] = []
    for s in selections:
        if s.value != "auto":
            concrete = concrete + [s]
    val errs = var_validate(manifest, concrete)
    if errs.len() == 0:
        print "ok: manifest + selections valid"
        return 0
    print "INVALID:"
    for e in errs:
        print "  {e}"
    1

fn cmd_roots(manifest: VarManifest, selections: [VarSelection]):
    val roots = var_candidate_roots("variants", manifest, selections)
    print "active candidate roots:"
    for r in roots:
        print "  {r}"

fn cmd_resolve(root: text, manifest: VarManifest, selections: [VarSelection], module: text):
    val roots = var_candidate_roots("variants", manifest, selections)
    val segments = module.split(".")
    val cands = var_module_candidates(root, roots, segments)
    print "resolve {module}:"
    var hit = ""
    for c in cands:
        val mark = if file_exists(c) and hit == "":
            hit = c
            "*"
        else:
            " "
        print "  {mark} {c}"
    if hit == "":
        print "  (no variant file; falls through to src/stdlib)"
    else:
        print "  -> first existing: {hit}"

fn first_non_flag_after(args: [text], after: text) -> text:
    var i = 0
    var seen = false
    while i < args.len():
        if args[i] == after:
            seen = true
            i = i + 1
            continue
        if seen and not args[i].starts_with("-"):
            return args[i]
        i = i + 1
    ""

fn main() -> i64:
    val args = get_cli_args()
    if args.len() == 0 or args.contains("-h") or args.contains("--help"):
        print_help()
        return 0

    val sub = first_non_flag(args)
    val profile = flag_value(args, "--var-profile")
    val root = cwd()

    match load_manifest(root):
        case nil:
            print "error: no variants/__init__.spl found at {root}/variants"
            return 1
        case Some(manifest):
            val selections = load_selections(root, manifest, profile)
            if sub == "list":
                cmd_list(manifest)
                return 0
            if sub == "check":
                return cmd_check(manifest, selections)
            if sub == "roots":
                cmd_roots(manifest, selections)
                return 0
            if sub == "resolve":
                val module = first_non_flag_after(args, "resolve")
                if module == "":
                    print "error: `var resolve` needs a module path (e.g. crypto.provider)"
                    return 1
                cmd_resolve(root, manifest, selections, module)
                return 0
            print_help()
            0
