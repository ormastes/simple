@allow(unnamed_duplicate_typed_args)
# Serial MCP Protocol — initialize + tools/list responses

use app.simple_lsp_mcp.json_helpers.{LB, RB, Q, SB_L, SB_R, jp, js, jo1, jo2, jo3, escape_json, jsonrpc_result}

fn make_init_response(id: text) -> text:
    if INIT_CACHE != "":
        return jsonrpc_result(id, INIT_CACHE)

    val tools_cap = jo1(jp("listChanged", "false"))
    var caps = LB()
    caps = caps + jp("tools", tools_cap)
    caps = caps + "," + jp("logging", LB() + RB())
    caps = caps + RB()

    val server_info = jo2(
        jp("name", js(SERVER_NAME)),
        jp("version", js(SERVER_VERSION))
    )

    var result = LB()
    result = result + jp("protocolVersion", js("2025-06-18"))
    result = result + "," + jp("capabilities", caps)
    result = result + "," + jp("instructions", js("Serial MCP — SSH over serial and raw serial port access. 5 tools: ssh_serial_connect, ssh_serial_exec, serial_open, serial_write, serial_read."))
    result = result + "," + jp("serverInfo", server_info)
    result = result + RB()

    INIT_CACHE = result
    jsonrpc_result(id, result)

fn make_tools_list(id: text) -> text:
    if TOOLS_CACHE != "":
        return jsonrpc_result(id, TOOLS_CACHE)

    var tool_parts: [text] = []
    tool_parts.push(make_tool_ssh_serial_connect())
    tool_parts.push(make_tool_ssh_serial_exec())
    tool_parts.push(make_tool_serial_open())
    tool_parts.push(make_tool_serial_write())
    tool_parts.push(make_tool_serial_read())

    val tools = SB_L() + tool_parts.join(",") + SB_R()
    val result = jo1(jp("tools", tools))
    TOOLS_CACHE = result
    jsonrpc_result(id, result)

fn make_prop_str(name: text, desc: text) -> text:
    jp(name, jo2(jp("type", js("string")), jp("description", js(desc))))

fn make_prop_int(name: text, desc: text) -> text:
    jp(name, jo2(jp("type", js("integer")), jp("description", js(desc))))

fn make_tool_schema(name: text, desc: text, props_body: text, required_list: text) -> text:
    var props = LB() + props_body + RB()
    val input_schema = LB() + jp("type", js("object")) + "," + jp("properties", props) + "," + jp("required", SB_L() + required_list + SB_R()) + RB()
    jo3(jp("name", js(name)), jp("description", js(desc)), jp("inputSchema", input_schema))

fn make_tool_ssh_serial_connect() -> text:
    var props = ""
    props = props + make_prop_str("device", "Serial device path, e.g. /dev/ttyUSB0")
    props = props + "," + make_prop_int("baud", "Baud rate (9600 / 19200 / 115200 / 230400)")
    props = props + "," + make_prop_str("user", "SSH username on remote target")
    props = props + "," + make_prop_str("path", "Transport path: socat (default) or native")
    val req = js("device") + "," + js("baud") + "," + js("user")
    make_tool_schema("ssh_serial_connect", "Validate SSH-over-serial connection parameters. Returns session info for ssh_serial_exec.", props, req)

fn make_tool_ssh_serial_exec() -> text:
    var props = ""
    props = props + make_prop_str("device", "Serial device path")
    props = props + "," + make_prop_int("baud", "Baud rate")
    props = props + "," + make_prop_str("user", "SSH username")
    props = props + "," + make_prop_str("cmd", "Shell command to run on the remote target")
    props = props + "," + make_prop_str("path", "Transport path: socat (default) or native")
    val req = js("device") + "," + js("baud") + "," + js("user") + "," + js("cmd")
    make_tool_schema("ssh_serial_exec", "Run a shell command on a remote device over a serial SSH connection. Returns stdout, stderr, and exit_code.", props, req)

fn make_tool_serial_open() -> text:
    var props = ""
    props = props + make_prop_str("device", "Serial device path")
    props = props + "," + make_prop_int("baud", "Baud rate")
    val req = js("device") + "," + js("baud")
    make_tool_schema("serial_open", "Open a serial port in raw mode. Returns a handle (integer) for serial_read/write.", props, req)

fn make_tool_serial_write() -> text:
    var props = ""
    props = props + make_prop_int("handle", "Serial handle from serial_open")
    props = props + "," + make_prop_str("data", "Data string to send to the serial port")
    val req = js("handle") + "," + js("data")
    make_tool_schema("serial_write", "Write data to an open serial port. Returns number of bytes written.", props, req)

fn make_tool_serial_read() -> text:
    var props = ""
    props = props + make_prop_int("handle", "Serial handle from serial_open")
    props = props + "," + make_prop_int("max_bytes", "Maximum bytes to read (default 1024)")
    val req = js("handle")
    make_tool_schema("serial_read", "Read data from an open serial port. Blocks until data arrives (5s timeout).", props, req)
