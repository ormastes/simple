#![allow(unnamed_duplicate_typed_args)]
# Simple Debugger — Command Parsing and Dispatch
# Maps GDB-like commands to backend debugger operations.

extern fn stdout_write(s: text)
extern fn stdout_flush()
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

use app.cli_debug.format.{
    fmt_help_main, fmt_help_break, fmt_help_print, fmt_help_info,
    fmt_error, fmt_session_created,
    fmt_session_closed, fmt_program_started, fmt_bold
}

use app.mcpgdb.debug_backend_common.{
    run_session_command, create_debugger_process, make_session,
    stop_session_process, choose_workspace_root, ps_is_alive
}

use app.mcpgdb.state.{
    DebugSession,
    next_session_id, set_current_session,
    put_session, remove_session
}


# ============================================================================
# State
# ============================================================================

var SDB_BREAKPOINT_NUM: i64 = 0
var SDB_TARGET_PROGRAM: text = ""
var SDB_SESSION: DebugSession? = nil
var SDB_BACKEND: text = "gdb"          # gdb | lldb | interpreter | smf | native

# ============================================================================
# Output Helpers
# ============================================================================

fn sdb_print(msg: text):
    print msg

fn sdb_print_raw(output: text):
    """Print raw backend output, stripping JSON wrapper if present."""
    if output == "":
        return
    # Backend returns JSON: {"status":"ok","command":"...","output":"..."}
    # Extract the output field
    if output.starts_with("{"):
        val out_field = extract_json_field(output, "output")
        val status = extract_json_field(output, "status")
        if status == "error":
            val msg = extract_json_field(output, "message")
            sdb_print(fmt_error(msg))
            return
        if out_field != "":
            print out_field
        return
    print output

fn extract_json_field(json: text, field: text) -> text:
    """Simple JSON field extractor — looks for "field":"value" pattern."""
    val key = "\"" + field + "\":"
    val idx_opt = json.index_of(key)
    match idx_opt:
        Some(idx):
            val after = json.substring(idx + key.len())
            if after.starts_with("\""):
                # String value — find closing quote (handle escaped quotes)
                val content = after.substring(1)
                var end_idx = 0
                var escaped = false
                while end_idx < content.len():
                    val ch = content.substring(end_idx, end_idx + 1)
                    if escaped:
                        escaped = false
                    elif ch == "\\":
                        escaped = true
                    elif ch == "\"":
                        break
                    end_idx = end_idx + 1
                val raw = content.substring(0, end_idx)
                # Unescape basic sequences
                var result = raw
                result = result.replace("\\n", "\n")
                result = result.replace("\\t", "\t")
                result = result.replace("\\\"", "\"")
                result = result.replace("\\\\", "\\")
                return result
            else:
                # Non-string value (number, bool, null)
                var end_idx = 0
                while end_idx < after.len():
                    val ch = after.substring(end_idx, end_idx + 1)
                    if ch == "," or ch == "}":
                        break
                    end_idx = end_idx + 1
                return after.substring(0, end_idx).trim()
        nil:
            return ""

# ============================================================================
# Session Management
# ============================================================================

fn sdb_ensure_session() -> bool:
    """Ensure a debug session exists. Returns true if ready."""
    match SDB_SESSION:
        Some(session):
            if session.process_pid != "" and ps_is_alive(session.process_pid):
                return true
            sdb_print(fmt_error("debug session died"))
            SDB_SESSION = nil
            return false
        nil:
            sdb_print(fmt_error("no debug session. Use 'file <program>' to load an executable."))
            return false

fn sdb_run_cmd(command: text) -> text:
    """Run a command on the current debug session."""
    match SDB_SESSION:
        Some(session):
            val result = run_session_command(session, command, false)
            return extract_json_field(result, "output")
        nil:
            return ""

fn sdb_detect_backend(program: text) -> text:
    """Auto-detect backend from file extension/type."""
    if program.ends_with(".spl"):
        return "interpreter"
    if program.ends_with(".smf"):
        return "smf"
    # Native binary — check if it's a compiled Simple program or generic
    if SDB_BACKEND != "gdb":
        return SDB_BACKEND
    "gdb"

fn sdb_create_session(backend: text):
    val session_id = next_session_id()
    var session = make_session(session_id, backend, choose_workspace_root(""))
    val (updated, err) = create_debugger_process(session)
    if err != "":
        sdb_print(fmt_error(err))
        return
    put_session(updated)
    set_current_session(session_id)
    SDB_SESSION = Some(updated)
    SDB_BACKEND = backend
    sdb_print(fmt_session_created(session_id, backend))

fn cmd_backend(args: text):
    """Set or show the debug backend."""
    if args == "":
        sdb_print("Current backend: " + fmt_bold(SDB_BACKEND))
        sdb_print("")
        sdb_print("Available backends:")
        sdb_print("  gdb           GDB (native binaries, default)")
        sdb_print("  lldb          LLDB (native binaries, macOS)")
        sdb_print("  interpreter   Simple interpreter (debug .spl files directly)")
        sdb_print("  smf           SMF loader (debug .smf bytecode)")
        sdb_print("  native        Native ptrace (debug compiled Simple binaries)")
        sdb_print("")
        sdb_print("Usage: backend <name>")
        sdb_print("  Auto-detected from file extension: .spl → interpreter, .smf → smf")
        return
    val new_backend = args.trim()
    if (new_backend == "gdb" or new_backend == "lldb" or
        new_backend == "interpreter" or new_backend == "smf" or
        new_backend == "native"):
        SDB_BACKEND = new_backend
        sdb_print("Backend set to: " + fmt_bold(new_backend))
        # Close existing session if backend changed
        match SDB_SESSION:
            Some(session):
                if session.backend != new_backend:
                    stop_session_process(session)
                    remove_session(session.session_id)
                    SDB_SESSION = nil
                    sdb_print("Previous session closed (backend changed).")
            nil: pass
    else:
        sdb_print(fmt_error("unknown backend '" + new_backend + "'. Use: gdb, lldb, interpreter, smf, native"))

# ============================================================================
# Command Handlers
# ============================================================================

fn cmd_file(args: text):
    """Load a program for debugging. Auto-detects backend from extension."""
    if args == "":
        sdb_print("Usage: file <program>")
        sdb_print("  file app.spl         Debug with interpreter backend")
        sdb_print("  file app.smf         Debug with SMF loader backend")
        sdb_print("  file ./my_binary     Debug with GDB/LLDB backend")
        return
    SDB_TARGET_PROGRAM = args
    val detected = sdb_detect_backend(args)

    # Create session with detected or selected backend
    match SDB_SESSION:
        nil:
            sdb_create_session(detected)
        Some(session):
            # If backend changed, restart session
            if session.backend != detected:
                stop_session_process(session)
                remove_session(session.session_id)
                SDB_SESSION = nil
                sdb_create_session(detected)
    if not sdb_ensure_session():
        return
    val output = sdb_run_cmd("file " + args)
    if output != "":
        sdb_print(output)
    else:
        sdb_print("Reading symbols from " + fmt_bold(args) + "... (backend: " + detected + ")")

fn cmd_run(args: text):
    if not sdb_ensure_session():
        return
    if SDB_TARGET_PROGRAM != "" and args == "":
        sdb_print(fmt_program_started(SDB_TARGET_PROGRAM))
    val cmd = if args != "": "run " + args else: "run"
    val output = sdb_run_cmd(cmd)
    sdb_print(output)

