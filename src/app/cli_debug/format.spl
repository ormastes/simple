# Simple Debugger — Output Formatting
# Converts structured debug data to human-readable GDB-style text output.

# ============================================================================
# ANSI Colors (for terminal output)
# ============================================================================

fn fmt_bold(s: text) -> text:
    "\x1b[1m" + s + "\x1b[0m"

fn fmt_dim(s: text) -> text:
    "\x1b[2m" + s + "\x1b[0m"

fn fmt_red(s: text) -> text:
    "\x1b[31m" + s + "\x1b[0m"

fn fmt_green(s: text) -> text:
    "\x1b[32m" + s + "\x1b[0m"

fn fmt_yellow(s: text) -> text:
    "\x1b[33m" + s + "\x1b[0m"

fn fmt_blue(s: text) -> text:
    "\x1b[34m" + s + "\x1b[0m"

fn fmt_cyan(s: text) -> text:
    "\x1b[36m" + s + "\x1b[0m"

# ============================================================================
# Breakpoint Output
# ============================================================================

fn fmt_breakpoint_set(num: i64, file: text, line: i64) -> text:
    "Breakpoint " + str(num) + " at " + fmt_bold(file) + ":" + fmt_yellow(str(line))

fn fmt_breakpoint_hit(num: i64, func_name: text, file: text, line: i64) -> text:
    "\nBreakpoint " + str(num) + ", " + fmt_bold(func_name) + " () at " + file + ":" + str(line)

fn fmt_breakpoint_deleted(num: i64) -> text:
    "Deleted breakpoint " + str(num)

fn fmt_breakpoint_list_header() -> text:
    fmt_bold("Num     Type           Disp Enb Address    What")

fn fmt_breakpoint_entry(num: i64, enabled: bool, file: text, line: i64) -> text:
    val enb = if enabled: "y" else: "n"
    val num_str = str(num)
    val padding = "        ".substring(0, 8 - num_str.len())
    num_str + padding + "breakpoint     keep " + enb + "   " + file + ":" + str(line)

# ============================================================================
# Stack Trace Output
# ============================================================================

fn fmt_frame(num: i64, func_name: text, args: text, file: text, line: i64) -> text:
    val prefix = "#" + str(num)
    val padding = if num < 10: "  " else: " "
    prefix + padding + fmt_bold(func_name) + " (" + args + ")" + " at " + fmt_cyan(file) + ":" + fmt_yellow(str(line))

fn fmt_frame_selected(num: i64, func_name: text, file: text, line: i64) -> text:
    "#" + str(num) + "  " + fmt_bold(func_name) + " () at " + file + ":" + str(line)

# ============================================================================
# Variable Output
# ============================================================================

fn fmt_variable(name: text, value: text) -> text:
    fmt_bold(name) + " = " + value

fn fmt_variable_typed(name: text, type_name: text, value: text) -> text:
    fmt_bold(name) + " = (" + fmt_cyan(type_name) + ") " + value

# ============================================================================
# Source Listing
# ============================================================================

fn fmt_source_line(line_num: i64, content: text, is_current: bool) -> text:
    val num_str = str(line_num)
    val padding = "     ".substring(0, 5 - num_str.len())
    val marker = if is_current: fmt_green("=>") else: "  "
    marker + padding + fmt_dim(num_str) + "\t" + content

# ============================================================================
# Status Messages
# ============================================================================

fn fmt_program_started(program: text) -> text:
    "Starting program: " + fmt_bold(program)

fn fmt_program_exited(code: i64) -> text:
    if code == 0:
        "[Inferior 1 exited normally]"
    else:
        "[Inferior 1 exited with code " + fmt_red(str(code)) + "]"

fn fmt_program_stopped(reason: text, func_name: text, file: text, line: i64) -> text:
    val reason_str = if reason == "breakpoint-hit":
        "Breakpoint hit"
    elif reason == "end-stepping-range":
        "Step completed"
    elif reason == "signal-received":
        "Signal received"
    else:
        reason
    reason_str + ", " + fmt_bold(func_name) + " () at " + file + ":" + str(line)

fn fmt_session_created(session_id: text, backend: text) -> text:
    "Debug session " + fmt_bold(session_id) + " created (backend: " + backend + ")"

fn fmt_session_closed(session_id: text) -> text:
    "Session " + session_id + " closed."

fn fmt_error(msg: text) -> text:
    fmt_red("Error: ") + msg

fn fmt_warning(msg: text) -> text:
    fmt_yellow("Warning: ") + msg

fn fmt_info(msg: text) -> text:
    msg

# ============================================================================
# Thread Info
# ============================================================================

fn fmt_thread_entry(id: i64, name: text, func_name: text, file: text, line: i64, is_current: bool) -> text:
    val marker = if is_current: "* " else: "  "
    marker + str(id) + "  Thread " + name + "  " + func_name + " () at " + file + ":" + str(line)

# ============================================================================
# Help Text
# ============================================================================

fn fmt_help_main() -> text:
    var h = "List of commands:\n\n"
    h = h + fmt_bold("Running") + "\n"
    h = h + "  run (r)           Start debugged program\n"
    h = h + "  start             Start and break at main\n"
    h = h + "  continue (c, fg)  Continue program after stop\n"
    h = h + "  next (n)          Step over (source line)\n"
    h = h + "  nexti (ni)        Step over (machine instruction)\n"
    h = h + "  step (s)          Step into (source line)\n"
    h = h + "  stepi (si)        Step into (machine instruction)\n"
    h = h + "  finish (fin)      Execute until function returns\n"
    h = h + "  until (u)         Continue until line past current\n"
    h = h + "  return            Return from current function\n"
    h = h + "  jump (j)          Jump to location\n"
    h = h + "  kill (k)          Kill the running program\n"
    h = h + "  signal            Continue with signal\n\n"
    h = h + fmt_bold("Breakpoints") + "\n"
    h = h + "  break (b)         Set breakpoint at location\n"
    h = h + "  tbreak (tb)       Set temporary breakpoint\n"
    h = h + "  rbreak (rb)       Set breakpoint on regex-matching functions\n"
    h = h + "  hbreak            Set hardware breakpoint\n"
    h = h + "  delete (d)        Delete breakpoint(s)\n"
    h = h + "  clear             Delete breakpoints at location\n"
    h = h + "  enable            Enable breakpoint(s)\n"
    h = h + "  disable           Disable breakpoint(s)\n"
    h = h + "  condition (cond)  Set conditional breakpoint\n"
    h = h + "  commands          Set commands for breakpoint\n"
    h = h + "  info break        List breakpoints\n\n"
    h = h + fmt_bold("Watchpoints") + "\n"
    h = h + "  watch             Stop when expression changes\n"
    h = h + "  awatch            Stop on read or write (access)\n"
    h = h + "  rwatch            Stop on read\n"
    h = h + "  catch             Set catchpoint (throw, catch, signal, fork, exec)\n\n"
    h = h + fmt_bold("Data / Variables") + "\n"
    h = h + "  print (p)         Print expression value\n"
    h = h + "  printf            Print with C format string\n"
    h = h + "  display           Auto-display on each stop\n"
    h = h + "  undisplay         Remove auto-display\n"
    h = h + "  ptype             Print type definition\n"
    h = h + "  whatis            Print expression type\n"
    h = h + "  x                 Examine memory (x/FMT ADDR)\n"
    h = h + "  set               Set variable or debugger option\n"
    h = h + "  show              Show debugger option\n\n"
    h = h + fmt_bold("Stack") + "\n"
    h = h + "  backtrace (bt)    Print call stack\n"
    h = h + "  frame (f)         Select stack frame\n"
    h = h + "  up                Move up one frame\n"
    h = h + "  down (do)         Move down one frame\n"
    h = h + "  info frame        Frame info\n"
    h = h + "  info locals       Local variables\n"
    h = h + "  info args         Function arguments\n\n"
    h = h + fmt_bold("Source / Assembly") + "\n"
    h = h + "  list (l)          List source code\n"
    h = h + "  disassemble       Disassemble function or range\n"
    h = h + "  directory (dir)   Add source search path\n\n"
    h = h + fmt_bold("Threads") + "\n"
    h = h + "  thread            Switch thread / apply commands\n"
    h = h + "  info threads      List all threads\n\n"
    h = h + fmt_bold("Process / Remote") + "\n"
    h = h + "  file              Load executable\n"
    h = h + "  attach            Attach to running process\n"
    h = h + "  detach            Detach from process\n"
    h = h + "  target            Connect to remote target\n"
    h = h + "  handle            Configure signal handling\n\n"
    h = h + fmt_bold("Memory") + "\n"
    h = h + "  dump              Write memory to file\n"
    h = h + "  restore           Restore memory from file\n\n"
    h = h + fmt_bold("Backend") + "\n"
    h = h + "  backend           Show/switch backend (gdb, lldb, interpreter, smf, native)\n\n"
    h = h + fmt_bold("Scripting / Misc") + "\n"
    h = h + "  source            Execute commands from file\n"
    h = h + "  define            Define custom command\n"
    h = h + "  shell (!)         Execute shell command\n"
    h = h + "  help (h)          Show this help\n"
    h = h + "  quit (q)          Exit debugger\n\n"
    h = h + "Type " + fmt_bold("help <command>") + " for details on a command.\n"
    h = h + "Unknown commands are passed directly to the backend debugger."
    h

fn fmt_help_break() -> text:
    var h = "Usage: break [LOCATION]\n\n"
    h = h + "Set breakpoint at specified location.\n\n"
    h = h + "  break main          Break at function 'main'\n"
    h = h + "  break file.spl:42   Break at file.spl line 42\n"
    h = h + "  break 42            Break at line 42 in current file\n"
    h = h + "  break               Break at current location"
    h

fn fmt_help_print() -> text:
    var h = "Usage: print [EXPRESSION]\n\n"
    h = h + "Print value of expression.\n\n"
    h = h + "  print x         Print variable x\n"
    h = h + "  print x + y     Print expression result\n"
    h = h + "  print *ptr      Print dereferenced pointer"
    h

fn fmt_help_info() -> text:
    var h = "Usage: info [ITEM]\n\n"
    h = h + "Show various information.\n\n"
    h = h + "  info breakpoints (info break)   List breakpoints\n"
    h = h + "  info locals                     Show local variables\n"
    h = h + "  info args                       Show function arguments\n"
    h = h + "  info threads                    Show threads\n"
    h = h + "  info frame                      Show current frame"
    h
