# Simple Debugger (sdb) — GDB-like Interactive CLI
#
# Usage:
#   bin/simple debug                           # Start debugger (no program loaded)
#   bin/simple debug <program>                 # Start and load (auto-detect backend)
#   bin/simple debug app.spl                   # Debug .spl with interpreter backend
#   bin/simple debug app.smf                   # Debug .smf with SMF loader backend
#   bin/simple debug ./binary                  # Debug native with GDB backend
#   bin/simple debug --backend lldb ./binary   # Force LLDB backend
#   bin/simple debug -i app.spl               # Force interpreter backend
#
# Provides a (sdb) prompt with GDB-compatible commands and
# human-readable text output formatting.

extern fn input() -> text
extern fn stdout_write(s: text)
extern fn stdout_flush()
extern fn rt_cli_get_args() -> [text]

use app.cli_debug.commands.{
    dispatch_command, cmd_file, cmd_quit,
    sdb_create_session, sdb_detect_backend,
    SDB_TARGET_PROGRAM, SDB_BACKEND
}
use app.cli_debug.format.{fmt_bold, fmt_dim, fmt_cyan}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

# ============================================================================
# State
# ============================================================================

var SDB_RUNNING: bool = true

# ============================================================================
# Banner
# ============================================================================

fn print_banner():
    print "Simple Debugger (sdb) 0.1.0"
    print "GDB-compatible CLI for the Simple Language toolchain."
    print "Backends: gdb, lldb, interpreter (.spl), smf (.smf), native"
    print "Type " + fmt_bold("help") + " for commands, " + fmt_bold("backend") + " to switch backend, " + fmt_bold("quit") + " to exit."
    print ""

fn print_usage():
    print "Simple Debugger (sdb) 0.1.0"
    print ""
    print "Usage:"
    print "  simple debug [--backend TYPE] [program] [args...]"
    print "  simple debug --help"
    print ""
    print "Backends: gdb, lldb, interpreter, smf, native"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

# ============================================================================
# REPL Loop
# ============================================================================

fn read_line(prompt: text) -> text:
    stdout_write(prompt)
    stdout_flush()
    input() ?? ""

fn run_debug_repl() -> i64:
    print_banner()

    # Parse CLI args: bin/simple debug [--backend TYPE] [program] [args...]
    val all_args = rt_cli_get_args()
    # Strip leading args up to and including "debug" command
    var args: [text] = []
    var found_debug = false
    for a in all_args:
        if found_debug:
            args.push(a)
        elif a == "debug":
            found_debug = true
    var program = ""
    var run_args = ""
    var i = 0
    while i < args.len():
        if args[i] == "--backend" and i + 1 < args.len():
            SDB_BACKEND = args[i + 1]
            i = i + 2
            continue
        elif args[i] == "--interpreter" or args[i] == "-i":
            SDB_BACKEND = "interpreter"
            i = i + 1
            continue
        elif args[i] == "--lldb":
            SDB_BACKEND = "lldb"
            i = i + 1
            continue
        elif program == "":
            program = args[i]
        else:
            if run_args != "":
                run_args = run_args + " "
            run_args = run_args + args[i]
        i = i + 1

    if program != "":
        val detected = sdb_detect_backend(program)
        sdb_create_session(detected)
        cmd_file(program)
        if run_args != "":
            print "Arguments: " + run_args
        print ""

    while SDB_RUNNING:
        val prompt = fmt_cyan("(sdb) ")
        val line_raw = read_line(prompt)

        # EOF handling
        if line_raw == "":
            val should_quit = dispatch_command("quit")
            if should_quit:
                SDB_RUNNING = false
            continue

        val line = line_raw.trim()
        if line == "":
            continue

        val should_quit = dispatch_command(line)
        if should_quit:
            SDB_RUNNING = false

    0

fn main() -> i64:
    val raw_args = debug_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("debug", log_opts.error)
        return 1

    val args = debug_clean_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_usage()
        return 0

    if raw_args.len() > 0 and args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"debug\",\"status\":\"ready\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "ready")
        if progress != "":
            print progress
            return 0

    run_debug_repl()

fn debug_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn debug_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if debug_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn debug_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_debug = false
    var i = 0
    while i < all_args.len():
        if found_debug:
            args.push(all_args[i])
        elif all_args[i] == "debug" or all_args[i] == "cli-debug":
            found_debug = true
        i = i + 1
    if found_debug:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("main.spl"):
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
