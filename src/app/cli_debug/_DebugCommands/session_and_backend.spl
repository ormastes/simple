fn cmd_break(args: text):
    if not sdb_ensure_session():
        return
    if args == "":
        sdb_print("Usage: break <location>")
        sdb_print("  break main          Break at function 'main'")
        sdb_print("  break file.spl:42   Break at file line 42")
        sdb_print("  break 42            Break at line 42")
        return
    val cmd = "break " + args
    val output = sdb_run_cmd(cmd)
    SDB_BREAKPOINT_NUM = SDB_BREAKPOINT_NUM + 1
    sdb_print(output)

