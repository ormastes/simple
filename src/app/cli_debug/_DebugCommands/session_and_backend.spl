fn cmd_shell(args: text):
    """Execute shell command."""
    if args == "":
        sdb_print("Usage: shell <command>  or  !<command>")
        return
    val (out, err, code) = process_run("bash", ["-c", args])
    if out.trim() != "":
        sdb_print(out.trim())
    if err.trim() != "" and code != 0:
        sdb_print(err.trim())

