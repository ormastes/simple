# Traceability Checker Core
#
# Builds a lightweight traceability index over src/, test/, and doc/ and emits
# warnings for missing source/test links, missing backwards documentation links,
# and uncovered REQ/NFR identifiers.

# Split from src/app/traceability/core.spl to keep module cohesion under the 800-line source limit.
export use app.traceability._TraceabilityCore.config_and_analysis.*
export use app.traceability._TraceabilityCore.warning_counts.*
export use app.traceability._TraceabilityCore.manifest_and_report.*
