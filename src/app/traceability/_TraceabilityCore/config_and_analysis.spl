# Traceability — config loading + repo/spec-layout analysis
use app.traceability.core.*
# Traceability Checker Core
#
# Builds a lightweight traceability index over src/, test/, and doc/ and emits
# warnings for missing source/test links, missing backwards documentation links,
# and uncovered REQ/NFR identifiers.

use app.io.mod (file_exists, file_read, dir_walk, is_dir)
use common.text_advanced.{escape_json}

struct TraceabilityConfig:
    generated_spec_root: text
    legacy_requirement_root: text
    warn_source_roots: [text]

struct TraceabilityWarning:
    code: text
    path: text
    line: i64
    message: text

struct VirtualFile:
    path: text
    content: text

struct PathMapping:
    root: text
    relative: text

struct ParsedTraceFile:
    path: text
    kind: text
    slug: text
    normalized_slug: text
    requirement_value: text
    plan_value: text
    design_value: text
    research_value: text
    requirement_paths: [text]
    plan_paths: [text]
    design_paths: [text]
    research_paths: [text]
    generated_spec_paths: [text]
    raw_test_paths: [text]
    req_ids: [text]
    nfr_ids: [text]

fn default_traceability_config() -> TraceabilityConfig:
    TraceabilityConfig(
        generated_spec_root: "doc/06_spec",
        legacy_requirement_root: "doc/requirement",
        warn_source_roots: []
    )

fn load_traceability_config() -> TraceabilityConfig:
    val path = "config/traceability.sdn"
    if not file_exists(path):
        return default_traceability_config()

    val content = file_read(path)
    if content == "":
        return default_traceability_config()

    var cfg = default_traceability_config()
    var in_section = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if has_prefix(s: trimmed, prefix: "#"):
            continue
        if trimmed == "traceability:":
            in_section = true
            continue
        if not in_section:
            continue
        if has_prefix(s: line, prefix: "  ") == false:
            in_section = false
            continue

        if has_prefix(s: trimmed, prefix: "generated_spec_root:"):
            val start_idx = 20
            val value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            if value != "":
                cfg.generated_spec_root = value
        elif has_prefix(s: trimmed, prefix: "legacy_requirement_root:"):
            val start_idx = 24
            val value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            if value != "":
                cfg.legacy_requirement_root = value
        elif has_prefix(s: trimmed, prefix: "warn_source_root:"):
            val start_idx = 17
            val value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            if value != "":
                cfg.warn_source_roots.push(value)
    cfg

fn make_virtual_file(path: text, content: text) -> VirtualFile:
    VirtualFile(path: path, content: content)

fn analyze_repo_traceability(paths: [text], scope: text, config: TraceabilityConfig, enforce_source_roots: bool) -> [TraceabilityWarning]:
    val files = collect_virtual_files(paths)
    analyze_virtual_files(files, scope, config, enforce_source_roots)

fn run_traceability_build_warnings(verbose: bool) -> i64:
    if verbose:
        print "Checking traceability links..."
    val warnings = analyze_repo_traceability([], "all", load_traceability_config(), true)
    for warning in warnings:
        print format_traceability_warning(warning)
    warnings.len()

fn analyze_virtual_files(files: [VirtualFile], scope: text, config: TraceabilityConfig, enforce_source_roots: bool) -> [TraceabilityWarning]:
    var parsed: [ParsedTraceFile] = []
    var existing_paths: [text] = []

    for file in files:
        existing_paths.push(file.path)
        parsed.push(parse_trace_file(file))
    existing_paths = unique_texts(existing_paths)

    var warnings: [TraceabilityWarning] = []
    warnings = extend_warnings(base: warnings, extra: analyze_generated_spec_layout(parsed, existing_paths, config, scope))
    warnings = extend_warnings(base: warnings, extra: analyze_specs(parsed, existing_paths, config, scope))
    warnings = extend_warnings(base: warnings, extra: analyze_requirements(parsed, existing_paths, config, scope))
    warnings = extend_warnings(base: warnings, extra: analyze_backwards_docs(parsed, existing_paths, config, scope))
    if enforce_source_roots:
        warnings = extend_warnings(base: warnings, extra: analyze_source_tests(parsed, existing_paths, config, scope))

    warnings

fn analyze_generated_spec_layout(parsed: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig, scope: text) -> [TraceabilityWarning]:
    if scope != "all" and scope != "spec":
        return []

    var warnings: [TraceabilityWarning] = []
    for file in parsed:
        if not is_executable_spec_kind(file.kind):
            continue
        val expected = expected_generated_spec_path(file.path, config)
        if expected == "":
            continue
        if path_list_contains(existing_paths, expected) == false:
            warnings.push(make_warning(code: "TRC231", path: file.path, line_num: 1, message: "Missing mirrored generated spec doc '{expected}'"))
        val wrong = find_mismatched_generated_spec_path(expected: expected, source_path: file.path, parsed: parsed, config: config)
        if wrong != "":
            warnings.push(make_warning(code: "TRC232", path: wrong, line_num: 1, message: "Generated spec doc should mirror '{file.path}' at '{expected}'"))
    warnings

fn count_virtual_file_warnings_by_code(files: [VirtualFile], scope: text, config: TraceabilityConfig, enforce_source_roots: bool, code: text) -> i64:
    var file_pairs: [text] = []
    var file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        file_pairs.push(file.path)
        file_pairs.push(file.content)
        file_idx = file_idx + 1
    count_virtual_file_pair_warnings_by_code(file_pairs: file_pairs, scope: scope, config: config, enforce_source_roots: enforce_source_roots, code: code)

fn count_virtual_file_pair_warnings_by_code(file_pairs: [text], scope: text, config: TraceabilityConfig, enforce_source_roots: bool, code: text) -> i64:
    var existing_paths: [text] = []

    var file_idx = 0
    while file_idx + 1 < file_pairs.len():
        existing_paths.push(file_pairs[file_idx])
        file_idx = file_idx + 2
    existing_paths = unique_texts(existing_paths)

    var count = 0
    count = count + count_generated_spec_layout_pair_warnings_by_code(file_pairs: file_pairs, existing_paths: existing_paths, config: config, scope: scope, target_code: code)
    count = count + count_spec_pair_warnings_by_code(file_pairs: file_pairs, existing_paths: existing_paths, config: config, scope: scope, target_code: code)
    count = count + count_requirement_pair_warnings_by_code(file_pairs: file_pairs, existing_paths: existing_paths, config: config, scope: scope, target_code: code)
    count = count + count_backwards_doc_pair_warnings_by_code(file_pairs: file_pairs, existing_paths: existing_paths, config: config, scope: scope, target_code: code)
    if enforce_source_roots:
        count = count + count_source_test_pair_warnings_by_code(file_pairs: file_pairs, existing_paths: existing_paths, config: config, scope: scope, target_code: code)
    count

fn count_traceability_manifest_warnings_by_code(manifest: text, scope: text, config: TraceabilityConfig, enforce_source_roots: bool, code: text) -> i64:
    val file_pairs = parse_traceability_manifest(manifest)
    count_virtual_file_pair_warnings_by_code(file_pairs: file_pairs, scope: scope, config: config, enforce_source_roots: enforce_source_roots, code: code)

fn count_traceability_manifest_default_warnings_by_code(manifest: text, scope: text, code: text) -> i64:
    count_traceability_manifest_warnings_by_code(manifest: manifest, scope: scope, config: default_traceability_config(), enforce_source_roots: false, code: code)

fn count_traceability_manifest_single_root_warnings_by_code(manifest: text, scope: text, warn_source_root: text, code: text) -> i64:
    val config = TraceabilityConfig(
        generated_spec_root: "doc/06_spec",
        legacy_requirement_root: "doc/requirement",
        warn_source_roots: [warn_source_root]
    )
    count_traceability_manifest_warnings_by_code(manifest: manifest, scope: scope, config: config, enforce_source_roots: true, code: code)

fn collect_virtual_files(paths: [text]) -> [VirtualFile]:
    var roots = paths
    if roots.len() == 0:
        roots = ["src", "test", "doc"]

    var files: [VirtualFile] = []
    var seen: [text] = []
    for root in roots:
        if not file_exists(root) and not is_dir(root):
            continue
        if is_traceable_file_path(root):
            if path_list_contains(seen, root) == false:
                seen.push(root)
                files.push(VirtualFile(path: root, content: file_read(root)))
            continue
        val walked = dir_walk(root)
        for path in walked:
            if not is_traceable_file_path(path):
                continue
            if path_list_contains(seen, path):
                continue
            seen.push(path)
            files.push(VirtualFile(path: path, content: file_read(path)))
    files

fn is_traceable_file_path(path: text) -> bool:
    if has_prefix(s: path, prefix: "src/"):
        if has_suffix(s: path, suffix: ".spl"):
            return true
    if has_prefix(s: path, prefix: "test/"):
        if has_suffix(s: path, suffix: ".spl"):
            return true
    if has_prefix(s: path, prefix: "doc/"):
        if has_suffix(s: path, suffix: ".md"):
            return true
    false

fn parse_trace_file(file: VirtualFile) -> ParsedTraceFile:
    val kind = classify_trace_path(file.path)
    val slug = basename_no_ext(file.path)
    val normalized = normalize_slug(slug)

    var requirement_value = ""
    var plan_value = ""
    var design_value = ""
    var research_value = ""

    if kind == "spec_feature" or kind == "spec_system":
        val lines = file.content.split("\n")
        for line in lines:
            val trimmed = line.trim()
            if has_prefix(s: trimmed, prefix: "**Requirements:**") and requirement_value == "":
                val start_idx = 17
                requirement_value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            elif has_prefix(s: trimmed, prefix: "**Plan:**") and plan_value == "":
                val start_idx = 9
                plan_value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            elif has_prefix(s: trimmed, prefix: "**Design:**") and design_value == "":
                val start_idx = 11
                design_value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
            elif has_prefix(s: trimmed, prefix: "**Research:**") and research_value == "":
                val start_idx = 13
                research_value = strip_quotes(trimmed[start_idx:trimmed.len()].trim())
    ParsedTraceFile(
        path: file.path,
        kind: kind,
        slug: slug,
        normalized_slug: normalized,
        requirement_value: requirement_value,
        plan_value: plan_value,
        design_value: design_value,
        research_value: research_value,
        requirement_paths: extract_paths_for_field(content: file.content, field_name: "requirement"),
        plan_paths: extract_paths_for_field(content: file.content, field_name: "plan"),
        design_paths: extract_paths_for_field(content: file.content, field_name: "design"),
        research_paths: extract_paths_for_field(content: file.content, field_name: "research"),
        generated_spec_paths: extract_prefixed_paths(content: file.content, prefix: "doc/06_spec/"),
        raw_test_paths: extract_raw_test_paths(file.content),
        req_ids: extract_ids_by_prefix(content: file.content, prefix: "REQ-"),
        nfr_ids: extract_ids_by_prefix(content: file.content, prefix: "NFR-")
    )

fn analyze_specs(parsed: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig, scope: text) -> [TraceabilityWarning]:
    if scope != "all" and scope != "spec":
        return []

    var warnings: [TraceabilityWarning] = []
    for file in parsed:
        if file.kind != "spec_feature" and file.kind != "spec_system":
            continue

        warnings = extend_warnings(base: warnings, extra: validate_spec_field(file, existing_paths, config, "requirements"))
        warnings = extend_warnings(base: warnings, extra: validate_spec_field(file, existing_paths, config, "plan"))
        warnings = extend_warnings(base: warnings, extra: validate_spec_field(file, existing_paths, config, "design"))
        warnings = extend_warnings(base: warnings, extra: validate_spec_field(file, existing_paths, config, "research"))

        val requirement_slugs = canonical_requirement_slugs(paths: file.requirement_paths, existing_paths: existing_paths, config: config)
        if requirement_slugs.len() == 1:
            val req_slug = requirement_slugs[0]
            warnings = extend_warnings(base: warnings, extra: validate_companion_slug(path: file.path, requirement_slug: req_slug, links: file.plan_paths, code: "TRC221", label: "Plan link"))
            warnings = extend_warnings(base: warnings, extra: validate_companion_slug(path: file.path, requirement_slug: req_slug, links: file.design_paths, code: "TRC222", label: "Design link"))
            warnings = extend_warnings(base: warnings, extra: validate_companion_slug(path: file.path, requirement_slug: req_slug, links: file.research_paths, code: "TRC223", label: "Research link"))
    warnings

fn validate_spec_field(file: ParsedTraceFile, existing_paths: [text], config: TraceabilityConfig, field_name: text) -> [TraceabilityWarning]:
    var warnings: [TraceabilityWarning] = []
    val raw_value = match field_name:
        case "requirements": file.requirement_value
        case "plan": file.plan_value
        case "design": file.design_value
        case "research": file.research_value
        case _: ""
    val links = match field_name:
        case "requirements": file.requirement_paths
        case "plan": file.plan_paths
        case "design": file.design_paths
        case "research": file.research_paths
        case _: []
    val code_prefix = match field_name:
        case "requirements": "TRC301"
        case "plan": "TRC302"
        case "design": "TRC303"
        case "research": "TRC304"
        case _: "TRC399"
    val human = capitalize(field_name)

    if raw_value == "":
        warnings.push(make_warning(code: code_prefix, path: file.path, line_num: 1, message: "Missing '**{human}:**' link"))
        return warnings
    if raw_value == "N/A":
        return warnings
    if links.len() == 0:
        warnings.push(make_warning(code: code_prefix, path: file.path, line_num: 1, message: "{human} link must point to a relative file path"))
        return warnings

    for link in links:
        if field_name == "requirements":
            if has_prefix(s: link, prefix: config.legacy_requirement_root + "/"):
                warnings.push(make_warning(code: "TRC211", path: file.path, line_num: 1, message: "Requirement link uses legacy root '{link}'"))
        if path_list_contains(existing_paths, link) == false:
            warnings.push(make_warning(code: code_prefix, path: file.path, line_num: 1, message: "{human} link not found: '{link}'"))
    warnings

fn validate_companion_slug(path: text, requirement_slug: text, links: [text], code: text, label: text) -> [TraceabilityWarning]:
    var warnings: [TraceabilityWarning] = []
    for link in links:
        if normalize_slug(basename_no_ext(link)) != requirement_slug:
            warnings.push(make_warning(code: code, path: path, line_num: 1, message: "{label} should use the same slug as the linked requirement"))
    warnings

fn analyze_requirements(parsed: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig, scope: text) -> [TraceabilityWarning]:
    if scope != "all" and scope != "spec" and scope != "doc":
        return []

    var warnings: [TraceabilityWarning] = []
    for file in parsed:
        if file.kind != "requirement" and file.kind != "nfr":
            continue

        val ids = merge_unique(a: file.req_ids, b: file.nfr_ids)
        if ids.len() == 0:
            warnings.push(make_warning(code: "TRC311", path: file.path, line_num: 1, message: "Requirement document has no REQ-/NFR- identifiers"))

        var linked_spec_count = 0
        for spec in parsed:
            if spec.kind != "spec_feature" and spec.kind != "spec_system":
                continue
            val canonical_paths = canonical_requirement_paths(paths: spec.requirement_paths, existing_paths: existing_paths, config: config)
            if path_list_contains(canonical_paths, file.path):
                linked_spec_count = linked_spec_count + 1

        if linked_spec_count == 0:
            warnings.push(make_warning(code: "TRC312", path: file.path, line_num: 1, message: "No feature/system spec links to this requirement document"))

        for id in ids:
            var covered = false
            for spec in parsed:
                if spec.kind != "spec_feature" and spec.kind != "spec_system":
                    continue
                val canonical_paths = canonical_requirement_paths(paths: spec.requirement_paths, existing_paths: existing_paths, config: config)
                if path_list_contains(canonical_paths, file.path) == false:
                    continue
                if path_list_contains(spec.req_ids, id) or path_list_contains(spec.nfr_ids, id):
                    covered = true
                    break
            if not covered:
                warnings.push(make_warning(code: "TRC401", path: file.path, line_num: 1, message: "Identifier '{id}' is not covered by linked feature/system specs"))
        warnings = extend_warnings(base: warnings, extra: validate_requirement_companions(file, existing_paths))
    warnings

fn validate_requirement_companions(file: ParsedTraceFile, existing_paths: [text]) -> [TraceabilityWarning]:
    var warnings: [TraceabilityWarning] = []
    val slug = file.normalized_slug
    val plan_path = "doc/03_plan/{slug}.md"
    val design_path = "doc/05_design/{slug}.md"
    val architecture_path = "doc/04_architecture/{slug}.md"
    val research_path = "doc/01_research/{slug}.md"

    if path_list_contains(existing_paths, plan_path):
        if path_list_contains(file.plan_paths, plan_path) == false:
            warnings.push(make_warning(code: "TRC321", path: file.path, line_num: 1, message: "Requirement document should link sibling plan '{plan_path}'"))
    if path_list_contains(existing_paths, design_path):
        if path_list_contains(file.design_paths, design_path) == false:
            warnings.push(make_warning(code: "TRC322", path: file.path, line_num: 1, message: "Requirement document should link sibling design '{design_path}'"))
    if path_list_contains(existing_paths, architecture_path):
        if path_list_contains(file.design_paths, architecture_path) == false:
            warnings.push(make_warning(code: "TRC323", path: file.path, line_num: 1, message: "Requirement document should link sibling architecture '{architecture_path}'"))
    if path_list_contains(existing_paths, research_path):
        if path_list_contains(file.research_paths, research_path) == false:
            warnings.push(make_warning(code: "TRC324", path: file.path, line_num: 1, message: "Requirement document should link sibling research '{research_path}'"))
    warnings

fn analyze_backwards_docs(parsed: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig, scope: text) -> [TraceabilityWarning]:
    if scope != "all" and scope != "doc":
        return []

    var warnings: [TraceabilityWarning] = []
    var requirement_slugs: [text] = []
    for file in parsed:
        if file.kind == "requirement" or file.kind == "nfr":
            requirement_slugs.push(file.normalized_slug)
    requirement_slugs = unique_texts(requirement_slugs)

    for file in parsed:
        if file.kind != "plan" and file.kind != "design" and file.kind != "architecture" and file.kind != "research":
            continue

        for raw_test_path in file.raw_test_paths:
            warnings.push(make_warning(code: "TRC205", path: file.path, line_num: 1, message: "Document links raw spec '{raw_test_path}'; point to generated markdown under {config.generated_spec_root}/"))

        val has_requirement_backlink = file.requirement_paths.len() > 0
        val same_slug_requirement_exists = path_list_contains(requirement_slugs, file.normalized_slug)
        if same_slug_requirement_exists and not has_requirement_backlink:
            warnings.push(make_warning(code: "TRC206", path: file.path, line_num: 1, message: "Document should link back to the matching requirement document"))
        elif same_slug_requirement_exists and requirement_path_matches_slug(file.requirement_paths, file.normalized_slug) == false:
            warnings.push(make_warning(code: "TRC207", path: file.path, line_num: 1, message: "Document requirement backlink does not match its slug"))
    warnings

fn analyze_source_tests(parsed: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig, scope: text) -> [TraceabilityWarning]:
    if scope != "all" and scope != "src":
        return []
    if config.warn_source_roots.len() == 0:
        return []

    var warnings: [TraceabilityWarning] = []
    var source_dirs: [text] = []
    var init_dirs: [text] = []
    for file in parsed:
        if file.kind != "source":
            continue
        if is_under_warn_root(file.path, config.warn_source_roots) == false:
            continue
        val dir_path = dirname(file.path)
        source_dirs.push(dir_path)
        if basename(file.path) == "__init__.spl":
            init_dirs.push(dir_path)
        if basename(file.path) != "__init__.spl":
            val unit_candidates = map_source_to_unit_candidates(file.path)
            if unit_candidates.len() > 0:
                if any_path_exists(paths: unit_candidates, existing_paths: existing_paths) == false:
                    warnings.push(make_warning(code: "TRC101", path: file.path, line_num: 1, message: "Missing unit spec for source file; expected one of {join_list(unit_candidates)}"))
    var anchor_dirs = unique_texts(init_dirs)
    val unique_dirs = unique_texts(source_dirs)
    for dir_path in unique_dirs:
        if path_list_contains(anchor_dirs, dir_path):
            continue
        if not has_child_source_dir(unique_dirs, dir_path):
            anchor_dirs.push(dir_path)
    anchor_dirs = unique_texts(anchor_dirs)
    for dir_path in anchor_dirs:
        val integration_candidates = map_source_dir_to_integration_candidates(dir_path)
        if integration_candidates.len() > 0:
            if any_path_exists(paths: integration_candidates, existing_paths: existing_paths) == false:
                warnings.push(make_warning(code: "TRC111", path: dir_path + "/__module__", line_num: 1, message: "Missing module/integration spec for source directory; expected one of {join_list(integration_candidates)}"))
    warnings

fn count_spec_warnings_by_code(files: [VirtualFile], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "spec":
        return 0

    var count = 0
    var file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        val kind = classify_trace_path(file.path)
        if kind != "spec_feature" and kind != "spec_system":
            file_idx = file_idx + 1
            continue

        val requirement_value = find_header_field_value(content: file.content, marker: "**Requirements:**")
        val plan_value = find_header_field_value(content: file.content, marker: "**Plan:**")
        val design_value = find_header_field_value(content: file.content, marker: "**Design:**")
        val research_value = find_header_field_value(content: file.content, marker: "**Research:**")
        val requirement_paths = extract_paths_for_field(content: file.content, field_name: "requirement")
        val plan_paths = extract_paths_for_field(content: file.content, field_name: "plan")
        val design_paths = extract_paths_for_field(content: file.content, field_name: "design")
        val research_paths = extract_paths_for_field(content: file.content, field_name: "research")

        count = count + count_spec_field_matches(raw_value: requirement_value, links: requirement_paths, existing_paths: existing_paths, config: config, field_name: "requirements", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: plan_value, links: plan_paths, existing_paths: existing_paths, config: config, field_name: "plan", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: design_value, links: design_paths, existing_paths: existing_paths, config: config, field_name: "design", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: research_value, links: research_paths, existing_paths: existing_paths, config: config, field_name: "research", target_code: target_code)

        val requirement_slugs = canonical_requirement_slugs(paths: requirement_paths, existing_paths: existing_paths, config: config)
        if requirement_slugs.len() == 1:
            val req_slug = requirement_slugs[0]
            count = count + count_companion_slug_matches(path: file.path, requirement_slug: req_slug, links: plan_paths, code: "TRC221", target_code: target_code)
            count = count + count_companion_slug_matches(path: file.path, requirement_slug: req_slug, links: design_paths, code: "TRC222", target_code: target_code)
            count = count + count_companion_slug_matches(path: file.path, requirement_slug: req_slug, links: research_paths, code: "TRC223", target_code: target_code)
        file_idx = file_idx + 1
    count

fn count_spec_field_matches(raw_value: text, links: [text], existing_paths: [text], config: TraceabilityConfig, field_name: text, target_code: text) -> i64:
    val code_prefix = match field_name:
        case "requirements": "TRC301"
        case "plan": "TRC302"
        case "design": "TRC303"
        case "research": "TRC304"
        case _: "TRC399"

    var count = 0
    if raw_value == "":
        return count_if_code(target_code: target_code, actual_code: code_prefix)
    if raw_value == "N/A":
        return 0
    if links.len() == 0:
        return count_if_code(target_code: target_code, actual_code: code_prefix)

    for link in links:
        if field_name == "requirements":
            if has_prefix(s: link, prefix: config.legacy_requirement_root + "/"):
                count = count + count_if_code(target_code: target_code, actual_code: "TRC211")
        if path_list_contains(existing_paths, link) == false:
            count = count + count_if_code(target_code: target_code, actual_code: code_prefix)
    count

fn count_companion_slug_matches(path: text, requirement_slug: text, links: [text], code: text, target_code: text) -> i64:
    var count = 0
    for link in links:
        if normalize_slug(basename_no_ext(link)) != requirement_slug:
            count = count + count_if_code(target_code: target_code, actual_code: code)
    count

fn count_requirement_warnings_by_code(files: [VirtualFile], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "spec" and scope != "doc":
        return 0

    var count = 0
    var file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        val kind = classify_trace_path(file.path)
        if kind != "requirement" and kind != "nfr":
            file_idx = file_idx + 1
            continue

        val requirement_paths = extract_paths_for_field(content: file.content, field_name: "requirement")
        val plan_paths = extract_paths_for_field(content: file.content, field_name: "plan")
        val design_paths = extract_paths_for_field(content: file.content, field_name: "design")
        val research_paths = extract_paths_for_field(content: file.content, field_name: "research")
        val ids = merge_unique(
            a: extract_ids_by_prefix(content: file.content, prefix: "REQ-"),
            b: extract_ids_by_prefix(content: file.content, prefix: "NFR-")
        )
        if ids.len() == 0:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC311")

        var linked_spec_count = 0
        var spec_idx = 0
        while spec_idx < files.len():
            val maybe_spec = files[spec_idx]
            val spec_kind = classify_trace_path(maybe_spec.path)
            if spec_kind != "spec_feature" and spec_kind != "spec_system":
                spec_idx = spec_idx + 1
                continue
            val spec_requirement_paths = extract_paths_for_field(content: maybe_spec.content, field_name: "requirement")
            val canonical_paths = canonical_requirement_paths(paths: spec_requirement_paths, existing_paths: existing_paths, config: config)
            if path_list_contains(canonical_paths, file.path):
                linked_spec_count = linked_spec_count + 1
            spec_idx = spec_idx + 1

        if linked_spec_count == 0:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC312")

        for id in ids:
            var covered = false
            spec_idx = 0
            while spec_idx < files.len():
                val maybe_spec = files[spec_idx]
                val spec_kind = classify_trace_path(maybe_spec.path)
                if spec_kind != "spec_feature" and spec_kind != "spec_system":
                    spec_idx = spec_idx + 1
                    continue
                val spec_requirement_paths = extract_paths_for_field(content: maybe_spec.content, field_name: "requirement")
                val canonical_paths = canonical_requirement_paths(paths: spec_requirement_paths, existing_paths: existing_paths, config: config)
                if path_list_contains(canonical_paths, file.path) == false:
                    spec_idx = spec_idx + 1
                    continue
                val spec_req_ids = extract_ids_by_prefix(content: maybe_spec.content, prefix: "REQ-")
                val spec_nfr_ids = extract_ids_by_prefix(content: maybe_spec.content, prefix: "NFR-")
                if path_list_contains(spec_req_ids, id) or path_list_contains(spec_nfr_ids, id):
                    covered = true
                    break
                spec_idx = spec_idx + 1
            if not covered:
                count = count + count_if_code(target_code: target_code, actual_code: "TRC401")
        count = count + count_requirement_companion_matches(path: file.path, plan_paths: plan_paths, design_paths: design_paths, research_paths: research_paths, existing_paths: existing_paths, target_code: target_code)
        file_idx = file_idx + 1
    count

fn count_requirement_companion_matches(path: text, plan_paths: [text], design_paths: [text], research_paths: [text], existing_paths: [text], target_code: text) -> i64:
    var count = 0
    val slug = normalize_slug(basename_no_ext(path))
    val plan_path = "doc/03_plan/{slug}.md"
    val design_path = "doc/05_design/{slug}.md"
    val architecture_path = "doc/04_architecture/{slug}.md"
    val research_path = "doc/01_research/{slug}.md"

    if path_list_contains(existing_paths, plan_path):
        if path_list_contains(plan_paths, plan_path) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC321")
    if path_list_contains(existing_paths, design_path):
        if path_list_contains(design_paths, design_path) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC322")
    if path_list_contains(existing_paths, architecture_path):
        if path_list_contains(design_paths, architecture_path) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC323")
    if path_list_contains(existing_paths, research_path):
        if path_list_contains(research_paths, research_path) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC324")
    count
