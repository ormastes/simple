# Part 2 of src/app/traceability/core.spl
use app.traceability.core.*
# Traceability Checker Core
#
# Builds a lightweight traceability index over src/, test/, and doc/ and emits
# warnings for missing source/test links, missing backwards documentation links,
# and uncovered REQ/NFR identifiers.

use app.io.mod (file_exists, file_read, dir_walk, is_dir)
use common.text_advanced.{escape_json}

fn count_backwards_doc_warnings_by_code(files: [VirtualFile], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "doc":
        return 0

    var requirement_slugs: [text] = []
    var file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        val kind = classify_trace_path(file.path)
        if kind == "requirement" or kind == "nfr":
            requirement_slugs.push(normalize_slug(basename_no_ext(file.path)))
        file_idx = file_idx + 1
    requirement_slugs = unique_texts(requirement_slugs)

    var count = 0
    file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        val kind = classify_trace_path(file.path)
        if kind != "plan" and kind != "design" and kind != "architecture" and kind != "research":
            file_idx = file_idx + 1
            continue

        val raw_test_paths = extract_raw_test_paths(file.content)
        for _ in raw_test_paths:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC205")

        val requirement_paths = extract_paths_for_field(content: file.content, field_name: "requirement")
        val normalized_slug = normalize_slug(basename_no_ext(file.path))
        val has_requirement_backlink = requirement_paths.len() > 0
        val same_slug_requirement_exists = path_list_contains(requirement_slugs, normalized_slug)
        if same_slug_requirement_exists and not has_requirement_backlink:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC206")
        elif same_slug_requirement_exists and requirement_path_matches_slug(requirement_paths, normalized_slug) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC207")
        file_idx = file_idx + 1
    count

fn count_source_test_warnings_by_code(files: [VirtualFile], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "src":
        return 0
    if config.warn_source_roots.len() == 0:
        return 0

    var count = 0
    var source_dirs: [text] = []
    var init_dirs: [text] = []
    var file_idx = 0
    while file_idx < files.len():
        val file = files[file_idx]
        val kind = classify_trace_path(file.path)
        if kind != "source":
            file_idx = file_idx + 1
            continue
        if is_under_warn_root(file.path, config.warn_source_roots) == false:
            file_idx = file_idx + 1
            continue
        val dir_path = dirname(file.path)
        source_dirs.push(dir_path)
        if basename(file.path) == "__init__.spl":
            init_dirs.push(dir_path)
        if basename(file.path) != "__init__.spl":
            val unit_candidates = map_source_to_unit_candidates(file.path)
            if unit_candidates.len() > 0:
                if any_path_exists(paths: unit_candidates, existing_paths: existing_paths) == false:
                    count = count + count_if_code(target_code: target_code, actual_code: "TRC101")
        file_idx = file_idx + 1

    var anchor_dirs = unique_texts(init_dirs)
    val unique_dirs = unique_texts(source_dirs)
    for dir_path in unique_dirs:
        if path_list_contains(anchor_dirs, dir_path):
            continue
        if not has_child_source_dir(unique_dirs, dir_path):
            anchor_dirs.push(dir_path)
    anchor_dirs = unique_texts(anchor_dirs)

    for dir_path in anchor_dirs:
        val integration_candidates = map_source_dir_to_integration_candidates(dir_path)
        if integration_candidates.len() > 0:
            if any_path_exists(paths: integration_candidates, existing_paths: existing_paths) == false:
                count = count + count_if_code(target_code: target_code, actual_code: "TRC111")
    count

fn count_spec_pair_warnings_by_code(file_pairs: [text], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "spec":
        return 0

    var count = 0
    var file_idx = 0
    while file_idx + 1 < file_pairs.len():
        val path = file_pairs[file_idx]
        val content = file_pairs[file_idx + 1]
        val kind = classify_trace_path(path)
        if kind != "spec_feature" and kind != "spec_system":
            file_idx = file_idx + 2
            continue

        val requirement_value = find_header_field_value(content: content, marker: "**Requirements:**")
        val plan_value = find_header_field_value(content: content, marker: "**Plan:**")
        val design_value = find_header_field_value(content: content, marker: "**Design:**")
        val research_value = find_header_field_value(content: content, marker: "**Research:**")
        val requirement_paths = extract_paths_for_field(content: content, field_name: "requirement")
        val plan_paths = extract_paths_for_field(content: content, field_name: "plan")
        val design_paths = extract_paths_for_field(content: content, field_name: "design")
        val research_paths = extract_paths_for_field(content: content, field_name: "research")

        count = count + count_spec_field_matches(raw_value: requirement_value, links: requirement_paths, existing_paths: existing_paths, config: config, field_name: "requirements", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: plan_value, links: plan_paths, existing_paths: existing_paths, config: config, field_name: "plan", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: design_value, links: design_paths, existing_paths: existing_paths, config: config, field_name: "design", target_code: target_code)
        count = count + count_spec_field_matches(raw_value: research_value, links: research_paths, existing_paths: existing_paths, config: config, field_name: "research", target_code: target_code)

        val requirement_slugs = canonical_requirement_slugs(paths: requirement_paths, existing_paths: existing_paths, config: config)
        if requirement_slugs.len() == 1:
            val req_slug = requirement_slugs[0]
            count = count + count_companion_slug_matches(path: path, requirement_slug: req_slug, links: plan_paths, code: "TRC221", target_code: target_code)
            count = count + count_companion_slug_matches(path: path, requirement_slug: req_slug, links: design_paths, code: "TRC222", target_code: target_code)
            count = count + count_companion_slug_matches(path: path, requirement_slug: req_slug, links: research_paths, code: "TRC223", target_code: target_code)
        file_idx = file_idx + 2
    count

fn count_requirement_pair_warnings_by_code(file_pairs: [text], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "spec" and scope != "doc":
        return 0

    var count = 0
    var file_idx = 0
    while file_idx + 1 < file_pairs.len():
        val path = file_pairs[file_idx]
        val content = file_pairs[file_idx + 1]
        val kind = classify_trace_path(path)
        if kind != "requirement" and kind != "nfr":
            file_idx = file_idx + 2
            continue

        val plan_paths = extract_paths_for_field(content: content, field_name: "plan")
        val design_paths = extract_paths_for_field(content: content, field_name: "design")
        val research_paths = extract_paths_for_field(content: content, field_name: "research")
        val ids = merge_unique(
            a: extract_ids_by_prefix(content: content, prefix: "REQ-"),
            b: extract_ids_by_prefix(content: content, prefix: "NFR-")
        )
        if ids.len() == 0:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC311")

        var linked_spec_count = 0
        var spec_idx = 0
        while spec_idx + 1 < file_pairs.len():
            val spec_path = file_pairs[spec_idx]
            val spec_content = file_pairs[spec_idx + 1]
            val spec_kind = classify_trace_path(spec_path)
            if spec_kind != "spec_feature" and spec_kind != "spec_system":
                spec_idx = spec_idx + 2
                continue
            val spec_requirement_paths = extract_paths_for_field(content: spec_content, field_name: "requirement")
            val canonical_paths = canonical_requirement_paths(paths: spec_requirement_paths, existing_paths: existing_paths, config: config)
            if path_list_contains(canonical_paths, path):
                linked_spec_count = linked_spec_count + 1
            spec_idx = spec_idx + 2

        if linked_spec_count == 0:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC312")

        for id in ids:
            var covered = false
            spec_idx = 0
            while spec_idx + 1 < file_pairs.len():
                val spec_path = file_pairs[spec_idx]
                val spec_content = file_pairs[spec_idx + 1]
                val spec_kind = classify_trace_path(spec_path)
                if spec_kind != "spec_feature" and spec_kind != "spec_system":
                    spec_idx = spec_idx + 2
                    continue
                val spec_requirement_paths = extract_paths_for_field(content: spec_content, field_name: "requirement")
                val canonical_paths = canonical_requirement_paths(paths: spec_requirement_paths, existing_paths: existing_paths, config: config)
                if path_list_contains(canonical_paths, path) == false:
                    spec_idx = spec_idx + 2
                    continue
                val spec_req_ids = extract_ids_by_prefix(content: spec_content, prefix: "REQ-")
                val spec_nfr_ids = extract_ids_by_prefix(content: spec_content, prefix: "NFR-")
                if path_list_contains(spec_req_ids, id) or path_list_contains(spec_nfr_ids, id):
                    covered = true
                    break
                spec_idx = spec_idx + 2
            if not covered:
                count = count + count_if_code(target_code: target_code, actual_code: "TRC401")
        count = count + count_requirement_companion_matches(
            path: path,
            plan_paths: plan_paths,
            design_paths: design_paths,
            research_paths: research_paths,
            existing_paths: existing_paths,
            target_code: target_code
        )
        file_idx = file_idx + 2
    count

fn count_backwards_doc_pair_warnings_by_code(file_pairs: [text], existing_paths: [text], config: TraceabilityConfig, scope: text, target_code: text) -> i64:
    if scope != "all" and scope != "doc":
        return 0

    var requirement_slugs: [text] = []
    var file_idx = 0
    while file_idx + 1 < file_pairs.len():
        val path = file_pairs[file_idx]
        val kind = classify_trace_path(path)
        if kind == "requirement" or kind == "nfr":
            requirement_slugs.push(normalize_slug(basename_no_ext(path)))
        file_idx = file_idx + 2
    requirement_slugs = unique_texts(requirement_slugs)

    var count = 0
    file_idx = 0
    while file_idx + 1 < file_pairs.len():
        val path = file_pairs[file_idx]
        val content = file_pairs[file_idx + 1]
        val kind = classify_trace_path(path)
        if kind != "plan" and kind != "design" and kind != "architecture" and kind != "research":
            file_idx = file_idx + 2
            continue

        val raw_test_paths = extract_raw_test_paths(content)
        for _ in raw_test_paths:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC205")

        val requirement_paths = extract_paths_for_field(content: content, field_name: "requirement")
        val normalized_slug = normalize_slug(basename_no_ext(path))
        val has_requirement_backlink = requirement_paths.len() > 0
        val same_slug_requirement_exists = path_list_contains(requirement_slugs, normalized_slug)
        if same_slug_requirement_exists and not has_requirement_backlink:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC206")
        elif same_slug_requirement_exists and requirement_path_matches_slug(requirement_paths, normalized_slug) == false:
            count = count + count_if_code(target_code: target_code, actual_code: "TRC207")
        file_idx = file_idx + 2
    count

