    count

fn specs_for_requirement(requirement_path: text, specs: [ParsedTraceFile], existing_paths: [text], config: TraceabilityConfig) -> [ParsedTraceFile]:
    var matches: [ParsedTraceFile] = []
    for spec in specs:
        val canonical_paths = canonical_requirement_paths(paths: spec.requirement_paths, existing_paths: existing_paths, config: config)
        if path_list_contains(canonical_paths, requirement_path):
            matches.push(spec)
    matches

fn any_spec_covers_id(specs: [ParsedTraceFile], id: text) -> bool:
    for spec in specs:
        if path_list_contains(spec.req_ids, id) or path_list_contains(spec.nfr_ids, id):
            return true
    false

fn canonical_requirement_paths(paths: [text], existing_paths: [text], config: TraceabilityConfig) -> [text]:
    var result: [text] = []
    for path in paths:
        result.push(canonical_requirement_path(path, existing_paths, config))
    unique_texts(result)

fn canonical_requirement_slugs(paths: [text], existing_paths: [text], config: TraceabilityConfig) -> [text]:
    var slugs: [text] = []
    for path in canonical_requirement_paths(paths: paths, existing_paths: existing_paths, config: config):
        if path != "":
            slugs.push(normalize_slug(basename_no_ext(path)))
    unique_texts(slugs)

fn canonical_requirement_path(path: text, existing_paths: [text], config: TraceabilityConfig) -> text:
    if has_prefix(s: path, prefix: config.legacy_requirement_root + "/"):
        val start_idx = text_len(config.legacy_requirement_root)
        val suffix = path[start_idx:path.len()]
        val canonical = "doc/03_plan/requirement{suffix}"
        if path_list_contains(existing_paths, canonical):
            return canonical
    path

fn collect_module_anchor_dirs(parsed: [ParsedTraceFile], warn_source_roots: [text]) -> [text]:
    var source_dirs: [text] = []
    var init_dirs: [text] = []
    for file in parsed:
        if file.kind != "source":
            continue
        if is_under_warn_root(file.path, warn_source_roots) == false:
            continue
        val dir_path = dirname(file.path)
        source_dirs.push(dir_path)
        if basename(file.path) == "__init__.spl":
            init_dirs.push(dir_path)

    var anchors = unique_texts(init_dirs)
    val unique_dirs = unique_texts(source_dirs)
    for dir_path in unique_dirs:
        if path_list_contains(anchors, dir_path):
            continue
        if not has_child_source_dir(unique_dirs, dir_path):
            anchors.push(dir_path)
    unique_texts(anchors)

fn has_child_source_dir(dirs: [text], parent_dir: text) -> bool:
    for dir_path in dirs:
        if dir_path != parent_dir:
            if has_prefix(s: dir_path, prefix: parent_dir + "/"):
                return true
    false

fn classify_trace_path(path: text) -> text:
    if has_prefix(s: path, prefix: "test/feature/") and has_suffix(s: path, suffix: ".spl"):
        return "spec_feature"
    if has_prefix(s: path, prefix: "test/system/") and has_suffix(s: path, suffix: ".spl"):
        return "spec_system"
    if has_prefix(s: path, prefix: "src/") and has_suffix(s: path, suffix: ".spl"):
        return "source"
    if has_prefix(s: path, prefix: "doc/02_requirements/feature/") and has_suffix(s: path, suffix: ".md"):
        return "requirement"
    if has_prefix(s: path, prefix: "doc/02_requirements/nfr/") and has_suffix(s: path, suffix: ".md"):
        return "nfr"
    if has_prefix(s: path, prefix: "doc/03_plan/") and has_suffix(s: path, suffix: ".md"):
        return "plan"
    if has_prefix(s: path, prefix: "doc/05_design/") and has_suffix(s: path, suffix: ".md"):
        return "design"
    if has_prefix(s: path, prefix: "doc/04_architecture/") and has_suffix(s: path, suffix: ".md"):
        return "architecture"
    if has_prefix(s: path, prefix: "doc/01_research/") and has_suffix(s: path, suffix: ".md"):
        return "research"
    if has_prefix(s: path, prefix: "doc/06_spec/") and has_suffix(s: path, suffix: ".md"):
        return "spec_md"
    "other"

fn map_source_to_unit_candidates(path: text) -> [text]:
    val mapping = map_source_path(path)
    if mapping.root == "":
        return []
    if mapping.relative == "":
        return []
    val unit_root = mapping.root
    val rel_no_ext = mapping.relative
    [
        "{unit_root}/{rel_no_ext}_spec.spl",
        "{unit_root}/{rel_no_ext}_test.spl"
    ]

fn map_source_dir_to_integration_candidates(dir_path: text) -> [text]:
    val mapping = map_source_dir(dir_path)
    if mapping.root == "":
        return []
    if mapping.relative == "":
        return []
    val integration_root = mapping.root
    val rel = mapping.relative
    val leaf = basename(rel)
    [
        "{integration_root}/{rel}/module_spec.spl",
        "{integration_root}/{rel}/integration_spec.spl",
        "{integration_root}/{rel}/{leaf}_spec.spl"
    ]

fn map_source_path(path: text) -> PathMapping:
    val under_src = has_prefix(s: path, prefix: "src/")
    if under_src == false:
        return PathMapping(root: "", relative: "")
    val is_spl = has_suffix(s: path, suffix: ".spl")
    if is_spl == false:
        return PathMapping(root: "", relative: "")
    val rel = drop_first_segment(path)
    if has_prefix(s: rel, prefix: "compiler/"):
        val compiler_rel = drop_first_segment(rel)
        val normalized = normalize_compiler_relative(compiler_rel)
        return PathMapping(root: "test/unit/compiler", relative: remove_spl_extension(normalized))
    if has_prefix(s: rel, prefix: "app/"):
        val app_rel = drop_first_segment(rel)
        return PathMapping(root: "test/unit/app", relative: remove_spl_extension(app_rel))
    if has_prefix(s: rel, prefix: "lib/"):
        val lib_rel = drop_first_segment(rel)
        if find_index(s: lib_rel, needle: "/") < 0:
            return PathMapping(root: "", relative: "")
        val unit_rel = drop_first_segment(lib_rel)
        return PathMapping(root: "test/unit/lib", relative: remove_spl_extension(unit_rel))
    if has_prefix(s: rel, prefix: "os/"):
        val os_rel = drop_first_segment(rel)
        return PathMapping(root: "test/unit/os", relative: remove_spl_extension(os_rel))
    PathMapping(root: "", relative: "")

fn map_source_dir(dir_path: text) -> PathMapping:
    val under_src = has_prefix(s: dir_path, prefix: "src/")
    if under_src == false:
        return PathMapping(root: "", relative: "")
    val rel = drop_first_segment(dir_path)
    if has_prefix(s: rel, prefix: "compiler/"):
        val compiler_rel = drop_first_segment(rel)
        return PathMapping(root: "test/integration/compiler", relative: normalize_compiler_relative(compiler_rel))
    if has_prefix(s: rel, prefix: "app/"):
        val app_rel = drop_first_segment(rel)
        return PathMapping(root: "test/integration/app", relative: app_rel)
    if has_prefix(s: rel, prefix: "lib/"):
        val lib_rel = drop_first_segment(rel)
        if find_index(s: lib_rel, needle: "/") < 0:
            return PathMapping(root: "", relative: "")
        val integration_rel = drop_first_segment(lib_rel)
        return PathMapping(root: "test/integration/lib", relative: integration_rel)
    if has_prefix(s: rel, prefix: "os/"):
        val os_rel = drop_first_segment(rel)
        return PathMapping(root: "test/integration/os", relative: os_rel)
    PathMapping(root: "", relative: "")

fn normalize_compiler_relative(rel: text) -> text:
    val slash_idx = find_index(s: rel, needle: "/")
    if slash_idx < 0:
        return strip_compiler_layer(rel)
    val first = rel[0:slash_idx]
    val rest_start = slash_idx + 1
    if rest_start >= text_len(rel):
        return rel
    val rest = rel[rest_start:rel.len()]
    "{strip_compiler_layer(first)}/{rest}"

fn strip_compiler_layer(segment: text) -> text:
    val dot_idx = find_index(s: segment, needle: ".")
    if dot_idx <= 0:
        return segment
    val layer = segment[0:dot_idx]
    var numeric = true
    var i = 0
    while i < text_len(layer):
        val ch = layer[i:i + 1]
        if ch < "0" or ch > "9":
            numeric = false
            break
        i = i + 1
    if numeric:
        val start_idx = dot_idx + 1
        return segment[start_idx:segment.len()]
    segment

fn normalize_slug(name: text) -> text:
    var base = name
    if has_suffix(s: base, suffix: "_spec"):
        val end_idx = text_len(base) - 5
        base = base[0:end_idx]
    elif has_suffix(s: base, suffix: "_test"):
        val end_idx = text_len(base) - 5
        base = base[0:end_idx]
    strip_date_suffix(base)

fn strip_date_suffix(value: text) -> text:
    val value_len = text_len(value)
    if value_len > 11:
        val underscore_idx = value_len - 11
        val underscore_next = underscore_idx + 1
        if value[underscore_idx:underscore_next] == "_":
            val suffix = value[underscore_next:value_len]
            if is_date_suffix(suffix):
                return value[0:underscore_idx]
        val dash_idx = value_len - 11
        val dash_next = dash_idx + 1
        if value[dash_idx:dash_next] == "-":
            val suffix = value[dash_next:value_len]
            if is_date_suffix(suffix):
                return value[0:dash_idx]
    value

fn is_date_suffix(value: text) -> bool:
    if text_len(value) != 10:
        return false
    if value[4:5] != "-":
        return false
    if value[7:8] != "-":
        return false
    var i = 0
    val value_len = text_len(value)
    while i < value_len:
        if i == 4 or i == 7:
            i = i + 1
            continue
        val next_i = i + 1
        val ch = value[i:next_i]
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    true

fn extract_relative_paths(content: text) -> [text]:
    var result: [text] = []
    var i = 0
    val content_len = text_len(content)
    while i < content_len:
        if matches_at(s: content, start_idx: i, needle: "doc/") or matches_at(s: content, start_idx: i, needle: "test/"):
            val normalized = trim_trailing_path_punct(capture_relative_path_from(content, i).trim())
            if normalized != "":
                result.push(normalized)
        i = i + 1
    unique_texts(result)

fn capture_relative_path_from(content: text, start_idx: i64) -> text:
    var result = ""
    var i = start_idx
    val content_len = text_len(content)
    while i < content_len:
        val ch = content[i:i + 1]
        if is_path_delimiter(ch):
            break
        result = result + ch
        i = i + 1
    trim_trailing_path_punct(result)

fn is_path_delimiter(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\t" or ch == ")" or ch == "]" or ch == "\"" or ch == "'" or ch == "," or ch == ";"

fn trim_trailing_path_punct(path: text) -> text:
    var value = path
    while has_suffix(s: value, suffix: ".") or has_suffix(s: value, suffix: ":"):
        val end_idx = text_len(value) - 1
        value = value[0:end_idx]
    value

fn extract_trace_ids(content: text) -> [text]:
    merge_unique(
        a: extract_ids_by_prefix(content: content, prefix: "REQ-"),
        b: extract_ids_by_prefix(content: content, prefix: "NFR-")
    )

fn extract_ids_by_prefix(content: text, prefix: text) -> [text]:
    var result: [text] = []
    var i = 0
    val content_len = text_len(content)
    while i < content_len:
        if matches_at(s: content, start_idx: i, needle: prefix):
            val normalized = trim_trailing_path_punct(capture_id_from(content, i).trim())
            if normalized != "":
                result.push(normalized)
        i = i + 1
    unique_texts(result)

fn capture_id_from(content: text, start_idx: i64) -> text:
    var result = ""
    var i = start_idx
    val content_len = text_len(content)
    while i < content_len:
        val ch = content[i:i + 1]
        if is_id_char(ch):
            result = result + ch
            i = i + 1
        else:
            break
    result

fn is_id_char(ch: text) -> bool:
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    ch == "-" or ch == "_" or ch == "."

fn extract_raw_test_paths(content: text) -> [text]:
    var result: [text] = []
    for path in extract_relative_paths(content):
        if has_prefix(s: path, prefix: "test/") and has_suffix(s: path, suffix: ".spl"):
            result.push(path)
    unique_texts(result)

fn extract_prefixed_paths(content: text, prefix: text) -> [text]:
    var result: [text] = []
    for path in extract_relative_paths(content):
        if has_prefix(s: path, prefix: prefix):
            result.push(path)
    unique_texts(result)
