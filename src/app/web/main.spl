# Simple CLI - web command
# Startup-light wrapper that delegates real web work to the Rust CLI.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.io.mod.{process_run}

fn print_help():
    print "Simple Web Framework - Compile .sui files to HTML + WASM"
    print ""
    print "Usage:"
    print "  simple web build <file.sui> [options]"
    print "  simple web serve <file.sui> [options]"
    print "  simple web init <name>"
    print "  simple web features"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("web", log_opts.error)
        return 1

    val args = web_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"web\",\"status\":\"error\",\"error\":\"missing web subcommand\"}"
            return 1
        print_help_with_progress(log_opts.progress)
        return 1
    delegate_web(args)

fn delegate_web(args: [text]) -> i64:
    var forwarded: [text] = ["web"]
    for arg in args:
        forwarded.push(arg)
    val (stdout, stderr, code) = process_run("./bin/simple", forwarded)
    if stdout != "":
        print stdout
    if stderr != "":
        print stderr
    code

fn web_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn web_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if web_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
