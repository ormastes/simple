# Dashboard → UI Core Bridge
#
# Provides functions to convert dashboard rendering primitives
# (progress bars, tables) into UI core WidgetNode trees.
# This allows dashboards to be rendered through any RenderBackend.

use common.ui.widget.{WidgetNode, WidgetKind, LayoutKind}
use common.ui.builder.{column, row, panel, text_widget, progress, label}

# =========================================================================
# Progress Bar → WidgetNode
# =========================================================================

fn progress_to_widget(id: text, percent: f64) -> WidgetNode:
    """Convert a progress bar to a Progress widget."""
    var node = WidgetNode.new(id, WidgetKind.Progress)
    node = node.set_prop("value", "{percent}")
    return node

fn progress_with_label(id: text, label_text: text, percent: f64) -> WidgetNode:
    """Create a progress widget with a label."""
    return row("{id}_row", [
        label("{id}_label", label_text),
        progress("{id}_bar", (percent as i32))
    ])

fn progress_with_counts(id: text, label_text: text, current: i32, total: i32) -> WidgetNode:
    """Create a progress widget with current/total counts."""
    val percent = if total == 0:
        0.0
    else:
        ((current as f64) / (total as f64)) * 100.0
    val count_text = "{current}/{total}"
    return row("{id}_row", [
        label("{id}_label", label_text),
        progress("{id}_bar", (percent as i32)),
        text_widget("{id}_count", count_text)
    ])

# =========================================================================
# Table → WidgetNode
# =========================================================================

fn table_to_widget(id: text, headers: [text], rows: [[text]]) -> WidgetNode:
    """Convert a table to a Table widget."""
    var node = WidgetNode.new(id, WidgetKind.Table)

    # Add header row
    var header_node = WidgetNode.new("{id}_header", WidgetKind.Text)
    header_node = header_node.set_prop("label", headers.join(" | "))
    node = node.add_child(header_node)

    # Add data rows
    var row_idx = 0
    for data_row in rows:
        var row_node = WidgetNode.new("{id}_row_{row_idx}", WidgetKind.Text)
        row_node = row_node.set_prop("label", data_row.join(" | "))
        node = node.add_child(row_node)
        row_idx = row_idx + 1

    return node

fn key_value_table_to_widget(id: text, pairs: [(text, text)]) -> WidgetNode:
    """Convert key-value pairs to a Table widget."""
    var headers: [text] = ["Key", "Value"]
    var rows: [[text]] = []
    for pair in pairs:
        rows.push([pair.0, pair.1])
    return table_to_widget(id, headers, rows)

# =========================================================================
# Dashboard Layout → WidgetNode
# =========================================================================

fn dashboard_layout(id: text, title: text, sections: [WidgetNode]) -> WidgetNode:
    """Create a standard dashboard layout with titled panel."""
    return panel(id, title, sections)
