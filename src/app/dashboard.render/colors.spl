@allow(unnamed_duplicate_typed_args)
# Dashboard Colors — Re-exports + Dashboard-Specific Utilities
#
# This file keeps a self-contained ANSI surface for the dashboard render
# layer so the render adapters and views can compile without depending on
# package-root re-export resolution.

val RESET: text = "\u{001b}[0m"
val BOLD: text = "\u{001b}[1m"
val DIM: text = "\u{001b}[2m"
val ITALIC: text = "\u{001b}[3m"
val UNDERLINE: text = "\u{001b}[4m"

val BLACK: text = "\u{001b}[30m"
val RED: text = "\u{001b}[31m"
val GREEN: text = "\u{001b}[32m"
val YELLOW: text = "\u{001b}[33m"
val BLUE: text = "\u{001b}[34m"
val MAGENTA: text = "\u{001b}[35m"
val CYAN: text = "\u{001b}[36m"
val WHITE: text = "\u{001b}[37m"

val BRIGHT_BLACK: text = "\u{001b}[90m"
val BRIGHT_RED: text = "\u{001b}[91m"
val BRIGHT_GREEN: text = "\u{001b}[92m"
val BRIGHT_YELLOW: text = "\u{001b}[93m"
val BRIGHT_BLUE: text = "\u{001b}[94m"
val BRIGHT_MAGENTA: text = "\u{001b}[95m"
val BRIGHT_CYAN: text = "\u{001b}[96m"
val BRIGHT_WHITE: text = "\u{001b}[97m"

# =========================================================================
# Shortcut Functions
# =========================================================================

fn red(text: text) -> text:
    return "{RED}{text}{RESET}"

fn green(text: text) -> text:
    return "{GREEN}{text}{RESET}"

fn yellow(text: text) -> text:
    return "{YELLOW}{text}{RESET}"

fn blue(text: text) -> text:
    return "{BLUE}{text}{RESET}"

fn cyan(text: text) -> text:
    return "{CYAN}{text}{RESET}"

fn magenta(text: text) -> text:
    return "{MAGENTA}{text}{RESET}"

fn bold(text: text) -> text:
    return "{BOLD}{text}{RESET}"

fn dim(text: text) -> text:
    return "{DIM}{text}{RESET}"

fn colorize(text: text, color: text) -> text:
    return "{color}{text}{RESET}"

# Color for status
fn status_color(status: text) -> text:
    match status:
        "complete" => GREEN
        "in_progress" => YELLOW
        "planned" => BLUE
        "blocked" => RED
        "failed" => RED
        "passed" => GREEN
        "skipped" => DIM
        _ => RESET

# Colorize by status
fn colorize_status(text: text, status: text) -> text:
    val color = status_color(status)
    return "{color}{text}{RESET}"

# =========================================================================
# HTML Color Helpers
# =========================================================================

# CSS class for status
fn status_css_class(status: text) -> text:
    match status:
        "complete" => "badge-green"
        "in_progress" => "badge-yellow"
        "planned" => "badge-blue"
        "blocked" => "badge-red"
        "failed" => "badge-red"
        "passed" => "badge-green"
        "skipped" => "badge-dim"
        _ => ""

# CSS color variable for threshold-based coloring
fn threshold_css_color(percent: f64) -> text:
    if percent >= 80.0:
        "var(--green, #3fb950)"
    elif percent >= 60.0:
        "var(--yellow, #d29922)"
    else:
        "var(--red, #f85149)"

# Wrap text in HTML span with status badge
fn html_badge(label: text, status: text) -> text:
    val cls = status_css_class(status)
    "<span class=\"badge {cls}\">{label}</span>"

# =========================================================================
# Exports
# =========================================================================

export RESET, BOLD, DIM, ITALIC, UNDERLINE
export BLACK, RED, GREEN, YELLOW, BLUE, MAGENTA, CYAN, WHITE
export BRIGHT_BLACK, BRIGHT_RED, BRIGHT_GREEN, BRIGHT_YELLOW
export BRIGHT_BLUE, BRIGHT_MAGENTA, BRIGHT_CYAN, BRIGHT_WHITE
export red, green, yellow, blue, cyan, magenta, bold, dim, colorize
export status_color, colorize_status, status_css_class, threshold_css_color, html_badge
export status_css_class, threshold_css_color, html_badge
