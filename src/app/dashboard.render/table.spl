# ASCII Table Rendering
#
# Re-exports from shared ui.render.table module for backward compatibility.
# New code should import from app.ui.render.table directly.

use app.ui.render.table.{
    TableBuilder, ALIGN_LEFT, ALIGN_RIGHT, ALIGN_CENTER,
    pad_right, pad_left, center,
    render_kv_table, render_html_table_limited
}

# =========================================================================
# Backward-Compatible Aliases
# =========================================================================

# render_key_value_table delegates to the shared render_kv_table
fn render_key_value_table(pairs: [(text, text)]) -> text:
    render_kv_table(pairs)

# render_html_table remains here as a simple convenience wrapper
fn render_html_table(headers: [text], rows: [[text]]) -> text:
    var h = "<table class=\"data-table\"><tr>"
    for header in headers:
        h = "{h}<th>{header}</th>"
    h = "{h}</tr>"
    for row in rows:
        h = "{h}<tr>"
        for cell in row:
            h = "{h}<td>{cell}</td>"
        h = "{h}</tr>"
    h = "{h}</table>"
    h

# =========================================================================
# Exports
# =========================================================================
export render_html_table_limited
