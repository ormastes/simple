@allow(unnamed_duplicate_typed_args)
# mcpgdb MCP production wrapper — cold frontend with repo-local heavy runners

extern fn rt_env_cwd() -> text
extern fn rt_env_get(name: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

use examples.mcpgdb.json_helpers.{read_stdin_message, write_stdout_message, extract_field, has_method, jsonrpc_result, jsonrpc_error, LB, RB, shell_bin, shell_quote}
use examples.mcpgdb.protocol.{make_init_response, make_tools_list}

val DEBUG_RUNNER_SOURCE = "src/app/mcpgdb/debug_runner.spl"
val DEBUG_EXEC_RUNNER_SOURCE = "src/app/mcpgdb/debug_exec_runner.spl"
val DEBUG_SESSION_RUNNER_SOURCE = "src/app/mcpgdb/debug_session_runner.spl"
val DEBUG_STATE_RUNNER_SOURCE = "src/app/mcpgdb/debug_state_runner.spl"
val CLANGD_RUNNER_SOURCE = "src/app/mcpgdb/clangd_runner.spl"

fn main():
    while true:
        val msg = read_stdin_message()
        if msg == "":
            return
        val id = local_extract_id(msg)
        val method = detect_method(msg)
        var response = ""
        if method == "initialize":
            response = make_init_response(id)
        elif method == "initialized" or method == "notifications/initialized" or method == "notifications/cancelled" or method == "notifications/roots/list_changed":
            response = ""
        elif method == "shutdown":
            response = jsonrpc_result(id, "null")
        elif method == "ping":
            response = jsonrpc_result(id, LB() + RB())
        elif method == "tools/list":
            response = make_tools_list(id)
        elif method == "tools/call":
            response = run_tool_runner(id, msg)
        else:
            if id != "" and id != "null":
                response = jsonrpc_error(id, -32601, "Method not found: " + method)
        if response != "":
            write_stdout_message(response)

fn local_extract_id(json: text) -> text:
    val parts1 = json.split("\"id\":\"")
    if parts1.len() >= 2:
        return "\"" + parts1[1].split("\"")[0] + "\""
    val parts2 = json.split("\"id\": \"")
    if parts2.len() >= 2:
        return "\"" + parts2[1].split("\"")[0] + "\""
    "null"

fn detect_method(msg: text) -> text:
    if has_method(msg, "initialize"):
        return "initialize"
    if has_method(msg, "initialized"):
        return "initialized"
    if has_method(msg, "notifications/initialized"):
        return "notifications/initialized"
    if has_method(msg, "shutdown"):
        return "shutdown"
    if has_method(msg, "ping"):
        return "ping"
    if has_method(msg, "tools/list"):
        return "tools/list"
    if has_method(msg, "tools/call"):
        return "tools/call"
    if has_method(msg, "notifications/cancelled"):
        return "notifications/cancelled"
    if has_method(msg, "notifications/roots/list_changed"):
        return "notifications/roots/list_changed"
    extract_field(msg, "method")

fn simple_binary() -> text:
    val env_value = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_value != "":
        return env_value
    "bin/simple"

fn temp_request_path() -> text:
    val (stdout, _stderr, code) = rt_process_run(shell_bin(), ["-c", "mktemp /tmp/mcpgdb_request.XXXXXX"])
    if code != 0:
        return ""
    stdout.trim()

fn body_has_tool(body: text, name: text) -> bool:
    body.contains("\"name\":\"" + name + "\"") or body.contains("\"name\": \"" + name + "\"")

fn runner_source_for_body(body: text) -> text:
    if body_has_tool(body, "debug_session_create") or body_has_tool(body, "debug_session_close"):
        return DEBUG_SESSION_RUNNER_SOURCE
    if body_has_tool(body, "debug_command_run"):
        return DEBUG_EXEC_RUNNER_SOURCE
    if body_has_tool(body, "workspace_open") or body_has_tool(body, "workspace_status") or body_has_tool(body, "debug_session_list") or body_has_tool(body, "debug_session_select"):
        return DEBUG_STATE_RUNNER_SOURCE
    if body_has_tool(body, "clangd_open") or body_has_tool(body, "clangd_definition") or body_has_tool(body, "clangd_references") or body_has_tool(body, "clangd_hover") or body_has_tool(body, "clangd_completion") or body_has_tool(body, "clangd_type_definition") or body_has_tool(body, "clangd_symbols") or body_has_tool(body, "clangd_diagnostics"):
        return CLANGD_RUNNER_SOURCE
    DEBUG_RUNNER_SOURCE

fn sanitize_segment(value: text) -> text:
    if value == "":
        return "_"
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "." or ch == "-" or ch == "_":
            out = out + ch
        else:
            out = out + "_"
        i = i + 1
    if out == "":
        return "_"
    out

fn runner_cache_dir() -> text:
    "/tmp/mcpgdb_compiled_" + sanitize_segment(rt_env_cwd())

fn runner_artifact_path(source: text) -> text:
    var base = source.replace("/", "_")
    base = base.replace(".spl", ".smf")
    runner_cache_dir() + "/" + base

fn ensure_runner_artifact(source: text) -> text:
    val artifact = runner_artifact_path(source)
    if rt_file_exists(artifact):
        return artifact
    rt_dir_create(runner_cache_dir(), true)
    val (_stdout, _stderr, code) = rt_process_run(simple_binary(), ["compile", source, "-o", artifact])
    if code != 0:
        return ""
    artifact

fn run_compiled_runner(artifact: text, request_path: text) -> (text, text, i64):
    val cmd = "MCPGDB_REQUEST_PATH=" + shell_quote(request_path) + " " + shell_quote(simple_binary()) + " " + shell_quote(artifact)
    rt_process_run(shell_bin(), ["-c", cmd])

fn run_source_runner(source: text, request_path: text) -> (text, text, i64):
    val cmd = "MCPGDB_REQUEST_PATH=" + shell_quote(request_path) + " " + shell_quote(simple_binary()) + " " + shell_quote(source)
    rt_process_run(shell_bin(), ["-c", cmd])

fn run_tool_runner(id: text, body: text) -> text:
    val request_path = temp_request_path()
    if request_path == "":
        return jsonrpc_error(id, -32603, "failed to allocate temp request file")
    if not rt_file_write_text(request_path, body):
        return jsonrpc_error(id, -32603, "failed to write temp request file")
    val source = runner_source_for_body(body)
    var stdout = ""
    var stderr = ""
    var code = 0
    val artifact = ensure_runner_artifact(source)
    if artifact != "":
        (stdout, stderr, code) = run_compiled_runner(artifact, request_path)
    if artifact == "" or code != 0 or stdout.trim() == "":
        (stdout, stderr, code) = run_source_runner(source, request_path)
    rt_file_delete(request_path)
    if code != 0:
        var message = stderr.trim()
        if message == "":
            message = stdout.trim()
        if message == "":
            message = "tool runner failed"
        return jsonrpc_error(id, -32603, message)
    val response = stdout.trim()
    if response == "":
        return jsonrpc_error(id, -32603, "tool runner returned empty response")
    response

main()
