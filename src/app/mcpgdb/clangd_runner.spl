@allow(unnamed_duplicate_typed_args)
# mcpgdb clangd runner — repo-local wrapper to avoid examples timeout path

extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(name: text) -> text

use app.mcpgdb.json_helpers.{extract_id, jsonrpc_error}
use app.mcpgdb.state.{load_persisted_state, save_persisted_state}
use app.mcpgdb.clangd_tools

fn main():
    val path = rt_env_get("MCPGDB_REQUEST_PATH") ?? ""
    if path == "":
        print jsonrpc_error("null", -32602, "missing request path")
        return
    val body = rt_file_read_text(path) ?? ""
    if body == "":
        print jsonrpc_error("null", -32602, "empty request body")
        return
    val id = extract_id(body)
    load_persisted_state()
    val response = dispatch_tool(id, body)
    save_persisted_state()
    print response

fn dispatch_tool(id: text, body: text) -> text:
    if body.contains("\"name\":\"clangd_open\"") or body.contains("\"name\": \"clangd_open\""):
        return clangd_tools.handle_workspace_clangd_open(id, body)
    if body.contains("\"name\":\"clangd_definition\"") or body.contains("\"name\": \"clangd_definition\""):
        return clangd_tools.handle_clangd_definition(id, body)
    if body.contains("\"name\":\"clangd_references\"") or body.contains("\"name\": \"clangd_references\""):
        return clangd_tools.handle_clangd_references(id, body)
    if body.contains("\"name\":\"clangd_hover\"") or body.contains("\"name\": \"clangd_hover\""):
        return clangd_tools.handle_clangd_hover(id, body)
    if body.contains("\"name\":\"clangd_completion\"") or body.contains("\"name\": \"clangd_completion\""):
        return clangd_tools.handle_clangd_completion(id, body)
    if body.contains("\"name\":\"clangd_type_definition\"") or body.contains("\"name\": \"clangd_type_definition\""):
        return clangd_tools.handle_clangd_type_definition(id, body)
    if body.contains("\"name\":\"clangd_symbols\"") or body.contains("\"name\": \"clangd_symbols\""):
        return clangd_tools.handle_clangd_symbols(id, body)
    if body.contains("\"name\":\"clangd_diagnostics\"") or body.contains("\"name\": \"clangd_diagnostics\""):
        return clangd_tools.handle_clangd_diagnostics(id, body)
    jsonrpc_error(id, -32602, "Unknown clangd tool")
