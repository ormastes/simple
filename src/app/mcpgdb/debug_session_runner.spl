@allow(unnamed_duplicate_typed_args)
# mcpgdb session lifecycle runner — narrow path for session registry updates

extern fn rt_env_get(name: text) -> text
extern fn rt_dir_remove_all(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

use app.mcpgdb.json_helpers.{extract_id, extract_nested, make_tool_error, make_tool_result, LB, RB, jp, js}
use app.mcpgdb.state.{DebugSession, MCPGDB_SESSIONS, save_persisted_state, next_session_id, set_current_session, current_or_named_session, remove_session, session_count}
use app.mcpgdb.state_loader.{load_persisted_state_safe}
use app.mcpgdb.debug_backend_common.{choose_workspace_root, make_session}

fn session_json_message(fields: [text]) -> text:
    LB() + fields.join(",") + RB()

fn put_session_local(session: DebugSession):
    var kept: [DebugSession] = []
    var replaced = false
    for existing in MCPGDB_SESSIONS:
        if existing.session_id == session.session_id:
            kept = kept + [session]
            replaced = true
        else:
            kept = kept + [existing]
    if not replaced:
        kept = kept + [session]
    MCPGDB_SESSIONS = kept

fn handle_debug_session_create(id: text, body: text) -> text:
    var backend = extract_nested(body, "backend")
    if backend == "":
        backend = "gdb"
    val workspace_root = choose_workspace_root(extract_nested(body, "workspace_root"))
    val session_id = next_session_id()
    var session = make_session(session_id, backend, workspace_root)
    session.bootstrap_monitor = extract_nested(body, "bootstrap_monitor")
    session.state = "created"
    put_session_local(session)
    set_current_session(session_id)
    make_tool_result(id, session_json_message([
        jp("session_id", js(session.session_id)),
        jp("backend", js(session.backend)),
        jp("state", js(session.state)),
        jp("workspace_root", js(session.workspace_root))
    ]))

fn stop_session_process_local(session: DebugSession):
    if session.process_pid != "":
        val (_stdout, _stderr, _code) = rt_process_run("bash", ["-lc", "kill " + session.process_pid + " >/dev/null 2>&1 || true"])
    rt_dir_remove_all(session.session_dir)

fn handle_debug_session_close(id: text, body: text) -> text:
    val session_id = extract_nested(body, "session_id")
    if val session = current_or_named_session(session_id):
        stop_session_process_local(session)
        remove_session(session.session_id)
        return make_tool_result(id, session_json_message([
            jp("closed", js(session.session_id)),
            jp("remaining_sessions", str(session_count()))
        ]))
    make_tool_error(id, "session not found")

fn main():
    val path = rt_env_get("MCPGDB_REQUEST_PATH") ?? ""
    if path == "":
        print make_tool_error("null", "missing request path")
        return
    val body = rt_file_read_text(path) ?? ""
    if body == "":
        print make_tool_error("null", "empty request body")
        return
    val id = extract_id(body)
    load_persisted_state_safe()
    var response = make_tool_error(id, "Unknown debug session tool")
    if body.contains("\"name\":\"debug_session_create\"") or body.contains("\"name\": \"debug_session_create\""):
        response = handle_debug_session_create(id, body)
    elif body.contains("\"name\":\"debug_session_close\"") or body.contains("\"name\": \"debug_session_close\""):
        response = handle_debug_session_close(id, body)
    save_persisted_state()
    print response
