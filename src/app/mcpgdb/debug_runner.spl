#![allow(unnamed_duplicate_typed_args)]
# mcpgdb debug runner — repo-local wrapper to avoid examples timeout path

extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(name: text) -> text

use app.mcpgdb.json_helpers.{extract_id, jsonrpc_error}
use app.mcpgdb.state.{save_persisted_state}
use app.mcpgdb.state_loader.{load_persisted_state_safe}
use app.mcpgdb.debug_tools

fn main():
    val path = rt_env_get("MCPGDB_REQUEST_PATH") ?? ""
    if path == "":
        print jsonrpc_error("null", -32602, "missing request path")
        return
    val body = rt_file_read_text(path) ?? ""
    if body == "":
        print jsonrpc_error("null", -32602, "empty request body")
        return
    val id = extract_id(body)
    load_persisted_state_safe()
    val response = dispatch_tool(id, body)
    save_persisted_state()
    print response

fn dispatch_tool(id: text, body: text) -> text:
    if body.contains("\"name\":\"workspace_open\"") or body.contains("\"name\": \"workspace_open\""):
        return debug_tools.handle_workspace_open(id, body)
    if body.contains("\"name\":\"workspace_status\"") or body.contains("\"name\": \"workspace_status\""):
        return debug_tools.handle_workspace_status(id, body)
    if body.contains("\"name\":\"debug_session_list\"") or body.contains("\"name\": \"debug_session_list\""):
        return debug_tools.handle_debug_session_list(id, body)
    if body.contains("\"name\":\"debug_session_select\"") or body.contains("\"name\": \"debug_session_select\""):
        return debug_tools.handle_debug_session_select(id, body)
    if body.contains("\"name\":\"debug_launch\"") or body.contains("\"name\": \"debug_launch\""):
        return debug_tools.handle_debug_launch(id, body)
    if body.contains("\"name\":\"debug_attach\"") or body.contains("\"name\": \"debug_attach\""):
        return debug_tools.handle_debug_attach(id, body)
    if body.contains("\"name\":\"debug_connect_remote\"") or body.contains("\"name\": \"debug_connect_remote\""):
        return debug_tools.handle_debug_connect_remote(id, body)
    if body.contains("\"name\":\"debug_disconnect\"") or body.contains("\"name\": \"debug_disconnect\""):
        return debug_tools.handle_debug_disconnect(id, body)
    if body.contains("\"name\":\"debug_restart\"") or body.contains("\"name\": \"debug_restart\""):
        return debug_tools.handle_debug_restart(id, body)
    if body.contains("\"name\":\"debug_continue\"") or body.contains("\"name\": \"debug_continue\""):
        return debug_tools.handle_debug_continue(id, body)
    if body.contains("\"name\":\"debug_pause\"") or body.contains("\"name\": \"debug_pause\""):
        return debug_tools.handle_debug_pause(id, body)
    if body.contains("\"name\":\"debug_step_in\"") or body.contains("\"name\": \"debug_step_in\""):
        return debug_tools.handle_debug_step_in(id, body)
    if body.contains("\"name\":\"debug_step_over\"") or body.contains("\"name\": \"debug_step_over\""):
        return debug_tools.handle_debug_step_over(id, body)
    if body.contains("\"name\":\"debug_step_out\"") or body.contains("\"name\": \"debug_step_out\""):
        return debug_tools.handle_debug_step_out(id, body)
    if body.contains("\"name\":\"breakpoint_set\"") or body.contains("\"name\": \"breakpoint_set\""):
        return debug_tools.handle_breakpoint_set(id, body)
    if body.contains("\"name\":\"breakpoint_remove\"") or body.contains("\"name\": \"breakpoint_remove\""):
        return debug_tools.handle_breakpoint_remove(id, body)
    if body.contains("\"name\":\"breakpoint_list\"") or body.contains("\"name\": \"breakpoint_list\""):
        return debug_tools.handle_breakpoint_list(id, body)
    if body.contains("\"name\":\"thread_list\"") or body.contains("\"name\": \"thread_list\""):
        return debug_tools.handle_thread_list(id, body)
    if body.contains("\"name\":\"frame_list\"") or body.contains("\"name\": \"frame_list\""):
        return debug_tools.handle_frame_list(id, body)
    if body.contains("\"name\":\"frame_select\"") or body.contains("\"name\": \"frame_select\""):
        return debug_tools.handle_frame_select(id, body)
    if body.contains("\"name\":\"variable_list\"") or body.contains("\"name\": \"variable_list\""):
        return debug_tools.handle_variable_list(id, body)
    if body.contains("\"name\":\"evaluate\"") or body.contains("\"name\": \"evaluate\""):
        return debug_tools.handle_evaluate(id, body)
    if body.contains("\"name\":\"register_read\"") or body.contains("\"name\": \"register_read\""):
        return debug_tools.handle_register_read(id, body)
    if body.contains("\"name\":\"register_write\"") or body.contains("\"name\": \"register_write\""):
        return debug_tools.handle_register_write(id, body)
    if body.contains("\"name\":\"memory_read\"") or body.contains("\"name\": \"memory_read\""):
        return debug_tools.handle_memory_read(id, body)
    if body.contains("\"name\":\"memory_write\"") or body.contains("\"name\": \"memory_write\""):
        return debug_tools.handle_memory_write(id, body)
    if body.contains("\"name\":\"debug_command_run\"") or body.contains("\"name\": \"debug_command_run\""):
        return debug_tools.handle_debug_command_run(id, body)
    jsonrpc_error(id, -32602, "Unknown debug tool")
