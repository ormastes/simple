# mcpgdb MCP — debugger-only backend helpers

use std.io_runtime.{cwd, dir_create, file_exists, file_read, file_size, process_run}
use std.nogc_sync_mut.io.dir_ops.{dir_remove_all}

use app.mcpgdb.json_helpers.{shell_bin, shell_quote, shell_sleep, find_binary, LB, RB, jp, js}
use app.mcpgdb.state.{DebugSession, MCPGDB_SESSIONS}

fn cwd_path() -> text:
    val cwd_val = cwd()
    if cwd_val != "":
        return cwd_val
    "."

fn choose_workspace_root(root: text) -> text:
    if root != "":
        return root
    cwd_path()

fn gdb_binary() -> text:
    find_binary("GDB_BINARY", ["gdb", "gdb-multiarch"])

fn lldb_binary() -> text:
    find_binary("LLDB_BINARY", ["lldb"])

fn ps_is_alive(pid: text) -> bool:
    if pid == "":
        return false
    val (_stdout, _stderr, code) = process_run(shell_bin(), ["-c", "ps -p " + shell_quote(pid) + " >/dev/null 2>&1"])
    code == 0

fn session_prompt(session_id: text) -> text:
    "[mcpgdb:" + session_id + "] "

fn initial_backend_prompt(session: DebugSession) -> text:
    if session.backend == "lldb":
        return "(lldb) "
    "(gdb) "

fn debugger_launch_command(session: DebugSession) -> text:
    if session.backend == "lldb":
        val lldb = lldb_binary()
        if lldb == "":
            return ""
        return shell_quote(lldb) + " --no-lldbinit"
    val gdb = gdb_binary()
    if gdb == "":
        return ""
    shell_quote(gdb) + " --quiet --nx"

fn init_debugger_session(session: DebugSession) -> DebugSession:
    var updated = session
    val prompt = session_prompt(session.session_id)
    updated.prompt = initial_backend_prompt(session)
    if session.backend == "lldb":
        val _r = run_session_command(updated, "settings set prompt " + prompt, true)
        val _r2 = run_session_command(updated, "settings set auto-confirm true", true)
        updated.prompt = prompt
        return updated
    val _r3 = run_session_command(updated, "set pagination off", true)
    val _r4 = run_session_command(updated, "set confirm off", true)
    val _r5 = run_session_command(updated, "set prompt " + prompt, true)
    updated.prompt = prompt
    updated

fn create_debugger_process(session: DebugSession) -> (DebugSession, text):
    var updated = session
    dir_create(updated.session_dir, true)
    val launch = debugger_launch_command(updated)
    if launch == "":
        return (updated, "required debugger binary not found for backend " + updated.backend)
    val inner = "exec 3<>" + shell_quote(updated.input_path) + " ; exec " + launch + " <&3"
    val cmd = "rm -f " + shell_quote(updated.input_path) + " " + shell_quote(updated.output_path) + " " + shell_quote(updated.error_path)
        + " ; mkfifo " + shell_quote(updated.input_path)
        + " ; : > " + shell_quote(updated.output_path)
        + " ; : > " + shell_quote(updated.error_path)
        + " ; nohup " + shell_quote(shell_bin()) + " -lc " + shell_quote(inner)
        + " < /dev/null > " + shell_quote(updated.output_path)
        + " 2> " + shell_quote(updated.error_path)
        + " & echo $!"
    val (stdout, stderr, code) = process_run(shell_bin(), ["-c", cmd])
    if code != 0:
        return (updated, "failed to launch debugger: " + stderr.trim())
    updated.process_pid = stdout.trim()
    if updated.process_pid == "":
        return (updated, "failed to capture debugger pid")
    shell_sleep("0.10")
    if not ps_is_alive(updated.process_pid):
        return (updated, "debugger process exited immediately")
    updated = init_debugger_session(updated)
    updated.state = "ready"
    (updated, "")

fn send_fifo_line(fifo_path: text, line: text) -> text:
    val (stdout, stderr, code) =
        process_run(shell_bin(), ["-c", "printf '%s\\n' " + shell_quote(line) + " > " + shell_quote(fifo_path)])
    if code != 0:
        if stderr.trim() != "":
            return stderr.trim()
        return stdout.trim()
    ""

fn read_output_delta(path: text, offset: i64) -> text:
    val all = file_read(path)
    if all.len() <= offset:
        return ""
    all.substring(offset, all.len())

fn strip_prompt(output: text, prompt: text) -> text:
    var result = output
    if result.contains(prompt):
        val idx_opt = result.last_index_of(prompt)
        match idx_opt:
            Some(idx):
                result = result.substring(0, idx)
            nil: pass
    result.trim()

fn run_session_command(session: DebugSession, command: text, allow_timeout: bool) -> text:
    if session.process_pid == "" or not ps_is_alive(session.process_pid):
        return LB() + jp("status", js("error")) + "," + jp("message", js("session process is not alive")) + RB()
    val before = file_size(session.output_path)
    val err_text = send_fifo_line(session.input_path, command)
    if err_text != "":
        return LB() + jp("status", js("error")) + "," + jp("message", js(err_text)) + RB()
    var attempt = 0
    var chunk = ""
    while attempt < 30:
        shell_sleep("0.05")
        chunk = read_output_delta(session.output_path, before)
        if chunk != "" and (session.prompt == "" or chunk.contains(session.prompt)):
            break
        attempt = attempt + 1
    if chunk == "" and not allow_timeout:
        val stderr_text = file_read(session.error_path)
        return LB() + jp("status", js("error")) + "," + jp("message", js("no backend response")) + "," + jp("stderr", js(stderr_text.trim())) + RB()
    val clean = strip_prompt(chunk, session.prompt)
    var result = LB()
    result = result + jp("status", js("ok"))
    result = result + "," + jp("command", js(command))
    result = result + "," + jp("output", js(clean))
    result = result + RB()
    result

fn build_session_dir(session_id: text) -> text:
    "/tmp/mcpgdb_" + session_id

fn make_session(session_id: text, backend: text, workspace_root: text) -> DebugSession:
    val session_dir = build_session_dir(session_id)
    DebugSession(
        session_id: session_id,
        backend: backend,
        state: "starting",
        workspace_root: workspace_root,
        process_pid: "",
        input_path: session_dir + "/stdin.fifo",
        output_path: session_dir + "/stdout.log",
        error_path: session_dir + "/stderr.log",
        session_dir: session_dir,
        prompt: "",
        remote_host: "",
        remote_port: "",
        current_thread: "",
        current_frame: "",
        bootstrap_monitor: ""
    )

fn graceful_quit_debugger(session: DebugSession):
    if session.process_pid == "" or not ps_is_alive(session.process_pid):
        return
    val _err = send_fifo_line(session.input_path, "quit")
    shell_sleep("0.20")

fn kill_process_children(pid: text):
    val (_s, _e, _c) = process_run(shell_bin(), ["-c",
        "pkill -TERM -P " + shell_quote(pid) + " >/dev/null 2>&1 || true"])
    shell_sleep("0.10")
    val (_s2, _e2, _c2) = process_run(shell_bin(), ["-c",
        "pkill -9 -P " + shell_quote(pid) + " >/dev/null 2>&1 || true"])

fn kill_pid_escalating(pid: text):
    val (_s1, _e1, _c1) = process_run(shell_bin(), ["-c",
        "kill " + shell_quote(pid) + " >/dev/null 2>&1 || true"])
    shell_sleep("0.30")
    if ps_is_alive(pid):
        val (_s2, _e2, _c2) = process_run(shell_bin(), ["-c",
            "kill -9 " + shell_quote(pid) + " >/dev/null 2>&1 || true"])
        shell_sleep("0.10")

fn stop_session_process(session: DebugSession):
    if session.process_pid != "":
        graceful_quit_debugger(session)
        kill_process_children(session.process_pid)
        kill_pid_escalating(session.process_pid)
    dir_remove_all(session.session_dir)

fn cleanup_stale_sessions():
    var kept: [DebugSession] = []
    for session in MCPGDB_SESSIONS:
        if session.process_pid != "" and not ps_is_alive(session.process_pid):
            dir_remove_all(session.session_dir)
        else:
            kept.push(session)
    MCPGDB_SESSIONS = kept
