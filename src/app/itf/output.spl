# ITF CLI — gh-compatible output formatting
#
# Supports: --json <fields>, --jq <expr>, --web, --no-pager
# Respects: NO_COLOR, ITF_FORCE_COLOR, ITF_PAGER, PAGER

use std.nogc_sync_mut.env.{env_get, env_has}
use std.common.report.ansi.{ansi_red, ansi_green, ansi_yellow, ansi_blue, ansi_bold, ansi_reset, ansi_dim, ansi_cyan}
use std.common.json.{json_parse, json_serialize, json_pretty, json_object_get, json_object_keys, json_object_has, json_object, json_string, json_array, json_array_get, json_array_length, json_get_type}
use app.itf.flags.{_extract_flag, _has_flag}


fn should_use_color() -> bool:
    """Check if color output should be used."""
    if env_has("NO_COLOR"):
        return false
    val force = env_get("ITF_FORCE_COLOR")
    if force == "1":
        return true
    true


fn print_error(msg: text):
    """Print error message to stderr (red if color enabled)."""
    if should_use_color():
        print "{ansi_red()}error:{ansi_reset()} {msg}"
    else:
        print "error: {msg}"


fn print_success(msg: text):
    """Print success message (green if color enabled)."""
    if should_use_color():
        print "{ansi_green()}{msg}{ansi_reset()}"
    else:
        print msg


fn print_warning(msg: text):
    """Print warning message (yellow if color enabled)."""
    if should_use_color():
        print "{ansi_yellow()}warning:{ansi_reset()} {msg}"
    else:
        print "warning: {msg}"


fn print_info(label: text, value: text):
    """Print a label: value pair with colored label."""
    if should_use_color():
        print "{ansi_bold()}{label}:{ansi_reset()} {value}"
    else:
        print "{label}: {value}"


fn print_dim(msg: text):
    """Print dimmed text."""
    if should_use_color():
        print "{ansi_dim()}{msg}{ansi_reset()}"
    else:
        print msg


fn format_json_output(data: text, args: [text]) -> text:
    """Apply --json field filtering and --jq queries to JSON data.

    Args:
        data: Raw JSON string from API
        args: CLI args to check for --json and --jq flags

    Returns:
        Formatted output string
    """
    val json_fields = _extract_flag(args, "--json", "")
    val jq_expr = _extract_flag(args, "--jq", "")

    if json_fields != "":
        return _filter_json_fields(data, json_fields)

    if jq_expr != "":
        return _apply_jq(data, jq_expr)

    # Default: pretty-print the JSON
    val parsed = json_parse(data)
    if parsed != nil:
        return json_pretty(parsed)
    data


fn wants_json(args: [text]) -> bool:
    """Check if user requested JSON output."""
    _has_flag(args, "--json") or _extract_flag(args, "--format", "") == "json"


fn _filter_json_fields(data: text, fields: text) -> text:
    """Filter JSON to only include specified fields."""
    val parsed = json_parse(data)
    if parsed == nil:
        return data

    val field_list = fields.split(",")
    val data_type = json_get_type(parsed)

    if data_type == "array":
        # Filter each item in array
        var items: [text] = []
        var i = 0
        val arr_len = json_array_length(parsed)
        while i < arr_len:
            val item = json_array_get(parsed, i)
            val filtered = _filter_object_fields(item, field_list)
            items = items + [json_serialize(filtered)]
            i = i + 1
        return "[" + items.join(", ") + "]"
    else if data_type == "object":
        val filtered = _filter_object_fields(parsed, field_list)
        return json_pretty(filtered)

    data


fn _filter_object_fields(obj: any, fields: [text]) -> any:
    """Keep only specified fields from a JSON object."""
    var pairs: [(text, any)] = []
    for field in fields:
        val trimmed = field.trim()
        if json_object_has(obj, trimmed):
            val value = json_object_get(obj, trimmed)
            pairs = pairs + [(trimmed, value)]
    json_object(pairs)


fn _apply_jq(data: text, expr: text) -> text:
    """Simple jq-like path query. Supports .field, .[].field, .[N]."""
    val parsed = json_parse(data)
    if parsed == nil:
        return data

    # Simple path navigation
    val path = expr.trim()
    if path == ".":
        return json_pretty(parsed)

    # Strip leading dot
    val clean_path = if path.starts_with("."): path[1:] else: path

    # Handle .[].field pattern (array iteration)
    if clean_path.starts_with("[]."):
        val field = clean_path[3:]
        val arr_len = json_array_length(parsed)
        var results: [text] = []
        var i = 0
        while i < arr_len:
            val item = json_array_get(parsed, i)
            val value = json_object_get(item, field)
            results = results + [json_serialize(value)]
            i = i + 1
        return results.join("\n")

    # Simple field access
    val value = json_object_get(parsed, clean_path)
    if value != nil:
        val vtype = json_get_type(value)
        if vtype == "string":
            return json_serialize(value)
        return json_pretty(value)

    ""


fn print_table_header(columns: [text]):
    """Print a table header row with formatting."""
    if should_use_color():
        var header = ""
        for col in columns:
            header = header + "{ansi_bold()}{col.pad_right(20)}{ansi_reset()}"
        print header
    else:
        var header = ""
        for col in columns:
            header = header + col.pad_right(20)
        print header


fn print_table_row(values: [text]):
    """Print a table data row."""
    var row = ""
    for val_text in values:
        row = row + val_text.pad_right(20)
    print row


fn open_in_browser(url: text) -> i64:
    """Open URL in browser (--web flag handler)."""
    use std.nogc_sync_mut.io.process_ops.{process_run}

    # Try platform-specific openers
    val (_, _, code) = process_run("xdg-open", [url])
    if code == 0:
        return 0
    val (_, _, code2) = process_run("open", [url])
    if code2 == 0:
        return 0
    print_error("could not open browser for: {url}")
    1
