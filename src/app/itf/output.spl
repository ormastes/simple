# ITF CLI — gh-compatible output formatting
#
# Supports: --json <fields>, --jq <expr>, --web, --no-pager
# Respects: NO_COLOR, ITF_FORCE_COLOR, ITF_PAGER, PAGER

use std.nogc_sync_mut.env.{env_get, env_has}
use app.ui.render.ansi.{ansi_red, ansi_green, ansi_yellow, ansi_bold, ansi_reset, ansi_dim}
use std.json.{json_parse, json_serialize, json_pretty, json_object_get, json_object_keys, json_object_has, json_object, json_string, json_array, json_array_get, json_array_length, json_get_type}
use app.itf.flags.{_extract_flag, _has_flag}


fn should_use_color() -> bool:
    """Check if color output should be used."""
    if env_has("NO_COLOR"):
        return false
    val force = env_get("ITF_FORCE_COLOR")
    if force == "1":
        return true
    true


fn format_size(bytes: i64) -> text:
    """Human-readable size: B / KiB / MiB / GiB / TiB, 1 decimal place
    (bytes shown as a bare integer). Uses scaled-integer math (value*10 /
    divisor, split into whole.frac) rather than float formatting, since
    that keeps rounding behavior exact and independent of float-to-text
    precision. Negative input (unknown size, e.g. -1) passes through as-is.
    """
    if bytes < 0:
        return "{bytes}"
    if bytes < 1024:
        return "{bytes} B"
    val kib = 1024
    val mib = kib * 1024
    val gib = mib * 1024
    val tib = gib * 1024
    val (scaled, unit) = if bytes < mib:
        (bytes * 10 / kib, "KiB")
    else if bytes < gib:
        (bytes * 10 / mib, "MiB")
    else if bytes < tib:
        (bytes * 10 / gib, "GiB")
    else:
        (bytes * 10 / tib, "TiB")
    val whole = scaled / 10
    val frac = scaled % 10
    "{whole}.{frac} {unit}"


fn print_error(msg: text):
    """Print error message to stderr (red if color enabled)."""
    if should_use_color():
        print "{ansi_red()}error:{ansi_reset()} {msg}"
    else:
        print "error: {msg}"


fn print_success(msg: text):
    """Print success message (green if color enabled)."""
    if should_use_color():
        print "{ansi_green()}{msg}{ansi_reset()}"
    else:
        print msg


fn print_warning(msg: text):
    """Print warning message (yellow if color enabled)."""
    if should_use_color():
        print "{ansi_yellow()}warning:{ansi_reset()} {msg}"
    else:
        print "warning: {msg}"


fn print_info(label: text, value: text):
    """Print a label: value pair with colored label."""
    if should_use_color():
        print "{ansi_bold()}{label}:{ansi_reset()} {value}"
    else:
        print "{label}: {value}"


fn print_dim(msg: text):
    """Print dimmed text."""
    if should_use_color():
        print "{ansi_dim()}{msg}{ansi_reset()}"
    else:
        print msg


fn format_json_output(data: text, args: [text]) -> text:
    """Apply --json field filtering and --jq queries to JSON data.

    Args:
        data: Raw JSON string from API
        args: CLI args to check for --json and --jq flags

    Returns:
        Formatted output string
    """
    val json_fields = _extract_flag(args, "--json", "")
    val jq_expr = _extract_flag(args, "--jq", "")

    if json_fields != "":
        return _filter_json_fields(data, json_fields)

    if jq_expr != "":
        return _apply_jq(data, jq_expr)

    # Default: pretty-print the JSON
    val parsed = json_parse(data)
    if parsed != nil:
        return json_pretty(parsed)
    data


fn wants_json(args: [text]) -> bool:
    """Check if user requested JSON output."""
    _has_flag(args, "--json") or _extract_flag(args, "--format", "") == "json"


fn _filter_json_fields(data: text, fields: text) -> text:
    """Filter JSON to only include specified fields."""
    val parsed = json_parse(data)
    if parsed == nil:
        return data

    val field_list = fields.split(",")
    val data_type = json_get_type(parsed)

    if data_type == "array":
        # Filter each item in array
        var items: [text] = []
        var i = 0
        val arr_len = json_array_length(parsed)
        while i < arr_len:
            val item = json_array_get(parsed, i)
            val filtered = _filter_object_fields(item, field_list)
            items = items + [json_serialize(filtered)]
            i = i + 1
        return "[" + items.join(", ") + "]"
    else if data_type == "object":
        val filtered = _filter_object_fields(parsed, field_list)
        return json_pretty(filtered)

    data


fn _filter_object_fields(obj: any, fields: [text]) -> any:
    """Keep only specified fields from a JSON object."""
    var pairs: [(text, any)] = []
    for field in fields:
        val trimmed = field.trim()
        if json_object_has(obj, trimmed):
            val value = json_object_get(obj, trimmed)
            pairs = pairs + [(trimmed, value)]
    json_object(pairs)


fn _apply_jq(data: text, expr: text) -> text:
    """Simple jq-like path query. Supports .field, .[].field, .[N]."""
    val parsed = json_parse(data)
    if parsed == nil:
        return data

    # Simple path navigation
    val path = expr.trim()
    if path == ".":
        return json_pretty(parsed)

    # Strip leading dot
    val clean_path = if path.starts_with("."): path[1:] else: path

    # Handle .[].field pattern (array iteration)
    if clean_path.starts_with("[]."):
        val field = clean_path[3:]
        val arr_len = json_array_length(parsed)
        var results: [text] = []
        var i = 0
        while i < arr_len:
            val item = json_array_get(parsed, i)
            val value = json_object_get(item, field)
            results = results + [json_serialize(value)]
            i = i + 1
        return results.join("\n")

    # Simple field access
    val value = json_object_get(parsed, clean_path)
    if value != nil:
        val vtype = json_get_type(value)
        if vtype == "string":
            return json_serialize(value)
        return json_pretty(value)

    ""


fn print_table_header(columns: [text]):
    """Print a table header row with formatting."""
    if should_use_color():
        var header = ""
        for col in columns:
            header = header + "{ansi_bold()}{col.pad_right(20)}{ansi_reset()}"
        print header
    else:
        var header = ""
        for col in columns:
            header = header + col.pad_right(20)
        print header


fn print_table_row(values: [text]):
    """Print a table data row."""
    var row = ""
    for val_text in values:
        row = row + val_text.pad_right(20)
    print row


fn _visible_len(s: text) -> i64:
    """Length of `s` excluding ANSI SGR escape sequences (`\x1b[...m`).

    Table column-width math must use this (not `.len()`) whenever a cell may
    have gone through colorize_state()/ansi_*() — otherwise the escape bytes
    inflate the measured width and every colored cell misaligns from its
    plain-text header (found via review: colorize_state fed straight into
    _table_col_widths/pad_right, which count bytes, before this fix).
    """
    var count = 0
    var i = 0
    val n = s.len()
    while i < n:
        val c = s.char_code_at(i)
        if c == 27 and i + 1 < n and s.char_code_at(i + 1) == 91:  # ESC '['
            var j = i + 2
            while j < n and s.char_code_at(j) != 109:  # until 'm'
                j = j + 1
            i = j + 1  # skip the 'm' too
        else:
            count = count + 1
            i = i + 1
    count


fn _pad_visible(s: text, target_width: i64) -> text:
    """Right-pad `s` with spaces so its VISIBLE width reaches target_width —
    ANSI SGR codes in `s` don't count, so colored and plain cells still line
    up in the same column."""
    val vlen = _visible_len(s)
    if vlen >= target_width:
        return s
    var pad = ""
    var i = vlen
    while i < target_width:
        pad = pad + " "
        i = i + 1
    s + pad


fn _table_col_widths(headers: [text], rows: [[text]]) -> [i64]:
    """Max content width per column (visible width, ANSI-aware), seeded
    with the header width."""
    var widths: [i64] = []
    for h in headers:
        widths.push(_visible_len(h))
    for row in rows:
        var i = 0
        while i < row.len() and i < widths.len():
            val vlen = _visible_len(row[i])
            if vlen > widths[i]:
                widths[i] = vlen
            i = i + 1
    widths


fn print_table_dynamic(headers: [text], rows: [[text]]):
    """Print a table with per-column widths computed from content (2-space gap).

    Unlike print_table_header/print_table_row (fixed pad_right(20), used by
    minio/jira listings), this does not truncate long titles/keys — used for
    github issue/PR listings where titles vary widely in length. Padding is
    visible-width-aware (see _pad_visible) so colorize_state()'d cells still
    align with plain headers/columns.
    """
    val widths = _table_col_widths(headers, rows)
    val color = should_use_color()
    var header_line = ""
    var i = 0
    while i < headers.len():
        val w = if i < widths.len(): widths[i] else: _visible_len(headers[i])
        header_line = header_line + _pad_visible(headers[i], w + 2)
        i = i + 1
    if color:
        print "{ansi_bold()}{header_line}{ansi_reset()}"
    else:
        print header_line
    for row in rows:
        var line = ""
        var j = 0
        while j < row.len():
            val w = if j < widths.len(): widths[j] else: 0
            line = line + _pad_visible(row[j], w + 2)
            j = j + 1
        print line


fn colorize_state(state: text) -> text:
    """Color a status word: open=green, closed/merged/done=dim, in-progress/review=yellow.

    Used by github issue/PR listings and jira status columns. No-op when
    color is disabled (NO_COLOR / non-tty) or the state doesn't match a
    known bucket.
    """
    if not should_use_color():
        return state
    val lower = state.lower()
    if lower == "open" or lower == "opened" or lower == "to do" or lower == "todo":
        return "{ansi_green()}{state}{ansi_reset()}"
    if lower == "closed" or lower == "merged" or lower == "done" or lower == "resolved":
        return "{ansi_dim()}{state}{ansi_reset()}"
    if lower.contains("progress") or lower == "review" or lower == "in review":
        return "{ansi_yellow()}{state}{ansi_reset()}"
    state


fn open_in_browser(url: text) -> i64:
    """Open URL in browser (--web flag handler)."""
    use std.nogc_sync_mut.io.process_ops.{process_run}

    # Try platform-specific openers
    val (_, _, code) = process_run("xdg-open", [url])
    if code == 0:
        return 0
    val (_, _, code2) = process_run("open", [url])
    if code2 == 0:
        return 0
    print_error("could not open browser for: {url}")
    1
