# ITF CLI — Auth commands
#
# Subcommands: login, status, logout
# Manages credentials for Confluence and Jira

use app.itf.config.{ItfConfig, load_config, save_config, load_auth_token, save_auth_token, config_dir}
use app.itf.auth.{check_confluence_auth, check_jira_auth}
use app.itf.flags.{_extract_flag, _has_flag}
use app.itf.output.{print_error, print_success, print_info, should_use_color}
use std.common.report.ansi.{ansi_green, ansi_red, ansi_bold, ansi_reset}
use std.nogc_sync_mut.file_system.file_ops.{file_exists, file_write_text, file_read_text}
use std.nogc_sync_mut.io.process_ops.{process_run}


fn handle_auth(args: [text]) -> i64:
    """Dispatch auth subcommands."""
    if args.len() == 0:
        _print_auth_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "login":
            _auth_login(action_args)
        "status":
            _auth_status(action_args)
        "logout":
            _auth_logout(action_args)
        "-h" | "--help" | "help":
            _print_auth_help()
            0
        _:
            print_error("unknown auth command: {action}")
            _print_auth_help()
            1


fn _auth_login(args: [text]) -> i64:
    """Login to a provider.

    Usage:
      itf auth login --confluence --url URL --user EMAIL --token TOKEN
      itf auth login --jira
    """
    val is_confluence = _has_flag(args, "--confluence")
    val is_jira = _has_flag(args, "--jira")

    if not is_confluence and not is_jira:
        print_error("specify --confluence or --jira")
        return 1

    if is_confluence:
        return _login_confluence(args)
    if is_jira:
        return _login_jira(args)
    1


fn _login_confluence(args: [text]) -> i64:
    """Setup Confluence authentication."""
    val url = _extract_flag(args, "--url", "")
    val user = _extract_flag(args, "--user", "")
    val token = _extract_flag(args, "--token", "")

    if url == "":
        print_error("--url required (e.g., https://company.atlassian.net/wiki)")
        return 1
    if user == "":
        print_error("--user required (your email)")
        return 1
    if token == "":
        print_error("--token required (Atlassian API token)")
        print "Generate a token at: https://id.atlassian.com/manage-profile/security/api-tokens"
        return 1

    # Ensure config dir exists
    _ensure_config_dir()

    # Save config
    var config = load_config()
    config = ItfConfig(
        confluence_url: url,
        confluence_user: user,
        confluence_default_space: config.confluence_default_space,
        jira_url: config.jira_url,
        jira_acli_path: config.jira_acli_path,
        default_output: config.default_output,
        color_mode: config.color_mode,
        editor_override: config.editor_override,
        pager_override: config.pager_override
    )
    save_config(config)

    # Save token
    save_auth_token("confluence", token)

    print_success("Confluence authentication configured.")
    print_info("URL", url)
    print_info("User", user)
    0


fn _login_jira(args: [text]) -> i64:
    """Verify Jira authentication via acli."""
    val config = load_config()
    val acli = config.jira_acli_path

    # Check if acli is available
    val (_, _, which_code) = process_run("which", [acli])
    if which_code != 0:
        print_error("acli not found at '{acli}'. Install Atlassian CLI or set jira.acli_path in config.")
        return 1

    # Delegate auth to acli
    print "Delegating to acli for Jira authentication..."
    val (_, stderr, code) = process_run(acli, ["jira", "auth", "login", "--web"])
    if code != 0:
        print_error("acli auth failed: {stderr}")
        return 1

    print_success("Jira authentication configured via acli.")
    0


fn _auth_status(args: [text]) -> i64:
    """Show authentication status for all providers."""
    val config = load_config()
    val use_color = should_use_color()

    print "Authentication status:"
    print ""

    # Confluence
    val conf_ok = check_confluence_auth(config)
    if use_color:
        if conf_ok:
            print "  {ansi_green()}●{ansi_reset()} Confluence: {ansi_bold()}authenticated{ansi_reset()}"
        else:
            print "  {ansi_red()}●{ansi_reset()} Confluence: not configured"
    else:
        if conf_ok:
            print "  ● Confluence: authenticated"
        else:
            print "  ○ Confluence: not configured"

    if conf_ok:
        print "    URL:  {config.confluence_url}"
        print "    User: {config.confluence_user}"

    print ""

    # Jira
    val jira_ok = config.jira_url != ""
    if use_color:
        if jira_ok:
            print "  {ansi_green()}●{ansi_reset()} Jira: {ansi_bold()}configured{ansi_reset()}"
        else:
            print "  {ansi_red()}●{ansi_reset()} Jira: not configured"
    else:
        if jira_ok:
            print "  ● Jira: configured"
        else:
            print "  ○ Jira: not configured"

    if jira_ok:
        print "    URL:  {config.jira_url}"
        print "    CLI:  {config.jira_acli_path}"

    0


fn _auth_logout(args: [text]) -> i64:
    """Remove stored credentials."""
    val is_confluence = _has_flag(args, "--confluence")
    val is_jira = _has_flag(args, "--jira")

    if not is_confluence and not is_jira:
        # Logout all
        save_auth_token("confluence", "")
        save_auth_token("jira", "")
        print_success("All credentials removed.")
        return 0

    if is_confluence:
        save_auth_token("confluence", "")
        print_success("Confluence credentials removed.")
    if is_jira:
        save_auth_token("jira", "")
        print_success("Jira credentials removed.")

    0


fn _ensure_config_dir():
    """Create config directory if it doesn't exist."""
    val dir = config_dir()
    # Use mkdir -p via process_run
    process_run("mkdir", ["-p", dir])


fn _print_auth_help():
    """Print auth subcommand help."""
    print "Usage: itf auth <command> [flags]"
    print ""
    print "Commands:"
    print "  login    Configure authentication"
    print "  status   Show authentication status"
    print "  logout   Remove stored credentials"
    print ""
    print "Login examples:"
    print "  itf auth login --confluence --url https://company.atlassian.net/wiki --user email --token TOKEN"
    print "  itf auth login --jira"
    print ""
    print "Flags:"
    print "  --confluence   Target Confluence"
    print "  --jira         Target Jira (delegates to acli)"
    print "  --url URL      Provider URL"
    print "  --user EMAIL   Email address"
    print "  --token TOKEN  API token"
