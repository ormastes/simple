# ITF CLI — Error types and exit code mapping
#
# gh-compatible exit codes:
#   0 = success
#   1 = general failure
#   2 = user cancelled
#   4 = authentication required

# Error kind tags (Simple has no enum yet in all backends, use text tags)
val ITF_ERR_AUTH = "auth_required"
val ITF_ERR_NOT_FOUND = "not_found"
val ITF_ERR_API = "api_error"
val ITF_ERR_CONFIG = "config_error"
val ITF_ERR_CANCELLED = "cancelled"
val ITF_ERR_NETWORK = "network_error"
val ITF_ERR_CONFLICT = "version_conflict"

class ItfError:
    kind: text
    message: text
    status_code: i64
    trace_id: text

    static fn auth(msg: text) -> ItfError:
        ItfError(kind: ITF_ERR_AUTH, message: msg, status_code: 0, trace_id: "")

    static fn not_found(resource: text) -> ItfError:
        ItfError(kind: ITF_ERR_NOT_FOUND, message: "not found: {resource}", status_code: 404, trace_id: "")

    static fn api(status: i64, body: text) -> ItfError:
        ItfError(kind: ITF_ERR_API, message: body, status_code: status, trace_id: "")

    static fn config(msg: text) -> ItfError:
        ItfError(kind: ITF_ERR_CONFIG, message: msg, status_code: 0, trace_id: "")

    static fn cancelled() -> ItfError:
        ItfError(kind: ITF_ERR_CANCELLED, message: "operation cancelled", status_code: 0, trace_id: "")

    static fn network(msg: text) -> ItfError:
        ItfError(kind: ITF_ERR_NETWORK, message: msg, status_code: 0, trace_id: "")

    static fn conflict(expected: i64, found: i64) -> ItfError:
        ItfError(kind: ITF_ERR_CONFLICT, message: "version conflict: expected {expected}, found {found}", status_code: 409, trace_id: "")

    fn exit_code() -> i64:
        match self.kind:
            ITF_ERR_AUTH: 4
            ITF_ERR_CANCELLED: 2
            _: 1

    fn display() -> text:
        if self.trace_id != "":
            "error: {self.message} (trace: {self.trace_id})"
        else:
            "error: {self.message}"


fn itf_error_from_http(status: i64, body: text) -> ItfError:
    """Map HTTP status codes to ItfError variants."""
    if status == 401 or status == 403:
        ItfError.auth("authentication required (HTTP {status})")
    else if status == 404:
        ItfError.not_found("HTTP {status}")
    else if status == 409:
        ItfError.conflict(0, 0)
    else:
        ItfError.api(status, body)
