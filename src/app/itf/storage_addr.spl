# storage_addr.spl — mc-shaped address parsing for `devhub storage` / `itf storage`.
#
# Reference: doc/05_design/app/devhub/facade_storage.md §1 ("Ground truth: mc
# grammar") and §3 ("Facade grammar" / verb→adapter mapping). Every TARGET is
# either a bare local filesystem path, or `ALIAS/bucket[/key...]` — mc infers
# which by checking whether the first "/"-segment matches a *registered*
# alias name, nothing more structural than that (a real mc footgun for typoed
# aliases, deliberately mirrored here rather than "fixed").
#
# Pure parsing only — no file/network I/O — except resolve_alias_config(),
# which loads (but never network-calls) the existing single-endpoint
# `[minio]` section via adapter_minio.load_minio_config().

use app.itf.adapter_minio.{MinioConfig, load_minio_config, check_minio_auth}


# ---------------------------------------------------------------------------
# Known aliases (facade_storage.md §4 — single-endpoint fallback)
# ---------------------------------------------------------------------------
#
# `adapter_minio.spl`'s config loader (`load_minio_config`) parses exactly one
# `[minio]` section from `~/.config/itf/auth.sdn` — there is no multi-alias
# store yet (that's the "biggest structural gap" called out in §4). Until
# `auth.sdn` grows named sections (or alias storage delegates to `mc`'s own
# config), the only alias name this facade recognizes is the bare `minio`
# literal, which maps onto that single section.

val STORAGE_KNOWN_ALIASES: [text] = ["minio"]


fn is_known_alias(name: text) -> bool:
    """Whether `name` matches a configured storage alias.

    Single-endpoint fallback: only `minio` is recognized today. Any other
    first-path-segment falls through to "local filesystem path" — this
    mirrors real `mc`'s own detection (first segment vs. its alias store),
    including the well-known typo footgun, on purpose (facade_storage.md §1).
    """
    for a in STORAGE_KNOWN_ALIASES:
        if a == name:
            return true
    false


# ---------------------------------------------------------------------------
# StorageAddr — parsed TARGET
# ---------------------------------------------------------------------------

class StorageAddr:
    """A single parsed mc-shaped TARGET.

    is_remote=false: local_path holds the (unmodified) filesystem path.
    is_remote=true: alias/bucket/key hold the parsed segments; any of
    bucket/key may be "" (e.g. bare `minio` -> bucket listing target,
    `minio/bucket` -> object listing target with no key).
    valid=false: parsing failed outright (currently only on ""); error
    holds a human-readable reason. Note this is distinct from "local path
    that happens not to be a valid storage target" -- callers that require a
    remote target check is_remote themselves and print their own
    usage-specific error (see cmd_storage.spl), since "not remote" is a valid
    parse result, just not one every verb accepts.
    """
    raw: text
    is_remote: bool
    alias: text
    bucket: text
    key: text
    local_path: text
    valid: bool
    error: text


fn _storage_addr_local(raw: text) -> StorageAddr:
    StorageAddr(raw: raw, is_remote: false, alias: "", bucket: "", key: "", local_path: raw, valid: true, error: "")


fn _storage_addr_remote(raw: text, alias: text, bucket: text, key: text) -> StorageAddr:
    StorageAddr(raw: raw, is_remote: true, alias: alias, bucket: bucket, key: key, local_path: "", valid: true, error: "")


fn _storage_addr_invalid(raw: text, error: text) -> StorageAddr:
    StorageAddr(raw: raw, is_remote: false, alias: "", bucket: "", key: "", local_path: "", valid: false, error: error)


fn parse_storage_addr(s: text) -> StorageAddr:
    """Parse one mc-shaped TARGET (facade_storage.md §1/§3).

    - "" -> invalid (empty path).
    - first "/"-segment matches a known alias (see is_known_alias):
        "minio"                 -> remote, bucket="", key=""   (alias-only)
        "minio/bucket"          -> remote, bucket="bucket", key=""
        "minio/bucket/a/b.bin"  -> remote, bucket="bucket", key="a/b.bin"
      The key preserves every "/" after the bucket verbatim -- S3 keys use
      "/" as a pseudo-directory separator, not a second split point.
    - anything else (including a first segment that *looks* alias-shaped but
      isn't registered) -> local filesystem path, unmodified.
    """
    if s == "":
        return _storage_addr_invalid(s, "empty path")
    val slash = s.find("/").unwrap_or(-1)
    val first_segment = if slash < 0: s else: s[0:slash]
    if not is_known_alias(first_segment):
        return _storage_addr_local(s)
    if slash < 0:
        return _storage_addr_remote(s, first_segment, "", "")
    val rest = s[slash + 1:]
    if rest == "":
        return _storage_addr_remote(s, first_segment, "", "")
    val bucket_slash = rest.find("/").unwrap_or(-1)
    if bucket_slash < 0:
        return _storage_addr_remote(s, first_segment, rest, "")
    val bucket = rest[0:bucket_slash]
    val key = rest[bucket_slash + 1:]
    _storage_addr_remote(s, first_segment, bucket, key)


# ---------------------------------------------------------------------------
# cp/mirror direction inference
# ---------------------------------------------------------------------------

fn infer_cp_direction(src: StorageAddr, dst: StorageAddr) -> text:
    """mc-style direction inference: purely which side is local vs. remote
    (facade_storage.md §1: "cp/mirror direction is inferred purely from
    which side is a local path vs. alias/bucket/... -- no explicit
    --upload/--download flag").

    Returns one of: "upload" (local->remote), "download" (remote->local),
    "error_remote_remote" (both remote -- explicitly an error per
    facade_storage.md §3's cp mapping row), or "error_local_local" (both
    local -- out of scope for an object-storage facade; use a plain
    filesystem copy instead).
    """
    if src.is_remote and dst.is_remote:
        return "error_remote_remote"
    if not src.is_remote and not dst.is_remote:
        return "error_local_local"
    if not src.is_remote and dst.is_remote:
        return "upload"
    "download"


# ---------------------------------------------------------------------------
# Alias -> config resolution (facade_storage.md §4)
# ---------------------------------------------------------------------------

fn resolve_alias_config(alias: text) -> (bool, MinioConfig, text):
    """Resolve a known alias name to its MinioConfig.

    Single-endpoint fallback: only "minio" is supported, mapping onto the
    existing `[minio]` section in `~/.config/itf/auth.sdn` (adapter_minio's
    `load_minio_config`). The alias-name check runs BEFORE any config load,
    so an unknown alias never touches the filesystem -- this keeps the
    behavior deterministic for callers/specs regardless of what's actually
    on disk for the "minio" alias.

    Re-implements adapter_minio's `tls_skip_verify` hard-fail and
    `check_minio_auth` gate inline (same rationale/message as
    cmd_minio.spl's private `_require_transport`/`_require_auth`, which this
    module cannot import -- they're module-private helpers in a file this
    worker must not edit).
    """
    if alias == "":
        return (false, MinioConfig.default(), "empty alias")
    if not is_known_alias(alias):
        return (false, MinioConfig.default(), "unknown alias '{alias}' — only the single-endpoint 'minio' alias is supported today (~/.config/itf/auth.sdn has no multi-alias sections yet); see doc/05_design/app/devhub/facade_storage.md §4")
    val cfg = load_minio_config()
    if cfg.tls_skip_verify:
        return (false, cfg, "tls_skip_verify is not supported by the pure-Simple HTTP transport (no TLS-verify override in the underlying HTTP SFFI). Remove tls_skip_verify from ~/.config/itf/auth.sdn.")
    if not check_minio_auth(cfg):
        return (false, cfg, "MinIO auth not configured for alias '{alias}'. Set [minio] section in ~/.config/itf/auth.sdn (url, access_key, secret_key).")
    (true, cfg, "")
