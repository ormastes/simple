# ITF CLI — Wiki commands (Confluence + GitHub-wiki backends)
#
# Subcommands: list, view, edit, create, delete, search
# gh-compatible flags: --json, --jq, --format, --web
# --backend confluence|github (default: confluence, matches pre-existing
# behavior verbatim); github routes onto app.itf.wiki_git (`.wiki.git`
# git-shell adapter — GitHub wikis have no REST/GraphQL API, see
# doc/05_design/app/devhub/facade_tasks_git_wiki.md §4).

use app.itf.config.{ItfConfig, load_config}
use app.itf.auth.{check_confluence_auth}
use app.itf.adapter_confluence.{confluence_list_pages, confluence_get_page, confluence_create_page, confluence_update_page, confluence_delete_page, confluence_search_pages, PageListItem, PageContent, PageRef}
use app.itf.flags.{_extract_flag, _has_flag, _positional_args}
use app.itf.output.{print_error, print_success, print_info, print_table_header, print_table_row, format_json_output, wants_json, should_use_color, open_in_browser}
use app.ui.render.ansi.{ansi_bold, ansi_reset, ansi_dim, ansi_cyan}
use app.itf.wiki_git.{sanitize_owner_repo_slug, wiki_git_ensure_synced, wiki_git_list, wiki_git_read, wiki_git_write, wiki_git_delete, wiki_git_push, wiki_git_search, wiki_git_page_modified, WikiGrepMatch}
use std.common.text_advanced.{escape_json}

# Real (non-mocked) file I/O, used by both backends' edit/create $EDITOR
# temp-file round-trips below. std.nogc_sync_mut.file_system.file_ops is a
# mock that never touches the real filesystem ("Mock implementations for
# pure Simple demonstration", per its own header — file_exists_mock() just
# checks whether the path string starts with "/" or "."); see the note in
# app.itf.wiki_git for detail. The confluence _wiki_edit/_wiki_create
# functions used to go through that mock (bug wiki-confluence-mock-file-io:
# the $EDITOR round-trip never actually read/wrote the edited page) — fixed
# by switching them onto these same externs the github functions already used.
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool


fn handle_wiki(args: [text]) -> i64:
    """Dispatch wiki subcommands."""
    if args.len() == 0:
        _print_wiki_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "list" | "ls":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_list(action_args)
                "confluence":
                    _wiki_list(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "view":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_view(action_args)
                "confluence":
                    _wiki_view(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "edit":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_edit(action_args)
                "confluence":
                    _wiki_edit(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "create":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_create(action_args)
                "confluence":
                    _wiki_create(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "delete" | "rm":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_delete(action_args)
                "confluence":
                    _wiki_delete(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "search":
            match _wiki_dispatch_backend(action_args):
                "github":
                    _wiki_github_search(action_args)
                "confluence":
                    _wiki_search(action_args)
                _:
                    _wiki_unknown_backend(action_args)
        "-h" | "--help" | "help":
            _print_wiki_help()
            0
        _:
            print_error("unknown wiki command: {action}")
            _print_wiki_help()
            1


fn _wiki_backend_default() -> text:
    """D1 precedence, step 2: the configured `wiki: default_backend:` in
    config.sdn (ItfConfig.wiki_default_backend, gap G6), else "confluence"
    (matches pre-existing behavior verbatim when unset)."""
    val configured = load_config().wiki_default_backend
    if configured != "": configured else: "confluence"


fn _wiki_dispatch_backend(args: [text]) -> text:
    """Resolve --backend, validated against the two supported values.
    D1 precedence: explicit `--backend` flag always wins; otherwise falls
    back to the configured wiki.default_backend (_wiki_backend_default()).
    Returns "" for an unsupported value — callers route that to
    _wiki_unknown_backend()."""
    val backend = _extract_flag(args, "--backend", _wiki_backend_default())
    if backend == "confluence" or backend == "github":
        backend
    else:
        ""


fn _wiki_unknown_backend(args: [text]) -> i64:
    val backend = _extract_flag(args, "--backend", _wiki_backend_default())
    print_error("unknown --backend '{backend}'; supported: confluence, github")
    1


fn _wiki_repo_flag(args: [text]) -> text:
    """--repo owner/name for --backend github (D8: -R is a gh-familiar
    alias for the same value)."""
    val repo = _extract_flag(args, "--repo", "")
    if repo != "":
        return repo
    _extract_flag(args, "-R", "")


fn _resolve_github_wiki(args: [text]) -> Result<(text, text), text>:
    """Parse+validate --repo owner/name and clone-or-sync its `.wiki.git`.
    Returns (repo_slug, cache_dir) on success."""
    val repo_flag = _wiki_repo_flag(args)
    if repo_flag == "":
        return Err("--repo owner/name required for --backend github")
    match sanitize_owner_repo_slug(repo_flag):
        Err(msg):
            Err("invalid --repo: {msg}")
        Ok(pair):
            val owner = pair.0
            val repo = pair.1
            val (ok, cache_dir, err) = wiki_git_ensure_synced(owner, repo)
            if not ok:
                Err("failed to sync {owner}/{repo}.wiki.git: {err}")
            else:
                Ok((repo_flag, cache_dir))


fn _require_confluence_auth() -> (bool, ItfConfig):
    """Load config and verify Confluence auth. Returns (ok, config)."""
    val config = load_config()
    if not check_confluence_auth(config):
        print_error("Confluence not configured. Run: itf auth login --confluence")
        return (false, config)
    (true, config)


fn _wiki_list(args: [text]) -> i64:
    """List wiki pages. Usage: itf wiki list [--space KEY] [--limit N] [--json fields]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val space = _extract_flag(args, "--space", config.confluence_default_space)
    val limit_str = _extract_flag(args, "--limit", "25")
    var limit = 25
    if limit_str != "25":
        # Simple integer parse
        var n = 0
        for ch in limit_str:
            if ch >= "0" and ch <= "9":
                n = n * 10 + (ch.to_i64() - "0".to_i64())
        if n > 0:
            limit = n

    val (success, items, raw_json) = confluence_list_pages(config, space, limit)
    if not success:
        print_error("failed to list pages: {raw_json}")
        return 1

    # --web flag: open in browser
    if _has_flag(args, "--web"):
        return open_in_browser("{config.confluence_url}/spaces/{space}/pages")

    # --json flag: output raw or filtered JSON
    if wants_json(args):
        print format_json_output(raw_json, args)
        return 0

    # Default: text table output
    if items.len() == 0:
        print "No pages found."
        return 0

    print_table_header(["ID", "TITLE", "STATUS", "MODIFIED"])
    for item in items:
        val item_id = item.id
        print_table_row([item_id, _truncate(item.title, 35), item.status, _truncate(item.last_modified, 20)])

    0


fn _wiki_view(args: [text]) -> i64:
    """View a wiki page. Usage: itf wiki view <page-id> [--format markdown|storage] [--json fields]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page ID required. Usage: itf wiki view <page-id>")
        return 1

    val page_id = positionals[0]
    val format = _extract_flag(args, "--format", "storage")

    val (success, content, raw_json) = confluence_get_page(config, page_id)
    if not success:
        print_error("failed to get page {page_id}: {raw_json}")
        return 1

    # --web flag
    if _has_flag(args, "--web") and content.ref.url != "":
        return open_in_browser(content.ref.url)

    # --json flag
    if wants_json(args):
        print format_json_output(raw_json, args)
        return 0

    # Text output
    val use_color = should_use_color()
    if use_color:
        print "{ansi_bold()}{content.ref.title}{ansi_reset()}"
        print "{ansi_dim()}Page ID: {content.ref.id} | Version: {content.ref.version} | Status: {content.ref.status}{ansi_reset()}"
    else:
        print content.ref.title
        print "Page ID: {content.ref.id} | Version: {content.ref.version} | Status: {content.ref.status}"
    print ""

    if format == "markdown":
        use app.itf.convert_storage.{storage_to_markdown}
        print storage_to_markdown(content.body_storage)
    else:
        print content.body_storage

    0


fn _wiki_edit(args: [text]) -> i64:
    """Edit a wiki page. Usage: itf wiki edit <page-id> [--mode markdown|storage] [--message MSG]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page ID required. Usage: itf wiki edit <page-id>")
        return 1

    val page_id = positionals[0]
    val message = _extract_flag(args, "--message", "")

    # Fetch current page
    val (success, content, _raw) = confluence_get_page(config, page_id)
    if not success:
        print_error("failed to get page {page_id}: {_raw}")
        return 1

    val version = content.ref.version
    val title = content.ref.title

    # Write to temp file via the extracted _wiki_edit_write_temp/
    # _wiki_edit_read_temp helpers below (real file I/O; see bug
    # wiki-confluence-mock-file-io)
    use std.nogc_sync_mut.io.process_ops.{process_run}

    val tmp_path = "/tmp/itf_edit_{page_id}.html"
    val _write_tmp = _wiki_edit_write_temp(tmp_path, content.body_storage)

    # Open editor
    val editor = _resolve_editor(config)
    val (_, _, editor_code) = process_run(editor, [tmp_path])
    if editor_code != 0:
        print_error("editor exited with code {editor_code}")
        return 2

    # Read edited content
    val (read_ok, edited) = _wiki_edit_read_temp(tmp_path)
    if not read_ok:
        print_error("could not read edited file")
        return 1

    # Check if changed
    if edited == content.body_storage:
        print "No changes made."
        return 0

    # Upload
    val commit_msg = if message != "": message else: "Edited via itf CLI"
    val (update_ok, updated_ref, update_raw) = confluence_update_page(config, page_id, title, edited, version, commit_msg)
    if not update_ok:
        print_error("failed to update page: {update_raw}")
        return 1

    print_success("Page updated: {updated_ref.title} (version {updated_ref.version})")
    if updated_ref.url != "":
        print updated_ref.url
    0


fn _wiki_read_file_if_exists(path: text) -> (bool, text):
    """Real (non-mocked) file read: returns (ok, content); ok is false if
    `path` does not exist. Shared by _wiki_create's --from-file read and
    _wiki_edit_read_temp below — both used to go through the
    std.nogc_sync_mut.file_system.file_ops mock (bug
    wiki-confluence-mock-file-io: file_exists_mock only checks the path
    prefix, so the $EDITOR round-trip never touched the real file), now
    fixed onto the same rt_file_* externs app.itf.wiki_git already uses."""
    if not rt_file_exists(path):
        return (false, "")
    (true, rt_file_read_text(path))


fn _wiki_edit_write_temp(tmp_path: text, content: text) -> bool:
    """Write the current page body to the $EDITOR temp file (real file
    I/O — rt_file_write_text). Extracted out of _wiki_edit so
    wiki_backend_routing_spec.spl can exercise the write/read round-trip
    directly against a temp path, without invoking a real editor or
    Confluence auth."""
    rt_file_write_text(tmp_path, content)


fn _wiki_edit_read_temp(tmp_path: text) -> (bool, text):
    """Read the edited $EDITOR temp file back. Returns (ok, content); ok
    is false if the file no longer exists (e.g. the editor process
    deleted it or never wrote it)."""
    _wiki_read_file_if_exists(tmp_path)


fn _wiki_create(args: [text]) -> i64:
    """Create a wiki page. Usage: itf wiki create --space KEY --title T [--parent ID] [--from-file PATH]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val space = _extract_flag(args, "--space", config.confluence_default_space)
    val title = _extract_flag(args, "--title", "")
    val parent = _extract_flag(args, "--parent", "")
    val from_file = _extract_flag(args, "--from-file", "")

    if title == "":
        print_error("--title required. Usage: itf wiki create --space KEY --title T")
        return 1
    if space == "":
        print_error("--space required (or set confluence.default_space in config)")
        return 1

    # Read body from file or empty (real file I/O — see
    # _wiki_read_file_if_exists above / bug wiki-confluence-mock-file-io)
    var body = "<p></p>"
    if from_file != "":
        val (read_ok, file_content) = _wiki_read_file_if_exists(from_file)
        if not read_ok:
            print_error("could not read file: {from_file}")
            return 1
        body = file_content

    val (success, ref, raw_json) = confluence_create_page(config, space, title, body, parent)
    if not success:
        print_error("failed to create page: {raw_json}")
        return 1

    # --json flag
    if wants_json(args):
        print format_json_output(raw_json, args)
        return 0

    print_success("Page created: {ref.title} (id: {ref.id})")
    if ref.url != "":
        print ref.url
    0


fn _wiki_delete(args: [text]) -> i64:
    """Delete a wiki page. Usage: itf wiki delete <page-id> [--yes]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page ID required. Usage: itf wiki delete <page-id>")
        return 1

    val page_id = positionals[0]

    if not _has_flag(args, "--yes"):
        print "Are you sure you want to delete page {page_id}? Use --yes to confirm."
        return 2

    val (success, err_msg) = confluence_delete_page(config, page_id)
    if not success:
        print_error("failed to delete page {page_id}: {err_msg}")
        return 1

    print_success("Page {page_id} deleted.")
    0


fn _wiki_search(args: [text]) -> i64:
    """Search wiki pages. Usage: itf wiki search <query> [--space KEY] [--limit N] [--json fields]"""
    val (ok, config) = _require_confluence_auth()
    if not ok:
        return 4

    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("search query required. Usage: itf wiki search <query>")
        return 1

    val query = positionals[0]
    val space = _extract_flag(args, "--space", config.confluence_default_space)
    val limit_str = _extract_flag(args, "--limit", "25")
    var limit = 25
    if limit_str != "25":
        var n = 0
        for ch in limit_str:
            if ch >= "0" and ch <= "9":
                n = n * 10 + (ch.to_i64() - "0".to_i64())
        if n > 0:
            limit = n

    val (success, items, raw_json) = confluence_search_pages(config, query, space, limit)
    if not success:
        print_error("search failed: {raw_json}")
        return 1

    if wants_json(args):
        print format_json_output(raw_json, args)
        return 0

    if items.len() == 0:
        print "No pages found matching \"{query}\"."
        return 0

    print_table_header(["ID", "TITLE", "SPACE", "STATUS"])
    for item in items:
        val item_id = item.id
        print_table_row([item_id, _truncate(item.title, 35), item.space_id, item.status])

    0


# ============================================================================
# GitHub wiki backend (`.wiki.git` git-shell adapter — gap G14-G16)
# ============================================================================

fn _wiki_github_list(args: [text]) -> i64:
    """List pages. Usage: itf wiki list --backend github --repo owner/name [--json fields]"""
    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val cache_dir = pair.1
            val pages = wiki_git_list(cache_dir)

            if _has_flag(args, "--web"):
                val repo_slug = pair.0
                return open_in_browser("https://github.com/{repo_slug}/wiki")

            if wants_json(args):
                print format_json_output(_github_wiki_list_json(pages, cache_dir), args)
                return 0

            if pages.len() == 0:
                print "No pages found."
                return 0

            print_table_header(["PAGE", "MODIFIED"])
            for page in pages:
                print_table_row([page, wiki_git_page_modified(cache_dir, page)])
            0


fn _wiki_github_view(args: [text]) -> i64:
    """View a page. Usage: itf wiki view <page-name> --backend github --repo owner/name [--json fields]"""
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page name required. Usage: itf wiki view <page-name> --backend github --repo owner/name")
        return 1
    val page = positionals[0]

    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val repo_slug = pair.0
            val cache_dir = pair.1

            if _has_flag(args, "--web"):
                return open_in_browser("https://github.com/{repo_slug}/wiki/{page}")

            match wiki_git_read(cache_dir, page):
                Err(msg):
                    print_error(msg)
                    1
                Ok(content):
                    if wants_json(args):
                        print format_json_output(_github_wiki_view_json(page, content), args)
                        return 0
                    if should_use_color():
                        print "{ansi_bold()}{page}{ansi_reset()}"
                    else:
                        print page
                    print ""
                    print content
                    0


fn _wiki_github_create(args: [text]) -> i64:
    """Create a page. Usage: itf wiki create --backend github --repo owner/name --title T [--from-file PATH] [--message MSG] [--push]"""
    val title = _extract_flag(args, "--title", "")
    if title == "":
        print_error("--title required. Usage: itf wiki create --backend github --repo owner/name --title T")
        return 1

    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val cache_dir = pair.1
            val from_file = _extract_flag(args, "--from-file", "")
            var body = "# {title}\n"
            if from_file != "":
                if not rt_file_exists(from_file):
                    print_error("could not read file: {from_file}")
                    return 1
                body = rt_file_read_text(from_file)

            val message = _extract_flag(args, "--message", "")
            val (ok, err) = wiki_git_write(cache_dir, title, body, message)
            if not ok:
                print_error("failed to create page: {err}")
                return 1

            if _has_flag(args, "--push"):
                val (push_ok, push_err) = wiki_git_push(cache_dir)
                if not push_ok:
                    print_error("committed locally but push failed: {push_err}")
                    return 1

            print_success("Page created: {title}")
            0


fn _wiki_github_edit(args: [text]) -> i64:
    """Edit a page in $EDITOR. Usage: itf wiki edit <page-name> --backend github --repo owner/name [--message MSG] [--push]"""
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page name required. Usage: itf wiki edit <page-name> --backend github --repo owner/name")
        return 1
    val page = positionals[0]

    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val cache_dir = pair.1
            match wiki_git_read(cache_dir, page):
                Err(_msg):
                    _wiki_github_edit_continue(cache_dir, page, "", args)
                Ok(content):
                    _wiki_github_edit_continue(cache_dir, page, content, args)


fn _wiki_github_edit_continue(cache_dir: text, page: text, original: text, args: [text]) -> i64:
    """Rest of _wiki_github_edit() once the (possibly empty, for a
    not-yet-existing page) current page content is resolved — split out so
    the wiki_git_read() Err/Ok branches don't need to bind a shared local
    (Simple's nested-closure capture can read but not modify outer vars;
    passing the resolved value as a plain argument sidesteps that instead
    of relying on match-arm mutation of an enclosing var)."""
    use std.nogc_sync_mut.io.process_ops.{process_run}

    val tmp_path = "/tmp/itf_wiki_github_edit_{page}.md"
    val _write_tmp = rt_file_write_text(tmp_path, original)

    val editor = _resolve_editor(load_config())
    val (_e_out, _e_err, editor_code) = process_run(editor, [tmp_path])
    if editor_code != 0:
        print_error("editor exited with code {editor_code}")
        return 2

    if not rt_file_exists(tmp_path):
        print_error("could not read edited file")
        return 1
    val edited = rt_file_read_text(tmp_path)
    if edited == original:
        print "No changes made."
        return 0

    val message = _extract_flag(args, "--message", "")
    val (ok, err) = wiki_git_write(cache_dir, page, edited, message)
    if not ok:
        print_error("failed to update page: {err}")
        return 1

    if _has_flag(args, "--push"):
        val (push_ok, push_err) = wiki_git_push(cache_dir)
        if not push_ok:
            print_error("committed locally but push failed: {push_err}")
            return 1

    print_success("Page updated: {page}")
    0


fn _wiki_github_delete(args: [text]) -> i64:
    """Delete a page. Usage: itf wiki delete <page-name> --backend github --repo owner/name [--yes] [--push]"""
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("page name required. Usage: itf wiki delete <page-name> --backend github --repo owner/name")
        return 1
    val page = positionals[0]

    if not _has_flag(args, "--yes"):
        print "Are you sure you want to delete page {page}? Use --yes to confirm."
        return 2

    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val cache_dir = pair.1
            val (ok, err) = wiki_git_delete(cache_dir, page, _extract_flag(args, "--message", ""))
            if not ok:
                print_error("failed to delete page {page}: {err}")
                return 1

            if _has_flag(args, "--push"):
                val (push_ok, push_err) = wiki_git_push(cache_dir)
                if not push_ok:
                    print_error("committed locally but push failed: {push_err}")
                    return 1

            print_success("Page {page} deleted.")
            0


fn _wiki_github_search(args: [text]) -> i64:
    """Search pages. Usage: itf wiki search <query> --backend github --repo owner/name [--json fields]"""
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("search query required. Usage: itf wiki search <query> --backend github --repo owner/name")
        return 1
    val query = positionals[0]

    match _resolve_github_wiki(args):
        Err(msg):
            print_error(msg)
            1
        Ok(pair):
            val cache_dir = pair.1
            match wiki_git_search(cache_dir, query):
                Err(msg):
                    print_error("search failed: {msg}")
                    1
                Ok(matches):
                    if wants_json(args):
                        print format_json_output(_github_wiki_search_json(matches), args)
                        return 0
                    if matches.len() == 0:
                        print "No pages found matching \"{query}\"."
                        return 0
                    print_table_header(["PAGE", "LINE", "MATCH"])
                    for m in matches:
                        print_table_row([m.page, "{m.line_no}", _truncate(m.line.trim(), 60)])
                    0


fn _github_wiki_list_json(pages: [text], cache_dir: text) -> text:
    var items: [text] = []
    for page in pages:
        val modified = wiki_git_page_modified(cache_dir, page)
        items.push("\{\"page\": \"{escape_json(page)}\", \"modified\": \"{escape_json(modified)}\"\}")
    "[" + items.join(", ") + "]"


fn _github_wiki_view_json(page: text, content: text) -> text:
    "\{\"page\": \"{escape_json(page)}\", \"content\": \"{escape_json(content)}\"\}"


fn _github_wiki_search_json(matches: [WikiGrepMatch]) -> text:
    var items: [text] = []
    for m in matches:
        items.push("\{\"page\": \"{escape_json(m.page)}\", \"line\": {m.line_no}, \"match\": \"{escape_json(m.line)}\"\}")
    "[" + items.join(", ") + "]"


fn _resolve_editor(config: ItfConfig) -> text:
    """Resolve editor from config/env."""
    use std.nogc_sync_mut.env.{env_get}
    use app.itf.config.{resolve_editor}
    resolve_editor(config)


fn _truncate(s: text, max_len: i64) -> text:
    """Truncate text with ellipsis if too long."""
    if s.len() <= max_len:
        return s
    s[0:max_len - 3] + "..."


fn _print_wiki_help():
    """Print wiki subcommand help."""
    print "Usage: itf wiki <command> [flags]"
    print ""
    print "Commands:"
    print "  list, ls     List pages in a space"
    print "  view         View a page"
    print "  edit         Edit a page in \$EDITOR"
    print "  create       Create a new page"
    print "  delete, rm   Delete a page"
    print "  search       Search pages by title"
    print ""
    print "Common flags:"
    print "  --backend confluence|github  Wiki backend (default: confluence, or wiki.default_backend in config)"
    print "  --space KEY  Confluence space (or set default in config)"
    print "  --repo, -R OWNER/NAME  GitHub repo whose .wiki.git to use (--backend github)"
    print "  --json       Output as JSON"
    print "  --jq EXPR    Filter JSON output (e.g. .[].title)"
    print "  --web        Open in browser"
    print "  --limit N    Max results (default: 25, confluence only)"
    print "  --push       Push local wiki commits to GitHub (--backend github create/edit/delete; never implied)"
    print ""
    print "Examples:"
    print "  itf wiki list --space ENG"
    print "  itf wiki list --backend github --repo acme/widgets"
    print "  itf wiki view Home --backend github --repo acme/widgets"
