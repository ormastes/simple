# ITF CLI — GitHub Adapter (stub, delegates to gh)
#
# Future: pass-through to `gh` CLI
# Currently a placeholder for Phase 3

use std.nogc_sync_mut.io.process_ops.{process_run}


fn github_passthrough(args: [text]) -> (bool, text, text):
    """Pass arguments through to gh CLI.

    Returns: (success, stdout, stderr)
    """
    val (stdout, stderr, code) = process_run("gh", args)
    (code == 0, stdout, stderr)
