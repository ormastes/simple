# devhub `task_manager` (alias `tasks`) — gh-issue-shaped facade over Jira +
# GitHub issues.
#
# Reference: doc/05_design/app/devhub/facade_tasks_git_wiki.md §2 (command
# table + gaps G1/G1b/G5) and doc/05_design/app/devhub/devhub_overview.md §5
# (D1-D8 cross-cutting decisions this file implements).
#
# Design posture: this is a THIN facade — almost every verb delegates to the
# existing `handle_github`/`handle_jira` dispatchers (both already handle
# their own table/JSON formatting, acli-vs-curl fallback, actionable errors,
# etc.) so this file only adds:
#   - backend resolution (D1: --backend flag > config `tasks: backend:` >
#     "github" default) and id-shape auto-detection (PROJ-123 -> jira) for
#     single-item verbs.
#   - G1: `_jira_build_list_jql` — synthesizes JQL from gh-shaped list flags
#     (--assignee/--label/--state/--search) since Jira has no `list`
#     equivalent to gh's `issue list`, only raw-JQL `search`. Implements
#     D3 (`@me` -> `currentUser()`) and D4 (state -> statusCategory).
#   - D6: `--backend all` for `list`/`search` — runs both backends, prefixes
#     rows with a BACKEND column, never hard-fails on a single backend
#     (prints a warning + the other backend's data instead).
#   - G5 workaround: `cmd_github.spl` has no `issue edit` dispatch case
#     (out of scope here — read-only file), so `tasks edit --backend github`
#     calls `gh_run` directly instead of going through `handle_github`.
#   - G1b: jira label/assignee edits (`--add-label` etc.) have no adapter
#     support (`acli`'s mutation surface for this is undocumented/unscoped)
#     — this prints the defined not-yet-supported error rather than
#     guessing at an `acli`/REST call that might not exist.
#   - G6 workaround: `ItfConfig` (config.spl) has no `tasks` section fields
#     yet — rather than editing that file (out of scope here), `tasks:
#     backend:`/`tasks: jira_done_status:` are read directly off
#     config.sdn by `_tasks_config_value`, mirroring `load_config()`'s own
#     line-scanning loop.
#
# NOT implemented (out of this file's scope, noted per gap):
#   - `--milestone` filtering on `list` — the facade doc's G1 gap summary
#     lists `milestone` as a `jira_build_list_jql` parameter, but `tasks
#     list`'s own flag row does not include -m/--milestone (only `create`/
#     `edit` do), and Jira has no single unambiguous JQL field for it
#     (fixVersion vs sprint vary by project type) — left out rather than
#     guessed.
#   - `--web` on `list`/`create`/`comment`/`close`/`edit` for the jira
#     backend — the facade doc's flag rows only list -w/--web for
#     `list`/`view`; github gets it for free (gh handles `--web` natively
#     via passthrough); jira only implements it for `view` here.

use app.itf.config.{load_config, config_path}
use app.itf.adapter_github.{gh_run, gh_available, gh_actionable_error}
use app.itf.cmd_github.{handle_github, _gh_field, _gh_login, _default_fields}
use app.itf.adapter_jira.{jira_search, JiraIssue}
use app.itf.cmd_jira.{handle_jira, _truncate}
use app.itf.flags.{_extract_flag, _has_flag, _positional_args, _remove_flags}
use app.itf.output.{print_error, print_warning, print_table_dynamic, colorize_state, relative_time, format_json_output, wants_json, set_no_pager, open_in_browser}
use std.nogc_sync_mut.file_system.file_ops.{file_read_text, file_exists}
use std.json.{json_parse, json_array_get, json_array_length, json_get_type}


fn handle_tasks(args: [text]) -> i64:
    """Dispatch `devhub tasks` / `itf task_manager` subcommands: list, view,
    create, comment, close, edit, search. See file header for design notes."""
    if args.len() == 0:
        _print_tasks_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "list":
            _tasks_list(action_args)
        "view":
            _tasks_view(action_args)
        "create":
            _tasks_create(action_args)
        "comment":
            _tasks_comment(action_args)
        "close":
            _tasks_close(action_args)
        "edit":
            _tasks_edit(action_args)
        "search":
            _tasks_search(action_args)
        "-h" | "--help" | "help":
            _print_tasks_help()
            0
        _:
            print_error("unknown tasks command: {action}")
            _print_tasks_help()
            1


fn _tasks_internal_error(backend: text) -> i64:
    """Should be unreachable — `_resolve_backend_*` already validates the
    backend value before any caller matches on it. Kept as an explicit,
    honest failure instead of a silent fallthrough."""
    print_error("internal error: unresolved backend '{backend}'")
    1


# ---------------------------------------------------------------------------
# Backend resolution (D1) + id-shape auto-detection
# ---------------------------------------------------------------------------

fn _tasks_config_value(section: text, key: text) -> text:
    """Read a single `section:\n    key: value` pair directly from
    config.sdn. `ItfConfig` (config.spl) has no `tasks` section fields yet
    (gap G6) — adding them means editing config.spl, out of scope for this
    file, so this reads the raw file instead. Mirrors load_config()'s own
    line-scanning loop (config.spl)."""
    val path = config_path()
    if not file_exists(path):
        return ""
    val content = file_read_text(path)
    if content == nil:
        return ""
    var cur_section = ""
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            pass_dn
        else if trimmed.ends_with(":") and not trimmed.contains(" "):
            cur_section = trimmed.replace(":", "")
        else if trimmed.contains(":"):
            val parts = trimmed.split(":", 2)
            val k = parts[0].trim()
            val v = parts[1].trim()
            if cur_section == section and k == key:
                return v
    ""


fn _tasks_backend_default() -> text:
    """D1 precedence, step 2: configured `tasks: backend:` in config.sdn,
    else "github" (step 3 of the full D1 rule — listing configured
    backends and erroring on ambiguity — is simplified to this fixed
    default per this facade's brief)."""
    val v = _tasks_config_value("tasks", "backend")
    if v == "": "github" else: v


fn _tasks_jira_done_status() -> text:
    """D5: the jira status `tasks close` transitions to, since Jira has no
    first-class "closed" state. Configurable via `tasks:
    jira_done_status:`, default "Done"."""
    val v = _tasks_config_value("tasks", "jira_done_status")
    if v == "": "Done" else: v


fn _looks_like_jira_key(id: text) -> bool:
    """True for a Jira-key shape: one or more uppercase letters, "-", then
    one or more digits (e.g. "PROJ-123"). Used to auto-detect backend for
    single-item verbs when --backend is omitted (facade doc §2 `tasks
    view` row)."""
    val dash = id.find("-")
    if dash <= 0:
        return false
    val prefix = id[0:dash]
    val suffix = id[dash + 1:id.len()]
    if suffix.len() == 0:
        return false
    var i = 0
    while i < prefix.len():
        val ch = prefix[i]
        if not (ch >= "A" and ch <= "Z"):
            return false
        i = i + 1
    i = 0
    while i < suffix.len():
        val ch = suffix[i]
        if not (ch >= "0" and ch <= "9"):
            return false
        i = i + 1
    true


fn _resolve_backend_list(args: [text]) -> (text, text):
    """Backend resolution for `list`/`search` (D1) — allows "all" (D6)."""
    val explicit = _extract_flag(args, "--backend", "")
    val backend = if explicit != "": explicit else: _tasks_backend_default()
    if backend != "jira" and backend != "github" and backend != "all":
        return ("", "--backend must be jira, github, or all (got '{backend}')")
    (backend, "")


fn _resolve_backend_single(args: [text], verb_name: text, id_for_autodetect: text) -> (text, text):
    """Backend resolution for single-item verbs (view/create/comment/close/
    edit) — rejects "all" (fanning a mutation out to two trackers has no
    defined semantics in the facade doc) and auto-detects jira from the id
    shape when --backend is omitted and an id is available."""
    val explicit = _extract_flag(args, "--backend", "")
    var backend = explicit
    if backend == "":
        if id_for_autodetect != "" and _looks_like_jira_key(id_for_autodetect):
            backend = "jira"
        else:
            backend = _tasks_backend_default()
    if backend == "all":
        return ("", "--backend all is not supported for `{verb_name}` — pick jira or github for a single item")
    if backend != "jira" and backend != "github":
        return ("", "--backend must be jira or github for `{verb_name}` (got '{backend}')")
    (backend, "")


# ---------------------------------------------------------------------------
# list / search (G1: jira_build_list_jql, D6: --backend all)
# ---------------------------------------------------------------------------

fn _jira_build_list_jql(assignee: text, label: text, state: text, search: text) -> text:
    """G1 — synthesize a JQL filter from gh-shaped list flags so `tasks list
    --backend jira` is flag-compatible with `tasks list --backend github`.
    D3: `--assignee @me` -> `assignee = currentUser()` (Jira has no `@me`
    literal; GitHub's is passed through unchanged elsewhere). D4: `--state`
    maps through `statusCategory` (open/closed), "all"/unrecognized omits
    the clause."""
    var clauses: [text] = []
    if assignee != "":
        if assignee == "@me":
            clauses.push("assignee = currentUser()")
        else:
            clauses.push("assignee = \"{assignee}\"")
    if label != "":
        clauses.push("labels = \"{label}\"")
    if state == "open":
        clauses.push("statusCategory != Done")
    else if state == "closed":
        clauses.push("statusCategory = Done")
    if search != "":
        clauses.push("text ~ \"{search}\"")
    if clauses.len() == 0:
        return ""
    clauses.join(" AND ")


fn _parse_limit(s: text, default_val: i64) -> i64:
    """Parse a decimal --limit value; any non-digit or empty/zero input
    falls back to `default_val` rather than crashing or truncating
    silently."""
    if s == "":
        return default_val
    var n = 0
    var any_digit = false
    for ch in s:
        if ch >= "0" and ch <= "9":
            n = n * 10 + (ch.to_i64() - "0".to_i64())
            any_digit = true
        else:
            return default_val
    if not any_digit:
        return default_val
    n


fn _strip_first_positional(args: [text]) -> [text]:
    """Remove the first bare (non-flag) token from `args`, keeping all
    flag+value pairs intact. Used by `tasks search <query>` to promote its
    positional query into a `--search` flag before delegating to
    `_tasks_list` (facade doc: "Thin alias for tasks list --search
    <query>")."""
    var result: [text] = []
    var removed = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--"):
            if i + 1 < args.len() and not args[i + 1].starts_with("--"):
                result = result + [args[i], args[i + 1]]
                i = i + 2
            else:
                result = result + [args[i]]
                i = i + 1
        else if not removed:
            removed = true
            i = i + 1
        else:
            result = result + [arg]
            i = i + 1
    result


fn _tasks_list(args: [text]) -> i64:
    """`tasks list` — D1 backend resolution, G1 jira JQL synthesis, D6
    --backend all merge."""
    set_no_pager(_has_flag(args, "--no-pager"))
    val (backend, err) = _resolve_backend_list(args)
    if err != "":
        print_error(err)
        return 1

    val assignee = _extract_flag(args, "--assignee", "")
    val label = _extract_flag(args, "--label", "")
    val state = _extract_flag(args, "--state", "open")
    val search = _extract_flag(args, "--search", "")
    val limit = _parse_limit(_extract_flag(args, "--limit", "30"), 30)

    match backend:
        "github":
            handle_github(["issue", "list"] + _remove_flags(args, ["--backend"]))
        "jira":
            _tasks_list_jira_only(args, assignee, label, state, search, limit)
        "all":
            _tasks_list_all(args, assignee, label, state, search, limit)
        _:
            _tasks_internal_error(backend)


fn _tasks_list_jira_only(args: [text], assignee: text, label: text, state: text, search: text, limit: i64) -> i64:
    val config = load_config()
    val jql = _jira_build_list_jql(assignee, label, state, search)
    val (ok, issues, raw) = jira_search(config, jql, "", limit)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print format_json_output(raw, args)
        return 0
    if issues.len() == 0:
        print "No issues found. Try --state all or check `itf auth status`."
        return 0
    var rows: [[text]] = []
    for issue in issues:
        val status = colorize_state(issue.status)
        val who = if issue.assignee != "": issue.assignee else: "(unassigned)"
        val updated = if issue.updated != "": relative_time(issue.updated) else: ""
        rows.push([issue.key, status, who, _truncate(issue.summary, 60), updated])
    print_table_dynamic(["KEY", "STATE", "ASSIGNEE", "SUMMARY", "UPDATED"], rows)
    0


fn _tasks_github_list_raw(assignee: text, label: text, state: text, search: text, limit: i64) -> (bool, text, text):
    """Fetch github issue-list JSON without printing (needed for the
    --backend all merge — handle_github()/_github_list() print directly).
    Returns (success, raw_json, error_message)."""
    if not gh_available():
        return (false, "", gh_actionable_error(""))
    var gh_args = ["issue", "list", "--json", _default_fields("issue")]
    if assignee != "":
        gh_args = gh_args + ["--assignee", assignee]
    if label != "":
        gh_args = gh_args + ["--label", label]
    if state != "":
        gh_args = gh_args + ["--state", state]
    if search != "":
        gh_args = gh_args + ["--search", search]
    gh_args = gh_args + ["--limit", "{limit}"]
    val (ok, stdout, stderr) = gh_run(gh_args)
    if not ok:
        return (false, "", gh_actionable_error(stderr))
    (true, stdout, "")


fn _tasks_github_rows_from_json(raw_json: text) -> [[text]]:
    """Parse gh's --json issue-list output into table rows (mirrors
    cmd_github.spl's _print_gh_table, without printing)."""
    val parsed = json_parse(raw_json)
    if parsed == nil or json_get_type(parsed) != "array":
        return []
    var rows: [[text]] = []
    var i = 0
    val n = json_array_length(parsed)
    while i < n:
        val item = json_array_get(parsed, i)
        val number = "#{_gh_field(item, "number")}"
        val st = colorize_state(_gh_field(item, "state"))
        val who = _gh_login(item, "author")
        val title = _truncate(_gh_field(item, "title"), 60)
        val updated = relative_time(_gh_field(item, "updatedAt"))
        rows.push([number, st, who, title, updated])
        i = i + 1
    rows


fn _tasks_list_all(args: [text], assignee: text, label: text, state: text, search: text, limit: i64) -> i64:
    """D6: --backend all — run both backends, prefix rows with a BACKEND
    column, never hard-fail on a single backend's failure (print a warning
    + the other backend's data instead); exit 0 if >= 1 backend
    succeeded."""
    val config = load_config()
    val (gh_ok, gh_raw, gh_err) = _tasks_github_list_raw(assignee, label, state, search, limit)
    val jql = _jira_build_list_jql(assignee, label, state, search)
    val (jr_ok, jr_issues, jr_raw) = jira_search(config, jql, "", limit)

    if not gh_ok and not jr_ok:
        print_error("github: {gh_err}; jira: {jr_raw}")
        return 1

    if wants_json(args):
        val gh_json = if gh_ok: gh_raw else: "null"
        val jr_json = if jr_ok: jr_raw else: "null"
        print "\{\"github\":{gh_json},\"jira\":{jr_json}\}"
        if not gh_ok:
            print_warning("github: {gh_err}")
        if not jr_ok:
            print_warning("jira: {jr_raw}")
        return 0

    var rows: [[text]] = []
    if gh_ok:
        for row in _tasks_github_rows_from_json(gh_raw):
            rows.push(["GITHUB"] + row)
    if jr_ok:
        for issue in jr_issues:
            val status = colorize_state(issue.status)
            val who = if issue.assignee != "": issue.assignee else: "(unassigned)"
            val updated = if issue.updated != "": relative_time(issue.updated) else: ""
            rows.push(["JIRA", issue.key, status, who, _truncate(issue.summary, 60), updated])

    if not gh_ok:
        print_warning("github: {gh_err}")
    if not jr_ok:
        print_warning("jira: {jr_raw}")

    if rows.len() == 0:
        print "No issues found across configured backends. Try --state all."
        return 0

    print_table_dynamic(["BACKEND", "KEY", "STATE", "ASSIGNEE", "SUMMARY", "UPDATED"], rows)
    0


fn _tasks_search(args: [text]) -> i64:
    """`tasks search <query>` — thin alias for `tasks list --search
    <query>` (facade doc §2 `tasks search` row)."""
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("query required. Usage: tasks search <query|JQL> [flags]")
        return 1
    val query = positionals[0]
    _tasks_list(_strip_first_positional(args) + ["--search", query])


# ---------------------------------------------------------------------------
# view
# ---------------------------------------------------------------------------

fn _strip_trailing_slash(url: text) -> text:
    if url.ends_with("/"):
        return url[0:url.len() - 1]
    url


fn _tasks_view_jira(id: text, args: [text]) -> i64:
    if _has_flag(args, "--web"):
        val config = load_config()
        if config.jira_url == "":
            print_error("--web requires jira.url to be configured (itf auth login --jira --url U --user E --token T)")
            return 1
        return open_in_browser("{_strip_trailing_slash(config.jira_url)}/browse/{id}")
    handle_jira(["view"] + _remove_flags(args, ["--backend"]))


fn _tasks_view(args: [text]) -> i64:
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("issue id required. Usage: tasks view <number|KEY>")
        return 1
    val id = positionals[0]
    val (backend, err) = _resolve_backend_single(args, "view", id)
    if err != "":
        print_error(err)
        return 1
    match backend:
        "github":
            handle_github(["issue", "view"] + _remove_flags(args, ["--backend"]))
        "jira":
            _tasks_view_jira(id, args)
        _:
            _tasks_internal_error(backend)


# ---------------------------------------------------------------------------
# create
# ---------------------------------------------------------------------------

fn _tasks_create_github(args: [text]) -> i64:
    if _extract_flag(args, "--title", "") == "":
        print_error("--title required. Usage: tasks create --title T [--body B]")
        return 1
    handle_github(["issue", "create"] + _remove_flags(args, ["--backend"]))


fn _tasks_create_jira(args: [text]) -> i64:
    val title = _extract_flag(args, "--title", "")
    val body = _extract_flag(args, "--body", "")
    val project = _extract_flag(args, "--project", "")
    val issue_type = _extract_flag(args, "--type", "")
    val assignee = _extract_flag(args, "--assignee", "")
    val label = _extract_flag(args, "--label", "")
    val milestone = _extract_flag(args, "--milestone", "")
    if project == "":
        print_error("--project required for the jira backend. Usage: tasks create --backend jira --project P --title T")
        return 1
    if title == "":
        print_error("--title required. Usage: tasks create --title T [--body B]")
        return 1
    if assignee != "" or label != "" or milestone != "":
        print_warning("--assignee/--label/--milestone are not yet supported by `tasks create --backend jira`; ignored")
    var jira_args = ["create", "--project", project, "--summary", title]
    if issue_type != "":
        jira_args = jira_args + ["--type", issue_type]
    if body != "":
        jira_args = jira_args + ["--description", body]
    handle_jira(jira_args)


fn _tasks_create(args: [text]) -> i64:
    val (backend, err) = _resolve_backend_single(args, "create", "")
    if err != "":
        print_error(err)
        return 1
    match backend:
        "github":
            _tasks_create_github(args)
        "jira":
            _tasks_create_jira(args)
        _:
            _tasks_internal_error(backend)


# ---------------------------------------------------------------------------
# comment
# ---------------------------------------------------------------------------

fn _tasks_comment(args: [text]) -> i64:
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("issue id required. Usage: tasks comment <id> --body TEXT")
        return 1
    val id = positionals[0]
    val (backend, err) = _resolve_backend_single(args, "comment", id)
    if err != "":
        print_error(err)
        return 1
    if _extract_flag(args, "--body", "") == "":
        print_error("--body required. Usage: tasks comment <id> --body TEXT")
        return 1
    match backend:
        "github":
            handle_github(["issue", "comment"] + _remove_flags(args, ["--backend"]))
        "jira":
            handle_jira(["comment"] + _remove_flags(args, ["--backend"]))
        _:
            _tasks_internal_error(backend)


# ---------------------------------------------------------------------------
# close (D5: jira transitions to a configured "done" status)
# ---------------------------------------------------------------------------

fn _tasks_close_jira(id: text, args: [text]) -> i64:
    val reason = _extract_flag(args, "--reason", "")
    val comment_text = _extract_flag(args, "--comment", "")
    if reason != "" or comment_text != "":
        print_warning("jira has no equivalent for --reason/--comment on close; ignoring")
    val done_status = _tasks_jira_done_status()
    handle_jira(["transition", id, done_status])


fn _tasks_close(args: [text]) -> i64:
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("issue id required. Usage: tasks close <id>")
        return 1
    val id = positionals[0]
    val (backend, err) = _resolve_backend_single(args, "close", id)
    if err != "":
        print_error(err)
        return 1
    match backend:
        "github":
            handle_github(["issue", "close"] + _remove_flags(args, ["--backend"]))
        "jira":
            _tasks_close_jira(id, args)
        _:
            _tasks_internal_error(backend)


# ---------------------------------------------------------------------------
# edit (G5: github passthrough gap worked around locally; G1b: jira
# label/assignee gap surfaced as a defined not-yet-supported error)
# ---------------------------------------------------------------------------

fn _tasks_edit_github(args: [text]) -> i64:
    """G5 workaround: cmd_github.spl's `_github_issue` match has no `edit`
    case (list/view/create/comment/close only) even though `gh issue edit`
    exists natively — adding that one-line match arm belongs in
    cmd_github.spl, which is read-only from here, so this calls `gh_run`
    directly instead of going through `handle_github`. `args` already
    starts with the id positional (mirrors the other backend-passthrough
    branches, e.g. `_tasks_view`/`_tasks_close`'s github arms), so it is
    forwarded as-is rather than re-prepended."""
    if not gh_available():
        print_error(gh_actionable_error(""))
        return 1
    val gh_args = ["issue", "edit"] + _remove_flags(args, ["--backend", "--status"])
    val (ok, stdout, stderr) = gh_run(gh_args)
    if stdout.trim() != "":
        print stdout
    if not ok:
        print_error(gh_actionable_error(stderr))
        return 1
    0


fn _tasks_edit_jira(id: text, args: [text]) -> i64:
    val add_label = _extract_flag(args, "--add-label", "")
    val remove_label = _extract_flag(args, "--remove-label", "")
    val add_assignee = _extract_flag(args, "--add-assignee", "")
    val remove_assignee = _extract_flag(args, "--remove-assignee", "")
    if add_label != "" or remove_label != "" or add_assignee != "" or remove_assignee != "":
        print_error("tasks edit --add-label/--remove-label/--add-assignee/--remove-assignee: not yet supported for the jira backend (gap G1b — acli's label/assignee mutation surface needs research; see doc/05_design/app/devhub/facade_tasks_git_wiki.md §5). Use `itf jira update`/`itf jira transition` directly, or the jira web UI, in the meantime.")
        return 1
    val title = _extract_flag(args, "--title", "")
    val body = _extract_flag(args, "--body", "")
    val status = _extract_flag(args, "--status", "")
    if title == "" and body == "" and status == "":
        print_error("nothing to edit: provide --title/--body/--status")
        return 1
    var code = 0
    if title != "" or body != "":
        var upd_args = ["update", id]
        if title != "":
            upd_args = upd_args + ["--summary", title]
        if body != "":
            upd_args = upd_args + ["--description", body]
        val c = handle_jira(upd_args)
        if c != 0:
            code = c
    if status != "":
        val c2 = handle_jira(["transition", id, status])
        if c2 != 0:
            code = c2
    code


fn _tasks_edit(args: [text]) -> i64:
    val positionals = _positional_args(args)
    if positionals.len() == 0:
        print_error("issue id required. Usage: tasks edit <id> [flags]")
        return 1
    val id = positionals[0]
    val (backend, err) = _resolve_backend_single(args, "edit", id)
    if err != "":
        print_error(err)
        return 1
    match backend:
        "github":
            _tasks_edit_github(args)
        "jira":
            _tasks_edit_jira(id, args)
        _:
            _tasks_internal_error(backend)


# ---------------------------------------------------------------------------
# help
# ---------------------------------------------------------------------------

fn _print_tasks_help():
    print "devhub tasks (alias: itf task_manager) — gh-issue-shaped view over Jira + GitHub issues"
    print ""
    print "Usage: tasks <command> [flags]"
    print ""
    print "Commands:"
    print "  list                 List issues (--assignee, --label, --state, --search, --limit)"
    print "  view <id>            View an issue (number for github, KEY for jira, e.g. PROJ-123)"
    print "  create               Create an issue (--title T [--body B] [--project P] [--type T])"
    print "  comment <id>         Add a comment (--body TEXT)"
    print "  close <id>           Close an issue"
    print "  edit <id>            Edit an issue (--title/--body/--status; github also: --add-label etc.)"
    print "  search <query>       Alias for `list --search <query>`"
    print ""
    print "Flags:"
    print "  --backend jira|github|all   Select backend (default: config `tasks: backend:` or github)"
    print "  --assignee VALUE             Filter by assignee (`@me` for the authenticated user)"
    print "  --label VALUE                 Filter by label"
    print "  --state open|closed|all      Filter by state (default: open)"
    print "  --search TEXT                Free-text search (backend-native: gh qualifiers / Jira JQL fragment)"
    print "  --limit N                     Max results (default: 30)"
    print "  --json / --jq EXPR           JSON output / jq-style filter"
    print "  --web                         Open in browser (github: native passthrough; jira: `view` only)"
    print ""
    print "Config: ~/.config/itf/config.sdn — tasks: backend: jira|github, tasks: jira_done_status: Done"
    print ""
    print "Examples:"
    print "  itf tasks list --assignee @me --state open"
    print "  itf tasks view PROJ-123"
    print "  itf tasks create --backend jira --project PROJ --title \"New bug\""
    print "  itf tasks close 42 --backend github"
    print ""
    print "Requires: gh CLI (github backend) / acli or jira curl credentials (jira backend)."
