# ITF CLI — `itf github` (alias `gh`) commands.
#
# Delegates every operation to the system `gh` CLI (see adapter_github.spl)
# and adds itf-consistent table/JSON formatting on top of `gh ... --json`
# output. Replaces the previously-unwired `github_passthrough` stub — there
# was no `github` case in main.spl's dispatch before this.
#
# Subcommands: issue {list,view,create,edit,comment,close}, pr {list,view,create,merge,review,checkout},
# repo {view,clone}.

use std.json.{json_parse, json_object_get, json_array_get, json_array_length, json_serialize, json_get_type}
use app.itf.adapter_github.{gh_run, gh_available, gh_actionable_error}
use app.itf.flags.{_extract_flag, _has_flag, _remove_flags}
use app.itf.output.{print_error, print_table_dynamic, colorize_state, format_json_output, wants_json, relative_time, set_no_pager}


fn handle_github(args: [text]) -> i64:
    """Dispatch `itf github` (alias `gh`) subcommands."""
    if args.len() == 0:
        _print_github_help()
        return 0

    val action = args[0]
    val action_args = if args.len() > 1: args[1:] else: []

    match action:
        "issue":
            _github_issue(action_args)
        "pr":
            _github_pr(action_args)
        "repo":
            _github_repo(action_args)
        "-h" | "--help" | "help":
            _print_github_help()
            0
        _:
            print_error("unknown github command: {action}")
            _print_github_help()
            1


fn _github_issue(args: [text]) -> i64:
    if args.len() == 0:
        print_error("usage: itf github issue <list|view|create|edit|comment|close> ...")
        return 1
    val sub = args[0]
    val rest = if args.len() > 1: args[1:] else: []
    match sub:
        "list":
            _github_list("issue", rest)
        "view":
            _github_passthrough(["issue", "view"] + rest)
        "create":
            _github_passthrough(["issue", "create"] + rest)
        "edit":
            _github_passthrough(["issue", "edit"] + rest)
        "comment":
            _github_passthrough(["issue", "comment"] + rest)
        "close":
            _github_passthrough(["issue", "close"] + rest)
        "-h" | "--help" | "help":
            print "Usage: itf github issue <command> [flags]"
            print ""
            print "Commands:"
            print "  list              List issues (--state, --limit, --assignee, --label pass through to gh)"
            print "  view <number>     View an issue"
            print "  create            Create an issue (--title T --body B; interactive prompts are not supported)"
            print "  edit <number>     Edit an issue (--title, --body, --add-label, --remove-label, --add-assignee, --remove-assignee)"
            print "  comment <number>  Add a comment (--body B)"
            print "  close <number>    Close an issue"
            0
        _:
            print_error("unknown github issue command: {sub}")
            1


fn _github_pr(args: [text]) -> i64:
    if args.len() == 0:
        print_error("usage: itf github pr <list|view|create|merge|review|checkout> ...")
        return 1
    val sub = args[0]
    val rest = if args.len() > 1: args[1:] else: []
    match sub:
        "list":
            _github_list("pr", rest)
        "view":
            _github_passthrough(["pr", "view"] + rest)
        "create":
            _github_passthrough(["pr", "create"] + rest)
        "merge":
            _github_passthrough(["pr", "merge"] + rest)
        "review":
            _github_passthrough(["pr", "review"] + rest)
        "checkout":
            _github_passthrough(["pr", "checkout"] + rest)
        "-h" | "--help" | "help":
            print "Usage: itf github pr <command> [flags]"
            print ""
            print "Commands:"
            print "  list              List pull requests (--state, --limit, --base pass through to gh)"
            print "  view <number>     View a pull request"
            print "  create            Create a pull request (--title T --body B --base B; --fill/--draft supported)"
            print "  merge <number>    Merge a pull request (--squash/--rebase/--merge)"
            print "  review <number>   Review a pull request (--approve/--request-changes/--comment, --body B)"
            print "  checkout <number> Check out a pull request locally"
            0
        _:
            print_error("unknown github pr command: {sub}")
            1


fn _github_repo(args: [text]) -> i64:
    if args.len() == 0:
        print_error("usage: itf github repo <view|clone> [name]")
        return 1
    val sub = args[0]
    val rest = if args.len() > 1: args[1:] else: []
    match sub:
        "view":
            _github_passthrough(["repo", "view"] + rest)
        "clone":
            _github_passthrough(["repo", "clone"] + rest)
        "-h" | "--help" | "help":
            print "Usage: itf github repo <command> [flags]"
            print ""
            print "Commands:"
            print "  view [name]           View a repository"
            print "  clone <repo> [dir]    Clone a repository (gh-native args after `--` pass to git clone)"
            0
        _:
            print_error("unknown github repo command: {sub}")
            1


fn _github_passthrough(gh_args: [text]) -> i64:
    """Run gh with the given args and print its output verbatim.

    Used for single-item / mutating commands (view, create, edit, comment,
    close, merge, review, checkout, repo view, repo clone) where gh's own
    text formatting is already good — only `list` gets itf table/JSON
    reformatting.
    """
    if not gh_available():
        print_error(gh_actionable_error(""))
        return 1
    val (ok, stdout, stderr) = gh_run(gh_args)
    if stdout.trim() != "":
        print stdout
    if not ok:
        print_error(gh_actionable_error(stderr))
        return 1
    0


fn _default_fields(entity: text) -> text:
    if entity == "pr":
        "number,title,state,author,headRefName,updatedAt"
    else:
        "number,title,state,author,updatedAt"


fn _github_list(entity: text, args: [text]) -> i64:
    """`itf github issue list` / `itf github pr list` — table by default, --json/--jq passthrough. --no-pager suppresses paging."""
    set_no_pager(_has_flag(args, "--no-pager"))
    if not gh_available():
        print_error(gh_actionable_error(""))
        return 1
    val fields = _extract_flag(args, "--json", _default_fields(entity))
    var gh_args = [entity, "list", "--json", fields]
    gh_args = gh_args + _remove_flags(args, ["--json", "--jq", "--no-pager"])
    val (ok, stdout, stderr) = gh_run(gh_args)
    if not ok:
        print_error(gh_actionable_error(stderr))
        return 1
    if wants_json(args) or _has_flag(args, "--jq"):
        print format_json_output(stdout, args)
        return 0
    _print_gh_table(entity, stdout)
    0


fn _gh_field(obj: any, key: text) -> text:
    """Safely extract a string or number field from a gh --json object."""
    if obj == nil:
        return ""
    val v = json_object_get(obj, key)
    if v == nil:
        return ""
    val s = json_serialize(v)
    if s.starts_with("\"") and s.ends_with("\""):
        return s[1:s.len() - 1]
    s


fn _gh_login(obj: any, key: text) -> text:
    """Extract `<key>.login` (gh's shape for author/assignee objects)."""
    val nested = json_object_get(obj, key)
    if nested == nil:
        return ""
    _gh_field(nested, "login")


fn _print_gh_table(entity: text, raw_json: text):
    val parsed = json_parse(raw_json)
    if parsed == nil or json_get_type(parsed) != "array":
        print raw_json
        return
    val n = json_array_length(parsed)
    if n == 0:
        val label = if entity == "pr": "pull requests" else: "issues"
        print "No {label} found. Try --state all or check `gh auth status`."
        return
    var rows: [[text]] = []
    var i = 0
    while i < n:
        val item = json_array_get(parsed, i)
        val number = "#{_gh_field(item, "number")}"
        val title = _gh_field(item, "title")
        val state = colorize_state(_gh_field(item, "state"))
        val author = _gh_login(item, "author")
        val updated = relative_time(_gh_field(item, "updatedAt"))
        if entity == "pr":
            val branch = _gh_field(item, "headRefName")
            rows.push([number, title, state, author, branch, updated])
        else:
            rows.push([number, title, state, author, updated])
        i = i + 1
    if entity == "pr":
        print_table_dynamic(["NUMBER", "TITLE", "STATE", "AUTHOR", "BRANCH", "UPDATED"], rows)
    else:
        print_table_dynamic(["NUMBER", "TITLE", "STATE", "AUTHOR", "UPDATED"], rows)


fn _print_github_help():
    print "itf github (alias: gh) — GitHub via the system `gh` CLI"
    print ""
    print "Usage: itf github <command> [flags]"
    print ""
    print "Commands:"
    print "  issue   list, view, create, edit, comment, close"
    print "  pr      list, view, create, merge, review, checkout"
    print "  repo    view, clone"
    print ""
    print "Flags:"
    print "  --json [FIELDS]   Output as JSON (optionally selecting gh --json fields)"
    print "  --jq EXPR         Filter JSON output"
    print ""
    print "Examples:"
    print "  itf github issue list --state open --limit 20"
    print "  itf github issue view 123"
    print "  itf github issue edit 123 --add-label bug"
    print "  itf github pr list --state open"
    print "  itf github pr create --title T --body B --base main"
    print "  itf github pr merge 42 --squash"
    print "  itf github pr review 42 --approve"
    print "  itf github repo clone owner/name"
    print ""
    print "Requires: gh CLI installed and authenticated (gh auth login)."
