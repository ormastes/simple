#![allow(unnamed_duplicate_typed_args)]
# ITF CLI — Confluence REST v2 Adapter
#
# Direct HTTP calls to Confluence Cloud REST API v2
# Endpoints: /api/v2/pages, /api/v2/spaces
# Auth: Basic auth (email:api_token)

use std.nogc_sync_mut.http_client.{http_get, http_post, http_put, http_delete, create_headers, add_header, response_get_status_code, response_get_body, response_is_success}
use std.common.json.{json_parse, json_serialize, json_pretty, json_object_get, json_object, json_string, json_number, json_array, json_array_get, json_array_length, json_get_type, json_object_keys, json_object_has}
use app.itf.config.{ItfConfig, load_config, load_auth_token}
use app.itf.auth.{confluence_auth_header, confluence_api_base}
use app.itf.errors.{ItfError, itf_error_from_http}


# ============================================================================
# Data Structures
# ============================================================================

class PageRef:
    id: text
    title: text
    space_id: text
    version: i64
    status: text
    url: text

class PageContent:
    ref: PageRef
    body_storage: text

class PageListItem:
    id: text
    title: text
    space_id: text
    status: text
    last_modified: text

class ConfluenceSearchResult:
    items: [PageListItem]
    total: i64
    has_more: bool
    next_cursor: text


# ============================================================================
# Internal HTTP helpers
# ============================================================================

fn _confluence_headers(config: ItfConfig) -> list:
    """Build standard headers for Confluence REST calls."""
    val auth = confluence_auth_header(config)
    var headers = create_headers()
    headers = add_header(headers, "Content-Type", "application/json")
    headers = add_header(headers, "Accept", "application/json")
    if auth != "":
        headers = add_header(headers, "Authorization", auth)
    headers


fn _confluence_get(config: ItfConfig, path: text) -> (i64, text):
    """Make authenticated GET to Confluence REST v2."""
    val base = confluence_api_base(config)
    if base == "":
        return (0, "")
    val url = "{base}{path}"
    val headers = _confluence_headers(config)
    val response = http_get(url)
    # Note: http_get returns a tuple; we extract status and body
    val status = response_get_status_code(response)
    val body = response_get_body(response)
    (status, body)


fn _confluence_post(config: ItfConfig, path: text, payload: text) -> (i64, text):
    """Make authenticated POST to Confluence REST v2."""
    val base = confluence_api_base(config)
    val url = "{base}{path}"
    val response = http_post(url, payload)
    val status = response_get_status_code(response)
    val body = response_get_body(response)
    (status, body)


fn _confluence_put(config: ItfConfig, path: text, payload: text) -> (i64, text):
    """Make authenticated PUT to Confluence REST v2."""
    val base = confluence_api_base(config)
    val url = "{base}{path}"
    val response = http_put(url, payload)
    val status = response_get_status_code(response)
    val body = response_get_body(response)
    (status, body)


fn _confluence_delete_req(config: ItfConfig, path: text) -> (i64, text):
    """Make authenticated DELETE to Confluence REST v2."""
    val base = confluence_api_base(config)
    val url = "{base}{path}"
    val response = http_delete(url)
    val status = response_get_status_code(response)
    val body = response_get_body(response)
    (status, body)


# ============================================================================
# Page parsing helpers
# ============================================================================

fn _parse_page_ref(json_obj: any) -> PageRef:
    """Parse a page JSON object into PageRef."""
    val id = _json_str(json_obj, "id")
    val title = _json_str(json_obj, "title")
    val status = _json_str(json_obj, "status")
    val space_id = _json_str(json_obj, "spaceId")

    # Version is nested: { "version": { "number": N } }
    var version = 0
    val version_obj = json_object_get(json_obj, "version")
    if version_obj != nil:
        val num_val = json_object_get(version_obj, "number")
        if num_val != nil:
            version = _json_int(version_obj, "number")

    # Build web URL from _links.webui if available
    var url = ""
    val links = json_object_get(json_obj, "_links")
    if links != nil:
        url = _json_str(links, "webui")

    PageRef(id: id, title: title, space_id: space_id, version: version, status: status, url: url)


fn _parse_page_list_item(json_obj: any) -> PageListItem:
    """Parse a page JSON into PageListItem (lightweight)."""
    val id = _json_str(json_obj, "id")
    val title = _json_str(json_obj, "title")
    val space_id = _json_str(json_obj, "spaceId")
    val status = _json_str(json_obj, "status")
    val last_modified = _json_str(json_obj, "version")

    # Try to extract createdAt or version.createdAt
    var modified = ""
    val version_obj = json_object_get(json_obj, "version")
    if version_obj != nil:
        modified = _json_str(version_obj, "createdAt")

    PageListItem(id: id, title: title, space_id: space_id, status: status, last_modified: modified)


fn _json_str(obj: any, key: text) -> text:
    """Safely extract a string field from JSON object."""
    if obj == nil:
        return ""
    val value = json_object_get(obj, key)
    if value == nil:
        return ""
    val vtype = json_get_type(value)
    if vtype == "string":
        # json_serialize wraps in quotes, strip them
        val s = json_serialize(value)
        if s.starts_with("\"") and s.ends_with("\""):
            return s[1:s.len() - 1]
        return s
    json_serialize(value)


fn _json_int(obj: any, key: text) -> i64:
    """Safely extract an integer field from JSON object."""
    if obj == nil:
        return 0
    val value = json_object_get(obj, key)
    if value == nil:
        return 0
    val s = json_serialize(value)
    # Parse integer from string
    var result = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i64() - "0".to_i64())
    result


# ============================================================================
# Public API
# ============================================================================

fn confluence_list_pages(config: ItfConfig, space_id: text, limit: i64) -> (bool, [PageListItem], text):
    """List pages in a space.

    Returns: (success, items, raw_json_for_--json_mode)
    """
    var path = "/pages?body-format=storage&limit={limit}"
    if space_id != "":
        path = "/pages?space-id={space_id}&limit={limit}"

    val (status, body) = _confluence_get(config, path)
    if status < 200 or status >= 300:
        return (false, [], body)

    val parsed = json_parse(body)
    if parsed == nil:
        return (false, [], "invalid JSON response")

    val results_arr = json_object_get(parsed, "results")
    if results_arr == nil:
        return (true, [], body)

    var items: [PageListItem] = []
    val arr_len = json_array_length(results_arr)
    var i = 0
    while i < arr_len:
        val item = json_array_get(results_arr, i)
        items = items + [_parse_page_list_item(item)]
        i = i + 1

    (true, items, body)


fn confluence_get_page(config: ItfConfig, page_id: text) -> (bool, PageContent, text):
    """Get a single page with storage body.

    Returns: (success, page_content, raw_json)
    """
    val path = "/pages/{page_id}?body-format=storage"
    val (status, body) = _confluence_get(config, path)

    if status < 200 or status >= 300:
        val empty = PageContent(ref: PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: ""), body_storage: "")
        return (false, empty, body)

    val parsed = json_parse(body)
    if parsed == nil:
        val empty = PageContent(ref: PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: ""), body_storage: "")
        return (false, empty, "invalid JSON response")

    val ref = _parse_page_ref(parsed)

    # Extract body.storage.value
    var storage_body = ""
    val body_obj = json_object_get(parsed, "body")
    if body_obj != nil:
        val storage_obj = json_object_get(body_obj, "storage")
        if storage_obj != nil:
            storage_body = _json_str(storage_obj, "value")

    val content = PageContent(ref: ref, body_storage: storage_body)
    (true, content, body)


fn confluence_create_page(config: ItfConfig, space_id: text, title: text, body_storage: text, parent_id: text) -> (bool, PageRef, text):
    """Create a new page.

    Returns: (success, page_ref, raw_json)
    """
    # Build request payload
    var payload = "\{\"spaceId\": \"{space_id}\", \"status\": \"current\", \"title\": \"{_json_escape(title)}\", \"body\": \{\"representation\": \"storage\", \"value\": \"{_json_escape(body_storage)}\"\}"
    if parent_id != "":
        payload = payload + ", \"parentId\": \"{parent_id}\""
    payload = payload + "\}"

    val (status, resp_body) = _confluence_post(config, "/pages", payload)

    if status < 200 or status >= 300:
        val empty = PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: "")
        return (false, empty, resp_body)

    val parsed = json_parse(resp_body)
    if parsed == nil:
        val empty = PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: "")
        return (false, empty, "invalid JSON response")

    val ref = _parse_page_ref(parsed)
    (true, ref, resp_body)


fn confluence_update_page(config: ItfConfig, page_id: text, title: text, body_storage: text, version: i64, message: text) -> (bool, PageRef, text):
    """Update a page. Requires current version number.

    Returns: (success, updated_ref, raw_json)
    """
    val new_version = version + 1
    var payload = "\{\"id\": \"{page_id}\", \"status\": \"current\", \"title\": \"{_json_escape(title)}\", \"body\": \{\"representation\": \"storage\", \"value\": \"{_json_escape(body_storage)}\"\}, \"version\": \{\"number\": {new_version}"
    if message != "":
        payload = payload + ", \"message\": \"{_json_escape(message)}\""
    payload = payload + "\}\}"

    val (status, resp_body) = _confluence_put(config, "/pages/{page_id}", payload)

    if status < 200 or status >= 300:
        val empty = PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: "")
        return (false, empty, resp_body)

    val parsed = json_parse(resp_body)
    if parsed == nil:
        val empty = PageRef(id: "", title: "", space_id: "", version: 0, status: "", url: "")
        return (false, empty, "invalid JSON response")

    val ref = _parse_page_ref(parsed)
    (true, ref, resp_body)


fn confluence_delete_page(config: ItfConfig, page_id: text) -> (bool, text):
    """Delete a page.

    Returns: (success, error_message)
    """
    val (status, body) = _confluence_delete_req(config, "/pages/{page_id}")
    if status >= 200 and status < 300:
        (true, "")
    else:
        (false, body)


fn confluence_search_pages(config: ItfConfig, query: text, space_id: text, limit: i64) -> (bool, [PageListItem], text):
    """Search pages by title.

    Returns: (success, items, raw_json)
    """
    var path = "/pages?title={query}&limit={limit}"
    if space_id != "":
        path = "/pages?title={query}&space-id={space_id}&limit={limit}"

    val (status, body) = _confluence_get(config, path)
    if status < 200 or status >= 300:
        return (false, [], body)

    val parsed = json_parse(body)
    if parsed == nil:
        return (false, [], "invalid JSON response")

    val results_arr = json_object_get(parsed, "results")
    if results_arr == nil:
        return (true, [], body)

    var items: [PageListItem] = []
    val arr_len = json_array_length(results_arr)
    var i = 0
    while i < arr_len:
        val item = json_array_get(results_arr, i)
        items = items + [_parse_page_list_item(item)]
        i = i + 1

    (true, items, body)


fn _json_escape(s: text) -> text:
    """Escape a string for JSON embedding."""
    s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
