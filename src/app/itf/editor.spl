# ITF CLI — Editor workflow
#
# Fetch → tmpfile → $EDITOR → diff → upload
# Supports both storage (native) and markdown (lossy) edit modes

use std.nogc_sync_mut.file_system.file_ops.{file_read_text, file_write_text, file_exists, file_delete}
use std.nogc_sync_mut.io.process_ops.{process_run}
use app.itf.config.{ItfConfig, resolve_editor}
use app.itf.adapter_confluence.{confluence_get_page, confluence_update_page, PageContent}
use app.itf.convert_storage.{storage_to_markdown, markdown_to_storage}
use app.itf.output.{print_error, print_success}


fn edit_page(config: ItfConfig, page_id: text, mode: text, message: text) -> i64:
    """Full edit workflow: fetch, convert, edit, upload.

    Args:
        config: ITF configuration
        page_id: Confluence page ID
        mode: "storage" or "markdown"
        message: Version message (empty = default)

    Returns: exit code (0=success, 1=error, 2=cancelled)
    """
    # 1. Fetch current page
    val (ok, content, raw) = confluence_get_page(config, page_id)
    if not ok:
        print_error("failed to fetch page {page_id}: {raw}")
        return 1

    val version = content.ref.version
    val title = content.ref.title

    # 2. Prepare edit content based on mode
    var edit_text = ""
    var file_ext = ".html"
    if mode == "markdown":
        edit_text = storage_to_markdown(content.body_storage)
        file_ext = ".md"
    else:
        edit_text = content.body_storage
        file_ext = ".html"

    # 3. Write to temp file
    val tmp_path = "/tmp/itf_edit_{page_id}{file_ext}"
    file_write_text(tmp_path, edit_text)

    # 4. Open editor
    val editor = resolve_editor(config)
    val (_, _, editor_code) = process_run(editor, [tmp_path])
    if editor_code != 0:
        print_error("editor exited with code {editor_code}")
        return 2

    # 5. Read edited content
    val edited = file_read_text(tmp_path)
    if edited == nil:
        print_error("could not read edited file")
        return 1

    # 6. Check if changed
    if edited == edit_text:
        print "No changes made."
        # Clean up temp file
        file_delete(tmp_path)
        return 0

    # 7. Convert back if needed
    var new_storage = ""
    if mode == "markdown":
        new_storage = markdown_to_storage(edited)
    else:
        new_storage = edited

    # 8. Upload with version tracking
    val commit_msg = if message != "": message else: "Edited via itf CLI"
    val (update_ok, updated_ref, update_err) = confluence_update_page(config, page_id, title, new_storage, version, commit_msg)

    # Clean up temp file
    file_delete(tmp_path)

    if not update_ok:
        print_error("failed to update page: {update_err}")
        return 1

    print_success("Page updated: {updated_ref.title} (version {updated_ref.version})")
    if updated_ref.url != "":
        print updated_ref.url
    0
