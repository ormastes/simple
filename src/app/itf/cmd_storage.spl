fn _storage_presign(args: [text]) -> i64:
    """`storage presign alias/bucket/key [--expires SECONDS]` (mc: `share download`)."""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage presign alias/bucket/key [--expires SECONDS]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage presign alias/bucket/key â€” TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val expires = _parse_int(_extract_flag(args, "--expires", "86400"), 86400)
    val (ok, url, err) = minio_presign_get(cfg, addr.bucket, addr.key, expires)
    if not ok:
        print_error(err)
        return 1
    print url
    0


fn _storage_presign_put(args: [text]) -> i64:
    """`storage presign-put alias/bucket/key [--expires SECONDS]` (mc: `share upload`,
    deliberately simpler than mc's multi-field POST-policy form â€” a bare
    presigned PUT URL, per facade_storage.md Â§1/Â§3)."""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage presign-put alias/bucket/key [--expires SECONDS]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage presign-put alias/bucket/key â€” TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val expires = _parse_int(_extract_flag(args, "--expires", "86400"), 86400)
    val (ok, url, err) = minio_presign_put(cfg, addr.bucket, addr.key, expires)
    if not ok:
        print_error(err)
        return 1
    print url
    0


# ---------------------------------------------------------------------------
# du â€” client-side aggregation over minio_list_objects (facade_storage.md Â§3
# du row: "pure aggregation over existing minio_list_objects, no new SFFI").
# ---------------------------------------------------------------------------

fn _index_of(items: [text], value: text) -> i64:
    var i = 0
    while i < items.len():
        if items[i] == value:
            return i
        i = i + 1
    -1


fn _truncate_to_depth(key: text, depth: i64) -> text:
    """First `depth` "/"-separated segments of `key`, joined back with "/"
    and a trailing "/" (mc's own `du --depth` truncates the same way).
    Returns `key` unchanged if it has `depth` or fewer segments."""
    val parts = key.split("/")
    if parts.len() <= depth:
        return key
    var out: [text] = []
    var i = 0
    while i < depth:
        out.push(parts[i])
        i = i + 1
    out.join("/") + "/"


fn _storage_du(args: [text]) -> i64:
    """`storage du alias/bucket[/prefix] [--depth N] [--bytes] [--json]`

    No `--depth` (or `--depth 0`): one aggregate total-size + object-count
    line. `--depth N`: group by the first N "/"-segments under the prefix
    and print one row per group (mirrors mc's `du --depth` truncation).
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage du alias/bucket[/prefix] [--depth N]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage du alias/bucket[/prefix] â€” TARGET must be alias/bucket[/prefix] (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, objects, raw) = minio_list_objects(cfg, addr.bucket, addr.key)
    if not ok:
        print_error(raw)
        return 1
    val raw_bytes = _has_flag(args, "--bytes")
    val depth = _parse_int(_extract_flag(args, "--depth", "0"), 0)

    if depth <= 0:
        var total: i64 = 0
        for o in objects:
            total = total + o.size
        if wants_json(args):
            print "{{\"alias\":\"{addr.alias}\",\"bucket\":\"{addr.bucket}\",\"prefix\":\"{addr.key}\",\"total_size\":{total},\"object_count\":{objects.len()}}}"
            return 0
        val size_text = if raw_bytes: "{total}" else: format_size(total)
        print_success("{size_text}  {objects.len()} objects  {addr.alias}/{addr.bucket}/{addr.key}")
        return 0

    var group_names: [text] = []
    var group_sizes: [i64] = []
    for o in objects:
        val group = _truncate_to_depth(o.key, depth)
        val idx = _index_of(group_names, group)
        if idx < 0:
            group_names.push(group)
            group_sizes.push(o.size)
        else:
            group_sizes[idx] = group_sizes[idx] + o.size
    if objects.len() == 0:
        print "No objects found under {addr.alias}/{addr.bucket}/{addr.key}."
        return 0
    var rows: [[text]] = []
    var i = 0
    while i < group_names.len():
        val size_text = if raw_bytes: "{group_sizes[i]}" else: format_size(group_sizes[i])
        rows.push([size_text, group_names[i]])
        i = i + 1
    print_table_dynamic(["SIZE", "PATH"], rows)
    0


