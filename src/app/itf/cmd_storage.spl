# ---------------------------------------------------------------------------

fn _storage_mirror(args: [text]) -> i64:
    """`storage mirror SRC TARGET [--dry-run]` â€” not yet implemented, see docstring above."""
    print_error("storage mirror: not yet implemented â€” needs a new ls+cp loop or an `mc mirror` wrapper (out of scope for this pass); see doc/05_design/app/devhub/facade_storage.md Â§3/Â§7. Workaround: run `storage cp` per object, or use the real `mc mirror` CLI if installed.")
    1


# ---------------------------------------------------------------------------
# cp
# ---------------------------------------------------------------------------

fn _storage_cp(args: [text]) -> i64:
    """`storage cp SRC DST [--content-type CT]`

    Direction is inferred purely from which side is local vs. alias/bucket/key
    (facade_storage.md Â§1/Â§3, infer_cp_direction()) â€” no --upload/--download flag.
    """
    val pos = _positional_args(args)
    if pos.len() < 2:
        print_error("usage: storage cp SRC DST [--content-type CT]")
        return 1
    val src = parse_storage_addr(pos[0])
    val dst = parse_storage_addr(pos[1])
    if not src.valid:
        print_error("storage cp: invalid SRC '{pos[0]}': {src.error}")
        return 1
    if not dst.valid:
        print_error("storage cp: invalid DST '{pos[1]}': {dst.error}")
        return 1
    val direction = infer_cp_direction(src, dst)
    if direction == "error_remote_remote":
        print_error("storage cp: remoteâ†’remote copy is not supported by this facade â€” download then upload as two steps, or use `mc mirror`/`mc cp` directly if installed.")
        return 1
    if direction == "error_local_local":
        print_error("storage cp: both SRC and DST are local paths â€” the storage facade only handles localâ†”remote transfers; use a plain filesystem copy for localâ†’local.")
        return 1
    if direction == "upload":
        return _storage_cp_upload(src, dst, args)
    _storage_cp_download(src, dst, args)


fn _storage_cp_upload(src: StorageAddr, dst: StorageAddr, args: [text]) -> i64:
    """localâ†’remote. Text bodies (UTF-8 decodable) go through minio_put_text
    directly; binary bodies get a real, ready-to-run presigned-PUT curl
    command (the actual working escape hatch â€” see adapter_minio.minio_put_object's
    docstring for why a direct binary PUT isn't supported yet)."""
    if dst.bucket == "" or dst.key == "":
        print_error("storage cp: upload DST must be a full alias/bucket/key (got '{dst.raw}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(dst.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val ct = _extract_flag(args, "--content-type", "")
    val content = file_read_text(src.local_path)
    if content != nil:
        val started = time_now_unix_micros()
        val (ok, _etag, raw) = minio_put_text(cfg, dst.bucket, dst.key, content, ct)
        val elapsed_ms = (time_now_unix_micros() - started) / 1000
        if not ok:
            print_error(raw)
            return 1
        print_success("uploaded {dst.alias}/{dst.bucket}/{dst.key} ({content.len()} bytes, text path)")
        print_dim(format_transfer_summary("uploaded", content.len(), elapsed_ms))
        return 0
    val (ok, url, err) = minio_presign_put(cfg, dst.bucket, dst.key, 86400)
    if not ok:
        print_error("storage cp: binary upload needs the presign-put escape hatch, and generating it failed: {err}")
        return 1
    print_error("storage cp: '{src.local_path}' isn't valid UTF-8 (binary body) â€” direct binary PUT isn't supported yet (needs a raw-bytes HTTP SFFI; see adapter_minio.minio_put_object). Run this instead:")
    print "  curl -X PUT --data-binary @{src.local_path} \"{url}\""
    1


fn _storage_cp_download(src: StorageAddr, dst: StorageAddr, args: [text]) -> i64:
    """remoteâ†’local, via the streaming presigned-download path (minio_download)
    so binary objects round-trip correctly (unlike the text-only get path)."""
    if src.bucket == "" or src.key == "":
        print_error("storage cp: download SRC must be a full alias/bucket/key (got '{src.raw}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(src.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val started = time_now_unix_micros()
    val (ok, bytes, err) = minio_download(cfg, src.bucket, src.key, dst.local_path, 3600)
    val elapsed_ms = (time_now_unix_micros() - started) / 1000
    if not ok:
        print_error(err)
        return 1
    print_success("wrote {bytes} bytes to {dst.local_path}")
    print_dim(format_transfer_summary("downloaded", bytes, elapsed_ms))
    0


# ---------------------------------------------------------------------------
# health
# ---------------------------------------------------------------------------

fn _storage_health(args: [text]) -> i64:
    """`storage health [alias] [--json]` â€” no TARGET defaults to `minio`."""
    val pos = _positional_args(args)
    val alias = if pos.len() > 0: pos[0] else: "minio"
    if not is_known_alias(alias):
        print_error("unknown alias '{alias}' â€” only the single-endpoint 'minio' alias is supported today; see doc/05_design/app/devhub/facade_storage.md Â§4")
        return 1
    val cfg = load_minio_config()
    if cfg.tls_skip_verify:
        print_error("tls_skip_verify is not supported by the pure-Simple HTTP transport (no TLS-verify override in the underlying HTTP SFFI). Remove tls_skip_verify from ~/.config/itf/auth.sdn.")
        return 1
    if cfg.url == "":
        print_error("MinIO URL not configured for alias '{alias}'")
        return 1
    val (ok, alive, latency_ms, raw) = minio_health_live(cfg)
    if not ok:
        print_error(raw)
        return 1
    if wants_json(args):
        print "{{\"alias\":\"{alias}\",\"alive\":{alive},\"status\":\"{raw}\",\"latency_ms\":{latency_ms},\"endpoint\":\"{cfg.url}\"}}"
        return 0
    if alive:
        print_success("OK â€” {alias} ({cfg.url}, {latency_ms}ms, {raw})")
        return 0
    print_error("FAIL â€” {alias} ({cfg.url}, {latency_ms}ms): {raw}")
    1


# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

fn _print_storage_help():
    """Print `storage`/`web_storage` help text (mc-shaped facade â€” see
    doc/05_design/app/devhub/facade_storage.md)."""
    print "storage (web_storage) â€” mc-style facade over S3-compatible object storage"
    print ""
    print "Usage: storage <command> [alias/][bucket[/key...]] [flags]"
    print ""
    print "Commands:"
    print "  ls [alias[/bucket[/prefix]]]     List buckets, or objects under a bucket/prefix"
    print "  cp SRC DST                       Copy â€” direction inferred from local vs alias/bucket/key"
    print "  cat alias/bucket/key             Print object body to stdout (--range R)"
    print "  stat alias/bucket/key            Size/etag/last-modified (via ListObjectsV2 â€” see NOTE)"
    print "  mb alias/bucket                  Create a bucket"
    print "  rb alias/bucket                  Delete an (empty) bucket (--force: not yet implemented)"
    print "  rm alias/bucket/key              Delete an object â€” NOT YET IMPLEMENTED (see below)"
    print "  presign alias/bucket/key         Generate a presigned GET URL (--expires SECONDS)"
    print "  presign-put alias/bucket/key     Generate a presigned PUT URL (binary-upload workaround)"
    print "  du alias/bucket[/prefix]         Aggregate object sizes under a prefix (--depth N)"
    print "  mirror SRC DST                   NOT YET IMPLEMENTED (see below)"
    print "  health [alias]                   Probe /minio/health/live"
    print ""
    print "Flags:"
    print "  --json            Output as JSON"
    print "  --range R         For `cat`: HTTP Range header value (e.g. bytes=0-1023)"
    print "  --bytes           For `ls`/`stat`/`du`: raw byte counts instead of KiB/MiB/GiB"
    print "  --expires N       For `presign`/`presign-put`: URL validity in seconds (default 86400)"
    print "  --depth N         For `du`: truncate the grouped summary to N path segments"
    print "  --content-type CT For `cp` (upload): response Content-Type"
    print "  --no-pager        Never page long `ls` output"
    print ""
    print "Addressing: every TARGET is either a local filesystem path, or"
    print "  alias/bucket[/key...] â€” bare `minio` is the only alias today (single-endpoint"
    print "  fallback onto the existing [minio] section; see facade_storage.md Â§4)."
    print ""
    print "NOTE: `stat`/`ls` cannot use a real HEAD for size/etag/last-modified â€” the"
    print "  underlying HTTP transport exposes no response headers, so these fall back"
    print "  to ListObjectsV2. `rm` and `mirror` are documented gaps, not silent no-ops."
    print ""
    print "Config: ~/.config/itf/auth.sdn"
    print "  [minio]"
    print "  url = https://minio.example.com:9000"
    print "  region = us-east-1"
    print "  access_key = AKIA..."
    print "  secret_key = ..."
    print "  tls_skip_verify = false"
