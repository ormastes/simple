fn _storage_mb(args: [text]) -> i64:
    """`storage mb alias/bucket`"""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage mb alias/bucket")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage mb alias/bucket â€” TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_create_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket created: {addr.alias}/{addr.bucket}")
    0


fn _storage_rb(args: [text]) -> i64:
    """`storage rb alias/bucket [--force]`

    `--force` (recursive empty-then-delete) is a documented gap
    (facade_storage.md Â§3 rb row): it depends on the same missing
    object-level DELETE that blocks `storage rm` below, so it prints the
    same not-yet-implemented message instead of silently ignoring --force
    or attempting a partial recursive delete.
    """
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rb alias/bucket [--force]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "":
        print_error("usage: storage rb alias/bucket â€” TARGET must be alias/bucket (got '{pos[0]}')")
        return 1
    if _has_flag(args, "--force"):
        print_error("storage rb --force: not yet implemented â€” recursive empty-then-delete needs object-level DELETE, which adapter_minio.spl doesn't expose yet (same gap as `storage rm`). Workaround: empty the bucket with the real `mc rm --recursive` CLI, then retry `storage rb` without --force.")
        return 1
    val (auth_ok, cfg, auth_err) = resolve_alias_config(addr.alias)
    if not auth_ok:
        print_error(auth_err)
        return 1
    val (ok, err) = minio_delete_bucket(cfg, addr.bucket)
    if not ok:
        print_error(err)
        return 1
    print_success("bucket deleted: {addr.alias}/{addr.bucket}")
    0


# ---------------------------------------------------------------------------
# rm â€” GAP (facade_storage.md Â§3/Â§7): no object-level DELETE in either
# adapter today. adapter_minio.spl would need a new signed DELETE call
# (out of this worker's scope â€” read-only import boundary), so this prints
# the spec's defined not-yet-supported error rather than a silent no-op.
# ---------------------------------------------------------------------------

fn _storage_rm(args: [text]) -> i64:
    """`storage rm alias/bucket/key [-r]` â€” not yet implemented, see docstring above."""
    val pos = _positional_args(args)
    if pos.len() < 1:
        print_error("usage: storage rm alias/bucket/key [-r]")
        return 1
    val addr = parse_storage_addr(pos[0])
    if not addr.valid or not addr.is_remote or addr.bucket == "" or addr.key == "":
        print_error("usage: storage rm alias/bucket/key â€” TARGET must be a full alias/bucket/key (got '{pos[0]}')")
        return 1
    print_error("storage rm: not yet implemented â€” adapter_minio.spl has no object-level DELETE call yet (only minio_delete_bucket exists at the bucket level); see doc/05_design/app/devhub/facade_storage.md Â§3 (rm row). Workaround: `mc rm {addr.alias}/{addr.bucket}/{addr.key}` with the real mc CLI if installed.")
    1


