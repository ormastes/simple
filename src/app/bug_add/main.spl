# Simple CLI - bug-add command
# Adds a new open bug to doc/08_tracking/bug/bug_db.sdn

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use nogc_sync_mut.database.bug.{Bug, BugSeverity, BugStatus, load_bug_database}
use std.log.{error}

val BUG_DB_PATH = "doc/08_tracking/bug/bug_db.sdn"

fn print_help():
    print "Usage: simple bug-add --id=<id> --severity=<p0|p1|p2|p3> --title=<t> --file=<path>"
    print ""
    print "Add a new open bug to the bug database."
    print ""
    print "Options:"
    print "  --id=<id>           Bug identifier (e.g. my_bug_001)"
    print "  --severity=<level>  Severity: p0, p1, p2, p3 (default: p2)"
    print "  --title=<text>      Short bug title"
    print "  --file=<path>       Source file path where bug occurs"
    print "  --line=<n>          Line number (default: 0)"
    print "  --repro=<test>      Reproducible-by test (default: N/A)"
    print "  --json              Output as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help          Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn parse_flag(args: [text], prefix: text) -> text:
    for arg in args:
        if arg.starts_with(prefix):
            return arg[prefix.len():]
    ""

fn parse_severity(s: text) -> BugSeverity:
    val lower = s.lower()
    val severity = if lower == "p0":
        BugSeverity.P0
    elif lower == "p1":
        BugSeverity.P1
    elif lower == "p2":
        BugSeverity.P2
    elif lower == "p3":
        BugSeverity.P3
    else:
        BugSeverity.P2
    severity

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("bug-add", log_opts.error)
        return 1

    var as_json = log_opts.log_mode == "json"
    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        ai = ai + 1

    val id = parse_flag(args, "--id=")
    val severity_str = parse_flag(args, "--severity=")
    val title = parse_flag(args, "--title=")
    val file = parse_flag(args, "--file=")
    val line_str = parse_flag(args, "--line=")
    val repro = parse_flag(args, "--repro=")

    if id == "":
        print "Error: --id is required"
        print_help()
        return 1

    if title == "":
        print "Error: --title is required"
        print_help()
        return 1

    val line_num = if line_str != "": line_str.parse_i64() ?? 0 else: 0
    val repro_val = if repro != "": repro else: "N/A"
    val file_val = if file != "": file else: "unknown"
    val severity = parse_severity(severity_str)

    val db_opt = load_bug_database(BUG_DB_PATH)
    if not db_opt.?:
        print "Error: could not load bug database at {BUG_DB_PATH}"
        return 1
    var db = db_opt.unwrap()

    val bug = Bug(
        id: id,
        severity: severity,
        status: BugStatus.Open,
        title: title,
        description: [""],
        file: file_val,
        line: line_num,
        reproducible_by: repro_val,
        fix_strategy: [""],
        investigation_log: [""],
        created_at: "2026-04-14",
        updated_at: "2026-04-14",
        valid: true
    )

    if not db.add_bug(bug):
        print "Error: failed to add bug (id may already exist)"
        return 1

    if not db.save():
        print "Error: failed to save bug database"
        return 1

    if log_opts.progress != "summary":
        val progress_line = render_progress(log_opts.progress, 1, 1, "bug-add")
        if progress_line != "":
            print progress_line
    if as_json:
        print "{\"command\":\"bug-add\",\"status\":\"ok\",\"id\":\"{id}\"}"
    else:
        print "Added bug {id} to {BUG_DB_PATH}"
    0
