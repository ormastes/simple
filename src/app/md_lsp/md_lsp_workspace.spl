# Document store for the Simple language markdown LSP server.
# Manages open documents and their cached ASTs.

use std.common.markdown

struct MdDocument:
    uri: text
    content: text
    version: i64
    ast: array
    headings: array

class MdWorkspace:
    documents: [MdDocument]

impl MdWorkspace:
    static fn new() -> MdWorkspace:
        MdWorkspace(documents: [])

    me open_document(uri: text, content: text, version: i64):
        val lines = split_lines(content)
        val ast = parse_blocks(lines)
        val headings = extract_headings(ast)
        val doc = MdDocument(
            uri: uri,
            content: content,
            version: version,
            ast: ast,
            headings: headings
        )
        var new_docs: [MdDocument] = []
        var i = 0
        var len = self.documents.length()
        while i < len:
            val existing = self.documents.get(i)
            if existing.uri != uri:
                new_docs.push(existing)
            i = i + 1
        new_docs.push(doc)
        self.documents = new_docs

    me update_document(uri: text, content: text, version: i64):
        val lines = split_lines(content)
        val ast = parse_blocks(lines)
        val headings = extract_headings(ast)
        val doc = MdDocument(
            uri: uri,
            content: content,
            version: version,
            ast: ast,
            headings: headings
        )
        var new_docs: [MdDocument] = []
        var i = 0
        var len = self.documents.length()
        while i < len:
            val existing = self.documents.get(i)
            if existing.uri != uri:
                new_docs.push(existing)
            i = i + 1
        new_docs.push(doc)
        self.documents = new_docs

    me close_document(uri: text):
        var new_docs: [MdDocument] = []
        var i = 0
        var len = self.documents.length()
        while i < len:
            val existing = self.documents.get(i)
            if existing.uri != uri:
                new_docs.push(existing)
            i = i + 1
        self.documents = new_docs

    fn get_document(uri: text) -> MdDocument:
        var i = 0
        var len = self.documents.length()
        while i < len:
            val doc = self.documents.get(i)
            if doc.uri == uri:
                return doc
            i = i + 1
        MdDocument(uri: "", content: "", version: 0, ast: [], headings: [])

    fn has_document(uri: text) -> bool:
        var i = 0
        var len = self.documents.length()
        while i < len:
            val doc = self.documents.get(i)
            if doc.uri == uri:
                return true
            i = i + 1
        false

    fn document_count() -> i64:
        self.documents.length()

    fn all_uris() -> [text]:
        var uris: [text] = []
        var i = 0
        var len = self.documents.length()
        while i < len:
            val doc = self.documents.get(i)
            uris.push(doc.uri)
            i = i + 1
        uris
