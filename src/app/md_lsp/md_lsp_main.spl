# Markdown LSP Server — stdio entry point
#
# Reads Content-Length framed JSON-RPC messages from stdin,
# dispatches to md_lsp_handler, and writes framed responses to stdout.
#
# Protocol:
#   Content-Length: N\r\n
#   \r\n
#   <N bytes of JSON body>

extern fn rt_stdin_read_line() -> text
extern fn rt_stdin_read_bytes(n: i64) -> text
extern fn rt_stdout_write(s: text)
extern fn rt_stderr_write(s: text)

use app.md_lsp.md_lsp_workspace
use app.md_lsp.md_lsp_handler

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

fn _md_lsp_log(message: text):
    rt_stderr_write("[md-lsp] " + message + "\n")

fn _md_lsp_parse_content_length(header_line: text) -> i64:
    val prefix = "Content-Length:"
    if not header_line.starts_with(prefix):
        return 0
    val rest = header_line.substring(prefix.len())
    val trimmed = rest.trim()
    var result: i64 = 0
    var i = 0
    val tlen = trimmed.len()
    while i < tlen:
        val ch = trimmed.char_at(i)
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_int() - "0".to_int())
        i = i + 1
    result

fn _md_lsp_has_id(json: text) -> bool:
    val search = "\"id\":"
    json.contains(search)

fn _md_lsp_extract_field(json: text, key: text) -> text:
    val search = "\"" + key + "\":"
    val idx_opt = json.index_of(search)
    var idx = -1
    match idx_opt:
        Some(i): idx = i
        nil: return ""
    if idx < 0:
        return ""
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if after.starts_with("\""):
        val inner = after.substring(1)
        val end_opt = inner.index_of("\"")
        var end_idx = -1
        match end_opt:
            Some(i): end_idx = i
            nil: return ""
        if end_idx < 0:
            return ""
        return inner.substring(0, end_idx)
    elif after.starts_with("{") or after.starts_with("["):
        # Return nested object/array as-is (find balanced close)
        var depth = 0
        var j = 0
        val alen = after.len()
        var parts: [text] = []
        while j < alen:
            val ch = after.char_at(j)
            if ch == "{" or ch == "[":
                depth = depth + 1
            elif ch == "}" or ch == "]":
                depth = depth - 1
            parts.push(ch)
            j = j + 1
            if depth == 0:
                return parts.join("")
        return parts.join("")
    else:
        # number or keyword (null, true, false)
        var parts: [text] = []
        var j = 0
        val alen = after.len()
        while j < alen:
            val ch = after.char_at(j)
            if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r":
                return parts.join("")
            parts.push(ch)
            j = j + 1
        parts.join("")

fn _md_lsp_frame(json: text) -> text:
    val byte_count = json.len()
    "Content-Length: " + str(byte_count) + "\r\n\r\n" + json

# ---------------------------------------------------------------------------
# Main server loop
# ---------------------------------------------------------------------------

fn md_lsp_server_main():
    var workspace = MdWorkspace.new()
    var running = true

    _md_lsp_log("md-lsp server starting")

    for _iter in range(0, 999999):
        if not running:
            return

        # Step 1: Read header lines until we find Content-Length
        var content_length: i64 = 0
        var found_header = false
        for _hiter in range(0, 100):
            if found_header:
                break
            val header_line = rt_stdin_read_line()
            if header_line == "":
                running = false
                return
            if header_line.starts_with("Content-Length:"):
                content_length = _md_lsp_parse_content_length(header_line)
                found_header = true

        if content_length <= 0:
            continue

        # Step 2: Read empty separator line (\r\n)
        val _sep = rt_stdin_read_line()

        # Step 3: Read exactly content_length bytes of JSON body
        val json = rt_stdin_read_bytes(content_length)
        if json == "":
            continue

        # Step 4: Parse fields
        val method = _md_lsp_extract_field(json, "method")
        val req_id = _md_lsp_extract_field(json, "id")
        val params_json = _md_lsp_extract_field(json, "params")

        _md_lsp_log("recv method=" + method + " id=" + req_id)

        # Step 5: Dispatch
        if method == "exit":
            running = false
        elif _md_lsp_has_id(json):
            val response = md_lsp_handle_request(method, params_json, req_id, workspace)
            if response != "":
                val framed = _md_lsp_frame(response)
                rt_stdout_write(framed)
        else:
            md_lsp_handle_notification(method, params_json, workspace)

    _md_lsp_log("md-lsp server stopped")

# Entry point
md_lsp_server_main()
