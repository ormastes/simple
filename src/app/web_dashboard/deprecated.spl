# web_dashboard — Deprecated Shim
#
# The web_dashboard app has been merged into llm_dashboard.
# This module re-exports key symbols for backward compatibility.
# Callers should migrate to app.llm_dashboard.gui.* imports.

use app.llm_dashboard.gui.terminal_panel.{
    handle_terminal_ws,
    generate_terminal_panel_html,
    generate_terminal_css,
    generate_terminal_js,
    TerminalTarget,
    parse_terminal_query
}
use app.llm_dashboard.gui.tmux_panel.{
    handle_tmux_api,
    api_tmux_status,
    api_tmux_sessions,
    api_tmux_windows,
    api_tmux_panes,
    api_tmux_capture,
    api_tmux_send,
    api_tmux_send_cmd,
    api_tmux_resize
}
use app.llm_dashboard.gui.html_views.{generate_agents_html, generate_agents_css}
use app.llm_dashboard.gui.ws_handler.{handle_agents_ws, AgentWsHandler}

fn _print_deprecation_warning():
    """Print a one-time deprecation notice."""
    print "[DEPRECATED] app.web_dashboard is deprecated. Use app.llm_dashboard.gui instead."

# Re-exports with deprecation notice on first use.
# The server.spl, terminal_ws.spl, tmux_api.spl, and dashboard_html.spl
# source files remain for existing import paths but new code should use
# the llm_dashboard equivalents directly.

export handle_terminal_ws
export handle_tmux_api
export generate_agents_html, generate_agents_css
export handle_agents_ws, AgentWsHandler
export generate_terminal_panel_html, generate_terminal_css, generate_terminal_js
