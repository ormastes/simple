use app.web_dashboard.dashboard_html.{generate_full_dashboard_html_with_diagnostics_and_tooling}
use app.llm_dashboard.collectors.diagnostics_jsonl_collector.{collect_llm_diagnostics_jsonl, render_llm_diagnostics_panel_html}
use app.llm_dashboard.collectors.tooling_artifact_collector.{collect_llm_tooling_artifacts, render_llm_tooling_artifacts_panel_html}
use app.llm_dashboard.collectors.vllm_control_panel.{collect_llm_dashboard_vllm_control_preflight, collect_llm_dashboard_vllm_control_action_with_overrides, render_llm_dashboard_vllm_control_panel_html}
use app.llm_runtime.dashboard_live_control.{llm_runtime_execute_dashboard_control_jsonl, llm_runtime_dashboard_live_boundary_jsonl}
use app.llm_runtime.manifest.{llm_runtime_manifest_from_text}
use app.dashboard.assistant_bridge.{assistant_bridge_default_policy}
use app.dashboard.assistant_collectors.{collect_assistant_snapshot_from_root}
use app.dashboard.assistant_live_view.{assistant_dashboard_live_view_from_snapshot, assistant_dashboard_render_live_view}
use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use app.llm_dashboard.web_login.{
    DashboardAuthSession,
    auth_session_from_headers,
    auth_authenticate_form,
    auth_delete_session,
    auth_login_page,
    auth_login_cookie_header,
    auth_clear_cookie_header
}

extern fn rt_env_get(key: text) -> text

val DEFAULT_DIAGNOSTICS_JSONL = ".build/llm_dashboard/diagnostics/session.jsonl"

# Auth is opt-in (DASH_AUTH=1) so plain localhost dev usage needs no login.
fn _dash_auth_enabled() -> bool:
    rt_env_get("DASH_AUTH") == "1"

fn _status_text(status: i64) -> text:
    match status:
        case 200:
            "OK"
        case 302:
            "Found"
        case 401:
            "Unauthorized"
        case _:
            "Error"

pub fn http_response(status: i64, content_type: text, body: text) -> text:
    var response = "HTTP/1.1 " + str(status) + " " + _status_text(status) + "\r\n"
    response = response + "Content-Type: " + content_type + "\r\n"
    response = response + "Content-Length: " + str(body.len()) + "\r\n\r\n"
    response + body

pub fn http_redirect(location: text) -> text:
    "HTTP/1.1 302 Found\r\nLocation: " + location + "\r\nContent-Length: 0\r\n\r\n"

pub fn http_redirect_with_headers(location: text, extra_headers: [text]) -> text:
    var response = "HTTP/1.1 302 Found\r\nLocation: " + location + "\r\n"
    for header in extra_headers:
        response = response + header + "\r\n"
    response + "Content-Length: 0\r\n\r\n"

pub fn http_error(status: i64, message: text) -> text:
    http_response(status, "text/plain", message)

pub struct DashboardServer:
    port: i64
    diagnostics_path: text
    tooling_source_path: text
    tooling_target: text
    vllm_manifest_text: text
    is_ios: bool
    agent_dir: text

    static fn new(port: i64) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: DEFAULT_DIAGNOSTICS_JSONL, tooling_source_path: "", tooling_target: "", vllm_manifest_text: "", is_ios: false, agent_dir: "")

    static fn new_with_diagnostics(port: i64, diagnostics_path: text) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: diagnostics_path, tooling_source_path: "", tooling_target: "", vllm_manifest_text: "", is_ios: false, agent_dir: "")

    static fn new_with_diagnostics_and_tooling(port: i64, diagnostics_path: text, tooling_source_path: text, tooling_target: text) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: diagnostics_path, tooling_source_path: tooling_source_path, tooling_target: tooling_target, vllm_manifest_text: "", is_ios: false, agent_dir: "")

    static fn new_with_vllm_manifest(port: i64, diagnostics_path: text, tooling_source_path: text, tooling_target: text, vllm_manifest_text: text) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: diagnostics_path, tooling_source_path: tooling_source_path, tooling_target: tooling_target, vllm_manifest_text: vllm_manifest_text, is_ios: false, agent_dir: "")

    static fn new_ios(port: i64, agent_dir: text) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: DEFAULT_DIAGNOSTICS_JSONL, tooling_source_path: "", tooling_target: "", vllm_manifest_text: "", is_ios: true, agent_dir: agent_dir)

    static fn new_with_agent_dir(port: i64, agent_dir: text) -> DashboardServer:
        DashboardServer(port: port, diagnostics_path: DEFAULT_DIAGNOSTICS_JSONL, tooling_source_path: "", tooling_target: "", vllm_manifest_text: "", is_ios: false, agent_dir: agent_dir)

    # Real TCP accept loop. Reuses login_only_server's request-parsing shape,
    # dispatching every request through route_http (auth optionally gated by
    # DASH_AUTH=1; see _route_request).
    fn start():
        print "Starting LLM dashboard web server on http://localhost:{self.port}"
        print "Press Ctrl+C to stop"
        match TcpListener.bind("0.0.0.0:{self.port}"):
            Err(e):
                print "Error: Failed to bind to port {self.port}: {e}"
                return
            Ok(listener):
                loop:
                    match listener.accept():
                        Ok(stream):
                            self.dash_handle_connection(stream)
                        Err(e):
                            print "Error accepting connection: {e}"

    # Named dash_* (not handle_connection/route_request) to avoid colliding
    # with LoginOnlyServer's identically-shaped methods in the interpreter's
    # method dispatch (verified empirically: same name+signature on a
    # different struct otherwise resolves to the wrong class's method body).
    fn dash_handle_connection(stream: TcpStream):
        match stream.read_line():
            Err(_):
                val _ = stream.close()
                return
            Ok(request_line):
                val parts = request_line.split(" ")
                if parts.len() < 2:
                    val _ = stream.write_text(http_error(400, "Bad Request"))
                    val _ = stream.close()
                    return
                val method = parts[0]
                val path = parts[1]

                var headers = ""
                var content_length = 0
                loop:
                    match stream.read_line():
                        Ok(header_line):
                            if header_line.trim() == "":
                                break
                            headers = "{headers}{header_line}\n"
                            if header_line.starts_with("Content-Length:"):
                                content_length = header_line[15:].trim().to_i64() ?? 0
                        Err(_):
                            break

                var body = ""
                if method == "POST" and content_length > 0:
                    match stream.read_bytes(content_length):
                        Ok(data):
                            body = data
                        Err(_):
                            pass_dn

                val response = self.dash_route_request(method, path, body, headers)
                val _ = stream.write_text(response)
                val _ = stream.close()

    # Auth-aware wrapper around route_http. Off by default (DASH_AUTH unset)
    # so localhost dev needs no login; set DASH_AUTH=1 to require the
    # web_login cookie session before any /agents or /api/ route resolves.
    fn dash_route_request(method: text, path: text, body: text, headers: text) -> text:
        if not _dash_auth_enabled():
            return self.route_http(method, path, body, "local-dev")

        val clean_path = _clean_path(path)
        val session = auth_session_from_headers(headers)

        if clean_path == "/login":
            return self.dash_handle_login(method, body, session)
        if clean_path == "/logout":
            if val active = session:
                auth_delete_session(active.session_id)
            return http_redirect_with_headers("/login", [auth_clear_cookie_header()])

        match session:
            case Some(active):
                self.route_http(method, path, body, active.session_id)
            case nil:
                http_redirect("/login")

    fn dash_handle_login(method: text, body: text, session: DashboardAuthSession?) -> text:
        if method == "GET":
            if session != nil:
                return http_redirect("/")
            return http_response(200, "text/html", auth_login_page("", ""))
        if method != "POST":
            return http_error(401, "Method not supported")
        val auth_result = auth_authenticate_form(body)
        if val auth_session = auth_result.0:
            return http_redirect_with_headers("/", [auth_login_cookie_header(auth_session)])
        http_response(401, "text/html", auth_login_page(auth_result.1, auth_result.2))

    fn render_dashboard_html() -> text:
        val panel = collect_llm_diagnostics_jsonl(self.diagnostics_path)
        val diagnostics_html = render_llm_diagnostics_panel_html(panel)
        val tooling_html = _render_tooling_panel_if_configured(self.tooling_source_path, self.tooling_target)
        val vllm_html = render_llm_dashboard_vllm_control_panel_html(collect_llm_dashboard_vllm_control_preflight(self.vllm_manifest_text))
        generate_full_dashboard_html_with_diagnostics_and_tooling(
            self.port,
            "<section id=\"status-card\">status</section>",
            "diagnostics@fixture",
            "<div id=\"tmux-card\">tmux</div>",
            "<span>admin</span><a href=\"/logout\">Log out</a>",
            diagnostics_html + vllm_html,
            tooling_html
        )

    fn route_http(method: text, path: text, body: text, session: text?) -> text:
        val clean_path = _clean_path(path)
        if not _session_authenticated(session):
            if _is_agents_path(clean_path):
                return http_redirect("/login")
            if path.starts_with("/api/"):
                return http_error(401, "Authentication required")
            return http_redirect("/login")
        if _is_agents_path(clean_path):
            if method != "GET":
                return http_error(401, "Method not supported")
            return http_response(200, "text/html", self.render_agents_html())
        if path.starts_with("/api/vllm/control"):
            if method != "GET":
                return http_error(401, "Method not supported")
            return http_response(200, "application/json", self._route_vllm_control(path))
        if path.starts_with("/api/tmux"):
            return http_response(200, "application/json", "[]")
        if method != "GET":
            return http_error(401, "Method not supported")
        http_response(200, "text/html", self.render_dashboard_html())

    fn render_agents_html() -> text:
        val snapshot = collect_assistant_snapshot_from_root(self.agent_dir)
        val view = assistant_dashboard_live_view_from_snapshot(snapshot, assistant_bridge_default_policy(), 0, 0, false)
        val lines = assistant_dashboard_render_live_view(view)
        var html = "<!doctype html><html><head><title>Agents</title></head><body><main id=\"agent-dashboard\"><h1>Agents</h1>"
        html = html + "<section id=\"agent-live-view\">"
        for line in lines:
            html = html + "<p>" + _html_escape(line) + "</p>"
        html = html + "</section></main></body></html>"
        html

    fn _route_vllm_control(path: text) -> text:
        val action = _query_value(path, "action")
        val pid = _query_i64(path, "pid", -1)
        val base_model = _query_value(path, "base_model")
        val fallback_base_model = _query_value(path, "base-model")
        val endpoint = _query_value(path, "endpoint")
        val vllm_available = _query_bool_either(path, "vllm_available", "vllm-available", true)
        val gpu_available = _query_bool_either(path, "gpu_available", "gpu-available", true)
        val selected_base_model = _selected_non_empty(base_model, fallback_base_model)
        val boundary_jsonl = llm_runtime_dashboard_live_boundary_jsonl(action, vllm_available, gpu_available)
        if _is_vllm_side_effect_action(action):
            val manifest = llm_runtime_manifest_from_text(_vllm_manifest_text_with_overrides(self.vllm_manifest_text, selected_base_model, endpoint))
            return boundary_jsonl + llm_runtime_execute_dashboard_control_jsonl(manifest, action, pid, vllm_available, gpu_available)
        if base_model.trim() != "":
            return boundary_jsonl + collect_llm_dashboard_vllm_control_action_with_overrides(self.vllm_manifest_text, action, pid, base_model, endpoint, vllm_available, gpu_available).evidence_jsonl
        boundary_jsonl + collect_llm_dashboard_vllm_control_action_with_overrides(self.vllm_manifest_text, action, pid, fallback_base_model, endpoint, vllm_available, gpu_available).evidence_jsonl

fn _render_tooling_panel_if_configured(path: text, target: text) -> text:
    if path.trim() == "":
        return ""
    render_llm_tooling_artifacts_panel_html(collect_llm_tooling_artifacts(path, target))

fn _clean_path(path: text) -> text:
    val parts = path.split("?")
    if parts.len() == 0:
        return path
    parts[0]

fn _is_agents_path(path: text) -> bool:
    path == "/agents" or path.starts_with("/agents/")

fn _session_authenticated(session: text?) -> bool:
    if session == nil:
        return false
    if val value = session:
        return value.trim() != ""
    false

fn _html_escape(value: text) -> text:
    var escaped = value.split("&").join("&amp;")
    escaped = escaped.split("<").join("&lt;")
    escaped = escaped.split(">").join("&gt;")
    escaped.split("\"").join("&quot;")

fn _query_value(path: text, key: text) -> text:
    val marker = key + "="
    val parts = path.split("?")
    if parts.len() < 2:
        return ""
    for raw in parts[1].split("&"):
        if raw.starts_with(marker):
            return raw.slice(marker.len(), raw.len())
    ""

fn _query_i64(path: text, key: text, fallback: i64) -> i64:
    val value = _query_value(path, key)
    if value.trim() == "":
        return fallback
    value.to_i64() ?? fallback

fn _query_bool(path: text, key: text, fallback: bool) -> bool:
    val value = _query_value(path, key).trim().to_lower()
    if value == "":
        return fallback
    value == "true" or value == "1" or value == "yes"

fn _query_bool_either(path: text, first: text, second: text, fallback: bool) -> bool:
    val first_value = _query_value(path, first)
    if first_value.trim() != "":
        return _query_bool(path, first, fallback)
    _query_bool(path, second, fallback)

fn _selected_non_empty(first: text, second: text) -> text:
    if first.trim() != "":
        return first
    second

fn _is_vllm_side_effect_action(action: text) -> bool:
    val normalized = action.trim().to_lower()
    normalized == "start" or normalized == "poll" or normalized == "probe" or normalized == "stop"

fn _vllm_manifest_text_with_overrides(manifest_text: text, base_model: text, endpoint: text) -> text:
    var out = manifest_text
    if base_model.trim() != "":
        out = out + "\nbase_model=" + base_model.trim()
    if endpoint.trim() != "":
        out = out + "\nendpoint=" + endpoint.trim()
    out
