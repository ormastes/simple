#![allow(unnamed_duplicate_typed_args)]
# Dashboard Web Server
#
# HTTP server for the main dashboard web interface.

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use app.dashboard.cache.{get_cached_data}
use std.json.builder.{escape_json}
use app.web_dashboard.dashboard_html.{generate_full_dashboard_html}
use app.llm_dashboard.web_login.{
    DashboardAuthSession,
    auth_ensure_bootstrap,
    auth_authenticate_form,
    auth_session_from_headers,
    auth_delete_session,
    auth_has_capability,
    auth_login_page,
    auth_login_cookie_header,
    auth_clear_cookie_header,
    auth_identity_html
}
use std.text.{to_int_or}
use dashboard.views.status.{render_status_html, render_vcs_state_html}
use app.llm_dashboard.data.store.{AgentDashboardStore}
use app.llm_dashboard.gui.html_views.{generate_agents_html, generate_agents_html_with_ios}
use app.llm_dashboard.gui.ws_handler.{handle_agents_ws}
use app.llm_dashboard.gui.tasks_api.{handle_tasks_api}
use lib.common.llm.output_gate.{OutputGate, filter_response_body}
use lib.common.privilege.authority_token.{AuthorityToken}

extern fn rt_bytes_to_text(data: [u8]) -> text

fn parse_request_line(request_line: text) -> (text, text):
    var method = ""
    var path = ""
    var idx = 0
    for part in request_line.split(" "):
        if idx == 0:
            method = part
        elif idx == 1:
            path = part
            break
        idx = idx + 1
    return (method, path)

# =========================================================================
# HTTP Server
# =========================================================================

class DashboardServer:
    port: i32
    auto_refresh_seconds: i32
    agent_watch_dir: text
    is_ios: bool

    static fn new(port: i32) -> DashboardServer:
        return DashboardServer {
            port: port,
            auto_refresh_seconds: 30,
            agent_watch_dir: "",
            is_ios: false
        }

    static fn new_with_agent_dir(port: i32, agent_watch_dir: text) -> DashboardServer:
        return DashboardServer {
            port: port,
            auto_refresh_seconds: 30,
            agent_watch_dir: agent_watch_dir,
            is_ios: false
        }

    static fn new_ios(port: i32, watch_dir: text) -> DashboardServer:
        return DashboardServer {
            port: port,
            auto_refresh_seconds: 30,
            agent_watch_dir: watch_dir,
            is_ios: true
        }

    fn start():
        print "Starting Dashboard Web Server on port {self.port}..."
        print "Open http://localhost:{self.port} in your browser"
        print "Press Ctrl+C to stop"
        print ""

        match TcpListener.bind("0.0.0.0:{self.port}"):
            Err(e):
                print "Error: Failed to bind to port {self.port}: {e}"
                return
            Ok(listener):
                self.serve_loop(listener)

    fn serve_loop(listener: TcpListener):
        loop:
            match listener.accept():
                Ok(stream):
                    self.handle_connection(stream)
                Err(e):
                    print "Error accepting connection: {e}"

    fn handle_connection(stream: TcpStream):
        match stream.read_line():
            Err(e):
                print "Error reading request: {e}"
            Ok(request_line):
                val request = parse_request_line(request_line)
                val method = request.0
                val path = request.1
                if method == "" or path == "":
                    val _ = stream.write_text(http_error(400, "Bad Request"))
                    val _ = stream.close()
                    return

                var headers = ""
                var is_ws = false
                var content_length = 0
                loop:
                    match stream.read_line():
                        Ok(header_line):
                            if header_line.trim() == "":
                                break
                            headers = "{headers}{header_line}\n"
                            if header_line.contains("Upgrade: websocket"):
                                is_ws = true
                            if header_line.starts_with("Content-Length:"):
                                val len_str = header_line[15:]
                                content_length = to_int_or(len_str.trim(), 0)
                        Err(_):
                            break

                var body = ""
                if (method == "POST" or method == "DELETE") and content_length > 0:
                    match stream.read_bytes(content_length):
                        Ok(data):
                            body = data
                        Err(_):
                            pass_dn

                val session = auth_session_from_headers(headers)

                if is_ws and path.starts_with("/ws/agents"):
                    if val active_session = session:
                        if not auth_has_capability(active_session, "dashboard.agents.view"):
                            val _ = stream.write_text(http_error(403, "Forbidden"))
                            val _ = stream.close()
                            return
                        val store = self.agent_store()
                        handle_agents_ws(stream, headers, store)
                        return
                    val _ = stream.write_text(http_error(401, "Authentication required"))
                    val _ = stream.close()
                    return

                if is_ws and path.starts_with("/ws/terminal"):
                    if val active_session = session:
                        if not auth_has_capability(active_session, "dashboard.terminal.use"):
                            val _ = stream.write_text(http_error(403, "Forbidden"))
                            val _ = stream.close()
                            return
                        val _ = stream.write_text(http_error(503, "Terminal websocket is unavailable in this runtime mode"))
                        val _ = stream.close()
                        return
                    val _ = stream.write_text(http_error(401, "Authentication required"))
                    val _ = stream.close()
                    return

                val response = self.route_request(method, path, body, headers)
                match stream.write_text(response):
                    Err(e):
                        print "Error writing response: {e}"
                    Ok(_):
                        pass_dn

                match stream.close():
                    Err(e):
                        print "Close error: {e}"
                    Ok(_):
                        pass_dn

    fn route_request(method: text, path: text, body: text, headers: text) -> text:
        val clean_path = _clean_path(path)

        # In iOS mode the WKWebView is the sole client; skip auth for agents page.
        if self.is_ios and (clean_path == "/agents" or clean_path.starts_with("/agents")):
            return self.serve_agents()

        val session = auth_session_from_headers(headers)

        if clean_path == "/login":
            return self.handle_login(method, body, session)

        if clean_path == "/logout":
            return self.handle_logout(session)

        if path.starts_with("/static/"):
            return self.serve_static(path)

        if session == nil:
            if clean_path.starts_with("/api/"):
                return http_error(401, "Authentication required")
            return http_redirect("/login")

        val required_capability = _required_capability(clean_path)
        if required_capability != "":
            if val active_session = session:
                if not auth_has_capability(active_session, required_capability):
                    if clean_path.starts_with("/api/"):
                        return http_error(403, "Forbidden")
                    return http_response(403, "text/html", "<h1>403 Forbidden</h1>")

        if path.starts_with("/api/tmux"):
            return http_error(503, "Tmux API is unavailable in this runtime mode")

        if path.starts_with("/api/tasks"):
            val tasks_result = handle_tasks_api(method, path, body)
            return http_response(tasks_result.0, tasks_result.1, tasks_result.2)

        if path.starts_with("/api/"):
            return self.handle_api(method, path)

        if clean_path == "/agents" or clean_path.starts_with("/agents"):
            return self.serve_agents()

        if val active_session = session:
            return self.serve_index(active_session)
        http_redirect("/login")

    fn handle_login(method: text, body: text, session: DashboardAuthSession?) -> text:
        if method == "GET":
            if session != nil:
                return http_redirect("/")
            return http_response(200, "text/html", auth_login_page("", ""))

        if method != "POST":
            return http_error(405, "Method Not Allowed")

        val auth_result = auth_authenticate_form(body)
        if val auth_session = auth_result.0:
            return http_redirect_with_headers("/", [auth_login_cookie_header(auth_session)])
        return http_response(401, "text/html", auth_login_page(auth_result.1, auth_result.2))

    fn handle_logout(session: DashboardAuthSession?) -> text:
        if val active = session:
            auth_delete_session(active.session_id)
        return http_redirect_with_headers("/login", [auth_clear_cookie_header()])

    fn handle_api(method: text, path: text) -> text:
        if method != "GET":
            return http_error(405, "Method Not Allowed")

        val clean_path = if path.contains("?"):
            path[0:path.index_of("?") ?? path.len()]
        else:
            path

        match clean_path:
            "/api/status":
                return self.api_status()
            "/api/features":
                return self.api_features()
            "/api/todos":
                return self.api_todos()
            "/api/coverage":
                return self.api_coverage()
            "/api/tests":
                return self.api_tests()
            "/api/trends":
                return self.api_trends()
            "/api/alerts":
                return self.api_alerts()
            "/api/vcs":
                return self.api_vcs()
            "/api/plans":
                return self.api_plans()
            _:
                return http_error(404, "Not Found")

    fn serve_index(session: DashboardAuthSession) -> text:
        var status_html = ""
        var vcs_html = "--"
        var tmux_card_html = ""

        match get_cached_data():
            Ok(data):
                status_html = render_status_html(data)
                vcs_html = render_vcs_state_html(data.vcs_state)
            Err(_):
                status_html = "<div class=\"empty-state\">No dashboard data. Run: simple dashboard collect</div>"

        val html = generate_full_dashboard_html(self.port, status_html, vcs_html, tmux_card_html, auth_identity_html(session))
        return http_response(200, "text/html", html)

    fn serve_agents() -> text:
        var store = self.agent_store()
        store.poll()
        val html = generate_agents_html_with_ios(store, self.is_ios)
        if self.is_ios:
            return http_response_with_headers(200, "text/html", html, ["Cache-Control: no-store"])
        return http_response(200, "text/html", html)

    fn serve_static(path: text) -> text:
        return http_error(404, "Not Found")

    fn agent_store() -> AgentDashboardStore:
        if self.agent_watch_dir != "":
            return AgentDashboardStore.with_dir(self.agent_watch_dir)
        return AgentDashboardStore.new()

    # =========================================================================
    # API Endpoints
    # =========================================================================

    fn api_status() -> text:
        match get_cached_data():
            Ok(data):
                var json = "{\n"
                json = "{json}  \"features_total\": {data.total_features()},\n"
                json = "{json}  \"features_complete\": {data.completed_features()},\n"
                json = "{json}  \"todos_total\": {data.total_todos()},\n"
                json = "{json}  \"todos_critical\": {data.critical_todos()},\n"
                json = "{json}  \"coverage_percent\": {data.overall_coverage()},\n"
                json = "{json}  \"sspec_tests\": {data.sspec_tests.len()},\n"
                json = "{json}  \"plans_total\": {data.plans.len()},\n"
                json = "{json}  \"timestamp\": \"{data.timestamp}\"\n"
                json = "{json}}"
                return http_response(200, "application/json", json)
            Err(e):
                return http_error(500, "Failed to load data: {e}")

    fn api_features() -> text:
        match get_cached_data():
            Ok(data):
                var parts: [text] = []
                parts.push("[\n")
                var i = 0
                while i < data.features.len():
                    val f = data.features[i]
                    parts.push("  {\n")
                    parts.push("    \"id\": {f.id},\n")
                    parts.push("    \"category\": \"{escape_json(f.category)}\",\n")
                    parts.push("    \"name\": \"{escape_json(f.name)}\",\n")
                    parts.push("    \"status\": \"{escape_json(f.status)}\"\n")
                    parts.push("  }")
                    if i < data.features.len() - 1:
                        parts.push(",")
                    parts.push("\n")
                    i = i + 1
                parts.push("]")
                return http_response(200, "application/json", parts.join(""))
            Err(e):
                return http_error(500, e)

    fn api_todos() -> text:
        match get_cached_data():
            Ok(data):
                var parts: [text] = []
                parts.push("[\n")
                var i = 0
                while i < data.todos.len():
                    val t = data.todos[i]
                    parts.push("  {\n")
                    parts.push("    \"id\": {t.id},\n")
                    parts.push("    \"priority\": \"{escape_json(t.priority)}\",\n")
                    parts.push("    \"area\": \"{escape_json(t.area)}\",\n")
                    parts.push("    \"description\": \"{escape_json(t.description)}\",\n")
                    parts.push("    \"file\": \"{escape_json(t.file)}\"\n")
                    parts.push("  }")
                    if i < data.todos.len() - 1:
                        parts.push(",")
                    parts.push("\n")
                    i = i + 1
                parts.push("]")
                return http_response(200, "application/json", parts.join(""))
            Err(e):
                return http_error(500, e)

    fn api_coverage() -> text:
        match get_cached_data():
            Ok(data):
                var parts: [text] = []
                parts.push("{\n")
                parts.push("  \"overall\": {data.overall_coverage()},\n")
                parts.push("  \"metrics\": [\n")
                var i = 0
                while i < data.coverage.len():
                    val c = data.coverage[i]
                    parts.push("    {\n")
                    parts.push("      \"level\": \"{escape_json(c.level)}\",\n")
                    parts.push("      \"crate\": \"{escape_json(c.crate)}\",\n")
                    parts.push("      \"percent\": {c.lines_percent}\n")
                    parts.push("    }")
                    if i < data.coverage.len() - 1:
                        parts.push(",")
                    parts.push("\n")
                    i = i + 1
                parts.push("  ]\n")
                parts.push("}")
                return http_response(200, "application/json", parts.join(""))
            Err(e):
                return http_error(500, e)

    fn api_tests() -> text:
        match get_cached_data():
            Ok(data):
                var passing = 0
                for test in data.sspec_tests:
                    if test.success_rate() == 100.0:
                        passing = passing + 1

                var json = "{\n"
                json = "{json}  \"total\": {data.sspec_tests.len()},\n"
                json = "{json}  \"passing\": {passing}\n"
                json = "{json}}"
                return http_response(200, "application/json", json)
            Err(e):
                return http_error(500, e)

    fn api_trends() -> text:
        var json = "{\n"
        json = "{json}  \"days\": 0,\n"
        json = "{json}  \"coverage\": {\n"
        json = "{json}    \"current\": 0.0,\n"
        json = "{json}    \"change\": 0.0,\n"
        json = "{json}    \"status\": \"unavailable\"\n"
        json = "{json}  },\n"
        json = "{json}  \"features\": {\n"
        json = "{json}    \"current\": 0.0,\n"
        json = "{json}    \"change\": 0.0,\n"
        json = "{json}    \"status\": \"unavailable\"\n"
        json = "{json}  }\n"
        json = "{json}}"
        return http_response(200, "application/json", json)

    fn api_alerts() -> text:
        return http_response(200, "application/json", "[]")

    fn api_vcs() -> text:
        match get_cached_data():
            Ok(data):
                var json = "{\n"
                json = "{json}  \"bookmark\": \"{escape_json(data.vcs_state.bookmark)}\",\n"
                json = "{json}  \"commit_id\": \"{escape_json(data.vcs_state.commit_id)}\",\n"
                json = "{json}  \"uncommitted\": {data.vcs_state.uncommitted_files},\n"
                json = "{json}  \"is_clean\": {data.vcs_state.is_clean()}\n"
                json = "{json}}"
                return http_response(200, "application/json", json)
            Err(e):
                return http_error(500, e)

    fn api_plans() -> text:
        match get_cached_data():
            Ok(data):
                var parts: [text] = []
                parts.push("[\n")
                var i = 0
                while i < data.plans.len():
                    val p = data.plans[i]
                    parts.push("  {\n")
                    parts.push("    \"id\": {p.id},\n")
                    parts.push("    \"title\": \"{escape_json(p.title)}\",\n")
                    parts.push("    \"status\": \"{escape_json(p.status)}\",\n")
                    parts.push("    \"progress\": {p.progress_percent()}\n")
                    parts.push("  }")
                    if i < data.plans.len() - 1:
                        parts.push(",")
                    parts.push("\n")
                    i = i + 1
                parts.push("]")
                return http_response(200, "application/json", parts.join(""))
            Err(e):
                return http_error(500, e)

# =========================================================================
# HTTP Helpers
# =========================================================================

fn http_response(status: i32, content_type: text, body: text) -> text:
    return http_response_with_headers(status, content_type, body, [])

# spm-winfs-llm-suite AC-5: route every response body through the LLM
# output gate before emitting it on the wire. Public token is used for
# anonymous routes; authenticated routes can call the gate themselves
# with their session token for tighter clearance.
fn _gate_response_body(body: text) -> text:
    val gate = OutputGate.default()
    val filtered = filter_response_body(gate, body.bytes(), AuthorityToken.public())
    rt_bytes_to_text(filtered.bytes)

fn http_response_with_headers(status: i32, content_type: text, body: text, extra_headers: [text]) -> text:
    val gated_body = _gate_response_body(body)
    val status_text = match status:
        200: "OK"
        201: "Created"
        302: "Found"
        400: "Bad Request"
        401: "Unauthorized"
        403: "Forbidden"
        404: "Not Found"
        405: "Method Not Allowed"
        500: "Internal Server Error"
        503: "Service Unavailable"
        _: "Unknown"

    var response = "HTTP/1.1 {status} {status_text}\r\n"
    response = "{response}Content-Type: {content_type}\r\n"
    response = "{response}Content-Length: {gated_body.len()}\r\n"
    for header in extra_headers:
        response = "{response}{header}\r\n"
    response = "{response}Access-Control-Allow-Origin: *\r\n"
    response = "{response}Connection: close\r\n"
    response = "{response}\r\n"
    response = "{response}{gated_body}"
    return response

fn http_redirect(location: text) -> text:
    return http_redirect_with_headers(location, [])

fn http_redirect_with_headers(location: text, extra_headers: [text]) -> text:
    var headers = ["Location: {location}"]
    for header in extra_headers:
        headers.push(header)
    return http_response_with_headers(302, "text/plain", "", headers)

fn http_error(status: i32, message: text) -> text:
    val body = "{\"error\": \"{escape_json(message)}\"}"
    return http_response(status, "application/json", body)

fn _clean_path(path: text) -> text:
    if path.contains("?"):
        return path[0:path.index_of("?") ?? path.len()]
    path

fn _required_capability(clean_path: text) -> text:
    if clean_path == "/" or clean_path == "":
        return "dashboard.view"
    if clean_path == "/agents" or clean_path.starts_with("/agents/"):
        return "dashboard.agents.view"
    if clean_path.starts_with("/api/tasks"):
        return "dashboard.tasks.view"
    if clean_path.starts_with("/api/tmux"):
        return "dashboard.tmux.use"
    if clean_path.starts_with("/api/"):
        return "dashboard.view"
    "dashboard.view"
