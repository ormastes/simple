pub fn generate_full_dashboard_html(port: i64, status_html: text, revision: text, tmux_html: text, identity_html: text) -> text:
    generate_full_dashboard_html_with_diagnostics(port, status_html, revision, tmux_html, identity_html, "")

pub fn generate_full_dashboard_html_with_diagnostics(port: i64, status_html: text, revision: text, tmux_html: text, identity_html: text, diagnostics_html: text) -> text:
    generate_full_dashboard_html_with_diagnostics_and_tooling(port, status_html, revision, tmux_html, identity_html, diagnostics_html, "")

pub fn generate_full_dashboard_html_with_diagnostics_and_tooling(port: i64, status_html: text, revision: text, tmux_html: text, identity_html: text, diagnostics_html: text, tooling_html: text) -> text:
    var html = "<!DOCTYPE html>\n"
    val has_tooling = tooling_html.trim() != ""
    html = html + "<html lang=\"en\"><head>"
    html = html + "<meta charset=\"utf-8\">"
    html = html + "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">"
    html = html + "<link rel=\"icon\" href=\"data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230A84FF'/%3E%3Crect x='7' y='9' width='18' height='12' rx='2' fill='white'/%3E%3Crect x='11' y='23' width='10' height='2' rx='1' fill='white'/%3E%3C/svg%3E\">"
    html = html + "<title>Simple Compiler Dashboard</title>"
    html = html + "<style>.view{{display:none}}.view.active{{display:block}}.header-identity{{float:right}}.noscript-banner{{background:#3a2f00;color:#ffd479;padding:8px 12px;font-size:0.85rem;text-align:center}}</style>"
    html = html + "<script>"
    html = html + "function switchView(name, el){{document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));document.getElementById('view-'+name).classList.add('active');}}"
    html = html + "function refreshTmux(){{fetch('/api/tmux/sessions');fetch('/api/tmux/windows?session=main');fetch('/api/tmux/panes?session=main&window=0');fetch('/api/tmux/capture?session=main&window=0&pane=0');}}"
    html = html + "function openTerminal(){{return '/ws/terminal?session=';}}"
    html = html + "function sendCommand(){{return fetch('/api/tmux/send-command',{{method:'POST'}});}}"
    html = html + "setTimeout(() => location.reload(), 30000);"
    html = html + "</script></head><body>"
    html = html + "<noscript><div class=\"noscript-banner\">JavaScript is disabled: tab switching and terminal/tmux refresh need it. This page is server-rendered and stays readable without it.</div></noscript>"
    html = html + "<header><h1>Simple Dashboard</h1><div class=\"header-identity\">" + identity_html + "</div></header>"
    html = html + "<nav><button onclick=\"switchView('status', this)\">Status</button><button onclick=\"switchView('terminal', this)\">Terminal</button><button onclick=\"switchView('diagnostics', this)\">Diagnostics</button>"
    if has_tooling:
        html = html + "<button onclick=\"switchView('tooling', this)\">Tooling</button>"
    html = html + "<button onclick=\"switchView('gui', this)\">GUI</button><button onclick=\"window.location='/agents'\">Agents</button><button onclick=\"window.location='/agents/full'\">Agent Dashboard</button></nav>"
    html = html + "<main>"
    html = html + "<div id=\"view-status\" class=\"view active\">" + status_html + "</div>"
    html = html + "<div id=\"view-terminal\" class=\"view\">" + tmux_html + "<button class=\"send-command\">Send</button></div>"
    html = html + "<div id=\"view-diagnostics\" class=\"view\">" + diagnostics_html + "</div>"
    if has_tooling:
        html = html + "<div id=\"view-tooling\" class=\"view\">" + tooling_html + "</div>"
    html = html + "<div id=\"view-gui\" class=\"view\"><p>GUI surface on port " + str(port) + "</p><p>" + revision + "</p></div>"
    html = html + "</main></body></html>"
    html
