# Chromium Shell DevTools — Live DOM Mirror (V3 simple_browser shell — M10)
#
# Milestone M10 of Row 5 requires surfacing `examples/browser/devtools_panel.spl`
# against a live `DesktopShell` window so V3 paint issues can be debugged.
# The acceptance criteria are:
#
#   - [ ] DevTools panel renders the live DOM tree.
#   - [ ] CSS inspector shows computed styles.
#   - [ ] No requirement for Chrome DevTools Protocol parity.
#
# This module owns the *live DOM mirror* side of that contract: a plain,
# order-preserving tree of nodes with enough metadata for the DevTools panel
# to render a collapsible DOM view. It is deliberately a pure in-memory data
# structure with no FFI, no compositor bring-up, and no Chrome DevTools
# Protocol parity — the `ChromiumApp` render loop (or a test harness) is
# expected to feed snapshots into the mirror on every repaint, and the panel
# reads them back through `DevToolsAttachSession` (see `attach_session.spl`).
#
# Node semantics mirror a DOM subset large enough for the devtools tree view:
#   - `id`        — stable identity across snapshots (monotonic from the shell)
#   - `tag`       — element tag (e.g. "div"), or "#text" for text nodes
#   - `text`      — text payload for text nodes / attribute summary for elements
#   - `depth`     — indentation depth in the flattened tree listing
#   - `child_ids` — ordered child identities, resolved via `find_by_id`
#
# No inheritance: `DevToolsDomMirror` composes `DevToolsDomNode` values in a
# flat `[DevToolsDomNode]` so iteration, find-by-id, and flattened listing
# are all O(n) scans — cheap enough for devtools and trivially testable.

# =========================================================================
# DevToolsDomNode
# =========================================================================

class DevToolsDomNode:
    """One node in the live DOM mirror.

    The mirror is intentionally flat: instead of a recursive node-with-
    children structure (which the compile pipeline still has rough edges
    around for self-referential classes), children are tracked as an
    ordered `[i64]` of child ids and resolved on demand via
    `DevToolsDomMirror.find_by_id`. `depth` lets the devtools panel render
    a flattened, indented tree view without walking the structure.
    """
    id: i64
    tag: text
    text_value: text
    depth: i32
    child_ids: [i64]

impl DevToolsDomNode:

    static fn new_element(id: i64, tag: text, depth: i32) -> DevToolsDomNode:
        """Create an element node with no children yet."""
        DevToolsDomNode(
            id: id,
            tag: tag,
            text_value: "",
            depth: depth,
            child_ids: []
        )

    static fn new_text(id: i64, text_value: text, depth: i32) -> DevToolsDomNode:
        """Create a text node. The tag is the synthetic `#text` marker so
        the devtools panel can distinguish it from elements without an
        extra enum."""
        DevToolsDomNode(
            id: id,
            tag: "#text",
            text_value: text_value,
            depth: depth,
            child_ids: []
        )

    fn is_text() -> bool:
        """Return true for text nodes, false for elements."""
        self.tag == "#text"

    fn child_count() -> i32:
        self.child_ids.len().to_i32()

    me add_child(child_id: i64):
        """Append a child id to the ordered child list."""
        self.child_ids = self.child_ids + [child_id]

    me set_text(value: text):
        """Replace the text payload (used when an element summarises its
        attributes or a text node is updated in place)."""
        self.text_value = value

    fn display_label() -> text:
        """Return a short human-readable label for the devtools tree view.

        For elements the label is `<tag>` (with attribute summary appended
        when non-empty); for text nodes it is the text payload truncated
        by the caller if needed.
        """
        if self.is_text():
            self.text_value
        else:
            if self.text_value == "":
                "<" + self.tag + ">"
            else:
                "<" + self.tag + " " + self.text_value + ">"

# =========================================================================
# DevToolsDomMirror
# =========================================================================

class DevToolsDomMirror:
    """Flat, order-preserving mirror of the live DOM tree.

    The mirror is *snapshot-driven*: the chromium shell rebuilds it on
    every repaint via `clear` + a sequence of `push_element` / `push_text`
    calls. The devtools panel reads it through `nodes()`, `find_by_id`,
    and `flattened()` so it can render an indented tree view without
    knowing about the chromium shell internals.

    `root_id` is the id of the first pushed node and is -1 on an empty
    mirror.
    """
    nodes_list: [DevToolsDomNode]
    root_id: i64
    next_id: i64

impl DevToolsDomMirror:

    static fn new() -> DevToolsDomMirror:
        DevToolsDomMirror(
            nodes_list: [],
            root_id: -1,
            next_id: 1
        )

    fn count() -> i32:
        self.nodes_list.len().to_i32()

    fn is_empty() -> bool:
        self.nodes_list.len() == 0

    fn root_id_of() -> i64:
        self.root_id

    fn nodes() -> [DevToolsDomNode]:
        """Return the underlying node list in push order."""
        self.nodes_list

    me clear():
        """Drop every node and reset the id counter. The chromium shell
        calls this at the start of a fresh snapshot pass."""
        self.nodes_list = []
        self.root_id = -1
        self.next_id = 1

    me push_element(tag: text, depth: i32) -> i64:
        """Append a fresh element node and return its id. The first node
        pushed on an empty mirror also becomes the root."""
        val id = self.next_id
        self.next_id = self.next_id + 1
        val node = DevToolsDomNode.new_element(id, tag, depth)
        self.nodes_list = self.nodes_list + [node]
        if self.root_id == -1:
            self.root_id = id
        id

    me push_text(value: text, depth: i32) -> i64:
        """Append a fresh text node and return its id."""
        val id = self.next_id
        self.next_id = self.next_id + 1
        val node = DevToolsDomNode.new_text(id, value, depth)
        self.nodes_list = self.nodes_list + [node]
        if self.root_id == -1:
            self.root_id = id
        id

    me attach_child(parent_id: i64, child_id: i64) -> bool:
        """Record `child_id` as a child of `parent_id`.

        Returns false if the parent is not in the mirror. The child is
        not required to exist yet — devtools occasionally replays a
        snapshot before the child is pushed.
        """
        var i: i32 = 0
        val n = self.nodes_list.len().to_i32()
        while i < n:
            val node = self.nodes_list[i]
            if node.id == parent_id:
                node.add_child(child_id)
                return true
            i = i + 1
        false

    fn find_by_id(id: i64) -> i32:
        """Return the index of the node with `id`, or -1 if not present."""
        var i: i32 = 0
        val n = self.nodes_list.len().to_i32()
        while i < n:
            if self.nodes_list[i].id == id:
                return i
            i = i + 1
        -1

    fn has_node(id: i64) -> bool:
        self.find_by_id(id) >= 0

    fn node_at(idx: i32) -> DevToolsDomNode:
        """Return the node at `idx`. Caller must ensure `idx < count()`."""
        self.nodes_list[idx]

    fn max_depth() -> i32:
        """Return the deepest `depth` value in the mirror, or 0 if empty.

        The devtools panel uses this to size the tree column."""
        var d: i32 = 0
        var i: i32 = 0
        val n = self.nodes_list.len().to_i32()
        while i < n:
            val nd = self.nodes_list[i].depth
            if nd > d:
                d = nd
            i = i + 1
        d

    fn flattened_labels() -> [text]:
        """Return the node labels in push order — the devtools panel uses
        this to render the DOM tree column without a recursive walk."""
        var out: [text] = []
        var i: i32 = 0
        val n = self.nodes_list.len().to_i32()
        while i < n:
            out = out + [self.nodes_list[i].display_label()]
            i = i + 1
        out
