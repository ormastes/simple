# Office Plugin Registration
#
# Registers the Office apps as separate plugins layered on the shared Markdown,
# CSS/HTML, and SDN substrates. Each plugin declares the headless actions it
# contributes, using the same registry manifest format as the IDE adapter.

use app.plugin.registry.{PluginEntry, plugin_entry_new, plugin_manifest_to_text, parse_plugin_manifest_text}
use app.office.llm_catalog.{office_llm_feature_catalog}

# A snapshot of the office plugin manifest for verification / display.
struct OfficePluginProbe:
    plugin_count: i32
    round_trip_ok: bool
    manifest_text: text

fn office_plugin_entries() -> [PluginEntry]:
    """Office apps as separate plugins on the shared document/design substrates."""
    var entries: [PluginEntry] = []
    for row in office_llm_feature_catalog():
        entries.push(plugin_entry_new(
            "office-" + row.app_name.lower(),
            row.owner_module,
            "0.1.0",
            row.actions))
    entries

fn office_plugin_names() -> [text]:
    """The registered office plugin names."""
    var names: [text] = []
    for e in office_plugin_entries():
        names.push(e.name)
    names

fn office_plugin_manifest_probe() -> OfficePluginProbe:
    """Serialize the office plugin entries to manifest text and parse them back,
    proving the manifest round-trips through the shared registry format."""
    val entries = office_plugin_entries()
    val manifest = plugin_manifest_to_text(entries)
    val parsed = parse_plugin_manifest_text(manifest)
    OfficePluginProbe(
        plugin_count: parsed.len(),
        round_trip_ok: parsed.len() == entries.len(),
        manifest_text: manifest)

fn office_plugin_validate(entries: [PluginEntry]) -> text:
    """Return a non-empty error message if the manifest is malformed, else ""."""
    var seen: [text] = []
    var seen_functions: [text] = []
    for entry in entries:
        if entry.name == "":
            return "manifest error: entry with empty name"
        if entry.library == "":
            return "manifest error: entry '" + entry.name + "' has empty library"
        if entry.version == "":
            return "manifest error: entry '" + entry.name + "' has empty version"
        for s in seen:
            if s == entry.name:
                return "manifest error: duplicate plugin name '" + entry.name + "'"
        seen.push(entry.name)
        if entry.functions.len() == 0:
            return "manifest error: entry '" + entry.name + "' has no functions"
        for function_name in entry.functions:
            if function_name == "":
                return "manifest error: entry '" + entry.name + "' has empty function"
            for seen_function in seen_functions:
                if seen_function == function_name:
                    return "manifest error: duplicate function '" + function_name + "'"
            seen_functions.push(function_name)
    ""

fn office_plugin_is_valid() -> bool:
    """Whether the office plugin manifest is well-formed."""
    office_plugin_validate(office_plugin_entries()) == ""
