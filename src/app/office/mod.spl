fn office_catalog_dispatch_probe() -> OfficeCatalogDispatchProbe:
    var advertised_count = 0
    var recognized_count = 0
    var missing_actions: [text] = []
    for row in office_llm_feature_catalog():
        for action in row.actions:
            advertised_count = advertised_count + 1
            val context = office_plugin_context(action, row.component, row.source_format, row.evidence_key)
            val result = office_action_dispatch_with_context(context, "")
            if result.reason == "unknown-action" or result.reason == "context-mismatch" or result.reason == "source-format-mismatch":
                missing_actions.push(action)
            else:
                recognized_count = recognized_count + 1
    OfficeCatalogDispatchProbe(advertised_count: advertised_count, recognized_count: recognized_count, missing_actions: missing_actions)

fn _run_writer_markdown_command() -> i32:
    val view = build_wysiwyg_view("# Untitled")
    print "LibreOffice Writer Markdown loaded (lines={wysiwyg_line_count(view)}, source=markdown, render=html)"
    0

fn _office_action_writer_markdown_summary(source: text) -> text:
    val view = build_wysiwyg_view(source)
    "source=markdown\nformat=Writer Markdown\nlines=" + wysiwyg_line_count(view).to_text() + "\nrender=html"

fn _office_action_writer_markdown_stats(source: text) -> text:
    val view = build_wysiwyg_view(source)
    "lines=" + wysiwyg_line_count(view).to_text() + "\nblocks=" + _office_action_writer_markdown_block_count(source).to_text() + "\nheadings=" + _office_action_writer_markdown_heading_count(source).to_text() + "\nwords=" + _office_action_writer_markdown_word_count(source).to_text()

fn _office_action_writer_markdown_search(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val query = parts[0].trim()
    if query == "":
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-search", output: "", reason: "invalid-args")
    var out: [text] = []
    var line_no = 0
    for line in parts[1].split("\n"):
        val column = line.index_of(query)
        if column >= 0:
            out.push(line_no.to_text() + "|" + column.to_text() + "|" + _office_action_escape_piped_field(line.trim()))
        line_no = line_no + 1
    OfficeActionResult(ok: true, code: 0, action: "writer-markdown-search", output: out.join("\n"), reason: "listed")

fn _office_action_writer_markdown_range(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val fields = parts[0].split("|")
    if fields.len() != 2 or not _is_office_cli_non_negative_i32_token(fields[0].trim()) or not _is_office_cli_non_negative_i32_token(fields[1].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-range", output: "", reason: "invalid-args")
    val start = fields[0].trim().to_i64()
    val count = fields[1].trim().to_i64()
    val lines = parts[1].split("\n")
    if start > lines.len():
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-range", output: "", reason: "invalid-args")
    var out: [text] = []
    var i = start
    val end = start + count
    while i < end and i < lines.len():
        out.push(i.to_text() + "|" + _office_action_escape_piped_field(lines[i]))
        i = i + 1
    OfficeActionResult(ok: true, code: 0, action: "writer-markdown-range", output: out.join("\n"), reason: "listed")

fn _office_action_writer_markdown_blocks(source: text) -> text:
    var out: [text] = []
    var index = 0
    for block in parse_markdown_blocks(source):
        out.push(index.to_text() + "|" + block.from_line.to_text() + "|" + block.to_line.to_text() + "|" + block.kind + "|" + _office_action_escape_piped_field(block.content.trim()))
        index = index + 1
    out.join("\n")

fn _office_action_writer_markdown_tables(source: text) -> text:
    var out: [text] = []
    var index = 0
    for block in parse_markdown_blocks(source):
        if block.kind == "table":
            out.push(index.to_text() + "|" + block.from_line.to_text() + "|" + block.to_line.to_text() + "|" + _office_action_escape_piped_field(block.content.trim()))
            index = index + 1
    out.join("\n")

fn _office_action_writer_markdown_replace(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val fields = _office_action_split_piped_args(parts[0])
    if fields.len() != 2 or fields[0].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-replace", output: "", reason: "invalid-args")
    OfficeActionResult(ok: true, code: 0, action: "writer-markdown-replace", output: parts[1].replace(fields[0].trim(), fields[1]), reason: "updated")

fn _office_action_writer_markdown_insert(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val fields = _office_action_split_piped_args(parts[0])
    if fields.len() != 2 or not _is_office_cli_non_negative_i32_token(fields[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-insert", output: "", reason: "invalid-args")
    val line_no = fields[0].trim().to_i64()
    val lines = parts[1].split("\n")
    if line_no > lines.len():
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-insert", output: "", reason: "invalid-args")
    var out: [text] = []
    var i = 0
    while i < line_no:
        out.push(lines[i])
        i = i + 1
    out.push(fields[1])
    while i < lines.len():
        out.push(lines[i])
        i = i + 1
    OfficeActionResult(ok: true, code: 0, action: "writer-markdown-insert", output: out.join("\n"), reason: "updated")

fn _office_action_writer_markdown_delete(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    if not _is_office_cli_non_negative_i32_token(parts[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-delete", output: "", reason: "invalid-args")
    val line_no = parts[0].trim().to_i64()
    val lines = parts[1].split("\n")
    if line_no >= lines.len():
        return OfficeActionResult(ok: false, code: 1, action: "writer-markdown-delete", output: "", reason: "invalid-args")
    var out: [text] = []
    var i = 0
    while i < lines.len():
        if i != line_no:
            out.push(lines[i])
        i = i + 1
    OfficeActionResult(ok: true, code: 0, action: "writer-markdown-delete", output: out.join("\n"), reason: "updated")

fn _office_action_writer_markdown_block_count(source: text) -> i64:
    var count = 0
    var in_block = false
    for line in source.split("\n"):
        if line.trim() == "":
            in_block = false
        elif not in_block:
            count = count + 1
            in_block = true
    count

fn _office_action_writer_markdown_heading_count(source: text) -> i64:
    val outline = _office_action_writer_markdown_outline(source)
    if outline == "":
        return 0
    outline.split("\n").len()

fn _office_action_writer_markdown_word_count(source: text) -> i64:
    var count = 0
    var in_fence = false
    for line in source.split("\n"):
        val trimmed = line.trim()
        if markdown_is_code_fence(trimmed):
            in_fence = not in_fence
        else:
            var text_line = trimmed
            if not in_fence and trimmed.starts_with("#"):
                var level = 0
                while level < trimmed.len() and level < 6 and trimmed.char_at(level) == "#":
                    level = level + 1
                if level > 0 and level < trimmed.len() and trimmed.char_at(level) == " ":
                    text_line = trimmed.substring(level + 1).trim()
            for token in text_line.replace("\t", " ").split(" "):
                if token.trim() != "":
                    count = count + 1
    count

fn _office_action_writer_markdown_outline(source: text) -> text:
    var out: [text] = []
    var line_no = 0
    var in_fence = false
    for line in source.split("\n"):
        val trimmed = line.trim()
        if markdown_is_code_fence(trimmed):
            in_fence = not in_fence
        elif not in_fence and trimmed.starts_with("#"):
            var level = 0
            while level < trimmed.len() and level < 6 and trimmed.char_at(level) == "#":
                level = level + 1
            if level > 0 and level < trimmed.len() and trimmed.char_at(level) == " ":
                val title = trimmed.substring(level + 1).trim()
                if title != "":
                    out.push(line_no.to_text() + "|" + level.to_text() + "|" + title)
        line_no = line_no + 1
    out.join("\n")

fn _office_action_ppt_markdown_outline(source: text) -> text:
    var out: [text] = []
    var line_no = 0
    var slide_no = 0
    var in_fence = false
    for line in source.split("\n"):
        val trimmed = line.trim()
        if markdown_is_code_fence(trimmed):
            in_fence = not in_fence
        elif not in_fence and trimmed.starts_with("## "):
            slide_no = slide_no + 1
            val title = trimmed.substring(3).trim()
            if title != "":
                out.push(slide_no.to_text() + "|" + line_no.to_text() + "|" + title)
        line_no = line_no + 1
    out.join("\n")

fn _office_action_split_edit_source(source: text) -> [text]:
    val lines = source.split("\n")
    if lines.len() == 0:
        return ["", ""]
    var body: [text] = []
    var i = 1
    while i < lines.len():
        body.push(lines[i])
        i = i + 1
    [lines[0], body.join("\n")]

fn _office_action_split_piped_args(value: text) -> [text]:
    var args: [text] = []
    var current = ""
    var escaped = false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if escaped:
            if ch == "|" or ch == "\\":
                current = current + ch
            else:
                current = current + "\\" + ch
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "|":
            args.push(current)
            current = ""
        else:
            current = current + ch
        i = i + 1
    if escaped:
        current = current + "\\"
    args.push(current)
    args

fn _office_action_escape_piped_field(value: text) -> text:
    val escaped_slash = value.replace("\\", "\\\\")
    escaped_slash.replace("|", "\\|")

fn _office_action_split_ids(value: text) -> [text]:
    var ids: [text] = []
    for raw in value.split(","):
        val id = raw.trim()
        if id != "":
            ids.push(id)
    ids

fn _office_action_ids_are_safe(ids: [text]) -> bool:
    for id in ids:
        if not _is_office_cli_safe_style_token(id):
            return false
    true

fn _office_action_layout_mode_is_safe(kind: text, mode: text) -> bool:
    val trimmed = mode.trim()
    if kind == "align":
        return trimmed == "left" or trimmed == "center" or trimmed == "right" or trimmed == "top" or trimmed == "middle" or trimmed == "bottom"
    trimmed == "horizontal" or trimmed == "vertical"

fn _office_action_render_sdd_html_with_selection(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    if parts[0].starts_with("select|"):
        val args = parts[0].split("|")
        if args.len() != 3:
            return OfficeActionResult(ok: false, code: 1, action: "render-sdd-html-with-selection", output: "", reason: "invalid-args")
        val node_id = args[1].trim()
        val edge_index_text = args[2].trim()
        if node_id != "" and not _is_office_cli_safe_style_token(node_id):
            return OfficeActionResult(ok: false, code: 1, action: "render-sdd-html-with-selection", output: "", reason: "invalid-args")
        if edge_index_text != "" and not _is_office_cli_non_negative_i32_token(edge_index_text):
            return OfficeActionResult(ok: false, code: 1, action: "render-sdd-html-with-selection", output: "", reason: "invalid-args")
        val edge_index = if edge_index_text == "" then -1 else: edge_index_text.to_i64()
        return OfficeActionResult(ok: true, code: 0, action: "render-sdd-html-with-selection", output: sdn_graph_render_html_with_selection(sdn_graph_parse(parts[1]), node_id, edge_index), reason: "rendered")
    OfficeActionResult(ok: true, code: 0, action: "render-sdd-html-with-selection", output: sdn_graph_render_html_with_selection(sdn_graph_parse(source), "", -1), reason: "rendered")

fn _office_action_render_ui_html_with_selection(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    if parts[0].starts_with("select|"):
        val args = parts[0].split("|")
        if args.len() != 2:
            return OfficeActionResult(ok: false, code: 1, action: "render-ui-html-with-selection", output: "", reason: "invalid-args")
        val node_id = args[1].trim()
        if node_id != "" and not _is_office_cli_safe_style_token(node_id):
            return OfficeActionResult(ok: false, code: 1, action: "render-ui-html-with-selection", output: "", reason: "invalid-args")
        return OfficeActionResult(ok: true, code: 0, action: "render-ui-html-with-selection", output: office_ui_design_render_html_with_selection(office_ui_design_parse(parts[1]), node_id), reason: "rendered")
    OfficeActionResult(ok: true, code: 0, action: "render-ui-html-with-selection", output: office_ui_design_render_html_with_selection(office_ui_design_parse(source), ""), reason: "rendered")

fn _office_action_md_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    if args.len() != 3 or not _is_office_cli_non_negative_i32_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "md-edit", output: "", reason: "invalid-args")
    val result = wysiwyg_update_line_checked(build_wysiwyg_view(parts[1]), args[0].trim().to_i32(), args[1], args[2])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "md-edit", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "md-edit", output: wysiwyg_source_pane(result.view), reason: result.reason)

fn _office_action_sheet_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    if args.len() != 3 or args[0].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: "", reason: "invalid-args")
    val source_error = _sheet_cli_source_error(parts[1])
    if source_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: "", reason: source_error)
    val sheet = _load_sheet_cli_source(parts[1])
    val result = sheet.update_cell_checked(args[0].trim(), args[1], args[2])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "sheet-edit", output: result.cell_ref + "=" + result.new_value, reason: result.reason)

fn _office_action_format_cell_value(source: text) -> OfficeActionResult:
    val args = _office_action_split_piped_args(source)
    if args.len() != 2 or not _is_office_cli_decimal_token(args[0].trim()) or args[1].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "format-cell-value", output: "", reason: "invalid-args")
    OfficeActionResult(ok: true, code: 0, action: "format-cell-value", output: apply_cell_format(office_parse_signed_decimal_f64(args[0].trim()), args[1].trim()), reason: "formatted")

fn _office_action_evaluate_sheet_formula(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val formula = parts[0].trim()
    if formula == "":
        return OfficeActionResult(ok: false, code: 1, action: "evaluate-sheet-formula", output: "", reason: "invalid-args")
    val source_error = _sheet_cli_source_error(parts[1])
    if source_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "evaluate-sheet-formula", output: "", reason: source_error)
    val result = evaluate_formula_display_text_checked(formula, _load_sheet_cli_source(parts[1]))
    if not result.ok:
        return OfficeActionResult(ok: false, code: 1, action: "evaluate-sheet-formula", output: "", reason: "unsupported-formula")
    OfficeActionResult(ok: true, code: 0, action: "evaluate-sheet-formula", output: result.value, reason: "evaluated")

fn _office_action_slide_edit(source: text) -> OfficeActionResult:
