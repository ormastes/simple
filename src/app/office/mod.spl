fn _office_sdd_layers_summary(graph: SdnGraph) -> text:
    var lines: [text] = []
    var index = 0
    for node in graph.nodes:
        lines.push("index=" + index.to_text() + " id=" + node.id + " label=" + node.label + " role=" + node.role + " shape=" + node.shape + " layer=" + node.layer + " z_index=" + _office_sdd_layer_z_index(node.layer) + " parent=" + node.parent)
        index = index + 1
    lines.join("\n")

fn _office_sdd_layer_z_index(layer: text) -> text:
    val normalized = layer.trim().to_lower()
    if normalized == "":
        return ""
    if normalized == "background" or normalized == "back":
        return "0"
    if normalized == "base" or normalized == "default":
        return "10"
    if normalized == "controls" or normalized == "ui" or normalized == "middle":
        return "20"
    if normalized == "front" or normalized == "foreground" or normalized == "overlay":
        return "30"
    "20"

fn _run_office_action_command(args: [text]) -> i32:
    if args.len() != 2:
        print "Usage: simple office " + args[0] + " <source>"
        return 1
    val result = office_action_dispatch(args[0], args[1])
    if result.ok:
        print result.output
        return result.code
    print "office-action: rejected (" + result.reason + ")"
    if result.output != "":
        print result.output
    return result.code

fn _is_office_cli_non_negative_i32_token(value: text) -> bool:
    if value.len() == 0:
        return false
    if value.len() > 10:
        return false
    var i = 0
    while i < value.len():
        val c = value.char_at(i)
        val code = c.char_code_at(0)
        if code < 48 or code > 57:
            return false
        i = i + 1
    if value.len() == 10 and value > "2147483647":
        return false
    true

fn _is_office_cli_signed_i64_token(value: text) -> bool:
    if value.len() == 0:
        return false
    var start = 0
    if value.starts_with("-"):
        if value.len() == 1:
            return false
        start = 1
    val digits = value.slice(start, value.len())
    if digits.len() > 19:
        return false
    if digits.len() == 19:
        val limit = if start == 1 then "9223372036854775808" else: "9223372036854775807"
        if digits > limit:
            return false
    var i = start
    while i < value.len():
        val c = value.char_at(i)
        val code = c.char_code_at(0)
        if code < 48 or code > 57:
            return false
        i = i + 1
    true

fn _is_office_cli_decimal_token(value: text) -> bool:
    if value.len() == 0:
        return false
    var start = 0
    if value.starts_with("-"):
        if value.len() == 1:
            return false
        start = 1
    var dots = 0
    var digits = 0
    var i = start
    while i < value.len():
        val c = value.char_at(i)
        val code = c.char_code_at(0)
        if c == ".":
            dots = dots + 1
            if dots > 1:
                return false
        elif code >= 48 and code <= 57:
            digits = digits + 1
        else:
            return false
        i = i + 1
    digits > 0

fn _is_office_cli_sdd_route_token(value: text) -> bool:
    value == "" or value == "simple" or value == "orthogonal"

fn _is_office_cli_sdd_anchor_token(value: text) -> bool:
    value == "" or value == "left" or value == "right" or value == "top" or value == "bottom"

fn _is_office_cli_sdd_waypoints_token(value: text) -> bool:
    if value.trim() == "":
        return true
    for raw in value.split(";"):
        val waypoint = raw.trim()
        val parts = waypoint.split("x")
        if parts.len() != 2 or not _is_office_cli_signed_i64_token(parts[0].trim()) or not _is_office_cli_signed_i64_token(parts[1].trim()):
            return false
    true

fn _is_office_cli_sdd_canvas_number_token(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "" or trimmed.len() > 9:
        return false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    true

fn _is_office_cli_ui_layout_mode_token(value: text) -> bool:
    value == "off" or value == "horizontal" or value == "vertical"

fn _is_office_cli_ui_padding_token(value: text) -> bool:
    val parts = value.split(",")
    if parts.len() != 4:
        return false
    for part in parts:
        if not _is_office_cli_signed_i64_token(part.trim()):
            return false
    true

fn _is_office_cli_ui_constraint_h_token(value: text) -> bool:
    value == "left" or value == "right" or value == "center" or value == "stretch"

fn _is_office_cli_ui_constraint_v_token(value: text) -> bool:
    value == "top" or value == "bottom" or value == "center" or value == "stretch"

fn _is_office_cli_safe_style_token(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if not ((ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "-" or ch == "_"):
            return false
        i = i + 1
    true

fn _is_office_cli_safe_style_token_list(value: text) -> bool:
    for part in value.split(" "):
        val token = part.trim()
        if token != "" and not _is_office_cli_safe_style_token(token):
            return false
    true

fn _is_office_cli_safe_css_value(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if not ((ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "#" or ch == "." or ch == "-" or ch == "_" or ch == "%" or ch == " " or ch == "(" or ch == ")"):
            return false
        i = i + 1
    true

fn _office_cli_canonical_cell_ref(value: text) -> text:
    val upper = value.trim().upper()
    var letters = ""
    var digits = ""
    var i = 0
    while i < upper.len():
        val c = upper.char_at(i)
        val code = c.char_code_at(0)
        if code >= 65 and code <= 90:
            letters = letters + c
        else:
            digits = digits + c
        i = i + 1
    var first_digit = 0
    while first_digit < digits.len() - 1 and digits.char_at(first_digit) == "0":
        first_digit = first_digit + 1
    letters + digits.slice(first_digit, digits.len())

fn _run_markdown_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office md-edit <line> <expected> <new> <source>"
        return 1
    if not _is_office_cli_non_negative_i32_token(args[1]):
        print "office-md-edit: rejected (invalid-line)"
        print "@@ line {args[1]} @@\nexpected: {args[2]}\nactual: <invalid-line>\nrejected: {args[3]}"
        return 2
    val line_no = args[1].to_i32()
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source = _decode_office_cli_text(args[4])
    val view = build_wysiwyg_view(source)
    val result = wysiwyg_update_line_checked(view, line_no, expected, replacement)
    if result.accepted:
        print "office-md-edit: updated"
        print result.diff
        print wysiwyg_source_pane(result.view).replace("\n", "\\n")
        return 0
    print "office-md-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _office_cli_split_source_entries(source: text) -> [text]:
    var entries: [text] = []
    var current = ""
    var escaped = false
    var i = 0
    while i < source.len():
        val ch = source.char_at(i)
        if escaped:
            if ch == ";" or ch == "\\":
                current = current + ch
            else:
                current = current + "\\" + ch
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == ";":
            entries.push(current)
            current = ""
        else:
            current = current + ch
        i = i + 1
    if escaped:
        current = current + "\\"
    entries.push(current)
    entries

fn _load_sheet_cli_source(source: text) -> Sheet:
    val sheet = Sheet.new("CLI")
    val decoded = _decode_office_cli_text(source)
    val entries = _office_cli_split_source_entries(decoded)
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val ref_str = parts[0].trim()
                val value = parts[1:].join("=")
                if parse_cell_ref(ref_str) != nil:
                    sheet.set_value(ref_str, value)
    sheet

fn _sheet_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = _office_cli_split_source_entries(decoded)
    var refs: [text] = []
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val ref_str = parts[0].trim()
            val parsed = parse_cell_ref(ref_str)
            if parsed == nil:
                return "invalid-source-ref"
            val key = _office_cli_canonical_cell_ref(ref_str)
            for seen in refs:
                if seen == key:
                    return "duplicate-source-ref"
            refs.push(key)
    ""

fn _run_sheet_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office sheet-edit <cell> <expected> <new> <sheet-source>"
        return 1
    val cell_ref = args[1]
    if cell_ref.trim() == "":
        print "office-sheet-edit: rejected (invalid-args)"
        return 2
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _sheet_cli_source_error(args[4])
    if source_error != "":
        print "office-sheet-edit: rejected ({source_error})"
        return 2
    val sheet = _load_sheet_cli_source(args[4])
    val result = sheet.update_cell_checked(cell_ref, expected, replacement)
    if result.accepted:
        print "office-sheet-edit: updated"
        print result.diff
        print "{result.cell_ref}={result.new_value}"
        return 0
    print "office-sheet-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _slide_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = _office_cli_split_source_entries(decoded)
    var ids: [text] = []
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val element_id = parts[0].trim()
            if element_id == "":
                return "missing-element-id"
            for seen in ids:
                if seen == element_id:
                    return "duplicate-source-id"
            ids.push(element_id)
    ""

fn _load_slide_cli_source(source: text) -> Slide:
    var slide = blank_slide("cli_slide")
    val decoded = _decode_office_cli_text(source)
    val entries = _office_cli_split_source_entries(decoded)
    var offset: i32 = 0
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val element_id = parts[0].trim()
                val value = parts[1:].join("=")
                if element_id != "":
                    slide = add_text_box(slide, element_id, value, 40, 40 + offset, 840, 60)
                    offset = offset + 72
    slide

fn _run_slide_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office slide-edit <element-id> <expected> <new> <slide-source>"
        return 1
    val element_id = args[1]
    if element_id.trim() == "":
        print "office-slide-edit: rejected (invalid-args)"
        return 2
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _slide_cli_source_error(args[4])
    if source_error != "":
        print "office-slide-edit: rejected ({source_error})"
        return 2
    val slide = _load_slide_cli_source(args[4])
    val result = slide_update_text_checked(slide, element_id, expected, replacement)
    if result.accepted:
        print "office-slide-edit: updated"
        print result.diff
        print "{result.element_id}={result.new_value}"
        return 0
    print "office-slide-edit: rejected ({result.reason})"
    print result.diff
    return 2
