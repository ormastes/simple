fn _office_action_math_result(action: text, result: MathRenderResult) -> OfficeActionResult:
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: result.mathml, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: result.mathml, reason: result.reason)

fn _office_action_render_mathml_checked(source: text) -> OfficeActionResult:
    _office_action_math_result("render-mathml-checked", math_to_mathml_checked(source))

fn _office_action_render_math_structure(source: text) -> OfficeActionResult:
    val result = math_to_mathml_checked(source)
    var output = "reason=" + result.reason + "\naccepted=" + result.accepted.to_text()
    if result.mathml.contains("<mfrac>"):
        output = output + "\ncontains=fraction"
    if result.mathml.contains("<msup>"):
        output = output + "\ncontains=superscript"
    if result.mathml.contains("<msub>"):
        output = output + "\ncontains=subscript"
    if result.mathml.contains("<msqrt>"):
        output = output + "\ncontains=square-root"
    if result.mathml.contains("<mrow>"):
        output = output + "\ncontains=row"
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "render-math-structure", output: output, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "render-math-structure", output: output, reason: result.reason)

fn _office_action_counter_output(result: CounterTransition) -> text:
    "value=" + result.value.to_text() + "\nstatus=" + result.status + "\nchanged=" + result.changed.to_text()

fn _office_action_mail_summary() -> text:
    val app = MailApp.new()
    "folder=" + folder_name(app.active_folder) + "\nemails=" + app.emails.len().to_text() + "\nunread=" + app.unread_count().to_text() + "\nfolders=" + app.folders.len().to_text() + "\nfiltered=" + app.filtered_emails().len().to_text()

fn _office_action_planner_summary() -> text:
    val app = PlannerApp.new()
    "project=" + app.project.title + "\nview=" + app.active_view + "\ntasks=" + app.project.tasks.len().to_text() + "\ncolumns=" + app.project.board.columns.len().to_text()

fn _office_action_counter_action(source: text) -> OfficeActionResult:
    val args = _office_action_split_piped_args(source)
    if args.len() != 2 or not _is_office_cli_signed_i64_token(args[0].trim()) or args[1].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "counter-action", output: "", reason: "invalid-args")
    val result = counter_apply_action(args[0].trim().to_i64(), args[1].trim())
    if not result.changed and result.status == "unsupported":
        return OfficeActionResult(ok: false, code: 1, action: "counter-action", output: _office_action_counter_output(result), reason: result.status)
    OfficeActionResult(ok: true, code: 0, action: "counter-action", output: _office_action_counter_output(result), reason: result.status)

fn _office_action_format_sdd_node_inspector(inspector: SdnGraphNodeInspector) -> text:
    "node_index=" + inspector.node_index.to_text() + "\nid=" + inspector.id + "\nlabel=" + inspector.label + "\ncss=" + inspector.css + "\nrole=" + inspector.role + "\nshape=" + inspector.shape + "\nx=" + inspector.x + "\ny=" + inspector.y + "\nwidth=" + inspector.width + "\nheight=" + inspector.height + "\nlayer=" + inspector.layer + "\nparent=" + inspector.parent + "\nchild_count=" + inspector.child_count + "\nchild_bounds=" + inspector.child_bounds

fn _office_action_format_sdd_edge_inspector(inspector: SdnGraphEdgeInspector) -> text:
    "edge_index=" + inspector.edge_index.to_text() + "\nfrom=" + inspector.from_id + "\nto=" + inspector.to_id + "\nlabel=" + inspector.label + "\ncss=" + inspector.css + "\nkind=" + inspector.kind + "\nroute=" + inspector.route + "\nwaypoints=" + inspector.waypoints + "\nstart_anchor=" + inspector.start_anchor + "\nend_anchor=" + inspector.end_anchor + "\nlabel_x=" + inspector.label_x + "\nlabel_y=" + inspector.label_y + "\npath=" + inspector.path + "\npath_bounds=" + inspector.path_bounds + "\nsegment_count=" + inspector.segment_count + "\nsegments=" + inspector.segments + "\nsegment_midpoints=" + inspector.segment_midpoints + "\nsegment_orientations=" + inspector.segment_orientations

fn _office_action_format_sdd_style_inspector(inspector: SdnGraphStyleInspector) -> text:
    "css=" + inspector.css + "\ntarget=" + inspector.target + "\nparent=" + inspector.parent_css + "\nkey=" + inspector.key + "\nvalue=" + inspector.value

