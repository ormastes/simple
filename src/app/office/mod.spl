    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    if args.len() != 11 or not _is_office_cli_signed_i64_token(args[5].trim()) or not _is_office_cli_signed_i64_token(args[6].trim()) or not _is_office_cli_non_negative_i32_token(args[7].trim()) or not _is_office_cli_non_negative_i32_token(args[8].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "add-sdd-node", output: "", reason: "invalid-args")
    val result = sdn_graph_add_node_checked(sdn_graph_parse(parts[1]), args[0].trim(), args[1], args[2].trim(), args[3].trim(), args[4].trim(), args[5].trim(), args[6].trim(), args[7].trim(), args[8].trim(), args[9].trim(), args[10].trim())
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "add-sdd-node", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "add-sdd-node", output: sdn_graph_render_html(result.graph), reason: result.reason)

fn _office_action_sdd_node_index(graph: SdnGraph, node_id: text) -> i64:
    var i: i64 = 0
    for node in graph.nodes:
        if node.id == node_id:
            return i
        i = i + 1
    -1

fn _office_action_edit_sdd_node_value(source: text, field: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    if args.len() != 2 or args[0].trim() == "" or not _is_office_cli_safe_style_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-" + field, output: "", reason: "invalid-args")
    if field == "parent" and args[1].trim() != "" and not _is_office_cli_safe_style_token(args[1].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-parent", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val idx = _office_action_sdd_node_index(graph, args[0].trim())
    if idx < 0:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-" + field, output: "", reason: "missing-node")
    if field == "parent":
        val result = sdn_graph_update_node_parent_checked(graph, args[0].trim(), args[1].trim())
        if not result.accepted:
            return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-parent", output: result.diff, reason: result.reason)
        return OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-parent", output: sdn_graph_render_html(result.graph), reason: result.reason)
    if field == "label":
        val label_result = sdn_graph_update_node_label_checked(graph, idx, args[1])
        return OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-label", output: sdn_graph_render_html(label_result.graph), reason: label_result.reason)
    val result = if field == "shape" then sdn_graph_update_node_shape_checked(graph, idx, args[1].trim()) elif field == "layer" then sdn_graph_update_node_layer_checked(graph, idx, args[1].trim()) elif field == "role" then sdn_graph_update_node_role_checked(graph, idx, args[1].trim()) else: sdn_graph_update_node_style_checked(graph, idx, args[1].trim())
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-" + field, output: result.diff, reason: result.reason)
    val updated = result.graph
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-" + field, output: sdn_graph_render_html(updated), reason: "updated")

