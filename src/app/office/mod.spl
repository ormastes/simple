fn _office_action_split_csv(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var in_quote = false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "\"":
            if in_quote and i + 1 < value.len() and value.char_at(i + 1) == "\"":
                current = current + "\""
                i = i + 1
            else:
                in_quote = not in_quote
        elif ch == "," and not in_quote:
            out.push(current.trim())
            current = ""
        else:
            current = current + ch
        i = i + 1
    out.push(current.trim())
    out

fn _office_action_csv_is_well_formed(value: text) -> bool:
    var in_quote = false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "\"":
            if in_quote and i + 1 < value.len() and value.char_at(i + 1) == "\"":
                i = i + 1
            else:
                in_quote = not in_quote
        i = i + 1
    not in_quote

fn _office_action_quote_csv(value: text) -> text:
    if value.contains(",") or value.contains("\""):
        return "\"" + value.replace("\"", "\"\"") + "\""
    value

fn _office_action_parse_db_table(source: text) -> DbTable:
    var name = "Table"
    var columns: [text] = []
    var rows: [[text]] = []
    for raw in source.split("\n"):
        val line = raw.trim()
        if line == "" or line.starts_with("#"):
            continue
        if line.starts_with("table:"):
            name = line.slice(6, line.len()).trim()
        elif line.starts_with("columns:"):
            val column_text = line.slice(8, line.len()).trim()
            columns = if _office_action_csv_is_well_formed(column_text) then _office_action_split_csv(column_text) else: [""]
        elif line.starts_with("row:"):
            val row_text = line.slice(4, line.len()).trim()
            rows.push(if _office_action_csv_is_well_formed(row_text) then _office_action_split_csv(row_text) else: [])
    DbTable(name: name, columns: columns, rows: rows)

fn _office_action_render_db_table(table: DbTable) -> text:
    var lines: [text] = []
    lines.push("table: " + table.name)
    var columns: [text] = []
    for column in table.columns:
        columns.push(_office_action_quote_csv(column))
    lines.push("columns: " + columns.join(","))
    for row in table.rows:
        var cells: [text] = []
        for cell in row:
            cells.push(_office_action_quote_csv(cell))
        lines.push("row: " + cells.join(","))
    lines.join("\n")

fn _office_action_escape_html(value: text) -> text:
    var out = value.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out.replace("\"", "&quot;")

fn _office_action_render_db_table_html(table: DbTable) -> text:
    var html = "<table class=\"base-table\" data-format=\"base-table\" data-format-name=\"Base Table\" data-table=\"" + _office_action_escape_html(table.name) + "\" data-column-count=\"" + table.columns.len().to_text() + "\" data-row-count=\"" + table.rows.len().to_text() + "\"><thead><tr>"
    for column in table.columns:
        html = html + "<th scope=\"col\" data-column=\"" + _office_action_escape_html(column) + "\">" + _office_action_escape_html(column) + "</th>"
    html = html + "</tr></thead><tbody>"
    var row_index = 0
    for row in table.rows:
        html = html + "<tr data-row-index=\"" + row_index.to_text() + "\">"
        var col_index = 0
        for cell in row:
            html = html + "<td data-row-index=\"" + row_index.to_text() + "\" data-column=\"" + _office_action_escape_html(_office_action_column_name_at(table, col_index)) + "\">" + _office_action_escape_html(cell) + "</td>"
            col_index = col_index + 1
        html = html + "</tr>"
        row_index = row_index + 1
    html + "</tbody></table>"

fn _office_action_column_name_at(table: DbTable, target: i32) -> text:
    var i = 0
    for column in table.columns:
        if i == target:
            return column
        i = i + 1
    ""

fn _office_action_db_table_schema_error(table: DbTable) -> text:
    if table.name.trim() == "":
        return "missing-table-name"
    if table.columns.len() == 0:
        return "missing-columns"
    var has_column_name = false
    for column in table.columns:
        if column != "":
            has_column_name = true
    if not has_column_name:
        return "missing-columns"
    for column in table.columns:
        if column == "":
            return "blank-column"
    var i = 0
    while i < table.columns.len():
        var j = i + 1
        while j < table.columns.len():
            if table.columns[i] == table.columns[j]:
                return "duplicate-column"
            j = j + 1
        i = i + 1
    for row in table.rows:
        if row.len() != table.columns.len():
            return "row-width-mismatch"
    ""

fn _office_action_db_query_error(table: DbTable, column: text) -> text:
    val schema_error = _office_action_db_table_schema_error(table)
    if schema_error != "":
        return schema_error
    if column_index(table, column) < 0:
        return "missing-column"
    ""

fn _office_action_render_base_table_html(source: text) -> OfficeActionResult:
    val table = _office_action_parse_db_table(source)
    val error = _office_action_db_table_schema_error(table)
    if error != "":
        return OfficeActionResult(ok: false, code: 1, action: "render-base-table-html", output: _office_action_render_db_table(table), reason: error)
    OfficeActionResult(ok: true, code: 0, action: "render-base-table-html", output: _office_action_render_db_table_html(table), reason: "rendered")

fn _office_action_base_table_summary(source: text) -> OfficeActionResult:
    val table = _office_action_parse_db_table(source)
    val error = _office_action_db_table_schema_error(table)
    val output = "table=" + table.name + "\ncolumns=" + table.columns.join(",") + "\nrows=" + table.rows.len().to_text()
    if error != "":
        return OfficeActionResult(ok: false, code: 1, action: "base-table-summary", output: output, reason: error)
    OfficeActionResult(ok: true, code: 0, action: "base-table-summary", output: output, reason: "summarized")

fn _office_action_db_result(action: text, result: DbEditResult) -> OfficeActionResult:
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: _office_action_render_db_table(result.table), reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_render_db_table(result.table), reason: result.reason)

fn _office_action_query_table(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    val table = _office_action_parse_db_table(parts[1])
    if args.len() == 3 and args[0].trim() == "count-where":
        if args[1].trim() == "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: "", reason: "invalid-args")
        val error = _office_action_db_query_error(table, args[1].trim())
        if error != "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: _office_action_render_db_table(table), reason: error)
        return OfficeActionResult(ok: true, code: 0, action: "query-table", output: count_where(table, args[1].trim(), args[2].trim()).to_text(), reason: "counted")
    if args.len() == 3 and args[0].trim() == "select-where":
        if args[1].trim() == "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: "", reason: "invalid-args")
        val error = _office_action_db_query_error(table, args[1].trim())
        if error != "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: _office_action_render_db_table(table), reason: error)
        return OfficeActionResult(ok: true, code: 0, action: "query-table", output: _office_action_render_db_table(DbTable(name: table.name, columns: table.columns, rows: select_where(table, args[1].trim(), args[2].trim()))), reason: "selected")
    if args.len() == 2 and args[0].trim() == "project-column":
        if args[1].trim() == "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: "", reason: "invalid-args")
        val error = _office_action_db_query_error(table, args[1].trim())
        if error != "":
            return OfficeActionResult(ok: false, code: 1, action: "query-table", output: _office_action_render_db_table(table), reason: error)
        return OfficeActionResult(ok: true, code: 0, action: "query-table", output: project_column(table, args[1].trim()).join("\n"), reason: "projected")
    OfficeActionResult(ok: false, code: 1, action: "query-table", output: "", reason: "invalid-args")

fn _office_action_db_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    val table = _office_action_parse_db_table(parts[1])
    val schema_error = _office_action_db_table_schema_error(table)
    if schema_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "db-edit", output: _office_action_render_db_table(table), reason: schema_error)
    if args.len() == 2 and args[0].trim() == "insert":
        return _office_action_db_result("db-edit", insert_row_checked(table, _office_action_split_csv(args[1])))
    if args.len() == 5 and args[0].trim() == "update-where":
        if args[1].trim() == "" or args[3].trim() == "":
            return OfficeActionResult(ok: false, code: 1, action: "db-edit", output: "", reason: "invalid-args")
        return _office_action_db_result("db-edit", update_where(table, args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim()))
    if args.len() == 3 and args[0].trim() == "delete-where":
        if args[1].trim() == "":
            return OfficeActionResult(ok: false, code: 1, action: "db-edit", output: "", reason: "invalid-args")
        return _office_action_db_result("db-edit", delete_where(table, args[1].trim(), args[2].trim()))
    OfficeActionResult(ok: false, code: 1, action: "db-edit", output: _office_action_render_db_table(table), reason: "invalid-args")

fn _office_action_export_base_game_state(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    val table = _office_action_parse_db_table(parts[1])
    if args.len() != 4 or args[0].trim() == "" or args[2].trim() == "" or args[3].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "export-base-game-state", output: "", reason: "invalid-args")
    val match_error = _office_action_db_query_error(table, args[0].trim())
    if match_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "export-base-game-state", output: _office_action_render_db_table(table), reason: match_error)
    if column_index(table, args[2].trim()) < 0 or column_index(table, args[3].trim()) < 0:
        return OfficeActionResult(ok: false, code: 1, action: "export-base-game-state", output: _office_action_render_db_table(table), reason: "missing-column")
    OfficeActionResult(ok: true, code: 0, action: "export-base-game-state", output: base_query_to_game_state(table, args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim()), reason: "exported")

