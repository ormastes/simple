fn _office_action_edit_sdd_node_geometry(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 5 or args[0].trim() == "" or not _is_office_cli_safe_style_token(args[0].trim()) or not _is_office_cli_signed_i64_token(args[1].trim()) or not _is_office_cli_signed_i64_token(args[2].trim()) or not _is_office_cli_non_negative_i32_token(args[3].trim()) or not _is_office_cli_non_negative_i32_token(args[4].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-geometry", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val idx = _office_action_sdd_node_index(graph, args[0].trim())
    if idx < 0:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-geometry", output: "", reason: "missing-node")
    val result = sdn_graph_update_node_geometry_checked(graph, idx, args[1], args[2], args[3], args[4])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-geometry", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-geometry", output: sdn_graph_render_html(result.graph), reason: result.reason)

fn _office_action_edit_sdd_canvas(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = _office_action_split_piped_args(parts[0])
    if args.len() != 6 or args[0].trim() == "" or args[1].trim() == "" or args[2].trim() == "" or args[3].trim() == "" or args[4].trim() == "" or args[5].trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-canvas", output: "", reason: "invalid-args")
