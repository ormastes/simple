fn _office_action_edit_sdd_node_geometry(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 5 or not _is_office_cli_signed_i64_token(args[1].trim()) or not _is_office_cli_signed_i64_token(args[2].trim()) or not _is_office_cli_non_negative_i32_token(args[3].trim()) or not _is_office_cli_non_negative_i32_token(args[4].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-geometry", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val idx = _office_action_sdd_node_index(graph, args[0].trim())
    if idx < 0:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-geometry", output: "", reason: "missing-node")
    val node = graph.nodes[idx]
    val updated = sdn_graph_update_node_at(graph, idx, node.css, node.role, node.shape, args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim(), node.layer)
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-geometry", output: sdn_graph_render_html(updated), reason: "updated")

