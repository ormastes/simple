# Simple Office Suite
#
# Entry point for the office suite CLI command.

use app.office.launcher.{build_launcher_ui}
use common.office.file_ops.{RecentFileStore}

# =========================================================================
# Office CLI Dispatcher
# =========================================================================

fn run_office(args: [text]) -> i32:
    """Dispatch to the requested office app or show the launcher."""
    val cmd = if args.len() > 0: args[0] else: "launcher"

    match cmd:
        "launcher" =>
            val store = RecentFileStore.new(20)
            val recent = store.get_recent(10)
            val ui = build_launcher_ui(recent)
            print "Simple Office Launcher loaded ({ui.root_id})"
            return 0
        "word" =>
            print "Simple Word - document editor (placeholder)"
            return 0
        "sheets" =>
            print "Simple Sheets - spreadsheet editor (placeholder)"
            return 0
        "slides" =>
            print "Simple Slides - presentation editor (placeholder)"
            return 0
        "mail" =>
            print "Simple Mail - email client (placeholder)"
            return 0
        "planner" =>
            print "Simple Planner - task and project manager (placeholder)"
            return 0
        _ =>
            print "Usage: simple office [launcher|word|sheets|slides|mail|planner]"
            return 1
