fn _office_action_edit_sdd_edge_endpoints(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3 or not _is_office_cli_non_negative_i32_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-edge-endpoints", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val edge_index = args[0].trim().to_i64()
    if edge_index >= graph.edges.len():
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-edge-endpoints", output: "", reason: "missing-edge")
    val from_id = args[1].trim()
    val to_id = args[2].trim()
    if not sdn_graph_inspect_node(graph, from_id).found or not sdn_graph_inspect_node(graph, to_id).found:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-edge-endpoints", output: "", reason: "missing-node")
    val updated = sdn_graph_update_edge_endpoints_at(graph, edge_index, from_id, to_id)
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-edge-endpoints", output: sdn_graph_render_html(updated), reason: "updated")

