fn _run_sheet_tui(in_path: text) -> i32:
    """Keystroke-driven full-screen editing: real termios raw mode, arrow
    keys (ESC[C etc.) move, typing edits the active cell, Enter commits with
    live recalculation, s saves, q quits. The loop itself lives in
    interactive.spl (run_sheet_tui_mode) — rt_stdin_read_byte and the raw
    mode externs resolve fine from an imported module; see
    doc/08_tracking/bug/raw_mode_extern_registry_2026-07-03.md for the
    root-cause history."""
    run_sheet_tui_mode(in_path)
use std.nogc_sync_mut.sffi.io.{file_read_bytes, file_write_bytes}
use app.ui.render.types.{RenderConfig}
use std.io_runtime.{write_file, read_file, file_exists, mkdir_p}

fn main() -> i64:
    val args = _get_office_cli_args()
    run_office(args).to_i64()

fn _get_office_cli_args() -> [text]:
    val all_args = cli_get_args()
    var args: [text] = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("/app/office/mod.spl") or all_args[scan_idx] == "src/app/office/mod.spl":
            start_idx = scan_idx + 1
            scan_idx = all_args.len()
        else:
            scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    if args.len() > 0 and args[0] == "office":
        return args[1:]
    args

fn _run_office_gui_command(app_name: text) -> i32:
    """Render one frame of the named office app through the real UI stack
    (UITree -> ui.browser backend -> browser engine -> pixels) and report a
    pixel-level proof line instead of the print-root_id dead end."""
    val pixels = office_gui_frame(app_name)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for {app_name}"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui: {app_name} frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    return 0

fn _build_office_gui_sheet_demo() -> Sheet:
    """Build the demo sheet for `office sheet-gui`: a header row, 4 data
    rows (one of which is hidden via hide_row, one of which is a =SUM(...)
    formula total), rendered through sheet_gui_view/office_gui_sheet_pixels."""
    var sheet = Sheet.new("Demo")
    sheet.set_value("A1", "Item")
    sheet.set_value("B1", "Price")
    sheet.set_value("C1", "Qty")
    sheet.set_value("D1", "Total")
    sheet.set_value("A2", "Widget")
    sheet.set_value("B2", "10")
    sheet.set_value("C2", "2")
    sheet.set_value("D2", "=B2*C2")
    sheet.set_value("A3", "Gadget")
    sheet.set_value("B3", "20")
    sheet.set_value("C3", "3")
    sheet.set_value("D3", "=B3*C3")
    sheet.set_value("A4", "Hidden")
    sheet.set_value("B4", "999")
    sheet.set_value("C4", "1")
    sheet.set_value("D4", "=B4*C4")
    sheet.set_value("A5", "Total")
    sheet.set_value("D5", "=SUM(D2:D3)")
    sheet.hide_row(4)
    sheet = recalculate_formula_cells(sheet)
    sheet

fn _run_office_gui_sheet_edit_command() -> i32:
    """Script the first sheet-GUI INTERACTION end to end: select D2, edit
    B2 from 10 to 40, and print BEFORE/AFTER text_dumps + pixel-rendered
    frame lines proving the =B2*C2 (D2) and =SUM(D2:D3) (D5) formula cells
    recalculated. The input-DEVICE layer (mouse/keyboard -> event) is
    stubbed: session_select/session_edit are called directly instead of
    routing through common.ui.event's real handle_pointer/handle_keypress
    dispatch (see gui.spl's sheet-GUI-session comment for why: today's
    table_widget grid has no per-cell click target to hit-test against)."""
    val sheet = _build_office_gui_sheet_demo()
    var session = session_new(sheet, "D2")
    session = session_select(session, "D2", 5, 4)

    val before_view = sheet_gui_view_with_selection(session, 5, 4)
    val before_pixels = office_gui_sheet_session_pixels(before_view, session.selected_ref)
    if before_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-edit (before)"
        return 1
    val before_non_background = office_gui_non_background_pixel_count(before_pixels)
    print "office-gui-edit: BEFORE frame {office_gui_frame_width()}x{office_gui_frame_height()}, {before_non_background} non-background pixels"
    for line in before_view.text_dump.split("\n"):
        print "office-gui-edit-before: {line}"

    session = session_edit(session, "B2", "40")

    val after_view = sheet_gui_view_with_selection(session, 5, 4)
    val after_pixels = office_gui_sheet_session_pixels(after_view, session.selected_ref)
    if after_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-edit (after)"
        return 1
    val after_non_background = office_gui_non_background_pixel_count(after_pixels)
    print "office-gui-edit: AFTER frame {office_gui_frame_width()}x{office_gui_frame_height()}, {after_non_background} non-background pixels"
    for line in after_view.text_dump.split("\n"):
        print "office-gui-edit-after: {line}"
    return 0

fn _run_office_gui_sheet_click_command() -> i32:
    """Script the real pointer-click path end to end: start with D2 selected
    (BEFORE frame), compute the on-screen point that lands on cell B2 from
    the SAME layout pass handle_pointer's hit-test uses (sheet_gui_cell_
    click_point), route that (x, y) through session_click (which itself
    routes a genuine UIEvent.Resize + UIEvent.MouseEvent through common.ui.
    event's process_event/handle_pointer -- no parallel coordinate mapper),
    and print the coordinates used plus the hit result. Closes doc/
    08_tracking/bug/office_gui_no_per_cell_click_target_2026-07-04.md's
    pointer-click gap: real (x, y) -> hit-test -> cell selected."""
    val viewport_w = 640
    val viewport_h = 480
    val sheet = _build_office_gui_sheet_demo()
    var session = session_new(sheet, "D2")
    session = session_select(session, "D2", 5, 4)

    val before_view = sheet_gui_view_with_selection(session, 5, 4)
    val before_pixels = office_gui_sheet_session_pixels(before_view, session.selected_ref)
    if before_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-click (before)"
        return 1
    val before_non_background = office_gui_non_background_pixel_count(before_pixels)
    print "office-gui-click: BEFORE frame {office_gui_frame_width()}x{office_gui_frame_height()}, {before_non_background} non-background pixels"
    for line in before_view.text_dump.split("\n"):
        print "office-gui-click-before: {line}"

    val point = sheet_gui_cell_click_point(before_view, "B2", viewport_w, viewport_h)
    val click_x = point.0
    val click_y = point.1
    print "office-gui-click: computed click point for B2 = ({click_x}, {click_y}) at viewport {viewport_w}x{viewport_h}"

    session = session_click(session, click_x, click_y, 5, 4, viewport_w, viewport_h)
    print "office-gui-click: hit={session.selected_ref}"

    val after_view = sheet_gui_view_with_selection(session, 5, 4)
    val after_pixels = office_gui_sheet_session_pixels(after_view, session.selected_ref)
    if after_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-click (after)"
        return 1
    val after_non_background = office_gui_non_background_pixel_count(after_pixels)
    print "office-gui-click: AFTER frame {office_gui_frame_width()}x{office_gui_frame_height()}, {after_non_background} non-background pixels"
    for line in after_view.text_dump.split("\n"):
        print "office-gui-click-after: {line}"
    return 0

fn _run_office_gui_sheet_key_command() -> i32:
    """Script the keyboard-interaction path end to end: start with B2
    selected (BEFORE frame), step through a real key sequence -- "down"
    (arrow-key grid navigation via session_key), "9", "9" (typed-buffer
    accumulation), "enter" (commit + recalculation) -- printing each step's
    resulting selection (office-gui-key: <key> -> <selected_ref>), then the
    AFTER dump/pixel proof showing B3=99 and its dependent formula cells
    (D3 = B3*C3, D5 = SUM(D2:D3)) recalculated. See gui.spl's "Keyboard
    interaction" comment block for why session_key is a session-level
    translator rather than a call into common.ui.event.process_event."""
    val sheet = _build_office_gui_sheet_demo()
    var session = session_new(sheet, "B2")

    val before_view = sheet_gui_view_with_selection(session, 5, 4)
    val before_pixels = office_gui_sheet_session_pixels(before_view, session.selected_ref)
    if before_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-key (before)"
        return 1
    val before_non_background = office_gui_non_background_pixel_count(before_pixels)
    print "office-gui-key: BEFORE frame {office_gui_frame_width()}x{office_gui_frame_height()}, {before_non_background} non-background pixels"
    for line in before_view.text_dump.split("\n"):
        print "office-gui-key-before: {line}"

    val keys: [text] = ["down", "9", "9", "enter"]
    for k in keys:
        session = session_key(session, k, 5, 4, 5, 4)
        print "office-gui-key: {k} -> {session.selected_ref}"

    val after_view = sheet_gui_view_with_selection(session, 5, 4)
    val after_pixels = office_gui_sheet_session_pixels(after_view, session.selected_ref)
    if after_pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-key (after)"
        return 1
    val after_non_background = office_gui_non_background_pixel_count(after_pixels)
    print "office-gui-key: AFTER frame {office_gui_frame_width()}x{office_gui_frame_height()}, {after_non_background} non-background pixels"
    for line in after_view.text_dump.split("\n"):
        print "office-gui-key-after: {line}"
    return 0

fn _build_office_gui_sheet_scroll_demo() -> Sheet:
    """Build the demo sheet for `office sheet-gui-scroll`: 20 data rows
    (A2:A21 labels, B2:B21 values 1..20) under a header row, plus a
    =SUM(B2:B21) total placed a few rows further down (row 23) so it is
    only reachable by scrolling PAST the initial 5-visible-row window --
    proving the viewport is a real navigable window over a sheet bigger
    than what first renders, not just a relabeled fixed grid."""
    var sheet = Sheet.new("ScrollDemo")
    sheet.set_value("A1", "Item")
    sheet.set_value("B1", "Value")
    var i = 1
    while i <= 20:
        val r = i + 1
        sheet.set_value("A{r}", "Item {i}")
        sheet.set_value("B{r}", "{i}")
        i = i + 1
    sheet.set_value("A23", "Total")
    sheet.set_value("B23", "=SUM(B2:B21)")
    sheet = recalculate_formula_cells(sheet)
    sheet

fn _office_gui_scroll_view_ref(session: SheetGuiSession) -> text:
    """The current viewport's top-left cell ref (e.g. "A1"), built by
    concatenation (not adjacent "{...}{...}" interpolation blocks) per the
    quirk ledger's string-interpolation guidance."""
    col_to_letter(session.view_left_col - 1) + "{session.view_top_row}"

fn _run_office_gui_sheet_scroll_command() -> i32:
    """Script the viewport/scroll path end to end over the 20-row scroll
    demo sheet with a 5-visible-row x 2-column window: print the initial
    window, walk the selection down 6 arrow-key steps (the viewport
    auto-scrolls the minimal amount once the selection steps past the
    window's bottom edge -- see gui.spl's _sheet_gui_scroll_to_show_row),
    page down one full window (session_scroll -- selection follows the
    page move, keeping its same relative row inside the window), then jump
    the selection directly to A18 (an off-window session_select that must
    scroll to reveal it). Each step prints "office-gui-scroll: <action> ->
    sel=<ref> view=<top_ref>", then the final text_dump (which carries its
    own "viewport|..." marker line -- see sheet_gui_view_with_selection)
    and a pixel-rendered proof-of-frame line."""
    val view_rows = 5
    val view_cols = 2
    val grid_rows = 30
    val grid_cols = 2
    val sheet = _build_office_gui_sheet_scroll_demo()
    var session = session_new(sheet, "B2")
    print "office-gui-scroll: initial -> sel={session.selected_ref} view={_office_gui_scroll_view_ref(session)}"

    val keys: [text] = ["down", "down", "down", "down", "down", "down"]
    for k in keys:
        session = session_key(session, k, grid_rows, grid_cols, view_rows, view_cols)
        print "office-gui-scroll: {k} -> sel={session.selected_ref} view={_office_gui_scroll_view_ref(session)}"

    session = session_scroll(session, "page_down", view_rows, view_cols)
    print "office-gui-scroll: page_down -> sel={session.selected_ref} view={_office_gui_scroll_view_ref(session)}"

    session = session_select(session, "A18", view_rows, view_cols)
    print "office-gui-scroll: select_A18 -> sel={session.selected_ref} view={_office_gui_scroll_view_ref(session)}"

    val view = sheet_gui_view_with_selection(session, view_rows, view_cols)
    val pixels = office_gui_sheet_session_pixels(view, session.selected_ref)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-scroll"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui-scroll: AFTER frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-scroll-after: {line}"
    return 0

fn _run_office_gui_sheet_live_command() -> i32:
    """`office sheet-gui-live`: the live interactive keystroke loop -- real
    termios raw-mode input (the same rt_stdin_read_byte/decode_key_byte
    machinery run_sheet_tui_mode's TUI backend uses) driving the
    sheet-GUI session (SheetGuiSession/session_key), one frame re-rendered
    through the real office_gui_sheet_session_pixels pixel path per
    keystroke. See interactive.spl's run_sheet_gui_live for the loop itself
    (owned there since it already owns the termios externs) and gui.spl's
    run_gui_live_step for the pure, spec-tested per-keystroke core. Closes
    doc/08_tracking/bug/office_gui_no_per_cell_click_target_2026-07-04.md's
    residual #4 for terminal input: piped/non-TTY stdin (CI) prints one
    rendered frame plus a documented notice and exits 0 instead of hanging."""
    run_sheet_gui_live(_build_office_gui_sheet_demo())

fn _build_office_gui_sheet_cf_demo() -> Sheet:
    """Build the demo sheet for `office sheet-gui-cf`: a Value column
    B2:B6 = 10,20,30,40,50 (the data-bar rule's range -- percents 0/25/50/
    75/100 over the 10..50 span, so buckets bar0/bar2/bar5/bar7/bar10) and
    a Score column C2:C6 = 5,3,8,3,6 (the above_average rule's range --
    mean (5+3+8+3+6)/5 = 5, so ONLY 8 (C4) and 6 (C6) are strictly above
    it; the two 3s and the 5 itself are not)."""
    var sheet = Sheet.new("CfDemo")
    sheet.set_value("A1", "Item")
    sheet.set_value("B1", "Value")
    sheet.set_value("C1", "Score")
    sheet.set_value("A2", "Alpha")
    sheet.set_value("B2", "10")
    sheet.set_value("C2", "5")
    sheet.set_value("A3", "Beta")
    sheet.set_value("B3", "20")
    sheet.set_value("C3", "3")
    sheet.set_value("A4", "Gamma")
    sheet.set_value("B4", "30")
    sheet.set_value("C4", "8")
    sheet.set_value("A5", "Delta")
    sheet.set_value("B5", "40")
    sheet.set_value("C5", "3")
    sheet.set_value("A6", "Epsilon")
    sheet.set_value("B6", "50")
    sheet.set_value("C6", "6")
    sheet

fn _run_office_gui_sheet_cf_command() -> i32:
    """`office sheet-gui-cf`: conditional formatting rendered LIVE in the
    sheet GUI (Excel-parity -- the grid shows rule matches, not just the
    export path). Builds the cf demo sheet, applies the cond_format
    engine's rules (a data_bar rule over B2:B6 and an above_average rule
    over C2:C6, both plain engine CondRule values -- evaluation stays 100%
    in cond_format.spl), renders one real pixel frame through
    office_gui_sheet_cf_pixels (matched cells' cf-* classes painted by
    office_gui_sheet_minimal_css), and prints the frame proof line plus
    the text_dump whose "!<marker>" suffixes name every matched cell (see
    _build_office_gui_sheet_cf_demo's docstring for the hand-computed
    expected buckets/mean)."""
    val sheet = _build_office_gui_sheet_cf_demo()
    val session = session_new(sheet, "")
    val bar_rule = CondRule(range: "B2:B6", kind: "data_bar", criteria: "", n: 0, css: "")
    val avg_rule = CondRule(range: "C2:C6", kind: "above_average", criteria: "", n: 0, css: "")
    val rules: [CondRule] = [bar_rule, avg_rule]
    val view = sheet_gui_view_with_formats(session, rules, 6, 3)
    val pixels = office_gui_sheet_cf_pixels(view, session.selected_ref)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-cf"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui-cf: frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-cf: {line}"
    return 0

fn _run_office_gui_sheet_fmt_command() -> i32:
    """`office sheet-gui-fmt`: number formats RENDERED and data validation
    ENFORCED live in the sheet GUI (Excel parity: formatted values in the
    grid, invalid entry rejected at commit time). Demo sheet: an Item
    column plus a Price column whose cells B2:B4 carry the "$#,##0.00"
    currency code AND a whole_number 1-100 validation rule on column B.
    Script: render (formatted currency strings visible in the dump) ->
    session_edit_validated B2 = "42" (valid; commits and re-renders as
    "$42.00") -> session_edit_validated B2 = "999" (out of range; prints
    the rejection message and the dump proves the cell is UNCHANGED)."""
    var sheet = Sheet.new("Fmt")
    sheet.set_value("A1", "Item")
    sheet.set_value("B1", "Price")
    sheet.set_value("A2", "Widget")
    sheet.set_value("B2", "10")
    sheet.set_value("A3", "Gadget")
    sheet.set_value("B3", "1234.5")
    sheet.set_value("A4", "Gizmo")
    sheet.set_value("B4", "7")
    var formats = empty_sheet_formats()
    formats = sheet_set_number_format(formats, "B2", "$#,##0.00")
    formats = sheet_set_number_format(formats, "B3", "$#,##0.00")
    formats = sheet_set_number_format(formats, "B4", "$#,##0.00")
    var vrules = empty_validation_rules()
    vrules = validation_add(vrules, "B", "whole_number", "", 1.0, 100.0, "", "Price must be a whole number between 1 and 100")
    var session = session_new(sheet, "B2")
    val no_rules: [CondRule] = []

    val before_view = sheet_gui_view_full(session, no_rules, formats, 4, 2)
    val pixels = office_gui_sheet_session_pixels(before_view, session.selected_ref)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui-fmt"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui-fmt: frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in before_view.text_dump.split("\n"):
        print "office-gui-fmt-before: {line}"

    val valid_outcome = session_edit_validated(session, "B2", "42", vrules)
    session = valid_outcome.session
    print "office-gui-fmt: edit B2=42 -> last_error=\"{valid_outcome.last_error}\""
    val after_view = sheet_gui_view_full(session, no_rules, formats, 4, 2)
    for line in after_view.text_dump.split("\n"):
        print "office-gui-fmt-after: {line}"

    val invalid_outcome = session_edit_validated(session, "B2", "999", vrules)
    print "office-gui-fmt: rejected: {invalid_outcome.last_error}"
    session = invalid_outcome.session
    val rejected_view = sheet_gui_view_full(session, no_rules, formats, 4, 2)
    for line in rejected_view.text_dump.split("\n"):
        print "office-gui-fmt-rejected: {line}"
    return 0

fn _office_gui_undo_cell_text(session: SheetGuiSession, ref_str: text) -> text:
    """Display text of one cell in the session's sheet (hoisted locals --
    no chained calls, quirk ledger item 1)."""
    val sheet = session.sheet
    val cell = sheet.get_cell(ref_str)
    cell_display_text(cell)

fn _office_gui_undo_print_step(op: text, session: SheetGuiSession, err: text):
    """One "office-gui-undo:" marker line per scripted step: the operation,
    the resulting B2/D2 display values (D2 is =B2*C2, so it proves the
    recalculate path ran), and the outcome's last_error."""
    val b2 = _office_gui_undo_cell_text(session, "B2")
    val d2 = _office_gui_undo_cell_text(session, "D2")
    print "office-gui-undo: {op} -> B2={b2} D2={d2} err={err}"

fn _run_office_gui_sheet_undo_command() -> i32:
    """`office sheet-gui-undo`: undo/redo scripted end to end over the demo
    sheet (B2=10, D2==B2*C2=20). Script: undo on empty history (fail-closed
    "nothing-to-undo") -> edit B2=40 (D2 recalcs to 80) -> undo (back to
    10/20) -> redo (40/80 again) -> edit B2=50 (50/100) -> undo (40/80) ->
    edit B2=60 (60/120, TRUNCATES the redo tail holding the 50 edit) ->
    redo (fail-closed "nothing-to-redo", values unchanged). Every step
    prints an "office-gui-undo:" marker with B2/D2 + err; BEFORE/FINAL
    text_dumps bracket the run."""
    val sheet = _build_office_gui_sheet_demo()
    var session = session_new(sheet, "B2")
    var history = history_new()
    val vrules = empty_validation_rules()

    val before_view = sheet_gui_view_with_selection(session, 5, 4)
    for line in before_view.text_dump.split("\n"):
        print "office-gui-undo-before: {line}"
    _office_gui_undo_print_step("start", session, "")

    var out = session_undo(session, history)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("undo-empty", session, out.last_error)

    out = session_edit_undoable(session, history, "B2", "40", vrules)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("edit B2=40", session, out.last_error)

    out = session_undo(session, history)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("undo", session, out.last_error)

    out = session_redo(session, history)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("redo", session, out.last_error)

    out = session_edit_undoable(session, history, "B2", "50", vrules)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("edit B2=50", session, out.last_error)

    out = session_undo(session, history)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("undo", session, out.last_error)

    out = session_edit_undoable(session, history, "B2", "60", vrules)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("edit B2=60", session, out.last_error)

    out = session_redo(session, history)
    session = out.session
    history = out.history
    _office_gui_undo_print_step("redo-truncated", session, out.last_error)

    val final_view = sheet_gui_view_with_selection(session, 5, 4)
    for line in final_view.text_dump.split("\n"):
        print "office-gui-undo-final: {line}"
    return 0

fn _run_office_gui_sheet_command() -> i32:
    """Render the demo sheet's grid view through the real UI stack and
    report the same pixel-level proof line style as the counter pilot, plus
    a content marker line per rendered row (pipe-separated) so tests can
    assert content without pixel parsing."""
    val sheet = _build_office_gui_sheet_demo()
    val view = sheet_gui_view(sheet, 5, 4)
    val pixels = office_gui_sheet_pixels(view)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for sheet-gui"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui: sheet-gui frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-sheet-row: {line}"
    return 0

fn _build_office_gui_chart_demo() -> Sheet:
    """Build the demo sheet for `office chart-gui`: 4 labeled values, one of
    which (B4) is a =B1+B2 formula so the chart's rendered text_dump proves
    it reads the computed value, not the raw formula text. Column C is a
    second data column (Sales, distinct from column B's Units) so the
    CHART GUI INTERACTIVITY step script below has a real second range to
    re-point the chart's value_range onto -- same "second column" role
    _pivot_gui_dataset_with_extra_col's column D plays for pivot_session_
    set_value_col."""
    var sheet = Sheet.new("ChartDemo")
    sheet.set_value("A1", "Widget")
    sheet.set_value("B1", "10")
    sheet.set_value("C1", "5")
    sheet.set_value("A2", "Gadget")
    sheet.set_value("B2", "20")
    sheet.set_value("C2", "15")
    sheet.set_value("A3", "Gizmo")
    sheet.set_value("B3", "15")
    sheet.set_value("C3", "10")
    sheet.set_value("A4", "Combo")
    sheet.set_value("B4", "=B1+B2")
    sheet.set_value("C4", "20")
    sheet = recalculate_formula_cells(sheet)
    sheet

fn _run_office_gui_chart_command() -> i32:
    """Render the demo sheet's bar chart through the real UI stack and
    report the same pixel-level proof line style as sheet-gui, plus a
    content marker line per data point (pipe-separated) so tests can assert
    content without pixel parsing.

    Then scripts a fixed ChartGuiSession op sequence (CHART GUI
    INTERACTIVITY): set_title "Sales*" -> set_value_range C1:C4 (the demo
    sheet's second, Sales, data column). Each step prints an "office-gui-
    chart-step: <op> -> kind=<k> range=<r>" marker line, followed by the
    resulting chart_session_view's own "office-gui-chart: <line>" dump
    lines -- proves the session pattern drives the SAME chart_gui_view
    render the static (pre-step) dump above uses, with no render
    duplication."""
    val sheet = _build_office_gui_chart_demo()
    val view = chart_gui_view(sheet, "bar", "B1:B4", "A1:A4", "Demo Chart", 80, 40)
    val pixels = office_gui_chart_pixels(view)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for chart-gui"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui: chart-gui frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-chart: {line}"

    var session = chart_session_new(sheet, "bar", "B1:B4", "A1:A4", "Demo Chart")

    session = chart_session_set_title(session, "Sales*")
    print "office-gui-chart-step: set_title Sales* -> kind={session.chart_kind} range={session.value_range}"
    val view1 = chart_session_view(session)
    for line1 in view1.text_dump.split("\n"):
        print "office-gui-chart: {line1}"

    session = chart_session_set_value_range(session, "C1:C4")
    print "office-gui-chart-step: set_value_range C1:C4 -> kind={session.chart_kind} range={session.value_range}"
    val view2 = chart_session_view(session)
    for line2 in view2.text_dump.split("\n"):
        print "office-gui-chart: {line2}"

    # Kind lift (COLUMN/PIE GUI kinds): drive the SAME session through the
    # two new chart_gui_view render branches. Column keeps the bar kind's
    # pct-of-max scale ("col|..." lines); pie switches to share-of-TOTAL
    # ("pie|..." lines -- C1:C4 = 5/15/10/20, total 50 -> 10/30/20/40).
    session = chart_session_set_kind(session, "column")
    print "office-gui-chart-step: set_kind column -> kind={session.chart_kind} range={session.value_range}"
    val view3 = chart_session_view(session)
    for line3 in view3.text_dump.split("\n"):
        print "office-gui-chart: {line3}"

    session = chart_session_set_kind(session, "pie")
    print "office-gui-chart-step: set_kind pie -> kind={session.chart_kind} range={session.value_range}"
    val view4 = chart_session_view(session)
    for line4 in view4.text_dump.split("\n"):
        print "office-gui-chart: {line4}"

    return 0

fn _build_office_gui_pivot_demo() -> Sheet:
    """Build the demo sheet for `office pivot-gui`: Region/Product/Amount
    header row + 6 data rows (East/West x A/B mix -- same dataset shape the
    pivot engine's own spec hand-verifies in
    test/01_unit/app/office/sheets/pivot_spec.spl), pivoted region x product
    with SUM through pivot_gui_view/office_gui_pivot_pixels."""
    var sheet = Sheet.new("PivotDemo")
    sheet.set_value("A1", "Region")
    sheet.set_value("B1", "Product")
    sheet.set_value("C1", "Amount")
    sheet.set_value("A2", "East")
    sheet.set_value("B2", "A")
    sheet.set_value("C2", "10")
    sheet.set_value("A3", "East")
    sheet.set_value("B3", "B")
    sheet.set_value("C3", "20")
    sheet.set_value("A4", "West")
    sheet.set_value("B4", "A")
    sheet.set_value("C4", "30")
    sheet.set_value("A5", "West")
    sheet.set_value("B5", "B")
    sheet.set_value("C5", "40")
    sheet.set_value("A6", "East")
    sheet.set_value("B6", "A")
    sheet.set_value("C6", "5")
    sheet.set_value("A7", "West")
    sheet.set_value("B7", "B")
    sheet.set_value("C7", "15")
    sheet

fn _run_office_gui_pivot_command() -> i32:
    """Render the demo sheet's region x product SUM pivot through the real
    UI stack and report the same pixel-level proof line style as sheet-gui/
    chart-gui, plus a content marker line per pivot row (pipe-separated) so
    tests can assert content without pixel parsing.

    Then scripts a fixed PivotGuiSession op sequence (PIVOT-TABLE
    INTERACTIVITY): set_agg average -> swap_fields -> set_agg count. Each
    step prints an "office-gui-pivot-step: <op> -> agg=<agg>
    rows=<row_col> cols=<col_col>" marker line, followed by the resulting
    pivot_session_view's own "office-gui-pivot: <line>" dump lines -- proves
    the session pattern drives the SAME pivot_gui_view render the static
    (pre-step) dump above uses, with no render duplication."""
    val sheet = _build_office_gui_pivot_demo()
    val view = pivot_gui_view(sheet, "A2:C7", 0, 1, 2, "SUM", "Region x Product")
    val pixels = office_gui_pivot_pixels(view)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for pivot-gui"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui: pivot-gui frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-pivot: {line}"

    var session = pivot_session_new(sheet, "A2:C7", 0, 1, 2, "SUM", "Region x Product")

    session = pivot_session_set_agg(session, "average")
    val letters1 = pivot_session_field_letters(session)
    print "office-gui-pivot-step: set_agg average -> agg={session.agg_name} rows={letters1.0} cols={letters1.1}"
    val view1 = pivot_session_view(session)
    for line1 in view1.text_dump.split("\n"):
        print "office-gui-pivot: {line1}"

    session = pivot_session_swap_fields(session)
    val letters2 = pivot_session_field_letters(session)
    print "office-gui-pivot-step: swap_fields -> agg={session.agg_name} rows={letters2.0} cols={letters2.1}"
    val view2 = pivot_session_view(session)
    for line2 in view2.text_dump.split("\n"):
        print "office-gui-pivot: {line2}"

    session = pivot_session_set_agg(session, "count")
    val letters3 = pivot_session_field_letters(session)
    print "office-gui-pivot-step: set_agg count -> agg={session.agg_name} rows={letters3.0} cols={letters3.1}"
    val view3 = pivot_session_view(session)
    for line3 in view3.text_dump.split("\n"):
        print "office-gui-pivot: {line3}"

    return 0

fn _build_office_gui_slides_demo_deck() -> [Slide]:
    """Demo deck for `office slides-gui` when no file argument is given:
    3 slides (a title slide, a bullets slide with two nesting levels, and a
    table slide), built by parsing inline deck text through the REAL
    deck_format parser (parse_deck) -- the exact load path a deck.md file
    argument takes, not a bespoke hand-assembled model."""
    val deck_text = "Demo Deck\nWelcome to Simple Slides\n@layout: title-only\n---\nAgenda\n- First point\n  - Nested detail\n- Second point\n---\nResults\n| Region | Sales |\n| --- | --- |\n| East | 10 |\n| West | 20 |"
    parse_deck(deck_text)

fn _run_office_gui_slides_command(args: [text]) -> i32:
    """`office slides-gui [deck.md]`: load a deck (parse_deck over the named
    file, or the inline 3-slide demo deck when no file is given), render
    slide 1 through the real UI stack with the same pixel-level proof line
    style as sheet-gui/chart-gui/pivot-gui plus "office-gui-slides: <line>"
    content marker lines, then script a fixed presenter key sequence
    (SLIDE PRESENTER SURFACE): n -> n -> p -> 3 (next, next, prev, digit
    goto). Each step prints an "office-gui-slides-step: <key> ->
    slide=<n>/<total>" marker line followed by the resulting
    slide_session_view's own dump lines -- proves the session pattern drives
    the SAME slide_gui_view render the static (pre-step) dump above uses,
    with no render duplication."""
    var deck: [Slide] = []
    if args.len() > 1:
        val deck_path = args[1]
        if not file_exists(deck_path):
            print "Error: deck file not found: {deck_path}"
            return 1
        val deck_content = read_file(deck_path)
        deck = parse_deck(deck_content)
    else:
        deck = _build_office_gui_slides_demo_deck()
    var total = 0
    for s in deck:
        total = total + 1
    if total == 0:
        print "Error: deck has no slides"
        return 1

    var session = slide_session_new(deck)
    val view = slide_session_view(session)
    val pixels = office_gui_slide_pixels(view)
    if pixels.len() == 0:
        print "Error: office GUI render produced an empty frame for slides-gui"
        return 1
    val non_background = office_gui_non_background_pixel_count(pixels)
    print "office-gui: slides-gui frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels"
    for line in view.text_dump.split("\n"):
        print "office-gui-slides: {line}"

    val keys = ["n", "n", "p", "3"]
    for k in keys:
        var step_res = slide_gui_step(session, k)
        session = step_res.session
        print "office-gui-slides-step: {k} -> slide={session.current_index + 1}/{total}"
        val step_view = slide_session_view(session)
        for step_line in step_view.text_dump.split("\n"):
            print "office-gui-slides: {step_line}"
    return 0

fn _run_office_gui_slides_live_command(args: [text]) -> i32:
    """`office slides-gui-live [deck.md]`: the live interactive slide
    presenter -- real termios raw mode, arrow keys (right/space -> next,
    left -> prev), n/p, digit goto, q/Ctrl-C quits, one real-pixel-path
    frame re-rendered per keystroke. Deck loading mirrors `office
    slides-gui` exactly: parse_deck over the named file, or the inline
    3-slide demo deck when no file is given. The loop itself lives in
    interactive.spl (run_slides_gui_live), which also handles the non-TTY
    case (piped stdin prints one frame plus a notice and exits 0)."""
    var deck: [Slide] = []
    if args.len() > 1:
        val deck_path = args[1]
        if not file_exists(deck_path):
            print "Error: deck file not found: {deck_path}"
            return 1
        val deck_content = read_file(deck_path)
        deck = parse_deck(deck_content)
    else:
        deck = _build_office_gui_slides_demo_deck()
    var total = 0
    for s in deck:
        total = total + 1
    if total == 0:
        print "Error: deck has no slides"
        return 1
    run_slides_gui_live(deck)

fn _run_office_notes_demo() -> i32:
    """Notes MVP demo: 2 sections, 3 pages, one search."""
    var nb = notebook_new("Demo Notebook")
    nb = add_section(nb, "Work")
    nb = add_section(nb, "Personal")
    nb = add_page(nb, "Work", "Standup", "# Standup\n\nDiscuss roadmap and blockers.")
    nb = add_page(nb, "Work", "Roadmap", "# Roadmap\n\nQ3 priorities: search and sync.")
    nb = add_page(nb, "Personal", "Groceries", "- milk\n- bread")
    val section_count = nb.section_names.len()
    val page_count = nb.page_titles.len()
    print "office-notes: notebook={nb.name} sections={section_count} pages={page_count}"
    val hits = notes_search(nb, "roadmap")
    for h in hits:
        print "office-notes: hit {h}"
    return 0

fn _run_office_db_demo() -> i32:
    """Access-like DB demo: a 3-row employees table + a case-insensitive
    dept filter through query_select_where."""
    var t = table_new("employees", ["id", "name", "dept"])
    t = table_insert(t, ["1", "Alice", "Eng"])
    t = table_insert(t, ["2", "Bob", "Sales"])
    t = table_insert(t, ["3", "Carol", "Eng"])
    val eng = query_select_where(t, "dept", "=", "eng")
    val total = table_row_count(t)
    val eng_rows = table_row_count(eng)
    print "office-db: table={t.name} rows={total} dept=eng matches={eng_rows}"
    return 0

fn _run_office_report_demo() -> i32:
    """Access-like banded report demo: group sales by region, sum amounts,
    print the banded report (group headers, subtotals, grand total)."""
    var t = table_new("sales", ["region", "amount"])
    t = table_insert(t, ["East", "100"])
    t = table_insert(t, ["East", "200"])
    t = table_insert(t, ["West", "300"])
    t = table_insert(t, ["West", "400"])
    val banded = report_grouped(t, "region", "amount", "sum")
    print banded
    return 0

fn _run_office_publisher_demo() -> i32:
    """Publisher DTP demo: flow a sentence across two linked text frames,
    overflow spilling from f1 into f2."""
    var page = page_new(300, 200)
    val f1 = frame_new("f1", 0, 0, 66, 16, "f2")
    val f2 = frame_new("f2", 0, 20, 200, 40, "")
    page = page_add_frame(page, f1)
    page = page_add_frame(page, f2)
    page = page_flow_text(page, "f1", "The cat sat on the mat")
    val ft1 = frame_text(page, "f1")
    val ft2 = frame_text(page, "f2")
    val nframes = page_frame_count(page)
    print "office-publisher: frames={nframes} f1=[{ft1}] f2=[{ft2}]"
    return 0

fn run_office(args: [text]) -> i32:
    """Dispatch to the requested office app or show the launcher."""
    val cmd = if args.len() > 0: args[0] else: "launcher"
    match cmd:
        "launcher" =>
            val store = RecentFileStore.new(20)
            val recent = store.get_recent(10)
            val ui = build_launcher_ui(recent)
            print "Simple Office Launcher loaded (root={ui.root_id}, recent={recent.len()})"
            return 0
        "word" =>
            val app = WordApp.new()
            val ui = app.build_ui()
            print "Simple Word loaded (root={ui.root_id}, words={app.word_count()}, modified={app.modified})"
            return 0
        "sheets" =>
            val app = SheetsApp.new()
            val ui = app.build_ui()
            val active_ref = cell_ref_to_string(app.active_cell)
            print "Simple Sheets loaded (root={ui.root_id}, sheets={app.workbook.sheets.len()}, active={active_ref})"
            return 0
        "slides" =>
            val app = SlidesApp.new()
            val ui = app.build_ui()
            print "Simple Slides loaded (root={ui.root_id}, slides={slide_count(app.presentation)}, modified={app.modified})"
            return 0
        "mail" =>
            val app = MailApp.new()
            val ui = app.build_ui()
            print "Simple Mail loaded (root={ui.root_id}, emails={app.emails.len()}, unread={app.unread_count()})"
            return 0
        "planner" =>
            val app = PlannerApp.new()
            val ui = app.build_ui()
            print "Simple Planner loaded (root={ui.root_id}, tasks={app.project.tasks.len()}, view={app.active_view})"
            return 0
        "counter" =>
            if args.len() > 1 and args[1] == "--gui":
                return _run_office_gui_command("counter")
            val app = CounterApp.new()
            val ui = app.build_ui()
            print "Simple Counter loaded (root={ui.root_id}, value={app.value}, modified={app.modified})"
            return 0
        "notes-demo" =>
            return _run_office_notes_demo()
        "db-demo" =>
            return _run_office_db_demo()
        "report-demo" =>
            return _run_office_report_demo()
        "publisher-demo" =>
            return _run_office_publisher_demo()
        "sheet-gui" =>
            return _run_office_gui_sheet_command()
        "sheet-gui-edit" =>
            return _run_office_gui_sheet_edit_command()
        "sheet-gui-click" =>
            return _run_office_gui_sheet_click_command()
        "sheet-gui-key" =>
            return _run_office_gui_sheet_key_command()
        "sheet-gui-scroll" =>
            return _run_office_gui_sheet_scroll_command()
        "sheet-gui-live" =>
            return _run_office_gui_sheet_live_command()
        "sheet-gui-cf" =>
            return _run_office_gui_sheet_cf_command()
        "sheet-gui-fmt" =>
            return _run_office_gui_sheet_fmt_command()
        "sheet-gui-undo" =>
            return _run_office_gui_sheet_undo_command()
        "chart-gui" =>
            return _run_office_gui_chart_command()
        "pivot-gui" =>
            return _run_office_gui_pivot_command()
        "slides-gui" =>
            return _run_office_gui_slides_command(args)
        "slides-gui-live" =>
            return _run_office_gui_slides_live_command(args)
        "render" =>
            return _run_render_command(args)
        "edit-sheet" =>
            if args.len() < 2:
                print "Usage: simple office edit-sheet <file.csv|.ods|.xlsx> [--screen]"
                return 1
            if args.len() > 2 and args[2] == "--tui":
                return _run_sheet_tui(args[1])
            val screen_mode = args.len() > 2 and args[2] == "--screen"
            return run_sheet_editor_mode(args[1], screen_mode)
        "open" =>
            return _run_open_command(args)
        "convert" =>
            return _run_convert_command(args)
        "toc" =>
            return _run_toc_command(args)
        "merge" =>
            return _run_merge_command(args)
        "mail-merge" =>
            return _run_mail_merge_command(args)
        "sort-sheet" =>
            return _run_sort_sheet_command(args)
        "find" =>
            return _run_find_command(args)
        "find-sheet" =>
            return _run_find_sheet_command(args)
        "stats" =>
            return _run_stats_command(args)
        "chart" =>
            return _run_chart_command(args)
        "pivot" =>
            return _run_pivot_command(args)
        "md-edit" =>
            return _run_markdown_edit_command(args)
        "sheet-edit" =>
            return _run_sheet_edit_command(args)
        "slide-edit" =>
            return _run_slide_edit_command(args)
        "erp-to-sheet" =>
            return _run_erp_to_sheet_command(args)
        "erp-invoice" =>
            return _run_erp_invoice_command(args)
        case _("unsupported office app names show usage"):
            print "Usage: simple office [launcher|word|sheets|slides|mail|planner|counter|sheet-gui|sheet-gui-edit|sheet-gui-click|sheet-gui-key|sheet-gui-scroll|sheet-gui-cf|sheet-gui-undo|chart-gui|pivot-gui|render|open|convert|toc|merge|mail-merge|sort-sheet|find|find-sheet|stats|chart|pivot|md-edit|sheet-edit|slide-edit|erp-to-sheet|erp-invoice]"
            return 1

fn _basename(path: text) -> text:
    val parts = path.split("/")
    if parts.len() == 0:
        return path
    parts[parts.len() - 1]

fn _run_open_command(args: [text]) -> i32:
    """Open a real document file and render it to a styled HTML page.

    Usage: simple office open <word|sheets|slides> <in-file> [out.html]"""
    if args.len() < 3:
        print "Usage: simple office open <word|sheets|slides> <in-file> [out.html]"
        return 1
    val surface = args[1]
    val in_path = args[2]
    if not file_exists(in_path):
        print "office-open: rejected (missing-file: {in_path})"
        return 2
    val content = read_file(in_path)
    val result = office_render_source(surface, _basename(in_path), content)
    print result.text_output
    if args.len() > 3:
        val out_path = args[3]
        if write_file(out_path, result.html_output):
            print "office-open: wrote {result.html_output.len()} bytes to {out_path}"
            return 0
        print "office-open: failed to write {out_path}"
        return 2
    return 0

fn _run_convert_command(args_in: [text]) -> i32:
    """Round-trip a document through parse+serialize, proving persistence.

    Usage: simple office convert <word|sheets|slides> <in-file> <out-file> [--styles <fmt-file>]

    `--styles` (sheets only, .xlsx/.fods outputs) applies per-cell formats
    from a plain-text spec file — one cell per line, e.g.
    `B2 num_fmt=0.00 bold bg=#ffe4b5 fg=#7a2e00` (see macro_parse_formats)."""
    var args: [text] = []
    var styles_path = ""
    var ai = 0
    while ai < args_in.len():
        if args_in[ai] == "--styles" and ai + 1 < args_in.len():
            styles_path = args_in[ai + 1]
            ai = ai + 2
        else:
            args.push(args_in[ai])
            ai = ai + 1
    if args.len() < 4:
        print "Usage: simple office convert <word|sheets|slides> <in-file> <out-file> [--styles <fmt-file>]"
        return 1
    if styles_path != "" and not file_exists(styles_path):
        print "office-convert: rejected (missing-styles: {styles_path})"
        return 2
    val surface = args[1]
    val in_path = args[2]
    val out_path = args[3]
    if not file_exists(in_path):
        print "office-convert: rejected (missing-file: {in_path})"
        return 2
    var serialized = ""
    if surface == "word" or surface == "writer":
        var doc = parse_markdown_document("", _basename(in_path))
        if in_path.ends_with(".odt") or in_path.ends_with(".docx"):
            val zip_bytes = file_read_bytes(in_path)
            if zip_bytes == nil:
                print "office-convert: rejected (unreadable: {in_path})"
                return 2
            if in_path.ends_with(".odt"):
                doc = odt_bytes_to_document(zip_bytes, _basename(in_path))
            else:
                doc = docx_bytes_to_document(zip_bytes, _basename(in_path))
        else:
            doc = parse_markdown_document(read_file(in_path), _basename(in_path))
        if out_path.ends_with(".odt"):
            val odt = document_to_odt_bytes(doc)
            if file_write_bytes(out_path, odt):
                print "office-convert: {surface} {in_path} -> {out_path} ({odt.len()} bytes, odt)"
                return 0
            print "office-convert: failed to write {out_path}"
            return 2
        if out_path.ends_with(".docx"):
            val docx = document_to_docx_bytes(doc)
            if file_write_bytes(out_path, docx):
                print "office-convert: {surface} {in_path} -> {out_path} ({docx.len()} bytes, docx)"
                return 0
            print "office-convert: failed to write {out_path}"
            return 2
        if out_path.ends_with(".fodt"):
            serialized = document_to_fodt(doc)
        else:
            serialized = document_to_markdown(doc)
    elif surface == "sheets" or surface == "calc" or surface == "excel":
        var sheet = Sheet.new(_basename(in_path))
        if in_path.ends_with(".ods") or in_path.ends_with(".xlsx"):
            val zip_bytes = file_read_bytes(in_path)
            if zip_bytes == nil:
                print "office-convert: rejected (unreadable: {in_path})"
                return 2
            if in_path.ends_with(".ods"):
                sheet = ods_bytes_to_sheet(zip_bytes, _basename(in_path))
            else:
                sheet = xlsx_bytes_to_sheet(zip_bytes, _basename(in_path))
        else:
            sheet = parse_csv_sheet(read_file(in_path), _basename(in_path))
        if out_path.ends_with(".ods") or out_path.ends_with(".xlsx"):
            var container: [u8] = []
            if out_path.ends_with(".ods"):
                container = sheet_to_ods_bytes(sheet)
            elif styles_path != "":
                val fmts = macro_parse_formats(read_file(styles_path))
                container = sheet_to_xlsx_bytes_formatted(sheet, fmts)
            else:
                container = sheet_to_xlsx_bytes(sheet)
            if file_write_bytes(out_path, container):
                print "office-convert: {surface} {in_path} -> {out_path} ({container.len()} bytes, zip)"
                return 0
            print "office-convert: failed to write {out_path}"
            return 2
        if out_path.ends_with(".fods"):
            if styles_path != "":
                val fmts = macro_parse_formats(read_file(styles_path))
                serialized = sheet_to_fods_formatted(sheet, fmts)
            else:
                serialized = sheet_to_fods(sheet)
        else:
            serialized = sheet_to_csv(sheet)
    elif surface == "slides" or surface == "impress" or surface == "ppt":
        var deck: [Slide] = []
        if in_path.ends_with(".pptx"):
            val zip_bytes = file_read_bytes(in_path)
            if zip_bytes == nil:
                print "office-convert: rejected (unreadable: {in_path})"
                return 2
            deck = pptx_bytes_to_deck(zip_bytes)
        else:
            deck = parse_deck(read_file(in_path))
        if out_path.ends_with(".pptx"):
            val pptx = deck_to_pptx_bytes(deck)
            if file_write_bytes(out_path, pptx):
                print "office-convert: {surface} {in_path} -> {out_path} ({pptx.len()} bytes, pptx)"
                return 0
            print "office-convert: failed to write {out_path}"
            return 2
        serialized = deck_to_text(deck)
    else:
        print "office-convert: rejected (unsupported-surface: {surface})"
        return 1
    if write_file(out_path, serialized):
        print "office-convert: {surface} {in_path} -> {out_path} ({serialized.len()} bytes)"
        return 0
    print "office-convert: failed to write {out_path}"
    return 2

fn _run_render_command(args: [text]) -> i32:
    """Render an office surface to a styled HTML page.

    Usage: simple office render [word|sheets|slides|suite] [out.html]"""
    val surface = if args.len() > 1: args[1] else: "suite"
    var cfg = RenderConfig.html_export()
    cfg.adapter_name = surface
    val result = office_render(cfg)
    print result.text_output
    if args.len() > 2:
        val out_path = args[2]
        if write_file(out_path, result.html_output):
            print "office-render: wrote {result.html_output.len()} bytes to {out_path}"
            return 0
        print "office-render: failed to write {out_path}"
        return 2
    return 0

fn _run_toc_command(args: [text]) -> i32:
    """Insert a numbered table of contents at the top of a markdown document.

    Usage: simple office toc <in.md> <out.md> [--depth N]"""
    if args.len() < 3:
        print "Usage: simple office toc <in.md> <out.md> [--depth N]"
        return 1
    val in_path = args[1]
    val out_path = args[2]
    if not file_exists(in_path):
        print "office-toc: rejected (missing-file: {in_path})"
        return 2
    var depth: i32 = 3
    if args.len() > 3:
        if args[3] != "--depth" or args.len() < 5 or not _is_office_cli_non_negative_i32_token(args[4]):
            print "office-toc: rejected (invalid-option; expected --depth N)"
            return 1
        depth = args[4].to_i32()
    val doc = parse_markdown_document(read_file(in_path), _basename(in_path))
    val with_toc = toc_generate(doc, depth, "Contents")
    val serialized = document_to_markdown(with_toc)
    if write_file(out_path, serialized):
        print "office-toc: {in_path} -> {out_path} (depth={depth}, {serialized.len()} bytes)"
        return 0
    print "office-toc: failed to write {out_path}"
    return 2

fn _run_merge_command(args: [text]) -> i32:
    """Mail-merge a markdown template against CSV data rows (header row 1).

    Usage: simple office merge <template.md> <data.csv> <out.md>"""
    if args.len() < 4:
        print "Usage: simple office merge <template.md> <data.csv> <out.md>"
        return 1
    val template_path = args[1]
    val data_path = args[2]
    val out_path = args[3]
    if not file_exists(template_path):
        print "office-merge: rejected (missing-file: {template_path})"
        return 2
    if not file_exists(data_path):
        print "office-merge: rejected (missing-file: {data_path})"
        return 2
    val doc = parse_markdown_document(read_file(template_path), _basename(template_path))
    val sheet = parse_csv_sheet(read_file(data_path), _basename(data_path))
    val merged = merge_all_markdown(doc, sheet)
    if write_file(out_path, merged):
        print "office-merge: {template_path} + {data_path} -> {out_path} ({merged.len()} bytes)"
        return 0
    print "office-merge: failed to write {out_path}"
    return 2

fn _mail_merge_load_template(template_path: text) -> RichDocument:
    """Load a mail-merge template document from .md or .docx (mirrors
    `office open`'s doc-loading branch by extension)."""
    if template_path.ends_with(".docx"):
        return docx_bytes_to_document(file_read_bytes(template_path), _basename(template_path))
    parse_markdown_document(read_file(template_path), _basename(template_path))

fn _mail_merge_write_record(doc: RichDocument, template_path: text, out_dir: text, index: i32) -> text:
    """Write one merged record document to out_dir/record_<index>.<ext>
    (ext follows the template's format: docx or md), returning the path
    written or "" on failure."""
    val out_dir_clean = if out_dir.ends_with("/"): out_dir.slice(0, out_dir.len() - 1) else: out_dir
    if template_path.ends_with(".docx"):
        val out_path = "{out_dir_clean}/record_{index}.docx"
        val bytes = document_to_docx_bytes(doc)
        if file_write_bytes(out_path, bytes):
            return out_path
        return ""
    val out_path = "{out_dir_clean}/record_{index}.md"
    val md = document_to_markdown(doc)
    if write_file(out_path, md):
        return out_path
    ""

fn _run_mail_merge_command(args: [text]) -> i32:
    """Inspect, preview, or run a mail merge with fail-closed validation.

    Usage: simple office mail-merge <template.md-or-docx> <records.csv> [--preview N] [--out dir]

    Validation issues (missing header columns, blank per-record values,
    unused CSV columns) print first as warnings; the run still proceeds on
    a nonzero-issue count (Office behavior). With --preview N, prints the
    merged text of data record N (1-based) as "office-mail-merge:"-prefixed
    lines instead of writing files. Without --preview, writes one merged
    document per data row into --out (default build/mail_merge_out),
    printing each file written."""
    if args.len() < 3:
        print "Usage: simple office mail-merge <template.md-or-docx> <records.csv> [--preview N] [--out dir]"
        return 1
    val template_path = args[1]
    val data_path = args[2]
    if not file_exists(template_path):
        print "office-mail-merge: rejected (missing-file: {template_path})"
        return 2
    if not file_exists(data_path):
        print "office-mail-merge: rejected (missing-file: {data_path})"
        return 2

    var preview_index: i32 = -1
    var out_dir = "build/mail_merge_out"
    var i = 3
    while i < args.len():
        val opt = args[i]
        if opt == "--preview" and i + 1 < args.len() and _is_office_cli_non_negative_i32_token(args[i + 1]):
            preview_index = args[i + 1].to_i32()
            i = i + 2
        elif opt == "--out" and i + 1 < args.len():
            out_dir = args[i + 1]
            i = i + 2
        else:
            print "office-mail-merge: rejected (invalid-option: {opt})"
            return 1

    val doc = _mail_merge_load_template(template_path)
    val sheet = parse_csv_sheet(read_file(data_path), _basename(data_path))

    val issues = merge_validate(doc, sheet)
    for issue in issues:
        print "office-mail-merge: warning: {issue}"

    if preview_index >= 0:
        val merged = merge_preview(doc, sheet, preview_index)
        val text = document_to_markdown(merged)
        for line in text.split("\n"):
            print "office-mail-merge: {line}"
        return 0

    mkdir_p(out_dir)
    val docs = merge_all(doc, sheet)
    var idx = 1
    for merged in docs:
        val written = _mail_merge_write_record(merged, template_path, out_dir, idx)
        if written == "":
            print "office-mail-merge: failed to write record {idx}"
        else:
            print "office-mail-merge: wrote {written}"
        idx = idx + 1
    return 0

fn _run_sort_sheet_command(args: [text]) -> i32:
    """Sort a CSV range by a key column and write the sorted sheet back out.

    Usage: simple office sort-sheet <in.csv> <range> <key_col> <out.csv> [--desc] [--header]"""
    if args.len() < 5:
        print "Usage: simple office sort-sheet <in.csv> <range> <key_col> <out.csv> [--desc] [--header]"
        return 1
    val in_path = args[1]
    val range_a1 = args[2]
    val key_col_token = args[3]
    val out_path = args[4]
    if not file_exists(in_path):
        print "office-sort-sheet: rejected (missing-file: {in_path})"
        return 2
    if parse_range(range_a1) == nil:
        print "office-sort-sheet: rejected (invalid-range: {range_a1})"
        return 2
    if not _is_office_cli_non_negative_i32_token(key_col_token):
        print "office-sort-sheet: rejected (invalid-key-col: {key_col_token})"
        return 2
    val key_col = key_col_token.to_i32()
    var ascending = true
    var has_header = false
    var i = 5
    while i < args.len():
        if args[i] == "--desc":
            ascending = false
        elif args[i] == "--header":
            has_header = true
        else:
            print "office-sort-sheet: rejected (unknown-option: {args[i]})"
            return 1
        i = i + 1
    val sheet = parse_csv_sheet(read_file(in_path), _basename(in_path))
    val sorted = sheet_sort_range(sheet, range_a1, key_col, ascending, has_header)
    val serialized = sheet_to_csv(sorted)
    if write_file(out_path, serialized):
        print "office-sort-sheet: {in_path} {range_a1} col={key_col} -> {out_path} ({serialized.len()} bytes)"
        return 0
    print "office-sort-sheet: failed to write {out_path}"
    return 2

fn _run_find_command(args: [text]) -> i32:
    """Print document_find hits as blockIndex:charOffset, one per line.

    Usage: simple office find <in.md> <needle>"""
    if args.len() < 3:
        print "Usage: simple office find <in.md> <needle>"
        return 1
    val in_path = args[1]
    val needle = args[2]
    if not file_exists(in_path):
        print "office-find: rejected (missing-file: {in_path})"
        return 2
    val doc = parse_markdown_document(read_file(in_path), _basename(in_path))
    val hits = document_find(doc, needle)
    for hit in hits:
        print hit
    return 0

fn _run_find_sheet_command(args: [text]) -> i32:
    """Print sheet cells (A1 refs, one per line) whose display text contains
    needle, case-insensitive.

    Usage: simple office find-sheet <in.csv> <needle>"""
    if args.len() < 3:
        print "Usage: simple office find-sheet <in.csv> <needle>"
        return 1
    val in_path = args[1]
    val needle = args[2]
    if not file_exists(in_path):
        print "office-find-sheet: rejected (missing-file: {in_path})"
        return 2
    val sheet = parse_csv_sheet(read_file(in_path), _basename(in_path))
    val hits = sheet_find(sheet, needle, false)
    for hit in hits:
        print hit
    return 0

fn _run_stats_command(args: [text]) -> i32:
    """Print word/character/paragraph counts for a markdown document.

    Usage: simple office stats <in.md>"""
    if args.len() < 2:
        print "Usage: simple office stats <in.md>"
        return 1
    val in_path = args[1]
    if not file_exists(in_path):
        print "office-stats: rejected (missing-file: {in_path})"
        return 2
    val doc = parse_markdown_document(read_file(in_path), _basename(in_path))
    val stats = document_stats(doc)
    print "words: {stats.words}"
    print "characters: {stats.characters}"
    print "paragraphs: {stats.paragraphs}"
    return 0

fn _office_chart_stem(path: text) -> text:
    val base = _basename(path)
    val parts = base.split(".")
    if parts.len() <= 1:
        return base
    parts[0:parts.len() - 1].join(".")

fn _chart_split_columns(range_a1: text) -> [text]:
    """Split a two-column A1 range into [first-column-range, second-column-range]."""
    val r = parse_range(range_a1)
    if r == nil:
        return []
    val min_col = if r.start.col < r.end_ref.col: r.start.col else: r.end_ref.col
    val max_col = if r.start.col > r.end_ref.col: r.start.col else: r.end_ref.col
    val min_row = if r.start.row < r.end_ref.row: r.start.row else: r.end_ref.row
    val max_row = if r.start.row > r.end_ref.row: r.start.row else: r.end_ref.row
    if max_col - min_col != 1:
        return []
    val a_top = cell_ref_to_string(CellRef(col: min_col, row: min_row))
    val a_bot = cell_ref_to_string(CellRef(col: min_col, row: max_row))
    val b_top = cell_ref_to_string(CellRef(col: max_col, row: min_row))
    val b_bot = cell_ref_to_string(CellRef(col: max_col, row: max_row))
    ["{a_top}:{a_bot}", "{b_top}:{b_bot}"]

fn _run_chart_command(args: [text]) -> i32:
    """Render a chart SVG from a CSV sheet range (labels col 1, values col 2).

    Usage: simple office chart <in.csv> <bar|line|pie|scatter|area> <out.svg> [--title T] [--range A1:B4] [--range2 C1:C4]"""
    if args.len() < 4:
        print "Usage: simple office chart <in.csv> <bar|line|pie|scatter|area> <out.svg> [--title T] [--range A1:B4] [--range2 C1:C4]"
        return 1
    val in_path = args[1]
    val chart_type = args[2]
    val out_path = args[3]
    if not file_exists(in_path):
        print "office-chart: rejected (missing-file: {in_path})"
        return 2
    if chart_type != "bar" and chart_type != "line" and chart_type != "pie" and chart_type != "scatter" and chart_type != "area":
        print "office-chart: rejected (unknown-type: {chart_type})"
        return 1
    var title = ""
    var range_a1 = ""
    var range2_a1 = ""
    var i = 4
    while i < args.len():
        if args[i] == "--title" and i + 1 < args.len():
            title = args[i + 1]
            i = i + 2
        elif args[i] == "--range" and i + 1 < args.len():
            range_a1 = args[i + 1]
            i = i + 2
        elif args[i] == "--range2" and i + 1 < args.len():
            range2_a1 = args[i + 1]
            i = i + 2
        else:
            print "office-chart: rejected (unknown-option: {args[i]})"
            return 1
    val sheet = parse_csv_sheet(read_file(in_path), _basename(in_path))
    if range_a1 == "":
        range_a1 = sheet.used_range()
    if parse_range(range_a1) == nil:
        print "office-chart: rejected (invalid-range: {range_a1})"
        return 2
    if range2_a1 != "" and parse_range(range2_a1) == nil:
        print "office-chart: rejected (invalid-range: {range2_a1})"
        return 2
    var label_range = ""
    var value_range = ""
    if range2_a1 != "":
        label_range = range_a1
        value_range = range2_a1
    else:
        val cols = _chart_split_columns(range_a1)
        if cols.len() != 2:
            print "office-chart: rejected (range-needs-two-columns: {range_a1})"
            return 2
        label_range = cols[0]
        value_range = cols[1]
    if title == "":
        title = _office_chart_stem(out_path)
    var svg = ""
    if chart_type == "bar":
        svg = sheet_bar_chart_svg(sheet, label_range, value_range, title)
    elif chart_type == "line":
        svg = sheet_line_chart_svg(sheet, label_range, value_range, title)
    elif chart_type == "pie":
        svg = sheet_pie_chart_svg(sheet, label_range, value_range, title)
    elif chart_type == "area":
        svg = sheet_area_chart_svg(sheet, label_range, value_range, title)
    else:
        svg = sheet_scatter_chart_svg(sheet, label_range, value_range, title)
    if write_file(out_path, svg):
        print "office-chart: {chart_type} {in_path} {range_a1} -> {out_path} ({svg.len()} bytes)"
        return 0
    print "office-chart: failed to write {out_path}"
    return 2

fn _run_pivot_command(args_in: [text]) -> i32:
    """Group a CSV range by one or two key columns and aggregate a value
    column (SUM/COUNT/AVERAGE/MIN/MAX), printing the resulting pivot grid as
    a pipe-delimited table (one sheet row per output line).

    Usage: simple office pivot <in.csv> <range> <row_col> <val_col> <agg> [--col <col>]

    All column indices are 0-based WITHIN <range>. Without --col this is a
    one-dimensional pivot (single value column); with --col it cross-tabs
    row_col x col."""
    var args: [text] = []
    var col_key_token = ""
    var have_col = false
    var ai = 0
    while ai < args_in.len():
        if args_in[ai] == "--col" and ai + 1 < args_in.len():
            col_key_token = args_in[ai + 1]
            have_col = true
            ai = ai + 2
        else:
            args.push(args_in[ai])
            ai = ai + 1
    if args.len() < 6:
        print "Usage: simple office pivot <in.csv> <range> <row_col> <val_col> <agg> [--col <col>]"
        return 1
    val in_path = args[1]
    val range_a1 = args[2]
    val row_col_token = args[3]
    val val_col_token = args[4]
    val agg = args[5]
    if not file_exists(in_path):
        print "office-pivot: rejected (missing-file: {in_path})"
        return 2
    if parse_range(range_a1) == nil:
        print "office-pivot: rejected (invalid-range: {range_a1})"
        return 2
    if not _is_office_cli_non_negative_i32_token(row_col_token):
        print "office-pivot: rejected (invalid-row-col: {row_col_token})"
        return 2
    if not _is_office_cli_non_negative_i32_token(val_col_token):
        print "office-pivot: rejected (invalid-val-col: {val_col_token})"
        return 2
    if have_col and not _is_office_cli_non_negative_i32_token(col_key_token):
        print "office-pivot: rejected (invalid-col: {col_key_token})"
        return 2
    var col_key_col = -1
    if have_col:
        col_key_col = col_key_token.to_i32()
    val sheet = parse_csv_sheet(read_file(in_path), _basename(in_path))
    val result = pivot_build(sheet, range_a1, row_col_token.to_i32(), col_key_col, val_col_token.to_i32(), agg)
    if result.len() == 0:
        print "office-pivot: rejected (empty-result: bad range/column/agg or no data rows)"
        return 2
    var r = 0
    while r < result.len():
        val row = result[r]
        var line = ""
        var c = 0
        while c < row.len():
            if c == 0:
                line = row[c]
            else:
                line = "{line}|{row[c]}"
            c = c + 1
        print line
        r = r + 1
    return 0

fn _run_erp_to_sheet_command(args: [text]) -> i32:
    """Parse a Simple-ERP ubslog v1 records file (sale.write events) into a
    Sheet and write it out as CSV or XLSX.

    Usage: simple office erp-to-sheet <records-file> <out.csv|out.xlsx>"""
    if args.len() < 3:
        print "Usage: simple office erp-to-sheet <records-file> <out.csv|out.xlsx>"
        return 1
    val in_path = args[1]
    val out_path = args[2]
    if not file_exists(in_path):
        print "office-erp-to-sheet: rejected (missing-file: {in_path})"
        return 2
    val sheet = erp_records_to_sheet(read_file(in_path), _basename(in_path))
    if out_path.ends_with(".xlsx"):
        val bytes = sheet_to_xlsx_bytes(sheet)
        if file_write_bytes(out_path, bytes):
            print "office-erp-to-sheet: {in_path} -> {out_path} ({bytes.len()} bytes, xlsx)"
            return 0
        print "office-erp-to-sheet: failed to write {out_path}"
        return 2
    val csv = sheet_to_csv(sheet)
    if write_file(out_path, csv):
        print "office-erp-to-sheet: {in_path} -> {out_path} ({csv.len()} bytes, csv)"
        return 0
    print "office-erp-to-sheet: failed to write {out_path}"
    return 2

fn _run_erp_invoice_command(args: [text]) -> i32:
    """Render one ERP Sale row from a records file into an invoice document
    (default_invoice_template + mail-merge, app.office.erp_bridge).

    Usage: simple office erp-invoice <records-file> <row> <out.md|out.docx>"""
    if args.len() < 4:
        print "Usage: simple office erp-invoice <records-file> <row> <out.md|out.docx>"
        return 1
    val in_path = args[1]
    val row_token = args[2]
    val out_path = args[3]
    if not file_exists(in_path):
        print "office-erp-invoice: rejected (missing-file: {in_path})"
        return 2
    if not _is_office_cli_non_negative_i32_token(row_token):
        print "office-erp-invoice: rejected (invalid-row: {row_token})"
        return 2
    val row = row_token.to_i32()
    val sheet = erp_records_to_sheet(read_file(in_path), _basename(in_path))
    val doc = erp_invoice_from_sheet(sheet, row, default_invoice_template())
    if out_path.ends_with(".docx"):
        val bytes = document_to_docx_bytes(doc)
        if file_write_bytes(out_path, bytes):
            print "office-erp-invoice: {in_path} row={row} -> {out_path} ({bytes.len()} bytes, docx)"
            return 0
        print "office-erp-invoice: failed to write {out_path}"
        return 2
    val md = document_to_markdown(doc)
    if write_file(out_path, md):
        print "office-erp-invoice: {in_path} row={row} -> {out_path} ({md.len()} bytes, md)"
        return 0
    print "office-erp-invoice: failed to write {out_path}"
    return 2

fn _decode_office_cli_text(value: text) -> text:
    value.replace("\\n", "\n")

fn _is_office_cli_non_negative_i32_token(value: text) -> bool:
    if value.len() == 0:
        return false
    if value.len() > 9:
        return false
    var i = 0
    while i < value.len():
        val c = value.char_at(i)
        val code = c.char_code_at(0)
        if code < 48 or code > 57:
            return false
        i = i + 1
    true

fn _run_markdown_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office md-edit <line> <expected> <new> <source>"
        return 1
    if not _is_office_cli_non_negative_i32_token(args[1]):
        print "office-md-edit: rejected (invalid-line)"
        print "@@ line {args[1]} @@\nexpected: {args[2]}\nactual: <invalid-line>\nrejected: {args[3]}"
        return 2
    val line_no = args[1].to_i32()
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source = _decode_office_cli_text(args[4])
    val view = build_wysiwyg_view(source)
    val result = wysiwyg_update_line_checked(view, line_no, expected, replacement)
    if result.accepted:
        print "office-md-edit: updated"
        print result.diff
        print wysiwyg_source_pane(result.view).replace("\n", "\\n")
        return 0
    print "office-md-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _load_sheet_cli_source(source: text) -> Sheet:
    val sheet = Sheet.new("CLI")
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val ref_str = parts[0].trim()
                val value = parts[1:].join("=")
                if parse_cell_ref(ref_str) != nil:
                    sheet.set_value(ref_str, value)
    sheet

fn _sheet_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val ref_str = parts[0].trim()
            if parse_cell_ref(ref_str) == nil:
                return "invalid-source-ref"
    ""

fn _run_sheet_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office sheet-edit <cell> <expected> <new> <sheet-source>"
        return 1
    val cell_ref = args[1]
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _sheet_cli_source_error(args[4])
    if source_error != "":
        print "office-sheet-edit: rejected ({source_error})"
        return 2
    val sheet = _load_sheet_cli_source(args[4])
    val result = sheet.update_cell_checked(cell_ref, expected, replacement)
    if result.accepted:
        print "office-sheet-edit: updated"
        print result.diff
        print "{result.cell_ref}={result.new_value}"
        return 0
    print "office-sheet-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _slide_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val element_id = parts[0].trim()
            if element_id == "":
                return "missing-element-id"
    ""

fn _load_slide_cli_source(source: text) -> Slide:
    var slide = blank_slide("cli_slide")
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    var offset: i32 = 0
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val element_id = parts[0].trim()
                val value = parts[1:].join("=")
                if element_id != "":
                    slide = add_text_box(slide, element_id, value, 40, 40 + offset, 840, 60)
                    offset = offset + 72
    slide

fn _run_slide_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office slide-edit <element-id> <expected> <new> <slide-source>"
        return 1
    val element_id = args[1]
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _slide_cli_source_error(args[4])
    if source_error != "":
        print "office-slide-edit: rejected ({source_error})"
        return 2
    val slide = _load_slide_cli_source(args[4])
    val result = slide_update_text_checked(slide, element_id, expected, replacement)
    if result.accepted:
        print "office-slide-edit: updated"
        print result.diff
        print "{result.element_id}={result.new_value}"
        return 0
    print "office-slide-edit: rejected ({result.reason})"
    print result.diff
    return 2
