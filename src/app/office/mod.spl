        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-canvas", output: "", reason: "invalid-canvas-number")
    if args[3].trim() != "true" and args[3].trim() != "false":
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-canvas", output: "", reason: "invalid-canvas-snap")
    if not _is_office_cli_safe_css_value(args[5].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-canvas", output: "", reason: "invalid-canvas-background")
    val result = sdn_graph_update_canvas_checked(sdn_graph_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim(), args[5].trim())
