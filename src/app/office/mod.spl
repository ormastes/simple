fn _decode_office_cli_text(value: text) -> text:
    value.replace("\\n", "\n")

fn office_plugin_context(action_id: text, app_id: text, source_format: text, evidence_key: text) -> OfficePluginContext:
    OfficePluginContext(app_id: app_id, action_id: action_id, source_format: source_format, evidence_key: evidence_key)

fn office_action_dispatch(action: text, source: text) -> OfficeActionResult:
    office_action_dispatch_with_context(office_plugin_context(action, "", "", ""), source)

fn office_action_dispatch_with_context(context: OfficePluginContext, source: text) -> OfficeActionResult:
    if context.action_id.trim() == "":
        return OfficeActionResult(ok: false, code: 1, action: context.action_id, output: "", reason: "invalid-context")
    if not _office_action_context_matches_catalog(context):
        return OfficeActionResult(ok: false, code: 1, action: context.action_id, output: "", reason: "context-mismatch")
    if not _office_action_source_format_matches(context):
        return OfficeActionResult(ok: false, code: 1, action: context.action_id, output: "", reason: "source-format-mismatch")
    _office_action_dispatch_core(context.action_id, source)

fn _office_action_context_matches_catalog(context: OfficePluginContext) -> bool:
    if context.app_id.trim() == "" and context.evidence_key.trim() == "":
        return true
    for row in office_llm_feature_catalog():
        var has_action = false
        for action in row.actions:
            if action == context.action_id:
                has_action = true
        if has_action:
            val app_matches = context.app_id.trim() == "" or context.app_id == row.component or context.app_id == row.app_name.to_lower()
            val evidence_matches = context.evidence_key.trim() == "" or context.evidence_key == row.evidence_key
            if app_matches and evidence_matches:
                return true
    false

fn _office_action_source_format_matches(context: OfficePluginContext) -> bool:
    val format = context.source_format.trim()
    if format == "":
        return true
    val action = context.action_id
    if format == "markdown":
        return action == "md-edit" or action == "render-markdown-preview-html" or action.starts_with("writer-markdown-") or action.starts_with("render-writer-markdown-")
    if format == "slides":
        return action == "slide-edit" or action.starts_with("ppt-markdown-") or action.starts_with("render-ppt-markdown-")
    if format == "sdd" or format == "sdn":
        return action.starts_with("sdd-") or action.starts_with("render-sdd-") or action.starts_with("export-sdd-") or action.starts_with("edit-sdd-") or action.starts_with("add-sdd-") or action.starts_with("delete-sdd-") or action.starts_with("duplicate-sdd-") or action.starts_with("inspect-sdd-") or action.starts_with("align-sdd-") or action.starts_with("distribute-sdd-") or action == "reroute-sdd-connector" or action == "order-sdd-node"
    if format == "html-ui":
        return action.starts_with("ui-") or action.starts_with("render-ui-") or action.starts_with("export-ui-")
    if format == "table":
        return action == "query-table" or action == "base-table-summary" or action == "export-base-game-state" or action == "render-base-table-html" or action == "db-edit"
    if format == "sheet":
        return action == "sheet-edit" or action == "format-cell-value" or action == "evaluate-sheet-formula"
    if format == "math":
        return action.starts_with("render-math")
    if format == "mail":
        return action == "mail-summary"
    if format == "planner":
        return action == "planner-summary"
    if format == "counter":
        return action == "counter-action"
    if format == "launcher":
        return action.starts_with("open_")
    false

fn _office_action_dispatch_core(action: text, source: text) -> OfficeActionResult:
    val decoded = _decode_office_cli_text(source)
    if val Some(component) = office_component_for_action(action):
        return OfficeActionResult(ok: true, code: 0, action: action, output: "launcher-open: " + office_canonical_component(component), reason: "opened")
    match action:
        "render-writer-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_writer_markdown_html(decoded), reason: "rendered")
        "writer-markdown-summary" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_writer_markdown_summary(decoded), reason: "summarized")
        "writer-markdown-stats" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_writer_markdown_stats(decoded), reason: "counted")
        "writer-markdown-search" =>
            return _office_action_writer_markdown_search(decoded)
        "writer-markdown-range" =>
            return _office_action_writer_markdown_range(decoded)
        "writer-markdown-blocks" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_writer_markdown_blocks(decoded), reason: "listed")
        "writer-markdown-tables" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_writer_markdown_tables(decoded), reason: "listed")
        "writer-markdown-replace" =>
            return _office_action_writer_markdown_replace(decoded)
        "writer-markdown-insert" =>
            return _office_action_writer_markdown_insert(decoded)
        "writer-markdown-delete" =>
            return _office_action_writer_markdown_delete(decoded)
        "writer-markdown-outline" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: _office_action_writer_markdown_outline(decoded), reason: "listed")
        "render-ppt-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_ppt_markdown_html(decoded), reason: "rendered")
        "ppt-markdown-outline" =>
