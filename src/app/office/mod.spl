struct OfficeActionResult:
    ok: bool
    code: i32
    action: text
    output: text
    reason: text

struct OfficePluginContext:
    app_id: text
    action_id: text
    source_format: text
    evidence_key: text

struct OfficeCatalogDispatchProbe:
    advertised_count: i64
    recognized_count: i64
    missing_actions: [text]

fn main() -> i64:
    val args = _get_office_cli_args()
    run_office(args).to_i64()

fn _get_office_cli_args() -> [text]:
    val all_args = cli_get_args()
    var args: [text] = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("/app/office/mod.spl") or all_args[scan_idx] == "src/app/office/mod.spl":
            start_idx = scan_idx + 1
            scan_idx = all_args.len()
        else:
            scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    if args.len() > 0 and args[0] == "office":
        return args[1:]
    args

fn run_office(args: [text]) -> i32:
    """Dispatch to the requested office app or show the launcher."""
    var cmd = if args.len() > 0: args[0] else: "launcher"
    if val Some(component) = office_component_for_action(cmd):
        cmd = component
    cmd = office_canonical_component(cmd)
    match cmd:
        "launcher" =>
            val store = RecentFileStore.new(20)
            val recent = store.get_recent(10)
            val ui = build_launcher_ui(recent)
            print "LibreOffice Launcher loaded (root={ui.root_id}, recent={recent.len()})"
            return 0
        "word" =>
            return _run_writer_markdown_command()
        "writer" =>
            return _run_writer_markdown_command()
        "sheets" =>
            val app = SheetsApp.new()
            val ui = app.build_ui()
            val active_ref = cell_ref_to_string(app.active_cell)
            print "LibreOffice Calc loaded (root={ui.root_id}, sheets={app.workbook.sheets.len()}, active={active_ref})"
            return 0
        "slides" =>
            val app = SlidesApp.new()
            val ui = app.build_ui()
            print "LibreOffice Impress loaded (root={ui.root_id}, slides={slide_count(app.presentation)}, modified={app.modified})"
            return 0
        "draw" =>
            val graph = sdn_graph_parse("graph: Draw\nA: Start x: 0 y: 0 width: 80 height: 20")
            print "LibreOffice Draw loaded (nodes={graph.nodes.len()}, render=html)"
            return 0
        "db" =>
            val table = new_table("Base", ["id"])
            print "LibreOffice Base loaded (table={table.name}, columns={table.columns.len()}, rows={table.rows.len()})"
            return 0
        "math" =>
            val result = math_to_mathml_checked("x + y")
            print "LibreOffice Math loaded (accepted={result.accepted}, render=mathml)"
            return 0
        "mail" =>
            val app = MailApp.new()
            val ui = app.build_ui()
            print "Simple Mail loaded (root={ui.root_id}, emails={app.emails.len()}, unread={app.unread_count()})"
            return 0
        "planner" =>
            val app = PlannerApp.new()
            val ui = app.build_ui()
            print "Simple Planner loaded (root={ui.root_id}, tasks={app.project.tasks.len()}, view={app.active_view})"
            return 0
        "counter" =>
            val app = CounterApp.new()
            val ui = app.build_ui()
            print "Simple Counter loaded (root={ui.root_id}, value={app.value}, modified={app.modified})"
            return 0
        "md-edit" =>
            return _run_markdown_edit_command(args)
        "sheet-edit" =>
            return _run_sheet_edit_command(args)
        "format-cell-value" =>
            return _run_office_action_command(args)
