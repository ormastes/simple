# Simple Office Suite
#
# Canonical entry point for the office suite CLI command.

use std.sffi.cli (cli_get_args)
use app.office.launcher.{build_launcher_ui}
use app.office.word.word_app.{WordApp}
use app.office.sheets.sheets_app.{SheetsApp}
use app.office.slides.slides_app.{SlidesApp}
use app.office.slides.slide.{Slide, slide_count, blank_slide, add_text_box, slide_update_text_checked}
use app.office.mail.mail_app.{MailApp}
use app.office.planner.planner_app.{PlannerApp}
use app.office.counter.{CounterApp}
use app.office.md_wysiwyg.{build_wysiwyg_view, wysiwyg_source_pane, wysiwyg_update_line_checked, wysiwyg_preview_document_html}
use app.office.word.html_render.{render_writer_markdown_html}
use app.office.slides.html_render.{render_ppt_markdown_html}
use app.office.ui_editor.{OfficeUiEditResult, OfficeUiInspector, office_ui_design_align_checked, office_ui_design_distribute_checked, office_ui_design_duplicate_node_checked, office_ui_design_geometry_signature, office_ui_design_inspect_node, office_ui_design_parse, office_ui_design_read_style_token, office_ui_design_render_html, office_ui_design_to_sdd, office_ui_design_update_auto_layout_checked, office_ui_design_update_constraint_checked, office_ui_design_update_label_checked, office_ui_design_update_layer_checked, office_ui_design_update_layout_checked, office_ui_design_update_style_token_checked}
use app.office.sheets.spreadsheet.{Sheet}
use std.editor.services.sdn_graph.{SdnGraph, sdn_graph_align_checked, sdn_graph_distribute_checked, sdn_graph_duplicate_node_checked, sdn_graph_geometry_signature, sdn_graph_parse, sdn_graph_render_html, sdn_graph_render_html_with_selection, sdn_graph_update_canvas, sdn_graph_update_edge_at, sdn_graph_update_node_parent_at, sdn_graph_update_node_shape_at, sdn_graph_update_node_style_at}
use common.office.file_ops.{RecentFileStore}
use app.office.sheets.cell.{cell_ref_to_string, parse_cell_ref}

struct OfficeActionResult:
    ok: bool
    code: i32
    action: text
    output: text
    reason: text

fn main() -> i64:
    val args = _get_office_cli_args()
    run_office(args).to_i64()

fn _get_office_cli_args() -> [text]:
    val all_args = cli_get_args()
    var args: [text] = []
    var start_idx = 1
    var scan_idx = 0
    while scan_idx < all_args.len():
        if all_args[scan_idx].ends_with("/app/office/mod.spl") or all_args[scan_idx] == "src/app/office/mod.spl":
            start_idx = scan_idx + 1
            scan_idx = all_args.len()
        else:
            scan_idx = scan_idx + 1
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    if args.len() > 0 and args[0] == "office":
        return args[1:]
    args

fn run_office(args: [text]) -> i32:
    """Dispatch to the requested office app or show the launcher."""
    val cmd = if args.len() > 0: args[0] else: "launcher"
    match cmd:
        "launcher" =>
            val store = RecentFileStore.new(20)
            val recent = store.get_recent(10)
            val ui = build_launcher_ui(recent)
            print "Simple Office Launcher loaded (root={ui.root_id}, recent={recent.len()})"
            return 0
        "word" =>
            val app = WordApp.new()
            val ui = app.build_ui()
            print "Simple Word loaded (root={ui.root_id}, words={app.word_count()}, modified={app.modified})"
            return 0
        "sheets" =>
            val app = SheetsApp.new()
            val ui = app.build_ui()
            val active_ref = cell_ref_to_string(app.active_cell)
            print "Simple Sheets loaded (root={ui.root_id}, sheets={app.workbook.sheets.len()}, active={active_ref})"
            return 0
        "slides" =>
            val app = SlidesApp.new()
            val ui = app.build_ui()
            print "Simple Slides loaded (root={ui.root_id}, slides={slide_count(app.presentation)}, modified={app.modified})"
            return 0
        "mail" =>
            val app = MailApp.new()
            val ui = app.build_ui()
            print "Simple Mail loaded (root={ui.root_id}, emails={app.emails.len()}, unread={app.unread_count()})"
            return 0
        "planner" =>
            val app = PlannerApp.new()
            val ui = app.build_ui()
            print "Simple Planner loaded (root={ui.root_id}, tasks={app.project.tasks.len()}, view={app.active_view})"
            return 0
        "counter" =>
            val app = CounterApp.new()
            val ui = app.build_ui()
            print "Simple Counter loaded (root={ui.root_id}, value={app.value}, modified={app.modified})"
            return 0
        "md-edit" =>
            return _run_markdown_edit_command(args)
        "sheet-edit" =>
            return _run_sheet_edit_command(args)
        "slide-edit" =>
            return _run_slide_edit_command(args)
        "render-writer-markdown-html" =>
            return _run_office_action_command(args)
        "render-ppt-markdown-html" =>
            return _run_office_action_command(args)
        "render-markdown-preview-html" =>
            return _run_office_action_command(args)
        "render-ui-html" =>
            return _run_office_action_command(args)
        "ui-duplicate-node" =>
            return _run_office_action_command(args)
        "ui-label-edit" =>
            return _run_office_action_command(args)
        "ui-layout-edit" =>
            return _run_office_action_command(args)
        "ui-auto-layout-edit" =>
            return _run_office_action_command(args)
        "ui-constraints-edit" =>
            return _run_office_action_command(args)
        "ui-layer-edit" =>
            return _run_office_action_command(args)
        "ui-style-token-read" =>
            return _run_office_action_command(args)
        "ui-style-token-edit" =>
            return _run_office_action_command(args)
        "ui-inspect-node" =>
            return _run_office_action_command(args)
        "ui-align-selection" =>
            return _run_office_action_command(args)
        "ui-distribute-selection" =>
            return _run_office_action_command(args)
        "export-ui-sdd" =>
            return _run_office_action_command(args)
        "render-sdd-html" =>
            return _run_office_action_command(args)
        "render-sdd-html-with-selection" =>
            return _run_office_action_command(args)
        "duplicate-sdd-node" =>
            return _run_office_action_command(args)
        "reroute-sdd-connector" =>
            return _run_office_action_command(args)
        "edit-sdd-node-parent" =>
            return _run_office_action_command(args)
        "edit-sdd-node-shape" =>
            return _run_office_action_command(args)
        "edit-sdd-node-style" =>
            return _run_office_action_command(args)
        "edit-sdd-canvas" =>
            return _run_office_action_command(args)
        "align-sdd-selection" =>
            return _run_office_action_command(args)
        "distribute-sdd-selection" =>
            return _run_office_action_command(args)
        "ui-render" =>
            return _run_office_action_command(args)
        "ui-export-sdd" =>
            return _run_office_action_command(args)
        "render-sdd" =>
            return _run_office_action_command(args)
        case _("unsupported office app names show usage"):
            print "Usage: simple office <command>"
            return 1

fn _decode_office_cli_text(value: text) -> text:
    value.replace("\\n", "\n")

fn office_action_dispatch(action: text, source: text) -> OfficeActionResult:
    val decoded = _decode_office_cli_text(source)
    match action:
        "render-writer-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_writer_markdown_html(decoded), reason: "rendered")
        "render-ppt-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_ppt_markdown_html(decoded), reason: "rendered")
        "render-markdown-preview-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: wysiwyg_preview_document_html(decoded), reason: "rendered")
        "render-ui-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_render_html(office_ui_design_parse(decoded)), reason: "rendered")
        "ui-duplicate-node" =>
            return _office_action_duplicate_ui_node(decoded)
        "ui-label-edit" =>
            return _office_action_edit_ui_label(decoded)
        "ui-layout-edit" =>
            return _office_action_edit_ui_layout(decoded)
        "ui-auto-layout-edit" =>
            return _office_action_edit_ui_auto_layout(decoded)
        "ui-constraints-edit" =>
            return _office_action_edit_ui_constraints(decoded)
        "ui-layer-edit" =>
            return _office_action_edit_ui_layer(decoded)
        "ui-style-token-read" =>
            return _office_action_read_ui_style_token(decoded)
        "ui-style-token-edit" =>
            return _office_action_edit_ui_style_token(decoded)
        "ui-inspect-node" =>
            return _office_action_inspect_ui_node(decoded)
        "ui-align-selection" =>
            return _office_action_layout_ui_nodes(decoded, "align")
        "ui-distribute-selection" =>
            return _office_action_layout_ui_nodes(decoded, "distribute")
        "export-ui-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_to_sdd(office_ui_design_parse(decoded)), reason: "exported")
        "render-sdd-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: sdn_graph_render_html(sdn_graph_parse(decoded)), reason: "rendered")
        "render-sdd-html-with-selection" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: sdn_graph_render_html_with_selection(sdn_graph_parse(decoded), "", -1), reason: "rendered")
        "duplicate-sdd-node" =>
            return _office_action_duplicate_sdd_node(decoded)
        "reroute-sdd-connector" =>
            return _office_action_reroute_sdd_connector(decoded)
        "edit-sdd-node-parent" =>
            return _office_action_edit_sdd_node_value(decoded, "parent")
        "edit-sdd-node-shape" =>
            return _office_action_edit_sdd_node_value(decoded, "shape")
        "edit-sdd-node-style" =>
            return _office_action_edit_sdd_node_value(decoded, "style")
        "edit-sdd-canvas" =>
            return _office_action_edit_sdd_canvas(decoded)
        "align-sdd-selection" =>
            return _office_action_layout_sdd_nodes(decoded, "align")
        "distribute-sdd-selection" =>
            return _office_action_layout_sdd_nodes(decoded, "distribute")
        "ui-render" =>
            return OfficeActionResult(ok: true, code: 0, action: "render-ui-html", output: office_ui_design_render_html(office_ui_design_parse(decoded)), reason: "rendered")
        "ui-export-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: "export-ui-sdd", output: office_ui_design_to_sdd(office_ui_design_parse(decoded)), reason: "exported")
        "render-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: "render-sdd-html", output: sdn_graph_render_html(sdn_graph_parse(decoded)), reason: "rendered")
        case _("unknown office action"):
            OfficeActionResult(ok: false, code: 1, action: action, output: "", reason: "unknown-action")

fn _office_action_split_edit_source(source: text) -> [text]:
    val lines = source.split("\n")
    if lines.len() == 0:
        return ["", ""]
    var body: [text] = []
    var i = 1
    while i < lines.len():
        body.push(lines[i])
        i = i + 1
    [lines[0], body.join("\n")]

fn _office_action_split_ids(value: text) -> [text]:
    var ids: [text] = []
    for raw in value.split(","):
        val id = raw.trim()
        if id != "":
            ids.push(id)
    ids

fn _office_action_duplicate_ui_node(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 4:
        return OfficeActionResult(ok: false, code: 1, action: "ui-duplicate-node", output: "", reason: "invalid-args")
    val result = office_ui_design_duplicate_node_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim())
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "ui-duplicate-node", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "ui-duplicate-node", output: office_ui_design_render_html(result.design), reason: result.reason)

fn _office_action_ui_result(action: text, result: OfficeUiEditResult) -> OfficeActionResult:
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_render_html(result.design), reason: result.reason)

fn _office_action_edit_ui_label(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3:
        return OfficeActionResult(ok: false, code: 1, action: "ui-label-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-label-edit", office_ui_design_update_label_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim()))

fn _office_action_edit_ui_layout(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 9:
        return OfficeActionResult(ok: false, code: 1, action: "ui-layout-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-layout-edit", office_ui_design_update_layout_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim(), args[5].trim(), args[6].trim(), args[7].trim(), args[8].trim()))

fn _office_action_edit_ui_auto_layout(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 7:
        return OfficeActionResult(ok: false, code: 1, action: "ui-auto-layout-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-auto-layout-edit", office_ui_design_update_auto_layout_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim(), args[5].trim(), args[6].trim()))

fn _office_action_edit_ui_constraints(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 5:
        return OfficeActionResult(ok: false, code: 1, action: "ui-constraints-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-constraints-edit", office_ui_design_update_constraint_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim()))

fn _office_action_edit_ui_layer(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3:
        return OfficeActionResult(ok: false, code: 1, action: "ui-layer-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-layer-edit", office_ui_design_update_layer_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim()))

fn _office_action_edit_ui_style_token(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3:
        return OfficeActionResult(ok: false, code: 1, action: "ui-style-token-edit", output: "", reason: "invalid-args")
    _office_action_ui_result("ui-style-token-edit", office_ui_design_update_style_token_checked(office_ui_design_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim()))

fn _office_action_format_ui_inspector(inspector: OfficeUiInspector) -> text:
    "id=" + inspector.id + "\nlabel=" + inspector.label + "\nkind=" + inspector.kind + "\ncss=" + inspector.css + "\nx=" + inspector.x + "\ny=" + inspector.y + "\nwidth=" + inspector.width + "\nheight=" + inspector.height + "\nlayer=" + inspector.layer + "\ncomponent=" + inspector.component + "\nz_index=" + inspector.z_index + "\nparent=" + inspector.parent + "\nlayout_mode=" + inspector.layout_mode + "\nconstraint_h=" + inspector.constraint_horizontal + "\nconstraint_v=" + inspector.constraint_vertical

fn _office_action_inspect_ui_node(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val node_id = parts[0].trim()
    if node_id == "":
        return OfficeActionResult(ok: false, code: 1, action: "ui-inspect-node", output: "", reason: "invalid-args")
    val inspector = office_ui_design_inspect_node(office_ui_design_parse(parts[1]), node_id)
    if not inspector.found:
        return OfficeActionResult(ok: false, code: 1, action: "ui-inspect-node", output: "", reason: inspector.reason)
    OfficeActionResult(ok: true, code: 0, action: "ui-inspect-node", output: _office_action_format_ui_inspector(inspector), reason: inspector.reason)

fn _office_action_read_ui_style_token(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val node_id = parts[0].trim()
    if node_id == "":
        return OfficeActionResult(ok: false, code: 1, action: "ui-style-token-read", output: "", reason: "invalid-args")
    val inspector = office_ui_design_read_style_token(office_ui_design_parse(parts[1]), node_id)
    if not inspector.found:
        return OfficeActionResult(ok: false, code: 1, action: "ui-style-token-read", output: "", reason: inspector.reason)
    OfficeActionResult(ok: true, code: 0, action: "ui-style-token-read", output: inspector.css, reason: inspector.reason)

fn _office_action_duplicate_sdd_node(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 4:
        return OfficeActionResult(ok: false, code: 1, action: "duplicate-sdd-node", output: "", reason: "invalid-args")
    val result = sdn_graph_duplicate_node_checked(sdn_graph_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim())
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "duplicate-sdd-node", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "duplicate-sdd-node", output: sdn_graph_render_html(result.graph), reason: result.reason)

fn _office_action_sdd_node_index(graph: SdnGraph, node_id: text) -> i64:
    var i: i64 = 0
    for node in graph.nodes:
        if node.id == node_id:
            return i
        i = i + 1
    -1

fn _office_action_edit_sdd_node_value(source: text, field: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 2:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-" + field, output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val idx = _office_action_sdd_node_index(graph, args[0].trim())
    if idx < 0:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-node-" + field, output: "", reason: "missing-node")
    val updated = if field == "parent" then sdn_graph_update_node_parent_at(graph, idx, args[1].trim()) elif field == "shape" then sdn_graph_update_node_shape_at(graph, idx, args[1].trim()) else: sdn_graph_update_node_style_at(graph, idx, args[1].trim())
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-node-" + field, output: sdn_graph_render_html(updated), reason: "updated")

fn _office_action_edit_sdd_canvas(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 6:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-canvas", output: "", reason: "invalid-args")
    val updated = sdn_graph_update_canvas(sdn_graph_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim(), args[5].trim())
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-canvas", output: sdn_graph_render_html(updated), reason: "updated")

fn _office_action_reroute_sdd_connector(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 5 or not _is_office_cli_non_negative_i32_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "reroute-sdd-connector", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val edge_index = args[0].trim().to_i64()
    if edge_index >= graph.edges.len():
        return OfficeActionResult(ok: false, code: 1, action: "reroute-sdd-connector", output: "", reason: "missing-edge")
    val updated = sdn_graph_update_edge_at(graph, edge_index, args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim())
    OfficeActionResult(ok: true, code: 0, action: "reroute-sdd-connector", output: sdn_graph_render_html(updated), reason: "updated")

fn _office_action_layout_ui_nodes(source: text, kind: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 2:
        return OfficeActionResult(ok: false, code: 1, action: "ui-" + kind + "-selection", output: "", reason: "invalid-args")
    val design = office_ui_design_parse(parts[1])
    val ids = _office_action_split_ids(args[1])
    val signature = office_ui_design_geometry_signature(design, ids)
    val result = if kind == "align" then office_ui_design_align_checked(design, ids, signature, args[0].trim()) else: office_ui_design_distribute_checked(design, ids, signature, args[0].trim())
    val action = "ui-" + kind + "-selection"
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_render_html(result.design), reason: result.reason)

fn _office_action_layout_sdd_nodes(source: text, kind: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 2:
        return OfficeActionResult(ok: false, code: 1, action: kind + "-sdd-selection", output: "", reason: "invalid-args")
    val graph = sdn_graph_parse(parts[1])
    val ids = _office_action_split_ids(args[1])
    val signature = sdn_graph_geometry_signature(graph, ids)
    val result = if kind == "align" then sdn_graph_align_checked(graph, ids, signature, args[0].trim()) else: sdn_graph_distribute_checked(graph, ids, signature, args[0].trim())
    val action = kind + "-sdd-selection"
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: sdn_graph_render_html(result.graph), reason: result.reason)

fn _run_office_action_command(args: [text]) -> i32:
    if args.len() != 2:
        print "Usage: simple office " + args[0] + " <source>"
        return 1
    val result = office_action_dispatch(args[0], args[1])
    if result.ok:
        print result.output
        return result.code
    print "office-action: rejected (" + result.reason + ")"
    return result.code

fn _is_office_cli_non_negative_i32_token(value: text) -> bool:
    if value.len() == 0:
        return false
    if value.len() > 9:
        return false
    var i = 0
    while i < value.len():
        val c = value.char_at(i)
        val code = c.char_code_at(0)
        if code < 48 or code > 57:
            return false
        i = i + 1
    true

fn _run_markdown_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office md-edit <line> <expected> <new> <source>"
        return 1
    if not _is_office_cli_non_negative_i32_token(args[1]):
        print "office-md-edit: rejected (invalid-line)"
        print "@@ line {args[1]} @@\nexpected: {args[2]}\nactual: <invalid-line>\nrejected: {args[3]}"
        return 2
    val line_no = args[1].to_i32()
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source = _decode_office_cli_text(args[4])
    val view = build_wysiwyg_view(source)
    val result = wysiwyg_update_line_checked(view, line_no, expected, replacement)
    if result.accepted:
        print "office-md-edit: updated"
        print result.diff
        print wysiwyg_source_pane(result.view).replace("\n", "\\n")
        return 0
    print "office-md-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _load_sheet_cli_source(source: text) -> Sheet:
    val sheet = Sheet.new("CLI")
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val ref_str = parts[0].trim()
                val value = parts[1:].join("=")
                if parse_cell_ref(ref_str) != nil:
                    sheet.set_value(ref_str, value)
    sheet

fn _sheet_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val ref_str = parts[0].trim()
            if parse_cell_ref(ref_str) == nil:
                return "invalid-source-ref"
    ""

fn _run_sheet_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office sheet-edit <cell> <expected> <new> <sheet-source>"
        return 1
    val cell_ref = args[1]
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _sheet_cli_source_error(args[4])
    if source_error != "":
        print "office-sheet-edit: rejected ({source_error})"
        return 2
    val sheet = _load_sheet_cli_source(args[4])
    val result = sheet.update_cell_checked(cell_ref, expected, replacement)
    if result.accepted:
        print "office-sheet-edit: updated"
        print result.diff
        print "{result.cell_ref}={result.new_value}"
        return 0
    print "office-sheet-edit: rejected ({result.reason})"
    print result.diff
    return 2

fn _slide_cli_source_error(source: text) -> text:
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() < 2:
                return "malformed-source-entry"
            val element_id = parts[0].trim()
            if element_id == "":
                return "missing-element-id"
    ""

fn _load_slide_cli_source(source: text) -> Slide:
    var slide = blank_slide("cli_slide")
    val decoded = _decode_office_cli_text(source)
    val entries = decoded.split(";")
    var offset: i32 = 0
    for entry in entries:
        val trimmed = entry.trim()
        if trimmed.len() > 0:
            val parts = trimmed.split("=")
            if parts.len() >= 2:
                val element_id = parts[0].trim()
                val value = parts[1:].join("=")
                if element_id != "":
                    slide = add_text_box(slide, element_id, value, 40, 40 + offset, 840, 60)
                    offset = offset + 72
    slide

fn _run_slide_edit_command(args: [text]) -> i32:
    if args.len() != 5:
        print "Usage: simple office slide-edit <element-id> <expected> <new> <slide-source>"
        return 1
    val element_id = args[1]
    val expected = _decode_office_cli_text(args[2])
    val replacement = _decode_office_cli_text(args[3])
    val source_error = _slide_cli_source_error(args[4])
    if source_error != "":
        print "office-slide-edit: rejected ({source_error})"
        return 2
    val slide = _load_slide_cli_source(args[4])
    val result = slide_update_text_checked(slide, element_id, expected, replacement)
    if result.accepted:
        print "office-slide-edit: updated"
        print result.diff
        print "{result.element_id}={result.new_value}"
        return 0
    print "office-slide-edit: rejected ({result.reason})"
    print result.diff
    return 2
