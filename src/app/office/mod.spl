fn _office_action_edit_sdd_style_rule(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 5:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-style-rule", output: "", reason: "invalid-args")
    val result = sdn_graph_set_style_rule_checked(sdn_graph_parse(parts[1]), args[0].trim(), args[1].trim(), args[2].trim(), args[3].trim(), args[4].trim())
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "edit-sdd-style-rule", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "edit-sdd-style-rule", output: sdn_graph_to_canonical_sdn(result.graph), reason: result.reason)

