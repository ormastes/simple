fn _decode_office_cli_text(value: text) -> text:
    value.replace("\\n", "\n")

fn office_action_dispatch(action: text, source: text) -> OfficeActionResult:
    val decoded = _decode_office_cli_text(source)
    match action:
        "render-writer-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_writer_markdown_html(decoded), reason: "rendered")
        "render-ppt-markdown-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: render_ppt_markdown_html(decoded), reason: "rendered")
        "render-markdown-preview-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: wysiwyg_preview_document_html(decoded), reason: "rendered")
        "md-edit" =>
            return _office_action_md_edit(decoded)
        "sheet-edit" =>
            return _office_action_sheet_edit(decoded)
        "slide-edit" =>
            return _office_action_slide_edit(decoded)
        "render-mathml" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: math_to_mathml(decoded), reason: "rendered")
        "render-mathml-checked" =>
            return _office_action_render_mathml_checked(decoded)
        "render-math-structure" =>
            return _office_action_render_math_structure(decoded)
        "counter-action" =>
            return _office_action_counter_action(decoded)
        "query-table" =>
            return _office_action_query_table(decoded)
        "render-base-table-html" =>
            return _office_action_render_base_table_html(decoded)
        "db-edit" =>
            return _office_action_db_edit(decoded)
        "render-ui-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_render_html(office_ui_design_parse(decoded)), reason: "rendered")
        "ui-duplicate-node" =>
            return _office_action_duplicate_ui_node(decoded)
        "ui-label-edit" =>
            return _office_action_edit_ui_label(decoded)
        "ui-layout-edit" =>
            return _office_action_edit_ui_layout(decoded)
        "ui-auto-layout-edit" =>
            return _office_action_edit_ui_auto_layout(decoded)
        "ui-constraints-edit" =>
            return _office_action_edit_ui_constraints(decoded)
        "ui-layer-edit" =>
            return _office_action_edit_ui_layer(decoded)
        "ui-style-token-read" =>
            return _office_action_read_ui_style_token(decoded)
        "ui-style-token-edit" =>
            return _office_action_edit_ui_style_token(decoded)
        "ui-inspect-node" =>
            return _office_action_inspect_ui_node(decoded)
        "ui-align-selection" =>
            return _office_action_layout_ui_nodes(decoded, "align")
        "ui-distribute-selection" =>
            return _office_action_layout_ui_nodes(decoded, "distribute")
        "export-ui-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: office_ui_design_to_sdd(office_ui_design_parse(decoded)), reason: "exported")
        "render-sdd-html" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: sdn_graph_render_html(sdn_graph_parse(decoded)), reason: "rendered")
        "render-sdd-html-with-selection" =>
            return OfficeActionResult(ok: true, code: 0, action: action, output: sdn_graph_render_html_with_selection(sdn_graph_parse(decoded), "", -1), reason: "rendered")
        "inspect-sdd-node" =>
            return _office_action_inspect_sdd_node(decoded)
        "inspect-sdd-edge" =>
            return _office_action_inspect_sdd_edge(decoded)
        "inspect-sdd-style-rule" =>
            return _office_action_inspect_sdd_style_rule(decoded)
        "duplicate-sdd-node" =>
            return _office_action_duplicate_sdd_node(decoded)
        "add-sdd-node" =>
            return _office_action_add_sdd_node(decoded)
        "reroute-sdd-connector" =>
            return _office_action_reroute_sdd_connector(decoded)
        "add-sdd-edge" =>
            return _office_action_add_sdd_edge(decoded)
        "duplicate-sdd-edge" =>
            return _office_action_duplicate_sdd_edge(decoded)
        "edit-sdd-edge-label" =>
            return _office_action_edit_sdd_edge_label(decoded)
        "edit-sdd-edge-label-point" =>
            return _office_action_edit_sdd_edge_label_point(decoded)
        "edit-sdd-edge-style" =>
            return _office_action_edit_sdd_edge_style(decoded)
        "edit-sdd-edge-kind" =>
            return _office_action_edit_sdd_edge_kind(decoded)
        "edit-sdd-edge-endpoints" =>
            return _office_action_edit_sdd_edge_endpoints(decoded)
        "delete-sdd-edge" =>
            return _office_action_delete_sdd_edge(decoded)
        "delete-sdd-node" =>
            return _office_action_delete_sdd_node(decoded)
        "edit-sdd-node-label" =>
            return _office_action_edit_sdd_node_value(decoded, "label")
        "edit-sdd-node-parent" =>
            return _office_action_edit_sdd_node_value(decoded, "parent")
        "edit-sdd-node-geometry" =>
            return _office_action_edit_sdd_node_geometry(decoded)
        "edit-sdd-node-shape" =>
            return _office_action_edit_sdd_node_value(decoded, "shape")
        "edit-sdd-node-style" =>
            return _office_action_edit_sdd_node_value(decoded, "style")
        "edit-sdd-node-layer" =>
            return _office_action_edit_sdd_node_value(decoded, "layer")
        "order-sdd-node" =>
            return _office_action_order_sdd_node(decoded)
        "edit-sdd-node-role" =>
            return _office_action_edit_sdd_node_value(decoded, "role")
        "edit-sdd-canvas" =>
            return _office_action_edit_sdd_canvas(decoded)
        "edit-sdd-style-rule" =>
            return _office_action_edit_sdd_style_rule(decoded)
        "delete-sdd-style-rule" =>
            return _office_action_delete_sdd_style_rule(decoded)
        "align-sdd-selection" =>
            return _office_action_layout_sdd_nodes(decoded, "align")
        "distribute-sdd-selection" =>
            return _office_action_layout_sdd_nodes(decoded, "distribute")
        "ui-render" =>
            return OfficeActionResult(ok: true, code: 0, action: "render-ui-html", output: office_ui_design_render_html(office_ui_design_parse(decoded)), reason: "rendered")
        "ui-export-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: "export-ui-sdd", output: office_ui_design_to_sdd(office_ui_design_parse(decoded)), reason: "exported")
        "render-sdd" =>
            return OfficeActionResult(ok: true, code: 0, action: "render-sdd-html", output: sdn_graph_render_html(sdn_graph_parse(decoded)), reason: "rendered")
        case _("unknown office action"):
            OfficeActionResult(ok: false, code: 1, action: action, output: "", reason: "unknown-action")

fn office_catalog_dispatch_probe() -> OfficeCatalogDispatchProbe:
    var advertised_count = 0
    var recognized_count = 0
    var missing_actions: [text] = []
    for row in office_llm_feature_catalog():
        for action in row.actions:
            advertised_count = advertised_count + 1
            val result = office_action_dispatch(action, "")
            if result.reason == "unknown-action":
                missing_actions.push(action)
            else:
                recognized_count = recognized_count + 1
    OfficeCatalogDispatchProbe(advertised_count: advertised_count, recognized_count: recognized_count, missing_actions: missing_actions)

fn _run_writer_markdown_command() -> i32:
    val view = build_wysiwyg_view("# Untitled")
    print "LibreOffice Writer Markdown loaded (lines={wysiwyg_line_count(view)}, source=markdown, render=html)"
    0

fn _office_action_split_edit_source(source: text) -> [text]:
    val lines = source.split("\n")
    if lines.len() == 0:
        return ["", ""]
    var body: [text] = []
    var i = 1
    while i < lines.len():
        body.push(lines[i])
        i = i + 1
    [lines[0], body.join("\n")]

fn _office_action_split_ids(value: text) -> [text]:
    var ids: [text] = []
    for raw in value.split(","):
        val id = raw.trim()
        if id != "":
            ids.push(id)
    ids

fn _office_action_md_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3 or not _is_office_cli_non_negative_i32_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "md-edit", output: "", reason: "invalid-args")
    val result = wysiwyg_update_line_checked(build_wysiwyg_view(parts[1]), args[0].trim().to_i32(), args[1], args[2])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "md-edit", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "md-edit", output: wysiwyg_source_pane(result.view), reason: result.reason)

fn _office_action_sheet_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3:
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: "", reason: "invalid-args")
    val source_error = _sheet_cli_source_error(parts[1])
    if source_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: "", reason: source_error)
    val sheet = _load_sheet_cli_source(parts[1])
    val result = sheet.update_cell_checked(args[0].trim(), args[1], args[2])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "sheet-edit", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "sheet-edit", output: result.cell_ref + "=" + result.new_value, reason: result.reason)

fn _office_action_slide_edit(source: text) -> OfficeActionResult:
    val parts = _office_action_split_edit_source(source)
    val args = parts[0].split("|")
    if args.len() != 3:
        return OfficeActionResult(ok: false, code: 1, action: "slide-edit", output: "", reason: "invalid-args")
    val source_error = _slide_cli_source_error(parts[1])
    if source_error != "":
        return OfficeActionResult(ok: false, code: 1, action: "slide-edit", output: "", reason: source_error)
    val slide = _load_slide_cli_source(parts[1])
    val result = slide_update_text_checked(slide, args[0].trim(), args[1], args[2])
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "slide-edit", output: result.diff, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "slide-edit", output: result.element_id + "=" + result.new_value, reason: result.reason)

fn _office_action_math_result(action: text, result: MathRenderResult) -> OfficeActionResult:
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: action, output: result.mathml, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: action, output: result.mathml, reason: result.reason)

fn _office_action_render_mathml_checked(source: text) -> OfficeActionResult:
    _office_action_math_result("render-mathml-checked", math_to_mathml_checked(source))

fn _office_action_render_math_structure(source: text) -> OfficeActionResult:
    val result = math_to_mathml_checked(source)
    var output = "reason=" + result.reason + "\naccepted=" + result.accepted.to_text()
    if result.mathml.contains("<mfrac>"):
        output = output + "\ncontains=fraction"
    if result.mathml.contains("<msup>"):
        output = output + "\ncontains=superscript"
    if result.mathml.contains("<msub>"):
        output = output + "\ncontains=subscript"
    if result.mathml.contains("<msqrt>"):
        output = output + "\ncontains=square-root"
    if result.mathml.contains("<mrow>"):
        output = output + "\ncontains=row"
    if not result.accepted:
        return OfficeActionResult(ok: false, code: 1, action: "render-math-structure", output: output, reason: result.reason)
    OfficeActionResult(ok: true, code: 0, action: "render-math-structure", output: output, reason: result.reason)

fn _office_action_counter_output(result: CounterTransition) -> text:
    "value=" + result.value.to_text() + "\nstatus=" + result.status + "\nchanged=" + result.changed.to_text()

fn _office_action_counter_action(source: text) -> OfficeActionResult:
    val args = source.split("|")
    if args.len() != 2 or not _is_office_cli_signed_i64_token(args[0].trim()):
        return OfficeActionResult(ok: false, code: 1, action: "counter-action", output: "", reason: "invalid-args")
    val result = counter_apply_action(args[0].trim().to_i64(), args[1].trim())
    if not result.changed and result.status == "unsupported":
        return OfficeActionResult(ok: false, code: 1, action: "counter-action", output: _office_action_counter_output(result), reason: result.status)
    OfficeActionResult(ok: true, code: 0, action: "counter-action", output: _office_action_counter_output(result), reason: result.status)

fn _office_action_format_sdd_node_inspector(inspector: SdnGraphNodeInspector) -> text:
    "id=" + inspector.id + "\nlabel=" + inspector.label + "\ncss=" + inspector.css + "\nrole=" + inspector.role + "\nshape=" + inspector.shape + "\nx=" + inspector.x + "\ny=" + inspector.y + "\nwidth=" + inspector.width + "\nheight=" + inspector.height + "\nlayer=" + inspector.layer + "\nparent=" + inspector.parent + "\nchild_count=" + inspector.child_count + "\nchild_bounds=" + inspector.child_bounds

fn _office_action_format_sdd_edge_inspector(inspector: SdnGraphEdgeInspector) -> text:
    "edge_index=" + inspector.edge_index.to_text() + "\nfrom=" + inspector.from_id + "\nto=" + inspector.to_id + "\nlabel=" + inspector.label + "\ncss=" + inspector.css + "\nkind=" + inspector.kind + "\nroute=" + inspector.route + "\nwaypoints=" + inspector.waypoints + "\nstart_anchor=" + inspector.start_anchor + "\nend_anchor=" + inspector.end_anchor + "\nlabel_x=" + inspector.label_x + "\nlabel_y=" + inspector.label_y + "\npath=" + inspector.path + "\npath_bounds=" + inspector.path_bounds + "\nsegment_count=" + inspector.segment_count + "\nsegments=" + inspector.segments + "\nsegment_midpoints=" + inspector.segment_midpoints + "\nsegment_orientations=" + inspector.segment_orientations

fn _office_action_format_sdd_style_inspector(inspector: SdnGraphStyleInspector) -> text:
    "css=" + inspector.css + "\ntarget=" + inspector.target + "\nparent=" + inspector.parent_css + "\nkey=" + inspector.key + "\nvalue=" + inspector.value

