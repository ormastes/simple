fn _office_sdd_canvas_summary(graph: SdnGraph) -> text:
    "width=" + graph.canvas_width + " height=" + graph.canvas_height + " grid=" + graph.canvas_grid + " snap=" + graph.canvas_snap + " zoom=" + graph.canvas_zoom + " background=" + graph.canvas_background

fn _office_sdd_document_summary(graph: SdnGraph) -> text:
    var canvas = "false"
    if graph.canvas_width != "" or graph.canvas_height != "":
        canvas = "true"
    "name=" + graph.name + "\nnodes=" + graph.nodes.len().to_text() + "\nedges=" + graph.edges.len().to_text() + "\ncss_rules=" + graph.css_defs.len().to_text() + "\nstyle_rows=" + graph.styles.len().to_text() + "\ncanvas=" + canvas

fn _office_sdd_outline(graph: SdnGraph) -> text:
    var out: [text] = ["name=" + graph.name, "nodes=" + graph.nodes.len().to_text(), "edges=" + graph.edges.len().to_text()]
    var node_index: i64 = 0
    for node in graph.nodes:
        out.push("node " + node_index.to_text() + ":" + node.id + "|" + _office_action_escape_piped_field(node.label) + "|" + _office_action_escape_piped_field(node.role) + "|" + _office_action_escape_piped_field(node.shape) + "|" + _office_action_escape_piped_field(node.parent))
        node_index = node_index + 1
    var edge_index: i64 = 0
    for edge in graph.edges:
        out.push("edge " + edge_index.to_text() + ":" + edge.from_id + "->" + edge.to_id + "|" + _office_action_escape_piped_field(edge.label) + "|" + _office_action_escape_piped_field(edge.kind))
        edge_index = edge_index + 1
    out.join("\n")

fn _office_sdd_style_rules_summary(graph: SdnGraph) -> text:
    var out: [text] = ["css_rules=" + graph.css_defs.len().to_text(), "style_rows=" + graph.styles.len().to_text()]
    for css in graph.css_defs:
        out.push("css " + css.name + " extends=" + css.parent_css + " target=" + css.target)
    for style in graph.styles:
        out.push("style " + style.css + "." + style.key + "=" + style.value)
    out.join("\n")

fn _office_sdd_weave_summary(graph: SdnGraph) -> text:
    var out: [text] = ["weaves=" + graph.weaves.len().to_text()]
    var i: i64 = 0
    for rule in graph.weaves:
        out.push(i.to_text() + ":target=" + rule.target + " field=" + rule.field + " value=" + rule.value + " add=" + rule.add_css + " shape=" + rule.shape + " x=" + rule.x + " y=" + rule.y + " width=" + rule.width + " height=" + rule.height + " layer=" + rule.layer + " parent=" + rule.parent)
        i = i + 1
    out.join("\n")

