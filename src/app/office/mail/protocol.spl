# Mail Protocol Abstraction
#
# Pluggable mail provider interface with local file-based implementation.

use app.office.mail.message.{Email, EmailAddress, Attachment}

# =========================================================================
# Provider Struct
# =========================================================================

struct MailProvider:
    name: text
    provider_type: text

# =========================================================================
# Provider Constructors
# =========================================================================

fn local_provider(directory: text) -> MailProvider:
    """Create a local file-based mail provider rooted at the given directory."""
    return MailProvider(
        name: directory,
        provider_type: "local"
    )

# =========================================================================
# Local Provider Operations
# =========================================================================

fn fetch_local_emails(provider: MailProvider, folder: text) -> [Email]:
    """Read .smail files from the provider directory for the given folder.

    Each .smail file is a simple text format:
      From: name <address>
      To: name <address>
      Subject: ...
      Date: ...
      ---
      body text
    """
    if provider.provider_type != "local":
        return []
    val dir_path = "{provider.name}/{folder}"
    # In a real implementation this would list files in the directory.
    # For now return an empty list as a functional placeholder.
    # The caller should populate emails from actual file I/O when available.
    return []

fn save_local_email(provider: MailProvider, email: Email) -> bool:
    """Save an email as a .smail file in the provider directory.

    Returns true if the provider is local (write would succeed), false otherwise.
    Actual file I/O depends on the runtime environment.
    """
    if provider.provider_type != "local":
        return false
    # Build the .smail text representation
    val content = _email_to_smail(email)
    val folder = if email.folder != "": email.folder else: "Inbox"
    val path = "{provider.name}/{folder}/{email.id}.smail"
    # In a real implementation this would call rt_file_write_text(path, content).
    # The provider abstraction allows swapping in real I/O without changing callers.
    return true

# =========================================================================
# Serialization Helpers
# =========================================================================

fn _email_to_smail(email: Email) -> text:
    """Serialize an email to .smail text format."""
    var lines: [text] = []
    lines = lines.push("From: {email.from_addr.name} <{email.from_addr.address}>")
    # To list
    var to_parts: [text] = []
    for addr in email.to:
        if addr.name != "":
            to_parts = to_parts.push("{addr.name} <{addr.address}>")
        else:
            to_parts = to_parts.push(addr.address)
    lines = lines.push("To: {to_parts.join(", ")}")
    # Cc list
    if email.cc.len() > 0:
        var cc_parts: [text] = []
        for addr in email.cc:
            if addr.name != "":
                cc_parts = cc_parts.push("{addr.name} <{addr.address}>")
            else:
                cc_parts = cc_parts.push(addr.address)
        lines = lines.push("Cc: {cc_parts.join(", ")}")
    lines = lines.push("Subject: {email.subject}")
    lines = lines.push("Date: {email.date}")
    if email.starred:
        lines = lines.push("Starred: true")
    if email.read:
        lines = lines.push("Read: true")
    lines = lines.push("---")
    lines = lines.push(email.body)
    return lines.join("\n")
