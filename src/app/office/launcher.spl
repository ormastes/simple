# Office Suite Launcher
# Home screen with app grid and recent files.

use app.ui.tree.{UITree}

# A recently opened file entry shown in the launcher.
class RecentFile:
    name: text
    path: text
    app_name: text
    modified_at: text

fn build_launcher_ui(recent: [RecentFile]) -> UITree:
    UITree(root_id: "launcher_root", tokens: {})
