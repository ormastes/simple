# Office Suite Launcher
#
# Home screen with app grid and recent files.

use common.ui.widget.{WidgetNode, UITree}
use common.ui.builder.{column, row, panel, label, statusbar, build_tree_with_title}
use common.ui.theme_registry.{ThemeId, theme_id_key}
use common.ui.ios.builder.{navigation_bar, card}
use common.office.file_ops.{RecentFile}

fn launcher_action_allowlist() -> [text]:
    [
        "open_word",
        "open_sheets",
        "open_slides",
        "open_draw",
        "open_db",
        "open_math",
        "open_mail",
        "open_planner",
        "open_counter"
    ]

fn launcher_open_action(component: text) -> text:
    """Return the launcher action form for a component."""
    "open_{component}"

fn is_valid_launcher_action(action: text) -> bool:
    """True only for known launcher action values."""
    for allowed in launcher_action_allowlist():
        if allowed == action:
            return true
    false

fn launcher_action_to_component(action: text) -> text?:
    """Parse a validated launcher action into its target component."""
    if is_valid_launcher_action(action):
        return Some(action.substring(5, action.len()))
    nil

fn launcher_app_cards() -> [WidgetNode]:
    """Return card widgets for the office suite apps."""
    var cards: [WidgetNode] = []
    var word_card = card("card_word", "Writer", [
        label("card_word_icon", "W"),
        label("card_word_label", "Markdown Documents")
    ])
    word_card = word_card.set_prop("action", launcher_open_action("word"))
    cards.push(word_card)
    var sheets_card = card("card_sheets", "Calc", [
        label("card_sheets_icon", "C"),
        label("card_sheets_label", "Spreadsheets")
    ])
    sheets_card = sheets_card.set_prop("action", launcher_open_action("sheets"))
    cards.push(sheets_card)
    var slides_card = card("card_slides", "Impress", [
        label("card_slides_icon", "I"),
        label("card_slides_label", "Presentations")
    ])
    slides_card = slides_card.set_prop("action", launcher_open_action("slides"))
    cards.push(slides_card)
    var draw_card = card("card_draw", "Draw", [
        label("card_draw_icon", "D"),
        label("card_draw_label", "Diagrams")
    ])
    draw_card = draw_card.set_prop("action", launcher_open_action("draw"))
    cards.push(draw_card)
    var base_card = card("card_base", "Base", [
        label("card_base_icon", "B"),
        label("card_base_label", "Database")
    ])
    base_card = base_card.set_prop("action", launcher_open_action("db"))
    cards.push(base_card)
    var math_card = card("card_math", "Math", [
        label("card_math_icon", "M"),
        label("card_math_label", "Formula Editor")
    ])
    math_card = math_card.set_prop("action", launcher_open_action("math"))
    cards.push(math_card)
    var mail_card = card("card_mail", "Mail", [
        label("card_mail_icon", "M"),
        label("card_mail_label", "Email")
    ])
    mail_card = mail_card.set_prop("action", launcher_open_action("mail"))
    cards.push(mail_card)
    var planner_card = card("card_planner", "Planner", [
        label("card_planner_icon", "K"),
        label("card_planner_label", "Tasks & Projects")
    ])
    planner_card = planner_card.set_prop("action", launcher_open_action("planner"))
    cards.push(planner_card)
    var counter_card = card("card_counter", "Counter", [
        label("card_counter_icon", "C"),
        label("card_counter_label", "Counter")
    ])
    counter_card = counter_card.set_prop("action", launcher_open_action("counter"))
    cards.push(counter_card)
    cards

fn _build_recent_files_panel(recent: [RecentFile]) -> WidgetNode:
    var items: [WidgetNode] = []
    var idx = 0
    for file in recent:
        val item = label("recent_{idx}", "{file.title} ({file.app_name}) - {file.path}")
        items.push(item)
        idx = idx + 1
    if items.len() == 0:
        items.push(label("recent_empty", "No recent files"))
    panel("recent_panel", "Recent Files", items)

fn build_launcher_ui(recent: [RecentFile]) -> UITree:
    """Build the launcher home screen UI tree."""
    val nav = navigation_bar("nav", "LibreOffice", [], [])
    val cards = launcher_app_cards()
    val first_row = row("app_row_1", [cards[0], cards[1], cards[2]])
    val second_row = row("app_row_2", [cards[3], cards[4], cards[5]])
    val third_row = row("app_row_3", [cards[6], cards[7], cards[8]])
    val app_grid = column("app_grid", [first_row, second_row, third_row])
    val recent_panel = _build_recent_files_panel(recent)
    val status = statusbar("statusbar", "LibreOffice", "v1.0")
    val root = column("root", [
        nav,
        app_grid,
        recent_panel,
        status
    ])
    build_tree_with_title(root, "LibreOffice", theme_id_key(ThemeId.IOSLight))
