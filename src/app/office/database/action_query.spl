# Action Queries + Macro Runner
#
# Access's UPDATE / DELETE / APPEND action queries, plus a macro that runs an
# ordered batch of them — the action-query layer of the minimal Access-like
# database. Reuses table.spl's table_new/table_col_index/table_insert/
# table_row_count/table_get for all storage; this file only adds the
# update/delete/append/count operations and the macro runner on top.

use app.office.database.table.{Table, table_new, table_col_index, table_insert, table_row_count, table_get}

# =========================================================================
# Internal helpers
# =========================================================================

fn _is_numeric_text(s: text) -> bool:
    """True if `s` looks like a plain number (optional leading '-', digits,
    at most one '.'). Deliberately hand-rolled rather than trusting
    `to_f64()` alone: `to_f64()` silently returns 0.0 for garbage text, which
    would misclassify non-numeric cells as numeric zero."""
    if s == "":
        return false
    var i = 0
    var has_digit = false
    var has_dot = false
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "-" and i == 0:
            pass_do_nothing("leading minus sign allowed")
        elif ch == ".":
            if has_dot:
                return false
            has_dot = true
        elif ch >= "0" and ch <= "9":
            has_digit = true
        else:
            return false
        i = i + 1
    has_digit

fn _compare_values(a: text, b: text, op: text) -> bool:
    """Apply `op` ("=","!=",">","<",">=","<=") to cell values `a`,`b`.
    Numeric compare when both parse as numbers; otherwise case-insensitive
    text compare."""
    if _is_numeric_text(a) and _is_numeric_text(b):
        val av = a.to_f64()
        val bv = b.to_f64()
        if op == "=":
            return av == bv
        if op == "!=":
            return av != bv
        if op == ">":
            return av > bv
        if op == "<":
            return av < bv
        if op == ">=":
            return av >= bv
        if op == "<=":
            return av <= bv
        return false
    val al = a.lower()
    val bl = b.lower()
    if op == "=":
        return al == bl
    if op == "!=":
        return al != bl
    if op == ">":
        return al > bl
    if op == "<":
        return al < bl
    if op == ">=":
        return al >= bl
    if op == "<=":
        return al <= bl
    false

# =========================================================================
# update_where / delete_where / append_row / count_where
# =========================================================================

fn update_where(table: Table, set_col: text, set_value: text, where_col: text, where_op: text, where_value: text) -> Table:
    """Set `set_col` to `set_value` on every row where `where_col` `where_op`
    `where_value` holds (see `_compare_values`). Returns a new Table — RETURN
    THE OBJECT, reassign at call site. Unknown `set_col`/`where_col` leaves
    the table unchanged (fail-soft)."""
    val set_idx = table_col_index(table, set_col)
    val where_idx = table_col_index(table, where_col)
    if set_idx < 0 or where_idx < 0:
        return table
    var out = table_new(table.name, table.cols)
    var i = 0
    while i < table.rows.len():
        val row_vals = table.rows[i]
        if _compare_values(row_vals[where_idx], where_value, where_op):
            var new_row: [text] = []
            var c = 0
            while c < row_vals.len():
                if c == set_idx:
                    new_row.push(set_value)
                else:
                    new_row.push(row_vals[c])
                c = c + 1
            out = table_insert(out, new_row)
        else:
            out = table_insert(out, row_vals)
        i = i + 1
    out

fn delete_where(table: Table, where_col: text, where_op: text, where_value: text) -> Table:
    """Remove every row where `where_col` `where_op` `where_value` holds.
    Returns a new Table with those rows gone — RETURN THE OBJECT, reassign
    at call site. Unknown `where_col` leaves the table unchanged
    (fail-soft)."""
    val where_idx = table_col_index(table, where_col)
    if where_idx < 0:
        return table
    var out = table_new(table.name, table.cols)
    var i = 0
    while i < table.rows.len():
        val row_vals = table.rows[i]
        if not _compare_values(row_vals[where_idx], where_value, where_op):
            out = table_insert(out, row_vals)
        i = i + 1
    out

fn append_row(table: Table, values: [text]) -> Table:
    """Access's append query for one record — a thin wrapper over
    `table_insert`. Returns a new Table — RETURN THE OBJECT, reassign at call
    site."""
    table_insert(table, values)

fn count_where(table: Table, where_col: text, where_op: text, where_value: text) -> i32:
    """How many rows match `where_col` `where_op` `where_value` — useful to
    assert an update/delete's scope before running it. Unknown `where_col`
    yields 0 (fail-soft)."""
    val where_idx = table_col_index(table, where_col)
    if where_idx < 0:
        return 0
    var n = 0
    var i = 0
    while i < table.rows.len():
        val row_vals = table.rows[i]
        if _compare_values(row_vals[where_idx], where_value, where_op):
            n = n + 1
        i = i + 1
    n

# =========================================================================
# Macro runner: an ordered batch of action queries
# =========================================================================

struct MacroAction:
    """One action in a macro: `kind` selects which of update/delete/append
    runs, and the remaining fields carry the operands it needs (unused
    fields for a given kind are simply ignored). `append_values` is a
    single comma-joined text of the new row's cell values, in column
    order (kept flat/text like every other field here, no nested array
    plumbing through the macro)."""
    kind: text
    set_col: text
    set_value: text
    where_col: text
    where_op: text
    where_value: text
    append_values: text

fn action_new(kind: text, set_col: text, set_value: text, where_col: text, where_op: text, where_value: text, append_values: text) -> MacroAction:
    """Construct a `MacroAction` with all fields explicit (struct
    default-field omission is broken in this interpreter)."""
    MacroAction(kind: kind, set_col: set_col, set_value: set_value, where_col: where_col, where_op: where_op, where_value: where_value, append_values: append_values)

struct Macro:
    """Access's macro = an ordered batch of action queries."""
    actions: [MacroAction]

fn macro_new() -> Macro:
    """An empty macro with zero actions."""
    Macro(actions: [])

fn macro_add(m: Macro, action: MacroAction) -> Macro:
    """Append `action` to `m`'s action list. Returns a new Macro — RETURN
    THE OBJECT, reassign at call site (original `m` is untouched)."""
    var new_actions: [MacroAction] = []
    var i = 0
    while i < m.actions.len():
        new_actions.push(m.actions[i])
        i = i + 1
    new_actions.push(action)
    Macro(actions: new_actions)

fn macro_run(m: Macro, table: Table) -> Table:
    """Apply each action in `m` to `table` in order, threading the returned
    table through one action at a time. Returns the final table — RETURN
    THE OBJECT, reassign at call site."""
    var t = table
    var i = 0
    while i < m.actions.len():
        val a = m.actions[i]
        if a.kind == "update":
            t = update_where(t, a.set_col, a.set_value, a.where_col, a.where_op, a.where_value)
        elif a.kind == "delete":
            t = delete_where(t, a.where_col, a.where_op, a.where_value)
        elif a.kind == "append":
            t = table_insert(t, a.append_values.split(","))
        i = i + 1
    t
