# Query-By-Example (QBE) Grid
#
# Access's design-grid query: one row per output column, each with an
# optional criteria expression, a shown/hidden flag, and an optional sort
# direction. `qbe_run` compiles the grid into a filtered/sorted/projected
# result Table. Reuses table.spl's Table storage (table_new/table_col_index/
# table_insert/table_get) for both scanning the source table and building
# the result; this file only adds the criteria-matching, sort, and
# projection logic on top (mirrors query.spl/param_query.spl's hand-rolled
# numeric-vs-text compare rule: `to_f64()` silently returns 0.0 for garbage
# text, so numeric-ness is detected by hand rather than trusted from the
# parse result).

use app.office.database.table.{Table, table_new, table_col_index, table_insert}

struct QbeColumn:
    """One row of the QBE design grid for a single table column: `criteria`
    is an operator+value expression (e.g. ">100", "=Eng", "" for none),
    `shown` controls whether the column appears in the projected result, and
    `sort` is "asc"/"desc"/"" (empty = not a sort column)."""
    col: text
    criteria: text
    shown: bool
    sort: text

fn qbe_col_new(col: text, criteria: text, shown: bool, sort: text) -> QbeColumn:
    """A QBE grid column: table column `col`, criteria expression
    `criteria`, `shown` projection flag, `sort` direction."""
    QbeColumn(col: col, criteria: criteria, shown: shown, sort: sort)

struct Qbe:
    """A full QBE grid: an ordered list of `QbeColumn` design-grid rows."""
    columns: [QbeColumn]

fn qbe_new() -> Qbe:
    """An empty QBE grid."""
    Qbe(columns: [])

fn qbe_add(qbe: Qbe, qcol: QbeColumn) -> Qbe:
    """Append `qcol` to `qbe`. RETURN THE OBJECT — reassign at call site
    (mutating `qbe` in place does not persist across this fn boundary)."""
    var new_columns: [QbeColumn] = []
    var i = 0
    while i < qbe.columns.len():
        new_columns.push(qbe.columns[i])
        i = i + 1
    new_columns.push(qcol)
    Qbe(columns: new_columns)

# =========================================================================
# Internal helpers
# =========================================================================

fn _qbe_is_numeric(s: text) -> bool:
    """True if `s` looks like a plain number (optional leading '-', digits,
    at most one '.'). Hand-rolled rather than trusting `to_f64()` alone:
    `to_f64()` silently returns 0.0 for garbage text, which would
    misclassify non-numeric cells as numeric zero."""
    if s == "":
        return false
    var i = 0
    var has_digit = false
    var has_dot = false
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "-" and i == 0:
            pass_do_nothing("leading minus sign allowed")
        elif ch == ".":
            if has_dot:
                return false
            has_dot = true
        elif ch >= "0" and ch <= "9":
            has_digit = true
        else:
            return false
        i = i + 1
    has_digit

fn _qbe_less(a: text, b: text) -> bool:
    """Ordering primitive: numeric compare when both sides look numeric,
    else case-insensitive text compare."""
    if _qbe_is_numeric(a) and _qbe_is_numeric(b):
        return a.to_f64() < b.to_f64()
    a.lower() < b.lower()

fn _qbe_compare(a: text, b: text, op: text) -> bool:
    """Apply `op` ("=","!=",">","<",">=","<=") to cell value `a` against
    criteria value `b`. Numeric compare when both parse as numbers;
    otherwise case-insensitive text compare."""
    if _qbe_is_numeric(a) and _qbe_is_numeric(b):
        val av = a.to_f64()
        val bv = b.to_f64()
        if op == "=":
            return av == bv
        if op == "!=":
            return av != bv
        if op == ">":
            return av > bv
        if op == "<":
            return av < bv
        if op == ">=":
            return av >= bv
        if op == "<=":
            return av <= bv
        return false
    val al = a.lower()
    val bl = b.lower()
    if op == "=":
        return al == bl
    if op == "!=":
        return al != bl
    if op == ">":
        return al > bl
    if op == "<":
        return al < bl
    if op == ">=":
        return al >= bl
    if op == "<=":
        return al <= bl
    false

fn _qbe_match_criteria(cell: text, criteria: text) -> bool:
    """True if `cell` satisfies `criteria` (e.g. ">100", "=Eng", "<=50",
    "!=x", or a bare value which defaults to "="). Empty criteria always
    matches. Two-char operators (">=","<=","!=") are checked before
    one-char operators (">","<","=") so they are not truncated."""
    if criteria == "":
        return true
    var op = "="
    var value = criteria
    if criteria.len() >= 2:
        val prefix2 = criteria.slice(0, 2)
        if prefix2 == ">=" or prefix2 == "<=" or prefix2 == "!=":
            op = prefix2
            value = criteria.slice(2, criteria.len())
    if op == "=" and criteria.len() >= 1:
        val prefix1 = criteria.slice(0, 1)
        if prefix1 == ">" or prefix1 == "<" or prefix1 == "=":
            op = prefix1
            value = criteria.slice(1, criteria.len())
    _qbe_compare(cell, value, op)

fn _qbe_row_matches(qbe: Qbe, table: Table, row_vals: [text]) -> bool:
    """True if `row_vals` satisfies EVERY column's criteria in `qbe` (AND
    across columns). An unknown grid column fails the row (fail-soft, not
    an error)."""
    var i = 0
    var matches = true
    while i < qbe.columns.len() and matches:
        val qcol = qbe.columns[i]
        if qcol.criteria != "":
            val idx = table_col_index(table, qcol.col)
            if idx < 0 or idx >= row_vals.len():
                matches = false
            elif not _qbe_match_criteria(row_vals[idx], qcol.criteria):
                matches = false
        i = i + 1
    matches

fn _qbe_sort_rows(rows: [[text]], idx: i32, descending: bool) -> [[text]]:
    """Stable insertion sort of `rows` by column `idx`, numeric-aware via
    `_qbe_less`. Ties keep their original relative order."""
    var rows_copy: [[text]] = []
    var i = 0
    while i < rows.len():
        rows_copy.push(rows[i])
        i = i + 1
    var n = rows_copy.len()
    var a = 1
    while a < n:
        val key_row = rows_copy[a]
        val key_val = key_row[idx]
        var b = a - 1
        var shifting = true
        while shifting and b >= 0:
            val cur_val = rows_copy[b][idx]
            val should_shift = if descending: _qbe_less(cur_val, key_val) else: _qbe_less(key_val, cur_val)
            if should_shift:
                rows_copy[b + 1] = rows_copy[b]
                b = b - 1
            else:
                shifting = false
        rows_copy[b + 1] = key_row
        a = a + 1
    rows_copy

# =========================================================================
# qbe_run
# =========================================================================

fn qbe_run(qbe: Qbe, table: Table) -> Table:
    """Compile the QBE grid `qbe` against `table`: (1) keep rows where
    EVERY column's criteria matches (AND across columns, empty criteria
    always matches); (2) stable-sort by the FIRST grid column that
    declares a non-empty sort direction; (3) project to only the `shown`
    columns, in grid order. Returns a new Table (table.spl's storage is
    reused via table_new/table_insert, never reimplemented)."""
    var filtered_rows: [[text]] = []
    var i = 0
    while i < table.rows.len():
        val row_vals = table.rows[i]
        if _qbe_row_matches(qbe, table, row_vals):
            filtered_rows.push(row_vals)
        i = i + 1

    var sort_col = ""
    var sort_dir = ""
    var j = 0
    while j < qbe.columns.len() and sort_col == "":
        val qcol = qbe.columns[j]
        if qcol.sort == "asc" or qcol.sort == "desc":
            sort_col = qcol.col
            sort_dir = qcol.sort
        j = j + 1

    if sort_col != "":
        val sort_idx = table_col_index(table, sort_col)
        if sort_idx >= 0:
            filtered_rows = _qbe_sort_rows(filtered_rows, sort_idx, sort_dir == "desc")

    var shown_cols: [text] = []
    var shown_idx: [i32] = []
    var k = 0
    while k < qbe.columns.len():
        val qcol = qbe.columns[k]
        if qcol.shown:
            shown_cols.push(qcol.col)
            shown_idx.push(table_col_index(table, qcol.col))
        k = k + 1

    var out = table_new(table.name, shown_cols)
    var r = 0
    while r < filtered_rows.len():
        val src_row = filtered_rows[r]
        var new_row: [text] = []
        var c = 0
        while c < shown_idx.len():
            val ci = shown_idx[c]
            if ci >= 0 and ci < src_row.len():
                new_row.push(src_row[ci])
            else:
                new_row.push("")
            c = c + 1
        out = table_insert(out, new_row)
        r = r + 1
    out

# =========================================================================
# qbe_criteria_summary
# =========================================================================

fn qbe_criteria_summary(qbe: Qbe) -> [text]:
    """One preview line per grid column that carries a criterion or a sort
    direction: "<col> <criteria> sort=<sort> shown=<true/false>". Columns
    with neither a criterion nor a sort are omitted (nothing to preview)."""
    var lines: [text] = []
    var i = 0
    while i < qbe.columns.len():
        val qcol = qbe.columns[i]
        if qcol.criteria != "" or qcol.sort != "":
            val shown_str = if qcol.shown: "true" else: "false"
            val line = qcol.col + " " + qcol.criteria + " sort=" + qcol.sort + " shown=" + shown_str
            lines.push(line)
        i = i + 1
    lines
