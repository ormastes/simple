# Database <-> Spreadsheet/CSV Bridge
#
# Thin Access-like "import from Excel / export to Excel/CSV" bridge between
# the relational Table (table.spl) and the Sheet spreadsheet model
# (sheets/spreadsheet.spl), plus a quoted-CSV text format. Reuses
# table_new/table_insert for all Table construction — no storage logic here.

use app.office.database.table.{Table, table_new, table_insert}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{CellRef, cell_ref_to_string, cell_display_text}

# =========================================================================
# Table <-> Sheet
# =========================================================================

fn table_to_sheet(table: Table) -> Sheet:
    """Write `table` into a new Sheet: row 0 = column headers (A1, B1, ...),
    data rows follow starting at row 1. RETURN THE OBJECT (Sheet is a class,
    but callers should still reassign at the call site)."""
    var sheet = Sheet.new(table.name)
    var c = 0
    while c < table.cols.len():
        val ref_str = cell_ref_to_string(CellRef(col: c, row: 0))
        sheet.set_value(ref_str, table.cols[c])
        c = c + 1

    var r = 0
    while r < table.rows.len():
        val row_vals = table.rows[r]
        var cc = 0
        while cc < row_vals.len():
            val ref_str = cell_ref_to_string(CellRef(col: cc, row: r + 1))
            sheet.set_value(ref_str, row_vals[cc])
            cc = cc + 1
        r = r + 1
    sheet

fn table_from_sheet(sheet: Sheet, name: text, num_cols: i32, num_rows: i32) -> Table:
    """Read a Table back out of `sheet`: row 0 is the header (column names),
    the next `num_rows` rows are records. Caller passes `num_cols`/`num_rows`
    explicitly to avoid used-range ambiguity."""
    var col_names: [text] = []
    var c = 0
    while c < num_cols:
        val ref_str = cell_ref_to_string(CellRef(col: c, row: 0))
        col_names.push(cell_display_text(sheet.get_cell(ref_str)))
        c = c + 1

    var t = table_new(name, col_names)
    var r = 0
    while r < num_rows:
        var row_vals: [text] = []
        var cc = 0
        while cc < num_cols:
            val ref_str = cell_ref_to_string(CellRef(col: cc, row: r + 1))
            row_vals.push(cell_display_text(sheet.get_cell(ref_str)))
            cc = cc + 1
        t = table_insert(t, row_vals)
        r = r + 1
    t

# =========================================================================
# Table <-> CSV text
# =========================================================================

fn table_to_csv_text(table: Table) -> text:
    """Serialize `table` to CSV text: header line + one line per row.
    Fields containing a comma, quote, or newline are wrapped in double
    quotes with internal quotes escaped as `""`."""
    var lines: [text] = []
    lines.push(_csv_line(table.cols))
    var r = 0
    while r < table.rows.len():
        lines.push(_csv_line(table.rows[r]))
        r = r + 1
    lines.join("\n")

fn table_from_csv_text(text_in: text, name: text) -> Table:
    """Parse CSV text (first line = headers) back into a Table. Handles
    double-quoted fields with embedded commas/newlines/escaped quotes."""
    val lines = text_in.split("\n")
    if lines.len() == 0:
        return table_new(name, [])
    val header_fields = _parse_csv_line(lines[0])
    var t = table_new(name, header_fields)
    var i = 1
    while i < lines.len():
        val line_text = lines[i]
        if line_text.len() > 0:
            t = table_insert(t, _parse_csv_line(line_text))
        i = i + 1
    t

fn _csv_line(fields: [text]) -> text:
    """Join `fields` into one CSV line, quoting each field as needed."""
    var quoted: [text] = []
    var i = 0
    while i < fields.len():
        quoted.push(_csv_quote_field(fields[i]))
        i = i + 1
    quoted.join(",")

fn _csv_quote_field(field: text) -> text:
    """Wrap `field` in double quotes (escaping `"` as `""`) if it contains a
    comma, quote, or newline; otherwise return it unchanged."""
    val needs_quote = field.contains(",") or field.contains("\"") or field.contains("\n")
    if not needs_quote:
        return field
    val escaped = field.replace("\"", "\"\"")
    "\"{escaped}\""

fn _parse_csv_line(line_text: text) -> [text]:
    """Split one CSV line into fields, honoring double-quoted fields with
    `""`-escaped internal quotes."""
    var fields: [text] = []
    var cur = ""
    var in_quotes = false
    val n = line_text.len()
    var i = 0
    while i < n:
        val c = line_text.char_at(i)
        if in_quotes:
            if c == "\"":
                if i + 1 < n and line_text.char_at(i + 1) == "\"":
                    cur = "{cur}\""
                    i = i + 1
                else:
                    in_quotes = false
            else:
                cur = "{cur}{c}"
        else:
            if c == "\"":
                in_quotes = true
            elif c == ",":
                fields.push(cur)
                cur = ""
            else:
                cur = "{cur}{c}"
        i = i + 1
    fields.push(cur)
    fields
