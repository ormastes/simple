# Relational Table
#
# A minimal Access-like table: named columns + rows of values. Every cell is
# stored as `text`; "typed" text/number handling happens on demand at query
# time (see query.spl's numeric-vs-text comparison), not per-column, which
# keeps storage and insert trivial (no column-type registry to keep in sync).
#
# RETURN-THE-OBJECT: `table_insert` cannot mutate its `table` argument in
# place (arrays/structs passed to a fn lose mutations across the fn boundary
# in this interpreter) — it rebuilds and returns a new Table; callers must
# reassign (`t = table_insert(t, row)`).

struct Table:
    """A named table: parallel `cols` (names) and `rows` (each row is a flat
    array of cell values, same length/order as `cols`)."""
    name: text
    cols: [text]
    rows: [[text]]

fn table_new(name: text, col_names: [text]) -> Table:
    """An empty table named `name` with the given column names."""
    Table(name: name, cols: col_names, rows: [])

fn table_col_index(table: Table, col_name: text) -> i32:
    """Index of `col_name` in `table.cols`, or -1 if no such column."""
    var i = 0
    while i < table.cols.len():
        if table.cols[i] == col_name:
            return i
        i = i + 1
    -1

fn table_insert(table: Table, values: [text]) -> Table:
    """Append a row of `values` (must align with `table.cols`). Returns a new
    Table with the row appended — RETURN THE OBJECT, reassign at call site."""
    var new_rows: [[text]] = []
    var i = 0
    while i < table.rows.len():
        new_rows.push(table.rows[i])
        i = i + 1
    new_rows.push(values)
    Table(name: table.name, cols: table.cols, rows: new_rows)

fn table_row_count(table: Table) -> i32:
    """Number of rows currently in `table`."""
    table.rows.len()

fn table_get(table: Table, row: i32, col_name: text) -> text:
    """Cell value at (`row`, `col_name`). Returns "" if the column is unknown
    or `row` is out of range (fail-soft, not an error)."""
    val idx = table_col_index(table, col_name)
    if idx < 0:
        return ""
    if row < 0 or row >= table.rows.len():
        return ""
    val row_vals = table.rows[row]
    if idx >= row_vals.len():
        return ""
    row_vals[idx]
