# Table Relationships + Referential Integrity
#
# Access-style foreign-key relationships between two table.spl `Table`s:
# declare which child column references which parent column, then check/
# enforce referential integrity (orphan detection, insert/delete gating,
# and an FK-driven inner join). Reuses table.spl's table_new/table_insert/
# table_col_index/table_get for all storage — no separate storage or a
# generic join engine, just FK-shaped composition of the existing Table.

use app.office.database.table.{Table, table_new, table_insert, table_col_index, table_get, table_row_count}

struct Relationship:
    """A declared foreign key: `child_table.child_col` references
    `parent_table.parent_col`. Table names are stored as text (not live
    `Table` references) so a relationship can be declared before either
    table is loaded, same as Access's relationship designer."""
    child_table: text
    child_col: text
    parent_table: text
    parent_col: text

fn relationship_new(child_table: text, child_col: text, parent_table: text, parent_col: text) -> Relationship:
    """Declare a foreign key: `child_table.child_col` -> `parent_table.parent_col`."""
    Relationship(child_table: child_table, child_col: child_col, parent_table: parent_table, parent_col: parent_col)

# =========================================================================
# Internal helpers
# =========================================================================

fn _col_has_value(table: Table, idx: i32, value: text) -> bool:
    """True if some row of `table` has `value` at column index `idx`.
    `idx < 0` (unknown column) never matches."""
    if idx < 0:
        return false
    var i = 0
    while i < table.rows.len():
        val row_vals = table.rows[i]
        if idx < row_vals.len() and row_vals[idx] == value:
            return true
        i = i + 1
    false

# =========================================================================
# ref_integrity_check
# =========================================================================

fn ref_integrity_check(parent: Table, child: Table, parent_col: text, child_col: text) -> [text]:
    """Referential-integrity report: one `"orphan: <child_col>=<value>"`
    message per child row whose `child_col` value is non-empty and does not
    appear anywhere in the parent's `parent_col`. Empty FK values are treated
    as allowed nulls (not orphans). Empty result list = referentially intact."""
    val pidx = table_col_index(parent, parent_col)
    val cidx = table_col_index(child, child_col)
    var violations: [text] = []
    if cidx < 0:
        return violations
    var i = 0
    while i < child.rows.len():
        val row_vals = child.rows[i]
        if cidx < row_vals.len():
            val fk_value = row_vals[cidx]
            if fk_value != "" and not _col_has_value(parent, pidx, fk_value):
                violations.push("orphan: {child_col}={fk_value}")
        i = i + 1
    violations

# =========================================================================
# can_insert_child
# =========================================================================

fn can_insert_child(parent: Table, child_values: [text], child_col_index: i32, parent_col: text) -> bool:
    """True iff inserting `child_values` into the child table would keep
    referential integrity: the FK value at `child_values[child_col_index]`
    must exist in `parent.parent_col`, or be empty (allowed null FK)."""
    if child_col_index < 0 or child_col_index >= child_values.len():
        return false
    val fk_value = child_values[child_col_index]
    if fk_value == "":
        return true
    val pidx = table_col_index(parent, parent_col)
    _col_has_value(parent, pidx, fk_value)

# =========================================================================
# can_delete_parent
# =========================================================================

fn can_delete_parent(parent: Table, child: Table, parent_row_index: i32, parent_col: text, child_col: text) -> bool:
    """True iff deleting row `parent_row_index` from `parent` would not
    orphan any child row (Access's restrict-delete): no row of `child` may
    reference the parent row's `parent_col` value via `child_col`."""
    val parent_value = table_get(parent, parent_row_index, parent_col)
    val cidx = table_col_index(child, child_col)
    if cidx < 0:
        return true
    var i = 0
    while i < child.rows.len():
        val row_vals = child.rows[i]
        if cidx < row_vals.len() and row_vals[cidx] == parent_value:
            return false
        i = i + 1
    true

# =========================================================================
# join_on_fk
# =========================================================================

fn join_on_fk(parent: Table, child: Table, parent_col: text, child_col: text) -> Table:
    """Inner join of `child` to `parent` on the declared FK: every (child
    row, parent row) pair whose `child_col`/`parent_col` values compare
    exactly equal. Result columns are `child.cols` followed by `parent.cols`
    (child-then-parent, matching Access's child-datasheet-with-parent-
    lookup convention); unmatched child rows are dropped. Unknown join
    column on either side yields an empty table with the concatenated
    shape (fail-soft)."""
    val pidx = table_col_index(parent, parent_col)
    val cidx = table_col_index(child, child_col)
    var new_cols: [text] = []
    var i = 0
    while i < child.cols.len():
        new_cols.push(child.cols[i])
        i = i + 1
    i = 0
    while i < parent.cols.len():
        new_cols.push(parent.cols[i])
        i = i + 1
    var out = table_new("{child.name}_{parent.name}", new_cols)
    if pidx < 0 or cidx < 0:
        return out
    var ci = 0
    while ci < child.rows.len():
        val crow = child.rows[ci]
        if cidx < crow.len():
            val fk_value = crow[cidx]
            var pi = 0
            while pi < parent.rows.len():
                val prow = parent.rows[pi]
                if pidx < prow.len() and prow[pidx] == fk_value:
                    var joined_row: [text] = []
                    var k = 0
                    while k < crow.len():
                        joined_row.push(crow[k])
                        k = k + 1
                    k = 0
                    while k < prow.len():
                        joined_row.push(prow[k])
                        k = k + 1
                    out = table_insert(out, joined_row)
                pi = pi + 1
        ci = ci + 1
    out
