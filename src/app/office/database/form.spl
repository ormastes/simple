# Access-style Data-Entry Form
#
# A minimal bound form over table.spl's Table: an ordered list of field
# specs (col/label/required/kind), HTML rendering, hand-rolled validation,
# and submit-as-insert. Reuses table_insert/table_row_count/table_col_index
# for all storage — this file only adds the field metadata + HTML/validation
# layer on top.
#
# RETURN-THE-OBJECT: `form_add_field` and `form_submit` cannot mutate their
# `form` argument in place (structs passed to a fn lose mutations across the
# fn boundary in this interpreter) — they rebuild and return a new Form;
# callers must reassign (`f = form_add_field(f, spec)`).

use app.office.database.table.{Table, table_col_index, table_insert, table_row_count}

struct FieldSpec:
    """One bound field: `col` is the table column it maps to, `label` is the
    display label, `required` marks it mandatory, `kind` is "text" or
    "number" (drives the HTML input type and validation)."""
    col: text
    label: text
    required: bool
    kind: text

struct Form:
    """A data-entry form: `title`, ordered `fields`, and the bound `table`."""
    title: text
    fields: [FieldSpec]
    table: Table

fn form_new(title: text, table: Table) -> Form:
    """A form named `title` bound to `table`, with no fields yet."""
    Form(title: title, fields: [], table: table)

fn form_add_field(form: Form, field: FieldSpec) -> Form:
    """Append `field` to `form.fields` — RETURN THE OBJECT, reassign at call
    site."""
    var new_fields: [FieldSpec] = []
    var i = 0
    while i < form.fields.len():
        new_fields.push(form.fields[i])
        i = i + 1
    new_fields.push(field)
    Form(title: form.title, fields: new_fields, table: form.table)

# =========================================================================
# Internal helpers
# =========================================================================

fn _html_escape(s: text) -> text:
    """Escape &, <, >, and " for safe embedding in HTML attributes/text."""
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "&":
            out = out + "&amp;"
        elif ch == "<":
            out = out + "&lt;"
        elif ch == ">":
            out = out + "&gt;"
        elif ch == "\"":
            out = out + "&quot;"
        else:
            out = out + ch
        i = i + 1
    out

fn _is_numeric_text(s: text) -> bool:
    """True if `s` looks like a plain number (optional leading '-', digits,
    at most one '.'). Hand-rolled rather than trusting `to_f64()` alone:
    `to_f64()` silently returns 0.0 for garbage text, which would
    misclassify non-numeric values as numeric zero."""
    if s == "":
        return false
    var i = 0
    var has_digit = false
    var has_dot = false
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "-" and i == 0:
            pass_do_nothing("leading minus sign allowed")
        elif ch == ".":
            if has_dot:
                return false
            has_dot = true
        elif ch >= "0" and ch <= "9":
            has_digit = true
        else:
            return false
        i = i + 1
    has_digit

# =========================================================================
# Public API
# =========================================================================

fn form_render_html(form: Form) -> text:
    """Render `form` as a self-contained HTML <form>: one <label> + <input>
    per field, in field order. Input type is "number" or "text" per
    `kind`, with a `required` attribute when the field is required. Labels
    and attribute values are HTML-escaped."""
    var html = "<form>\n"
    var i = 0
    while i < form.fields.len():
        val field = form.fields[i]
        var actual_type = "text"
        if field.kind == "number":
            actual_type = "number"
        val label_html = _html_escape(field.label)
        val col_html = _html_escape(field.col)
        html = html + "  <label>" + label_html + "</label>\n"
        html = html + "  <input type=\"" + actual_type + "\" name=\"" + col_html + "\""
        if field.required:
            html = html + " required"
        html = html + ">\n"
        i = i + 1
    html = html + "</form>\n"
    html

fn form_validate(form: Form, values: [text]) -> [text]:
    """Validate `values` (one per field, in field order) against `form`'s
    field specs. Returns a list of human-readable error messages, in field
    order; an empty list means the values are valid."""
    var errors: [text] = []
    var i = 0
    while i < form.fields.len():
        val field = form.fields[i]
        var value = ""
        if i < values.len():
            value = values[i]
        if field.required and value == "":
            errors.push(field.label + " is required")
        elif field.kind == "number" and value != "" and not _is_numeric_text(value):
            errors.push(field.label + " must be a number")
        i = i + 1
    errors

fn form_submit(form: Form, values: [text]) -> Form:
    """Validate `values`; if valid, insert a new row into the bound table
    (mapping field values to their columns, unmapped columns get "") and
    return a Form with the updated table. If invalid, return `form`
    unchanged — RETURN THE OBJECT, reassign at call site; check
    `form_validate` first (or compare row counts) to know which happened."""
    val errors = form_validate(form, values)
    if errors.len() > 0:
        return form
    var row: [text] = []
    var c = 0
    while c < form.table.cols.len():
        val col_name = form.table.cols[c]
        var cell = ""
        var i = 0
        while i < form.fields.len():
            if form.fields[i].col == col_name and i < values.len():
                cell = values[i]
            i = i + 1
        row.push(cell)
        c = c + 1
    val new_table = table_insert(form.table, row)
    Form(title: form.title, fields: form.fields, table: new_table)

fn form_row_count(form: Form) -> i32:
    """Number of rows currently in the bound table."""
    table_row_count(form.table)
