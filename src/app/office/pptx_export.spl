# PPTX Export — Impress decks as real PowerPoint packages
#
# Builds a complete OPC package: content types, package rels, presentation
# (master list + slide list), a minimal slide master / layout / theme trio
# (required by strict OOXML consumers), and one slide part per deck slide with
# positioned text boxes (px -> EMU at 9525/px).
#
# Verified structurally: system unzip validates the archive; our own zip
# reader round-trips every part; slide text lands in a:t runs. Full
# PowerPoint-desktop rendering is untested locally — recorded ceiling.

use std.common.archive.zip.{zip_write_stored, zip_text_file, ZipFile, zip_extract_text}
use app.office.slides.slide.{Slide, SlideElement, SlideElementKind, blank_slide, add_text_box}

fn _x(s: text) -> text:
    var r = s
    r = r.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r

val _NS_A = "http://schemas.openxmlformats.org/drawingml/2006/main"
val _NS_P = "http://schemas.openxmlformats.org/presentationml/2006/main"
val _NS_R = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"

val _THEME = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><a:theme xmlns:a=\"http://schemas.openxmlformats.org/drawingml/2006/main\" name=\"Office\"><a:themeElements><a:clrScheme name=\"Office\"><a:dk1><a:sysClr val=\"windowText\" lastClr=\"000000\"/></a:dk1><a:lt1><a:sysClr val=\"window\" lastClr=\"FFFFFF\"/></a:lt1><a:dk2><a:srgbClr val=\"44546A\"/></a:dk2><a:lt2><a:srgbClr val=\"E7E6E6\"/></a:lt2><a:accent1><a:srgbClr val=\"4472C4\"/></a:accent1><a:accent2><a:srgbClr val=\"ED7D31\"/></a:accent2><a:accent3><a:srgbClr val=\"A5A5A5\"/></a:accent3><a:accent4><a:srgbClr val=\"FFC000\"/></a:accent4><a:accent5><a:srgbClr val=\"5B9BD5\"/></a:accent5><a:accent6><a:srgbClr val=\"70AD47\"/></a:accent6><a:hlink><a:srgbClr val=\"0563C1\"/></a:hlink><a:folHlink><a:srgbClr val=\"954F72\"/></a:folHlink></a:clrScheme><a:fontScheme name=\"Office\"><a:majorFont><a:latin typeface=\"Calibri Light\"/><a:ea typeface=\"\"/><a:cs typeface=\"\"/></a:majorFont><a:minorFont><a:latin typeface=\"Calibri\"/><a:ea typeface=\"\"/><a:cs typeface=\"\"/></a:minorFont></a:fontScheme><a:fmtScheme name=\"Office\"><a:fillStyleLst><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill></a:fillStyleLst><a:lnStyleLst><a:ln><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill></a:ln><a:ln><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill></a:ln><a:ln><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill></a:ln></a:lnStyleLst><a:effectStyleLst><a:effectStyle><a:effectLst/></a:effectStyle><a:effectStyle><a:effectLst/></a:effectStyle><a:effectStyle><a:effectLst/></a:effectStyle></a:effectStyleLst><a:bgFillStyleLst><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill><a:solidFill><a:schemeClr val=\"phClr\"/></a:solidFill></a:bgFillStyleLst></a:fmtScheme></a:themeElements></a:theme>"

fn _sp_tree_open() -> text:
    "<p:spTree><p:nvGrpSpPr><p:cNvPr id=\"1\" name=\"\"/><p:cNvGrpSpPr/><p:nvPr/></p:nvGrpSpPr><p:grpSpPr><a:xfrm><a:off x=\"0\" y=\"0\"/><a:ext cx=\"0\" cy=\"0\"/><a:chOff x=\"0\" y=\"0\"/><a:chExt cx=\"0\" cy=\"0\"/></a:xfrm></p:grpSpPr>"

fn _text_shape(id: i32, name: text, content: text, x: i32, y: i32, w: i32, h: i32) -> text:
    """One positioned text box shape. Coordinates are px, emitted as EMU."""
    val emu_x = x.to_i64() * 9525
    val emu_y = y.to_i64() * 9525
    val emu_w = w.to_i64() * 9525
    val emu_h = h.to_i64() * 9525
    var out = "<p:sp><p:nvSpPr><p:cNvPr id=\"{id}\" name=\"{name}\"/><p:cNvSpPr/><p:nvPr/></p:nvSpPr>"
    out = "{out}<p:spPr><a:xfrm><a:off x=\"{emu_x}\" y=\"{emu_y}\"/><a:ext cx=\"{emu_w}\" cy=\"{emu_h}\"/></a:xfrm><a:prstGeom prst=\"rect\"><a:avLst/></a:prstGeom></p:spPr>"
    out = "{out}<p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:r><a:t>{_x(content)}</a:t></a:r></a:p></p:txBody></p:sp>"
    out

fn _transition_xml(transition: text) -> text:
    """Map a deck transition name to a `<p:transition>` child. Empty or
    unrecognized values emit no element (schema treats it as optional)."""
    if transition == "fade":
        return "<p:transition><p:fade/></p:transition>"
    if transition == "wipe":
        return "<p:transition><p:wipe/></p:transition>"
    if transition == "push":
        return "<p:transition><p:push/></p:transition>"
    ""

fn _slide_xml(slide: Slide) -> text:
    var shapes = ""
    var id = 2
    for el in slide.elements:
        match el.kind:
            SlideElementKind.TextBox(content):
                shapes = "{shapes}{_text_shape(id, el.id, content, el.x, el.y, el.width, el.height)}"
                id = id + 1
            _:
                pass_do_nothing("only text boxes export to pptx v1")
    val transition_xml = _transition_xml(slide.transition)
    "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:sld xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\"><p:cSld>{_sp_tree_open()}{shapes}</p:spTree></p:cSld><p:clrMapOvr><a:overrideClrMapping bg1=\"lt1\" tx1=\"dk1\" bg2=\"lt2\" tx2=\"dk2\" accent1=\"accent1\" accent2=\"accent2\" accent3=\"accent3\" accent4=\"accent4\" accent5=\"accent5\" accent6=\"accent6\" hlink=\"hlink\" folHlink=\"folHlink\"/></p:clrMapOvr>{transition_xml}</p:sld>"

fn _notes_paragraphs_xml(notes: text) -> text:
    """One `<a:p>` per newline-separated line of speaker notes."""
    var out = ""
    for line in notes.split("\n"):
        out = "{out}<a:p><a:r><a:t>{_x(line)}</a:t></a:r></a:p>"
    out

fn _notes_slide_xml(notes: text) -> text:
    """Minimal notesSlide part: a notes-body placeholder shape holding the
    speaker notes text, per ECMA-376 CT_NotesSlide."""
    val paragraphs = _notes_paragraphs_xml(notes)
    "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:notes xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\"><p:cSld><p:spTree><p:nvGrpSpPr><p:cNvPr id=\"1\" name=\"\"/><p:cNvGrpSpPr/><p:nvPr/></p:nvGrpSpPr><p:grpSpPr/><p:sp><p:nvSpPr><p:cNvPr id=\"2\" name=\"Notes Placeholder\"/><p:cNvSpPr><a:spLocks noGrp=\"1\"/></p:cNvSpPr><p:nvPr><p:ph type=\"body\" idx=\"1\"/></p:nvPr></p:nvSpPr><p:spPr/><p:txBody><a:bodyPr/><a:lstStyle/>{paragraphs}</p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:notes>"

# =========================================================================
# PPTX import
# =========================================================================

fn _find_at(s: text, needle: text, from: i32) -> i32:
    var i = from
    while i + needle.len() <= s.len():
        if s.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn _unx(s: text) -> text:
    var r = s
    r = r.replace("&lt;", "<")
    r = r.replace("&gt;", ">")
    r = r.replace("&quot;", "\"")
    r = r.replace("&amp;", "&")
    r

fn pptx_slide_texts(slide_xml: text) -> [text]:
    """Every a:t run's text, in document order."""
    var texts: [text] = []
    var i = 0
    while i < slide_xml.len():
        val t = _find_at(slide_xml, "<a:t>", i)
        if t < 0:
            break
        val e = _find_at(slide_xml, "</a:t>", t)
        if e < 0:
            break
        texts.push(_unx(slide_xml.slice(t + 5, e)))
        i = e + 6
    texts

fn _extract_transition(slide_xml: text) -> text:
    """Read back the `<p:transition>` child written by `_transition_xml`."""
    if _find_at(slide_xml, "<p:transition>", 0) < 0:
        return ""
    if _find_at(slide_xml, "<p:fade/>", 0) >= 0:
        return "fade"
    if _find_at(slide_xml, "<p:wipe/>", 0) >= 0:
        return "wipe"
    if _find_at(slide_xml, "<p:push/>", 0) >= 0:
        return "push"
    ""

fn _notes_slide_text(notes_xml: text) -> text:
    """Join a notesSlide part's a:t runs (one per paragraph) back into
    newline-separated speaker notes text."""
    var out = ""
    var first = true
    for t in pptx_slide_texts(notes_xml):
        if first:
            out = t
            first = false
        else:
            out = "{out}\n{t}"
    out

fn pptx_bytes_to_deck(zip_bytes: [u8]) -> [Slide]:
    """Import a real .pptx: each slide part's text runs become a slide with a
    title box (first run) and body boxes — the same shape parse_deck builds.
    Transitions and speaker notes are read back from `<p:transition>` and the
    matching `ppt/notesSlides/notesSlideN.xml` part, if present."""
    var slides: [Slide] = []
    var n = 1
    var more = true
    while more and n <= 500:
        val xml = zip_extract_text(zip_bytes, "ppt/slides/slide{n}.xml")
        if xml == "":
            more = false
        else:
            var s = blank_slide("slide{slides.len() + 1}")
            var bi = 0
            for content in pptx_slide_texts(xml):
                if bi == 0:
                    s = add_text_box(s, "title", content, 60, 60, 840, 120)
                else:
                    s = add_text_box(s, "body{bi}", content, 60, 220 + 90 * (bi - 1), 840, 80)
                bi = bi + 1
            val transition = _extract_transition(xml)
            val notes_xml = zip_extract_text(zip_bytes, "ppt/notesSlides/notesSlide{n}.xml")
            var notes = ""
            if notes_xml != "":
                notes = _notes_slide_text(notes_xml)
            s = Slide(
                id: s.id,
                layout: s.layout,
                elements: s.elements,
                notes: notes,
                background: s.background,
                transition: transition
            )
            slides.push(s)
            n = n + 1
    slides

val _SLIDE_RELS ="<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideLayout\" Target=\"../slideLayouts/slideLayout1.xml\"/></Relationships>"

val _NOTES_MASTER_XML = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:notesMaster xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\"><p:cSld>{_sp_tree_open()}</p:spTree></p:cSld><p:clrMap bg1=\"lt1\" tx1=\"dk1\" bg2=\"lt2\" tx2=\"dk2\" accent1=\"accent1\" accent2=\"accent2\" accent3=\"accent3\" accent4=\"accent4\" accent5=\"accent5\" accent6=\"accent6\" hlink=\"hlink\" folHlink=\"folHlink\"/></p:notesMaster>"

val _NOTES_MASTER_RELS = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/theme\" Target=\"../theme/theme1.xml\"/></Relationships>"

val _NOTES_SLIDE_RELS = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/notesMaster\" Target=\"../notesMasters/notesMaster1.xml\"/></Relationships>"

fn _slide_rels_with_notes(i: i32) -> text:
    """Slide rels for a slide that has speaker notes: slideLayout plus a
    relationship to its notesSlide part."""
    "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideLayout\" Target=\"../slideLayouts/slideLayout1.xml\"/><Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/notesSlide\" Target=\"../notesSlides/notesSlide{i}.xml\"/></Relationships>"

fn _any_slide_has_notes(slides: [Slide]) -> bool:
    for slide in slides:
        if slide.notes != "":
            return true
    false

fn deck_to_pptx_bytes(slides: [Slide]) -> [u8]:
    """Build a genuine .pptx package from a deck. Text boxes only (v1).
    Slides with non-empty `notes` get a notesSlide part (plus the shared
    notesMaster part/relationships required to reference it); slides with a
    `transition` get a `<p:transition>` child in their slide XML."""
    var files: [ZipFile] = []
    val has_notes = _any_slide_has_notes(slides)
    # content types
    var overrides = "<Override PartName=\"/ppt/presentation.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.presentation.main+xml\"/><Override PartName=\"/ppt/slideMasters/slideMaster1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.slideMaster+xml\"/><Override PartName=\"/ppt/slideLayouts/slideLayout1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.slideLayout+xml\"/><Override PartName=\"/ppt/theme/theme1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.theme+xml\"/>"
    if has_notes:
        overrides = "{overrides}<Override PartName=\"/ppt/notesMasters/notesMaster1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.notesMaster+xml\"/>"
    var i = 1
    while i <= slides.len():
        overrides = "{overrides}<Override PartName=\"/ppt/slides/slide{i}.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.slide+xml\"/>"
        if slides[i - 1].notes != "":
            overrides = "{overrides}<Override PartName=\"/ppt/notesSlides/notesSlide{i}.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.presentationml.notesSlide+xml\"/>"
        i = i + 1
    files.push(zip_text_file("[Content_Types].xml", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\"><Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/><Default Extension=\"xml\" ContentType=\"application/xml\"/>{overrides}</Types>"))
    files.push(zip_text_file("_rels/.rels", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"ppt/presentation.xml\"/></Relationships>"))
    # presentation + rels
    var sld_ids = ""
    var pres_rels = "<Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideMaster\" Target=\"slideMasters/slideMaster1.xml\"/>"
    i = 1
    while i <= slides.len():
        sld_ids = "{sld_ids}<p:sldId id=\"{255 + i}\" r:id=\"rId{i + 1}\"/>"
        pres_rels = "{pres_rels}<Relationship Id=\"rId{i + 1}\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slide\" Target=\"slides/slide{i}.xml\"/>"
        i = i + 1
    var notes_master_lst = ""
    if has_notes:
        val notes_master_rid = "rId{slides.len() + 2}"
        pres_rels = "{pres_rels}<Relationship Id=\"{notes_master_rid}\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/notesMaster\" Target=\"notesMasters/notesMaster1.xml\"/>"
        notes_master_lst = "<p:notesMasterIdLst><p:notesMasterId r:id=\"{notes_master_rid}\"/></p:notesMasterIdLst>"
    files.push(zip_text_file("ppt/presentation.xml", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:presentation xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\"><p:sldMasterIdLst><p:sldMasterId id=\"2147483648\" r:id=\"rId1\"/></p:sldMasterIdLst>{notes_master_lst}<p:sldIdLst>{sld_ids}</p:sldIdLst><p:sldSz cx=\"9144000\" cy=\"5143500\"/><p:notesSz cx=\"6858000\" cy=\"9144000\"/></p:presentation>"))
    files.push(zip_text_file("ppt/_rels/presentation.xml.rels", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">{pres_rels}</Relationships>"))
    # master / layout / theme
    files.push(zip_text_file("ppt/slideMasters/slideMaster1.xml", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:sldMaster xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\"><p:cSld>{_sp_tree_open()}</p:spTree></p:cSld><p:clrMap bg1=\"lt1\" tx1=\"dk1\" bg2=\"lt2\" tx2=\"dk2\" accent1=\"accent1\" accent2=\"accent2\" accent3=\"accent3\" accent4=\"accent4\" accent5=\"accent5\" accent6=\"accent6\" hlink=\"hlink\" folHlink=\"folHlink\"/><p:sldLayoutIdLst><p:sldLayoutId id=\"2147483649\" r:id=\"rId1\"/></p:sldLayoutIdLst></p:sldMaster>"))
    files.push(zip_text_file("ppt/slideMasters/_rels/slideMaster1.xml.rels", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideLayout\" Target=\"../slideLayouts/slideLayout1.xml\"/><Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/theme\" Target=\"../theme/theme1.xml\"/></Relationships>"))
    files.push(zip_text_file("ppt/slideLayouts/slideLayout1.xml", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><p:sldLayout xmlns:a=\"{_NS_A}\" xmlns:p=\"{_NS_P}\" xmlns:r=\"{_NS_R}\" type=\"blank\"><p:cSld>{_sp_tree_open()}</p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sldLayout>"))
    files.push(zip_text_file("ppt/slideLayouts/_rels/slideLayout1.xml.rels", "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideMaster\" Target=\"../slideMasters/slideMaster1.xml\"/></Relationships>"))
    files.push(zip_text_file("ppt/theme/theme1.xml", _THEME))
    if has_notes:
        files.push(zip_text_file("ppt/notesMasters/notesMaster1.xml", _NOTES_MASTER_XML))
        files.push(zip_text_file("ppt/notesMasters/_rels/notesMaster1.xml.rels", _NOTES_MASTER_RELS))
    # slides
    i = 1
    for slide in slides:
        files.push(zip_text_file("ppt/slides/slide{i}.xml", _slide_xml(slide)))
        if slide.notes != "":
            files.push(zip_text_file("ppt/slides/_rels/slide{i}.xml.rels", _slide_rels_with_notes(i)))
            files.push(zip_text_file("ppt/notesSlides/notesSlide{i}.xml", _notes_slide_xml(slide.notes)))
            files.push(zip_text_file("ppt/notesSlides/_rels/notesSlide{i}.xml.rels", _NOTES_SLIDE_RELS))
        else:
            files.push(zip_text_file("ppt/slides/_rels/slide{i}.xml.rels", _SLIDE_RELS))
        i = i + 1
    zip_write_stored(files)
