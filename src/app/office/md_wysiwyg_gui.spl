# md_wysiwyg_gui.spl — render a markdown file through the WYSIWYG preview path
# (build_wysiwyg_view -> wysiwyg_preview_pane -> styled HTML) and present it to a
# window via the pure-Simple web renderer backed by Engine2D CPU SIMD.
#
# Mirrors examples/06_io/ui/web_render_file_gui.spl, but accepts markdown instead
# of pre-converted HTML. The window is only opened when SIMPLE_GUI == "1";
# otherwise it renders headlessly and returns 0.
#
# Run (window):
#   SIMPLE_GUI=1 SIMPLE_TIMEOUT_SECONDS=0 scripts/macos-gui-run.shs \
#     src/app/office/md_wysiwyg_gui.spl doc.md
# Headless: drop SIMPLE_GUI / use bin/simple run.

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}
use app.office.md_wysiwyg.{build_wysiwyg_view, wysiwyg_preview_pane}
use std.io.window_winit.{WinitLoop, WinitWindow, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_close_requested}
use std.sffi.cli.{cli_get_args}

use std.io_runtime.{env_get, read_file, file_exists}

# First argv entry that ends in .md, else empty.
fn md_path() -> text:
    val args = cli_get_args()
    var i = 0
    while i < args.len():
        if args[i].ends_with(".md"):
            return args[i]
        i = i + 1
    ""

val RW: i32 = 80
val RH: i32 = 60
val W: i32 = 80
val H: i32 = 60

fn pack_pixels(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

# Build the WYSIWYG styled preview HTML from raw markdown source.
fn markdown_preview_html(md_source: text) -> text:
    val view = build_wysiwyg_view(md_source)
    wysiwyg_preview_pane(view)

fn main() -> i64:
    val path = md_path()
    if path == "":
        print "No .md argument supplied"
        return 1
    if not file_exists(path):
        print "Markdown file not found: {path}"
        return 1
    val md_source = read_file(path)
    val html = markdown_preview_html(md_source)
    val resolved = simple_web_resolved_engine2d_backend_name(RW, RH, "cpu_simd")
    print "Pure-Simple markdown WYSIWYG render of {path} ({md_source.len()} bytes md, {html.len()} bytes html) at {W}x{H}"
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, RW, RH, "cpu_simd")
    print "Rendered {pixels.len()} px via requested backend 'cpu_simd' resolved='{resolved}'"

    if env_get("SIMPLE_GUI") != "1":
        print "No GUI requested; headless render only."
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime available."
        return 0
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Pure-Simple markdown WYSIWYG — {path}")
    if not win.is_valid:
        print "Window creation failed."
        winit_loop_free(lp)
        return 0
    val packed = pack_pixels(pixels)
    if not winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed):
        winit_window_free(win)
        winit_loop_free(lp)
        return 2
    var running = true
    var present_failed = false
    var iters = 0
    while running and iters < 2000000:
        if winit_poll_close_requested(lp):
            running = false
        if iters % 200 == 0:
            if not winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed):
                present_failed = true
                running = false
        iters = iters + 1
    winit_window_free(win)
    winit_loop_free(lp)
    if present_failed:
        return 2
    return 0
