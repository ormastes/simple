# ODT / DOCX Import + real .odt Writer
#
# Reads the two dominant office container formats into the suite's document
# model, and writes genuine zipped .odt files:
#   - .odt  (LibreOffice): content.xml   -> text:h / text:p / list items
#   - .docx (MS Word):     word/document.xml -> w:p paragraphs, Heading styles,
#     concatenated w:t runs
#
# Parsing is a targeted tag scan (find/strip/unescape), not a general XML DOM —
# enough to import real documents' text structure faithfully.
# ponytail: character-run styling (bold/italic spans) imports as plain text;
# add run-property scanning when styled import matters.

use std.common.archive.zip.{zip_extract_text, zip_write_stored, zip_text_file, ZipFile}
use common.rich_text.attributed_text.{RichDocument, DocBlock, BlockKind, TextSpan, InlineStyle}
use app.office.odf_export.{document_to_fodt, sheet_to_fods}
use app.office.file_formats.{parse_inline_spans, recalculate_formula_cells}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{col_to_letter, parse_cell_ref, CellValue}
use app.office.sheets.cell_format.{FormatSpec, SheetFormats, empty_sheet_formats, formats_get, formats_set}

# =========================================================================
# XML helpers
# =========================================================================

fn _find_from(s: text, needle: text, from: i32) -> i32:
    var i = from
    while i + needle.len() <= s.len():
        if s.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn _strip_tags(s: text) -> text:
    """Remove every <...> span, keeping the character data."""
    var out = ""
    var i = 0
    var in_tag = false
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "<":
            in_tag = true
        elif ch == ">":
            in_tag = false
        elif not in_tag:
            out = "{out}{ch}"
        i = i + 1
    out

fn _xml_unescape(s: text) -> text:
    var r = s
    r = r.replace("&lt;", "<")
    r = r.replace("&gt;", ">")
    r = r.replace("&quot;", "\"")
    r = r.replace("&apos;", "'")
    r = r.replace("&amp;", "&")
    r

fn _span(s: text) -> TextSpan:
    TextSpan(text: s, style: InlineStyle.Normal)

fn _plain_block(kind: BlockKind, content: text) -> DocBlock:
    DocBlock(kind: kind, spans: [_span(content)])

# =========================================================================
# ODT import
# =========================================================================

fn _odf_heading_kind(level_attr: text) -> BlockKind:
    if level_attr.contains("\"1\""):
        return BlockKind.Heading1
    if level_attr.contains("\"2\""):
        return BlockKind.Heading2
    BlockKind.Heading3

fn odt_content_to_document(content_xml: text, title: text) -> RichDocument:
    """Parse ODF content.xml into a RichDocument (headings, paragraphs, lists)."""
    var doc = RichDocument.new(title)
    var i = 0
    while i < content_xml.len():
        val h = _find_from(content_xml, "<text:h", i)
        val p = _find_from(content_xml, "<text:p", i)
        if h < 0 and p < 0:
            break
        val is_heading = h >= 0 and (p < 0 or h < p)
        val start = if is_heading: h else: p
        val close = if is_heading: "</text:h>" else: "</text:p>"
        val tag_end = _find_from(content_xml, ">", start)
        val end_pos = _find_from(content_xml, close, start)
        if tag_end < 0 or end_pos < 0:
            break
        val attrs = content_xml.slice(start, tag_end)
        val inner = content_xml.slice(tag_end + 1, end_pos)
        val content = _xml_unescape(_strip_tags(inner))
        # A text:p inside a list item becomes a bullet
        val before = content_xml.slice(_max0(start - 40), start)
        if is_heading:
            doc.blocks.push(_plain_block(_odf_heading_kind(attrs), content))
        elif before.contains("<text:list-item>"):
            doc.blocks.push(_plain_block(BlockKind.BulletItem, content))
        elif content.trim() != "":
            doc.blocks.push(_plain_block(BlockKind.Paragraph, content))
        i = end_pos + close.len()
    doc

fn _max0(v: i32) -> i32:
    if v < 0:
        return 0
    v

fn odt_bytes_to_document(zip_bytes: [u8], title: text) -> RichDocument:
    """Import a real .odt file (zip container) into a RichDocument."""
    odt_content_to_document(zip_extract_text(zip_bytes, "content.xml"), title)

# =========================================================================
# DOCX import
# =========================================================================

fn _docx_para_kind(para_xml: text) -> BlockKind:
    if para_xml.contains("w:val=\"Heading1\""):
        return BlockKind.Heading1
    if para_xml.contains("w:val=\"Heading2\""):
        return BlockKind.Heading2
    if para_xml.contains("w:val=\"Heading3\""):
        return BlockKind.Heading3
    if para_xml.contains("w:val=\"ListParagraph\""):
        return BlockKind.BulletItem
    BlockKind.Paragraph

fn _docx_para_text(para_xml: text) -> text:
    """Concatenate every <w:t> run's text within one paragraph."""
    var out = ""
    for span in _docx_para_spans(para_xml):
        out = "{out}{span.text}"
    out

fn _docx_para_spans(para_xml: text) -> [TextSpan]:
    """One styled span per <w:r> run: w:b -> Bold, w:i -> Italic (bold wins
    when both are set — the span model carries one style)."""
    var spans: [TextSpan] = []
    var i = 0
    while i < para_xml.len():
        val r = _find_from(para_xml, "<w:r>", i)
        val r2 = _find_from(para_xml, "<w:r ", i)
        val start = if r >= 0 and (r2 < 0 or r < r2): r else: r2
        if start < 0:
            break
        val end_pos = _find_from(para_xml, "</w:r>", start)
        if end_pos < 0:
            break
        val run = para_xml.slice(start, end_pos)
        val t = _find_from(run, "<w:t", 0)
        if t >= 0:
            val tag_end = _find_from(run, ">", t)
            val te = _find_from(run, "</w:t>", t)
            if tag_end >= 0 and te > tag_end:
                val content = _xml_unescape(run.slice(tag_end + 1, te))
                var style = InlineStyle.Normal
                if run.contains("<w:b/>") or run.contains("<w:b "):
                    style = InlineStyle.Bold
                elif run.contains("<w:i/>") or run.contains("<w:i "):
                    style = InlineStyle.Italic
                spans.push(TextSpan(text: content, style: style))
        i = end_pos + 6
    if spans.len() == 0:
        spans.push(_span(""))
    spans

fn docx_document_xml_to_document(document_xml: text, title: text) -> RichDocument:
    """Parse OOXML word/document.xml into a RichDocument."""
    var doc = RichDocument.new(title)
    var i = 0
    while i < document_xml.len():
        val p = _find_from(document_xml, "<w:p ", i)
        val p2 = _find_from(document_xml, "<w:p>", i)
        val start = if p >= 0 and (p2 < 0 or p < p2): p else: p2
        if start < 0:
            break
        val end_pos = _find_from(document_xml, "</w:p>", start)
        if end_pos < 0:
            break
        val para = document_xml.slice(start, end_pos)
        val content = _docx_para_text(para)
        if content.trim() != "":
            doc.blocks.push(DocBlock(kind: _docx_para_kind(para), spans: _docx_para_spans(para)))
        i = end_pos + 6
    doc

fn docx_bytes_to_document(zip_bytes: [u8], title: text) -> RichDocument:
    """Import a real .docx file (zip container) into a RichDocument."""
    docx_document_xml_to_document(zip_extract_text(zip_bytes, "word/document.xml"), title)

# =========================================================================
# Real .odt writer (zip container)
# =========================================================================

# =========================================================================
# ODS import (Calc)
# =========================================================================

fn _ods_cell_value(cell_xml: text) -> text:
    """The value to store for one table:table-cell — office:value for numbers,
    formula text if present, else the text:p character data."""
    val f = _find_from(cell_xml, "table:formula=\"", 0)
    if f >= 0:
        val fe = _find_from(cell_xml, "\"", f + 15)
        if fe > f:
            var formula = _xml_unescape(cell_xml.slice(f + 15, fe))
            if formula.starts_with("of:="):
                formula = "={formula.slice(4, formula.len())}"
            return formula
    val v = _find_from(cell_xml, "office:value=\"", 0)
    if v >= 0:
        val ve = _find_from(cell_xml, "\"", v + 14)
        if ve > v:
            return cell_xml.slice(v + 14, ve)
    val p = _find_from(cell_xml, "<text:p", 0)
    if p >= 0:
        val tag_end = _find_from(cell_xml, ">", p)
        val pe = _find_from(cell_xml, "</text:p>", p)
        if tag_end >= 0 and pe > tag_end:
            return _xml_unescape(_strip_tags(cell_xml.slice(tag_end + 1, pe)))
    ""

fn ods_content_to_sheet(content_xml: text, name: text) -> Sheet:
    """Parse ODF spreadsheet content.xml (first table) into a Sheet."""
    var sheet = Sheet.new(name)
    var row = 0
    var i = 0
    while i < content_xml.len():
        val r = _find_from(content_xml, "<table:table-row", i)
        if r < 0:
            break
        val r_end = _find_from(content_xml, "</table:table-row>", r)
        if r_end < 0:
            break
        val row_xml = content_xml.slice(r, r_end)
        var col = 0
        var j = 0
        while j < row_xml.len():
            val c = _find_from(row_xml, "<table:table-cell", j)
            if c < 0:
                break
            val tag_end = _find_from(row_xml, ">", c)
            if tag_end < 0:
                break
            val self_closing = row_xml.slice(tag_end - 1, tag_end) == "/"
            var cell_xml = row_xml.slice(c, tag_end)
            var next_j = tag_end + 1
            if not self_closing:
                val c_end = _find_from(row_xml, "</table:table-cell>", c)
                if c_end < 0:
                    break
                cell_xml = row_xml.slice(c, c_end)
                next_j = c_end + 19
            val value = _ods_cell_value(cell_xml)
            if value != "":
                sheet.set_value("{col_to_letter(col)}{row + 1}", value)
            col = col + 1
            j = next_j
        row = row + 1
        i = r_end + 18
    recalculate_formula_cells(sheet)

fn ods_bytes_to_sheet(zip_bytes: [u8], name: text) -> Sheet:
    """Import a real .ods file (zip container) into a Sheet."""
    ods_content_to_sheet(zip_extract_text(zip_bytes, "content.xml"), name)

# =========================================================================
# XLSX import (Excel)
# =========================================================================

fn _xlsx_shared_strings(shared_xml: text) -> [text]:
    """Collect each <si>'s concatenated <t> runs from sharedStrings.xml."""
    var strings: [text] = []
    var i = 0
    while i < shared_xml.len():
        val s = _find_from(shared_xml, "<si>", i)
        if s < 0:
            break
        val e = _find_from(shared_xml, "</si>", s)
        if e < 0:
            break
        val si = shared_xml.slice(s, e)
        var out = ""
        var j = 0
        while j < si.len():
            val t = _find_from(si, "<t", j)
            if t < 0:
                break
            val tag_end = _find_from(si, ">", t)
            val te = _find_from(si, "</t>", t)
            if tag_end < 0 or te < 0:
                break
            out = "{out}{_xml_unescape(si.slice(tag_end + 1, te))}"
            j = te + 4
        strings.push(out)
        i = e + 5
    strings

fn xlsx_sheet_xml_to_sheet(sheet_xml: text, shared: [text], name: text) -> Sheet:
    """Parse one OOXML worksheet: <c r="A1" t="s"><v>idx</v></c> cells."""
    var sheet = Sheet.new(name)
    var i = 0
    while i < sheet_xml.len():
        val c = _find_from(sheet_xml, "<c ", i)
        if c < 0:
            break
        val tag_end = _find_from(sheet_xml, ">", c)
        if tag_end < 0:
            break
        val attrs = sheet_xml.slice(c, tag_end)
        # cell ref
        var ref_str = ""
        val ra = _find_from(attrs, "r=\"", 0)
        if ra >= 0:
            val re = _find_from(attrs, "\"", ra + 3)
            if re > ra:
                ref_str = attrs.slice(ra + 3, re)
        val is_shared = attrs.contains("t=\"s\"")
        val is_inline = attrs.contains("t=\"inlineStr\"")
        val c_end = _find_from(sheet_xml, "</c>", c)
        if is_inline and ref_str != "" and c_end > c:
            # inline string: <is><t>text</t></is>
            val cell_xml = sheet_xml.slice(c, c_end)
            val t = _find_from(cell_xml, "<t", 0)
            if t >= 0:
                val t_end = _find_from(cell_xml, ">", t)
                val te = _find_from(cell_xml, "</t>", t)
                if t_end >= 0 and te > t_end:
                    sheet.set_value(ref_str, _xml_unescape(cell_xml.slice(t_end + 1, te)))
        else:
            val v = _find_from(sheet_xml, "<v>", tag_end)
            if ref_str != "" and v >= 0 and c_end > v:
                val ve = _find_from(sheet_xml, "</v>", v)
                if ve > v and ve < c_end:
                    var value = _xml_unescape(sheet_xml.slice(v + 3, ve))
                    if is_shared:
                        val idx = value.to_i64().to_i32()
                        if idx >= 0 and idx < shared.len():
                            value = shared[idx]
                    sheet.set_value(ref_str, value)
        i = if c_end > c: c_end + 4 else: tag_end + 1
    sheet

fn xlsx_bytes_to_sheet(zip_bytes: [u8], name: text) -> Sheet:
    """Import a real .xlsx file: worksheet 1 + shared strings."""
    val shared = _xlsx_shared_strings(zip_extract_text(zip_bytes, "xl/sharedStrings.xml"))
    xlsx_sheet_xml_to_sheet(zip_extract_text(zip_bytes, "xl/worksheets/sheet1.xml"), shared, name)

# =========================================================================
# Real .xlsx writer
# =========================================================================

fn _xml_escape_x(s: text) -> text:
    var r = s
    r = r.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r = r.replace("\"", "&quot;")
    r

fn _xlsx_cell_xml(sheet: Sheet, ref_str: text) -> text:
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return "<c r=\"{ref_str}\"><v>{value}</v></c>"
        CellValue.FormulaVal(expr, cached_display):
            val f = _xml_escape_x(expr)
            return "<c r=\"{ref_str}\"><f>{f}</f><v>{_xml_escape_x(cached_display)}</v></c>"
        CellValue.BoolVal(value):
            val b = if value: "1" else: "0"
            return "<c r=\"{ref_str}\" t=\"b\"><v>{b}</v></c>"
        CellValue.Empty:
            return ""
        _:
            val display = _xml_escape_x(cell_display_text_of(sheet, ref_str))
            return "<c r=\"{ref_str}\" t=\"inlineStr\"><is><t>{display}</t></is></c>"

fn cell_display_text_of(sheet: Sheet, ref_str: text) -> text:
    # tiny indirection to keep _xlsx_cell_xml readable
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.TextVal(value):
            return value
        _:
            return ""

fn sheet_to_xlsx_bytes(sheet: Sheet) -> [u8]:
    """Build a genuine .xlsx: content types, rels, workbook, one worksheet.
    Text cells use inline strings (no sharedStrings part needed); formulas
    carry both <f> and their cached <v>."""
    val range_str = sheet.used_range()
    val parts = range_str.split(":")
    val start = parse_cell_ref(parts[0])
    val end_ref = parse_cell_ref(parts[1])
    var rows = ""
    if start != nil and end_ref != nil:
        var r = start.row
        while r <= end_ref.row:
            var cells = ""
            var c = start.col
            while c <= end_ref.col:
                val ref_str = "{col_to_letter(c)}{r + 1}"
                cells = "{cells}{_xlsx_cell_xml(sheet, ref_str)}"
                c = c + 1
            rows = "{rows}<row r=\"{r + 1}\">{cells}</row>"
            r = r + 1
    val ws = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><worksheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\"><sheetData>{rows}</sheetData></worksheet>"
    val name = _xml_escape_x(sheet.name)
    val wb = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><workbook xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\" xmlns:r=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships\"><sheets><sheet name=\"{name}\" sheetId=\"1\" r:id=\"rId1\"/></sheets></workbook>"
    val wb_rels = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet\" Target=\"worksheets/sheet1.xml\"/></Relationships>"
    val root_rels = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"xl/workbook.xml\"/></Relationships>"
    val types = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\"><Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/><Default Extension=\"xml\" ContentType=\"application/xml\"/><Override PartName=\"/xl/workbook.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml\"/><Override PartName=\"/xl/worksheets/sheet1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml\"/></Types>"
    var files: [ZipFile] = []
    files.push(zip_text_file("[Content_Types].xml", types))
    files.push(zip_text_file("_rels/.rels", root_rels))
    files.push(zip_text_file("xl/workbook.xml", wb))
    files.push(zip_text_file("xl/_rels/workbook.xml.rels", wb_rels))
    files.push(zip_text_file("xl/worksheets/sheet1.xml", ws))
    zip_write_stored(files)

# =========================================================================
# XLSX styles (styles.xml): per-cell number formats + bold/bg/fg
#
# `sheet_to_xlsx_bytes_formatted` is a sibling of `sheet_to_xlsx_bytes` (which
# stays untouched/byte-identical for unformatted output) that additionally
# emits `xl/styles.xml` and references it from each `<c>` via `s="<xf idx>"`.
# Verification ceiling: no LibreOffice/Excel is available in this environment,
# so acceptance here is structural (zip integrity + well-formed XML, checked
# with the system `unzip -t` / `unzip -p`) plus our own importer reading the
# bytes back into an equal SheetFormats. Visual rendering in a real
# spreadsheet app was NOT verified.
# =========================================================================

struct SheetWithFormats:
    """A Sheet plus the SheetFormats read back from an .xlsx's styles.xml.
    (Sheet is a `class` -- heap identity -- so embedding it here is safe
    under this struct's copy-on-return semantics; see cell_format.spl's
    module docstring for why SheetFormats itself must avoid Dict fields.)"""
    sheet: Sheet
    formats: SheetFormats

struct _XlsxFont:
    bold: bool
    fg: text

struct _XlsxNumFmt:
    id: i32
    code: text

struct _XlsxXf:
    num_fmt_id: i32
    font_id: i32
    fill_id: i32

fn _xlsx_spec_eq(a: FormatSpec, b: FormatSpec) -> bool:
    a.num_fmt == b.num_fmt and a.bold == b.bold and a.bg == b.bg and a.fg == b.fg

fn _xlsx_spec_is_default(spec: FormatSpec) -> bool:
    spec.num_fmt == "" and not spec.bold and spec.bg == "" and spec.fg == ""

fn _xlsx_distinct_specs(formats: SheetFormats) -> [FormatSpec]:
    """Every distinct non-default FormatSpec used across the sheet, in first-
    seen order. Linear-scan dedupe (not a Dict) per this file's parallel-array
    idiom for aggregates under copy semantics."""
    var out: [FormatSpec] = []
    var i = 0
    while i < formats.specs.len():
        val spec = formats.specs[i]
        if not _xlsx_spec_is_default(spec):
            var found = false
            var j = 0
            while j < out.len():
                if _xlsx_spec_eq(out[j], spec):
                    found = true
                j = j + 1
            if not found:
                out.push(spec)
        i = i + 1
    out

fn _xlsx_distinct_num_fmts(specs: [FormatSpec]) -> [text]:
    """Distinct non-empty num_fmt strings, in first-seen order. Custom
    numFmtIds are assigned 164 + index (164 is the first free built-in id)."""
    var out: [text] = []
    var i = 0
    while i < specs.len():
        val fmt = specs[i].num_fmt
        if fmt != "":
            var found = false
            var j = 0
            while j < out.len():
                if out[j] == fmt:
                    found = true
                j = j + 1
            if not found:
                out.push(fmt)
        i = i + 1
    out

fn _xlsx_num_fmt_id(num_fmts: [text], fmt: text) -> i32:
    var i = 0
    while i < num_fmts.len():
        if num_fmts[i] == fmt:
            return 164 + i
        i = i + 1
    0

fn _xlsx_num_fmt_code(id: i32, num_fmts: [_XlsxNumFmt]) -> text:
    if id == 0:
        return ""
    var i = 0
    while i < num_fmts.len():
        if num_fmts[i].id == id:
            return num_fmts[i].code
        i = i + 1
    ""

fn _xlsx_distinct_fonts(specs: [FormatSpec]) -> [_XlsxFont]:
    """Font table; index 0 is always the plain default font (bold=false,
    fg="")."""
    var out: [_XlsxFont] = [_XlsxFont(bold: false, fg: "")]
    var i = 0
    while i < specs.len():
        val spec = specs[i]
        if spec.bold or spec.fg != "":
            var found = false
            var j = 0
            while j < out.len():
                if out[j].bold == spec.bold and out[j].fg == spec.fg:
                    found = true
                j = j + 1
            if not found:
                out.push(_XlsxFont(bold: spec.bold, fg: spec.fg))
        i = i + 1
    out

fn _xlsx_font_id(fonts: [_XlsxFont], spec: FormatSpec) -> i32:
    var i = 0
    while i < fonts.len():
        if fonts[i].bold == spec.bold and fonts[i].fg == spec.fg:
            return i
        i = i + 1
    0

fn _xlsx_distinct_fills(specs: [FormatSpec]) -> [text]:
    """Custom bg colors only; the two reserved fills (none / gray125) that
    xlsx requires at indices 0-1 are added separately in the XML emitter."""
    var out: [text] = []
    var i = 0
    while i < specs.len():
        val bg = specs[i].bg
        if bg != "":
            var found = false
            var j = 0
            while j < out.len():
                if out[j] == bg:
                    found = true
                j = j + 1
            if not found:
                out.push(bg)
        i = i + 1
    out

fn _xlsx_fill_id(fills: [text], bg: text) -> i32:
    if bg == "":
        return 0
    var i = 0
    while i < fills.len():
        if fills[i] == bg:
            return 2 + i
        i = i + 1
    0

fn _xlsx_xf_index_for(distinct_specs: [FormatSpec], spec: FormatSpec) -> i32:
    """cellXfs index for a spec: 0 is the always-present default xf; custom
    specs sit at 1 + their position in `distinct_specs`."""
    if _xlsx_spec_is_default(spec):
        return 0
    var i = 0
    while i < distinct_specs.len():
        if _xlsx_spec_eq(distinct_specs[i], spec):
            return i + 1
        i = i + 1
    0

fn _xlsx_argb(color: text) -> text:
    """"#rrggbb" -> "FFrrggbb" (opaque ARGB hex xlsx expects for rgb=).
    Case is preserved as written so re-importing round-trips exactly."""
    if color.starts_with("#"):
        return "FF{color.slice(1, color.len())}"
    "FF{color}"

fn _xlsx_from_argb(argb: text) -> text:
    """Inverse of `_xlsx_argb`: "FFrrggbb" -> "#rrggbb"."""
    if argb.len() >= 8:
        return "#{argb.slice(2, 8)}"
    "#{argb}"

fn _xml_attr(tag: text, name: text) -> text:
    """Value of `name="..."` inside a single XML start-tag fragment, or ""
    if absent. A targeted attribute scan (this file's XML strategy is a
    tag scan, not a general DOM), scoped to the caller-supplied fragment."""
    val needle = "{name}=\""
    val p = _find_from(tag, needle, 0)
    if p < 0:
        return ""
    val start = p + needle.len()
    val e = _find_from(tag, "\"", start)
    if e < 0:
        return ""
    tag.slice(start, e)

fn _xml_section(s: text, open_prefix: text, close_tag: text) -> text:
    """Inner XML of the first `<open_prefix ...>...</close_tag>` element, or
    "" if not present."""
    val start = _find_from(s, open_prefix, 0)
    if start < 0:
        return ""
    val tag_end = _find_from(s, ">", start)
    if tag_end < 0:
        return ""
    val end_pos = _find_from(s, close_tag, tag_end)
    if end_pos < 0:
        return ""
    s.slice(tag_end + 1, end_pos)

fn _xlsx_styles_xml(num_fmts: [text], fonts: [_XlsxFont], fills: [text], distinct_specs: [FormatSpec]) -> text:
    """Build xl/styles.xml: custom numFmts (164+), fonts (default + bold/fg
    variants), fills (2 reserved defaults + custom bg solids), and cellXfs
    (xf 0 = default; xf 1..N one per distinct FormatSpec)."""
    var num_fmts_xml = ""
    if num_fmts.len() > 0:
        var entries = ""
        var i = 0
        while i < num_fmts.len():
            entries = "{entries}<numFmt numFmtId=\"{164 + i}\" formatCode=\"{_xml_escape_x(num_fmts[i])}\"/>"
            i = i + 1
        num_fmts_xml = "<numFmts count=\"{num_fmts.len()}\">{entries}</numFmts>"
    var fonts_xml = ""
    var fi = 0
    while fi < fonts.len():
        val font = fonts[fi]
        val bold_xml = if font.bold: "<b/>" else: ""
        val color_xml = if font.fg != "": "<color rgb=\"{_xlsx_argb(font.fg)}\"/>" else: ""
        fonts_xml = "{fonts_xml}<font>{bold_xml}{color_xml}<sz val=\"11\"/><name val=\"Calibri\"/></font>"
        fi = fi + 1
    fonts_xml = "<fonts count=\"{fonts.len()}\">{fonts_xml}</fonts>"
    var fills_xml = "<fill><patternFill patternType=\"none\"/></fill><fill><patternFill patternType=\"gray125\"/></fill>"
    var fli = 0
    while fli < fills.len():
        fills_xml = "{fills_xml}<fill><patternFill patternType=\"solid\"><fgColor rgb=\"{_xlsx_argb(fills[fli])}\"/><bgColor indexed=\"64\"/></patternFill></fill>"
        fli = fli + 1
    fills_xml = "<fills count=\"{fills.len() + 2}\">{fills_xml}</fills>"
    val borders_xml = "<borders count=\"1\"><border><left/><right/><top/><bottom/><diagonal/></border></borders>"
    val cell_style_xfs_xml = "<cellStyleXfs count=\"1\"><xf numFmtId=\"0\" fontId=\"0\" fillId=\"0\" borderId=\"0\"/></cellStyleXfs>"
    var cell_xfs_xml = "<xf numFmtId=\"0\" fontId=\"0\" fillId=\"0\" borderId=\"0\" xfId=\"0\"/>"
    var si = 0
    while si < distinct_specs.len():
        val spec = distinct_specs[si]
        val num_fmt_id = if spec.num_fmt != "": _xlsx_num_fmt_id(num_fmts, spec.num_fmt) else: 0
        val font_id = _xlsx_font_id(fonts, spec)
        val fill_id = _xlsx_fill_id(fills, spec.bg)
        val apply_num = if spec.num_fmt != "": " applyNumberFormat=\"1\"" else: ""
        val apply_font = if spec.bold or spec.fg != "": " applyFont=\"1\"" else: ""
        val apply_fill = if spec.bg != "": " applyFill=\"1\"" else: ""
        cell_xfs_xml = "{cell_xfs_xml}<xf numFmtId=\"{num_fmt_id}\" fontId=\"{font_id}\" fillId=\"{fill_id}\" borderId=\"0\" xfId=\"0\"{apply_num}{apply_font}{apply_fill}/>"
        si = si + 1
    cell_xfs_xml = "<cellXfs count=\"{distinct_specs.len() + 1}\">{cell_xfs_xml}</cellXfs>"
    val cell_styles_xml = "<cellStyles count=\"1\"><cellStyle name=\"Normal\" xfId=\"0\" builtinId=\"0\"/></cellStyles>"
    "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><styleSheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\">{num_fmts_xml}{fonts_xml}{fills_xml}{borders_xml}{cell_style_xfs_xml}{cell_xfs_xml}{cell_styles_xml}</styleSheet>"

fn _xlsx_s_attr(xf_idx: i32) -> text:
    if xf_idx == 0:
        return ""
    " s=\"{xf_idx}\""

fn _xlsx_cell_xml_styled(sheet: Sheet, ref_str: text, xf_idx: i32) -> text:
    """Like `_xlsx_cell_xml`, plus an `s="<xf idx>"` attribute when the cell
    has a non-default format. An Empty cell with a format still emits a
    self-closing styled `<c/>` (formatting-only cells, e.g. a colored blank);
    an Empty cell with no format emits nothing, as before."""
    val cell = sheet.get_cell(ref_str)
    val s_attr = _xlsx_s_attr(xf_idx)
    match cell.value:
        CellValue.NumberVal(value):
            return "<c r=\"{ref_str}\"{s_attr}><v>{value}</v></c>"
        CellValue.FormulaVal(expr, cached_display):
            val f = _xml_escape_x(expr)
            return "<c r=\"{ref_str}\"{s_attr}><f>{f}</f><v>{_xml_escape_x(cached_display)}</v></c>"
        CellValue.BoolVal(value):
            val b = if value: "1" else: "0"
            return "<c r=\"{ref_str}\" t=\"b\"{s_attr}><v>{b}</v></c>"
        CellValue.Empty:
            if xf_idx == 0:
                return ""
            return "<c r=\"{ref_str}\"{s_attr}/>"
        _:
            val display = _xml_escape_x(cell_display_text_of(sheet, ref_str))
            return "<c r=\"{ref_str}\" t=\"inlineStr\"{s_attr}><is><t>{display}</t></is></c>"

fn sheet_to_xlsx_bytes_formatted(sheet: Sheet, formats: SheetFormats) -> [u8]:
    """Build a genuine .xlsx like `sheet_to_xlsx_bytes`, plus `xl/styles.xml`
    carrying per-cell number formats and bold/bg/fg, referenced from cells via
    `s="<xf idx>"`. `sheet_to_xlsx_bytes` itself is untouched and stays
    byte-identical for callers that don't need styling."""
    val range_str = sheet.used_range()
    val parts = range_str.split(":")
    val start = parse_cell_ref(parts[0])
    val end_ref = parse_cell_ref(parts[1])
    val distinct_specs = _xlsx_distinct_specs(formats)
    val num_fmts = _xlsx_distinct_num_fmts(distinct_specs)
    val fonts = _xlsx_distinct_fonts(distinct_specs)
    val fills = _xlsx_distinct_fills(distinct_specs)
    var rows = ""
    if start != nil and end_ref != nil:
        var r = start.row
        while r <= end_ref.row:
            var cells = ""
            var c = start.col
            while c <= end_ref.col:
                val ref_str = "{col_to_letter(c)}{r + 1}"
                val spec = formats_get(formats, ref_str)
                val xf_idx = _xlsx_xf_index_for(distinct_specs, spec)
                cells = "{cells}{_xlsx_cell_xml_styled(sheet, ref_str, xf_idx)}"
                c = c + 1
            rows = "{rows}<row r=\"{r + 1}\">{cells}</row>"
            r = r + 1
    val ws = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><worksheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\"><sheetData>{rows}</sheetData></worksheet>"
    val name = _xml_escape_x(sheet.name)
    val wb = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><workbook xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\" xmlns:r=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships\"><sheets><sheet name=\"{name}\" sheetId=\"1\" r:id=\"rId1\"/></sheets></workbook>"
    val wb_rels = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet\" Target=\"worksheets/sheet1.xml\"/><Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles\" Target=\"styles.xml\"/></Relationships>"
    val root_rels = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"xl/workbook.xml\"/></Relationships>"
    val types = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\"><Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/><Default Extension=\"xml\" ContentType=\"application/xml\"/><Override PartName=\"/xl/workbook.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml\"/><Override PartName=\"/xl/worksheets/sheet1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml\"/><Override PartName=\"/xl/styles.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.styles+xml\"/></Types>"
    val styles_xml = _xlsx_styles_xml(num_fmts, fonts, fills, distinct_specs)
    var files: [ZipFile] = []
    files.push(zip_text_file("[Content_Types].xml", types))
    files.push(zip_text_file("_rels/.rels", root_rels))
    files.push(zip_text_file("xl/workbook.xml", wb))
    files.push(zip_text_file("xl/_rels/workbook.xml.rels", wb_rels))
    files.push(zip_text_file("xl/worksheets/sheet1.xml", ws))
    files.push(zip_text_file("xl/styles.xml", styles_xml))
    zip_write_stored(files)

# =========================================================================
# XLSX styles import: styles.xml -> SheetFormats
# =========================================================================

fn _xlsx_parse_num_fmts(styles_xml: text) -> [_XlsxNumFmt]:
    val section = _xml_section(styles_xml, "<numFmts", "</numFmts>")
    var out: [_XlsxNumFmt] = []
    var i = 0
    while true:
        val s = _find_from(section, "<numFmt ", i)
        if s < 0:
            break
        val e = _find_from(section, "/>", s)
        if e < 0:
            break
        val tag = section.slice(s, e + 2)
        val id_str = _xml_attr(tag, "numFmtId")
        val code = _xml_attr(tag, "formatCode")
        out.push(_XlsxNumFmt(id: id_str.to_i64().to_i32(), code: _xml_unescape(code)))
        i = e + 2
    out

fn _xlsx_parse_fonts(styles_xml: text) -> [_XlsxFont]:
    val section = _xml_section(styles_xml, "<fonts", "</fonts>")
    var out: [_XlsxFont] = []
    var i = 0
    while true:
        val s = _find_from(section, "<font>", i)
        if s < 0:
            break
        val e = _find_from(section, "</font>", s)
        if e < 0:
            break
        val body = section.slice(s, e)
        val bold = body.contains("<b/>")
        var fg = ""
        val c = _find_from(body, "<color ", 0)
        if c >= 0:
            val ce = _find_from(body, "/>", c)
            if ce >= 0:
                val rgb = _xml_attr(body.slice(c, ce + 2), "rgb")
                if rgb != "":
                    fg = _xlsx_from_argb(rgb)
        out.push(_XlsxFont(bold: bold, fg: fg))
        i = e + 7
    out

fn _xlsx_parse_fills(styles_xml: text) -> [text]:
    """Custom fill colors only (indices 0-1 are the reserved defaults, always
    skipped); result[k] is the bg color for fillId = 2 + k."""
    val section = _xml_section(styles_xml, "<fills", "</fills>")
    var out: [text] = []
    var i = 0
    var idx = 0
    while true:
        val s = _find_from(section, "<fill>", i)
        if s < 0:
            break
        val e = _find_from(section, "</fill>", s)
        if e < 0:
            break
        val body = section.slice(s, e)
        if idx >= 2:
            var color = ""
            if body.contains("patternType=\"solid\""):
                val c = _find_from(body, "<fgColor ", 0)
                if c >= 0:
                    val ce = _find_from(body, "/>", c)
                    if ce >= 0:
                        val rgb = _xml_attr(body.slice(c, ce + 2), "rgb")
                        if rgb != "":
                            color = _xlsx_from_argb(rgb)
            out.push(color)
        idx = idx + 1
        i = e + 7
    out

fn _xlsx_parse_cell_xfs(styles_xml: text) -> [_XlsxXf]:
    val section = _xml_section(styles_xml, "<cellXfs", "</cellXfs>")
    var out: [_XlsxXf] = []
    var i = 0
    while true:
        val s = _find_from(section, "<xf ", i)
        if s < 0:
            break
        val e = _find_from(section, "/>", s)
        if e < 0:
            break
        val tag = section.slice(s, e + 2)
        val num_fmt_id = _xml_attr(tag, "numFmtId")
        val font_id = _xml_attr(tag, "fontId")
        val fill_id = _xml_attr(tag, "fillId")
        out.push(_XlsxXf(num_fmt_id: num_fmt_id.to_i64().to_i32(), font_id: font_id.to_i64().to_i32(), fill_id: fill_id.to_i64().to_i32()))
        i = e + 2
    out

fn _xlsx_spec_for_xf(xf: _XlsxXf, num_fmts: [_XlsxNumFmt], fonts: [_XlsxFont], fills: [text]) -> FormatSpec:
    val num_fmt = _xlsx_num_fmt_code(xf.num_fmt_id, num_fmts)
    var bold = false
    var fg = ""
    if xf.font_id > 0 and xf.font_id < fonts.len():
        bold = fonts[xf.font_id].bold
        fg = fonts[xf.font_id].fg
    var bg = ""
    if xf.fill_id >= 2 and (xf.fill_id - 2) < fills.len():
        bg = fills[xf.fill_id - 2]
    FormatSpec(num_fmt: num_fmt, bold: bold, bg: bg, fg: fg)

fn xlsx_sheet_xml_to_sheet_and_formats(sheet_xml: text, shared: [text], name: text, xfs: [_XlsxXf], num_fmts: [_XlsxNumFmt], fonts: [_XlsxFont], fills: [text]) -> SheetWithFormats:
    """Like `xlsx_sheet_xml_to_sheet`, plus reading each cell's `s="<xf idx>"`
    attribute back into a SheetFormats. Handles self-closing `<c .../>` cells
    (a format-only cell with no value)."""
    var sheet = Sheet.new(name)
    var formats = empty_sheet_formats()
    var i = 0
    while i < sheet_xml.len():
        val c = _find_from(sheet_xml, "<c ", i)
        if c < 0:
            break
        val tag_end = _find_from(sheet_xml, ">", c)
        if tag_end < 0:
            break
        val attrs = sheet_xml.slice(c, tag_end)
        val self_closing = sheet_xml.slice(tag_end - 1, tag_end) == "/"
        var ref_str = ""
        val ra = _find_from(attrs, "r=\"", 0)
        if ra >= 0:
            val re = _find_from(attrs, "\"", ra + 3)
            if re > ra:
                ref_str = attrs.slice(ra + 3, re)
        val s_str = _xml_attr(attrs, "s")
        val is_shared = attrs.contains("t=\"s\"")
        val is_inline = attrs.contains("t=\"inlineStr\"")
        var c_end = tag_end
        if not self_closing:
            val found_end = _find_from(sheet_xml, "</c>", c)
            if found_end < 0:
                break
            c_end = found_end
        if not self_closing:
            if is_inline and ref_str != "":
                val cell_xml = sheet_xml.slice(c, c_end)
                val t = _find_from(cell_xml, "<t", 0)
                if t >= 0:
                    val t_end = _find_from(cell_xml, ">", t)
                    val te = _find_from(cell_xml, "</t>", t)
                    if t_end >= 0 and te > t_end:
                        sheet.set_value(ref_str, _xml_unescape(cell_xml.slice(t_end + 1, te)))
            else:
                val v = _find_from(sheet_xml, "<v>", tag_end)
                if ref_str != "" and v >= 0 and v < c_end:
                    val ve = _find_from(sheet_xml, "</v>", v)
                    if ve > v and ve < c_end:
                        var value = _xml_unescape(sheet_xml.slice(v + 3, ve))
                        if is_shared:
                            val idx = value.to_i64().to_i32()
                            if idx >= 0 and idx < shared.len():
                                value = shared[idx]
                        sheet.set_value(ref_str, value)
        if ref_str != "" and s_str != "" and s_str != "0":
            val xf_idx = s_str.to_i64().to_i32()
            if xf_idx > 0 and xf_idx < xfs.len():
                val spec = _xlsx_spec_for_xf(xfs[xf_idx], num_fmts, fonts, fills)
                formats = formats_set(formats, ref_str, spec)
        i = if self_closing: tag_end + 1 else: c_end + 4
    SheetWithFormats(sheet: sheet, formats: formats)

fn xlsx_bytes_to_sheet_formatted(zip_bytes: [u8], name: text) -> SheetWithFormats:
    """Import a real .xlsx file including its styles.xml, if present, back
    into a Sheet + SheetFormats. Cells with no matching xf get the default
    (unformatted) spec."""
    val shared = _xlsx_shared_strings(zip_extract_text(zip_bytes, "xl/sharedStrings.xml"))
    val styles_xml = zip_extract_text(zip_bytes, "xl/styles.xml")
    val num_fmts = _xlsx_parse_num_fmts(styles_xml)
    val fonts = _xlsx_parse_fonts(styles_xml)
    val fills = _xlsx_parse_fills(styles_xml)
    val xfs = _xlsx_parse_cell_xfs(styles_xml)
    xlsx_sheet_xml_to_sheet_and_formats(zip_extract_text(zip_bytes, "xl/worksheets/sheet1.xml"), shared, name, xfs, num_fmts, fonts, fills)

# =========================================================================
# Real .ods writer
# =========================================================================

val _ODS_MANIFEST = "<?xml version=\"1.0\" encoding=\"UTF-8\"?><manifest:manifest xmlns:manifest=\"urn:oasis:names:tc:opendocument:xmlns:manifest:1.0\" manifest:version=\"1.2\"><manifest:file-entry manifest:full-path=\"/\" manifest:media-type=\"application/vnd.oasis.opendocument.spreadsheet\"/><manifest:file-entry manifest:full-path=\"content.xml\" manifest:media-type=\"text/xml\"/></manifest:manifest>"

fn sheet_to_ods_bytes(sheet: Sheet) -> [u8]:
    """Build a genuine zipped .ods from a Sheet, reusing the flat-ODF body."""
    val flat = sheet_to_fods(sheet)
    val content = flat.replace("office:mimetype=\"application/vnd.oasis.opendocument.spreadsheet\"", "")
    var files: [ZipFile] = []
    files.push(zip_text_file("mimetype", "application/vnd.oasis.opendocument.spreadsheet"))
    files.push(zip_text_file("META-INF/manifest.xml", _ODS_MANIFEST))
    files.push(zip_text_file("content.xml", content))
    zip_write_stored(files)

# =========================================================================
# Real .docx writer
# =========================================================================
#
# Hyperlinks (w:hyperlink r:id + external rels) and inline PNG images
# (w:drawing, wp:inline picture skeleton + word/media/imageN.png + image
# rels) both need per-document relationship bookkeeping (rId allocation +
# accumulated <Relationship> entries + extra zip parts). `_DocxRels` is a
# `class` (heap identity — mutation-through-methods is safe under this
# codebase's copy-return struct convention; see SheetWithFormats's docstring
# for the same reasoning) threaded through paragraph building so every
# hyperlink/image gets a fresh rId without a return-and-reassign dance.

val _DOCX_NS_W = "http://schemas.openxmlformats.org/wordprocessingml/2006/main"
val _DOCX_NS_R = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
val _DOCX_NS_WP = "http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing"

class _DocxRels:
    entries: [text]     # extra <Relationship .../> XML fragments (beyond the always-present rId1 styles rel)
    next_id: i32         # next free rId number (rId1 is reserved for styles.xml)
    media: [ZipFile]    # extra zip parts: word/media/imageN.png

impl _DocxRels:
    static fn new() -> _DocxRels:
        _DocxRels(entries: [], next_id: 2, media: [])

    me add_hyperlink(url: text) -> text:
        val rid = "rId{me.next_id}"
        me.next_id = me.next_id + 1
        me.entries.push("<Relationship Id=\"{rid}\" Type=\"{_DOCX_NS_R}/hyperlink\" Target=\"{_xml_attr_escape(url)}\" TargetMode=\"External\"/>")
        rid

    me add_image(bytes: [u8]) -> text:
        val idx = me.media.len() + 1
        val rid = "rId{me.next_id}"
        me.next_id = me.next_id + 1
        val target = "media/image{idx}.png"
        me.media.push(ZipFile(name: "word/{target}", data: bytes))
        me.entries.push("<Relationship Id=\"{rid}\" Type=\"{_DOCX_NS_R}/image\" Target=\"{target}\"/>")
        rid

    me add_header() -> text:
        val rid = "rId{me.next_id}"
        me.next_id = me.next_id + 1
        me.entries.push("<Relationship Id=\"{rid}\" Type=\"{_DOCX_NS_R}/header\" Target=\"header1.xml\"/>")
        rid

    me add_footer() -> text:
        val rid = "rId{me.next_id}"
        me.next_id = me.next_id + 1
        me.entries.push("<Relationship Id=\"{rid}\" Type=\"{_DOCX_NS_R}/footer\" Target=\"footer1.xml\"/>")
        rid

    me rels_xml() -> text:
        var body = "<Relationship Id=\"rId1\" Type=\"{_DOCX_NS_R}/styles\" Target=\"styles.xml\"/>"
        for e in me.entries:
            body = "{body}{e}"
        "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">{body}</Relationships>"

fn _xml_escape_d(s: text) -> text:
    var r = s
    r = r.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r

fn _xml_attr_escape(s: text) -> text:
    """Escape for use inside a double-quoted XML attribute value."""
    _xml_escape_d(s).replace("\"", "&quot;")

fn _docx_run(span: TextSpan, rels: _DocxRels) -> text:
    """One <w:r> (or <w:hyperlink><w:r>...</w:r></w:hyperlink> when the span
    carries a link_url), styled runs unaffected by hyperlink-wrapping."""
    val content = "<w:t xml:space=\"preserve\">{_xml_escape_d(span.text)}</w:t>"
    var run = ""
    match span.style:
        case Bold: run = "<w:r><w:rPr><w:b/></w:rPr>{content}</w:r>"
        case Italic: run = "<w:r><w:rPr><w:i/></w:rPr>{content}</w:r>"
        _: run = "<w:r>{content}</w:r>"
    if span.link_url != "":
        val rid = rels.add_hyperlink(span.link_url)
        return "<w:hyperlink r:id=\"{rid}\">{run}</w:hyperlink>"
    run

fn _docx_drawing_xml(rid: text, alt: text, src: text) -> text:
    """Minimal wp:inline DrawingML picture skeleton (PNG only). alt/src are
    stashed on wp:docPr's name/descr attributes so import can reconstruct
    the exact `![alt](src)` markdown without needing a separate side-channel
    (see `_docx_drawing_image`)."""
    val name_attr = _xml_attr_escape(alt)
    val descr_attr = _xml_attr_escape(src)
    "<w:r><w:drawing><wp:inline distT=\"0\" distB=\"0\" distL=\"0\" distR=\"0\"><wp:extent cx=\"990000\" cy=\"792000\"/><wp:docPr id=\"1\" name=\"{name_attr}\" descr=\"{descr_attr}\"/><a:graphic xmlns:a=\"http://schemas.openxmlformats.org/drawingml/2006/main\"><a:graphicData uri=\"http://schemas.openxmlformats.org/drawingml/2006/picture\"><pic:pic xmlns:pic=\"http://schemas.openxmlformats.org/drawingml/2006/picture\"><pic:nvPicPr><pic:cNvPr id=\"0\" name=\"{name_attr}\"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed=\"{rid}\"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x=\"0\" y=\"0\"/><a:ext cx=\"990000\" cy=\"792000\"/></a:xfrm><a:prstGeom prst=\"rect\"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r>"

fn _docx_image_run(alt: text, src: text, rels: _DocxRels) -> text:
    """Embed src's bytes as word/media/imageN.png + a minimal inline
    DrawingML picture. PNG only (documented scope); a missing file or a
    non-.png src falls back to a plain placeholder run carrying the alt
    text, never crashing the export."""
    if src.ends_with(".png") and rt_file_exists(src):
        val bytes = rt_file_read_bytes(src)
        val rid = rels.add_image(bytes)
        return _docx_drawing_xml(rid, alt, src)
    "<w:r><w:t xml:space=\"preserve\">{_xml_escape_d(alt)}</w:t></w:r>"

fn _docx_para(block: DocBlock, rels: _DocxRels) -> text:
    """One <w:p>. A block whose whole plain text is `![alt](src)` (the same
    whole-block image convention html_render.spl uses) renders as an inline
    picture (or its alt-text fallback) instead of ordinary runs."""
    val img = _parse_md_image(spans_to_plain_text(block.spans))
    if img.is_image:
        return "<w:p>{_docx_image_run(img.alt, img.src, rels)}</w:p>"
    var style = ""
    match block.kind:
        case Heading1: style = "<w:pPr><w:pStyle w:val=\"Heading1\"/></w:pPr>"
        case Heading2: style = "<w:pPr><w:pStyle w:val=\"Heading2\"/></w:pPr>"
        case Heading3: style = "<w:pPr><w:pStyle w:val=\"Heading3\"/></w:pPr>"
        case BulletItem: style = "<w:pPr><w:pStyle w:val=\"ListParagraph\"/></w:pPr>"
        _: style = ""
    var runs = ""
    for span in block.spans:
        runs = "{runs}{_docx_run(span, rels)}"
    "<w:p>{style}{runs}</w:p>"

fn _document_to_docx_bytes_core(doc: RichDocument, header_text: text, footer_text: text) -> [u8]:
    """Shared builder behind `document_to_docx_bytes` (header_text and
    footer_text both "") and `document_to_docx_bytes_hf`. Hyperlink/image
    relationships accumulate in `rels` while paragraphs are built; header/
    footer parts + the sectPr/rels/content-types wiring are added only when
    at least one of header_text/footer_text is non-empty, and the xmlns:r /
    xmlns:wp namespace declarations are added only when a hyperlink, image,
    or header/footer actually needs them — so a plain document with none of
    these features produces byte-identical output to this writer before any
    of the three features existed."""
    val rels = _DocxRels.new()
    var paras = ""
    for block in doc.blocks:
        paras = "{paras}{_docx_para(block, rels)}"
    val has_hf = header_text != "" or footer_text != ""
    var sect_pr = ""
    var header_part = ""
    var footer_part = ""
    if has_hf:
        val header_rid = rels.add_header()
        val footer_rid = rels.add_footer()
        sect_pr = "<w:sectPr><w:headerReference w:type=\"default\" r:id=\"{header_rid}\"/><w:footerReference w:type=\"default\" r:id=\"{footer_rid}\"/></w:sectPr>"
        header_part = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:hdr xmlns:w=\"{_DOCX_NS_W}\"><w:p><w:r><w:t xml:space=\"preserve\">{_xml_escape_d(header_text)}</w:t></w:r></w:p></w:hdr>"
        footer_part = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:ftr xmlns:w=\"{_DOCX_NS_W}\"><w:p><w:r><w:t xml:space=\"preserve\">{_xml_escape_d(footer_text)}</w:t></w:r><w:fldSimple w:instr=\" PAGE \"/></w:p></w:ftr>"
    val needs_r = rels.entries.len() > 0 or has_hf
    val needs_wp = rels.media.len() > 0
    var ns_attrs = " xmlns:w=\"{_DOCX_NS_W}\""
    if needs_r:
        ns_attrs = "{ns_attrs} xmlns:r=\"{_DOCX_NS_R}\""
    if needs_wp:
        ns_attrs = "{ns_attrs} xmlns:wp=\"{_DOCX_NS_WP}\""
    val document = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:document{ns_attrs}><w:body>{paras}{sect_pr}</w:body></w:document>"
    var styles = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:styles xmlns:w=\"{_DOCX_NS_W}\">"
    for level in ["1", "2", "3"]:
        styles = "{styles}<w:style w:type=\"paragraph\" w:styleId=\"Heading{level}\"><w:name w:val=\"heading {level}\"/><w:rPr><w:b/></w:rPr></w:style>"
    styles = "{styles}<w:style w:type=\"paragraph\" w:styleId=\"ListParagraph\"><w:name w:val=\"List Paragraph\"/></w:style></w:styles>"
    var overrides = "<Override PartName=\"/word/document.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml\"/><Override PartName=\"/word/styles.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.styles+xml\"/>"
    if has_hf:
        overrides = "{overrides}<Override PartName=\"/word/header1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.header+xml\"/><Override PartName=\"/word/footer1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.footer+xml\"/>"
    var default_exts = "<Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/><Default Extension=\"xml\" ContentType=\"application/xml\"/>"
    if needs_wp:
        default_exts = "{default_exts}<Default Extension=\"png\" ContentType=\"image/png\"/>"
    val types = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\">{default_exts}{overrides}</Types>"
    val root_rels = "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"word/document.xml\"/></Relationships>"
    val doc_rels = rels.rels_xml()
    var files: [ZipFile] = []
    files.push(zip_text_file("[Content_Types].xml", types))
    files.push(zip_text_file("_rels/.rels", root_rels))
    files.push(zip_text_file("word/document.xml", document))
    files.push(zip_text_file("word/_rels/document.xml.rels", doc_rels))
    files.push(zip_text_file("word/styles.xml", styles))
    if has_hf:
        files.push(zip_text_file("word/header1.xml", header_part))
        files.push(zip_text_file("word/footer1.xml", footer_part))
    for m in rels.media:
        files.push(m)
    zip_write_stored(files)

fn document_to_docx_bytes(doc: RichDocument) -> [u8]:
    """Build a genuine .docx: content types, rels, styles (Heading1-3 +
    ListParagraph), and word/document.xml with styled runs (w:b/w:i),
    hyperlinks (w:hyperlink r:id + external rels), and inline PNG images
    (w:drawing). No header/footer — see `document_to_docx_bytes_hf` — and
    this function's output is unaffected by that feature by construction
    (same core builder, called with header_text/footer_text both "")."""
    _document_to_docx_bytes_core(doc, "", "")

fn document_to_docx_bytes_hf(doc: RichDocument, header_text: text, footer_text: text) -> [u8]:
    """Like `document_to_docx_bytes`, plus word/header1.xml + word/footer1.xml
    parts wired via sectPr headerReference/footerReference + rels + content
    types when header_text/footer_text is non-empty. The footer always
    carries a PAGE field (`<w:fldSimple w:instr=" PAGE "/>`) after the
    footer text run."""
    _document_to_docx_bytes_core(doc, header_text, footer_text)

val _ODT_MANIFEST ="<?xml version=\"1.0\" encoding=\"UTF-8\"?><manifest:manifest xmlns:manifest=\"urn:oasis:names:tc:opendocument:xmlns:manifest:1.0\" manifest:version=\"1.2\"><manifest:file-entry manifest:full-path=\"/\" manifest:media-type=\"application/vnd.oasis.opendocument.text\"/><manifest:file-entry manifest:full-path=\"content.xml\" manifest:media-type=\"text/xml\"/></manifest:manifest>"

fn document_to_odt_bytes(doc: RichDocument) -> [u8]:
    """Build a genuine zipped .odt: mimetype (stored first, per spec),
    META-INF/manifest.xml, and content.xml reusing the flat-ODF body."""
    val flat = document_to_fodt(doc)
    # Reuse the flat document's office:body by re-rooting it as content.xml
    val content = flat.replace("office:mimetype=\"application/vnd.oasis.opendocument.text\"", "")
    var files: [ZipFile] = []
    files.push(zip_text_file("mimetype", "application/vnd.oasis.opendocument.text"))
    files.push(zip_text_file("META-INF/manifest.xml", _ODT_MANIFEST))
    files.push(zip_text_file("content.xml", content))
    zip_write_stored(files)
