# Interactive Sheet Editor
#
# A live editing session for Calc: load a sheet (csv/ods/xlsx), then edit it
# interactively — set cells, evaluate formulas, view the grid, save to any
# supported container — driven by stdin lines so it works both at a terminal
# and scripted (`printf 'set A1 5\nsave out.csv\nquit\n' | simple office
# edit-sheet in.csv`). The command core is a pure function over (Sheet, line)
# so the editing surface is unit-testable without a terminal.
#
# ponytail: line-based editor, not a TUI grid; the widget-tree SheetsApp is
# the eventual full-screen surface.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, CellRef, cell_ref_to_string, parse_cell_ref, col_to_letter}
use app.office.file_formats.{parse_csv_sheet, sheet_to_csv, recalculate_formula_cells}
use app.office.odf_ooxml.{ods_bytes_to_sheet, xlsx_bytes_to_sheet, sheet_to_ods_bytes, sheet_to_xlsx_bytes}
use app.office.odf_export.{sheet_to_fods}
use std.io_runtime.{write_file, read_file, file_exists}
use std.nogc_sync_mut.sffi.io.{file_read_bytes, file_write_bytes}

extern fn rt_stdin_read_line() -> text

struct EditorStep:
    sheet: Sheet
    reply: text
    quit: bool

fn _step(sheet: Sheet, reply: text, quit: bool) -> EditorStep:
    EditorStep(sheet: sheet, reply: reply, quit: quit)

fn sheet_grid_text(sheet: Sheet) -> text:
    """The used range as an aligned ASCII grid with column letters and row
    numbers — the terminal 'view' of the spreadsheet."""
    val range_str = sheet.used_range()
    val parts = range_str.split(":")
    val start = parse_cell_ref(parts[0])
    val end_ref = parse_cell_ref(parts[1])
    if start == nil or end_ref == nil:
        return "(empty sheet)"
    # column widths
    var widths: [i32] = []
    var c = start.col
    while c <= end_ref.col:
        var w = 3
        var r = start.row
        while r <= end_ref.row:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            val d = cell_display_text(sheet.get_cell(ref_str))
            if d.len() > w:
                w = d.len()
            r = r + 1
        widths.push(w)
        c = c + 1
    var out = "    "
    var ci = 0
    c = start.col
    while c <= end_ref.col:
        out = "{out}{_pad(col_to_letter(c), widths[ci] + 2)}"
        ci = ci + 1
        c = c + 1
    var r = start.row
    while r <= end_ref.row:
        out = "{out}\n{_pad("{r + 1}", 4)}"
        ci = 0
        c = start.col
        while c <= end_ref.col:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            out = "{out}{_pad(cell_display_text(sheet.get_cell(ref_str)), widths[ci] + 2)}"
            ci = ci + 1
            c = c + 1
        r = r + 1
    out

fn _pad(s: text, w: i32) -> text:
    var out = s
    while out.len() < w:
        out = "{out} "
    out

fn editor_load_sheet(path: text) -> Sheet:
    """Load csv/.ods/.xlsx by extension; missing file yields an empty sheet."""
    if not file_exists(path):
        return Sheet.new(path)
    if path.ends_with(".ods"):
        val b = file_read_bytes(path)
        if b != nil:
            return ods_bytes_to_sheet(b, path)
        return Sheet.new(path)
    if path.ends_with(".xlsx"):
        val b = file_read_bytes(path)
        if b != nil:
            return xlsx_bytes_to_sheet(b, path)
        return Sheet.new(path)
    parse_csv_sheet(read_file(path), path)

fn editor_save_sheet(sheet: Sheet, path: text) -> bool:
    """Save to csv/.fods/.ods/.xlsx by extension."""
    if path.ends_with(".ods"):
        return file_write_bytes(path, sheet_to_ods_bytes(sheet))
    if path.ends_with(".xlsx"):
        return file_write_bytes(path, sheet_to_xlsx_bytes(sheet))
    if path.ends_with(".fods"):
        return write_file(path, sheet_to_fods(sheet))
    write_file(path, sheet_to_csv(sheet))

fn editor_apply(sheet: Sheet, line: text) -> EditorStep:
    """Apply one editor command. Pure over (sheet, line) — the whole editing
    surface, testable without a terminal.

    Commands: set <ref> <value> | get <ref> | del <ref> | show |
              save <path> | help | quit"""
    val trimmed = line.trim()
    if trimmed == "" or trimmed == "quit" or trimmed == "exit":
        return _step(sheet, "bye", true)
    val parts = trimmed.split(" ")
    val cmd = parts[0].lower()
    if cmd == "help":
        return _step(sheet, "commands: set <ref> <value> | get <ref> | del <ref> | show | save <path> | quit", false)
    if cmd == "show":
        return _step(sheet, sheet_grid_text(sheet), false)
    if cmd == "get" and parts.len() >= 2:
        val ref_str = parts[1].upper()
        if parse_cell_ref(ref_str) == nil:
            return _step(sheet, "error: invalid ref {parts[1]}", false)
        return _step(sheet, "{ref_str} = {cell_display_text(sheet.get_cell(ref_str))}", false)
    if cmd == "del" and parts.len() >= 2:
        var sh = sheet
        sh.set_value(parts[1].upper(), "")
        sh = recalculate_formula_cells(sh)
        return _step(sh, "deleted {parts[1].upper()}", false)
    if cmd == "set" and parts.len() >= 3:
        val ref_str = parts[1].upper()
        if parse_cell_ref(ref_str) == nil:
            return _step(sheet, "error: invalid ref {parts[1]}", false)
        val value = parts[2:].join(" ")
        var sh = sheet
        sh.set_value(ref_str, value)
        sh = recalculate_formula_cells(sh)
        return _step(sh, "{ref_str} = {cell_display_text(sh.get_cell(ref_str))}", false)
    if cmd == "save" and parts.len() >= 2:
        if editor_save_sheet(sheet, parts[1]):
            return _step(sheet, "saved {parts[1]}", false)
        return _step(sheet, "error: could not save {parts[1]}", false)
    _step(sheet, "error: unknown command (try 'help')", false)

fn run_sheet_editor(in_path: text) -> i32:
    """The interactive loop: prompt, read a line, apply, print, repeat."""
    var sheet = editor_load_sheet(in_path)
    print "Simple Calc — editing {in_path} (type 'help' for commands)"
    var quit = false
    while not quit:
        val line = rt_stdin_read_line() ?? ""
        val step = editor_apply(sheet, line)
        sheet = step.sheet
        quit = step.quit
        print step.reply
    0
