# Slide Shapes + Build Animations
#
# Vector shapes (rect/ellipse/arrow/line/textbox) placed on a slide, each
# optionally tagged with a build (entrance) animation. Renders to SVG and
# reports the animation build order — a minimal PowerPoint "shapes + animation
# pane" slice, kept as a pure model -> SVG transform with no GUI dependency.

# =========================================================================
# Core Structs
# =========================================================================

struct Shape:
    kind: text
    x: i32
    y: i32
    w: i32
    h: i32
    content: text
    fill: text
    anim: text

struct ShapeSlide:
    title: text
    shapes: [Shape]

# =========================================================================
# Constructors
# =========================================================================

fn shape_new(kind: text, x: i32, y: i32, w: i32, h: i32, content: text, fill: text, anim: text) -> Shape:
    """Create a shape. `kind` is one of "rect"/"ellipse"/"arrow"/"line"/"textbox".
    `fill` is a hex color like "#4472c4" or "" for none. `anim` is the build
    (entrance) animation: "" (none), "fade", "fly-in", or "wipe"."""
    Shape(
        kind: kind,
        x: x,
        y: y,
        w: w,
        h: h,
        content: content,
        fill: fill,
        anim: anim
    )

fn shape_slide_new(title: text) -> ShapeSlide:
    """Create an empty shape slide with the given title."""
    ShapeSlide(title: title, shapes: [])

fn shape_slide_add(slide: ShapeSlide, shape: Shape) -> ShapeSlide:
    """Append a shape to a slide and return the updated slide (shapes are
    value types; mutating through a param is lost, so build a new list)."""
    var new_shapes: [Shape] = []
    for s in slide.shapes:
        new_shapes.push(s)
    new_shapes.push(shape)
    ShapeSlide(title: slide.title, shapes: new_shapes)

# =========================================================================
# SVG Rendering
# =========================================================================

fn _svg_escape(s: text) -> text:
    """Escape text for safe inclusion inside SVG markup/attributes."""
    var result = s
    result = result.replace("&", "&amp;")
    result = result.replace("<", "&lt;")
    result = result.replace(">", "&gt;")
    result = result.replace("\"", "&quot;")
    result

fn _fill_attr(fill: text) -> text:
    """SVG fill attribute fragment: `fill="none"` when unset, else the hex color."""
    if fill == "":
        return " fill=\"none\""
    " fill=\"{fill}\""

fn _stroke_color(fill: text) -> text:
    """Stroke color for line-like shapes: the fill hex when set, else black."""
    if fill == "":
        return "#000000"
    fill

fn _shape_rect_svg(shape: Shape) -> text:
    "<rect x=\"{shape.x}\" y=\"{shape.y}\" width=\"{shape.w}\" height=\"{shape.h}\"{_fill_attr(shape.fill)}/>"

fn _shape_ellipse_svg(shape: Shape) -> text:
    val cx = shape.x + shape.w / 2
    val cy = shape.y + shape.h / 2
    val rx = shape.w / 2
    val ry = shape.h / 2
    "<ellipse cx=\"{cx}\" cy=\"{cy}\" rx=\"{rx}\" ry=\"{ry}\"{_fill_attr(shape.fill)}/>"

fn _shape_line_svg(shape: Shape) -> text:
    val x2 = shape.x + shape.w
    val y2 = shape.y + shape.h
    val stroke = _stroke_color(shape.fill)
    "<line x1=\"{shape.x}\" y1=\"{shape.y}\" x2=\"{x2}\" y2=\"{y2}\" stroke=\"{stroke}\"/>"

fn _shape_arrow_svg(shape: Shape) -> text:
    """A line shaft plus a small triangular `<polygon>` arrowhead at the end."""
    val x2 = shape.x + shape.w
    val y2 = shape.y + shape.h
    val stroke = _stroke_color(shape.fill)
    val ln = "<line x1=\"{shape.x}\" y1=\"{shape.y}\" x2=\"{x2}\" y2=\"{y2}\" stroke=\"{stroke}\"/>"
    val hx = x2 - 8
    val hy1 = y2 - 4
    val hy2 = y2 + 4
    val head = "<polygon points=\"{x2},{y2} {hx},{hy1} {hx},{hy2}\" fill=\"{stroke}\"/>"
    "{ln}{head}"

fn _shape_textbox_svg(shape: Shape) -> text:
    """A background `<rect>` plus centered `<text>` (content escaped)."""
    val rect = "<rect x=\"{shape.x}\" y=\"{shape.y}\" width=\"{shape.w}\" height=\"{shape.h}\"{_fill_attr(shape.fill)}/>"
    val tx = shape.x + 4
    val ty = shape.y + shape.h / 2
    val txt = "<text x=\"{tx}\" y=\"{ty}\">{_svg_escape(shape.content)}</text>"
    "{rect}{txt}"

fn shape_to_svg(shape: Shape) -> text:
    """Render one shape as its SVG element(s)."""
    if shape.kind == "rect":
        return _shape_rect_svg(shape)
    if shape.kind == "ellipse":
        return _shape_ellipse_svg(shape)
    if shape.kind == "line":
        return _shape_line_svg(shape)
    if shape.kind == "arrow":
        return _shape_arrow_svg(shape)
    if shape.kind == "textbox":
        return _shape_textbox_svg(shape)
    ""

fn shape_slide_to_svg(slide: ShapeSlide, w: i32, h: i32) -> text:
    """Wrap every shape's SVG (insertion order) in an `<svg>` of size w x h."""
    var parts: [text] = []
    for s in slide.shapes:
        parts.push(shape_to_svg(s))
    val body = parts.join("")
    "<svg width=\"{w}\" height=\"{h}\">{body}</svg>"

# =========================================================================
# Build Animation Order
# =========================================================================

fn shape_anim_summary(slide: ShapeSlide) -> [text]:
    """One "<kind>:<anim>" line per shape that has a build animation, in
    slide (build) order. Shapes with anim == "" are skipped."""
    var out: [text] = []
    for s in slide.shapes:
        if s.anim != "":
            out.push("{s.kind}:{s.anim}")
    out
