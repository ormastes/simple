"""Slide transition + auto-advance timing model.

A minimal presentation timeline: each slide carries a transition kind, a
transition duration, and an optional auto-advance dwell time (kiosk mode).
Provides PowerPoint (`p:transition`) XML export for a single slide's timing
and whole-timeline summaries (total run length, count of auto-advancing
slides).
"""

struct SlideTiming:
    slide_title: text
    transition: text
    duration_ms: i32
    advance_ms: i32

fn timing_new(slide_title: text, transition: text, duration_ms: i32, advance_ms: i32) -> SlideTiming:
    return SlideTiming(slide_title: slide_title, transition: transition, duration_ms: duration_ms, advance_ms: advance_ms)

struct Timeline:
    slides: [SlideTiming]

fn timeline_new() -> Timeline:
    return Timeline(slides: [])

fn timeline_add(timeline: Timeline, timing: SlideTiming) -> Timeline:
    var slides = timeline.slides
    slides.push(timing)
    return Timeline(slides: slides)

fn timeline_total_ms(timeline: Timeline) -> i32:
    var total = 0
    for timing in timeline.slides:
        total = total + timing.duration_ms + timing.advance_ms
    return total

fn timeline_auto_slides(timeline: Timeline) -> i32:
    var count = 0
    for timing in timeline.slides:
        if timing.advance_ms > 0:
            count = count + 1
    return count

fn transition_speed(duration_ms: i32) -> text:
    if duration_ms <= 500:
        return "fast"
    elif duration_ms <= 1000:
        return "med"
    else:
        return "slow"

fn timing_to_pptx_xml(timing: SlideTiming) -> text:
    if timing.transition == "none":
        return ""
    val spd = transition_speed(timing.duration_ms)
    var adv_tm_attr = ""
    if timing.advance_ms > 0:
        adv_tm_attr = " advTm=\"{timing.advance_ms}\""
    val xml = "<p:transition spd=\"{spd}\"{adv_tm_attr}><p:{timing.transition}/></p:transition>"
    return xml

fn timeline_summary(timeline: Timeline) -> [text]:
    var lines: [text] = []
    for timing in timeline.slides:
        val line_text = "{timing.slide_title}: {timing.transition} {timing.duration_ms}ms advance={timing.advance_ms}ms"
        lines.push(line_text)
    return lines
