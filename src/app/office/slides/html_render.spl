# Slide HTML Rendering
#
# Renders a slide "like MS PowerPoint" by resolving each element's role through
# the shared office style resolver's slide theme (centered bold title, subtitle,
# body) and emitting a styled HTML fragment.
#
# Kept separate from `render.spl` — which depends on the UI widget tree — so this
# path stays a pure model -> CSS -> HTML transform that loads without the GUI
# widget stack.

use app.office.slides.slide.{Slide, SlideElement, SlideElementKind, SlideLayout}
use std.common.markdown.inline.{markdown_escape_html}
use std.editor.services.md_document_decor.{md_document_render_ppt_html}
use std.common.render_scene.office_style_resolver.{resolve_style, style_to_css_text}

fn _is_hex_digit(ch: text) -> bool:
    "0123456789abcdefABCDEF".contains(ch)

fn slide_safe_css_color(value: text, fallback: text) -> text:
    """Allow only simple #RGB/#RRGGBB colors in slide CSS values."""
    val trimmed = value.trim()
    if not trimmed.starts_with("#"):
        return fallback
    if trimmed.len() != 4 and trimmed.len() != 7:
        return fallback
    var i = 1
    while i < trimmed.len():
        if not _is_hex_digit(trimmed.char_at(i)):
            return fallback
        i = i + 1
    trimmed

fn _slide_safe_resource_url(value: text) -> text:
    val clean = value.trim()
    val lower = clean.lower()
    var compact = ""
    var i = 0
    while i < lower.len():
        val ch = lower.char_at(i)
        if ch != " " and ch != "\t" and ch != "\n" and ch != "\r":
            compact = compact + ch
        i = i + 1
    if compact.starts_with("javascript:") or compact.starts_with("vbscript:") or compact.starts_with("data:") or compact.starts_with("file:") or compact.starts_with("//"):
        return "#"
    clean

fn _slide_element_text(element: SlideElement) -> text:
    """Display text for a slide element based on its kind."""
    match element.kind:
        SlideElementKind.TextBox(content):
            return markdown_escape_html(content)
        SlideElementKind.ImageEl(src: src, alt: alt):
            return "<img src=\"" + markdown_escape_html(_slide_safe_resource_url(src)) + "\" alt=\"" + markdown_escape_html(alt) + "\">"
        SlideElementKind.ShapeEl(shape_type: shape_type, fill_color: fill_color):
            return "[" + markdown_escape_html(shape_type) + "]"

fn _slide_element_kind_name(element: SlideElement) -> text:
    match element.kind:
        SlideElementKind.TextBox(content):
            return "text"
        SlideElementKind.ImageEl(src: src, alt: alt):
            return "image"
        SlideElementKind.ShapeEl(shape_type: shape_type, fill_color: fill_color):
            return "shape"

fn _css_px(value: i32) -> text:
    if value < 0:
        return "0px"
    value.to_text() + "px"

fn _slide_element_box_css(element: SlideElement) -> text:
    var css = "position: absolute; "
    css = css + "left: " + _css_px(element.x) + "; "
    css = css + "top: " + _css_px(element.y) + "; "
    css = css + "width: " + _css_px(element.width) + "; "
    css = css + "height: " + _css_px(element.height) + "; "
    css + "box-sizing: border-box; overflow: hidden;"

fn _slide_shape_css(element: SlideElement) -> text:
    match element.kind:
        SlideElementKind.ShapeEl(shape_type: shape_type, fill_color: fill_color):
            val fill = slide_safe_css_color(fill_color, "#E5E7EB")
            return "background: " + fill + "; border: 1px solid #6B7280;"
        _:
            return ""

fn _slide_element_style_tag(layout: SlideLayout, index: i32) -> text:
    """Map an element's position within its slide layout to a resolver style
    tag (slide_title / slide_subtitle / slide_body)."""
    if index == 0:
        return "slide_title"
    match layout:
        SlideLayout.TitleSlide:
            return "slide_subtitle"
        SlideLayout.SectionHeader:
            return "slide_subtitle"
        _:
            return "slide_body"

fn render_slide_html(slide: Slide) -> text:
    """Render a slide as a styled HTML fragment using the shared office style
    resolver's slide theme, so the PPT surface renders with Word-level
    typography (centered bold title, subtitle, body) rather than primitive
    empty widgets."""
    val bg = slide_safe_css_color(slide.background, "#ffffff")
    var out = "<section class=\"slide\" data-slide-id=\"" + markdown_escape_html(slide.id) + "\" style=\"position: relative; width: 960px; height: 540px; overflow: hidden; background: {bg};\">"
    var index = 0
    for el in slide.elements:
        val tag = _slide_element_style_tag(slide.layout, index)
        val content = _slide_element_text(el)
        val style = resolve_style(tag, [])
        val css = style_to_css_text(style) + " " + _slide_element_box_css(el) + " " + _slide_shape_css(el)
        out = "{out}<div class=\"{tag}\" data-element-id=\"" + markdown_escape_html(el.id) + "\" data-kind=\"" + _slide_element_kind_name(el) + "\" style=\"{css}\">{content}</div>"
        index = index + 1
    "{out}</section>"

fn render_ppt_markdown_html(source: text) -> text:
    """Render Impress/PPT as Markdown source -> slide-deck HTML.

    Slides are authored in Markdown (`##` per slide plus optional frontmatter)
    and generated into HTML for the renderer. The object-model slide renderer
    remains a compatibility path for existing tests and tools.
    """
    md_document_render_ppt_html(source)
