# Slide Chart Embed — a chart as a positioned element on a slide
#
# A minimal PowerPoint "chart embedded on a slide" slice: a chart (bar,
# column, or pie) placed at (x, y, w, h) on the slide canvas, kept as a pure
# model -> SVG / pptx-xml transform with no GUI dependency. The pie chart
# reuses the stacked-strip approach from sheets/chart.spl (no trig needed).

# =========================================================================
# Core Structs
# =========================================================================

struct ChartSeries:
    labels: [text]
    values: [text]

struct EmbeddedChart:
    kind: text
    x: i32
    y: i32
    w: i32
    h: i32
    title: text
    series: ChartSeries

# =========================================================================
# Constructors
# =========================================================================

fn series_new(labels: [text], values: [text]) -> ChartSeries:
    """Build a chart series from parallel label/numeric-as-text arrays."""
    ChartSeries(labels: labels, values: values)

fn embed_new(kind: text, x: i32, y: i32, w: i32, h: i32, title: text, series: ChartSeries) -> EmbeddedChart:
    """Embed a chart (`kind` one of "bar"/"column"/"pie") at (x, y, w, h) on
    a slide, with a title and a data series."""
    EmbeddedChart(kind: kind, x: x, y: y, w: w, h: h, title: title, series: series)

# =========================================================================
# Numeric helpers
# =========================================================================

fn _values_i64(series: ChartSeries) -> [i64]:
    """Parse each series value (a clean integer-as-text) into an i64."""
    var out: [i64] = []
    for v in series.values:
        out.push(v.to_i64())
    out

fn _max_i64(vals: [i64]) -> i64:
    var m: i64 = 0
    for v in vals:
        if v > m:
            m = v
    m

fn _sum_i64(vals: [i64]) -> i64:
    var s: i64 = 0
    for v in vals:
        s = s + v
    s

fn _pct_list(chart: EmbeddedChart) -> [i64]:
    """Per-point percentage: share-of-total for "pie", share-of-max for
    "bar"/"column". Guards the degenerate all-zero case (divide-by-zero ->
    0 pct for every point)."""
    val vals = _values_i64(chart.series)
    var out: [i64] = []
    if chart.kind == "pie":
        val total = _sum_i64(vals)
        for v in vals:
            if total == 0:
                out.push(0)
            else:
                out.push(v * 100 / total)
    else:
        val maxv = _max_i64(vals)
        for v in vals:
            if maxv == 0:
                out.push(0)
            else:
                out.push(v * 100 / maxv)
    out

# =========================================================================
# Rendered bars (data description)
# =========================================================================

fn chart_bars(chart: EmbeddedChart) -> [text]:
    """One "<label>:<value>:<pct>" line per data point, in series order.
    `pct` is pct-of-max for "bar"/"column", pct-of-total for "pie"."""
    val vals = _values_i64(chart.series)
    val pcts = _pct_list(chart)
    var out: [text] = []
    var i = 0
    while i < vals.len():
        val label = if i < chart.series.labels.len(): chart.series.labels[i] else: ""
        val v = vals[i]
        val p = pcts[i]
        out.push("{label}:{v}:{p}")
        i = i + 1
    out

fn chart_point_count(chart: EmbeddedChart) -> i32:
    """Number of data points in the chart's series."""
    chart.series.values.len()

# =========================================================================
# SVG Rendering
# =========================================================================

fn _svg_escape(s: text) -> text:
    """Escape text for safe inclusion inside SVG markup."""
    var result = s
    result = result.replace("&", "&amp;")
    result = result.replace("<", "&lt;")
    result = result.replace(">", "&gt;")
    result

fn chart_to_svg(chart: EmbeddedChart) -> text:
    """Render the embedded chart as a self-contained `<svg>` positioned at
    (x, y) sized (w, h): vertical rects for "column", horizontal rects for
    "bar" (heights/widths proportional to pct-of-max), a stacked horizontal
    strip of segments for "pie" (widths proportional to share-of-total, no
    trig — same approach as sheets/chart.spl's donut). The title is drawn
    as `<text>`; labels are escaped."""
    val vals = _values_i64(chart.series)
    val pcts = _pct_list(chart)
    val n = vals.len()
    val safe_title = _svg_escape(chart.title)
    var out = "<svg x=\"{chart.x}\" y=\"{chart.y}\" width=\"{chart.w}\" height=\"{chart.h}\">"
    out = "{out}<text x=\"4\" y=\"14\">{safe_title}</text>"
    if n > 0:
        if chart.kind == "pie":
            var cursor = 0
            var i = 0
            while i < n:
                val p = pcts[i]
                val seg_w = chart.w * p / 100
                out = "{out}<rect x=\"{cursor}\" y=\"20\" width=\"{seg_w}\" height=\"30\"/>"
                cursor = cursor + seg_w
                i = i + 1
        elif chart.kind == "bar":
            val slot = chart.h / n
            var i = 0
            while i < n:
                val p = pcts[i]
                val bw = chart.w * p / 100
                val by = 20 + i * slot
                val bar_h = slot - 4
                out = "{out}<rect x=\"0\" y=\"{by}\" width=\"{bw}\" height=\"{bar_h}\"/>"
                i = i + 1
        else:
            val slot = chart.w / n
            val plot_h = chart.h - 20
            var i = 0
            while i < n:
                val p = pcts[i]
                val bh = plot_h * p / 100
                val bx = i * slot
                val by = chart.h - bh
                val bar_w = slot - 4
                out = "{out}<rect x=\"{bx}\" y=\"{by}\" width=\"{bar_w}\" height=\"{bh}\"/>"
                i = i + 1
    "{out}</svg>"

# =========================================================================
# PPTX XML (graphic frame)
# =========================================================================

fn embed_to_pptx_xml(chart: EmbeddedChart) -> text:
    """A `<p:graphicFrame>` fragment: `<p:xfrm>` carries the slide position
    and size (x, y, w, h), and a `<c:chart>` child names the kind and the
    series count."""
    val n = chart.series.values.len()
    var out = "<p:graphicFrame>"
    out = "{out}<p:xfrm><a:off x=\"{chart.x}\" y=\"{chart.y}\"/><a:ext cx=\"{chart.w}\" cy=\"{chart.h}\"/></p:xfrm>"
    out = "{out}<a:graphicData><c:chart kind=\"{chart.kind}\" seriesCount=\"{n}\"/></a:graphicData>"
    "{out}</p:graphicFrame>"
