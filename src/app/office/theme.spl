# Office App Themes
#
# Per-app accent colors building on iOS theme.

use common.ui.ios_theme.{ios_light, ios_dark}
use common.ui.style.{UITheme, ThemeColors, Spacing, BorderStyle, FontStyle}

# =========================================================================
# Per-App Accent Colors
# =========================================================================

fn _accent_for_app(app_name: text) -> text:
    """Return the accent hex color for an office app."""
    match app_name:
        "word" => return "#007AFF"
        "sheets" => return "#34C759"
        "slides" => return "#FF9500"
        "mail" => return "#007AFF"
        "planner" => return "#AF52DE"
        _ => return ""

# =========================================================================
# Office Theme Factory
# =========================================================================

fn office_theme(app_name: text, dark: bool) -> UITheme:
    """Return an iOS-based theme with a per-app accent color override."""
    val accent = _accent_for_app(app_name)
    if accent == "":
        # Unknown app: return default iOS theme
        if dark:
            return ios_dark()
        return ios_light()

    val base = if dark: ios_dark() else: ios_light()
    val base_colors = base.colors

    # Create new ThemeColors with the app-specific accent
    val colors = ThemeColors(
        background: base_colors.background,
        foreground: base_colors.foreground,
        border: base_colors.border,
        accent: accent,
        panel_bg: base_colors.panel_bg,
        hover_bg: base_colors.hover_bg,
        error: base_colors.error,
        warning: base_colors.warning,
        success: base_colors.success,
        info: base_colors.info
    )

    return UITheme(
        name: if dark: "office_{app_name}_dark" else: "office_{app_name}_light",
        colors: colors,
        spacing: base.spacing,
        border: base.border,
        font: base.font
    )
