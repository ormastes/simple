# LibreOffice Base — minimal in-memory relational table
#
# A simple text-valued table (columns + rows) with row insertion, column
# projection, and exact-match filtering — the data core of the Base database
# component. It connects to Calc by importing spreadsheet rows as table rows.
#
# NOTE: inner-row cells are read with `_row_get` (for-in iteration + counter)
# rather than `row.get(i)`. The interpreter corrupts array element access at
# index >= 1 via `.get(n)` (a value read that way fails `==` comparison), but
# for-in iteration reads elements correctly — the documented "use iteration, not
# indexed access" workaround.

struct DbTable:
    name: text
    columns: [text]
    rows: [[text]]

struct DbEditResult:
    accepted: bool
    reason: text
    affected_count: i32
    table: DbTable

fn new_table(name: text, columns: [text]) -> DbTable:
    """An empty table with the given column names."""
    DbTable(name: name, columns: columns, rows: [])

fn insert_row(table: DbTable, row: [text]) -> DbTable:
    """Return a new table with one row appended."""
    var rows: [[text]] = []
    for r in table.rows:
        rows.push(r)
    rows.push(row)
    DbTable(name: table.name, columns: table.columns, rows: rows)

fn insert_row_checked(table: DbTable, row: [text]) -> DbEditResult:
    """Append one row only when its width matches the table schema."""
    if row.len() != table.columns.len():
        return DbEditResult(accepted: false, reason: "row-width-mismatch", affected_count: 0, table: table)
    DbEditResult(accepted: true, reason: "inserted", affected_count: 1, table: insert_row(table, row))

fn row_count(table: DbTable) -> i32:
    """Number of rows in the table."""
    table.rows.len()

fn column_index(table: DbTable, col: text) -> i32:
    """Index of a column by name, or -1 if absent."""
    var i = 0
    for c in table.columns:
        if c == col:
            return i
        i = i + 1
    0 - 1

fn _row_get(row: [text], idx: i32) -> text:
    """Read a row cell by index via iteration (avoids the `.get(>=1)` corruption)."""
    var i = 0
    for cell in row:
        if i == idx:
            return cell
        i = i + 1
    ""

fn _row_set(row: [text], idx: i32, value: text) -> [text]:
    """Return a copy of a row with one cell replaced, using iteration for reads."""
    var out: [text] = []
    var i = 0
    for cell in row:
        if i == idx:
            out.push(value)
        else:
            out.push(cell)
        i = i + 1
    out

fn select_where(table: DbTable, col: text, value: text) -> [[text]]:
    """All rows whose `col` equals `value` (exact match)."""
    var out: [[text]] = []
    val idx = column_index(table, col)
    if idx < 0:
        return out
    for r in table.rows:
        if _row_get(r, idx) == value:
            out.push(r)
    out

fn project_column(table: DbTable, col: text) -> [text]:
    """All values in one column, in row order."""
    var out: [text] = []
    val idx = column_index(table, col)
    if idx < 0:
        return out
    for r in table.rows:
        out.push(_row_get(r, idx))
    out

fn count_where(table: DbTable, col: text, value: text) -> i32:
    """Count rows whose `col` equals `value`."""
    var count = 0
    val idx = column_index(table, col)
    if idx < 0:
        return 0
    for r in table.rows:
        if _row_get(r, idx) == value:
            count = count + 1
    count

fn update_where(table: DbTable, match_col: text, match_value: text, update_col: text, new_value: text) -> DbEditResult:
    """Update one column on rows matching an exact-value predicate."""
    val match_idx = column_index(table, match_col)
    if match_idx < 0:
        return DbEditResult(accepted: false, reason: "missing-match-column", affected_count: 0, table: table)
    val update_idx = column_index(table, update_col)
    if update_idx < 0:
        return DbEditResult(accepted: false, reason: "missing-update-column", affected_count: 0, table: table)
    var rows: [[text]] = []
    var affected = 0
    for r in table.rows:
        if _row_get(r, match_idx) == match_value:
            rows.push(_row_set(r, update_idx, new_value))
            affected = affected + 1
        else:
            rows.push(r)
    if affected == 0:
        return DbEditResult(accepted: false, reason: "no-matching-rows", affected_count: 0, table: table)
    DbEditResult(accepted: true, reason: "updated", affected_count: affected, table: DbTable(name: table.name, columns: table.columns, rows: rows))

fn delete_where(table: DbTable, match_col: text, match_value: text) -> DbEditResult:
    """Delete rows matching an exact-value predicate."""
    val match_idx = column_index(table, match_col)
    if match_idx < 0:
        return DbEditResult(accepted: false, reason: "missing-match-column", affected_count: 0, table: table)
    var rows: [[text]] = []
    var affected = 0
    for r in table.rows:
        if _row_get(r, match_idx) == match_value:
            affected = affected + 1
        else:
            rows.push(r)
    if affected == 0:
        return DbEditResult(accepted: false, reason: "no-matching-rows", affected_count: 0, table: table)
    DbEditResult(accepted: true, reason: "deleted", affected_count: affected, table: DbTable(name: table.name, columns: table.columns, rows: rows))
