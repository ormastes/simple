# Spreadsheet Model
#
# Sheet and Workbook types with cell operations.

use app.office.sheets.cell.{Cell, CellValue, CellStyle, CellRef, empty_cell, text_cell, number_cell, formula_cell, cell_display_text, cell_ref_to_string, parse_cell_ref, default_style}
use common.office.number.{office_parse_signed_decimal_f64}

# =========================================================================
# Sheet
# =========================================================================

class Sheet:
    name: text
    cells: Dict<text, Cell>   # Key: "A1", "B2" etc.
    col_count: i32
    row_count: i32
    hidden_rows: [i64]   # 1-based hidden row indices; plain list (no Dict-in-struct), deduped on insert

struct SheetEditResult:
    accepted: bool
    reason: text
    cell_ref: text
    expected_value: text
    actual_value: text
    new_value: text
    diff: text

impl Sheet:

    static fn new(name: text) -> Sheet:
        """Create an empty sheet with default 26 columns and 100 rows."""
        Sheet(
            name: name,
            cells: {},
            col_count: 26,
            row_count: 100,
            hidden_rows: []
        )

    me get_cell(ref_str: text) -> Cell:
        """Get the cell at the given reference, or an empty cell if none exists."""
        val key = ref_str.upper()
        val found = me.cells.get(key)
        if found != nil:
            return found
        empty_cell()

    me set_cell(ref_str: text, cell: Cell):
        """Set a cell at the given reference."""
        val key = ref_str.upper()
        me.cells[key] = cell

    me set_value(ref_str: text, value: text):
        """Parse a value string and set the appropriate cell type.
        Strings starting with '=' become formulas, numeric strings become numbers,
        'true'/'false' become bools, everything else becomes text."""
        val trimmed = value.trim()
        if trimmed.len() == 0:
            me.cells = me.cells.remove(ref_str.upper())
            return

        # Formula
        if trimmed.starts_with("="):
            val expr = trimmed.substring(1)
            me.set_cell(ref_str, formula_cell(expr))
            return

        # Boolean
        val lower = trimmed.lower()
        if lower == "true":
            val cell = Cell(value: CellValue.BoolVal(value: true), style: default_style())
            me.set_cell(ref_str, cell)
            return
        if lower == "false":
            val cell = Cell(value: CellValue.BoolVal(value: false), style: default_style())
            me.set_cell(ref_str, cell)
            return

        # Try number
        val num = _try_parse_number(trimmed)
        if num != nil:
            me.set_cell(ref_str, number_cell(num))
            return

        # Default to text
        me.set_cell(ref_str, text_cell(trimmed))

    me update_cell_checked(ref_str: text, expected_display: text, new_value: text) -> SheetEditResult:
        """Update a cell only when the caller's expected display text matches.

        This is the Calc-like fail-closed edit contract used by automation:
        stale expected values, missing refs, and malformed refs are rejected
        without mutating the sheet.
        """
        val ref_val = parse_cell_ref(ref_str)
        if ref_val == nil:
            return SheetEditResult(
                accepted: false,
                reason: "invalid-cell-ref",
                cell_ref: ref_str.upper(),
                expected_value: expected_display,
                actual_value: "<invalid-ref>",
                new_value: new_value,
                diff: sheet_edit_diff(ref_str.upper(), expected_display, "<invalid-ref>", new_value, false),
            )

        val key = cell_ref_to_string(ref_val)
        val found = me.cells.get(key)
        if found == nil:
            return SheetEditResult(
                accepted: false,
                reason: "missing-cell",
                cell_ref: key,
                expected_value: expected_display,
                actual_value: "<missing-cell>",
                new_value: new_value,
                diff: sheet_edit_diff(key, expected_display, "<missing-cell>", new_value, false),
            )

        val actual = cell_display_text(me.get_cell(key))
        if actual != expected_display:
            return SheetEditResult(
                accepted: false,
                reason: "stale-cell",
                cell_ref: key,
                expected_value: expected_display,
                actual_value: actual,
                new_value: new_value,
                diff: sheet_edit_diff(key, expected_display, actual, new_value, false),
            )

        me.set_value(key, new_value)
        val updated = cell_display_text(me.get_cell(key))
        SheetEditResult(
            accepted: true,
            reason: "updated",
            cell_ref: key,
            expected_value: expected_display,
            actual_value: actual,
            new_value: updated,
            diff: sheet_edit_diff(key, expected_display, updated, new_value, true),
        )

    me cell_count() -> i32:
        """Count non-empty cells."""
        var count = 0
        for key in me.cells.keys():
            count = count + 1
        count

    me used_range() -> text:
        """Return the bounding range string like 'A1:D10' based on actual cell content."""
        var min_col = 999999
        var max_col = 0
        var min_row = 999999
        var max_row = 0
        var has_cells = false

        for key in me.cells.keys():
            val ref_val = parse_cell_ref(key)
            if ref_val != nil:
                has_cells = true
                if ref_val.col < min_col:
                    min_col = ref_val.col
                if ref_val.col > max_col:
                    max_col = ref_val.col
                if ref_val.row < min_row:
                    min_row = ref_val.row
                if ref_val.row > max_row:
                    max_row = ref_val.row

        if not has_cells:
            return "A1:A1"

        val start_ref = CellRef(col: min_col, row: min_row)
        val end_ref = CellRef(col: max_col, row: max_row)
        "{cell_ref_to_string(start_ref)}:{cell_ref_to_string(end_ref)}"

    me is_row_hidden(row: i64) -> bool:
        """Whether the given 1-based row index is currently hidden."""
        for r in me.hidden_rows:
            if r == row:
                return true
        false

    me hide_row(row: i64):
        """Hide a single 1-based row index. Idempotent (hiding twice is a
        no-op) and out-of-range rows (< 1 or beyond row_count) are ignored.
        Mutates in place like set_cell/set_value; callers do not need to
        reassign the Sheet."""
        if row < 1 or row > me.row_count.to_i64():
            return
        if me.is_row_hidden(row):
            return
        var rows = me.hidden_rows
        rows.push(row)
        me.hidden_rows = rows

    me unhide_row(row: i64):
        """Unhide a single 1-based row index. No-op if it was not hidden."""
        var rows = me.hidden_rows
        var kept: [i64] = []
        for r in rows:
            if r != row:
                kept.push(r)
        me.hidden_rows = kept

    me hide_rows(from: i64, to: i64):
        """Hide every row in the inclusive range [from, to] (order-agnostic:
        from > to is swapped). Each row goes through hide_row so the same
        idempotency/range rules apply."""
        var lo = from
        var hi = to
        if lo > hi:
            val tmp = lo
            lo = hi
            hi = tmp
        var r = lo
        while r <= hi:
            me.hide_row(r)
            r = r + 1

    me unhide_all_rows():
        """Clear all row hiding (used by AutoFilter's clear-filter action)."""
        me.hidden_rows = []

# =========================================================================
# Workbook
# =========================================================================

class Workbook:
    title: text
    sheets: [Sheet]
    active_sheet: i32

impl Workbook:

    static fn new(title: text) -> Workbook:
        """Create a new workbook with one empty sheet named 'Sheet1'."""
        val first_sheet = Sheet.new("Sheet1")
        Workbook(
            title: title,
            sheets: [first_sheet],
            active_sheet: 0
        )

    me active() -> Sheet:
        """Get the currently active sheet."""
        me.sheets[me.active_sheet]

    me add_sheet(name: text):
        """Add a new empty sheet with the given name."""
        val sheet = Sheet.new(name)
        var sheets = me.sheets
        sheets.push(sheet)
        me.sheets = sheets

    me remove_sheet(index: i32):
        """Remove the sheet at the given index. Does nothing if only one sheet remains."""
        if me.sheets.len() <= 1:
            return
        if index < 0 or index >= me.sheets.len():
            return
        var new_sheets: [Sheet] = []
        var i = 0
        for sheet in me.sheets:
            if i != index:
                new_sheets.push(sheet)
            i = i + 1
        me.sheets = new_sheets
        # Adjust active_sheet if needed
        if me.active_sheet >= me.sheets.len():
            me.active_sheet = me.sheets.len() - 1
        if me.active_sheet < 0:
            me.active_sheet = 0

    me set_active(index: i32):
        """Switch the active sheet to the given index."""
        if index >= 0 and index < me.sheets.len():
            me.active_sheet = index

# =========================================================================
# Internal Helpers
# =========================================================================

fn _try_parse_number(s: text) -> f64?:
    """Attempt to parse text as a number. Returns nil if not a valid number."""
    if s.len() == 0:
        return nil
    var has_dot = false
    var has_digit = false
    var i = 0
    # Allow leading minus
    if s.char_at(0) == "-":
        if s.len() == 1:
            return nil
        i = 1
    while i < s.len():
        val c = s.char_at(i)
        if c == ".":
            if has_dot:
                return nil  # Two dots
            has_dot = true
        elif _is_digit(c):
            has_digit = true
        else:
            return nil
        i = i + 1
    if not has_digit:
        return nil
    # Parse it
    return _parse_f64(s)

fn _parse_f64(s: text) -> f64?:
    """Parse a float from text. Supports optional leading minus and one decimal point."""
    return office_parse_signed_decimal_f64(s)

fn _is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

fn _digit_val(c: text) -> i32:
    val code = c.char_code_at(0)
    code - 48

fn sheet_edit_diff(ref_str: text, expected_display: text, actual_display: text, new_value: text, accepted: bool) -> text:
    if accepted:
        return "@@ cell {ref_str.upper()} @@\n- {expected_display}\n+ {actual_display}"
    "@@ cell {ref_str.upper()} @@\nexpected: {expected_display}\nactual: {actual_display}\nrejected: {new_value}"
