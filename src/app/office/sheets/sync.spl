# Sheet Diff / Apply — async co-authoring sync primitives
#
# Companion to app.office.sheets.merge (three-way merge). Where merge3
# reconciles two full divergent copies, diff/apply is the transport half of
# the collaboration toolkit: compute a compact change list between two sheet
# states (sheet_diff) and replay it on another copy (sheet_apply). Typical
# async-collaboration flow: keep the shared base; ship
# ops = sheet_diff(base, mine) to a peer; the peer runs
# sheet_apply(their_base, ops); overlapping edits are then reconciled with
# sheet_merge3.
#
# Op model (SheetOp):
#   kind "set"    — ref is a cell reference ("A1"); text is the cell's RAW
#                   stored text (formula SOURCE "=A1+B1" for formula cells,
#                   never the cached computed display — same convention as
#                   merge.spl). Covers both added and changed cells.
#   kind "clear"  — ref is a cell reference; the cell was deleted. text "".
#   kind "hide"   — ref is a 1-based ROW NUMBER as text ("3"); the row was
#                   hidden in `current` but not in `base`. text "".
#   kind "unhide" — ref is a row number as text; the row was unhidden.
#
# Deterministic order: cell ops first in row-major order (A1, B1, ..., A2,
# B2, ...), then row-visibility ops in ascending row order. diff(x, x) is
# always empty, and apply(base, diff(base, current)) reproduces a sheet
# whose diff against current is empty (the round-trip law, spec-enforced).
#
# Wire format: one op per line, "op|<kind>|<ref>|<text>" via ops_to_lines /
# lines_to_ops. The text field is the REMAINDER of the line, so raw cell
# text containing "|" survives the round trip. Lines not starting with
# "op|" are ignored by the parser (safe to interleave with other traffic).
#
# CEILINGS (documented, not bugs): raw text is replayed through
# Sheet.set_value, so a literal text cell that LOOKS like a number/bool/
# formula re-enters as that richer type (same display text; merge.spl has
# the same text-level ceiling). Cell styles, sheet scalars (name,
# col_count, row_count), and column hiding are not diffed — cells and row
# visibility only.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{Cell, CellValue, cell_display_text, parse_cell_ref}
use app.office.file_formats.{recalculate_formula_cells}
use common.office.number.{office_parse_non_negative_i32}

struct SheetOp:
    ref: text     # cell ref ("A1") for set/clear; row number ("3") for hide/unhide
    kind: text    # "set" | "clear" | "hide" | "unhide"
    text: text    # raw stored text for set; "" for clear/hide/unhide

# =========================================================================
# Public API
# =========================================================================

fn sheet_diff(base: Sheet, current: Sheet) -> [SheetOp]:
    """Change list that transforms `base` into `current`: set ops for added/
    changed cells (raw stored text), clear ops for deleted cells, hide/
    unhide ops for row-visibility changes. Cell ops come first in row-major
    order, then row ops ascending by row. diff(x, x) == []."""
    var ops: [SheetOp] = []

    # Union of every cell reference in either sheet (keys are stored
    # uppercase by set_cell), first-seen order: base then current.
    var refs: [text] = []
    for k in base.cells.keys():
        if not _text_list_contains(refs, k):
            refs.push(k)
    for k in current.cells.keys():
        if not _text_list_contains(refs, k):
            refs.push(k)

    # Parse each ref into (row, col) for row-major ordering. Unparsable
    # refs (should not happen for set_cell keys) sort last, ref order kept.
    val n = refs.len()
    var rows: [i32] = []
    var cols: [i32] = []
    for k in refs:
        val parsed = parse_cell_ref(k)
        if parsed != nil:
            rows.push(parsed.row)
            cols.push(parsed.col)
        else:
            rows.push(2147483647)
            cols.push(2147483647)

    # Selection sort by (row, col) — n is the number of DISTINCT touched
    # cells, so quadratic is fine for a change list.
    var used: [bool] = []
    for k in refs:
        used.push(false)
    var i = 0
    while i < n:
        var best = -1
        var j = 0
        while j < n:
            val ju = used[j]
            if not ju:
                if best < 0:
                    best = j
                else:
                    val jr = rows[j]
                    val jc = cols[j]
                    val br = rows[best]
                    val bc = cols[best]
                    if jr < br or (jr == br and jc < bc):
                        best = j
            j = j + 1
        used[best] = true
        val k = refs[best]

        val b_cell = base.cells.get(k)
        val c_cell = current.cells.get(k)
        if b_cell == nil and c_cell != nil:
            ops.push(SheetOp(ref: k, kind: "set", text: _cell_raw_text(c_cell)))
        elif b_cell != nil and c_cell == nil:
            ops.push(SheetOp(ref: k, kind: "clear", text: ""))
        elif b_cell != nil and c_cell != nil:
            val b_text = _cell_raw_text(b_cell)
            val c_text = _cell_raw_text(c_cell)
            if b_text != c_text:
                ops.push(SheetOp(ref: k, kind: "set", text: c_text))
        i = i + 1

    # Row-visibility ops, ascending row order (naturally deterministic:
    # scan every candidate row once instead of sorting the hidden lists).
    var max_row = base.row_count.to_i64()
    val cur_max = current.row_count.to_i64()
    if cur_max > max_row:
        max_row = cur_max
    var r: i64 = 1
    while r <= max_row:
        val in_base = base.is_row_hidden(r)
        val in_cur = current.is_row_hidden(r)
        if in_cur and not in_base:
            ops.push(SheetOp(ref: "{r}", kind: "hide", text: ""))
        if in_base and not in_cur:
            ops.push(SheetOp(ref: "{r}", kind: "unhide", text: ""))
        r = r + 1

    ops

fn sheet_apply(sheet: Sheet, ops: [SheetOp]) -> Sheet:
    """Replay a change list onto a sheet and return the updated sheet
    (callers reassign — standard mutator convention). set ops go through
    Sheet.set_value (raw text re-parses to number/bool/formula/text); if
    any set op carries formula text ("=...") the whole sheet is
    recalculated at the end so formula displays are current."""
    var out = sheet
    var needs_recalc = false
    for op in ops:
        if op.kind == "set":
            out.set_value(op.ref, op.text)
            if op.text.starts_with("="):
                needs_recalc = true
        elif op.kind == "clear":
            out.set_value(op.ref, "")
        elif op.kind == "hide":
            val row = office_parse_non_negative_i32(op.ref).to_i64()
            out.hide_row(row)
        elif op.kind == "unhide":
            val row = office_parse_non_negative_i32(op.ref).to_i64()
            out.unhide_row(row)
    if needs_recalc:
        out = recalculate_formula_cells(out)
    out

fn ops_to_lines(ops: [SheetOp]) -> [text]:
    """Serialize ops to shippable text lines: "op|<kind>|<ref>|<text>"."""
    var lines: [text] = []
    for op in ops:
        lines.push("op|{op.kind}|{op.ref}|{op.text}")
    lines

fn lines_to_ops(lines: [text]) -> [SheetOp]:
    """Parse "op|<kind>|<ref>|<text>" lines back into ops. The text field
    is everything after the third "|" (so cell text containing "|"
    round-trips). Lines not starting with "op|" are skipped."""
    var ops: [SheetOp] = []
    for line in lines:
        if line.starts_with("op|"):
            val rest = line.substring(3)
            var field = 0
            var kind = ""
            var ref_s = ""
            var body = ""
            var i = 0
            while i < rest.len():
                val c = rest.char_at(i)
                if field < 2 and c == "|":
                    field = field + 1
                elif field == 0:
                    kind = "{kind}{c}"
                elif field == 1:
                    ref_s = "{ref_s}{c}"
                else:
                    body = "{body}{c}"
                i = i + 1
            ops.push(SheetOp(ref: ref_s, kind: kind, text: body))
    ops

# =========================================================================
# Internals
# =========================================================================

fn _cell_raw_text(cell: Cell) -> text:
    """Raw stored text for diff comparison: formula SOURCE ("=expr") for
    formula cells, display text otherwise — mirrors merge.spl so diff and
    merge3 agree on what counts as a change."""
    match cell.value:
        CellValue.FormulaVal(expr, cached_display):
            return "={expr}"
        _:
            return cell_display_text(cell)

fn _text_list_contains(items: [text], s: text) -> bool:
    for item in items:
        if item == s:
            return true
    false
