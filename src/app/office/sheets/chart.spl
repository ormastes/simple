# Calc Charts — SVG bar chart from a sheet range
#
# Pure model->SVG transform: labels from one column range, values from another
# (e.g. chart_from_ranges(sheet, "A2:A4", "B2:B4")). Bars scale to the max
# value; each bar carries its label and value as SVG text. No external assets.
#
# ponytail: bar chart only; add line/pie when a real document needs them.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, CellValue}
use app.office.sheets.cell_ref.{parse_range, expand_range_refs}

struct ChartSeries:
    labels: [text]
    values: [f64]

fn _cell_number(sheet: Sheet, ref_str: text) -> f64:
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return value
        CellValue.FormulaVal(expr, cached_display):
            # Use the cached computed display when numeric
            val d = cached_display
            if d.len() > 0:
                val parsed = d.to_f64()
                return parsed
            return 0.0
        _:
            return 0.0

fn chart_series_from_ranges(sheet: Sheet, label_range: text, value_range: text) -> ChartSeries:
    """Collect labels and numeric values from two same-length cell ranges."""
    var labels: [text] = []
    var values: [f64] = []
    val lr = parse_range(label_range)
    val vr = parse_range(value_range)
    if lr != nil:
        for ref_str in expand_range_refs(lr):
            labels.push(cell_display_text(sheet.get_cell(ref_str)))
    if vr != nil:
        for ref_str in expand_range_refs(vr):
            values.push(_cell_number(sheet, ref_str))
    ChartSeries(labels: labels, values: values)

fn _svg_escape(s: text) -> text:
    var r = s
    r = r.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r

fn _fmt_val(v: f64) -> text:
    val i = v.to_i64()
    if v - i.to_f64() == 0.0:
        return "{i}"
    "{v}"

fn render_bar_chart_svg(series: ChartSeries, title: text) -> text:
    """Render the series as a self-contained SVG bar chart (420x, 40px/bar)."""
    val n = series.values.len()
    if n == 0:
        return "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"420\" height=\"40\"><text x=\"10\" y=\"25\" font-size=\"13\">no data</text></svg>"
    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    if max_v <= 0.0:
        max_v = 1.0
    val bar_h = 26
    val row_h = 40
    val chart_w = 420
    val label_w = 110
    val height = 40 + n * row_h
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{chart_w}\" height=\"{height}\" font-family=\"sans-serif\">"
    val safe_title = _svg_escape(title)
    out = "{out}<text x=\"10\" y=\"24\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    var i = 0
    while i < n:
        val v = series.values[i]
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val y = 40 + i * row_h
        val bar_w = ((v / max_v) * (chart_w - label_w - 60).to_f64()).to_i64()
        val bar_y = y + 6
        val text_y = y + 24
        val bar_x_end = label_w + bar_w.to_i32() + 8
        out = "{out}<text x=\"10\" y=\"{text_y}\" font-size=\"13\">{label}</text>"
        out = "{out}<rect x=\"{label_w}\" y=\"{bar_y}\" width=\"{bar_w}\" height=\"{bar_h}\" fill=\"#2b579a\" rx=\"3\"/>"
        out = "{out}<text x=\"{bar_x_end}\" y=\"{text_y}\" font-size=\"13\" fill=\"#4b5563\">{_fmt_val(v)}</text>"
        i = i + 1
    "{out}</svg>"

fn sheet_bar_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    """One-call chart: ranges in, SVG out."""
    render_bar_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)
