# Table Queries
#
# Access-like structured queries over sheet tables: column projection with a
# filter (SELECT ... WHERE), multi-key sort (ORDER BY), a nested-loop join
# (JOIN), and group-aggregate (GROUP BY). Every operation reads a Sheet that
# has a header row somewhere in it and returns a NEW plain Sheet with its own
# header row at row 1 — so results compose: the output of sheet_select can
# feed sheet_sort_by, whose output can feed sheet_group_agg, without any
# glue code.
#
# Column selectors (`cols`, `criteria_col`, `keys`, `group_col`, `value_col`,
# `left_key`, `right_key`) are header NAMES resolved against the header row
# by exact (case-sensitive) text match — never letters. Reuses
# data_ops.spl's `cell_matches_criteria` / `compare_cells_for_sort` public
# wrappers rather than re-implementing criteria parsing or cell comparison.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{Cell, CellValue, CellRef, cell_ref_to_string, cell_display_text, empty_cell, text_cell, number_cell}
use app.office.sheets.cell_ref.{CellRange, parse_range}
use app.office.sheets.data_ops.{cell_matches_criteria, compare_cells_for_sort}
use std.common.math.statistics.{mean}

# =========================================================================
# Shared Helpers
# =========================================================================

fn _min_i32(a: i32, b: i32) -> i32:
    if a < b:
        return a
    b

fn _max_i32(a: i32, b: i32) -> i32:
    if a > b:
        return a
    b

fn _sheet_bounds(sheet: Sheet) -> CellRange:
    """Used-range bounds of `sheet` as a CellRange. Falls back to a single
    A1 cell in the (practically unreachable) case used_range's own string
    fails to parse."""
    val range_a1 = sheet.used_range()
    val parsed = parse_range(range_a1)
    if val rng = parsed:
        return rng
    CellRange(start: CellRef(col: 0, row: 0), end_ref: CellRef(col: 0, row: 0))

fn _header_col_index(sheet: Sheet, header_row: i64, name: text) -> i32:
    """0-based column index whose cell in `header_row` (1-based) displays
    `name` exactly. Returns -1 when no header cell matches."""
    val bounds = _sheet_bounds(sheet)
    val min_col = _min_i32(bounds.start.col, bounds.end_ref.col)
    val max_col = _max_i32(bounds.start.col, bounds.end_ref.col)
    val hr0 = (header_row - 1).to_i32()
    var c = min_col
    while c <= max_col:
        val ref = CellRef(col: c, row: hr0)
        val cell = sheet.get_cell(cell_ref_to_string(ref))
        if cell_display_text(cell) == name:
            return c
        c = c + 1
    -1

fn _row_cells(sheet: Sheet, row0: i32, min_col: i32, max_col: i32) -> [Cell]:
    """Read one 0-based row's cells across [min_col, max_col] inclusive."""
    var cells: [Cell] = []
    var c = min_col
    while c <= max_col:
        val ref = CellRef(col: c, row: row0)
        cells.push(sheet.get_cell(cell_ref_to_string(ref)))
        c = c + 1
    cells

fn _write_row(sheet: Sheet, row0: i32, cells: [Cell]) -> Sheet:
    """Write a full row of cells starting at column 0, row0 (0-based).
    Returns the mutated Sheet — callers MUST reassign. A freshly-created
    Sheet passed as a plain function parameter (as opposed to mutated via a
    direct method call on a function's own parameter) does not reliably
    keep its mutations under the interpreter, matching the codebase's
    general "aggregates pass by copy, return-and-reassign" convention."""
    var result = sheet
    var c = 0
    while c < cells.len():
        val ref = CellRef(col: c, row: row0)
        result.set_cell(cell_ref_to_string(ref), cells[c])
        c = c + 1
    result

fn _header_names(sheet: Sheet, header_row: i64, min_col: i32, max_col: i32) -> [text]:
    """Display text of every header cell in [min_col, max_col], in order."""
    val hr0 = (header_row - 1).to_i32()
    var names: [text] = []
    var c = min_col
    while c <= max_col:
        val ref = CellRef(col: c, row: hr0)
        names.push(cell_display_text(sheet.get_cell(cell_ref_to_string(ref))))
        c = c + 1
    names

# =========================================================================
# SELECT (project columns + filter rows)
# =========================================================================

fn sheet_select(sheet: Sheet, header_row: i64, cols: [text], criteria_col: text, criteria: text) -> Sheet:
    """SELECT `cols` FROM `sheet` WHERE `criteria_col` `criteria`.

    Projects the named columns (resolved against `header_row`, 1-based, by
    header NAME) and keeps only data rows whose cell under `criteria_col`
    matches `criteria` (semantics of data_ops's `cell_matches_criteria`:
    ">n"/"<=n"/"<>x"/bare case-insensitive equality). Pass an empty
    `criteria_col` ("") to select every data row unfiltered.

    Column names not found in the header are silently skipped (the output
    simply has fewer columns than requested) — this keeps the function
    total rather than failing on a typo'd name; callers that need strict
    validation should check `cols` against the header first.

    Returns a new Sheet: row 1 holds the requested header names (in
    request order, header row only re-emitted for names that resolved),
    data rows follow immediately below, so the result composes with
    sheet_sort_by / sheet_group_agg / another sheet_select.
    """
    val bounds = _sheet_bounds(sheet)
    val min_row = _min_i32(bounds.start.row, bounds.end_ref.row)
    val max_row = _max_i32(bounds.start.row, bounds.end_ref.row)
    val hr0 = (header_row - 1).to_i32()

    # Resolve requested columns to source indices, dropping unknown names.
    # NOTE: iterate `cols` with `for...in` rather than `cols[i]` — the
    # interpreter's array-parameter bug returns 0 for a variable index into
    # an array PARAMETER (doc interp_array_param_indexing_2026-07-03.md);
    # for-in iteration sidesteps it entirely.
    var src_cols: [i32] = []
    var out_names: [text] = []
    for name in cols:
        val idx = _header_col_index(sheet, header_row, name)
        if idx >= 0:
            src_cols.push(idx)
            out_names.push(name)

    val filter_idx = _header_col_index(sheet, header_row, criteria_col)
    val has_filter = criteria_col.len() > 0 and filter_idx >= 0

    var result = Sheet.new(sheet.name)
    var out_row0 = 0
    var out_header: [Cell] = []
    var oi = 0
    while oi < out_names.len():
        out_header.push(text_cell(out_names[oi]))
        oi = oi + 1
    result = _write_row(result, out_row0, out_header)
    out_row0 = out_row0 + 1

    var r = hr0 + 1
    while r <= max_row:
        var include = true
        if has_filter:
            val f_ref = CellRef(col: filter_idx, row: r)
            val f_cell = sheet.get_cell(cell_ref_to_string(f_ref))
            include = cell_matches_criteria(f_cell, criteria)
        if include:
            var row_out: [Cell] = []
            var ci = 0
            while ci < src_cols.len():
                val ref = CellRef(col: src_cols[ci], row: r)
                row_out.push(sheet.get_cell(cell_ref_to_string(ref)))
                ci = ci + 1
            result = _write_row(result, out_row0, row_out)
            out_row0 = out_row0 + 1
        r = r + 1

    result

# =========================================================================
# ORDER BY (stable multi-key sort)
# =========================================================================

fn _row_key_compare(row1: [Cell], row2: [Cell], key_cols: [i32], ascending: [bool]) -> i32:
    """Compare two rows key-by-key (numeric-aware via
    compare_cells_for_sort); the first non-equal key decides. Ties after all
    keys are exhausted compare equal (0), which keeps insertion-sort stable
    — equal-key rows retain their original relative order.

    `key_cols`/`ascending` are copied to local arrays before indexing (the
    interpreter's array-parameter bug returns 0 for a variable index into an
    array PARAMETER; `row1`/`row2` are `[Cell]` and indexed the same way
    data_ops.spl's `_compare_row_cells` proves safe in production)."""
    var kc_local: [i32] = []
    for kc in key_cols:
        kc_local.push(kc)
    var asc_local: [bool] = []
    for a in ascending:
        asc_local.push(a)
    var k = 0
    while k < kc_local.len():
        val col = kc_local[k]
        val cmp_raw = compare_cells_for_sort(row1[col], row2[col])
        var cmp = cmp_raw
        if k < asc_local.len() and not asc_local[k]:
            cmp = -cmp_raw
        if cmp != 0:
            return cmp
        k = k + 1
    0

fn sheet_sort_by(sheet: Sheet, header_row: i64, keys: [text], ascending: [bool]) -> Sheet:
    """ORDER BY `keys` [ASC|DESC per `ascending`] over `sheet`'s data rows.

    Multi-key stable sort: rows are compared key-by-key in the order given
    by `keys` (header names, resolved against `header_row`); the first key
    that differs decides, remaining keys are tie-breakers. Cells compare
    numerically when both sides parse as numbers, otherwise lexicographically
    (case-insensitive) via data_ops's compare_cells_for_sort — mixed
    numeric/text columns fall back to text comparison rules on a per-pair
    basis (numbers sort before text, per that function's documented rule).
    Rows that tie on every key keep their original relative order (stable
    insertion sort).

    `keys` and `ascending` must be the same length; if a `keys` name does not
    resolve to a column, or the two arrays differ in length, the sheet is
    returned UNCHANGED (fail closed).

    Returns a new Sheet spanning the full used-range width, header row
    preserved verbatim at row 1, data rows reordered below it.
    """
    if keys.len() != ascending.len() or keys.len() == 0:
        return sheet

    val bounds = _sheet_bounds(sheet)
    val min_col = _min_i32(bounds.start.col, bounds.end_ref.col)
    val max_col = _max_i32(bounds.start.col, bounds.end_ref.col)
    val min_row = _min_i32(bounds.start.row, bounds.end_ref.row)
    val max_row = _max_i32(bounds.start.row, bounds.end_ref.row)
    val hr0 = (header_row - 1).to_i32()

    # Iterate `keys`/`ascending` with for-in, not `keys[ki]` — variable
    # indexing into an array PARAMETER silently reads 0 in the interpreter
    # (doc interp_array_param_indexing_2026-07-03.md). `asc_local` is a
    # local copy so _row_key_compare can index it safely below.
    var key_cols: [i32] = []
    for name in keys:
        val idx = _header_col_index(sheet, header_row, name)
        if idx < 0:
            return sheet
        key_cols.push(idx - min_col)
    var asc_local: [bool] = []
    for a in ascending:
        asc_local.push(a)

    # Capture data rows (relative to min_col so key_cols index correctly).
    var rows: [[Cell]] = []
    var r = hr0 + 1
    while r <= max_row:
        rows.push(_row_cells(sheet, r, min_col, max_col))
        r = r + 1

    # Stable insertion sort.
    var i = 1
    while i < rows.len():
        val key_row = rows[i]
        var j = i - 1
        while j >= 0:
            val cmp = _row_key_compare(rows[j], key_row, key_cols, asc_local)
            if cmp <= 0:
                break
            rows[j + 1] = rows[j]
            j = j - 1
        rows[j + 1] = key_row
        i = i + 1

    var result = Sheet.new(sheet.name)
    result = _write_row(result, 0, _row_cells(sheet, hr0, min_col, max_col))
    var out_r = 1
    var ri = 0
    while ri < rows.len():
        result = _write_row(result, out_r, rows[ri])
        out_r = out_r + 1
        ri = ri + 1
    result

# =========================================================================
# JOIN (honest nested-loop, no hashing)
# =========================================================================

fn sheet_join(left: Sheet, right: Sheet, header_row: i64, left_key: text, right_key: text, join_kind: text) -> Sheet:
    """JOIN `left` and `right` on `left_key` = `right_key` (header names,
    resolved independently against each sheet's own `header_row`).

    Implementation is a plain nested loop over left rows x right rows —
    O(n*m) — with NO hash index: it re-scans right's data rows for every
    left row. This is the honest, small implementation for the row counts
    a hand-built spreadsheet table has; it is not intended for large tables.

    Key equality is case-insensitive display-text equality (matching the
    bare-value branch of data_ops's criteria matcher / sheet_remove_duplicates'
    key convention), NOT numeric-aware — "3" and "3.0" are different keys
    here since they are compared as their displayed text.

    `join_kind`: "inner" emits only matched (left, right) row pairs;
    "left" additionally emits every left row that matched NOTHING, with all
    right-side columns filled with "" (empty cells). Any other join_kind
    value falls back to "inner" behavior.

    Output header = left's header names, in order, followed by right's
    header names EXCLUDING `right_key` itself (its value is redundant with
    left_key's on every matched row). Output data rows = left row's cells
    followed by the matched right row's cells (right_key column omitted);
    for an unmatched left row under "left", the right-side cells are all
    empty. Unknown left_key/right_key names or a bad header_row make the
    function return an EMPTY new Sheet (header row only) rather than guess.
    """
    var result = Sheet.new(left.name)

    val lb = _sheet_bounds(left)
    val l_min_col = _min_i32(lb.start.col, lb.end_ref.col)
    val l_max_col = _max_i32(lb.start.col, lb.end_ref.col)
    val l_min_row = _min_i32(lb.start.row, lb.end_ref.row)
    val l_max_row = _max_i32(lb.start.row, lb.end_ref.row)

    val rb = _sheet_bounds(right)
    val r_min_col = _min_i32(rb.start.col, rb.end_ref.col)
    val r_max_col = _max_i32(rb.start.col, rb.end_ref.col)
    val r_min_row = _min_i32(rb.start.row, rb.end_ref.row)
    val r_max_row = _max_i32(rb.start.row, rb.end_ref.row)

    val hr0 = (header_row - 1).to_i32()

    val l_key_idx = _header_col_index(left, header_row, left_key)
    val r_key_idx = _header_col_index(right, header_row, right_key)
    if l_key_idx < 0 or r_key_idx < 0:
        result = _write_row(result, 0, [])
        return result

    val l_headers = _header_names(left, header_row, l_min_col, l_max_col)
    val r_headers_all = _header_names(right, header_row, r_min_col, r_max_col)

    # Right header cells minus right_key, tracked as absolute column indices.
    var r_out_cols: [i32] = []
    var rh = 0
    while rh < r_headers_all.len():
        val abs_col = r_min_col + rh
        if abs_col != r_key_idx:
            r_out_cols.push(abs_col)
        rh = rh + 1

    var out_header: [Cell] = []
    var hi = 0
    while hi < l_headers.len():
        out_header.push(text_cell(l_headers[hi]))
        hi = hi + 1
    var rci = 0
    while rci < r_out_cols.len():
        val ref = CellRef(col: r_out_cols[rci], row: hr0)
        out_header.push(right.get_cell(cell_ref_to_string(ref)))
        rci = rci + 1
    result = _write_row(result, 0, out_header)

    val kind_lower = join_kind.lower()
    val is_left_join = kind_lower == "left"

    var out_row0 = 1
    var lr = hr0 + 1
    while lr <= l_max_row:
        val l_row = _row_cells(left, lr, l_min_col, l_max_col)
        val l_key_cell = left.get_cell(cell_ref_to_string(CellRef(col: l_key_idx, row: lr)))
        val l_key_text = cell_display_text(l_key_cell).lower()

        var matched_any = false
        var rr = hr0 + 1
        while rr <= r_max_row:
            val r_key_cell = right.get_cell(cell_ref_to_string(CellRef(col: r_key_idx, row: rr)))
            val r_key_text = cell_display_text(r_key_cell).lower()
            if r_key_text == l_key_text:
                matched_any = true
                var out_row: [Cell] = []
                var lci = 0
                while lci < l_row.len():
                    out_row.push(l_row[lci])
                    lci = lci + 1
                var oci = 0
                while oci < r_out_cols.len():
                    out_row.push(right.get_cell(cell_ref_to_string(CellRef(col: r_out_cols[oci], row: rr))))
                    oci = oci + 1
                result = _write_row(result, out_row0, out_row)
                out_row0 = out_row0 + 1
            rr = rr + 1

        if not matched_any and is_left_join:
            var out_row: [Cell] = []
            var lci = 0
            while lci < l_row.len():
                out_row.push(l_row[lci])
                lci = lci + 1
            var oci = 0
            while oci < r_out_cols.len():
                out_row.push(empty_cell())
                oci = oci + 1
            result = _write_row(result, out_row0, out_row)
            out_row0 = out_row0 + 1

        lr = lr + 1

    result

# =========================================================================
# GROUP BY (aggregate)
# =========================================================================

fn _group_agg_apply(agg: text, values: [f64]) -> f64:
    """Apply one of sum/count/average/min/max to a flat value list. `average`
    reuses std.common.math.statistics.mean (zero duplication of the mean
    formula); unsupported agg names return 0.0 (callers pre-validate)."""
    if agg == "sum":
        var total = 0.0
        for v in values:
            total = total + v
        return total
    if agg == "count":
        return values.len().to_f64()
    if agg == "average":
        return mean(values)
    if agg == "min":
        if values.len() == 0:
            return 0.0
        var m = values[0]
        for v in values:
            if v < m:
                m = v
        return m
    if agg == "max":
        if values.len() == 0:
            return 0.0
        var m = values[0]
        for v in values:
            if v > m:
                m = v
        return m
    0.0

fn _is_supported_group_agg(agg: text) -> bool:
    (agg == "sum" or agg == "count" or agg == "average" or agg == "min" or agg == "max")

fn sheet_group_agg(sheet: Sheet, header_row: i64, group_col: text, value_col: text, agg: text) -> Sheet:
    """GROUP BY `group_col`, aggregate `value_col` with `agg` (one of
    "sum"/"count"/"average"/"min"/"max", case-insensitive).

    Groups are formed in FIRST-SEEN order (not sorted) by the display text
    of `group_col`; non-numeric `value_col` cells are excluded from the
    numeric aggregate (mirrors sheet_subtotals' convention). `average` is
    computed via std.common.math.statistics.mean — no reimplementation of
    the mean formula.

    Output = a new 2-column Sheet: header row ["<group_col>", "<agg>"],
    one row per group (key, aggregate) in first-seen order, followed by a
    ["Total", grand_aggregate] row where grand_aggregate is `agg` applied
    over EVERY value_col cell in the table (not a sum-of-group-aggregates)
    — this mirrors GROUPBY's landed semantics in formula.spl, so e.g. a
    "Total" row for "average" is the overall average, not an average of
    per-group averages.

    Unknown group_col/value_col names or an unsupported agg -> a Sheet
    with only the header row (no data, no Total).
    """
    var result = Sheet.new(sheet.name)
    val agg_lower = agg.lower()
    result.set_cell("A1", text_cell(group_col))
    result.set_cell("B1", text_cell(agg_lower))

    val g_idx = _header_col_index(sheet, header_row, group_col)
    val v_idx = _header_col_index(sheet, header_row, value_col)
    if g_idx < 0 or v_idx < 0 or not _is_supported_group_agg(agg_lower):
        return result

    val bounds = _sheet_bounds(sheet)
    val max_row = _max_i32(bounds.start.row, bounds.end_ref.row)
    val hr0 = (header_row - 1).to_i32()

    var names: [text] = []
    var groups: [[f64]] = []
    var all_values: [f64] = []

    var r = hr0 + 1
    while r <= max_row:
        val g_cell = sheet.get_cell(cell_ref_to_string(CellRef(col: g_idx, row: r)))
        val g_name = cell_display_text(g_cell)
        val v_cell = sheet.get_cell(cell_ref_to_string(CellRef(col: v_idx, row: r)))

        var has_value = false
        var v = 0.0
        match v_cell.value:
            CellValue.NumberVal(vv):
                has_value = true
                v = vv
            _:
                pass_do_nothing

        var gi = -1
        var s = 0
        while s < names.len():
            if names[s] == g_name:
                gi = s
            s = s + 1
        if gi < 0:
            gi = names.len()
            names.push(g_name)
            groups.push([])

        if has_value:
            var bucket = groups[gi]
            bucket.push(v)
            groups[gi] = bucket
            all_values.push(v)

        r = r + 1

    var out_r = 1
    var gi = 0
    while gi < names.len():
        val agg_val = _group_agg_apply(agg_lower, groups[gi])
        result.set_cell("A{out_r + 1}", text_cell(names[gi]))
        result.set_cell("B{out_r + 1}", number_cell(agg_val))
        out_r = out_r + 1
        gi = gi + 1

    val grand = _group_agg_apply(agg_lower, all_values)
    result.set_cell("A{out_r + 1}", text_cell("Total"))
    result.set_cell("B{out_r + 1}", number_cell(grand))

    result
