            if s < 0.0:
                s = 0.0 - s
            if s == 0.0:
                return CellValue.NumberVal(value: 0.0)
            val mode = if args.len() >= 3: _first_val(args[2]) else: 0.0
            # Default: round toward -inf. Negative number with nonzero mode: toward zero.
            if num < 0.0 and mode != 0.0:
                return CellValue.NumberVal(value: _ceil_f64(num / s) * s)
