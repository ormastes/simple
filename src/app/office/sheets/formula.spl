        "YIELD":
            if args.len() >= 6:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val rate = _first_val(args[2])
                val pr = _first_val(args[3])
                val redemption = _first_val(args[4])
                val freq = _first_val(args[5]).to_i64()
                val basis = if args.len() >= 7: _first_val(args[6]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or (freq != 1 and freq != 2 and freq != 4) or rate < 0.0 or pr <= 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "YIELD domain error")
                return CellValue.NumberVal(value: _sec_yield(settle, mat, rate, pr, redemption, freq, basis))
            return CellValue.ErrorVal(message: "YIELD requires settle, maturity, rate, pr, redemption, freq")
        "PRICEDISC":
            if args.len() >= 4:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val discount = _first_val(args[2])
                val redemption = _first_val(args[3])
                val basis = if args.len() >= 5: _first_val(args[4]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or discount <= 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "PRICEDISC domain error")
                return CellValue.NumberVal(value: redemption - discount * redemption * daycount_frac(settle, mat, basis))
            return CellValue.ErrorVal(message: "PRICEDISC requires settle, maturity, discount, redemption")
        "YIELDDISC":
            if args.len() >= 4:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val pr = _first_val(args[2])
                val redemption = _first_val(args[3])
                val basis = if args.len() >= 5: _first_val(args[4]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or pr <= 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "YIELDDISC domain error")
                return CellValue.NumberVal(value: (redemption - pr) / pr / daycount_frac(settle, mat, basis))
            return CellValue.ErrorVal(message: "YIELDDISC requires settle, maturity, pr, redemption")
        "PRICEMAT":
            if args.len() >= 5:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val issue = _first_val(args[2])
                val rate = _first_val(args[3])
                val yld = _first_val(args[4])
                val basis = if args.len() >= 6: _first_val(args[5]).to_i64() else: 0
                if settle >= mat or issue >= settle or basis < 0 or basis > 4 or rate < 0.0 or yld < 0.0:
                    return CellValue.ErrorVal(message: "PRICEMAT domain error")
                val dsm = daycount_frac(settle, mat, basis)
                val dim = daycount_frac(issue, mat, basis)
                val a = daycount_frac(issue, settle, basis)
                return CellValue.NumberVal(value: (100.0 + dim * rate * 100.0) / (1.0 + dsm * yld) - a * rate * 100.0)
            return CellValue.ErrorVal(message: "PRICEMAT requires settle, maturity, issue, rate, yld")
        "YIELDMAT":
            if args.len() >= 5:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val issue = _first_val(args[2])
                val rate = _first_val(args[3])
                val pr = _first_val(args[4])
                val basis = if args.len() >= 6: _first_val(args[5]).to_i64() else: 0
                if settle >= mat or issue >= settle or basis < 0 or basis > 4 or rate < 0.0 or pr <= 0.0:
                    return CellValue.ErrorVal(message: "YIELDMAT domain error")
                val dim = daycount_frac(issue, mat, basis)
                val a = daycount_frac(issue, settle, basis)
                val dsm = daycount_frac(settle, mat, basis)
                val base = pr / 100.0 + a * rate
                return CellValue.NumberVal(value: ((1.0 + dim * rate) - base) / base / dsm)
            return CellValue.ErrorVal(message: "YIELDMAT requires settle, maturity, issue, rate, pr")
        "DISC":
            if args.len() >= 4:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val pr = _first_val(args[2])
                val redemption = _first_val(args[3])
                val basis = if args.len() >= 5: _first_val(args[4]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or pr <= 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "DISC domain error")
                return CellValue.NumberVal(value: (redemption - pr) / redemption / daycount_frac(settle, mat, basis))
            return CellValue.ErrorVal(message: "DISC requires settle, maturity, pr, redemption")
        "INTRATE":
            if args.len() >= 4:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val investment = _first_val(args[2])
                val redemption = _first_val(args[3])
                val basis = if args.len() >= 5: _first_val(args[4]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or investment <= 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "INTRATE domain error")
                return CellValue.NumberVal(value: (redemption - investment) / investment / daycount_frac(settle, mat, basis))
            return CellValue.ErrorVal(message: "INTRATE requires settle, maturity, investment, redemption")
        "RECEIVED":
            if args.len() >= 4:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val investment = _first_val(args[2])
                val discount = _first_val(args[3])
                val basis = if args.len() >= 5: _first_val(args[4]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or investment <= 0.0 or discount <= 0.0:
                    return CellValue.ErrorVal(message: "RECEIVED domain error")
                val dd = 1.0 - discount * daycount_frac(settle, mat, basis)
                if dd <= 0.0:
                    return CellValue.ErrorVal(message: "RECEIVED domain error")
                return CellValue.NumberVal(value: investment / dd)
            return CellValue.ErrorVal(message: "RECEIVED requires settle, maturity, investment, discount")
        "DURATION":
            if args.len() >= 5:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val coupon = _first_val(args[2])
                val yld = _first_val(args[3])
                val freq = _first_val(args[4]).to_i64()
                val basis = if args.len() >= 6: _first_val(args[5]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or (freq != 1 and freq != 2 and freq != 4) or coupon < 0.0 or yld < 0.0:
                    return CellValue.ErrorVal(message: "DURATION domain error")
                return CellValue.NumberVal(value: _sec_duration(settle, mat, coupon, yld, freq, basis))
            return CellValue.ErrorVal(message: "DURATION requires settle, maturity, coupon, yld, freq")
        "MDURATION":
            if args.len() >= 5:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val coupon = _first_val(args[2])
                val yld = _first_val(args[3])
                val freq = _first_val(args[4]).to_i64()
                val basis = if args.len() >= 6: _first_val(args[5]).to_i64() else: 0
                if settle >= mat or basis < 0 or basis > 4 or (freq != 1 and freq != 2 and freq != 4) or coupon < 0.0 or yld < 0.0:
                    return CellValue.ErrorVal(message: "MDURATION domain error")
                val dur = _sec_duration(settle, mat, coupon, yld, freq, basis)
                return CellValue.NumberVal(value: dur / (1.0 + yld / freq.to_f64()))
            return CellValue.ErrorVal(message: "MDURATION requires settle, maturity, coupon, yld, freq")
        "TBILLPRICE":
            if args.len() >= 3:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val discount = _first_val(args[2])
                val dsm = mat - settle
                if settle >= mat or discount <= 0.0 or dsm > 365.0:
                    return CellValue.ErrorVal(message: "TBILLPRICE domain error")
                return CellValue.NumberVal(value: 100.0 * (1.0 - discount * dsm / 360.0))
            return CellValue.ErrorVal(message: "TBILLPRICE requires settle, maturity, discount")
        "TBILLYIELD":
            if args.len() >= 3:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val pr = _first_val(args[2])
                val dsm = mat - settle
                if settle >= mat or pr <= 0.0 or dsm > 365.0:
                    return CellValue.ErrorVal(message: "TBILLYIELD domain error")
                return CellValue.NumberVal(value: (100.0 - pr) / pr * 360.0 / dsm)
            return CellValue.ErrorVal(message: "TBILLYIELD requires settle, maturity, pr")
        "TBILLEQ":
            if args.len() >= 3:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val discount = _first_val(args[2])
                val dsm = mat - settle
                if settle >= mat or discount <= 0.0 or dsm > 365.0:
                    return CellValue.ErrorVal(message: "TBILLEQ domain error")
                if dsm <= 182.0:
                    return CellValue.NumberVal(value: 365.0 * discount / (360.0 - discount * dsm))
                val price = 100.0 * (1.0 - discount * dsm / 360.0)
                val ry = dsm / 365.0
                val disc_root = ry * ry - (2.0 * ry - 1.0) * (1.0 - 100.0 / price)
                if disc_root < 0.0:
                    return CellValue.ErrorVal(message: "TBILLEQ domain error")
                return CellValue.NumberVal(value: (0.0 - ry + sqrt_f64(disc_root)) / (ry - 0.5))
            return CellValue.ErrorVal(message: "TBILLEQ requires settle, maturity, discount")
        "DOLLARDE":
            if args.len() >= 2:
                val fd = _first_val(args[0])
                val fr = _first_val(args[1])
                if fr <= 0.0:
                    return CellValue.ErrorVal(message: "DOLLARDE domain error")
                val ip = _floor_f64(fd)
                val frac = fd - ip
                val power = _sec_pow10_digits(fr)
                return CellValue.NumberVal(value: ip + frac * power / fr)
            return CellValue.ErrorVal(message: "DOLLARDE requires fractional_dollar, fraction")
        "DOLLARFR":
            if args.len() >= 2:
                val dd = _first_val(args[0])
                val fr = _first_val(args[1])
                if fr <= 0.0:
                    return CellValue.ErrorVal(message: "DOLLARFR domain error")
                val ip = _floor_f64(dd)
                val frac = dd - ip
                val power = _sec_pow10_digits(fr)
                return CellValue.NumberVal(value: ip + frac * fr / power)
            return CellValue.ErrorVal(message: "DOLLARFR requires decimal_dollar, fraction")
        "ODDLPRICE":
            if args.len() >= 6:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val last_int = _first_val(args[2])
                val rate = _first_val(args[3])
                val yld = _first_val(args[4])
                val redemption = _first_val(args[5])
                val freq = if args.len() >= 7: _first_val(args[6]).to_i64() else: 2
                val basis = if args.len() >= 8: _first_val(args[7]).to_i64() else: 0
                if mat <= settle or settle <= last_int or basis < 0 or basis > 4 or (freq != 1 and freq != 2 and freq != 4) or rate < 0.0 or yld < 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "ODDLPRICE domain error")
                return CellValue.NumberVal(value: _odd_last_price(settle, mat, last_int, rate, yld, redemption, freq, basis))
            return CellValue.ErrorVal(message: "ODDLPRICE requires settle, maturity, last_interest, rate, yld, redemption")
        "ODDFPRICE":
            if args.len() >= 8:
                val settle = _first_val(args[0])
                val mat = _first_val(args[1])
                val issue = _first_val(args[2])
                val first_coup = _first_val(args[3])
                val rate = _first_val(args[4])
                val yld = _first_val(args[5])
                val redemption = _first_val(args[6])
                val freq = _first_val(args[7]).to_i64()
                val basis = if args.len() >= 9: _first_val(args[8]).to_i64() else: 0
                if mat <= first_coup or first_coup <= settle or settle <= issue or basis < 0 or basis > 4 or (freq != 1 and freq != 2 and freq != 4) or rate < 0.0 or yld < 0.0 or redemption <= 0.0:
                    return CellValue.ErrorVal(message: "ODDFPRICE domain error")
                # Short odd first period implementation only (long odd first periods not supported)
                val odd_period_days = _daycount_num(issue, first_coup, basis)
                val normal_period_days = 12 / freq
                val max_period_days = if basis == 0 or basis == 4: (normal_period_days * 30).to_f64()
                                       elif basis == 3: (normal_period_days * 365.0 / 12.0)
                                       else: (normal_period_days * 30).to_f64()
                if odd_period_days > max_period_days:
                    return CellValue.ErrorVal(message: "ODDFPRICE long odd first not supported")

                # Excel's short-odd-first formula:
                #   P = RDM/(1+y/f)^(N-1+DSC/E)
                #     + (100r/f)·(DFC/E)/(1+y/f)^(DSC/E)
                #     + Σ_{k=2..N} (100r/f)/(1+y/f)^(k-1+DSC/E)
                #     − (100r/f)·(A/E)
                # E = coupon period days, DSC = settlement→first coupon,
                # DFC = issue→first coupon, A = issue→settlement.
                # Verified against Excel's doc example: ODDFPRICE(2008-11-11,
                # 2021-03-01, 2008-10-15, 2009-03-01, 7.85%, 6.25%, 100, 2, 1)
                # = 113.598 (bare `price` fall-through previously discarded the
                # result and returned the arity error below).
                val n = _coup_num(settle, mat, freq).to_i64()
                val e = _coup_days(settle, mat, freq, basis)
                val dsc = _coup_daysnc(settle, mat, freq, basis)
                val coup = 100.0 * rate / freq.to_f64()
                val yf = yld / freq.to_f64()
                val dsce = dsc / e
                val dfc = _daycount_num(issue, first_coup, basis)
                val a_days = _daycount_num(issue, settle, basis)
                var price = redemption / powf(1.0 + yf, (n - 1).to_f64() + dsce)
                price = price + coup * (dfc / e) / powf(1.0 + yf, dsce)
                var k = 2
                while k <= n:
                    price = price + coup / powf(1.0 + yf, (k - 1).to_f64() + dsce)
                    k = k + 1
                price = price - coup * (a_days / e)
                return CellValue.NumberVal(value: price)
            return CellValue.ErrorVal(message: "ODDFPRICE requires settle, maturity, issue, first_coupon, rate, yld, redemption, freq")
        "AMORLINC":
            if args.len() >= 6:
                val cost = _first_val(args[0])
                val date_purch = _first_val(args[1])
                val first_period = _first_val(args[2])
                val salvage = _first_val(args[3])
                val period = _first_val(args[4]).to_i64()
                val rate = _first_val(args[5])
                val basis = if args.len() >= 7: _first_val(args[6]).to_i64() else: 0
                if cost <= 0.0 or salvage < 0.0 or salvage >= cost or rate < 0.0 or rate > 1.0 or basis < 0 or basis > 4 or period < 0 or first_period <= date_purch:
                    return CellValue.ErrorVal(message: "AMORLINC domain error")
                # French straight-line amortization from std.math.financial
                # (Excel numbering: period 0 is the prorated purchase slice).
                return CellValue.NumberVal(value: amorlinc_period(cost, date_purch, first_period, salvage, period, rate, basis))
            return CellValue.ErrorVal(message: "AMORLINC requires cost, date_purchased, first_period, salvage, period, rate")
        "AMORDEGRC":
            if args.len() >= 6:
                val cost = _first_val(args[0])
                val date_purch = _first_val(args[1])
                val first_period = _first_val(args[2])
                val salvage = _first_val(args[3])
                val period = _first_val(args[4]).to_i64()
                val rate = _first_val(args[5])
                val basis = if args.len() >= 7: _first_val(args[6]).to_i64() else: 0
                if cost <= 0.0 or salvage < 0.0 or salvage >= cost or rate < 0.0 or rate > 1.0 or basis < 0 or basis > 4 or period < 0 or first_period <= date_purch:
                    return CellValue.ErrorVal(message: "AMORDEGRC domain error")
                # French degressive amortization from std.math.financial
                # (Excel numbering: period 0 is the prorated purchase slice).
                return CellValue.NumberVal(value: amordegrc_period(cost, date_purch, first_period, salvage, period, rate, basis))
            return CellValue.ErrorVal(message: "AMORDEGRC requires cost, date_purchased, first_period, salvage, period, rate")
        "TRUE":
            return CellValue.BoolVal(value: true)
        "FALSE":
            return CellValue.BoolVal(value: false)
        "ISEVEN":
            if flat.len() > 0:
                return CellValue.BoolVal(value: flat[0].to_i64() % 2 == 0)
            return CellValue.ErrorVal(message: "ISEVEN requires 1 argument")
        "ISODD":
            if flat.len() > 0:
                val m = flat[0].to_i64() % 2
                return CellValue.BoolVal(value: m == 1 or m == -1)
            return CellValue.ErrorVal(message: "ISODD requires 1 argument")
        "GEOMEAN":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "GEOMEAN requires arguments")
            var ln_sum = 0.0
            for v in flat:
                if v <= 0.0:
                    return CellValue.ErrorVal(message: "GEOMEAN requires positive values")
                ln_sum = ln_sum + ln_f64(v)
            return CellValue.NumberVal(value: exp_f64(ln_sum / flat.len().to_f64()))
        "HARMEAN":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "HARMEAN requires arguments")
            var inv_sum = 0.0
            for v in flat:
                if v == 0.0:
                    return CellValue.ErrorVal(message: "HARMEAN requires nonzero values")
                inv_sum = inv_sum + 1.0 / v
            return CellValue.NumberVal(value: flat.len().to_f64() / inv_sum)
        "MODE":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "MODE requires arguments")
            var best = flat[0]
            var best_count = 0
            for candidate in flat:
                var count = 0
                for v in flat:
                    if v == candidate:
                        count = count + 1
                if count > best_count:
                    best_count = count
                    best = candidate
            return CellValue.NumberVal(value: best)
        "RANK":
            if args.len() >= 2:
                val x = _first_val(args[0])
                val pool = _flatten_args(args[1:])
                var rank = 1
                for v in pool:
                    if v > x:
                        rank = rank + 1
                return CellValue.NumberVal(value: rank.to_f64())
            return CellValue.ErrorVal(message: "RANK requires value and range")
        "RANK.AVG":
            if args.len() >= 2:
                val x = _first_val(args[0])
                val pool = _flatten_args(args[1:])
                var greater = 0
                var ties = 0
                for v in pool:
                    if v > x:
                        greater = greater + 1
                    if v == x:
                        ties = ties + 1
                # Descending default (order 0), matching RANK/RANK.EQ. RANK.AVG averages
                # the ranks that a tie group would otherwise occupy: EQ + (ties-1)/2.
                val eq_rank = (greater + 1).to_f64()
                val avg_rank = eq_rank + (ties - 1).to_f64() / 2.0
                return CellValue.NumberVal(value: avg_rank)
            return CellValue.ErrorVal(message: "RANK.AVG requires value and range")
        "PERCENTILE":
            if args.len() >= 2:
                val k = _first_val(args[args.len() - 1])
                val pool = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                if pool.len() == 0 or k < 0.0 or k > 1.0:
                    return CellValue.ErrorVal(message: "PERCENTILE domain error")
                val pos = k * (pool.len() - 1).to_f64()
                val lo = _floor_f64(pos).to_i64().to_i32()
                val frac = pos - lo.to_f64()
                if lo + 1 >= pool.len():
                    return CellValue.NumberVal(value: pool[pool.len() - 1])
                return CellValue.NumberVal(value: pool[lo] + frac * (pool[lo + 1] - pool[lo]))
            return CellValue.ErrorVal(message: "PERCENTILE requires range and k")
        "QUARTILE":
            if args.len() >= 2:
                val q = _first_val(args[args.len() - 1])
                val poolq = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                if poolq.len() == 0 or q < 0.0 or q > 4.0:
                    return CellValue.ErrorVal(message: "QUARTILE domain error")
                val posq = q / 4.0 * (poolq.len() - 1).to_f64()
                val loq = _floor_f64(posq).to_i64().to_i32()
                val fracq = posq - loq.to_f64()
                if loq + 1 >= poolq.len():
                    return CellValue.NumberVal(value: poolq[poolq.len() - 1])
                return CellValue.NumberVal(value: poolq[loq] + fracq * (poolq[loq + 1] - poolq[loq]))
            return CellValue.ErrorVal(message: "QUARTILE requires range and quart")
        "PERCENTRANK":
            if args.len() >= 2:
                val xr = _first_val(args[args.len() - 1])
                val poolr = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                val nr = poolr.len()
                if nr == 0 or xr < poolr[0] or xr > poolr[nr - 1]:
                    return CellValue.ErrorVal(message: "PERCENTRANK domain error")
                var idx = 0
                while idx < nr and poolr[idx] < xr:
                    idx = idx + 1
                var rank = 0.0
                if idx < nr and poolr[idx] == xr:
                    rank = idx.to_f64() / (nr - 1).to_f64()
                else:
                    val lo = poolr[idx - 1]
                    val hi = poolr[idx]
                    val frac = (xr - lo) / (hi - lo)
                    rank = ((idx - 1).to_f64() + frac) / (nr - 1).to_f64()
                return CellValue.NumberVal(value: _trunc_sig3(rank))
            return CellValue.ErrorVal(message: "PERCENTRANK requires range and x")
        "PERCENTILE.EXC":
            if args.len() >= 2:
                val ke = _first_val(args[args.len() - 1])
                val poole = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                val ne = poole.len()
                if ne == 0 or ke <= 0.0 or ke >= 1.0:
                    return CellValue.ErrorVal(message: "PERCENTILE.EXC domain error")
                val pose = ke * (ne + 1).to_f64()
                val nef = ne.to_f64()
                if pose < 1.0 or pose > nef:
                    return CellValue.ErrorVal(message: "PERCENTILE.EXC out of range")
                val loe = _floor_f64(pose).to_i64().to_i32()
                val frace = pose - loe.to_f64()
                if loe >= ne:
                    return CellValue.NumberVal(value: poole[ne - 1])
                return CellValue.NumberVal(value: poole[loe - 1] + frace * (poole[loe] - poole[loe - 1]))
            return CellValue.ErrorVal(message: "PERCENTILE.EXC requires range and k")
        "QUARTILE.EXC":
            if args.len() >= 2:
                val qe = _first_val(args[args.len() - 1])
                val poolqe = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                val nqe = poolqe.len()
                if nqe == 0 or qe < 1.0 or qe > 3.0:
                    return CellValue.ErrorVal(message: "QUARTILE.EXC domain error")
                val posqe = qe / 4.0 * (nqe + 1).to_f64()
                val nqef = nqe.to_f64()
                if posqe < 1.0 or posqe > nqef:
                    return CellValue.ErrorVal(message: "QUARTILE.EXC out of range")
                val loqe = _floor_f64(posqe).to_i64().to_i32()
                val fracqe = posqe - loqe.to_f64()
                if loqe >= nqe:
                    return CellValue.NumberVal(value: poolqe[nqe - 1])
                return CellValue.NumberVal(value: poolqe[loqe - 1] + fracqe * (poolqe[loqe] - poolqe[loqe - 1]))
            return CellValue.ErrorVal(message: "QUARTILE.EXC requires range and quart")
        "PERCENTRANK.EXC":
            if args.len() >= 2:
                val xe = _first_val(args[args.len() - 1])
                val poolre = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                val nre = poolre.len()
                if nre == 0:
                    return CellValue.ErrorVal(message: "PERCENTRANK.EXC domain error")
                val emin = poolre[0]
                val emax = poolre[nre - 1]
                if xe < emin or xe > emax:
                    return CellValue.ErrorVal(message: "PERCENTRANK.EXC out of range")
                var idxe = 0
                while idxe < nre and poolre[idxe] < xe:
                    idxe = idxe + 1
                var ranke = 0.0
                if idxe < nre and poolre[idxe] == xe:
                    ranke = (idxe + 1).to_f64() / (nre + 1).to_f64()
                else:
                    val elov = poolre[idxe - 1]
                    val ehiv = poolre[idxe]
                    val efrac = (xe - elov) / (ehiv - elov)
                    ranke = (idxe.to_f64() + efrac) / (nre + 1).to_f64()
                return CellValue.NumberVal(value: _trunc_sig3(ranke))
            return CellValue.ErrorVal(message: "PERCENTRANK.EXC requires range and x")
        "CRITBINOM":
            if args.len() >= 3:
                val cbn = _first_val(args[0]).to_i64()
                val cbp = _first_val(args[1])
                val cba = _first_val(args[2])
                if cbn < 0 or cbp < 0.0 or cbp > 1.0 or cba <= 0.0 or cba > 1.0:
                    return CellValue.ErrorVal(message: "CRITBINOM domain error")
                var cbcdf = 0.0
                var cbk: i64 = 0
                while cbk <= cbn:
                    cbcdf = cbcdf + binom_pmf(cbk, cbn, cbp)
                    if cbcdf >= cba:
                        return CellValue.NumberVal(value: cbk.to_f64())
                    cbk = cbk + 1
                return CellValue.NumberVal(value: cbn.to_f64())
            return CellValue.ErrorVal(message: "CRITBINOM requires trials, probability, alpha")
        "TRIMMEAN":
            if args.len() >= 2:
                val pct = _first_val(args[args.len() - 1])
                if pct < 0.0 or pct >= 1.0:
                    return CellValue.ErrorVal(message: "TRIMMEAN percent out of range")
                val poolt = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                val nt = poolt.len()
                if nt == 0:
                    return CellValue.ErrorVal(message: "TRIMMEAN requires values")
                val trim = _floor_f64(nt.to_f64() * pct / 2.0).to_i64().to_i32()
                if 2 * trim >= nt:
                    return CellValue.ErrorVal(message: "TRIMMEAN trims all values")
                var sumt = 0.0
                var it = trim
                while it < nt - trim:
                    sumt = sumt + poolt[it]
                    it = it + 1
                return CellValue.NumberVal(value: sumt / (nt - 2 * trim).to_f64())
            return CellValue.ErrorVal(message: "TRIMMEAN requires range and percent")
        "SKEW":
            if flat.len() >= 3:
                val ns = flat.len()
                var sms = 0.0
                for v in flat:
                    sms = sms + v
                val means = sms / ns.to_f64()
                var sqs = 0.0
                for v in flat:
                    val d = v - means
                    sqs = sqs + d * d
                val sds = sqrt_f64(sqs / (ns - 1).to_f64())
                if sds == 0.0:
                    return CellValue.ErrorVal(message: "SKEW zero deviation")
                var s3 = 0.0
                for v in flat:
                    val z = (v - means) / sds
                    s3 = s3 + z * z * z
                val coef = ns.to_f64() / ((ns - 1).to_f64() * (ns - 2).to_f64())
                return CellValue.NumberVal(value: coef * s3)
            return CellValue.ErrorVal(message: "SKEW requires 3+ values")
        "KURT":
            if flat.len() >= 4:
                val nk = flat.len()
                var smk = 0.0
                for v in flat:
                    smk = smk + v
                val meank = smk / nk.to_f64()
                var sqk = 0.0
                for v in flat:
                    val d = v - meank
                    sqk = sqk + d * d
                val sdk = sqrt_f64(sqk / (nk - 1).to_f64())
                if sdk == 0.0:
                    return CellValue.ErrorVal(message: "KURT zero deviation")
                var s4 = 0.0
                for v in flat:
                    val z = (v - meank) / sdk
                    s4 = s4 + z * z * z * z
                val nn = nk.to_f64()
                val a = nn * (nn + 1.0) / ((nn - 1.0) * (nn - 2.0) * (nn - 3.0))
                val b = 3.0 * (nn - 1.0) * (nn - 1.0) / ((nn - 2.0) * (nn - 3.0))
                return CellValue.NumberVal(value: a * s4 - b)
            return CellValue.ErrorVal(message: "KURT requires 4+ values")
        "SUMPRODUCT":
            if args.len() >= 2:
                val a = args[0]
                val b = args[1]
                if a.len() != b.len():
                    return CellValue.ErrorVal(message: "SUMPRODUCT ranges differ in size")
                var sp = 0.0
                var spi = 0
                while spi < a.len():
                    sp = sp + a[spi] * b[spi]
                    spi = spi + 1
                return CellValue.NumberVal(value: sp)
            return CellValue.ErrorVal(message: "SUMPRODUCT requires 2 ranges")
        "DELTA":
            if args.len() >= 2:
                val eq = _first_val(args[0]) == _first_val(args[1])
                return CellValue.NumberVal(value: if eq: 1.0 else: 0.0)
