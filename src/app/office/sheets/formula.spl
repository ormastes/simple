            # Serial day fraction (h*3600 + m*60 + s) / 86400, wrapped mod 1 day.
            if args.len() >= 3:
                val h = _first_val(args[0]).to_i64()
                val mi = _first_val(args[1]).to_i64()
                val se = _first_val(args[2]).to_i64()
                if h < 0 or mi < 0 or se < 0:
                    return CellValue.ErrorVal(message: "TIME requires non-negative parts")
                val total = (h * 3600 + mi * 60 + se) % 86400
                return CellValue.NumberVal(value: total.to_f64() / 86400.0)
            return CellValue.ErrorVal(message: "TIME requires hour, minute, second")
        "HOUR":
            if flat.len() > 0 and flat[0] >= 0.0:
                val ts = _time_total_seconds(flat[0])
                return CellValue.NumberVal(value: ((ts / 3600) % 24).to_f64())
            return CellValue.ErrorVal(message: "HOUR requires a non-negative serial")
        "MINUTE":
            if flat.len() > 0 and flat[0] >= 0.0:
                val ts = _time_total_seconds(flat[0])
                return CellValue.NumberVal(value: ((ts / 60) % 60).to_f64())
            return CellValue.ErrorVal(message: "MINUTE requires a non-negative serial")
        "SECOND":
            if flat.len() > 0 and flat[0] >= 0.0:
                val ts = _time_total_seconds(flat[0])
                return CellValue.NumberVal(value: (ts % 60).to_f64())
            return CellValue.ErrorVal(message: "SECOND requires a non-negative serial")
        "ISOWEEKNUM":
            # ISO-8601: the week number of the date's Thursday (Mon-start weeks).
            if flat.len() > 0:
                val sv = flat[0].to_i64()
                val wd = _iso_weekday(sv)
                val thu = sv - wd + 4
                val tc = _civil_from_serial(thu.to_f64())
                val ty = tc[0]
                val jan1 = _serial_from_civil(ty, 1, 1).to_i64()
                return CellValue.NumberVal(value: ((thu - jan1) / 7 + 1).to_f64())
            return CellValue.ErrorVal(message: "ISOWEEKNUM requires a serial")
        "DAYS360":
            if args.len() >= 2:
                val s1 = _first_val(args[0])
                val s2 = _first_val(args[1])
                var euro = false
                if args.len() >= 3:
                    euro = _first_val(args[2]) != 0.0
                if euro:
                    # European 30/360: both days clamped 31 -> 30 (= basis 4).
                    return CellValue.NumberVal(value: _daycount_num(s1, s2, 4))
                # US (NASD): start on last day of month (incl. Feb) -> 30;
                # end day 31 -> 30 only when adjusted start is 30.
                val c1 = _civil_from_serial(s1)
                val c2 = _civil_from_serial(s2)
                var d1 = c1[2]
                var d2 = c2[2]
                if d1 == _sec_days_in_month(c1[0], c1[1]):
                    d1 = 30
                if d2 == 31 and d1 == 30:
                    d2 = 30
                val days = 360 * (c2[0] - c1[0]) + 30 * (c2[1] - c1[1]) + (d2 - d1)
                return CellValue.NumberVal(value: days.to_f64())
            return CellValue.ErrorVal(message: "DAYS360 requires start, end")
        "YEARFRAC":
            # Thin wrapper over std.math.financial daycount_frac; Excel returns the absolute fraction.
            if args.len() >= 2:
                var s1 = _first_val(args[0])
                var s2 = _first_val(args[1])
                var basis: i64 = 0
                if args.len() >= 3:
                    basis = _first_val(args[2]).to_i64()
                if basis < 0 or basis > 4:
                    return CellValue.ErrorVal(message: "YEARFRAC basis must be 0..4")
                if s2 < s1:
                    val tmp = s1
                    s1 = s2
                    s2 = tmp
                return CellValue.NumberVal(value: daycount_frac(s1, s2, basis))
            return CellValue.ErrorVal(message: "YEARFRAC requires start, end")
        "NETWORKDAYS.INTL":
            # Weekend arg: numeric codes 1-7 (day pairs) and 11-17 (single day)
            # only; the "0000011" string mask form is not supported yet (the
            # numeric arg path coerces text to 0, which is rejected below).
            if args.len() >= 2:
                val s0 = _first_val(args[0]).to_i64()
                val e0 = _first_val(args[1]).to_i64()
                var wcode: i64 = 1
                if args.len() >= 3:
                    wcode = _first_val(args[2]).to_i64()
                if not ((wcode >= 1 and wcode <= 7) or (wcode >= 11 and wcode <= 17)):
                    return CellValue.ErrorVal(message: "NETWORKDAYS.INTL weekend must be 1-7 or 11-17")
                var hols: [f64] = []
                if args.len() >= 4:
                    hols = args[3]
                var lo = s0
                var hi = e0
                var sign = 1
                if e0 < s0:
                    lo = e0
                    hi = s0
                    sign = 0 - 1
                var count = 0
                var d = lo
                while d <= hi:
                    if not _intl_is_weekend(d, wcode):
                        var is_hol = false
                        var hj = 0
                        while hj < hols.len():
                            val hv = hols[hj]
                            if hv.to_i64() == d:
                                is_hol = true
                            hj = hj + 1
                        if not is_hol:
                            count = count + 1
                    d = d + 1
                return CellValue.NumberVal(value: (count * sign).to_f64())
            return CellValue.ErrorVal(message: "NETWORKDAYS.INTL requires start, end")
        "WORKDAY.INTL":
            # Same weekend-code subset as NETWORKDAYS.INTL (string mask deferred).
            if args.len() >= 2:
                var d = _first_val(args[0]).to_i64()
                val days = _first_val(args[1]).to_i64()
                var wcode: i64 = 1
                if args.len() >= 3:
                    wcode = _first_val(args[2]).to_i64()
                if not ((wcode >= 1 and wcode <= 7) or (wcode >= 11 and wcode <= 17)):
                    return CellValue.ErrorVal(message: "WORKDAY.INTL weekend must be 1-7 or 11-17")
                var hols: [f64] = []
                if args.len() >= 4:
                    hols = args[3]
                var remaining = if days < 0: 0 - days else: days
                val step = if days < 0: 0 - 1 else: 1
                while remaining > 0:
                    d = d + step
                    if not _intl_is_weekend(d, wcode):
                        var is_hol = false
                        var hj = 0
                        while hj < hols.len():
                            val hv = hols[hj]
                            if hv.to_i64() == d:
                                is_hol = true
                            hj = hj + 1
                        if not is_hol:
                            remaining = remaining - 1
                return CellValue.NumberVal(value: d.to_f64())
            return CellValue.ErrorVal(message: "WORKDAY.INTL requires start, days")
        "RAND":
            # Uniform [0, 1). Built on the i64 SFFI (the f64 SFFI returns 0.0
            # in this module context — probed).
            return CellValue.NumberVal(value: rt_random_randint(0, 999999999).to_f64() / 1000000000.0)
        "RANDBETWEEN":
            if args.len() >= 2:
                val lo = _first_val(args[0]).to_i64()
                val hi = _first_val(args[1]).to_i64()
                if hi < lo:
                    return CellValue.ErrorVal(message: "RANDBETWEEN requires bottom <= top")
                return CellValue.NumberVal(value: rt_random_randint(lo, hi).to_f64())
            return CellValue.ErrorVal(message: "RANDBETWEEN requires bottom, top")
        "PROB":
            if args.len() >= 3:
                val x_arr = args[0]
                val p_arr = args[1]
                val lower = _first_val(args[2])
                val upper = if args.len() >= 4: _first_val(args[3]) else: lower
                if x_arr.len() != p_arr.len():
                    return CellValue.ErrorVal(message: "PROB ranges must match")
                var p_sum = 0.0
                var p_match = 0.0
                var i = 0
                while i < x_arr.len():
                    val p = p_arr[i]
                    if p < 0.0 or p > 1.0:
                        return CellValue.ErrorVal(message: "PROB probabilities must be in [0,1]")
                    p_sum = p_sum + p
                    val x = x_arr[i]
                    if x >= lower and x <= upper:
                        p_match = p_match + p
                    i = i + 1
                val p_diff = if p_sum < 1.0: 1.0 - p_sum else: p_sum - 1.0
                if p_diff > 1e-9:
                    return CellValue.ErrorVal(message: "PROB probabilities must sum to 1")
                return CellValue.NumberVal(value: p_match)
            return CellValue.ErrorVal(message: "PROB requires 3+ arguments")
        "PERCENTOF":
            if args.len() >= 2:
                val subset_sum = eval_sum(args[0])
                val all_sum = eval_sum(args[1])
                if all_sum == 0.0:
                    return CellValue.ErrorVal(message: "PERCENTOF division by zero")
                return CellValue.NumberVal(value: subset_sum / all_sum)
            return CellValue.ErrorVal(message: "PERCENTOF requires 2 arguments")
        _:
            return CellValue.ErrorVal(message: "Unknown function: {name}")

# =========================================================================
# Dynamic Array Formulas (spill)
# =========================================================================
#
# SEQUENCE / TRANSPOSE / UNIQUE / SORT / FILTER evaluate to a 2D grid of
# display strings. `evaluate_formula_array` returns that grid (rows of
# columns); an empty result means the formula is NOT a dynamic-array formula
# and callers should fall back to the scalar `evaluate_formula` path. The
# recalc driver (file_formats.recalculate_formula_cells) writes the top-left
# value into the formula's own cell and spills the rest into the adjacent
# rectangle.

struct ArrNumArg:
    value: f64
    next_pos: i32
    present: bool

fn evaluate_formula_array(expr: text, sheet: Sheet) -> [[text]]:
    """Evaluate a dynamic-array formula to a 2D grid of display strings.

    Returns rows of column strings for SEQUENCE/TRANSPOSE/UNIQUE/SORT/FILTER.
    An empty outer list (len()==0) means the formula is not an array formula;
    the caller should use the scalar `evaluate_formula` path instead."""
    var formula = expr.trim()
    if formula.starts_with("="):
        formula = formula.substring(1)
    val tokens = tokenize_formula(formula)
    if tokens.len() < 2:
        return []
    val name = tokens.get(0).upper()
    if tokens.get(1) != "(":
        return []
    if name == "SEQUENCE":
        return _array_sequence(tokens, 2, sheet)
    if name == "TRANSPOSE":
        return _array_transpose(tokens, 2, sheet)
    if name == "UNIQUE":
        return _array_unique(tokens, 2, sheet)
    if name == "SORT":
        return _array_sort(tokens, 2, sheet)
    if name == "FILTER":
        return _array_filter(tokens, 2, sheet)
    if name == "CHOOSECOLS":
        return _array_choose_cols(tokens, 2, sheet)
    if name == "CHOOSEROWS":
        return _array_choose_rows(tokens, 2, sheet)
    if name == "TAKE":
        return _array_take(tokens, 2, sheet)
    if name == "DROP":
        return _array_drop(tokens, 2, sheet)
    if name == "VSTACK":
        return _array_vstack(tokens, 2, sheet)
    if name == "HSTACK":
        return _array_hstack(tokens, 2, sheet)
    if name == "TOCOL":
        return _array_tocol(tokens, 2, sheet)
    if name == "TOROW":
        return _array_torow(tokens, 2, sheet)
    if name == "TEXTSPLIT":
        return _array_textsplit(tokens, 2, sheet)
    if name == "MMULT":
        return _array_mmult(tokens, 2, sheet)
    if name == "MINVERSE":
        return _array_minverse(tokens, 2, sheet)
    if name == "MUNIT":
        return _array_munit(tokens, 2, sheet)
    if name == "MODE.MULT":
        return _array_mode_mult(tokens, 2, sheet)
    if name == "FREQUENCY":
        return _array_frequency(tokens, 2, sheet)
    if name == "LINEST":
        return _array_linest(tokens, 2, sheet)
    if name == "TREND":
        return _array_trend(tokens, 2, sheet)
    if name == "GROWTH":
        return _array_growth(tokens, 2, sheet)
    if name == "RANDARRAY":
        return _array_randarray(tokens, 2, sheet)
    if name == "SORTBY":
        return _array_sortby(tokens, 2, sheet)
    if name == "WRAPROWS":
        return _array_wraprows(tokens, 2, sheet)
    if name == "WRAPCOLS":
        return _array_wrapcols(tokens, 2, sheet)
    if name == "EXPAND":
        return _array_expand(tokens, 2, sheet)
    if name == "OFFSET":
        return _array_offset(tokens, 2, sheet)
    if name == "INDIRECT":
        return _array_indirect(tokens, 2, sheet)
    if name == "MAP":
        return _array_map(tokens, 2, sheet)
    if name == "SCAN":
        return _array_scan(tokens, 2, sheet)
    if name == "BYROW":
        return _array_byrow(tokens, 2, sheet)
    if name == "BYCOL":
        return _array_bycol(tokens, 2, sheet)
    if name == "MAKEARRAY":
        return _array_makearray(tokens, 2, sheet)
    if name == "GROUPBY":
        return _array_groupby(tokens, 2, sheet)
    if name == "PIVOTBY":
        return _array_pivotby(tokens, 2, sheet)
    []

fn _read_array_range_str(tokens: [text], pos: i32) -> text:
    """A range argument REF ':' REF starting at pos, or '' if not a range.
    Always spans exactly 3 tokens when present."""
    if (pos + 2 < tokens.len() and tokens.get(pos + 1) == ":" and
        _is_cell_ref_token(tokens.get(pos)) and _is_cell_ref_token(tokens.get(pos + 2))):
        return "{tokens.get(pos)}:{tokens.get(pos + 2)}"
    ""

fn _read_array_num_arg(tokens: [text], pos: i32, sheet: Sheet) -> ArrNumArg:
    """Read a numeric argument, or mark it absent at ')' / ',' / end."""
    if pos >= tokens.len() or tokens.get(pos) == ")" or tokens.get(pos) == ",":
        return ArrNumArg(value: 0.0, next_pos: pos, present: false)
    val r = _eval_comparison(tokens, pos, sheet, 0)
    ArrNumArg(value: _to_number(r.value), next_pos: r.next_pos, present: true)

struct ArrTextArg:
    value: text
    next_pos: i32
    present: bool

fn _read_fn_name_arg(tokens: [text], pos: i32) -> ArrTextArg:
    """Read a bare aggregate-function-name argument (SUM, AVERAGE, COUNT, MAX,
    MIN as an unquoted identifier token) or a quoted string naming the same.
    Unlike _read_array_text_arg this never evaluates the token as an
    expression -- a bare identifier like SUM has no defined value and would
    otherwise round-trip through the sheet's expression evaluator as #ERR."""
    if pos >= tokens.len() or tokens.get(pos) == ")" or tokens.get(pos) == ",":
        return ArrTextArg(value: "", next_pos: pos, present: false)
    val tok = tokens.get(pos)
    if tok.starts_with("\""):
        return ArrTextArg(value: tok.slice(1, tok.len() - 1), next_pos: pos + 1, present: true)
    ArrTextArg(value: tok, next_pos: pos + 1, present: true)

fn _read_array_text_arg(tokens: [text], pos: i32, sheet: Sheet) -> ArrTextArg:
    """Read a text argument as a display string: a quoted literal, a single cell
    ref, or an evaluated expression. Marks absent at ')' / ',' / end."""
    if pos >= tokens.len() or tokens.get(pos) == ")" or tokens.get(pos) == ",":
        return ArrTextArg(value: "", next_pos: pos, present: false)
    val tok = tokens.get(pos)
    val next_tok = if pos + 1 < tokens.len(): tokens.get(pos + 1) else: ""
    if tok.starts_with("\""):
        return ArrTextArg(value: tok.slice(1, tok.len() - 1), next_pos: pos + 1, present: true)
    if _is_cell_ref_token(tok) and (next_tok == "," or next_tok == ")"):
        return ArrTextArg(value: cell_display_text(sheet.get_cell(tok)), next_pos: pos + 1, present: true)
    val r = _eval_comparison(tokens, pos, sheet, 0)
    ArrTextArg(value: _cell_value_to_display(r.value), next_pos: r.next_pos, present: true)

fn _array_frequency(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """FREQUENCY(data_range, bins_range) -> a column of bins+1 counts that
    SPILLS: values <= bin_1, each (bin_i-1, bin_i], and finally values above
    the last bin. Bins are assumed ascending (unsorted bins are not
    re-ordered as Excel does); empty data cells resolve to 0 on this numeric
    range path."""
    val a_rs = _read_array_range_str(tokens, pos)
    if a_rs == "":
        return []
    val cur = _skip_comma(tokens, pos + 3)
    val b_rs = _read_array_range_str(tokens, cur)
    if b_rs == "":
        return []
    val data = _resolve_cell_range(a_rs, sheet, 0)
    val bins = _resolve_cell_range(b_rs, sheet, 0)
    val nbins = bins.len()
    if nbins == 0:
        return []
    var counts: [i64] = []
    var i = 0
    while i <= nbins:
        counts.push(0)
        i = i + 1
    for v in data:
        var idx = nbins
        var j = 0
        while j < nbins:
            val bj = bins[j]
            if idx == nbins and v <= bj:
                idx = j
            j = j + 1
        counts[idx] = counts[idx] + 1
    var out: [[text]] = []
    var k = 0
    while k <= nbins:
        val c = counts[k]
        out.push(["{c}"])
        k = k + 1
    out

fn _array_textsplit(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TEXTSPLIT(text, col_delim, [row_delim]) -> a 2D grid. The text is first
    split into rows by row_delim (when given), then each row into columns by
    col_delim. With no row_delim the result is a single row that spills across
    columns."""
    val a0 = _read_array_text_arg(tokens, pos, sheet)
    if not a0.present:
        return []
    var cur = _skip_comma(tokens, a0.next_pos)
    val a1 = _read_array_text_arg(tokens, cur, sheet)
    if not a1.present or a1.value == "":
        return []
    cur = _skip_comma(tokens, a1.next_pos)
    val a2 = _read_array_text_arg(tokens, cur, sheet)
    val src = a0.value
    val col_d = a1.value
    val has_row = a2.present and a2.value != ""
    var rows_src: [text] = []
    if has_row:
        rows_src = src.split(a2.value)
    else:
        rows_src.push(src)
    var out: [[text]] = []
    for r in rows_src:
        out.push(r.split(col_d))
    out

fn _array_offset(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """OFFSET(ref, rows, cols, height, width) — array form. Only a height or
    width > 1 makes OFFSET an array formula (the resulting rectangle SPILLS);
    every other case — height/width absent, both 1, out-of-domain values,
    negative target coordinates — returns [] so the scalar path either yields
    the single value or reports the precise #ERR."""
    if pos >= tokens.len() or not _is_cell_ref_token(tokens.get(pos)):
        return []
    val ref = parse_cell_ref(tokens.get(pos))
    if ref == nil:
        return []
    var cur = pos + 1
    # Range reference: use its top-left corner (Excel behavior).
    if (cur + 1 < tokens.len() and tokens.get(cur) == ":" and
        _is_cell_ref_token(tokens.get(cur + 1))):
        cur = cur + 2
    if cur >= tokens.len() or tokens.get(cur) != ",":
        return []
    val rr = _read_array_num_arg(tokens, cur + 1, sheet)
    if not rr.present:
        return []
    cur = _skip_comma(tokens, rr.next_pos)
    val cc = _read_array_num_arg(tokens, cur, sheet)
    if not cc.present:
        return []
    cur = _skip_comma(tokens, cc.next_pos)
    val hh = _read_array_num_arg(tokens, cur, sheet)
    if not hh.present:
        return []
    cur = _skip_comma(tokens, hh.next_pos)
    val ww = _read_array_num_arg(tokens, cur, sheet)
    val hi = hh.value.to_i64().to_i32()
    val wi = if ww.present: ww.value.to_i64().to_i32() else: 1
    if hi < 1 or wi < 1:
        return []
    if hi == 1 and wi == 1:
        return []
    val r0 = ref.row + rr.value.to_i64().to_i32()
    val c0 = ref.col + cc.value.to_i64().to_i32()
    if r0 < 0 or c0 < 0:
        return []
    val rng = CellRange(start: CellRef(col: c0, row: r0),
                        end_ref: CellRef(col: c0 + wi - 1, row: r0 + hi - 1))
    _array_range_grid(rng, sheet)

fn _array_indirect(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """INDIRECT(\"A1:B2\") — array form: a range-shaped reference string spills
    the referenced rectangle. Single-cell text (and anything unparseable)
    returns [] so the scalar path yields the value or the precise #ERR.
    R1C1 style is unsupported (A1 notation only)."""
    val a0 = _read_ref_text_arg(tokens, pos, sheet, 0)
    if not a0.present:
        return []
    val trimmed = a0.value.trim()
    if not trimmed.contains(":"):
        return []
    val rng = parse_range(trimmed)
    if rng == nil:
        return []
    _array_range_grid(rng, sheet)

fn _array_range_grid(range: CellRange, sheet: Sheet) -> [[text]]:
    """Read a range into a row-major grid of display strings."""
    var rows: [[text]] = []
    val min_col = if range.start.col < range.end_ref.col: range.start.col else: range.end_ref.col
    val max_col = if range.start.col > range.end_ref.col: range.start.col else: range.end_ref.col
    val min_row = if range.start.row < range.end_ref.row: range.start.row else: range.end_ref.row
    val max_row = if range.start.row > range.end_ref.row: range.start.row else: range.end_ref.row
    var r = min_row
    while r <= max_row:
        var row: [text] = []
        var c = min_col
        while c <= max_col:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            row.push(cell_display_text(sheet.get_cell(ref_str)))
            c = c + 1
        rows.push(row)
        r = r + 1
    rows

# =========================================================================
# MAP / SCAN / BYROW / BYCOL / MAKEARRAY (LAMBDA-driven array formulas)
# =========================================================================
#
# NOTE: never name a local `grid` or `unit` — both are broken/reserved
# identifiers in this interpreter (writing_calc_functions.md quirk #6); a
# later `.len()`/index off a var named `grid` corrupts the parse. Every
# range grid below is named `rgrid`/`agrid`/etc instead.

fn _byrow_fn_is_range_agg(name: text) -> bool:
    """Whitelist of single-range-arg aggregate functions a BYROW/BYCOL
    multi-cell row/column body may textually substitute into and dispatch
    through the normal evaluator (see _byrow_body_fn_name)."""
    (name == "SUM" or name == "AVERAGE" or name == "MAX" or name == "MIN" or
     name == "COUNT" or name == "MEDIAN" or name == "PRODUCT" or
     name == "STDEV" or name == "VAR")

fn _byrow_body_fn_name(tokens: [text], body_start: i32, end_pos: i32, pname: text) -> text:
    """The function name F when the body span is EXACTLY `F ( pname )`
    immediately closed by the LAMBDA's own ')' at end_pos-1 AND F is on the
    _byrow_fn_is_range_agg whitelist -- else '' (empty = unsupported
    shape). Bounds-guarded against a short/odd body."""
    if body_start + 4 != end_pos - 1:
        return ""
    if body_start + 3 >= tokens.len():
        return ""
    val open_tok = tokens.get(body_start + 1)
    val param_tok = tokens.get(body_start + 2)
    val close_tok = tokens.get(body_start + 3)
    if open_tok != "(" or close_tok != ")":
        return ""
    if param_tok.upper() != pname:
        return ""
    val fname = tokens.get(body_start).upper()
    if not _byrow_fn_is_range_agg(fname):
        return ""
    fname

fn _array_map(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MAP(range, LAMBDA(x, expr)) -> apply expr to each cell of range,
    preserving its shape (spills the same rows x cols as range). A
    non-LAMBDA 2nd argument or an unparseable range fails closed ([]),
    letting the scalar fallback report #ERR (Unknown function: MAP)."""
    val a_rs = _read_array_range_str(tokens, pos)
    if a_rs == "":
        return []
    var cur = _skip_comma(tokens, pos + 3)
    val lambda_tok = if cur < tokens.len(): tokens.get(cur) else: ""
    val lambda_upper = lambda_tok.upper()
    val after_lambda_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
    if not (lambda_upper == "LAMBDA" and after_lambda_tok == "("):
        return []
    val lam = _parse_lambda_literal(tokens, cur + 2, sheet)
    val lam_params = lam.params
    if not lam.ok or lam_params.len() != 1:
        return []
    val rng = parse_range(a_rs)
    if rng == nil:
        return []
    val rgrid = _array_range_grid(rng, sheet)
    val pname = lam_params[0]
    val lam_body_start = lam.body_start
    var out: [[text]] = []
    var r = 0
    while r < rgrid.len():
        val rrow = rgrid[r]
        var out_row: [text] = []
        var c = 0
        while c < rrow.len():
            _let_names.push(pname)
            _let_values.push(rrow[c])
            val body_result = _eval_concat(tokens, lam_body_start, sheet, 0)
            _let_names.pop()
            _let_values.pop()
            out_row.push(_cell_value_to_display(body_result.value))
            c = c + 1
        out.push(out_row)
        r = r + 1
    out

fn _array_scan(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """SCAN(initial, range, LAMBDA(acc, v, expr)) -> row-major running fold,
    spilling one intermediate accumulator value per cell of range (same
    shape as range). Fails closed ([]) on a malformed range or LAMBDA."""
    val init_result = _eval_comparison(tokens, pos, sheet, 0)
    var cur = _skip_comma(tokens, init_result.next_pos)
    val a_rs = _read_array_range_str(tokens, cur)
    if a_rs == "":
        return []
    cur = _skip_comma(tokens, cur + 3)
    val lambda_tok = if cur < tokens.len(): tokens.get(cur) else: ""
    val lambda_upper = lambda_tok.upper()
    val after_lambda_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
    if not (lambda_upper == "LAMBDA" and after_lambda_tok == "("):
        return []
    val lam = _parse_lambda_literal(tokens, cur + 2, sheet)
    val lam_params = lam.params
    if not lam.ok or lam_params.len() != 2:
        return []
    val rng = parse_range(a_rs)
    if rng == nil:
        return []
    val rgrid = _array_range_grid(rng, sheet)
    val acc_name = lam_params[0]
    val v_name = lam_params[1]
    val lam_body_start = lam.body_start
    var acc_disp = _cell_value_to_display(init_result.value)
    var out: [[text]] = []
    var r = 0
    while r < rgrid.len():
        val rrow = rgrid[r]
        var out_row: [text] = []
        var c = 0
        while c < rrow.len():
            _let_names.push(acc_name)
            _let_values.push(acc_disp)
            _let_names.push(v_name)
            _let_values.push(rrow[c])
            val body_result = _eval_concat(tokens, lam_body_start, sheet, 0)
            _let_names.pop()
            _let_values.pop()
            _let_names.pop()
            _let_values.pop()
            acc_disp = _cell_value_to_display(body_result.value)
            out_row.push(acc_disp)
            c = c + 1
        out.push(out_row)
        r = r + 1
    out

fn _array_byrow(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """BYROW(range, LAMBDA(r, expr)) -> one result per row, spilling a
    column. A single-cell row binds r to that cell's value and evaluates
    expr normally. A multi-cell row supports expr of the form F(r) for any
    single-range-arg function F on the _byrow_fn_is_range_agg whitelist
    (SUM/AVERAGE/MAX/MIN/COUNT/MEDIAN/PRODUCT/STDEV/VAR): r is substituted
    with the row's actual range reference (e.g. A2:C2) and the whole call
    is dispatched through the normal evaluator (_evaluate_formula) — no
    aggregate math is reimplemented here. Anything else on a multi-cell
    row fails closed ([]), since this evaluator has no array-valued LAMBDA
    parameter."""
    val a_rs = _read_array_range_str(tokens, pos)
    if a_rs == "":
        return []
    var cur = _skip_comma(tokens, pos + 3)
    val lambda_tok = if cur < tokens.len(): tokens.get(cur) else: ""
    val lambda_upper = lambda_tok.upper()
    val after_lambda_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
    if not (lambda_upper == "LAMBDA" and after_lambda_tok == "("):
        return []
    val lam = _parse_lambda_literal(tokens, cur + 2, sheet)
    val lam_params = lam.params
    if not lam.ok or lam_params.len() != 1:
        return []
    val rng = parse_range(a_rs)
    if rng == nil:
        return []
    val min_col = if rng.start.col < rng.end_ref.col: rng.start.col else: rng.end_ref.col
    val max_col = if rng.start.col > rng.end_ref.col: rng.start.col else: rng.end_ref.col
    val min_row = if rng.start.row < rng.end_ref.row: rng.start.row else: rng.end_ref.row
    val rgrid = _array_range_grid(rng, sheet)
    val pname = lam_params[0]
    val lam_body_start = lam.body_start
    val lam_end_pos = lam.end_pos
    val fn_name = _byrow_body_fn_name(tokens, lam_body_start, lam_end_pos, pname)
    var out: [[text]] = []
    var r = 0
    var failed = false
    while r < rgrid.len() and not failed:
        val rrow = rgrid[r]
        var cell_text = ""
        if rrow.len() == 1:
            _let_names.push(pname)
            _let_values.push(rrow[0])
            val body_result = _eval_concat(tokens, lam_body_start, sheet, 0)
            _let_names.pop()
            _let_values.pop()
            cell_text = _cell_value_to_display(body_result.value)
        elif fn_name != "":
            val sheet_row = min_row + r
            val row_start_ref = cell_ref_to_string(CellRef(col: min_col, row: sheet_row))
            val row_end_ref = cell_ref_to_string(CellRef(col: max_col, row: sheet_row))
            val body_value = _evaluate_formula("{fn_name}({row_start_ref}:{row_end_ref})", sheet, 0)
            cell_text = _cell_value_to_display(body_value)
        else:
            failed = true
        if not failed:
            out.push([cell_text])
        r = r + 1
    if failed:
        return []
    out

fn _array_bycol(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """BYCOL(range, LAMBDA(c, expr)) -> one result per column, spilling a
    row. Same ceiling as BYROW (see _byrow_body_fn_name), applied per
    column: c is substituted with the column's actual range reference and
    dispatched through the normal evaluator."""
    val a_rs = _read_array_range_str(tokens, pos)
    if a_rs == "":
        return []
    var cur = _skip_comma(tokens, pos + 3)
    val lambda_tok = if cur < tokens.len(): tokens.get(cur) else: ""
    val lambda_upper = lambda_tok.upper()
    val after_lambda_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
    if not (lambda_upper == "LAMBDA" and after_lambda_tok == "("):
        return []
    val lam = _parse_lambda_literal(tokens, cur + 2, sheet)
    val lam_params = lam.params
    if not lam.ok or lam_params.len() != 1:
        return []
    val rng = parse_range(a_rs)
    if rng == nil:
        return []
    val min_col = if rng.start.col < rng.end_ref.col: rng.start.col else: rng.end_ref.col
    val min_row = if rng.start.row < rng.end_ref.row: rng.start.row else: rng.end_ref.row
    val max_row = if rng.start.row > rng.end_ref.row: rng.start.row else: rng.end_ref.row
    val rgrid = _array_range_grid(rng, sheet)
    if rgrid.len() == 0:
        return []
    val pname = lam_params[0]
    val lam_body_start = lam.body_start
    val lam_end_pos = lam.end_pos
    val fn_name = _byrow_body_fn_name(tokens, lam_body_start, lam_end_pos, pname)
    val first_row = rgrid[0]
    val ncols = first_row.len()
    var out_row: [text] = []
    var c = 0
    var failed = false
    while c < ncols and not failed:
        var col_values: [text] = []
        var r = 0
        while r < rgrid.len():
            val rrow = rgrid[r]
            col_values.push(rrow[c])
            r = r + 1
        var cell_text = ""
        if col_values.len() == 1:
            _let_names.push(pname)
            _let_values.push(col_values[0])
            val body_result = _eval_concat(tokens, lam_body_start, sheet, 0)
            _let_names.pop()
            _let_values.pop()
            cell_text = _cell_value_to_display(body_result.value)
        elif fn_name != "":
            val sheet_col = min_col + c
            val col_start_ref = cell_ref_to_string(CellRef(col: sheet_col, row: min_row))
            val col_end_ref = cell_ref_to_string(CellRef(col: sheet_col, row: max_row))
            val body_value = _evaluate_formula("{fn_name}({col_start_ref}:{col_end_ref})", sheet, 0)
            cell_text = _cell_value_to_display(body_value)
        else:
            failed = true
        if not failed:
            out_row.push(cell_text)
        c = c + 1
    if failed:
        return []
    [out_row]

fn _array_makearray(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MAKEARRAY(rows, cols, LAMBDA(r, c, expr)) -> build a rows x cols
    grid, binding r and c as 1-based row/column indices for each cell.
    rows<1 or cols<1 fails closed ([]) -> scalar fallback reports #ERR."""
    val a0 = _read_array_num_arg(tokens, pos, sheet)
    if not a0.present:
        return []
    var cur = _skip_comma(tokens, a0.next_pos)
    val a1 = _read_array_num_arg(tokens, cur, sheet)
    if not a1.present:
        return []
    cur = _skip_comma(tokens, a1.next_pos)
    val lambda_tok = if cur < tokens.len(): tokens.get(cur) else: ""
    val lambda_upper = lambda_tok.upper()
    val after_lambda_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
    if not (lambda_upper == "LAMBDA" and after_lambda_tok == "("):
        return []
    val lam = _parse_lambda_literal(tokens, cur + 2, sheet)
    val lam_params = lam.params
    if not lam.ok or lam_params.len() != 2:
        return []
    val n_rows = a0.value.to_i64().to_i32()
    val n_cols = a1.value.to_i64().to_i32()
    if n_rows < 1 or n_cols < 1:
        return []
    val rname = lam_params[0]
    val cname = lam_params[1]
    val lam_body_start = lam.body_start
    var out: [[text]] = []
    var r = 1
    while r <= n_rows:
        var out_row: [text] = []
        var c = 1
        while c <= n_cols:
            _let_names.push(rname)
            _let_values.push("{r}")
            _let_names.push(cname)
            _let_values.push("{c}")
            val body_result = _eval_concat(tokens, lam_body_start, sheet, 0)
            _let_names.pop()
            _let_values.pop()
            _let_names.pop()
            _let_values.pop()
            out_row.push(_cell_value_to_display(body_result.value))
            c = c + 1
        out.push(out_row)
        r = r + 1
    out

fn _array_sequence(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """SEQUENCE(rows, [cols=1], [start=1], [step=1]) -> a rows x cols grid
    filled row-major with start + n*step."""
    val a0 = _read_array_num_arg(tokens, pos, sheet)
    if not a0.present:
        return []
    var cur = _skip_comma(tokens, a0.next_pos)
    val a1 = _read_array_num_arg(tokens, cur, sheet)
    if a1.present:
        cur = _skip_comma(tokens, a1.next_pos)
    val a2 = _read_array_num_arg(tokens, cur, sheet)
    if a2.present:
        cur = _skip_comma(tokens, a2.next_pos)
    val a3 = _read_array_num_arg(tokens, cur, sheet)
    val rows = a0.value.to_i64().to_i32()
    val cols = if a1.present: a1.value.to_i64().to_i32() else: 1
    val start = if a2.present: a2.value else: 1.0
    val step = if a3.present: a3.value else: 1.0
    if rows < 1 or cols < 1:
        return []
    var agrid: [[text]] = []
    var i = 0
    while i < rows:
        var row: [text] = []
        var j = 0
        while j < cols:
            val n = (i * cols + j).to_f64()
            row.push(_fmt_num_trim(start + n * step))
            j = j + 1
        agrid.push(row)
        i = i + 1
    agrid

fn _array_transpose(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TRANSPOSE(range) -> rows and columns swapped."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    val src = _array_range_grid(rng, sheet)
    if src.len() == 0:
        return []
    val nrows = src.len()
    val ncols = src[0].len()
    var out: [[text]] = []
    var j = 0
    while j < ncols:
        var row: [text] = []
        var i = 0
        while i < nrows:
            row.push(src[i][j])
            i = i + 1
        out.push(row)
        j = j + 1
    out

fn _array_row_key(row: [text]) -> text:
    """Join a row into a single comparison key (tab-separated)."""
    row.join("\t")

fn _array_contains(seen: [text], key: text) -> bool:
    for s in seen:
        if s == key:
            return true
    false

fn _array_unique(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """UNIQUE(range) -> distinct rows in first-seen order (single-column ranges
    reduce to the distinct list of values)."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    val src = _array_range_grid(rng, sheet)
    var out: [[text]] = []
    var seen: [text] = []
    for row in src:
        val key = _array_row_key(row)
        if not _array_contains(seen, key):
            seen.push(key)
            out.push(row)
    out

fn _arr_is_number(s: text) -> bool:
    """Whether a display string is a plain (optionally signed/decimal) number."""
    if s.len() == 0:
        return false
    var i = 0
    if s.char_at(0) == "-":
        if s.len() == 1:
            return false
        i = 1
    var has_digit = false
    var has_dot = false
    while i < s.len():
        val c = s.char_at(i)
        if c == ".":
            if has_dot:
                return false
            has_dot = true
        elif _is_digit(c):
            has_digit = true
        else:
            return false
        i = i + 1
    has_digit

fn _arr_text_lt(a: text, b: text) -> bool:
    """Lexicographic less-than by char code."""
    var i = 0
    while i < a.len() and i < b.len():
        val ca = a.char_code_at(i)
        val cb = b.char_code_at(i)
        if ca < cb:
            return true
        if ca > cb:
            return false
        i = i + 1
    a.len() < b.len()

fn _array_sort_less(a: [text], b: [text], kc: i32, ascending: bool) -> bool:
    """Whether row a sorts before row b on key column kc. Numeric compare when
    both keys are numeric, else lexicographic."""
    val av = if kc >= 0 and kc < a.len(): a[kc] else: ""
    val bv = if kc >= 0 and kc < b.len(): b[kc] else: ""
    val both_num = _arr_is_number(av) and _arr_is_number(bv)
    if ascending:
        if both_num:
            return av.to_f64() < bv.to_f64()
        return _arr_text_lt(av, bv)
    if both_num:
        return bv.to_f64() < av.to_f64()
    _arr_text_lt(bv, av)

fn _array_sort(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """SORT(range, [key_col=1], [ascending=TRUE]) -> rows ordered by key_col
    (1-based within the range). Stable insertion sort preserves ties."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    val src = _array_range_grid(rng, sheet)
    var cur = _skip_comma(tokens, pos + 3)
    val ka = _read_array_num_arg(tokens, cur, sheet)
    val key_col = if ka.present: ka.value.to_i64().to_i32() else: 1
    if ka.present:
        cur = _skip_comma(tokens, ka.next_pos)
    val asc_a = _read_array_num_arg(tokens, cur, sheet)
    val ascending = if asc_a.present: asc_a.value != 0.0 else: true
    val kc = key_col - 1
    var out: [[text]] = []
    for row in src:
        var inserted = false
        var result: [[text]] = []
        for existing in out:
            if not inserted and _array_sort_less(row, existing, kc, ascending):
                result.push(row)
                inserted = true
            result.push(existing)
        if not inserted:
            result.push(row)
        out = result
    out

fn _array_filter(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """FILTER(range, col_index, "criteria") -> rows whose cell in col_index
    (1-based within the range) matches the criteria.

    This is a pragmatic adaptation of Excel's boolean-array FILTER: instead of a
    parallel include-array, it reuses the COUNTIF-style criteria matcher
    (`_criteria_matches`) against one column of the source range. Returns a 1x1
    #CALC! grid when nothing matches, mirroring Excel's empty-filter error."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    var cur = _skip_comma(tokens, pos + 3)
    val col_a = _read_array_num_arg(tokens, cur, sheet)
    if not col_a.present:
        return []
    val col_index = col_a.value.to_i64().to_i32()
    cur = _skip_comma(tokens, col_a.next_pos)
    if cur >= tokens.len():
        return []
    var criteria = tokens.get(cur)
    if criteria.starts_with("\""):
        criteria = criteria.slice(1, criteria.len() - 1)
    val key_col = rng.start.col + col_index - 1
    var out: [[text]] = []
    var r = rng.start.row
    while r <= rng.end_ref.row:
        val key_ref = cell_ref_to_string(CellRef(col: key_col, row: r))
        val key_cell = sheet.get_cell(key_ref)
        val key_disp = cell_display_text(key_cell)
        val key_num = _to_number(key_cell.value)
        if _criteria_matches(key_disp, key_num, criteria):
            var row: [text] = []
            var c = rng.start.col
            while c <= rng.end_ref.col:
                val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
                row.push(cell_display_text(sheet.get_cell(ref_str)))
                c = c + 1
            out.push(row)
        r = r + 1
    if out.len() == 0:
        return [["#CALC!"]]
    out

fn _array_abs_i32(n: i32) -> i32:
    if n < 0:
        return 0 - n
    n

fn _array_collect_nums(tokens: [text], pos: i32, sheet: Sheet) -> [i32]:
    """Collect the trailing comma-separated scalar integer args (indices/counts)
    starting at pos, stopping at ')' or end. Empty tokens are skipped to keep
    the scan making progress."""
    var out: [i32] = []
    var cur = pos
    while cur < tokens.len() and tokens.get(cur) != ")":
        val a = _read_array_num_arg(tokens, cur, sheet)
        if a.present:
            out.push(a.value.to_i64().to_i32())
            cur = _skip_comma(tokens, a.next_pos)
        else:
            cur = _skip_comma(tokens, cur + 1)
    out

fn _array_read_grid(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """Read the leading range argument at pos into a row-major grid, or [] if
    the argument is not a range."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    _array_range_grid(rng, sheet)

fn _array_flatten_rowmajor(src2d: [[text]]) -> [text]:
    """Flatten a 2D grid into a single list, row by row (Excel row-major order)."""
    var out: [text] = []
    for row in src2d:
        for c in row:
            out.push(c)
    out

fn _array_mode_mult(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MODE.MULT(range) -> every value that repeats, in first-seen order, spilled
    down a single column. #ERR when no value repeats (Excel yields #N/A)."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val flat = _array_flatten_rowmajor(src)
    var nums: [f64] = []
    for s in flat:
        if _arr_is_number(s):
            nums.push(s.to_f64())
    if nums.len() == 0:
        return [["#ERR"]]
    var seen: [f64] = []
    var counts: [i32] = []
    for v in nums:
        var found = -1
        var i = 0
        while i < seen.len():
            val sv = seen[i]
            if sv == v:
                found = i
            i = i + 1
        if found >= 0:
            counts[found] = counts[found] + 1
        else:
            seen.push(v)
            counts.push(1)
    var out: [[text]] = []
    var j = 0
    while j < seen.len():
        if counts[j] >= 2:
            out.push([_fmt_num_trim(seen[j])])
        j = j + 1
    if out.len() == 0:
        return [["#ERR"]]
    out

fn _array_key_less(a: text, b: text, ascending: bool) -> bool:
    """Whether key a sorts before key b. Numeric compare when both numeric, else
    lexicographic. Ascending/descending controlled by the flag."""
    val both_num = _arr_is_number(a) and _arr_is_number(b)
    if ascending:
        if both_num:
            val an = a.to_f64()
            val bn = b.to_f64()
            return an < bn
        return _arr_text_lt(a, b)
    if both_num:
        val an2 = a.to_f64()
        val bn2 = b.to_f64()
        return bn2 < an2
    _arr_text_lt(b, a)

fn _array_sortby(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """SORTBY(range, by_range, [order]) -> rows of `range` reordered by the
    parallel single-column `by_range` keys (order 1=ascending default, -1=descending).
    Stable insertion sort preserves ties."""
    val rs = _read_array_range_str(tokens, pos)
    if rs == "":
        return []
    val rng = parse_range(rs)
    if rng == nil:
        return []
    val src = _array_range_grid(rng, sheet)
    var cur = _skip_comma(tokens, pos + 3)
    val brs = _read_array_range_str(tokens, cur)
    if brs == "":
        return []
    val brng = parse_range(brs)
    if brng == nil:
        return []
    val bgrid = _array_range_grid(brng, sheet)
    var keys: [text] = []
    for brow in bgrid:
        if brow.len() > 0:
            keys.push(brow[0])
        else:
            keys.push("")
    if keys.len() != src.len():
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val ord_a = _read_array_num_arg(tokens, cur, sheet)
    val ascending = if ord_a.present: ord_a.value >= 0.0 else: true
    var out_rows: [[text]] = []
    var out_keys: [text] = []
    var ri = 0
    while ri < src.len():
        val row = src[ri]
        val key = keys[ri]
        var inserted = false
        var res_rows: [[text]] = []
        var res_keys: [text] = []
        var k = 0
        while k < out_rows.len():
            val ek = out_keys[k]
            if not inserted and _array_key_less(key, ek, ascending):
                res_rows.push(row)
                res_keys.push(key)
                inserted = true
            res_rows.push(out_rows[k])
            res_keys.push(ek)
            k = k + 1
        if not inserted:
            res_rows.push(row)
            res_keys.push(key)
        out_rows = res_rows
        out_keys = res_keys
        ri = ri + 1
    out_rows

fn _array_wraprows(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """WRAPROWS(vector, count, [pad]) -> the flattened vector wrapped into rows of
    `count` columns, row by row; the final short row is right-padded with pad
    (default #N/A)."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val flat = _array_flatten_rowmajor(src)
    var cur = _skip_comma(tokens, pos + 3)
    val cnt_a = _read_array_num_arg(tokens, cur, sheet)
    if not cnt_a.present:
        return [["#ERR"]]
    val count = cnt_a.value.to_i64().to_i32()
    if count < 1:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cnt_a.next_pos)
    val pad_a = _read_array_text_arg(tokens, cur, sheet)
    val pad = if pad_a.present: pad_a.value else: "#N/A"
    var out: [[text]] = []
    var i = 0
    while i < flat.len():
        var row: [text] = []
        var j = 0
        while j < count:
            val idx = i + j
            if idx < flat.len():
                row.push(flat[idx])
            else:
                row.push(pad)
            j = j + 1
        out.push(row)
        i = i + count
    out

fn _array_wrapcols(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """WRAPCOLS(vector, count, [pad]) -> the flattened vector wrapped into columns
    of `count` rows, filling each column top-to-bottom; the final short column is
    bottom-padded with pad (default #N/A)."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val flat = _array_flatten_rowmajor(src)
    var cur = _skip_comma(tokens, pos + 3)
    val cnt_a = _read_array_num_arg(tokens, cur, sheet)
    if not cnt_a.present:
        return [["#ERR"]]
    val count = cnt_a.value.to_i64().to_i32()
    if count < 1:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cnt_a.next_pos)
    val pad_a = _read_array_text_arg(tokens, cur, sheet)
    val pad = if pad_a.present: pad_a.value else: "#N/A"
    val total = flat.len()
    var ncols = total / count
    if total % count != 0:
        ncols = ncols + 1
    var out: [[text]] = []
    var r = 0
    while r < count:
        var row: [text] = []
        var c = 0
        while c < ncols:
            val idx = c * count + r
            if idx < total:
                row.push(flat[idx])
            else:
                row.push(pad)
            c = c + 1
        out.push(row)
        r = r + 1
    out

fn _array_expand(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """EXPAND(range, rows, [cols], [pad]) -> the range grown to `rows` x `cols`,
    filling new cells with pad (default #N/A). Shrinking below the source size
    fails closed with #ERR."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val srows = src.len()
    val scols = src[0].len()
    var cur = _skip_comma(tokens, pos + 3)
    val rows_a = _read_array_num_arg(tokens, cur, sheet)
    if not rows_a.present:
        return [["#ERR"]]
    val nrows = rows_a.value.to_i64().to_i32()
    cur = _skip_comma(tokens, rows_a.next_pos)
    val cols_a = _read_array_num_arg(tokens, cur, sheet)
    val ncols = if cols_a.present: cols_a.value.to_i64().to_i32() else: scols
    if cols_a.present:
        cur = _skip_comma(tokens, cols_a.next_pos)
    val pad_a = _read_array_text_arg(tokens, cur, sheet)
    val pad = if pad_a.present: pad_a.value else: "#N/A"
    if nrows < srows or ncols < scols:
        return [["#ERR"]]
    var out: [[text]] = []
    var r = 0
    while r < nrows:
        var row: [text] = []
        var c = 0
        while c < ncols:
            if r < srows and c < scols:
                row.push(src[r][c])
            else:
                row.push(pad)
            c = c + 1
        out.push(row)
        r = r + 1
    out

fn _array_choose_cols(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """CHOOSECOLS(range, c1, [c2...]) -> the named columns in order (1-based;
    negative counts from the end). Out-of-range or index 0 -> #ERR."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val ncols = src[0].len()
    val want = _array_collect_nums(tokens, _skip_comma(tokens, pos + 3), sheet)
    if want.len() == 0:
        return [["#ERR"]]
    var idxs: [i32] = []
    for ci in want:
        var real = ci
        if real < 0:
            real = ncols + real + 1
        if real < 1 or real > ncols:
            return [["#ERR"]]
        idxs.push(real - 1)
    var out: [[text]] = []
    var r = 0
    while r < src.len():
        var row: [text] = []
        for ix in idxs:
            row.push(src[r][ix])
        out.push(row)
        r = r + 1
    out

fn _array_choose_rows(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """CHOOSEROWS(range, r1, [r2...]) -> the named rows in order (1-based;
    negative counts from the end). Out-of-range or index 0 -> #ERR."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val nrows = src.len()
    val want = _array_collect_nums(tokens, _skip_comma(tokens, pos + 3), sheet)
    if want.len() == 0:
        return [["#ERR"]]
    var out: [[text]] = []
    for ri in want:
        var real = ri
        if real < 0:
            real = nrows + real + 1
        if real < 1 or real > nrows:
            return [["#ERR"]]
        var row: [text] = []
        for c in src[real - 1]:
            row.push(c)
        out.push(row)
    out

fn _array_take(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TAKE(range, rows, [cols]) -> the first (or last, if negative) `rows` rows
    and, when given, `cols` columns. A 0 count or a count exceeding the size
    fails closed with #ERR; an omitted cols count keeps all columns."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val nrows = src.len()
    val ncols = src[0].len()
    val nums = _array_collect_nums(tokens, _skip_comma(tokens, pos + 3), sheet)
    if nums.len() == 0:
        return [["#ERR"]]
    val rn = nums[0]
    if rn == 0 or _array_abs_i32(rn) > nrows:
        return [["#ERR"]]
    val take_rows = _array_abs_i32(rn)
    val row_start = if rn > 0: 0 else: nrows - take_rows
    var col_start = 0
    var take_cols = ncols
    if nums.len() >= 2:
        val cn = nums[1]
        if cn == 0 or _array_abs_i32(cn) > ncols:
            return [["#ERR"]]
        take_cols = _array_abs_i32(cn)
        col_start = if cn > 0: 0 else: ncols - take_cols
    var out: [[text]] = []
    var r = row_start
    while r < row_start + take_rows:
        var row: [text] = []
        var c = col_start
        while c < col_start + take_cols:
            row.push(src[r][c])
            c = c + 1
        out.push(row)
        r = r + 1
    out

fn _array_drop(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """DROP(range, rows, [cols]) -> the range with the first (or last, if
    negative) `rows` rows and optional `cols` columns removed. A 0 count or a
    count that would remove everything fails closed with #ERR."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    val nrows = src.len()
    val ncols = src[0].len()
    val nums = _array_collect_nums(tokens, _skip_comma(tokens, pos + 3), sheet)
    if nums.len() == 0:
        return [["#ERR"]]
    val rn = nums[0]
    if rn == 0 or _array_abs_i32(rn) >= nrows:
        return [["#ERR"]]
    val drop_rows = _array_abs_i32(rn)
    val row_start = if rn > 0: drop_rows else: 0
    val row_end = if rn > 0: nrows else: nrows - drop_rows
    var col_start = 0
    var col_end = ncols
    if nums.len() >= 2:
        val cn = nums[1]
        if cn == 0 or _array_abs_i32(cn) >= ncols:
            return [["#ERR"]]
        val drop_cols = _array_abs_i32(cn)
        col_start = if cn > 0: drop_cols else: 0
        col_end = if cn > 0: ncols else: ncols - drop_cols
    var out: [[text]] = []
    var r = row_start
    while r < row_end:
        var row: [text] = []
        var c = col_start
        while c < col_end:
            row.push(src[r][c])
            c = c + 1
        out.push(row)
        r = r + 1
    out

fn _array_stack_grids(tokens: [text], pos: i32, sheet: Sheet) -> [[[text]]]:
    """Read the variadic range/cell arguments of VSTACK/HSTACK into a list of
    grids, in order."""
    var grids: [[[text]]] = []
    var cur = pos
    while cur < tokens.len() and tokens.get(cur) != ")":
        val rs = _read_array_range_str(tokens, cur)
        if rs != "":
            val rng = parse_range(rs)
            if rng != nil:
                grids.push(_array_range_grid(rng, sheet))
            cur = _skip_comma(tokens, cur + 3)
        else:
            val tok = tokens.get(cur)
            val next_tok = if cur + 1 < tokens.len(): tokens.get(cur + 1) else: ""
            if _is_cell_ref_token(tok) and (next_tok == "," or next_tok == ")"):
                grids.push([[cell_display_text(sheet.get_cell(tok))]])
                cur = _skip_comma(tokens, cur + 1)
            else:
                cur = _skip_comma(tokens, cur + 1)
    grids

fn _array_vstack(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """VSTACK(range1, range2, ...) -> the grids stacked top-to-bottom. Ragged
    widths are right-padded with #N/A to the widest row (Excel semantics)."""
    val grids = _array_stack_grids(tokens, pos, sheet)
    var maxw = 0
    for g in grids:
        for row in g:
            if row.len() > maxw:
                maxw = row.len()
    if maxw == 0:
        return [["#ERR"]]
    var out: [[text]] = []
    for g in grids:
        for row in g:
            var padded: [text] = []
            for c in row:
                padded.push(c)
            while padded.len() < maxw:
                padded.push("#N/A")
            out.push(padded)
    out

fn _array_hstack(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """HSTACK(range1, range2, ...) -> the grids placed side-by-side. Ragged
    heights are bottom-padded with #N/A to the tallest grid (Excel semantics)."""
    val grids = _array_stack_grids(tokens, pos, sheet)
    var maxh = 0
    for g in grids:
        if g.len() > maxh:
            maxh = g.len()
    if maxh == 0:
        return [["#ERR"]]
    var out: [[text]] = []
    var r = 0
    while r < maxh:
        var row: [text] = []
        for g in grids:
            var w = 0
            if g.len() > 0:
                w = g[0].len()
            if r < g.len():
                for c in g[r]:
                    row.push(c)
            else:
                var k = 0
                while k < w:
                    row.push("#N/A")
                    k = k + 1
        out.push(row)
        r = r + 1
    out

fn _array_tocol(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TOCOL(range) -> the range flattened row-major into a single column."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    var out: [[text]] = []
    for row in src:
        for c in row:
            out.push([c])
    if out.len() == 0:
        return [["#ERR"]]
    out

fn _array_torow(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TOROW(range) -> the range flattened row-major into a single row."""
    val src = _array_read_grid(tokens, pos, sheet)
    if src.len() == 0:
        return []
    var row: [text] = []
    for r in src:
        for c in r:
            row.push(c)
    if row.len() == 0:
        return [["#ERR"]]
    [row]

# =========================================================================
# Matrix functions (MMULT / MINVERSE / MUNIT / MDETERM)
# =========================================================================

# The matrix operations keep every numeric array as a LOCAL flat [f64] indexed
# as row*cols+col. This avoids two interpreter limitations proven during
# development: (1) indexing/iterating a `[[text]]` PARAMETER misparses, and
# (2) variable-indexing an array passed as a parameter reads 0. So each function
# reads its range into a local grid, flattens into local arrays, and does all
# math inline on locals — no struct or array parameters cross a call boundary.

fn _mat_abs(v: f64) -> f64:
    if v < 0.0:
        return 0.0 - v
    v

fn _mat_snap(v: f64) -> f64:
    """Round to 1e-9 so LU/Gauss-Jordan round-off (e.g. 0.6000000001) prints as
    the clean value; integer results become exact so `general` formatting trims
    them to integer form."""
    var scaled = v * 1000000000.0
    if scaled < 0.0:
        scaled = scaled - 0.5
    else:
        scaled = scaled + 0.5
    scaled.to_i64().to_f64() / 1000000000.0

fn _eval_mdeterm(tokens: [text], pos: i32, sheet: Sheet) -> EvalResult:
    """MDETERM(range) -> determinant of a square range via LU decomposition with
    partial pivoting (det = signed product of pivots; a zero pivot column means
    the matrix is singular, det = 0). Scalar result routed through the raw-range
    path so the 2D shape survives the flattened scalar-arg path."""
    val cells = _array_read_grid(tokens, pos, sheet)
    var np = pos
    while np < tokens.len() and tokens.get(np) != ")":
        np = np + 1
    if np < tokens.len():
        np = np + 1
    val nrows = cells.len()
    if nrows == 0:
        return EvalResult(value: CellValue.ErrorVal(message: "MDETERM requires a range"), next_pos: np)
    var ncols = 0
    for grow in cells:
        ncols = grow.len()
    if ncols != nrows:
        return EvalResult(value: CellValue.ErrorVal(message: "MDETERM requires a square matrix"), next_pos: np)
    val n = nrows
    var d: [f64] = []
    for grow2 in cells:
        for gcell in grow2:
            d.push(gcell.to_f64())
    var det = 1.0
    var i = 0
    while i < n:
        var piv = i
        var maxv = _mat_abs(d[i * n + i])
        var r = i + 1
        while r < n:
            val v = _mat_abs(d[r * n + i])
            if v > maxv:
                maxv = v
                piv = r
            r = r + 1
        if maxv == 0.0:
            return EvalResult(value: CellValue.NumberVal(value: 0.0), next_pos: np)
        if piv != i:
            var c = 0
            while c < n:
                val tmp = d[i * n + c]
                d[i * n + c] = d[piv * n + c]
                d[piv * n + c] = tmp
                c = c + 1
            det = 0.0 - det
        val pivot = d[i * n + i]
        det = det * pivot
        var rr = i + 1
        while rr < n:
            val factor = d[rr * n + i] / pivot
            var cc = i
            while cc < n:
                d[rr * n + cc] = d[rr * n + cc] - factor * d[i * n + cc]
                cc = cc + 1
            rr = rr + 1
        i = i + 1
    EvalResult(value: CellValue.NumberVal(value: _mat_snap(det)), next_pos: np)

fn _array_mmult(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MMULT(range1, range2) -> matrix product. cols(A) must equal rows(B),
    else a 1x1 #ERR grid."""
    val g1 = _array_read_grid(tokens, pos, sheet)
    if g1.len() == 0:
        return []
    val g2 = _array_read_grid(tokens, pos + 4, sheet)
    if g2.len() == 0:
        return [["#ERR"]]
    val arows = g1.len()
    var acols = 0
    for r1 in g1:
        acols = r1.len()
    var af: [f64] = []
    for r1b in g1:
        for c1 in r1b:
            af.push(c1.to_f64())
    val brows = g2.len()
    var bcols = 0
    for r2 in g2:
        bcols = r2.len()
    var bf: [f64] = []
    for r2b in g2:
        for c2 in r2b:
            bf.push(c2.to_f64())
    if acols != brows or acols == 0:
        return [["#ERR"]]
    var out: [[text]] = []
    var i = 0
    while i < arows:
        var row: [text] = []
        var j = 0
        while j < bcols:
            var s = 0.0
            var k = 0
            while k < acols:
                s = s + af[i * acols + k] * bf[k * bcols + j]
                k = k + 1
            row.push(_fmt_num_trim(_mat_snap(s)))
            j = j + 1
        out.push(row)
        i = i + 1
    out

fn _array_minverse(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MINVERSE(range) -> inverse via Gauss-Jordan elimination on [A|I] with
    partial pivoting; a singular matrix yields a 1x1 #ERR grid."""
    val g = _array_read_grid(tokens, pos, sheet)
    if g.len() == 0:
        return []
    val n = g.len()
    var ncols = 0
    for grow in g:
        ncols = grow.len()
    if ncols != n:
        return [["#ERR"]]
    val w = 2 * n
    # Build the augmented [A|I] as a local flat n x 2n array.
    var a: [f64] = []
    var rb = 0
    for grow2 in g:
        var cb = 0
        for gcell in grow2:
            a.push(gcell.to_f64())
            cb = cb + 1
        var ci = 0
        while ci < n:
            if ci == rb:
                a.push(1.0)
            else:
                a.push(0.0)
            ci = ci + 1
        rb = rb + 1
    var i = 0
    while i < n:
        var piv = i
        var maxv = _mat_abs(a[i * w + i])
        var rr = i + 1
        while rr < n:
            val v = _mat_abs(a[rr * w + i])
            if v > maxv:
                maxv = v
                piv = rr
            rr = rr + 1
        if maxv == 0.0:
            return [["#ERR"]]
        if piv != i:
            var c = 0
            while c < w:
                val tmp = a[i * w + c]
                a[i * w + c] = a[piv * w + c]
                a[piv * w + c] = tmp
                c = c + 1
        val pv = a[i * w + i]
        var cn = 0
        while cn < w:
            a[i * w + cn] = a[i * w + cn] / pv
            cn = cn + 1
        var er = 0
        while er < n:
            if er != i:
                val f = a[er * w + i]
                var ec = 0
                while ec < w:
                    a[er * w + ec] = a[er * w + ec] - f * a[i * w + ec]
                    ec = ec + 1
            er = er + 1
        i = i + 1
    var out: [[text]] = []
    var ro = 0
    while ro < n:
        var row: [text] = []
        var co = n
        while co < w:
            row.push(_fmt_num_trim(_mat_snap(a[ro * w + co])))
            co = co + 1
        out.push(row)
        ro = ro + 1
    out

fn _array_munit(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """MUNIT(n) -> the n x n identity matrix."""
    val a0 = _read_array_num_arg(tokens, pos, sheet)
    if not a0.present:
        return []
    val n = a0.value.to_i64().to_i32()
    if n < 1:
        return [["#ERR"]]
    var out: [[text]] = []
    var r = 0
    while r < n:
        var row: [text] = []
        var c = 0
        while c < n:
            if c == r:
                row.push("1")
            else:
                row.push("0")
            c = c + 1
        out.push(row)
        r = r + 1
    out

fn _array_linest(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """LINEST(known_ys, [known_xs], [const], [stats]) -> spills horizontally.

    Computes least-squares linear regression: y = slope*x + intercept.
    known_xs defaults to 1,2,...,n if omitted. `const` is accepted and
    skipped (this engine's fit always includes an intercept). When `stats`
    is TRUE/nonzero, spills the full 3-row form (2 columns):
      [slope, intercept]
      [se_slope, se_intercept]
      [r2, se_y]
    where se_y = STEYX, r2 = RSQ, se_slope = se_y/sqrt(DEVSQ(xs)),
    se_intercept = se_y*sqrt(1/n + x̄²/DEVSQ(xs)). Omitting stats (or the
    2-arg form) keeps the original single-row [slope, intercept] output.
    Returns [["#ERR"]] on error (mismatched lengths, n<2, zero x-variance)."""
    val yrs = _read_array_range_str(tokens, pos)
    if yrs == "":
        return [["#ERR"]]
    val ys = _resolve_cell_range(yrs, sheet, 0)
    var cur = _skip_comma(tokens, pos + 3)
    val xrs = _read_array_range_str(tokens, cur)
    var xs: [f64] = []
    if xrs != "":
        xs = _resolve_cell_range(xrs, sheet, 0)
        cur = cur + 3
    else:
        var i = 1
        while i <= ys.len():
            xs.push(i.to_f64())
            i = i + 1
    if xs.len() != ys.len():
        return [["#ERR"]]
    val fit = linfit(ys, xs)
    if fit[0] == 0.0 and fit[1] == 0.0 and ys.len() < 2:
        return [["#ERR"]]

    # Optional trailing const, stats args (both booleans in Excel).
    cur = _skip_comma(tokens, cur)
    if cur < tokens.len() and tokens.get(cur) != ")":
        val const_result = _eval_comparison(tokens, cur, sheet, 0)
        cur = const_result.next_pos
    cur = _skip_comma(tokens, cur)
    var stats_requested = false
    if cur < tokens.len() and tokens.get(cur) != ")":
        val stats_result = _eval_comparison(tokens, cur, sheet, 0)
        stats_requested = _to_number(stats_result.value) != 0.0

    if stats_requested:
        val dxs = devsq(xs)
        if dxs == 0.0:
            return [["#ERR"]]
        val se_y = steyx(ys, xs)
        val r2 = rsq(ys, xs)
        val se_slope = se_y / sqrt_f64(dxs)
        val xbar = mean(xs)
        val n = xs.len().to_f64()
        val se_intercept = se_y * sqrt_f64(1.0 / n + (xbar * xbar) / dxs)
        return [["{fit[0]}", "{fit[1]}"], ["{se_slope}", "{se_intercept}"], ["{r2}", "{se_y}"]]
    [["{fit[0]}", "{fit[1]}"]]

fn _array_trend(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """TREND(known_ys, [known_xs], [new_xs]) -> predicted values via linear fit.

    Fits y = slope*x + intercept using LINEST, then predicts at new_xs.
    known_xs defaults to 1,2,...,n if omitted.
    new_xs defaults to known_xs range if omitted, or can be a scalar/range.
    Returns [["#ERR"]] on error (fit failed), or a row of predicted values."""
    val yrs = _read_array_range_str(tokens, pos)
    if yrs == "":
        return [["#ERR"]]
    val ys = _resolve_cell_range(yrs, sheet, 0)
    var cur = _skip_comma(tokens, pos + 3)
    val xrs = _read_array_range_str(tokens, cur)
    var xs: [f64] = []
    if xrs != "":
        xs = _resolve_cell_range(xrs, sheet, 0)
    else:
        var i = 1
        while i <= ys.len():
            xs.push(i.to_f64())
            i = i + 1
    if xs.len() != ys.len():
        return [["#ERR"]]
    val fit = linfit(ys, xs)
    if fit[0] == 0.0 and fit[1] == 0.0 and ys.len() < 2:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val nxrs = _read_array_range_str(tokens, cur)
    var newxs: [f64] = []
    if nxrs != "":
        newxs = _resolve_cell_range(nxrs, sheet, 0)
    else:
        if cur < tokens.len() and tokens.get(cur) != ")" and tokens.get(cur) != ",":
            val nx_arg = _read_array_num_arg(tokens, cur, sheet)
            if nx_arg.present:
                newxs.push(nx_arg.value)
            else:
                newxs = xs
        else:
            newxs = xs
    var out_row: [text] = []
    var i = 0
    while i < newxs.len():
        val y_pred = fit[0] * newxs[i] + fit[1]
        out_row.push("{y_pred}")
        i = i + 1
    [out_row]

fn _array_growth(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """GROWTH(known_ys, [known_xs], [new_xs]) -> exponential predictions.

    Fits ln(y) = slope*x + intercept, then predicts exp(slope*x + intercept).
    All y must be > 0. Returns [["#ERR"]] on error or a row of predicted values."""
    val yrs = _read_array_range_str(tokens, pos)
    if yrs == "":
        return [["#ERR"]]
    val ys = _resolve_cell_range(yrs, sheet, 0)
    var i = 0
    while i < ys.len():
        if ys[i] <= 0.0:
            return [["#ERR"]]
        i = i + 1
    var log_ys: [f64] = []
    var j = 0
    while j < ys.len():
        log_ys.push(ln_f64(ys[j]))
        j = j + 1
    var cur = _skip_comma(tokens, pos + 3)
    val xrs = _read_array_range_str(tokens, cur)
    var xs: [f64] = []
    if xrs != "":
        xs = _resolve_cell_range(xrs, sheet, 0)
    else:
        var k = 1
        while k <= ys.len():
            xs.push(k.to_f64())
            k = k + 1
    if xs.len() != ys.len():
        return [["#ERR"]]
    val fit = linfit(log_ys, xs)
    if fit[0] == 0.0 and fit[1] == 0.0 and ys.len() < 2:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val nxrs = _read_array_range_str(tokens, cur)
    var newxs: [f64] = []
    if nxrs != "":
        newxs = _resolve_cell_range(nxrs, sheet, 0)
    else:
        if cur < tokens.len() and tokens.get(cur) != ")" and tokens.get(cur) != ",":
            val nx_arg = _read_array_num_arg(tokens, cur, sheet)
            if nx_arg.present:
                newxs.push(nx_arg.value)
            else:
                newxs = xs
        else:
            newxs = xs
    var out_row: [text] = []
    var m = 0
    while m < newxs.len():
        val log_y_pred = fit[0] * newxs[m] + fit[1]
        val y_pred = exp_f64(log_y_pred)
        out_row.push("{y_pred}")
        m = m + 1
    [out_row]

fn _array_randarray(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """RANDARRAY([rows], [cols], [min], [max], [integer]) -> random array.

    Defaults: rows=1, cols=1, min=0, max=1, integer=FALSE.
    Returns [["#ERR"]] on error (rows<1, cols<1, min>max)."""
    var cur = pos
    val rows_a = _read_array_num_arg(tokens, cur, sheet)
    var rows = 1
    if rows_a.present:
        rows = rows_a.value.to_i64().to_i32()
        cur = rows_a.next_pos
    if rows < 1:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur)
    val cols_a = _read_array_num_arg(tokens, cur, sheet)
    var cols = 1
    if cols_a.present:
        cols = cols_a.value.to_i64().to_i32()
        cur = cols_a.next_pos
    if cols < 1:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur)
    val min_a = _read_array_num_arg(tokens, cur, sheet)
    var min_val = 0.0
    if min_a.present:
        min_val = min_a.value
        cur = min_a.next_pos
    cur = _skip_comma(tokens, cur)
    val max_a = _read_array_num_arg(tokens, cur, sheet)
    var max_val = 1.0
    if max_a.present:
        max_val = max_a.value
        cur = max_a.next_pos
    if min_val > max_val:
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur)
    val int_a = _read_array_text_arg(tokens, cur, sheet)
    var is_integer = false
    if int_a.present:
        is_integer = int_a.value.upper() == "TRUE" or int_a.value == "1"
    var out: [[text]] = []
    var r = 0
    while r < rows:
        var row: [text] = []
        var c = 0
        while c < cols:
            val raw = rt_random_randint(0, 999999999).to_f64() / 1000000000.0
            val scaled = min_val + raw * (max_val - min_val)
            val val_final = if is_integer: _floor_f64(scaled) else: scaled
            row.push("{val_final}")
            c = c + 1
        out.push(row)
        r = r + 1
    out

# =========================================================================
# Cell Resolution
# =========================================================================

fn resolve_cell_value(ref_str: text, sheet: Sheet) -> f64:
    """Get the numeric value of a cell. Returns 0.0 if cell is empty or non-numeric."""
    _resolve_cell_value(ref_str, sheet, 0)

fn _resolve_cell_value(ref_str: text, sheet: Sheet, depth: i32) -> f64:
    if depth > MAX_EVAL_DEPTH:
        return 0.0
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return 1.0
            return 0.0
        CellValue.FormulaVal(expr, cached_display):
            # Array-registered functions (SEQUENCE/MMULT/TEXTSPLIT/...) have
            # no scalar handler, so scalar re-evaluation of a spill-origin
            # cell would yield 0. Reuse evaluate_formula_array's own
            # recognition — a non-empty grid means the head function is in
            # the array registry — and prefer the numeric parse of the
            # cached spill display written by the two-phase recalc. For
            # OFFSET/INDIRECT (on both paths) the cached origin display
            # equals the scalar top-left value, so this stays consistent.
            if cached_display != "":
                val agrid = evaluate_formula_array(expr, sheet)
                if agrid.len() > 0:
                    return cached_display.to_f64()
            # Recursively evaluate the formula, carrying depth so a circular
            # reference is caught instead of overflowing the stack.
            val result = _evaluate_formula(expr, sheet, depth + 1)
            return _to_number(result)
        _:
            return 0.0

fn resolve_cell_range(range_str: text, sheet: Sheet) -> [f64]:
    """Get all numeric values from cells in a range."""
    _resolve_cell_range(range_str, sheet, 0)

fn _resolve_cell_range(range_str: text, sheet: Sheet, depth: i32) -> [f64]:
    var values: [f64] = []
    val range = parse_range(range_str)
    if range == nil:
        return values
    val refs = expand_range_refs(range)
    for ref_str in refs:
        val v = _resolve_cell_value(ref_str, sheet, depth + 1)
        values.push(v)
    values

fn resolve_cell_display_i64(ref_str: text, sheet: Sheet) -> DisplayEvalResult:
    """Resolve a cell to an integer value for display-oriented formula checks."""
    _resolve_cell_display_i64(ref_str, sheet, 0)

fn _resolve_cell_display_i64(ref_str: text, sheet: Sheet, depth: i32) -> DisplayEvalResult:
    if depth > MAX_EVAL_DEPTH:
        return DisplayEvalResult(ok: false, value: 0)
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return DisplayEvalResult(ok: true, value: value.to_i64())
        CellValue.TextVal(value):
            return _parse_i64_text(value)
        CellValue.BoolVal(value):
            if value:
                return DisplayEvalResult(ok: true, value: 1)
            return DisplayEvalResult(ok: true, value: 0)
        CellValue.FormulaVal(expr, cached_display):
            if cached_display != "":
                return _parse_i64_text(cached_display)
            val text_value = _evaluate_formula_display_text(expr, sheet, depth + 1)
            return _parse_i64_text(text_value)
        _:
            return DisplayEvalResult(ok: false, value: 0)

# =========================================================================
# Aggregation Functions
# =========================================================================

fn eval_sum(values: [f64]) -> f64:
    """Sum all values."""
    var total = 0.0
    for v in values:
        total = total + v
    total

fn eval_product(values: [f64]) -> f64:
    """Multiply all values. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var total = 1.0
    for v in values:
        total = total * v
    total

fn eval_average(values: [f64]) -> f64:
    """Average of all values. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    val total = eval_sum(values)
    total / values.len().to_f64()

fn eval_count(values: [f64]) -> f64:
    """Count of values."""
    values.len().to_f64()

fn eval_min(values: [f64]) -> f64:
    """Minimum value. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var result = values[0]
    for v in values:
        if v < result:
            result = v
    result

fn eval_max(values: [f64]) -> f64:
    """Maximum value. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var result = values[0]
    for v in values:
        if v > result:
            result = v
    result

# =========================================================================
# Internal Helpers
# =========================================================================

fn _to_number(cv: CellValue) -> f64:
    """Extract numeric value from a CellValue. Non-numeric values return 0.0."""
    match cv:
        CellValue.NumberVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return 1.0
            return 0.0
        _:
            return 0.0

fn _cell_value_to_display(cv: CellValue) -> text:
    """Render a CellValue as a display string for concatenation."""
    match cv:
        CellValue.NumberVal(value):
            return _format_number(value)
        CellValue.TextVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return "TRUE"
            return "FALSE"
        CellValue.ErrorVal(message):
            return "#ERR"
        _:
            return ""

fn _format_number(v: f64) -> text:
    """Format a number, dropping the decimal when the value is integral."""
    val iv = v.to_i64()
    val iv_f = iv.to_f64()
    if iv_f == v:
        return "{iv}"
    "{v}"

fn _round_half_away(v: f64, factor: f64) -> f64:
    """Round v to the given power-of-ten factor, half away from zero."""
    val scaled = v * factor
    var rounded_scaled = 0.0
    if scaled >= 0.0:
        rounded_scaled = (scaled + 0.5).to_i64().to_f64()
    else:
        rounded_scaled = (scaled - 0.5).to_i64().to_f64()
    rounded_scaled / factor

fn _floor_f64(x: f64) -> f64:
    """Largest integer <= x."""
    val t = x.to_i64().to_f64()
    if t > x:
        return t - 1.0
    t

fn _ceil_f64(x: f64) -> f64:
    """Smallest integer >= x."""
    val t = x.to_i64().to_f64()
    if t < x:
        return t + 1.0
    t

fn _is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

fn _is_alpha(c: text) -> bool:
    val code = c.char_code_at(0)
    val is_upper = code >= 65 and code <= 90
    val is_lower = code >= 97 and code <= 122
    is_upper or is_lower

fn _is_cell_ref_token(token: text) -> bool:
    """Check if a token looks like a cell reference (letters followed by digits)."""
    if token.len() == 0:
        return false
    if not _is_alpha(token.char_at(0)):
        return false
    var has_digit = false
    var i = 0
    while i < token.len():
        val c = token.char_at(i)
        if _is_digit(c):
            has_digit = true
        i = i + 1
    has_digit

fn _pow_f64(base: f64, exp: f64) -> f64:
    """Simple power function for non-negative integer exponents."""
    val int_exp = exp.to_i64()
    if int_exp == 0:
        return 1.0
    var result = 1.0
    var neg = false
    var e = int_exp
    if e < 0:
        neg = true
        e = 0 - e
    var i: i64 = 0
    while i < e:
        result = result * base
        i = i + 1
    if neg:
        return 1.0 / result
    result

fn _pow10_f64(exp: i64) -> f64:
    """Calculate 10^exp for small exponents."""
    var result = 1.0
    var i: i64 = 0
    var e = exp
    if e < 0:
        e = 0 - e
    while i < e:
        result = result * 10.0
        i = i + 1
    if exp < 0:
        return 1.0 / result
    result

fn _flatten_args(args: [[f64]]) -> [f64]:
    """Flatten a list of float lists into a single flat list."""
    var result: [f64] = []
    for group in args:
        for v in group:
            result.push(v)
    result

fn _first_val(vals: [f64]) -> f64:
    """Get the first value from a float list, or 0.0 if empty."""
    if vals.len() > 0:
        return vals[0]
    0.0

fn _fin_pmt(rate: f64, nper: f64, pv: f64, fv: f64, typ: f64) -> f64:
    """Excel PMT closed form including future value and annuity-due (type) term."""
    if rate == 0.0:
        return 0.0 - (pv + fv) / nper
    val g = _pow_f64(1.0 + rate, nper)
    0.0 - (rate * (pv * g + fv)) / ((1.0 + rate * typ) * (g - 1.0))

fn _fin_fv_bal(rate: f64, n: f64, pmt: f64, pv: f64, typ: f64) -> f64:
    """Future value / outstanding balance after n periods (money-sign convention)."""
    if rate == 0.0:
        return 0.0 - (pv + pmt * n)
    val g = _pow_f64(1.0 + rate, n)
    0.0 - (pv * g + pmt * (1.0 + rate * typ) * (g - 1.0) / rate)

fn _fin_ipmt(rate: f64, per: f64, nper: f64, pv: f64, fv: f64, typ: f64) -> f64:
    """Interest portion of the payment for period `per`.

    Interest = (balance after per-1 payments) * rate; the annuity-due case
    discounts the first period back by (1 + rate).
    """
    val pmt = _fin_pmt(rate, nper, pv, fv, typ)
    val bal = _fin_fv_bal(rate, per - 1.0, pmt, pv, typ)
    var ip = bal * rate
    if typ == 1.0:
        ip = ip / (1.0 + rate)
    ip

fn _fin_db(cost: f64, salvage: f64, life: f64, period: f64) -> f64:
    """Fixed-declining-balance depreciation for `period`.

    Excel rounds the rate = 1 - (salvage/cost)^(1/life) to three decimals.
    No month argument is supported here: the first year is assumed full (no
    partial-period proration), matching a DB(...) call with month omitted.
    """
    val ratio = salvage / cost
    val raw_rate = 1.0 - powf(ratio, 1.0 / life)
    val rate = _round_half_away(raw_rate, 1000.0)
    var book = cost
    var dep = 0.0
    var i = 1.0
    while i <= period:
        dep = book * rate
        book = book - dep
        i = i + 1.0
    dep

fn _fin_ddb(cost: f64, salvage: f64, life: f64, period: f64) -> f64:
    """Double-declining-balance depreciation for `period`.

    Uses factor 2/life and clamps each period's depreciation so book value
    never falls below salvage.
    """
    val factor = 2.0 / life
    var book = cost
    var dep = 0.0
    var i = 1.0
    while i <= period:
        dep = book * factor
        if book - dep < salvage:
            dep = book - salvage
            if dep < 0.0:
                dep = 0.0
        book = book - dep
        i = i + 1.0
    dep

fn _fin_rate(nper: f64, pmt: f64, pv: f64, fv: f64) -> FinSolve:
    """Solve the annuity rate via Newton's method (guess 0.1, 100 iterations).

    Fails closed (ok = false) when the iteration diverges or fails to converge,
    which surfaces as #ERR at the call site.
    """
    var r = 0.1
    var i = 0
    while i < 100:
        val f = _fin_rate_f(r, nper, pmt, pv, fv)
        val h = 0.000001
        val f2 = _fin_rate_f(r + h, nper, pmt, pv, fv)
        val d = (f2 - f) / h
        if d == 0.0:
            return FinSolve(ok: false, value: 0.0)
        val rn = r - f / d
        var diff = rn - r
        if diff < 0.0:
            diff = 0.0 - diff
        if diff < 0.000000001:
            return FinSolve(ok: true, value: rn)
        r = rn
        i = i + 1
    FinSolve(ok: false, value: 0.0)

fn _fin_rate_f(r: f64, nper: f64, pmt: f64, pv: f64, fv: f64) -> f64:
    """Residual of the annuity equation at rate r (type 0)."""
    if r == 0.0:
        return pv + pmt * nper + fv
    val g = _pow_f64(1.0 + r, nper)
    pv * g + pmt * (g - 1.0) / r + fv

fn _fin_npv_at(r: f64, flows: [f64]) -> f64:
    """NPV of undiscounted-period-0 cashflows at rate r."""
    var s = 0.0
    var i = 0
    while i < flows.len():
        s = s + flows[i] / _pow_f64(1.0 + r, i.to_f64())
        i = i + 1
    s

fn _fin_irr(flows: [f64], guess: f64) -> FinSolve:
    """Internal rate of return via Newton's method with a bisection fallback."""
    var r = guess
    var i = 0
    while i < 100:
        val f = _fin_npv_at(r, flows)
        var d = 0.0
        var k = 1
        while k < flows.len():
            d = d - k.to_f64() * flows[k] / _pow_f64(1.0 + r, (k + 1).to_f64())
            k = k + 1
        if d == 0.0:
            i = 100
        else:
            val rn = r - f / d
            var diff = rn - r
            if diff < 0.0:
                diff = 0.0 - diff
            if diff < 0.000000001:
                return FinSolve(ok: true, value: rn)
            r = rn
            i = i + 1
    # Bisection fallback over a bracketed rate range.
    var lo = -0.999999
    var hi = 10.0
    var flo = _fin_npv_at(lo, flows)
    var j = 0
    while j < 200:
        val mid = (lo + hi) / 2.0
        val fm = _fin_npv_at(mid, flows)
        var afm = fm
        if afm < 0.0:
            afm = 0.0 - afm
        if afm < 0.000000001:
            return FinSolve(ok: true, value: mid)
        val same = (flo < 0.0) == (fm < 0.0)
        if same:
            lo = mid
            flo = fm
        else:
            hi = mid
        j = j + 1
    FinSolve(ok: false, value: 0.0)

fn _fin_mirr(flows: [f64], fin_rate: f64, rei_rate: f64) -> FinSolve:
    """Modified IRR: finance negative flows at fin_rate, reinvest positives at rei_rate."""
    val n = flows.len()
    if n < 2:
        return FinSolve(ok: false, value: 0.0)
    var pv_neg = 0.0
    var fv_pos = 0.0
    var i = 0
    while i < n:
        val cf = flows[i]
        if cf < 0.0:
            pv_neg = pv_neg + cf / _pow_f64(1.0 + fin_rate, i.to_f64())
        else:
            fv_pos = fv_pos + cf * _pow_f64(1.0 + rei_rate, (n - 1 - i).to_f64())
        i = i + 1
    if pv_neg == 0.0:
        return FinSolve(ok: false, value: 0.0)
    val ratio = fv_pos / (0.0 - pv_neg)
    if ratio <= 0.0:
        return FinSolve(ok: false, value: 0.0)
    FinSolve(ok: true, value: powf(ratio, 1.0 / (n - 1).to_f64()) - 1.0)

fn _is_nonneg_int(v: f64) -> bool:
    """True when v is a whole number >= 0 (Excel bitwise-op domain)."""
    v >= 0.0 and v == v.to_i64().to_f64()

fn _pow2_i64(exp: i64) -> i64:
    """2^exp for exp >= 0."""
    var result: i64 = 1
    var i: i64 = 0
    while i < exp:
        result = result * 2
        i = i + 1
    result

fn _bit_op(a_in: i64, b_in: i64, kind: i32) -> i64:
    """Bitwise op on two non-negative integers. kind: 0=AND, 1=OR, 2=XOR."""
    var a = a_in
    var b = b_in
    var result: i64 = 0
    var place: i64 = 1
    while a > 0 or b > 0:
        val abit = a % 2
        val bbit = b % 2
        var rbit: i64 = 0
        if kind == 0:
            rbit = if abit == 1 and bbit == 1: 1 else: 0
        elif kind == 1:
            rbit = if abit == 1 or bbit == 1: 1 else: 0
        else:
            rbit = if abit != bbit: 1 else: 0
        result = result + rbit * place
        place = place * 2
        a = a / 2
        b = b / 2
    result

fn _is_weekday(serial: i64) -> bool:
    """True when the Excel serial falls Mon..Fri (WEEKDAY 2..6, Sunday=1)."""
    var wd = serial % 7
    if wd < 0:
        wd = wd + 7
    if wd == 0:
        wd = 7
    wd >= 2 and wd <= 6

fn _iso_weekday(serial: i64) -> i64:
    """ISO weekday Mon=1..Sun=7. serial - 25569 = days since 1970-01-01 (a Thursday)."""
    val days = serial - 25569
    ((days % 7) + 10) % 7 + 1

fn _intl_is_weekend(serial: i64, wcode: i64) -> bool:
    """NETWORKDAYS.INTL/WORKDAY.INTL weekend test for numeric codes.

    1..7 = consecutive day pairs starting Sat/Sun (1) through Fri/Sat (7);
    11..17 = single days Sunday (11) through Saturday (17)."""
    val wd = _iso_weekday(serial)
    if wcode >= 1 and wcode <= 7:
        val first = (wcode + 4) % 7 + 1
        val second = first % 7 + 1
        return wd == first or wd == second
    if wcode >= 11 and wcode <= 17:
        val single = (wcode - 5) % 7 + 1
        return wd == single
    false

fn _time_total_seconds(serial: f64) -> i64:
    """Seconds-of-day from a non-negative serial's fraction, rounded to the
    nearest second (Excel HOUR/MINUTE/SECOND behavior), wrapped mod 86400."""
    val frac = serial - serial.to_i64().to_f64()
    (frac * 86400.0 + 0.5).to_i64() % 86400

fn _eval_display_sum(tokens: [text], sheet: Sheet, depth: i32) -> DisplayEvalResult:
    var total: i64 = 0
    var op = "+"
    var expecting_value = true
    for token in tokens:
        if token == "+" or token == "-":
            if expecting_value:
                return DisplayEvalResult(ok: false, value: 0)
            op = token
            expecting_value = true
            continue
        val value = _display_token_i64(token, sheet, depth)
        if not value.ok:
            return DisplayEvalResult(ok: false, value: 0)
        if op == "-":
            total = total - value.value
        else:
            total = total + value.value
        expecting_value = false
    if expecting_value:
        return DisplayEvalResult(ok: false, value: 0)
    DisplayEvalResult(ok: true, value: total)

fn _display_token_i64(token: text, sheet: Sheet, depth: i32) -> DisplayEvalResult:
    if token.len() == 0:
        return DisplayEvalResult(ok: false, value: 0)
    val upper_token = token.upper()
    if parse_cell_ref(upper_token) != nil:
        return _resolve_cell_display_i64(upper_token, sheet, depth)
    _parse_i64_text(token)

fn _parse_i64_text(s: text) -> DisplayEvalResult:
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return DisplayEvalResult(ok: false, value: 0)
    var negative = false
    var i = 0
    if trimmed.char_at(0) == "-":
        negative = true
        i = 1
        if trimmed.len() == 1:
            return DisplayEvalResult(ok: false, value: 0)
    var value: i64 = 0
    while i < trimmed.len():
        val c = trimmed.char_at(i)
        if not _is_digit(c):
            return DisplayEvalResult(ok: false, value: 0)
        value = value * 10 + (c.char_code_at(0) - 48).to_i64()
        i = i + 1
    if negative:
        return DisplayEvalResult(ok: true, value: 0 - value)
    DisplayEvalResult(ok: true, value: value)

fn _agg_apply(fname: text, vals: [f64]) -> f64:
    """Apply one of the GROUPBY/PIVOTBY aggregate functions to a flat value
    list. Caller must have already validated fname is one of the five
    supported names; unsupported names fall through to 0.0."""
    if fname == "SUM":
        return eval_sum(vals)
    if fname == "AVERAGE":
        return eval_average(vals)
    if fname == "COUNT":
        return vals.len().to_f64()
    if fname == "MAX":
        return eval_max(vals)
    if fname == "MIN":
        return eval_min(vals)
    0.0

fn _is_supported_agg_fn(fname: text) -> bool:
    """True for the five GROUPBY/PIVOTBY aggregate function names."""
    (fname == "SUM" or fname == "AVERAGE" or fname == "COUNT" or
     fname == "MAX" or fname == "MIN")

fn _array_groupby(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """GROUPBY(row_fields, values, function_name) -> groups rows by key,
    aggregates values per group, spills [key, aggregate] rows + [Total, grand_total]."""
    val row_fields_src = _array_read_grid(tokens, pos, sheet)
    if row_fields_src.len() == 0:
        return [["#ERR"]]
    var row_keys: [text] = []
    for r in row_fields_src:
        if r.len() > 0:
            row_keys.push(r[0])
        else:
            row_keys.push("")
    var cur = _skip_comma(tokens, pos + 3)
    val values_src = _array_read_grid(tokens, cur, sheet)
    if values_src.len() == 0:
        return [["#ERR"]]
    var values: [f64] = []
    for r in values_src:
        if r.len() > 0:
            val v = r[0]
            if _arr_is_number(v):
                values.push(v.to_f64())
            else:
                values.push(0.0)
        else:
            values.push(0.0)
    if values.len() != row_keys.len():
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val fname_a = _read_fn_name_arg(tokens, cur)
    if not fname_a.present:
        return [["#ERR"]]
    val fname_txt = fname_a.value
    val fname = fname_txt.upper()
    var unique_keys: [text] = []
    var key_indices: [[i32]] = []
    var ki = 0
    while ki < row_keys.len():
        val key = row_keys[ki]
        var found_idx = -1
        var uki = 0
        while uki < unique_keys.len():
            if unique_keys[uki] == key:
                found_idx = uki
            uki = uki + 1
        if found_idx >= 0:
            key_indices[found_idx].push(ki)
        else:
            unique_keys.push(key)
            var new_indices: [i32] = []
            new_indices.push(ki)
            key_indices.push(new_indices)
        ki = ki + 1
    if not _is_supported_agg_fn(fname):
        return [["#ERR"]]
    var aggregates: [f64] = []
    var uki = 0
    while uki < unique_keys.len():
        val indices = key_indices[uki]
        var agg_values: [f64] = []
        for idx in indices:
            agg_values.push(values[idx])
        val agg = _agg_apply(fname, agg_values)
        aggregates.push(agg)
        uki = uki + 1
    val aggregate_sum = _agg_apply(fname, values)
    var out: [[text]] = []
    var ri = 0
    while ri < unique_keys.len():
        val key = unique_keys[ri]
        val agg = aggregates[ri]
        out.push([key, _fmt_num_trim(agg)])
        ri = ri + 1
    out.push(["Total", _fmt_num_trim(aggregate_sum)])
    out

fn _array_pivotby(tokens: [text], pos: i32, sheet: Sheet) -> [[text]]:
    """PIVOTBY(row_fields, col_fields, values, function_name) -> pivot table grid
    with row totals, column totals, and grand total."""
    val row_fields_src = _array_read_grid(tokens, pos, sheet)
    if row_fields_src.len() == 0:
        return [["#ERR"]]
    var row_keys: [text] = []
    for r in row_fields_src:
        if r.len() > 0:
            row_keys.push(r[0])
        else:
            row_keys.push("")
    var cur = _skip_comma(tokens, pos + 3)
    val col_fields_src = _array_read_grid(tokens, cur, sheet)
    if col_fields_src.len() == 0:
        return [["#ERR"]]
    var col_keys: [text] = []
    for r in col_fields_src:
        if r.len() > 0:
            col_keys.push(r[0])
        else:
            col_keys.push("")
    if col_keys.len() != row_keys.len():
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val values_src = _array_read_grid(tokens, cur, sheet)
    if values_src.len() == 0:
        return [["#ERR"]]
    var values: [f64] = []
    for r in values_src:
        if r.len() > 0:
            val v = r[0]
            if _arr_is_number(v):
                values.push(v.to_f64())
            else:
                values.push(0.0)
        else:
            values.push(0.0)
    if values.len() != row_keys.len():
        return [["#ERR"]]
    cur = _skip_comma(tokens, cur + 3)
    val fname_a = _read_fn_name_arg(tokens, cur)
    if not fname_a.present:
        return [["#ERR"]]
    val fname_txt = fname_a.value
    val fname = fname_txt.upper()
    if not _is_supported_agg_fn(fname):
        return [["#ERR"]]
    var unique_rows: [text] = []
    var unique_cols: [text] = []
    var i = 0
    while i < row_keys.len():
        val rk = row_keys[i]
        var found = false
        for ur in unique_rows:
            if ur == rk:
                found = true
        if not found:
            unique_rows.push(rk)
        val ck = col_keys[i]
        var found_c = false
        for uc in unique_cols:
            if uc == ck:
                found_c = true
        if not found_c:
            unique_cols.push(ck)
        i = i + 1
    var nrows = unique_rows.len()
    var ncols = unique_cols.len()
    var pgrid: [[f64]] = []
    var ri = 0
    while ri < nrows:
        val rk = unique_rows[ri]
        var row: [f64] = []
        var ci = 0
        while ci < ncols:
            val ck = unique_cols[ci]
            var cell_values: [f64] = []
            var ii = 0
            while ii < row_keys.len():
                if row_keys[ii] == rk and col_keys[ii] == ck:
                    cell_values.push(values[ii])
                ii = ii + 1
            row.push(_agg_apply(fname, cell_values))
            ci = ci + 1
        pgrid.push(row)
        ri = ri + 1
    # No header row: the spill origin must never cache an empty display (an
    # empty cached_display makes cell_display_text fall back to the raw
    # formula text), so the grid starts directly at the first row key.
    var out: [[text]] = []
    var rri = 0
    while rri < nrows:
        val rk = unique_rows[rri]
        var row_out: [text] = []
        row_out.push(rk)
        var cci = 0
        while cci < ncols:
            row_out.push(_fmt_num_trim(pgrid[rri][cci]))
            cci = cci + 1
        var row_values: [f64] = []
        var jj = 0
        while jj < row_keys.len():
            if row_keys[jj] == rk:
                row_values.push(values[jj])
            jj = jj + 1
        row_out.push(_fmt_num_trim(_agg_apply(fname, row_values)))
        out.push(row_out)
        rri = rri + 1
    var totals: [text] = []
    totals.push("Total")
    var cii = 0
    while cii < ncols:
        val ck = unique_cols[cii]
        var col_values: [f64] = []
        var kk = 0
        while kk < col_keys.len():
            if col_keys[kk] == ck:
                col_values.push(values[kk])
            kk = kk + 1
        totals.push(_fmt_num_trim(_agg_apply(fname, col_values)))
        cii = cii + 1
    totals.push(_fmt_num_trim(_agg_apply(fname, values)))
    out.push(totals)
    out
# =========================================================================
# FORECAST.ETS seasonal decomposition helpers
# =========================================================================

fn _forecast_ets_decompose(values: [f64], timeline: [f64], seasonality: i32) -> [f64]:
    """Seasonal decomposition: fit linear trend, extract seasonal offsets.
    Returns [slope, intercept, offset_0, offset_1, ..., offset_(s-1)].
    On error, returns empty list.

    Trend fit: when there are >= 2 complete non-overlapping blocks of
    `seasonality` consecutive points, OLS is fit on PER-BLOCK AVERAGES
    (block mean x, block mean y) rather than raw points. A single-pass OLS
    on raw points is contaminated by an exact periodic signal whenever the
    data isn't symmetric about the window center (e.g. 5,9,5,9,... over
    x=1..8 has a spurious positive slope under raw OLS even though the
    series has zero trend) -- averaging over complete cycles first cancels
    the periodic component before the trend line is fit. Falls back to
    plain point-wise OLS when seasonality == 1 or there aren't enough whole
    blocks."""
    if values.len() != timeline.len() or values.len() < 2 or seasonality < 1:
        return []

    val n = values.len()
    val nblocks = n / seasonality

    var slope = 0.0
    var intercept = 0.0

    if seasonality >= 2 and nblocks >= 2:
        var bsum_x = 0.0
        var bsum_y = 0.0
        var bsum_xx = 0.0
        var bsum_xy = 0.0
        var b = 0
        while b < nblocks:
            var block_sum_x = 0.0
            var block_sum_y = 0.0
            var bi = 0
            while bi < seasonality:
                val idx = b * seasonality + bi
                block_sum_x = block_sum_x + timeline[idx]
                block_sum_y = block_sum_y + values[idx]
                bi = bi + 1
            val bx = block_sum_x / seasonality.to_f64()
            val by = block_sum_y / seasonality.to_f64()
            bsum_x = bsum_x + bx
            bsum_y = bsum_y + by
            bsum_xx = bsum_xx + bx * bx
            bsum_xy = bsum_xy + bx * by
            b = b + 1
        val bn = nblocks.to_f64()
        val bmean_x = bsum_x / bn
        val bmean_y = bsum_y / bn
        val bvar_x = bsum_xx / bn - bmean_x * bmean_x
        slope = if bvar_x == 0.0: 0.0 else: (bsum_xy / bn - bmean_x * bmean_y) / bvar_x
        intercept = bmean_y - slope * bmean_x
    else:
        var sum_x = 0.0
        var sum_y = 0.0
        var sum_xx = 0.0
        var sum_xy = 0.0
        var i = 0
        while i < n:
            val x = timeline[i]
            val y = values[i]
            sum_x = sum_x + x
            sum_y = sum_y + y
            sum_xx = sum_xx + x * x
            sum_xy = sum_xy + x * y
            i = i + 1

        val mean_x = sum_x / n.to_f64()
        val mean_y = sum_y / n.to_f64()
        val var_x = sum_xx / n.to_f64() - mean_x * mean_x

        slope = if var_x == 0.0: 0.0 else: (sum_xy / n.to_f64() - mean_x * mean_y) / var_x
        intercept = mean_y - slope * mean_x

    # Extract seasonal offsets: mean residual per phase
    var offsets: [f64] = []
    var offset_sum: [f64] = []
    var offset_count: [i64] = []
    var j = 0
    while j < seasonality:
        offsets.push(0.0)
        offset_sum.push(0.0)
        offset_count.push(0)
        j = j + 1

    var k = 0
    while k < n:
        val trend = intercept + slope * timeline[k]
        val residual = values[k] - trend
        val phase = k.to_i64() % seasonality.to_i64()
        offset_sum[phase.to_i32()] = offset_sum[phase.to_i32()] + residual
        offset_count[phase.to_i32()] = offset_count[phase.to_i32()] + 1
        k = k + 1

    var m = 0
    while m < seasonality:
        if offset_count[m] > 0:
            offsets[m] = offset_sum[m] / offset_count[m].to_f64()
        m = m + 1

    var result: [f64] = [slope, intercept]
    var n_off = 0
    while n_off < offsets.len():
        result.push(offsets[n_off])
        n_off = n_off + 1
    result

fn _forecast_ets_seasonality_strength(values: [f64], timeline: [f64], seasonality: i32) -> f64:
    """Seasonal strength: fraction of detrended-residual variance explained by
    the phase means: 1 - var(residual - phase_mean) / var(residual).
    Range [0, 1]; threshold 0.5 for significance.

    NOTE: an earlier version compared seasonal_var / (seasonal_var +
    residual_var), which double-counts the seasonal component in the
    denominator (residual_var already INCLUDES the seasonal variance) and
    under-scores clean periodic data (e.g. 5,9,5,9,... over x=1..8 scored
    ~0.49, just under the 0.5 detection threshold, instead of the correct
    1.0 for a noise-free periodic series)."""
    if values.len() != timeline.len() or values.len() < 2 * seasonality or seasonality < 2:
        return 0.0

    val decomp = _forecast_ets_decompose(values, timeline, seasonality)
    if decomp.len() < 2 + seasonality:
        return 0.0

    val slope = decomp[0]
    val intercept = decomp[1]
    var offsets: [f64] = []
    var idx = 2
    while idx < decomp.len():
        offsets.push(decomp[idx])
        idx = idx + 1

    # residual_sum_sq: total variance after removing only the trend.
    # noise_sum_sq: variance left after ALSO removing the seasonal offset —
    # this is the "unexplained" part.
    var residual_sum_sq = 0.0
    var noise_sum_sq = 0.0
    var n = values.len()
    var i = 0
    while i < n:
        val trend = intercept + slope * timeline[i]
        val residual = values[i] - trend
        residual_sum_sq = residual_sum_sq + residual * residual
        val phase = i.to_i64() % seasonality.to_i64()
        val noise = residual - offsets[phase.to_i32()]
        noise_sum_sq = noise_sum_sq + noise * noise
        i = i + 1

    if residual_sum_sq == 0.0:
        return 0.0

    1.0 - noise_sum_sq / residual_sum_sq

# =========================================================================
# GETPIVOTDATA — read values from rendered pivot tables
# =========================================================================

fn _eval_getpivotdata(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """GETPIVOTDATA(data_field, pivot_anchor_ref, [field1, item1, field2, item2, ...])

    Reads values from a pivot table rendered at pivot_anchor_ref (the top-left cell).
    No field/item pairs → grand total. One pair → row or column total. Two pairs → intersection.
    Parses field/item names from sheet display text (no direct pivot module coupling).
    Returns the numeric value as a CellValue or #ERR."""
    var cur_pos = pos

    # Parse data_field (first text argument)
    if cur_pos >= tokens.len() or tokens.get(cur_pos) == ")":
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA requires data_field"), next_pos: cur_pos)
    var data_field = ""
    val first_token = tokens.get(cur_pos)
    if _is_cell_ref_token(first_token):
        val data_val = _resolve_cell_value(first_token, sheet, depth)
        data_field = _format_number(data_val)
    elif first_token.starts_with("\""):
        # String literal tokens keep their surrounding quotes ("East" ->
        # the 6-char token `"East"`, see tokenize_formula) -- strip them so
        # comparisons against plain sheet text (e.g. pivot_grid cells) match.
        data_field = first_token.substring(1, first_token.len() - 1)
    else:
        data_field = first_token
    cur_pos = cur_pos + 1
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
        cur_pos = cur_pos + 1

    # Parse pivot_anchor_ref (cell reference)
    if cur_pos >= tokens.len() or not _is_cell_ref_token(tokens.get(cur_pos)):
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA requires pivot_anchor_ref"), next_pos: cur_pos)
    val pivot_ref_str = tokens.get(cur_pos)
    val pivot_anchor = parse_cell_ref(pivot_ref_str)
    if pivot_anchor == nil:
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA bad pivot_anchor_ref"), next_pos: cur_pos)
    cur_pos = cur_pos + 1
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
        cur_pos = cur_pos + 1

    # Parse field/item pairs
    var field_items: [text] = []
    while cur_pos < tokens.len() and tokens.get(cur_pos) != ")":
        # Parse field name (text or ref)
        if cur_pos >= tokens.len():
            return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA incomplete field/item pair"), next_pos: cur_pos)
        var field_str = ""
        val ft = tokens.get(cur_pos)
        if _is_cell_ref_token(ft):
            field_str = _format_number(_resolve_cell_value(ft, sheet, depth))
        elif ft.starts_with("\""):
            field_str = ft.substring(1, ft.len() - 1)
        else:
            field_str = ft
        cur_pos = cur_pos + 1
        if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
            cur_pos = cur_pos + 1

        # Parse item name (text or ref)
        if cur_pos >= tokens.len():
            return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA incomplete field/item pair"), next_pos: cur_pos)
        var item_str = ""
        val it = tokens.get(cur_pos)
        if _is_cell_ref_token(it):
            item_str = _format_number(_resolve_cell_value(it, sheet, depth))
        elif it.starts_with("\""):
            item_str = it.substring(1, it.len() - 1)
        else:
            item_str = it
        cur_pos = cur_pos + 1
        if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
            cur_pos = cur_pos + 1

        field_items.push(field_str)
        field_items.push(item_str)

    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1

    # Read the pivot grid from the sheet (starting at pivot_anchor).
    #
    # Two passes: (1) find the table's true bounds (max_row/max_col) by
    # scanning for non-empty cells, stopping after 5 consecutive fully-empty
    # rows/cols past the last content seen; (2) re-read the grid strictly
    # within those bounds. A single-pass version that pushed every scanned
    # cell (including trailing blanks) into row_data produced ragged rows
    # padded to ~100 columns wide whenever a row had ANY content (the
    # "has_content" flag never reset within a row), which silently corrupted
    # every "last column"/"last row" lookup (grand total, row/column totals,
    # intersections all read a blank padding cell instead of the real one).
    val anchor_col = pivot_anchor.col
    val anchor_row = pivot_anchor.row
    var max_col = anchor_col
    var max_row = anchor_row

    var scan_row = anchor_row
    var empty_row_streak = 0
    while scan_row < anchor_row + 100:
        var scan_col = anchor_col
        var row_has_content = false
        var empty_col_streak = 0
        while scan_col < anchor_col + 100:
            val cell_key = cell_ref_to_string(CellRef(col: scan_col, row: scan_row))
            val disp = cell_display_text(sheet.get_cell(cell_key))
            if disp.len() > 0:
                row_has_content = true
                empty_col_streak = 0
                if scan_col > max_col:
                    max_col = scan_col
                if scan_row > max_row:
                    max_row = scan_row
            else:
                empty_col_streak = empty_col_streak + 1
                if empty_col_streak > 5:
                    break
            scan_col = scan_col + 1
        if row_has_content:
            empty_row_streak = 0
        else:
            empty_row_streak = empty_row_streak + 1
            if empty_row_streak > 5:
                break
        scan_row = scan_row + 1

    if max_col == anchor_col and max_row == anchor_row and cell_display_text(sheet.get_cell(cell_ref_to_string(CellRef(col: anchor_col, row: anchor_row)))).len() == 0:
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA empty pivot"), next_pos: cur_pos)

    var pivot_grid: [[text]] = []
    var pr = anchor_row
    while pr <= max_row:
        var row_data: [text] = []
        var pc = anchor_col
        while pc <= max_col:
            val cell_key2 = cell_ref_to_string(CellRef(col: pc, row: pr))
            row_data.push(cell_display_text(sheet.get_cell(cell_key2)))
            pc = pc + 1
        pivot_grid.push(row_data)
        pr = pr + 1

    if pivot_grid.len() == 0:
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA empty pivot"), next_pos: cur_pos)

    # Determine pivot structure (1D vs 2D)
    val header_row = pivot_grid[0]
    val is_2d = header_row.len() > 2 and header_row[0] != "Row"

    # Validate data_field against the pivot's value-column header (the
    # top-left header cell, e.g. "Amount") before any lookup. Excel returns
    # #REF for an unrecognized data field rather than silently falling back
    # to the grand total.
    if header_row.len() > 0:
        val value_header = header_row[0]
        if value_header.lower() != data_field.lower():
            return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA unknown data_field"), next_pos: cur_pos)

    if field_items.len() == 0:
        # Grand total: bottom-right cell
        if pivot_grid.len() > 0 and header_row.len() > 0:
            val last_row = pivot_grid[pivot_grid.len() - 1]
            if last_row.len() > 0:
                val grand_total_str = last_row[last_row.len() - 1]
                if grand_total_str.len() > 0:
                    val gt_val = grand_total_str.to_f64()
                    return EvalResult(value: CellValue.NumberVal(value: gt_val), next_pos: cur_pos)
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA no grand total"), next_pos: cur_pos)

    if field_items.len() == 2:
        # One field/item pair: row or column total
        val field_1 = field_items[0]
        val item_1 = field_items[1]

        if is_2d:
            # Look in first column for item, check if it's a row key
            var target_row = -1
            var r = 1
            while r < pivot_grid.len():
                if pivot_grid[r].len() > 0 and pivot_grid[r][0] == item_1:
                    target_row = r
                    break
                r = r + 1
            if target_row >= 0 and target_row < pivot_grid.len():
                val data_row = pivot_grid[target_row]
                if data_row.len() > 0:
                    val row_total_str = data_row[data_row.len() - 1]
                    if row_total_str.len() > 0:
                        val rt_val = row_total_str.to_f64()
                        return EvalResult(value: CellValue.NumberVal(value: rt_val), next_pos: cur_pos)

            # Otherwise look in header row for column total
            var target_col = -1
            var c = 1
            while c < header_row.len() - 1:
                if header_row[c] == item_1:
                    target_col = c
                    break
                c = c + 1
            if target_col >= 0:
                if pivot_grid.len() > 0:
                    val last_row = pivot_grid[pivot_grid.len() - 1]
                    if target_col < last_row.len():
                        val col_total_str = last_row[target_col]
                        if col_total_str.len() > 0:
                            val ct_val = col_total_str.to_f64()
                            return EvalResult(value: CellValue.NumberVal(value: ct_val), next_pos: cur_pos)
        else:
            # 1D pivot: look for row key
            var r = 1
            while r < pivot_grid.len():
                if pivot_grid[r].len() > 0 and pivot_grid[r][0] == item_1:
                    if pivot_grid[r].len() > 1:
                        val val_str = pivot_grid[r][1]
                        if val_str.len() > 0:
                            val v = val_str.to_f64()
                            return EvalResult(value: CellValue.NumberVal(value: v), next_pos: cur_pos)
                r = r + 1
        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA field/item not found"), next_pos: cur_pos)

    if field_items.len() == 4:
        # Two field/item pairs: intersection cell
        val field_1 = field_items[0]
        val item_1 = field_items[1]
        val field_2 = field_items[2]
        val item_2 = field_items[3]

        if is_2d:
            # Find row matching item_1 in first column
            var target_row = -1
            var r = 1
            while r < pivot_grid.len() - 1:
                if pivot_grid[r].len() > 0 and pivot_grid[r][0] == item_1:
                    target_row = r
                    break
                r = r + 1

            # Find column matching item_2 in header row
            var target_col = -1
            var c = 1
            while c < header_row.len() - 1:
                if header_row[c] == item_2:
                    target_col = c
                    break
                c = c + 1

            if target_row >= 0 and target_col >= 0 and target_row < pivot_grid.len():
                val data_row = pivot_grid[target_row]
                if target_col < data_row.len():
                    val cell_val_str = data_row[target_col]
                    if cell_val_str.len() > 0:
                        val cv = cell_val_str.to_f64()
                        return EvalResult(value: CellValue.NumberVal(value: cv), next_pos: cur_pos)

        return EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA intersection not found"), next_pos: cur_pos)

    EvalResult(value: CellValue.ErrorVal(message: "GETPIVOTDATA unsupported field/item count"), next_pos: cur_pos)
