                var remaining = if days < 0: 0 - days else: days
                val step = if days < 0: 0 - 1 else: 1
                while remaining > 0:
                    d = d + step
                    if _is_weekday(d):
                        remaining = remaining - 1
                return CellValue.NumberVal(value: d.to_f64())
