                return CellValue.NumberVal(value: if v < 0.0: 0.0 - down else: down)
            return CellValue.ErrorVal(message: "ROUNDDOWN requires 1 argument")
        "EVEN":
            if flat.len() > 0:
                var n = _ceil_f64(flat[0]).to_i64()
                if n % 2 != 0:
                    n = n + 1
                return CellValue.NumberVal(value: n.to_f64())
            return CellValue.ErrorVal(message: "EVEN requires 1 argument")
        "ODD":
            if flat.len() > 0:
                var n = _ceil_f64(flat[0]).to_i64()
                if n % 2 == 0:
                    n = n + 1
                return CellValue.NumberVal(value: n.to_f64())
            return CellValue.ErrorVal(message: "ODD requires 1 argument")
        "FACT":
            if flat.len() > 0 and flat[0] >= 0.0 and flat[0] <= 170.0:
                return CellValue.NumberVal(value: _fact_i64(flat[0].to_i64()))
            return CellValue.ErrorVal(message: "FACT requires 0..170")
        "GCD":
            if args.len() >= 2:
                return CellValue.NumberVal(value: _gcd_i64(_first_val(args[0]).to_i64(), _first_val(args[1]).to_i64()).to_f64())
            return CellValue.ErrorVal(message: "GCD requires 2 arguments")
        "LCM":
            if args.len() >= 2:
                val a = _first_val(args[0]).to_i64()
                val b = _first_val(args[1]).to_i64()
                val g = _gcd_i64(a, b)
                if g == 0:
                    return CellValue.NumberVal(value: 0.0)
                var l = (a / g) * b
                if l < 0:
                    l = -l
                return CellValue.NumberVal(value: l.to_f64())
            return CellValue.ErrorVal(message: "LCM requires 2 arguments")
        "AVEDEV":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "AVEDEV requires arguments")
            var mean_sum = 0.0
            for v in flat:
                mean_sum = mean_sum + v
            val mean = mean_sum / flat.len().to_f64()
            var dev_sum = 0.0
            for v in flat:
                val d = v - mean
                dev_sum = dev_sum + (if d < 0.0: 0.0 - d else: d)
            return CellValue.NumberVal(value: dev_sum / flat.len().to_f64())
        "TODAY":
            # UTC day; local-timezone offset is a recorded ceiling
            val micros = rt_time_now_unix_micros()
            return CellValue.NumberVal(value: (micros / 86400000000 + 25569).to_f64())
        "NOW":
            val now_micros = rt_time_now_unix_micros()
            val day_part = (now_micros / 86400000000).to_f64()
            val frac = (now_micros % 86400000000).to_f64() / 86400000000.0
            return CellValue.NumberVal(value: day_part + 25569.0 + frac)
        "COMPLEX":
            if args.len() >= 2:
                return CellValue.TextVal(value: _format_complex(_first_val(args[0]), _first_val(args[1])))
            return CellValue.ErrorVal(message: "COMPLEX requires re, im")
        "DATE":
            if args.len() >= 3:
                return CellValue.NumberVal(value: _serial_from_civil(_first_val(args[0]).to_i64(), _first_val(args[1]).to_i64(), _first_val(args[2]).to_i64()))
            return CellValue.ErrorVal(message: "DATE requires year, month, day")
        "YEAR":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _civil_from_serial(flat[0])[0].to_f64())
            return CellValue.ErrorVal(message: "YEAR requires a serial")
        "MONTH":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _civil_from_serial(flat[0])[1].to_f64())
            return CellValue.ErrorVal(message: "MONTH requires a serial")
        "DAY":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _civil_from_serial(flat[0])[2].to_f64())
            return CellValue.ErrorVal(message: "DAY requires a serial")
        "DAYS":
            if args.len() >= 2:
                return CellValue.NumberVal(value: _first_val(args[0]) - _first_val(args[1]))
            return CellValue.ErrorVal(message: "DAYS requires end, start")
        "WEEKDAY":
            if flat.len() > 0:
                # Excel default: 1 = Sunday .. 7 = Saturday; WD = serial mod 7 (0 -> 7)
                var wd = (flat[0].to_i64() % 7).to_i32()
                if wd < 0:
                    wd = wd + 7
                if wd == 0:
                    wd = 7
                return CellValue.NumberVal(value: wd.to_f64())
            return CellValue.ErrorVal(message: "WEEKDAY requires a serial")
        "EDATE":
            if args.len() >= 2:
                val ymd = _civil_from_serial(_first_val(args[0]))
                var total = ymd[0] * 12 + (ymd[1] - 1) + _first_val(args[1]).to_i64()
                val ny = total / 12
                val nm = total % 12 + 1
                var nd = ymd[2]
                if nd > 28:
                    val next_month = _serial_from_civil(if nm == 12: ny + 1 else: ny, if nm == 12: 1 else: nm + 1, 1)
                    val last_day = _civil_from_serial(next_month - 1.0)[2]
                    if nd > last_day:
                        nd = last_day
                return CellValue.NumberVal(value: _serial_from_civil(ny, nm, nd))
            return CellValue.ErrorVal(message: "EDATE requires serial, months")
        "ATAN2":
            if args.len() >= 2:
                val yy = _first_val(args[0])
                val xx = _first_val(args[1])
                if xx > 0.0:
                    return CellValue.NumberVal(value: _atan_f64(yy / xx))
                if xx < 0.0 and yy >= 0.0:
                    return CellValue.NumberVal(value: _atan_f64(yy / xx) + _PI)
                if xx < 0.0:
                    return CellValue.NumberVal(value: _atan_f64(yy / xx) - _PI)
                if yy > 0.0:
                    return CellValue.NumberVal(value: _PI / 2.0)
                if yy < 0.0:
                    return CellValue.NumberVal(value: 0.0 - _PI / 2.0)
                return CellValue.ErrorVal(message: "ATAN2(0,0) undefined")
            return CellValue.ErrorVal(message: "ATAN2 requires 2 arguments")
        "ACOSH":
            if flat.len() > 0 and flat[0] >= 1.0:
                val v = flat[0]
                return CellValue.NumberVal(value: _ln_f64(v + _sqrt_f64(v * v - 1.0)))
            return CellValue.ErrorVal(message: "ACOSH requires x >= 1")
        "ASINH":
            if flat.len() > 0:
                val v = flat[0]
                return CellValue.NumberVal(value: _ln_f64(v + _sqrt_f64(v * v + 1.0)))
            return CellValue.ErrorVal(message: "ASINH requires 1 argument")
        "ATANH":
            if flat.len() > 0 and flat[0] > -1.0 and flat[0] < 1.0:
                return CellValue.NumberVal(value: 0.5 * _ln_f64((1.0 + flat[0]) / (1.0 - flat[0])))
            return CellValue.ErrorVal(message: "ATANH requires -1 < x < 1")
        "COT":
            if flat.len() > 0:
                val sv = _sin_f64(flat[0])
                if sv == 0.0:
                    return CellValue.ErrorVal(message: "COT undefined")
                return CellValue.NumberVal(value: _cos_f64(flat[0]) / sv)
            return CellValue.ErrorVal(message: "COT requires 1 argument")
        "SEC":
            if flat.len() > 0:
                val cv2 = _cos_f64(flat[0])
                if cv2 == 0.0:
                    return CellValue.ErrorVal(message: "SEC undefined")
                return CellValue.NumberVal(value: 1.0 / cv2)
            return CellValue.ErrorVal(message: "SEC requires 1 argument")
        "CSC":
            if flat.len() > 0:
                val sv2 = _sin_f64(flat[0])
                if sv2 == 0.0:
                    return CellValue.ErrorVal(message: "CSC undefined")
                return CellValue.NumberVal(value: 1.0 / sv2)
            return CellValue.ErrorVal(message: "CSC requires 1 argument")
        "VARP":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "VARP requires arguments")
            return CellValue.NumberVal(value: _pop_variance(flat))
        "STDEVP":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "STDEVP requires arguments")
            return CellValue.NumberVal(value: _sqrt_f64(_pop_variance(flat)))
        "DEVSQ":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "DEVSQ requires arguments")
            return CellValue.NumberVal(value: _pop_variance(flat) * flat.len().to_f64())
        "CORREL":
            if args.len() >= 2 and args[0].len() == args[1].len() and args[0].len() > 1:
                val denom = _sqrt_f64(_pop_variance(args[0]) * _pop_variance(args[1]))
                if denom == 0.0:
                    return CellValue.ErrorVal(message: "CORREL zero variance")
                return CellValue.NumberVal(value: _covariance(args[0], args[1]) / denom)
            return CellValue.ErrorVal(message: "CORREL requires 2 equal ranges")
        "COVAR":
            if args.len() >= 2 and args[0].len() == args[1].len() and args[0].len() > 0:
                return CellValue.NumberVal(value: _covariance(args[0], args[1]))
            return CellValue.ErrorVal(message: "COVAR requires 2 equal ranges")
        "SLOPE":
            if args.len() >= 2 and args[0].len() == args[1].len() and args[0].len() > 1:
                val vx = _pop_variance(args[1])
                if vx == 0.0:
                    return CellValue.ErrorVal(message: "SLOPE zero x variance")
                return CellValue.NumberVal(value: _covariance(args[0], args[1]) / vx)
            return CellValue.ErrorVal(message: "SLOPE requires y then x ranges")
        "INTERCEPT":
            if args.len() >= 2 and args[0].len() == args[1].len() and args[0].len() > 1:
                val vx2 = _pop_variance(args[1])
                if vx2 == 0.0:
                    return CellValue.ErrorVal(message: "INTERCEPT zero x variance")
                val slope = _covariance(args[0], args[1]) / vx2
                return CellValue.NumberVal(value: _mean(args[0]) - slope * _mean(args[1]))
            return CellValue.ErrorVal(message: "INTERCEPT requires y then x ranges")
        "RSQ":
            if args.len() >= 2 and args[0].len() == args[1].len() and args[0].len() > 1:
                val d = _pop_variance(args[0]) * _pop_variance(args[1])
                if d == 0.0:
                    return CellValue.ErrorVal(message: "RSQ zero variance")
                val c = _covariance(args[0], args[1])
                return CellValue.NumberVal(value: c * c / d)
            return CellValue.ErrorVal(message: "RSQ requires 2 equal ranges")
        "PMT":
            if args.len() >= 3:
                val rate = _first_val(args[0])
                val nper = _first_val(args[1])
                val pv = _first_val(args[2])
                if nper == 0.0:
                    return CellValue.ErrorVal(message: "PMT nper is zero")
                if rate == 0.0:
                    return CellValue.NumberVal(value: 0.0 - pv / nper)
                val g = _pow_f64(1.0 + rate, nper)
                return CellValue.NumberVal(value: 0.0 - pv * rate * g / (g - 1.0))
            return CellValue.ErrorVal(message: "PMT requires rate, nper, pv")
        "FV":
            if args.len() >= 3:
                val rate = _first_val(args[0])
                val nper = _first_val(args[1])
                val pmt = _first_val(args[2])
                if rate == 0.0:
                    return CellValue.NumberVal(value: 0.0 - pmt * nper)
                return CellValue.NumberVal(value: 0.0 - pmt * (_pow_f64(1.0 + rate, nper) - 1.0) / rate)
            return CellValue.ErrorVal(message: "FV requires rate, nper, pmt")
        "PV":
            if args.len() >= 3:
                val rate = _first_val(args[0])
                val nper = _first_val(args[1])
                val pmt = _first_val(args[2])
                if rate == 0.0:
                    return CellValue.NumberVal(value: 0.0 - pmt * nper)
                return CellValue.NumberVal(value: 0.0 - pmt * (1.0 - _pow_f64(1.0 + rate, 0.0 - nper)) / rate)
            return CellValue.ErrorVal(message: "PV requires rate, nper, pmt")
        "NPV":
            if args.len() >= 2:
                val rate = _first_val(args[0])
                val flows = _flatten_args(args[1:])
                var npv = 0.0
                var period = 1
                for cash in flows:
                    npv = npv + cash / _pow_f64(1.0 + rate, period.to_f64())
                    period = period + 1
                return CellValue.NumberVal(value: npv)
            return CellValue.ErrorVal(message: "NPV requires rate and flows")
        "NPER":
            if args.len() >= 3:
                val rate = _first_val(args[0])
                val pmt = _first_val(args[1])
                val pv = _first_val(args[2])
                if rate <= 0.0 or pmt == 0.0:
                    return CellValue.ErrorVal(message: "NPER domain error")
                val ratio = pmt / (pmt + pv * rate)
                if ratio <= 0.0:
                    return CellValue.ErrorVal(message: "NPER domain error")
                return CellValue.NumberVal(value: _ln_f64(ratio) / _ln_f64(1.0 + rate))
            return CellValue.ErrorVal(message: "NPER requires rate, pmt, pv")
        "TRUE":
            return CellValue.BoolVal(value: true)
        "FALSE":
            return CellValue.BoolVal(value: false)
        "ISEVEN":
            if flat.len() > 0:
                return CellValue.BoolVal(value: flat[0].to_i64() % 2 == 0)
            return CellValue.ErrorVal(message: "ISEVEN requires 1 argument")
        "ISODD":
            if flat.len() > 0:
                val m = flat[0].to_i64() % 2
                return CellValue.BoolVal(value: m == 1 or m == -1)
            return CellValue.ErrorVal(message: "ISODD requires 1 argument")
        "GEOMEAN":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "GEOMEAN requires arguments")
            var ln_sum = 0.0
            for v in flat:
                if v <= 0.0:
                    return CellValue.ErrorVal(message: "GEOMEAN requires positive values")
                ln_sum = ln_sum + _ln_f64(v)
            return CellValue.NumberVal(value: _exp_f64(ln_sum / flat.len().to_f64()))
        "HARMEAN":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "HARMEAN requires arguments")
            var inv_sum = 0.0
            for v in flat:
                if v == 0.0:
                    return CellValue.ErrorVal(message: "HARMEAN requires nonzero values")
                inv_sum = inv_sum + 1.0 / v
            return CellValue.NumberVal(value: flat.len().to_f64() / inv_sum)
        "MODE":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "MODE requires arguments")
            var best = flat[0]
            var best_count = 0
            for candidate in flat:
                var count = 0
                for v in flat:
                    if v == candidate:
                        count = count + 1
                if count > best_count:
                    best_count = count
                    best = candidate
            return CellValue.NumberVal(value: best)
        "RANK":
            if args.len() >= 2:
                val x = _first_val(args[0])
                val pool = _flatten_args(args[1:])
                var rank = 1
                for v in pool:
                    if v > x:
                        rank = rank + 1
                return CellValue.NumberVal(value: rank.to_f64())
            return CellValue.ErrorVal(message: "RANK requires value and range")
        "PERCENTILE":
            if args.len() >= 2:
                val k = _first_val(args[args.len() - 1])
                val pool = _sorted_asc(_flatten_args(args[0:args.len() - 1]))
                if pool.len() == 0 or k < 0.0 or k > 1.0:
                    return CellValue.ErrorVal(message: "PERCENTILE domain error")
                val pos = k * (pool.len() - 1).to_f64()
                val lo = _floor_f64(pos).to_i64().to_i32()
                val frac = pos - lo.to_f64()
                if lo + 1 >= pool.len():
                    return CellValue.NumberVal(value: pool[pool.len() - 1])
                return CellValue.NumberVal(value: pool[lo] + frac * (pool[lo + 1] - pool[lo]))
            return CellValue.ErrorVal(message: "PERCENTILE requires range and k")
        "SUMPRODUCT":
            if args.len() >= 2:
                val a = args[0]
                val b = args[1]
                if a.len() != b.len():
                    return CellValue.ErrorVal(message: "SUMPRODUCT ranges differ in size")
                var sp = 0.0
                var spi = 0
                while spi < a.len():
                    sp = sp + a[spi] * b[spi]
                    spi = spi + 1
                return CellValue.NumberVal(value: sp)
            return CellValue.ErrorVal(message: "SUMPRODUCT requires 2 ranges")
        "DELTA":
            if args.len() >= 2:
                val eq = _first_val(args[0]) == _first_val(args[1])
                return CellValue.NumberVal(value: if eq: 1.0 else: 0.0)
            return CellValue.ErrorVal(message: "DELTA requires 2 arguments")
        "GESTEP":
            if args.len() >= 2:
                val ge = _first_val(args[0]) >= _first_val(args[1])
                return CellValue.NumberVal(value: if ge: 1.0 else: 0.0)
            return CellValue.ErrorVal(message: "GESTEP requires 2 arguments")
        "FISHER":
            if flat.len() > 0 and flat[0] > -1.0 and flat[0] < 1.0:
                return CellValue.NumberVal(value: 0.5 * _ln_f64((1.0 + flat[0]) / (1.0 - flat[0])))
            return CellValue.ErrorVal(message: "FISHER requires -1 < x < 1")
        "FISHERINV":
            if flat.len() > 0:
                val e2 = _exp_f64(2.0 * flat[0])
                return CellValue.NumberVal(value: (e2 - 1.0) / (e2 + 1.0))
            return CellValue.ErrorVal(message: "FISHERINV requires 1 argument")
        "MEDIAN":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "MEDIAN requires arguments")
            val sorted_m = _sorted_asc(flat)
            val n = sorted_m.len()
            if n % 2 == 1:
                return CellValue.NumberVal(value: sorted_m[n / 2])
            return CellValue.NumberVal(value: (sorted_m[n / 2 - 1] + sorted_m[n / 2]) / 2.0)
        "VAR":
            if flat.len() < 2:
                return CellValue.ErrorVal(message: "VAR requires 2+ values")
            return CellValue.NumberVal(value: _sample_variance(flat))
        "STDEV":
            if flat.len() < 2:
                return CellValue.ErrorVal(message: "STDEV requires 2+ values")
            return CellValue.NumberVal(value: _sqrt_f64(_sample_variance(flat)))
        "LARGE":
            if args.len() >= 2:
                val ks = _first_val(args[args.len() - 1]).to_i64()
                val pool = _flatten_args(args[0:args.len() - 1])
                val sorted_l = _sorted_asc(pool)
                if ks < 1 or ks.to_i32() > sorted_l.len():
                    return CellValue.ErrorVal(message: "LARGE k out of range")
                return CellValue.NumberVal(value: sorted_l[sorted_l.len() - ks.to_i32()])
            return CellValue.ErrorVal(message: "LARGE requires range and k")
        "SMALL":
            if args.len() >= 2:
                val ks = _first_val(args[args.len() - 1]).to_i64()
                val pool = _flatten_args(args[0:args.len() - 1])
                val sorted_s = _sorted_asc(pool)
                if ks < 1 or ks.to_i32() > sorted_s.len():
                    return CellValue.ErrorVal(message: "SMALL k out of range")
                return CellValue.NumberVal(value: sorted_s[ks.to_i32() - 1])
            return CellValue.ErrorVal(message: "SMALL requires range and k")
        "ABS":
            if flat.len() > 0:
                val v = flat[0]
                val abs_v = if v < 0.0: 0.0 - v else: v
                return CellValue.NumberVal(value: abs_v)
            return CellValue.ErrorVal(message: "ABS requires 1 argument")
        "SQRT":
            if flat.len() > 0:
                val v = flat[0]
                if v < 0.0:
                    return CellValue.ErrorVal(message: "SQRT of negative")
                return CellValue.NumberVal(value: _sqrt_f64(v))
            return CellValue.ErrorVal(message: "SQRT requires 1 argument")
        "POWER":
            if args.len() >= 2:
                val base = _first_val(args[0])
                val exp = _first_val(args[1])
                return CellValue.NumberVal(value: _pow_f64(base, exp))
            return CellValue.ErrorVal(message: "POWER requires 2 arguments")
        "MOD":
            if args.len() >= 2:
                val a = _first_val(args[0])
                val b = _first_val(args[1])
                if b == 0.0:
                    return CellValue.ErrorVal(message: "MOD by zero")
                val q = _floor_f64(a / b)
                return CellValue.NumberVal(value: a - (b * q))
            return CellValue.ErrorVal(message: "MOD requires 2 arguments")
        "INT":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _floor_f64(flat[0]))
            return CellValue.ErrorVal(message: "INT requires 1 argument")
        "TRUNC":
            if flat.len() > 0:
                return CellValue.NumberVal(value: flat[0].to_i64().to_f64())
            return CellValue.ErrorVal(message: "TRUNC requires 1 argument")
        "FLOOR":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _floor_f64(flat[0]))
            return CellValue.ErrorVal(message: "FLOOR requires 1 argument")
        "CEILING":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _ceil_f64(flat[0]))
            return CellValue.ErrorVal(message: "CEILING requires 1 argument")
        "SIGN":
            if flat.len() > 0:
                val v = flat[0]
                if v > 0.0:
                    return CellValue.NumberVal(value: 1.0)
                if v < 0.0:
                    return CellValue.NumberVal(value: 0.0 - 1.0)
                return CellValue.NumberVal(value: 0.0)
            return CellValue.ErrorVal(message: "SIGN requires 1 argument")
        "AND":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "AND requires arguments")
            var all_true = true
            for v in flat:
                if v == 0.0:
                    all_true = false
            return CellValue.BoolVal(value: all_true)
        "OR":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "OR requires arguments")
            var any_true = false
            for v in flat:
                if v != 0.0:
                    any_true = true
            return CellValue.BoolVal(value: any_true)
        "NOT":
            if flat.len() > 0:
                return CellValue.BoolVal(value: flat[0] == 0.0)
            return CellValue.ErrorVal(message: "NOT requires 1 argument")
        "ROUND":
            if args.len() >= 2:
                val v = _first_val(args[0])
                val digits = _first_val(args[1]).to_i64()
                val factor = _pow10_f64(digits)
                return CellValue.NumberVal(value: _round_half_away(v, factor))
            if flat.len() > 0:
                return CellValue.NumberVal(value: _round_half_away(flat[0], 1.0))
            return CellValue.ErrorVal(message: "ROUND requires 1-2 arguments")
        "IF":
            if args.len() >= 3:
                val cond = _first_val(args[0])
                if cond != 0.0:
                    return CellValue.NumberVal(value: _first_val(args[1]))
                return CellValue.NumberVal(value: _first_val(args[2]))
            return CellValue.ErrorVal(message: "IF requires 3 arguments")
        _:
            return CellValue.ErrorVal(message: "Unknown function: {name}")

# =========================================================================
# Cell Resolution
# =========================================================================

fn resolve_cell_value(ref_str: text, sheet: Sheet) -> f64:
    """Get the numeric value of a cell. Returns 0.0 if cell is empty or non-numeric."""
    _resolve_cell_value(ref_str, sheet, 0)

fn _resolve_cell_value(ref_str: text, sheet: Sheet, depth: i32) -> f64:
    if depth > MAX_EVAL_DEPTH:
        return 0.0
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return 1.0
            return 0.0
        CellValue.FormulaVal(expr, cached_display):
            # Recursively evaluate the formula, carrying depth so a circular
            # reference is caught instead of overflowing the stack.
            val result = _evaluate_formula(expr, sheet, depth + 1)
            return _to_number(result)
        _:
            return 0.0

fn resolve_cell_range(range_str: text, sheet: Sheet) -> [f64]:
    """Get all numeric values from cells in a range."""
    _resolve_cell_range(range_str, sheet, 0)

fn _resolve_cell_range(range_str: text, sheet: Sheet, depth: i32) -> [f64]:
    var values: [f64] = []
    val range = parse_range(range_str)
    if range == nil:
        return values
    val refs = expand_range_refs(range)
    for ref_str in refs:
        val v = _resolve_cell_value(ref_str, sheet, depth + 1)
        values.push(v)
    values

fn resolve_cell_display_i64(ref_str: text, sheet: Sheet) -> DisplayEvalResult:
    """Resolve a cell to an integer value for display-oriented formula checks."""
    _resolve_cell_display_i64(ref_str, sheet, 0)

fn _resolve_cell_display_i64(ref_str: text, sheet: Sheet, depth: i32) -> DisplayEvalResult:
    if depth > MAX_EVAL_DEPTH:
        return DisplayEvalResult(ok: false, value: 0)
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return DisplayEvalResult(ok: true, value: value.to_i64())
        CellValue.TextVal(value):
            return _parse_i64_text(value)
        CellValue.BoolVal(value):
            if value:
                return DisplayEvalResult(ok: true, value: 1)
            return DisplayEvalResult(ok: true, value: 0)
        CellValue.FormulaVal(expr, cached_display):
            if cached_display != "":
                return _parse_i64_text(cached_display)
            val text_value = _evaluate_formula_display_text(expr, sheet, depth + 1)
            return _parse_i64_text(text_value)
        _:
            return DisplayEvalResult(ok: false, value: 0)

# =========================================================================
# Aggregation Functions
# =========================================================================

fn eval_sum(values: [f64]) -> f64:
    """Sum all values."""
    var total = 0.0
    for v in values:
        total = total + v
    total

fn eval_product(values: [f64]) -> f64:
    """Multiply all values. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var total = 1.0
    for v in values:
        total = total * v
    total

fn eval_average(values: [f64]) -> f64:
    """Average of all values. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    val total = eval_sum(values)
    total / values.len().to_f64()

fn eval_count(values: [f64]) -> f64:
    """Count of values."""
    values.len().to_f64()

fn eval_min(values: [f64]) -> f64:
    """Minimum value. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var result = values[0]
    for v in values:
        if v < result:
            result = v
    result

fn eval_max(values: [f64]) -> f64:
    """Maximum value. Returns 0.0 if empty."""
    if values.len() == 0:
        return 0.0
    var result = values[0]
    for v in values:
        if v > result:
            result = v
    result

# =========================================================================
# Internal Helpers
# =========================================================================

fn _to_number(cv: CellValue) -> f64:
    """Extract numeric value from a CellValue. Non-numeric values return 0.0."""
    match cv:
        CellValue.NumberVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return 1.0
            return 0.0
        _:
            return 0.0

fn _cell_value_to_display(cv: CellValue) -> text:
    """Render a CellValue as a display string for concatenation."""
    match cv:
        CellValue.NumberVal(value):
            return _format_number(value)
        CellValue.TextVal(value):
            return value
        CellValue.BoolVal(value):
            if value:
                return "TRUE"
            return "FALSE"
        CellValue.ErrorVal(message):
            return "#ERR"
        _:
            return ""

fn _format_number(v: f64) -> text:
    """Format a number, dropping the decimal when the value is integral."""
    val iv = v.to_i64()
    val iv_f = iv.to_f64()
    if iv_f == v:
        return "{iv}"
    "{v}"

fn _round_half_away(v: f64, factor: f64) -> f64:
    """Round v to the given power-of-ten factor, half away from zero."""
    val scaled = v * factor
    var rounded_scaled = 0.0
    if scaled >= 0.0:
        rounded_scaled = (scaled + 0.5).to_i64().to_f64()
    else:
        rounded_scaled = (scaled - 0.5).to_i64().to_f64()
    rounded_scaled / factor

fn _floor_f64(x: f64) -> f64:
    """Largest integer <= x."""
    val t = x.to_i64().to_f64()
    if t > x:
        return t - 1.0
    t

fn _ceil_f64(x: f64) -> f64:
    """Smallest integer >= x."""
    val t = x.to_i64().to_f64()
    if t < x:
        return t + 1.0
    t

fn _sqrt_f64(x: f64) -> f64:
    """Square root via Newton's method. Assumes x >= 0."""
    if x == 0.0:
        return 0.0
    var g = x
    var i = 0
    while i < 40:
        g = 0.5 * (g + (x / g))
        i = i + 1
    g

fn _is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

fn _is_alpha(c: text) -> bool:
    val code = c.char_code_at(0)
    val is_upper = code >= 65 and code <= 90
    val is_lower = code >= 97 and code <= 122
    is_upper or is_lower

fn _is_cell_ref_token(token: text) -> bool:
    """Check if a token looks like a cell reference (letters followed by digits)."""
    if token.len() == 0:
        return false
    if not _is_alpha(token.char_at(0)):
        return false
    var has_digit = false
    var i = 0
    while i < token.len():
        val c = token.char_at(i)
        if _is_digit(c):
            has_digit = true
        i = i + 1
    has_digit

fn _pow_f64(base: f64, exp: f64) -> f64:
    """Simple power function for non-negative integer exponents."""
    val int_exp = exp.to_i64()
    if int_exp == 0:
        return 1.0
    var result = 1.0
    var neg = false
    var e = int_exp
    if e < 0:
        neg = true
        e = 0 - e
    var i: i64 = 0
    while i < e:
        result = result * base
        i = i + 1
    if neg:
        return 1.0 / result
    result

fn _pow10_f64(exp: i64) -> f64:
    """Calculate 10^exp for small exponents."""
    var result = 1.0
    var i: i64 = 0
    var e = exp
    if e < 0:
        e = 0 - e
    while i < e:
        result = result * 10.0
        i = i + 1
    if exp < 0:
        return 1.0 / result
    result

fn _flatten_args(args: [[f64]]) -> [f64]:
    """Flatten a list of float lists into a single flat list."""
    var result: [f64] = []
    for group in args:
        for v in group:
            result.push(v)
    result

fn _first_val(vals: [f64]) -> f64:
    """Get the first value from a float list, or 0.0 if empty."""
    if vals.len() > 0:
        return vals[0]
    0.0

fn _eval_display_sum(tokens: [text], sheet: Sheet, depth: i32) -> DisplayEvalResult:
    var total: i64 = 0
    var op = "+"
    var expecting_value = true
    for token in tokens:
        if token == "+" or token == "-":
            if expecting_value:
                return DisplayEvalResult(ok: false, value: 0)
            op = token
            expecting_value = true
            continue
        val value = _display_token_i64(token, sheet, depth)
        if not value.ok:
            return DisplayEvalResult(ok: false, value: 0)
        if op == "-":
            total = total - value.value
        else:
            total = total + value.value
        expecting_value = false
    if expecting_value:
        return DisplayEvalResult(ok: false, value: 0)
    DisplayEvalResult(ok: true, value: total)

fn _display_token_i64(token: text, sheet: Sheet, depth: i32) -> DisplayEvalResult:
    if token.len() == 0:
        return DisplayEvalResult(ok: false, value: 0)
    val upper_token = token.upper()
    if parse_cell_ref(upper_token) != nil:
        return _resolve_cell_display_i64(upper_token, sheet, depth)
    _parse_i64_text(token)

fn _parse_i64_text(s: text) -> DisplayEvalResult:
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return DisplayEvalResult(ok: false, value: 0)
    var negative = false
    var i = 0
    if trimmed.char_at(0) == "-":
        negative = true
        i = 1
        if trimmed.len() == 1:
            return DisplayEvalResult(ok: false, value: 0)
    var value: i64 = 0
    while i < trimmed.len():
        val c = trimmed.char_at(i)
        if not _is_digit(c):
            return DisplayEvalResult(ok: false, value: 0)
        value = value * 10 + (c.char_code_at(0) - 48).to_i64()
        i = i + 1
    if negative:
        return DisplayEvalResult(ok: true, value: 0 - value)
    DisplayEvalResult(ok: true, value: value)
