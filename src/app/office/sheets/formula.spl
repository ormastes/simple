            if flat.len() > 0:
                val v = flat[0]
                val up = _ceil_f64(if v < 0.0: 0.0 - v else: v)
                return CellValue.NumberVal(value: if v < 0.0: 0.0 - up else: up)
            return CellValue.ErrorVal(message: "ROUNDUP requires 1 argument")
        "ROUNDDOWN":
            if flat.len() > 0:
                val v = flat[0]
