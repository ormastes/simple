        "CEILING.MATH":
            if flat.len() == 0:
                return CellValue.ErrorVal(message: "CEILING.MATH requires a number")
            val num = flat[0]
            var s = if args.len() >= 2: _first_val(args[1]) else: 1.0
            if s < 0.0:
                s = 0.0 - s
            if s == 0.0:
                return CellValue.NumberVal(value: 0.0)
            val mode = if args.len() >= 3: _first_val(args[2]) else: 0.0
            # Default: round toward +inf. Negative number with nonzero mode: away from zero.
            if num < 0.0 and mode != 0.0:
                return CellValue.NumberVal(value: _floor_f64(num / s) * s)
            return CellValue.NumberVal(value: _ceil_f64(num / s) * s)
