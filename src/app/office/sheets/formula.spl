# Formula Engine
#
# Recursive-descent parser and evaluator for spreadsheet formulas.
# Supports numbers, cell references, ranges, arithmetic operators,
# comparison operators, string concatenation (&), parentheses, and
# built-in functions. Cell-reference resolution is depth-bounded so
# circular references resolve to an error instead of overflowing the stack.

use app.office.sheets.cell.{CellValue, CellRef, parse_cell_ref, cell_ref_to_string, cell_display_text}
use app.office.sheets.cell_ref.{parse_range, expand_range_refs, CellRange}
use app.office.sheets.spreadsheet.{Sheet}
use common.office.number.{office_parse_unsigned_decimal_f64}

# =========================================================================
# Types
# =========================================================================

struct EvalResult:
    value: CellValue
    next_pos: i32

struct DisplayEvalResult:
    ok: bool
    value: i64

# Maximum cell-reference resolution depth. A chain longer than this (which
# a circular reference always is) returns a circular-reference error.
val MAX_EVAL_DEPTH = 64

extern fn rt_time_now_unix_micros() -> i64

# =========================================================================
# Main Entry Point
# =========================================================================

fn evaluate_formula(expr: text, sheet: Sheet) -> CellValue:
    """Evaluate a formula expression. Strips leading '=' if present.
    Returns a CellValue with the result or an error."""
    _evaluate_formula(expr, sheet, 0)

fn _evaluate_formula(expr: text, sheet: Sheet, depth: i32) -> CellValue:
    if depth > MAX_EVAL_DEPTH:
        return CellValue.ErrorVal(message: "Circular reference")
    var formula = expr.trim()
    if formula.len() == 0:
        return CellValue.Empty
    if formula.starts_with("="):
        formula = formula.substring(1)
    if formula.len() == 0:
        return CellValue.Empty
    val tokens = tokenize_formula(formula)
    if tokens.len() == 0:
        return CellValue.Empty
    val result = _eval_concat(tokens, 0, sheet, depth)
    result.value

fn evaluate_formula_display_text(expr: text, sheet: Sheet) -> text:
    """Evaluate a simple arithmetic formula for display using integer-safe paths.

    This complements `evaluate_formula` for UI/report surfaces that only need a
    stable display value while the native f64-return path is not reliable from
    every entrypoint.
    """
    _evaluate_formula_display_text(expr, sheet, 0)

fn _evaluate_formula_display_text(expr: text, sheet: Sheet, depth: i32) -> text:
    if depth > MAX_EVAL_DEPTH:
        return ""
    var formula = expr.trim()
    if formula.len() == 0:
        return ""
    if formula.starts_with("="):
        formula = formula.substring(1)
    val tokens = tokenize_formula(formula)
    if tokens.len() == 0:
        return ""
    val result = _eval_display_sum(tokens, sheet, depth)
    if not result.ok:
        return ""
    "{result.value}"

# =========================================================================
# Tokenizer
# =========================================================================

fn tokenize_formula(expr: text) -> [text]:
    """Tokenize a formula string into a list of tokens.
    Recognizes: numbers, cell refs, function names, operators, parens, commas, colons."""
    var tokens: [text] = []
    var i = 0
    val len = expr.len()
    while i < len:
        val c = expr.char_at(i)
        # Skip whitespace
        if c == " " or c == "\t":
            i = i + 1
            continue
        # Operators and punctuation
        if c == "+" or c == "-" or c == "*" or c == "/" or c == "^" or c == "(" or c == ")" or c == "," or c == ":" or c == "&":
            tokens.push(c)
            i = i + 1
            continue
        # Comparison operators
        if c == "=":
            tokens.push("=")
            i = i + 1
            continue
        if c == "<":
            if i + 1 < len:
                val next = expr.char_at(i + 1)
                if next == "=":
                    tokens.push("<=")
                    i = i + 2
                    continue
                if next == ">":
                    tokens.push("<>")
                    i = i + 2
                    continue
            tokens.push("<")
            i = i + 1
            continue
        if c == ">":
            if i + 1 < len and expr.char_at(i + 1) == "=":
                tokens.push(">=")
                i = i + 2
                continue
            tokens.push(">")
            i = i + 1
            continue
        # Numbers
        if _is_digit(c) or (c == "." and i + 1 < len and _is_digit(expr.char_at(i + 1))):
            var num_str = ""
            while i < len:
                val ch = expr.char_at(i)
                if _is_digit(ch) or ch == ".":
                    num_str = "{num_str}{ch}"
                    i = i + 1
                else:
                    break
            tokens.push(num_str)
            continue
        # Letters: could be cell ref (A1) or function name (SUM)
        if _is_alpha(c):
            var word = ""
            while i < len:
                val ch = expr.char_at(i)
                if _is_alpha(ch) or _is_digit(ch):
                    word = "{word}{ch}"
                    i = i + 1
                else:
                    break
            tokens.push(word)
            continue
        # String literals in double quotes
        if c == "\"":
            var str_val = ""
            i = i + 1
            while i < len:
                val ch = expr.char_at(i)
                if ch == "\"":
                    i = i + 1
                    break
                str_val = "{str_val}{ch}"
                i = i + 1
            tokens.push("\"{str_val}\"")
            continue
        # Unknown character, skip
        i = i + 1
    tokens

# =========================================================================
# Recursive Descent Parser
# =========================================================================

fn _eval_concat(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse string concatenation: comparison ( '&' comparison )*"""
    var left = _eval_comparison(tokens, pos, sheet, depth)
    var cur_pos = left.next_pos
    while cur_pos < tokens.len():
        val op = tokens[cur_pos]
        if op == "&":
            val right = _eval_comparison(tokens, cur_pos + 1, sheet, depth)
            val ls = _cell_value_to_display(left.value)
            val rs = _cell_value_to_display(right.value)
            left = EvalResult(
                value: CellValue.TextVal(value: "{ls}{rs}"),
                next_pos: right.next_pos
            )
            cur_pos = right.next_pos
        else:
            break
    left

fn _eval_comparison(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse comparison: expr (( '>' | '<' | '>=' | '<=' | '=' | '<>' ) expr)?"""
    var left = _eval_expression(tokens, pos, sheet, depth)
    var cur_pos = left.next_pos
    while cur_pos < tokens.len():
        val op = tokens[cur_pos]
        if op == ">" or op == "<" or op == ">=" or op == "<=" or op == "=" or op == "<>":
            val right = _eval_expression(tokens, cur_pos + 1, sheet, depth)
            val lv = _to_number(left.value)
            val rv = _to_number(right.value)
            var bool_result = false
            if op == ">":
                bool_result = lv > rv
            elif op == "<":
                bool_result = lv < rv
            elif op == ">=":
                bool_result = lv >= rv
            elif op == "<=":
                bool_result = lv <= rv
            elif op == "=":
                bool_result = lv == rv
            elif op == "<>":
                bool_result = lv != rv
            left = EvalResult(
                value: CellValue.BoolVal(value: bool_result),
                next_pos: right.next_pos
            )
            cur_pos = right.next_pos
        else:
            break
    left

fn _eval_expression(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse addition/subtraction: term (( '+' | '-' ) term)*"""
    var left = _eval_term(tokens, pos, sheet, depth)
    var cur_pos = left.next_pos
    while cur_pos < tokens.len():
        val op = tokens[cur_pos]
        if op == "+" or op == "-":
            val right = _eval_term(tokens, cur_pos + 1, sheet, depth)
            val lv = _to_number(left.value)
            val rv = _to_number(right.value)
            var result_val = 0.0
            if op == "+":
                result_val = lv + rv
            else:
                result_val = lv - rv
            left = EvalResult(
                value: CellValue.NumberVal(value: result_val),
                next_pos: right.next_pos
            )
            cur_pos = right.next_pos
        else:
            break
    left

fn _eval_term(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse multiplication/division: factor (( '*' | '/' ) factor)*"""
    var left = _eval_power(tokens, pos, sheet, depth)
    var cur_pos = left.next_pos
    while cur_pos < tokens.len():
        val op = tokens[cur_pos]
        if op == "*" or op == "/":
            val right = _eval_power(tokens, cur_pos + 1, sheet, depth)
            val lv = _to_number(left.value)
            val rv = _to_number(right.value)
            var result_val = 0.0
            if op == "*":
                result_val = lv * rv
            else:
                if rv == 0.0:
                    return EvalResult(
                        value: CellValue.ErrorVal(message: "Division by zero"),
                        next_pos: right.next_pos
                    )
                result_val = lv / rv
            left = EvalResult(
                value: CellValue.NumberVal(value: result_val),
                next_pos: right.next_pos
            )
            cur_pos = right.next_pos
        else:
            break
    left

fn _eval_power(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse exponentiation: unary ( '^' unary )*"""
    var left = _eval_unary(tokens, pos, sheet, depth)
    var cur_pos = left.next_pos
    while cur_pos < tokens.len():
        val op = tokens[cur_pos]
        if op == "^":
            val right = _eval_unary(tokens, cur_pos + 1, sheet, depth)
            val base = _to_number(left.value)
            val exp = _to_number(right.value)
            val result_val = _pow_f64(base, exp)
            left = EvalResult(
                value: CellValue.NumberVal(value: result_val),
                next_pos: right.next_pos
            )
            cur_pos = right.next_pos
        else:
            break
    left

fn _eval_unary(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse unary minus: '-' primary | primary"""
    if pos < tokens.len() and tokens.get(pos) == "-":
        val inner = _eval_primary(tokens, pos + 1, sheet, depth)
        val v = _to_number(inner.value)
        return EvalResult(
            value: CellValue.NumberVal(value: 0.0 - v),
            next_pos: inner.next_pos
        )
    _eval_primary(tokens, pos, sheet, depth)

fn _eval_primary(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Parse primary: number | string | cell_ref | function_call | '(' expression ')'"""
    if pos >= tokens.len():
        return EvalResult(value: CellValue.NumberVal(value: 0.0), next_pos: pos)

    val token = tokens.get(pos)

    # Parenthesized expression
    if token == "(":
        val inner = _eval_concat(tokens, pos + 1, sheet, depth)
        var end_pos = inner.next_pos
        if end_pos < tokens.len() and tokens.get(end_pos) == ")":
            end_pos = end_pos + 1
        return EvalResult(value: inner.value, next_pos: end_pos)

    # String literal
    if token.starts_with("\""):
        val str_content = token.substring(1, token.len() - 1)
        return EvalResult(
            value: CellValue.TextVal(value: str_content),
            next_pos: pos + 1
        )

    # Number literal
    if _is_digit(token.char_at(0)) or (token.char_at(0) == "." and token.len() > 1):
        val num = office_parse_unsigned_decimal_f64(token)
        return EvalResult(
            value: CellValue.NumberVal(value: num),
            next_pos: pos + 1
        )

    # Identifier: could be function name or cell reference
    if _is_alpha(token.char_at(0)):
        val upper_token = token.upper()
        # Check if this is a function call: NAME(
        if pos + 1 < tokens.len() and tokens.get(pos + 1) == "(":
            return _eval_function_call(upper_token, tokens, pos + 2, sheet, depth)
        # Boolean literals
        if upper_token == "TRUE":
            return EvalResult(value: CellValue.BoolVal(value: true), next_pos: pos + 1)
        if upper_token == "FALSE":
            return EvalResult(value: CellValue.BoolVal(value: false), next_pos: pos + 1)
        # Otherwise it's a cell reference (possibly with range via colon)
        # Check if next token is ':' for a range
        if pos + 1 < tokens.len() and tokens.get(pos + 1) == ":":
            if pos + 2 < tokens.len():
                # This is a range reference like A1:B3 — return the first cell value
                val ref_val = parse_cell_ref(upper_token)
                if ref_val != nil:
                    val v = _resolve_cell_value(upper_token, sheet, depth + 1)
                    return EvalResult(
                        value: CellValue.NumberVal(value: v),
                        next_pos: pos + 3  # skip ref, colon, ref
                    )
        val ref_val = parse_cell_ref(upper_token)
        if ref_val != nil:
            val v = _resolve_cell_value(upper_token, sheet, depth + 1)
            return EvalResult(
                value: CellValue.NumberVal(value: v),
                next_pos: pos + 1
            )
        # Unknown identifier — treat as error
        return EvalResult(
            value: CellValue.ErrorVal(message: "Unknown: {token}"),
            next_pos: pos + 1
        )

    # Fallback
    EvalResult(value: CellValue.NumberVal(value: 0.0), next_pos: pos + 1)

# =========================================================================
# Function Call Evaluation
# =========================================================================

fn _is_text_function(name: text) -> bool:
    (name == "CONCAT" or name == "CONCATENATE" or name == "UPPER" or
     name == "LOWER" or name == "TRIM" or name == "LEN" or name == "LEFT" or
     name == "RIGHT" or name == "MID" or name == "EXACT" or
     name == "IMREAL" or name == "IMAGINARY" or name == "IMABS" or
     name == "IMSUM" or name == "IMSUB" or name == "IMPRODUCT" or
     name == "IMCONJUGATE")

fn _fmt_num_trim(v: f64) -> text:
    val i = v.to_i64()
    if v - i.to_f64() == 0.0:
        return "{i}"
    "{v}"

fn _format_complex(re: f64, im: f64) -> text:
    """Excel-style complex text: 3+4i, 3-4i, 4i, 3."""
    if im == 0.0:
        return _fmt_num_trim(re)
    val im_abs = if im < 0.0: 0.0 - im else: im
    val im_txt = "{_fmt_num_trim(im_abs)}i"
    if re == 0.0:
        return if im < 0.0: "-{im_txt}" else: im_txt
    if im < 0.0:
        return "{_fmt_num_trim(re)}-{im_txt}"
    "{_fmt_num_trim(re)}+{im_txt}"

fn _parse_complex(s_in: text) -> [f64]:
    """Parse a+bi / a-bi / bi / a into [re, im]."""
    val s = s_in.trim()
    if s == "":
        return [0.0, 0.0]
    if not s.ends_with("i"):
        return [s.to_f64(), 0.0]
    val body = s.slice(0, s.len() - 1)
    # find the sign separating re and im (skip index 0)
    var split = -1
    var i = body.len() - 1
    while i > 0:
        val ch = body.slice(i, i + 1)
        if ch == "+" or ch == "-":
            split = i
            i = 0
        i = i - 1
    if split <= 0:
        # pure imaginary: "i", "-i", "4i"
        if body == "" or body == "+":
            return [0.0, 1.0]
        if body == "-":
            return [0.0, -1.0]
        val im_only = body.to_f64()
        return [0.0, im_only]
    val re_txt = body.slice(0, split)
    val re = re_txt.to_f64()
    val im_txt = body.slice(split, body.len())
    if im_txt == "+":
        return [re, 1.0]
    if im_txt == "-":
        return [re, -1.0]
    val im = im_txt.to_f64()
    [re, im]

fn _eval_text_function(name: text, tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Evaluate a text function. Args are collected as display strings, so cell
    refs, string literals, and numbers all work. pos = first token after '('."""
    var args: [text] = []
    var cur_pos = pos
    while cur_pos < tokens.len() and tokens.get(cur_pos) != ")":
        val tok = tokens.get(cur_pos)
        val next_tok = if cur_pos + 1 < tokens.len(): tokens.get(cur_pos + 1) else: ""
        if tok.starts_with("\""):
            # String literal: strip the tokenizer's surrounding quotes
            args.push(tok.slice(1, tok.len() - 1))
            cur_pos = cur_pos + 1
        elif _is_cell_ref_token(tok) and (next_tok == "," or next_tok == ")"):
            # Bare cell ref: take its display text (text cells stay text —
            # the numeric evaluator would coerce them to 0)
            args.push(cell_display_text(sheet.get_cell(tok)))
            cur_pos = cur_pos + 1
        else:
            val result = _eval_comparison(tokens, cur_pos, sheet, depth)
            args.push(_cell_value_to_display(result.value))
            cur_pos = result.next_pos
        if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
            cur_pos = cur_pos + 1
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1
    EvalResult(value: _dispatch_text_function(name, args), next_pos: cur_pos)

fn _arg_int(args: [text], idx: i32) -> i32:
    """Numeric argument (e.g. LEFT's count) parsed from its display string."""
    if idx >= args.len():
        return 0
    args[idx].to_f64().to_i64().to_i32()

fn _dispatch_text_function(name: text, args: [text]) -> CellValue:
    if name == "CONCAT" or name == "CONCATENATE":
        var out = ""
        for a in args:
            out = "{out}{a}"
        return CellValue.TextVal(value: out)
    if args.len() == 0:
        return CellValue.ErrorVal(message: "{name} requires arguments")
    val s = args[0]
    if name == "UPPER":
        return CellValue.TextVal(value: s.upper())
    if name == "LOWER":
        return CellValue.TextVal(value: s.lower())
    if name == "TRIM":
        return CellValue.TextVal(value: s.trim())
    if name == "LEN":
        return CellValue.NumberVal(value: s.len().to_f64())
    if name == "LEFT":
        val n = _clamp_i32(_arg_int(args, 1), 0, s.len())
        return CellValue.TextVal(value: s.slice(0, n))
    if name == "RIGHT":
        val n = _clamp_i32(_arg_int(args, 1), 0, s.len())
        return CellValue.TextVal(value: s.slice(s.len() - n, s.len()))
    if name == "MID":
        # 1-based start, length
        val start = _clamp_i32(_arg_int(args, 1) - 1, 0, s.len())
        val length = _clamp_i32(_arg_int(args, 2), 0, s.len() - start)
        return CellValue.TextVal(value: s.slice(start, start + length))
    if name == "EXACT":
        val other = if args.len() > 1: args[1] else: ""
        return CellValue.BoolVal(value: s == other)
    if name == "IMREAL":
        return CellValue.NumberVal(value: _parse_complex(s)[0])
    if name == "IMAGINARY":
        return CellValue.NumberVal(value: _parse_complex(s)[1])
    if name == "IMABS":
        val z = _parse_complex(s)
        return CellValue.NumberVal(value: _sqrt_f64(z[0] * z[0] + z[1] * z[1]))
    if name == "IMCONJUGATE":
        val z2 = _parse_complex(s)
        return CellValue.TextVal(value: _format_complex(z2[0], 0.0 - z2[1]))
    if name == "IMSUM":
        var re_sum = 0.0
        var im_sum = 0.0
        for a in args:
            val z3 = _parse_complex(a)
            re_sum = re_sum + z3[0]
            im_sum = im_sum + z3[1]
        return CellValue.TextVal(value: _format_complex(re_sum, im_sum))
    if name == "IMSUB":
        if args.len() < 2:
            return CellValue.ErrorVal(message: "IMSUB requires 2 arguments")
        val za = _parse_complex(args[0])
        val zb = _parse_complex(args[1])
        return CellValue.TextVal(value: _format_complex(za[0] - zb[0], za[1] - zb[1]))
    if name == "IMPRODUCT":
        var re_p = 1.0
        var im_p = 0.0
        for a in args:
            val z4 = _parse_complex(a)
            val nr = re_p * z4[0] - im_p * z4[1]
            val ni = re_p * z4[1] + im_p * z4[0]
            re_p = nr
            im_p = ni
        return CellValue.TextVal(value: _format_complex(re_p, im_p))
    CellValue.ErrorVal(message: "unknown text function {name}")

fn _clamp_i32(v: i32, lo: i32, hi: i32) -> i32:
    if v < lo:
        return lo
    if v > hi:
        return hi
    v

fn _is_criteria_function(name: text) -> bool:
    name == "COUNTIF" or name == "SUMIF" or name == "AVERAGEIF"

fn _criteria_matches(display: text, value: f64, criteria: text) -> bool:
    """Excel-style criteria: >5, >=5, <5, <=5, <>x, =x, or bare equality.
    Numeric comparisons parse the rhs; equality falls back to case-insensitive
    text comparison when the rhs is not numeric."""
    var op = "="
    var rhs = criteria
    if criteria.starts_with(">="):
        op = ">="
        rhs = criteria.slice(2, criteria.len())
    elif criteria.starts_with("<="):
        op = "<="
        rhs = criteria.slice(2, criteria.len())
    elif criteria.starts_with("<>"):
        op = "<>"
        rhs = criteria.slice(2, criteria.len())
    elif criteria.starts_with(">"):
        op = ">"
        rhs = criteria.slice(1, criteria.len())
    elif criteria.starts_with("<"):
        op = "<"
        rhs = criteria.slice(1, criteria.len())
    elif criteria.starts_with("="):
        rhs = criteria.slice(1, criteria.len())
    val rhs_num = rhs.to_f64()
    val rhs_is_num = rhs_num != 0.0 or rhs.trim() == "0" or rhs.trim().starts_with("0.")
    if op == ">":
        return value > rhs_num
    if op == ">=":
        return value >= rhs_num
    if op == "<":
        return value < rhs_num
    if op == "<=":
        return value <= rhs_num
    if op == "<>":
        if rhs_is_num:
            return value != rhs_num
        return display.lower() != rhs.lower()
    if rhs_is_num:
        return value == rhs_num
    display.lower() == rhs.lower()

fn _eval_criteria_function(name: text, tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """COUNTIF/SUMIF/AVERAGEIF: (range, criteria[, sum_range])."""
    # range
    if not (pos + 2 < tokens.len() and tokens.get(pos + 1) == ":"):
        return EvalResult(value: CellValue.ErrorVal(message: "{name} requires a range"), next_pos: pos)
    val range_str = "{tokens.get(pos)}:{tokens.get(pos + 2)}"
    var cur_pos = pos + 3
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
        cur_pos = cur_pos + 1
    # criteria: quoted string or number token
    if cur_pos >= tokens.len():
        return EvalResult(value: CellValue.ErrorVal(message: "{name} requires criteria"), next_pos: cur_pos)
    var criteria = tokens.get(cur_pos)
    if criteria.starts_with("\""):
        criteria = criteria.slice(1, criteria.len() - 1)
    cur_pos = cur_pos + 1
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
        cur_pos = cur_pos + 1
    # optional sum range
    var sum_range = range_str
    if cur_pos + 2 < tokens.len() and tokens.get(cur_pos + 1) == ":" and _is_cell_ref_token(tokens.get(cur_pos)):
        sum_range = "{tokens.get(cur_pos)}:{tokens.get(cur_pos + 2)}"
        cur_pos = cur_pos + 3
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1
    val range_val = parse_range(range_str)
    val sum_val = parse_range(sum_range)
    if range_val == nil or sum_val == nil:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} invalid range"), next_pos: cur_pos)
    val refs = expand_range_refs(range_val)
    val sum_refs = expand_range_refs(sum_val)
    var count = 0
    var total = 0.0
    var i = 0
    while i < refs.len():
        val cell = sheet.get_cell(refs[i])
        val display = cell_display_text(cell)
        val num = _to_number(cell.value)
        if display != "" and _criteria_matches(display, num, criteria):
            count = count + 1
            if i < sum_refs.len():
                val sum_cell = sheet.get_cell(sum_refs[i])
                total = total + _to_number(sum_cell.value)
        i = i + 1
    if name == "COUNTIF":
        return EvalResult(value: CellValue.NumberVal(value: count.to_f64()), next_pos: cur_pos)
    if name == "AVERAGEIF":
        if count == 0:
            return EvalResult(value: CellValue.ErrorVal(message: "AVERAGEIF no matches"), next_pos: cur_pos)
        return EvalResult(value: CellValue.NumberVal(value: total / count.to_f64()), next_pos: cur_pos)
    EvalResult(value: CellValue.NumberVal(value: total), next_pos: cur_pos)

fn _is_lookup_function(name: text) -> bool:
    name == "VLOOKUP" or name == "HLOOKUP" or name == "INDEX" or name == "MATCH"

struct LookupArg:
    display: text
    num: f64
    next_pos: i32

fn _lookup_value_arg(tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> LookupArg:
    """One lookup argument: quoted string, bare cell ref, or numeric expr."""
    val tok = tokens.get(pos)
    val next_tok = if pos + 1 < tokens.len(): tokens.get(pos + 1) else: ""
    if tok.starts_with("\""):
        return LookupArg(display: tok.slice(1, tok.len() - 1), num: 0.0, next_pos: pos + 1)
    if _is_cell_ref_token(tok) and (next_tok == "," or next_tok == ")"):
        val cell = sheet.get_cell(tok)
        return LookupArg(display: cell_display_text(cell), num: _to_number(cell.value), next_pos: pos + 1)
    val r = _eval_comparison(tokens, pos, sheet, depth)
    LookupArg(display: _cell_value_to_display(r.value), num: _to_number(r.value), next_pos: r.next_pos)

fn _lookup_eq(needle_display: text, needle_num: f64, cell: Cell) -> bool:
    val d = cell_display_text(cell)
    if d.lower() == needle_display.lower():
        return true
    match cell.value:
        CellValue.NumberVal(value):
            return needle_display != "" and value == needle_num and needle_num != 0.0
        _:
            return false

fn _skip_comma(tokens: [text], pos: i32) -> i32:
    if pos < tokens.len() and tokens.get(pos) == ",":
        return pos + 1
    pos

fn _eval_lookup_function(name: text, tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """VLOOKUP(value, range, col) / HLOOKUP(value, range, row) /
    INDEX(range, row[, col]) / MATCH(value, range) — exact match semantics."""
    var cur_pos = pos
    var needle = LookupArg(display: "", num: 0.0, next_pos: cur_pos)
    if name != "INDEX":
        needle = _lookup_value_arg(tokens, cur_pos, sheet, depth)
        cur_pos = _skip_comma(tokens, needle.next_pos)
    # range
    if not (cur_pos + 2 < tokens.len() and tokens.get(cur_pos + 1) == ":"):
        return EvalResult(value: CellValue.ErrorVal(message: "{name} requires a range"), next_pos: cur_pos)
    val range_val = parse_range("{tokens.get(cur_pos)}:{tokens.get(cur_pos + 2)}")
    cur_pos = _skip_comma(tokens, cur_pos + 3)
    if range_val == nil:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} invalid range"), next_pos: cur_pos)
    # trailing numeric args (col/row indexes); ignore an optional FALSE/0 flag
    var idx1 = 1
    var idx2 = 1
    if cur_pos < tokens.len() and tokens.get(cur_pos) != ")":
        val a1 = _eval_comparison(tokens, cur_pos, sheet, depth)
        idx1 = _to_number(a1.value).to_i64().to_i32()
        cur_pos = _skip_comma(tokens, a1.next_pos)
    if cur_pos < tokens.len() and tokens.get(cur_pos) != ")":
        val a2 = _eval_comparison(tokens, cur_pos, sheet, depth)
        idx2 = _to_number(a2.value).to_i64().to_i32()
        cur_pos = _skip_comma(tokens, a2.next_pos)
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1
    val start = range_val.start
    val end_ref = range_val.end_ref
    if name == "MATCH":
        var mpos = 1
        for ref_str in expand_range_refs(range_val):
            if _lookup_eq(needle.display, needle.num, sheet.get_cell(ref_str)):
                return EvalResult(value: CellValue.NumberVal(value: mpos.to_f64()), next_pos: cur_pos)
            mpos = mpos + 1
        return EvalResult(value: CellValue.ErrorVal(message: "MATCH not found"), next_pos: cur_pos)
    if name == "INDEX":
        val target = CellRef(col: start.col + idx2 - 1, row: start.row + idx1 - 1)
        if target.col > end_ref.col or target.row > end_ref.row:
            return EvalResult(value: CellValue.ErrorVal(message: "INDEX out of range"), next_pos: cur_pos)
        return EvalResult(value: sheet.get_cell(cell_ref_to_string(target)).value, next_pos: cur_pos)
    if name == "VLOOKUP":
        var r = start.row
        while r <= end_ref.row:
            val first = cell_ref_to_string(CellRef(col: start.col, row: r))
            if _lookup_eq(needle.display, needle.num, sheet.get_cell(first)):
                val target = CellRef(col: start.col + idx1 - 1, row: r)
                if target.col > end_ref.col:
                    return EvalResult(value: CellValue.ErrorVal(message: "VLOOKUP col out of range"), next_pos: cur_pos)
                return EvalResult(value: sheet.get_cell(cell_ref_to_string(target)).value, next_pos: cur_pos)
            r = r + 1
        return EvalResult(value: CellValue.ErrorVal(message: "VLOOKUP not found"), next_pos: cur_pos)
    # HLOOKUP
    var c = start.col
    while c <= end_ref.col:
        val first = cell_ref_to_string(CellRef(col: c, row: start.row))
        if _lookup_eq(needle.display, needle.num, sheet.get_cell(first)):
            val target = CellRef(col: c, row: start.row + idx1 - 1)
            if target.row > end_ref.row:
                return EvalResult(value: CellValue.ErrorVal(message: "HLOOKUP row out of range"), next_pos: cur_pos)
            return EvalResult(value: sheet.get_cell(cell_ref_to_string(target)).value, next_pos: cur_pos)
        c = c + 1
    EvalResult(value: CellValue.ErrorVal(message: "HLOOKUP not found"), next_pos: cur_pos)

fn _is_db_function(name: text) -> bool:
    (name == "DSUM" or name == "DCOUNT" or name == "DAVERAGE" or
     name == "DMAX" or name == "DMIN" or name == "DGET")

fn _db_cell(sheet: Sheet, col: i32, row: i32) -> Cell:
    sheet.get_cell(cell_ref_to_string(CellRef(col: col, row: row)))

fn _db_header_col(sheet: Sheet, range_val: CellRange, header: text) -> i32:
    """Column index of a header name in a range's first row, or -1."""
    var c = range_val.start.col
    while c <= range_val.end_ref.col:
        val d = cell_display_text(_db_cell(sheet, c, range_val.start.row))
        if d.lower() == header.lower():
            return c
        c = c + 1
    -1

fn _eval_db_function(name: text, tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """DSUM/DCOUNT/DAVERAGE/DMAX/DMIN/DGET(database, field, criteria).
    Database and criteria ranges carry header rows; field is a quoted header
    name or 1-based column number; conditions AND across criteria columns."""
    if not (pos + 2 < tokens.len() and tokens.get(pos + 1) == ":"):
        return EvalResult(value: CellValue.ErrorVal(message: "{name} requires a database range"), next_pos: pos)
    val db = parse_range("{tokens.get(pos)}:{tokens.get(pos + 2)}")
    var cur_pos = _skip_comma(tokens, pos + 3)
    if db == nil:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} invalid database"), next_pos: cur_pos)
    # field: quoted header name or numeric 1-based index
    var field_col = -1
    val ftok = tokens.get(cur_pos)
    if ftok.starts_with("\""):
        field_col = _db_header_col(sheet, db, ftok.slice(1, ftok.len() - 1))
        cur_pos = _skip_comma(tokens, cur_pos + 1)
    else:
        val fr = _eval_comparison(tokens, cur_pos, sheet, depth)
        field_col = db.start.col + _to_number(fr.value).to_i64().to_i32() - 1
        cur_pos = _skip_comma(tokens, fr.next_pos)
    if field_col < db.start.col or field_col > db.end_ref.col:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} unknown field"), next_pos: cur_pos)
    if not (cur_pos + 2 < tokens.len() and tokens.get(cur_pos + 1) == ":"):
        return EvalResult(value: CellValue.ErrorVal(message: "{name} requires a criteria range"), next_pos: cur_pos)
    val crit = parse_range("{tokens.get(cur_pos)}:{tokens.get(cur_pos + 2)}")
    cur_pos = cur_pos + 3
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1
    if crit == nil:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} invalid criteria"), next_pos: cur_pos)
    var count = 0
    var total = 0.0
    var best = 0.0
    var got_text = ""
    var r = db.start.row + 1
    while r <= db.end_ref.row:
        var matches = true
        var cc = crit.start.col
        while cc <= crit.end_ref.col:
            val header = cell_display_text(_db_cell(sheet, cc, crit.start.row))
            var cr = crit.start.row + 1
            while cr <= crit.end_ref.row:
                val cond = cell_display_text(_db_cell(sheet, cc, cr))
                if cond != "" and header != "":
                    val dbc = _db_header_col(sheet, db, header)
                    if dbc < 0:
                        matches = false
                    else:
                        val cell = _db_cell(sheet, dbc, r)
                        if not _criteria_matches(cell_display_text(cell), _to_number(cell.value), cond):
                            matches = false
                cr = cr + 1
            cc = cc + 1
        if matches:
            val target = _db_cell(sheet, field_col, r)
            val v = _to_number(target.value)
            if count == 0:
                best = v
            elif name == "DMAX" and v > best:
                best = v
            elif name == "DMIN" and v < best:
                best = v
            total = total + v
            got_text = cell_display_text(target)
            count = count + 1
        r = r + 1
    if name == "DCOUNT":
        return EvalResult(value: CellValue.NumberVal(value: count.to_f64()), next_pos: cur_pos)
    if count == 0:
        return EvalResult(value: CellValue.ErrorVal(message: "{name} no matches"), next_pos: cur_pos)
    if name == "DSUM":
        return EvalResult(value: CellValue.NumberVal(value: total), next_pos: cur_pos)
    if name == "DAVERAGE":
        return EvalResult(value: CellValue.NumberVal(value: total / count.to_f64()), next_pos: cur_pos)
    if name == "DMAX" or name == "DMIN":
        return EvalResult(value: CellValue.NumberVal(value: best), next_pos: cur_pos)
    if count != 1:
        return EvalResult(value: CellValue.ErrorVal(message: "DGET matched {count} rows"), next_pos: cur_pos)
    EvalResult(value: CellValue.TextVal(value: got_text), next_pos: cur_pos)

fn _eval_function_call(name: text, tokens: [text], pos: i32, sheet: Sheet, depth: i32) -> EvalResult:
    """Evaluate a function call. pos points to first token after '('."""
    if _is_text_function(name):
        return _eval_text_function(name, tokens, pos, sheet, depth)
    if _is_criteria_function(name):
        return _eval_criteria_function(name, tokens, pos, sheet, depth)
    if _is_lookup_function(name):
        return _eval_lookup_function(name, tokens, pos, sheet, depth)
    if _is_db_function(name):
        return _eval_db_function(name, tokens, pos, sheet, depth)
    # Collect arguments separated by commas
    # Each argument can be a range (A1:B3) or an expression
    var args: [[f64]] = []
    var cur_pos = pos

    while cur_pos < tokens.len() and tokens.get(cur_pos) != ")":
        # Check for range argument: REF:REF
        if (cur_pos + 2 < tokens.len() and
            tokens.get(cur_pos + 1) == ":" and
            _is_cell_ref_token(tokens.get(cur_pos)) and
            _is_cell_ref_token(tokens.get(cur_pos + 2))):
            val range_str = "{tokens.get(cur_pos)}:{tokens.get(cur_pos + 2)}"
            val values = _resolve_cell_range(range_str, sheet, depth)
            args.push(values)
            cur_pos = cur_pos + 3
        else:
            # Expression argument
            val result = _eval_comparison(tokens, cur_pos, sheet, depth)
            val num_val = _to_number(result.value)
            args.push([num_val])
            cur_pos = result.next_pos

        # Skip comma
        if cur_pos < tokens.len() and tokens.get(cur_pos) == ",":
            cur_pos = cur_pos + 1

    # Skip closing paren
    if cur_pos < tokens.len() and tokens.get(cur_pos) == ")":
        cur_pos = cur_pos + 1

    val result_val = _dispatch_function(name, args, sheet)
    EvalResult(value: result_val, next_pos: cur_pos)

val _LN2 = 0.6931471805599453
val _PI = 3.141592653589793

fn _exp_f64(x: f64) -> f64:
    """e^x via argument halving + Taylor series, squared back up."""
    var v = x
    var squarings = 0
    while v > 0.5 or v < -0.5:
        v = v / 2.0
        squarings = squarings + 1
    # Taylor around 0
    var term = 1.0
    var sum = 1.0
    var n = 1
    while n <= 18:
        term = term * v / n.to_f64()
        sum = sum + term
        n = n + 1
    while squarings > 0:
        sum = sum * sum
        squarings = squarings - 1
    sum

fn _ln_f64(x: f64) -> f64:
    """Natural log via binary normalization + atanh series. x must be > 0."""
    var m = x
    var e = 0
    while m >= 2.0:
        m = m / 2.0
        e = e + 1
    while m < 1.0:
        m = m * 2.0
        e = e - 1
    val z = (m - 1.0) / (m + 1.0)
    val z2 = z * z
    var term = z
    var sum = 0.0
    var k = 1
    while k <= 30:
        sum = sum + term / k.to_f64()
        term = term * z2
        k = k + 2
    e.to_f64() * _LN2 + 2.0 * sum

fn _sin_f64(x: f64) -> f64:
    """Sine via range reduction to [-pi, pi] + Taylor series."""
    var v = x
    val two_pi = 2.0 * _PI
    while v > _PI:
        v = v - two_pi
    while v < 0.0 - _PI:
        v = v + two_pi
    var term = v
    var sum = v
    var n = 1
    while n <= 10:
        term = 0.0 - term * v * v / ((2 * n).to_f64() * (2 * n + 1).to_f64())
        sum = sum + term
        n = n + 1
    sum

fn _cos_f64(x: f64) -> f64:
    _sin_f64(x + _PI / 2.0)

fn _atan_f64(x: f64) -> f64:
    """Arctangent: series for |x|<=1, identity atan(x)=pi/2-atan(1/x) beyond."""
    if x > 1.0:
        return _PI / 2.0 - _atan_f64(1.0 / x)
    if x < -1.0:
        return 0.0 - _PI / 2.0 - _atan_f64(1.0 / x)
    # atan(x) = x / (1 + x^2/(3 + (2x)^2/(5 + (3x)^2/...))) — use Euler series
    val x2 = x * x
    var sum = 0.0
    var term = x / (1.0 + x2)
    var mult = 1.0
    var n = 0
    while n < 40:
        sum = sum + term * mult
        val k = (n + 1).to_f64()
        mult = mult * (2.0 * k) / (2.0 * k + 1.0) * (x2 / (1.0 + x2))
        n = n + 1
    sum

fn _fact_i64(n: i64) -> f64:
    var out = 1.0
    var i: i64 = 2
    while i <= n:
        out = out * i.to_f64()
        i = i + 1
    out

fn _gcd_i64(a: i64, b: i64) -> i64:
    var x = if a < 0: -a else: a
    var y = if b < 0: -b else: b
    while y != 0:
        val t = x % y
        x = y
        y = t
    x

fn _sorted_asc(values: [f64]) -> [f64]:
    """Insertion-sorted copy, ascending. ponytail: O(n^2), fine for formula args."""
    var out: [f64] = []
    for v in values:
        var inserted = false
        var result: [f64] = []
        for existing in out:
            if not inserted and v < existing:
                result.push(v)
                inserted = true
            result.push(existing)
        if not inserted:
            result.push(v)
        out = result
    out

# Civil <-> Excel-serial date conversion (Hinnant's algorithms, pure integer)
fn _days_from_civil(y_in: i64, m: i64, d: i64) -> i64:
    """Days since 1970-01-01 for a civil date."""
    var y = y_in
    if m <= 2:
        y = y - 1
    val era = (if y >= 0: y else: y - 399) / 400
    val yoe = y - era * 400
    val mp = if m > 2: m - 3 else: m + 9
    val doy = (153 * mp + 2) / 5 + d - 1
    val doe = yoe * 365 + yoe / 4 - yoe / 100 + doy
    era * 146097 + doe - 719468

fn _civil_from_days(z_in: i64) -> [i64]:
    """[year, month, day] for days since 1970-01-01."""
    val z = z_in + 719468
    val era = (if z >= 0: z else: z - 146096) / 146097
    val doe = z - era * 146097
    val yoe = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    val doy = doe - (365 * yoe + yoe / 4 - yoe / 100)
    val mp = (5 * doy + 2) / 153
    val d = doy - (153 * mp + 2) / 5 + 1
    val m = if mp < 10: mp + 3 else: mp - 9
    val y = yoe + era * 400 + (if m <= 2: 1 else: 0)
    [y, m, d]

fn _serial_from_civil(y: i64, m: i64, d: i64) -> f64:
    """Excel date serial (1900 system): days since 1899-12-30."""
    (_days_from_civil(y, m, d) + 25569).to_f64()

fn _civil_from_serial(serial: f64) -> [i64]:
    _civil_from_days(serial.to_i64() - 25569)

fn _mean(values: [f64]) -> f64:
    var sum = 0.0
    for v in values:
        sum = sum + v
    sum / values.len().to_f64()

fn _pop_variance(values: [f64]) -> f64:
    """Population variance (n denominator)."""
    val m = _mean(values)
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    sq / values.len().to_f64()

fn _covariance(ys: [f64], xs: [f64]) -> f64:
    """Population covariance of two equal-length series."""
    val my = _mean(ys)
    val mx = _mean(xs)
    var sum = 0.0
    var i = 0
    while i < ys.len():
        sum = sum + (ys[i] - my) * (xs[i] - mx)
        i = i + 1
    sum / ys.len().to_f64()

fn _sample_variance(values: [f64]) -> f64:
    """Sample variance (n-1 denominator), matching Excel VAR/STDEV."""
    val n = values.len()
    var sum = 0.0
    for v in values:
        sum = sum + v
    val mean = sum / n.to_f64()
    var sq = 0.0
    for v in values:
        val d = v - mean
        sq = sq + d * d
    sq / (n - 1).to_f64()

fn _dispatch_function(name: text, args: [[f64]], sheet: Sheet) -> CellValue:
    """Dispatch a function call by name to the appropriate implementation."""
    val flat = _flatten_args(args)
    match name:
        "SUM":
            return CellValue.NumberVal(value: eval_sum(flat))
        "AVERAGE":
            return CellValue.NumberVal(value: eval_average(flat))
        "COUNT":
            return CellValue.NumberVal(value: eval_count(flat))
        "MIN":
            return CellValue.NumberVal(value: eval_min(flat))
        "MAX":
            return CellValue.NumberVal(value: eval_max(flat))
        "PRODUCT":
            return CellValue.NumberVal(value: eval_product(flat))
        "PI":
            return CellValue.NumberVal(value: _PI)
        "SIN":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _sin_f64(flat[0]))
            return CellValue.ErrorVal(message: "SIN requires 1 argument")
        "COS":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _cos_f64(flat[0]))
            return CellValue.ErrorVal(message: "COS requires 1 argument")
        "TAN":
            if flat.len() > 0:
                val cv = _cos_f64(flat[0])
                if cv == 0.0:
                    return CellValue.ErrorVal(message: "TAN undefined")
                return CellValue.NumberVal(value: _sin_f64(flat[0]) / cv)
            return CellValue.ErrorVal(message: "TAN requires 1 argument")
        "ATAN":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _atan_f64(flat[0]))
            return CellValue.ErrorVal(message: "ATAN requires 1 argument")
        "ASIN":
            if flat.len() > 0 and flat[0] >= -1.0 and flat[0] <= 1.0:
                val v = flat[0]
                if v == 1.0:
                    return CellValue.NumberVal(value: _PI / 2.0)
                if v == -1.0:
                    return CellValue.NumberVal(value: 0.0 - _PI / 2.0)
                return CellValue.NumberVal(value: _atan_f64(v / _sqrt_f64(1.0 - v * v)))
            return CellValue.ErrorVal(message: "ASIN requires -1..1")
        "ACOS":
            if flat.len() > 0 and flat[0] >= -1.0 and flat[0] <= 1.0:
                val v = flat[0]
                if v == 1.0:
                    return CellValue.NumberVal(value: 0.0)
                if v == -1.0:
                    return CellValue.NumberVal(value: _PI)
                return CellValue.NumberVal(value: _PI / 2.0 - _atan_f64(v / _sqrt_f64(1.0 - v * v)))
            return CellValue.ErrorVal(message: "ACOS requires -1..1")
        "SINH":
            if flat.len() > 0:
                return CellValue.NumberVal(value: (_exp_f64(flat[0]) - _exp_f64(0.0 - flat[0])) / 2.0)
            return CellValue.ErrorVal(message: "SINH requires 1 argument")
        "COSH":
            if flat.len() > 0:
                return CellValue.NumberVal(value: (_exp_f64(flat[0]) + _exp_f64(0.0 - flat[0])) / 2.0)
            return CellValue.ErrorVal(message: "COSH requires 1 argument")
        "TANH":
            if flat.len() > 0:
                val e2 = _exp_f64(2.0 * flat[0])
                return CellValue.NumberVal(value: (e2 - 1.0) / (e2 + 1.0))
            return CellValue.ErrorVal(message: "TANH requires 1 argument")
        "LOG":
            if args.len() >= 2:
                val x = _first_val(args[0])
                val base = _first_val(args[1])
                if x > 0.0 and base > 0.0 and base != 1.0:
                    return CellValue.NumberVal(value: _ln_f64(x) / _ln_f64(base))
                return CellValue.ErrorVal(message: "LOG domain error")
            if flat.len() > 0 and flat[0] > 0.0:
                return CellValue.NumberVal(value: _ln_f64(flat[0]) / _ln_f64(10.0))
            return CellValue.ErrorVal(message: "LOG requires a positive argument")
        "COMBIN":
            if args.len() >= 2:
                val n = _first_val(args[0]).to_i64()
                val k = _first_val(args[1]).to_i64()
                if n >= 0 and k >= 0 and k <= n and n <= 170:
                    return CellValue.NumberVal(value: _fact_i64(n) / (_fact_i64(k) * _fact_i64(n - k)))
                return CellValue.ErrorVal(message: "COMBIN domain error")
            return CellValue.ErrorVal(message: "COMBIN requires 2 arguments")
        "PERMUT":
            if args.len() >= 2:
                val n = _first_val(args[0]).to_i64()
                val k = _first_val(args[1]).to_i64()
                if n >= 0 and k >= 0 and k <= n and n <= 170:
                    return CellValue.NumberVal(value: _fact_i64(n) / _fact_i64(n - k))
                return CellValue.ErrorVal(message: "PERMUT domain error")
            return CellValue.ErrorVal(message: "PERMUT requires 2 arguments")
        "QUOTIENT":
            if args.len() >= 2:
                val d = _first_val(args[1])
                if d == 0.0:
                    return CellValue.ErrorVal(message: "QUOTIENT by zero")
                val q = _first_val(args[0]) / d
                return CellValue.NumberVal(value: q.to_i64().to_f64())
            return CellValue.ErrorVal(message: "QUOTIENT requires 2 arguments")
        "MROUND":
            if args.len() >= 2:
                val m = _first_val(args[1])
                if m == 0.0:
                    return CellValue.NumberVal(value: 0.0)
                val q = _first_val(args[0]) / m
                val rounded = _floor_f64(q + 0.5)
                return CellValue.NumberVal(value: rounded * m)
            return CellValue.ErrorVal(message: "MROUND requires 2 arguments")
        "SQRTPI":
            if flat.len() > 0 and flat[0] >= 0.0:
                return CellValue.NumberVal(value: _sqrt_f64(flat[0] * _PI))
            return CellValue.ErrorVal(message: "SQRTPI requires a non-negative argument")
        "EXP":
            if flat.len() > 0:
                return CellValue.NumberVal(value: _exp_f64(flat[0]))
            return CellValue.ErrorVal(message: "EXP requires 1 argument")
        "LN":
            if flat.len() > 0 and flat[0] > 0.0:
                return CellValue.NumberVal(value: _ln_f64(flat[0]))
            return CellValue.ErrorVal(message: "LN requires a positive argument")
        "LOG10":
            if flat.len() > 0 and flat[0] > 0.0:
                return CellValue.NumberVal(value: _ln_f64(flat[0]) / _ln_f64(10.0))
            return CellValue.ErrorVal(message: "LOG10 requires a positive argument")
        "DEGREES":
            if flat.len() > 0:
                return CellValue.NumberVal(value: flat[0] * 180.0 / _PI)
            return CellValue.ErrorVal(message: "DEGREES requires 1 argument")
        "RADIANS":
            if flat.len() > 0:
                return CellValue.NumberVal(value: flat[0] * _PI / 180.0)
            return CellValue.ErrorVal(message: "RADIANS requires 1 argument")
        "SUMSQ":
            var sq_sum = 0.0
            for v in flat:
                sq_sum = sq_sum + v * v
            return CellValue.NumberVal(value: sq_sum)
