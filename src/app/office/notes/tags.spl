# Notes — OneNote-style note tags (To Do, Important, Question, Idea,
# Remember for Later, Definition, Contact, Custom).
#
# A Tag carries a kind ("to_do", "important", "question", "idea",
# "remember", "definition", "contact", "custom") and a name (the label
# shown next to the note item — for "to_do" this doubles as the task
# text). Tags are applied to a note ITEM: a (section, title, line) triple
# identifying one line/paragraph on a notebook page (OneNote tags attach
# per-paragraph, not per-page).
#
# Storage design mirrors notebook.spl: ONE flat table held in parallel
# arrays on TagStore — ROW i is one applied tag, columns
# entry_sections[i]/entry_titles[i]/entry_lines[i]/entry_names[i]/
# entry_kinds[i]/entry_done[i]. No Dict (corrupts under copy-return), no
# nested per-item tag lists (array-of-array crosses helper boundaries and
# misparses) — a flat row-per-application table is the flattest safe shape.
# Every mutator RETURNS the updated TagStore; callers must reassign
# (aggregates pass by copy across function calls).
#
# apply_tag is idempotent per (section, title, line, kind): re-applying
# the same kind to the same note item is a no-op (the existing row, and
# its "done" state if any, is left untouched). Two DIFFERENT kinds may
# both be applied to the same note item (a line can be both "important"
# and "to_do", as in real OneNote).
#
# find_tags is the rollup/search ("Find Tags" in OneNote): it scans every
# row in the store and returns one "section|title|line|name|done" string
# per row whose kind matches, across the whole notebook — not just one
# page.

class Tag:
    name: text
    kind: text
    done: bool

    static fn new(name: text, kind: text) -> Tag:
        Tag(name: name, kind: kind, done: false)

class TagStore:
    entry_sections: [text]
    entry_titles: [text]
    entry_lines: [i64]
    entry_names: [text]
    entry_kinds: [text]
    entry_done: [bool]

    static fn new() -> TagStore:
        TagStore(entry_sections: [], entry_titles: [], entry_lines: [], entry_names: [], entry_kinds: [], entry_done: [])

fn tag_store_new() -> TagStore:
    TagStore.new()

fn _entry_index(store: TagStore, section: text, title: text, line: i64, kind: text) -> i64:
    """Row index of the (section, title, line, kind) tag application, or -1."""
    var i = 0
    while i < store.entry_sections.len():
        val s = store.entry_sections[i]
        val t = store.entry_titles[i]
        val l = store.entry_lines[i]
        val k = store.entry_kinds[i]
        if s == section and t == title and l == line and k == kind:
            return i
        i = i + 1
    -1

fn apply_tag(store: TagStore, section: text, title: text, line: i64, name: text, kind: text) -> TagStore:
    """Apply a tag to a note item (section, title, line). No-op if this
    exact (section, title, line, kind) tag is already applied — the
    existing row (and its done state) is left untouched."""
    var out = store
    val idx = _entry_index(out, section, title, line, kind)
    if idx >= 0:
        return out
    out.entry_sections.push(section)
    out.entry_titles.push(title)
    out.entry_lines.push(line)
    out.entry_names.push(name)
    out.entry_kinds.push(kind)
    out.entry_done.push(false)
    out

fn remove_tag(store: TagStore, section: text, title: text, line: i64, kind: text) -> TagStore:
    """Remove the (section, title, line, kind) tag; no-op if absent.
    Rebuilds the parallel arrays (no in-place index deletion)."""
    val idx = _entry_index(store, section, title, line, kind)
    if idx < 0:
        return store
    var out = store
    var keep_sections: [text] = []
    var keep_titles: [text] = []
    var keep_lines: [i64] = []
    var keep_names: [text] = []
    var keep_kinds: [text] = []
    var keep_done: [bool] = []
    var i = 0
    while i < out.entry_sections.len():
        if i != idx:
            keep_sections.push(out.entry_sections[i])
            keep_titles.push(out.entry_titles[i])
            keep_lines.push(out.entry_lines[i])
            keep_names.push(out.entry_names[i])
            keep_kinds.push(out.entry_kinds[i])
            keep_done.push(out.entry_done[i])
        i = i + 1
    out.entry_sections = keep_sections
    out.entry_titles = keep_titles
    out.entry_lines = keep_lines
    out.entry_names = keep_names
    out.entry_kinds = keep_kinds
    out.entry_done = keep_done
    out

fn mark_tag_done(store: TagStore, section: text, title: text, line: i64, done: bool) -> TagStore:
    """Mark the "to_do" tag on note item (section, title, line) done or
    undone. No-op if that note item carries no "to_do" tag."""
    val idx = _entry_index(store, section, title, line, "to_do")
    if idx < 0:
        return store
    var out = store
    var new_done: [bool] = []
    var i = 0
    while i < out.entry_done.len():
        if i == idx:
            new_done.push(done)
        else:
            new_done.push(out.entry_done[i])
        i = i + 1
    out.entry_done = new_done
    out

fn tags_on(store: TagStore, section: text, title: text, line: i64) -> [Tag]:
    """All tags applied to note item (section, title, line), in the order
    they were applied."""
    var out: [Tag] = []
    var i = 0
    while i < store.entry_sections.len():
        val s = store.entry_sections[i]
        val t = store.entry_titles[i]
        val l = store.entry_lines[i]
        if s == section and t == title and l == line:
            var tag = Tag.new(store.entry_names[i], store.entry_kinds[i])
            tag.done = store.entry_done[i]
            out.push(tag)
        i = i + 1
    out

fn _bool_text(b: bool) -> text:
    if b:
        return "true"
    "false"

fn find_tags(store: TagStore, kind: text) -> [text]:
    """Rollup/search ("Find Tags"): every note item across the whole
    store carrying a tag of `kind`, formatted
    "section|title|line|name|done", in application order."""
    var hits: [text] = []
    var i = 0
    while i < store.entry_kinds.len():
        val k = store.entry_kinds[i]
        if k == kind:
            val line_text = store.entry_lines[i].to_text()
            val done_text = _bool_text(store.entry_done[i])
            hits.push(store.entry_sections[i] + "|" + store.entry_titles[i] + "|" + line_text + "|" + store.entry_names[i] + "|" + done_text)
        i = i + 1
    hits
