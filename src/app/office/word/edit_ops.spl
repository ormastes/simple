# Document Editing Operations
#
# Pure functions for word/character/paragraph count, text search/replace,
# and plain-text extraction over RichDocument.

use common.rich_text.attributed_text.{RichDocument, DocBlock, BlockKind, TextSpan, InlineStyle, spans_to_plain_text, block_to_plain_text}

# =========================================================================
# Types
# =========================================================================

struct DocStats:
    words: i64
    characters: i64
    paragraphs: i64

# =========================================================================
# Plain Text Extraction
# =========================================================================

fn document_plain_text(doc: RichDocument) -> text:
    """Extract plain text from document: blocks joined by newlines,
    span markup dropped, list items prefixed '- ', headings without # markers."""
    var out = ""
    var first = true
    for block in doc.blocks:
        val block_text = block_to_plain_text(block)
        val content = match block.kind:
            case BulletItem: "- {block_text}"
            case OrderedItem: block_text
            case Heading1: block_text
            case Heading2: block_text
            case Heading3: block_text
            case Paragraph: block_text
            case Quote: block_text
            case CodeBlock: block_text
            case FootnoteDef: block_text
        if not first:
            out = "{out}\n"
        out = "{out}{content}"
        first = false
    out

# =========================================================================
# Text Search
# =========================================================================

fn document_find(doc: RichDocument, needle: text) -> [text]:
    """Search for needle in document blocks and return hit locations as
    'blockIndex:charOffset' strings (case-sensitive, searching concatenated
    plain text of each block)."""
    var hits: [text] = []
    var block_idx = 0
    for block in doc.blocks:
        val plain = block_to_plain_text(block)
        var offset = 0
        while offset + needle.len() <= plain.len():
            if plain.slice(offset, offset + needle.len()) == needle:
                hits.push("{block_idx}:{offset}")
            offset = offset + 1
        block_idx = block_idx + 1
    hits

# =========================================================================
# Text Replacement
# =========================================================================

fn document_replace(doc: RichDocument, needle: text, replacement: text) -> RichDocument:
    """Replace all occurrences of needle with replacement in span text content.
    Replaces within each span's text independently; does not merge or restyle spans.
    Returns new document (aggregates copied)."""
    var new_blocks: [DocBlock] = []
    for block in doc.blocks:
        var new_spans: [TextSpan] = []
        for span in block.spans:
            val new_text = _replace_all(span.text, needle, replacement)
            new_spans.push(TextSpan(text: new_text, style: span.style, link_url: span.link_url, footnote_id: span.footnote_id, comment_id: span.comment_id, revision_id: span.revision_id))
        new_blocks.push(DocBlock(kind: block.kind, spans: new_spans))
    RichDocument(title: doc.title, blocks: new_blocks, comments: doc.comments, revisions: doc.revisions)

fn _replace_all(text_: text, needle: text, replacement: text) -> text:
    """Replace all occurrences of needle in text_ with replacement."""
    if needle.len() == 0:
        return text_
    var out = ""
    var i = 0
    while i < text_.len():
        if i + needle.len() <= text_.len() and text_.slice(i, i + needle.len()) == needle:
            out = "{out}{replacement}"
            i = i + needle.len()
        else:
            out = "{out}{text_.slice(i, i + 1)}"
            i = i + 1
    out

# =========================================================================
# Document Statistics
# =========================================================================

fn document_stats(doc: RichDocument) -> DocStats:
    """Count words (whitespace-separated tokens), characters (excluding
    newlines), and paragraphs (non-empty text blocks)."""
    var words: i64 = 0
    var characters: i64 = 0
    var paragraphs: i64 = 0

    for block in doc.blocks:
        val plain = block_to_plain_text(block)
        if plain.trim().len() > 0:
            paragraphs = paragraphs + 1
            # Count characters (excluding newlines, but the plain text shouldn't have them within a block)
            characters = characters + plain.len()
            # Count words by splitting on whitespace
            val tokens = plain.split(" ")
            for token in tokens:
                if token.trim().len() > 0:
                    words = words + 1

    DocStats(words: words, characters: characters, paragraphs: paragraphs)

fn document_word_count_new(doc: RichDocument) -> i64:
    """Count words in document (whitespace-separated tokens)."""
    val stats = document_stats(doc)
    stats.words

fn document_character_count(doc: RichDocument) -> i64:
    """Count characters in document (excluding newlines)."""
    val stats = document_stats(doc)
    stats.characters

fn document_paragraph_count(doc: RichDocument) -> i64:
    """Count paragraphs in document (non-empty text blocks)."""
    val stats = document_stats(doc)
    stats.paragraphs
