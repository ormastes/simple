# Word Citations & Bibliography
#
# Pure functions modeling Word's "Citations & Bibliography" feature: a small
# library of citation Sources, in-text citations rendered from a source's
# tag, and a formatted (APA-ish) bibliography sorted by author last name.
#
# Provides: Source, source_new, Bibliography, bibliography_new,
# bibliography_add, in_text_citation, bibliography_entries_apa,
# bibliography_render_html, source_count.
#
# Ground truth:
# - in_text_citation looks up a Source by tag and renders "(<LastName>, <year>)"
#   where LastName is the text before the first comma in `author`. Unknown
#   tag -> "(??)".
# - bibliography_entries_apa renders "<author> (<year>). <title>. <publisher>."
#   per source, sorted ascending by author last name (stable insertion sort).
# - bibliography_render_html wraps the sorted APA entries in an
#   <ol class="bibliography"> with one escaped <li> per entry.

struct Source:
    tag: text
    author: text
    title: text
    year: text
    publisher: text

fn source_new(tag: text, author: text, title: text, year: text, publisher: text) -> Source:
    Source(tag: tag, author: author, title: title, year: year, publisher: publisher)

struct Bibliography:
    sources: [Source]

fn bibliography_new() -> Bibliography:
    """An empty bibliography with no sources."""
    Bibliography(sources: [])

fn bibliography_add(bib: Bibliography, source: Source) -> Bibliography:
    """Append `source` to `bib`'s source list, returning the updated
    bibliography (bib is not mutated in place)."""
    var sources_copy = bib.sources
    sources_copy.push(source)
    Bibliography(sources: sources_copy)

fn source_count(bib: Bibliography) -> i32:
    """Number of sources currently in `bib`."""
    bib.sources.len()

# =========================================================================
# Author last-name extraction
# =========================================================================

fn _last_name(author: text) -> text:
    """The text before the first comma in `author` (trimmed), which is the
    "Last, First" convention's last-name component."""
    val parts = author.split(",")
    if parts.len() == 0:
        return author.trim()
    parts[0].trim()

# =========================================================================
# In-text citation
# =========================================================================

fn in_text_citation(bib: Bibliography, tag: text) -> text:
    """The parenthetical in-text citation for the source tagged `tag`:
    "(<LastName>, <year>)". Returns "(??)" when no source has that tag."""
    for source in bib.sources:
        if source.tag == tag:
            val last = _last_name(source.author)
            return "({last}, {source.year})"
    "(??)"

# =========================================================================
# APA bibliography entries (sorted by author last name)
# =========================================================================

fn _apa_entry(source: Source) -> text:
    """One APA-ish reference line: "<author> (<year>). <title>. <publisher>." """
    "{source.author} ({source.year}). {source.title}. {source.publisher}."

fn bibliography_entries_apa(bib: Bibliography) -> [text]:
    """APA-ish reference lines for every source in `bib`, one per line,
    sorted ascending by author last name (stable insertion sort — ties keep
    their original relative order)."""
    var sources_copy: [Source] = []
    for source in bib.sources:
        sources_copy.push(source)
    var n = sources_copy.len()
    var a = 1
    while a < n:
        val key_source = sources_copy[a]
        val key_last = _last_name(key_source.author)
        var b = a - 1
        var shifting = true
        while shifting and b >= 0:
            val cur_last = _last_name(sources_copy[b].author)
            if key_last < cur_last:
                sources_copy[b + 1] = sources_copy[b]
                b = b - 1
            else:
                shifting = false
        sources_copy[b + 1] = key_source
        a = a + 1
    var entries: [text] = []
    for source in sources_copy:
        entries.push(_apa_entry(source))
    entries

# =========================================================================
# HTML rendering
# =========================================================================

fn _html_escape(s: text) -> text:
    """Escape HTML metacharacters so citation content can't inject markup."""
    var result = s
    result = result.replace("&", "&amp;")
    result = result.replace("<", "&lt;")
    result = result.replace(">", "&gt;")
    result

fn bibliography_render_html(bib: Bibliography) -> text:
    """Render `bib`'s sorted APA entries as an <ol class="bibliography">
    with one escaped <li> per entry, as a single HTML string."""
    val entries = bibliography_entries_apa(bib)
    var items: [text] = []
    for entry in entries:
        items.push("<li>{_html_escape(entry)}</li>")
    val body = items.join("")
    "<ol class=\"bibliography\">{body}</ol>"
