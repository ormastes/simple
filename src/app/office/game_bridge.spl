# Game ↔ Office Data Bridge
#
# Lets the game-dev tool (examples/11_advanced/game2d) consume office documents
# as data sources. The genuine, common pattern implemented here is
# Calc-as-game-data: a game reads its level layout / tuning table from a
# spreadsheet by cell reference, getting back the cells' display strings.
#
# Draw (sprites from vector graphics) and Base (game state in a DB) are declared
# connection targets but are pending the drawing vector-shape model + the f64
# toolchain fix (Draw) and a simple_db query surface (Base); they are NOT claimed
# as implemented.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}

fn game_office_connections() -> [text]:
    """The office data sources the game tool can connect to."""
    ["calc", "draw", "db"]

fn game_connection_is_implemented(target: text) -> bool:
    """Whether a connection target is wired today (only 'calc' so far)."""
    target == "calc"

fn game_implemented_connections() -> [text]:
    """The connection targets actually wired today."""
    var live: [text] = []
    for c in game_office_connections():
        if game_connection_is_implemented(c):
            live.push(c)
    live

fn calc_cells_to_game_values(sheet: Sheet, refs: [text]) -> [text]:
    """Read the given spreadsheet cells as game data: returns each cell's display
    string in order, so a game can pull tuning values / level tokens from a Calc
    sheet by reference."""
    var out: [text] = []
    for ref in refs:
        val cell = sheet.get_cell(ref)
        out.push(cell_display_text(cell))
    out

fn calc_row_to_game_tokens(sheet: Sheet, refs: [text]) -> text:
    """A game-friendly single-string row: the referenced cells joined by spaces
    (e.g. a level-layout row read from a spreadsheet)."""
    val values = calc_cells_to_game_values(sheet, refs)
    values.join(" ")
