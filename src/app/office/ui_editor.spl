# Office UI Editor
#
# Pure HTML design-surface substrate for office UI/document mockups. This is the
# Figma-like layer for positioned frames/components, while SDD remains the
# canonical diagram interchange format.

use std.common.markdown.inline.{markdown_escape_html}

struct OfficeUiNode:
    id: text
    label: text
    kind: text
    css: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    component: text

struct OfficeUiDesign:
    name: text
    width: text
    height: text
    nodes: [OfficeUiNode]

struct OfficeUiEditResult:
    accepted: bool
    reason: text
    diff: text
    design: OfficeUiDesign

struct OfficeUiInspector:
    found: bool
    reason: text
    id: text
    label: text
    kind: text
    css: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    component: text
    z_index: text

struct OfficeUiI64Result:
    ok: bool
    value: i64

fn office_ui_editor_format_name() -> text:
    "HTML UI Design Document"

fn office_ui_design_empty() -> OfficeUiDesign:
    OfficeUiDesign(name: "", width: "960", height: "540", nodes: [])

fn office_ui_node(id: text, label: text, kind: text, x: text, y: text, width: text, height: text) -> OfficeUiNode:
    OfficeUiNode(id: id, label: label, kind: kind, css: "", x: x, y: y, width: width, height: height, layer: "", component: "")

fn office_ui_design_parse(source: text) -> OfficeUiDesign:
    var design = office_ui_design_empty()
    val lines = source.split("\n")
    for raw in lines:
        val line = raw.trim()
        if line == "" or line.starts_with("#"):
            continue
        if line.starts_with("design:"):
            design.name = line.slice(7, line.len()).trim()
        elif line.starts_with("size:"):
            val size_text = line.slice(5, line.len()).trim()
            val dims = size_text.split("x")
            if dims.len() >= 2:
                design.width = dims[0].trim()
                design.height = dims[1].trim()
        elif line.starts_with("node "):
            val node_text = line.slice(5, line.len()).trim()
            val node = _office_ui_parse_dense_node(node_text)
            design.nodes.push(node)
    design

fn office_ui_design_render_html(design: OfficeUiDesign) -> text:
    office_ui_design_render_html_with_selection(design, "")

fn office_ui_design_render_html_with_selection(design: OfficeUiDesign, selected_id: text) -> text:
    val w = _office_ui_safe_length(design.width)
    val h = _office_ui_safe_length(design.height)
    var out = "<div class=\"office-ui-design\" data-format=\"html-ui\" data-format-name=\"" + office_ui_editor_format_name() + "\" data-design=\"" + markdown_escape_html(design.name) + "\" data-selected-node-id=\"" + markdown_escape_html(selected_id) + "\" style=\"position: relative; width: " + w + "; height: " + h + "; box-sizing: border-box; background: #ffffff; border: 1px solid #d1d5db; overflow: hidden;\">"
    var z_index = 0
    for node in design.nodes:
        val selected = node.id == selected_id
        val selected_class = if selected then " office-ui-selected" else: ""
        val selected_value = if selected then "true" else: "false"
        val class_name = "office-ui-node office-ui-" + _office_ui_safe_token(node.kind) + _office_ui_css_class(node.css) + selected_class
        val node_z = _office_ui_layer_z_index(node.layer, z_index)
        val style = "position: absolute; left: " + _office_ui_safe_length(node.x) + "; top: " + _office_ui_safe_length(node.y) + "; width: " + _office_ui_safe_length(node.width) + "; height: " + _office_ui_safe_length(node.height) + "; z-index: " + node_z + "; box-sizing: border-box; border: 1px solid #6b7280; background: #f9fafb; color: #111827; overflow: hidden;"
        out = out + "<div class=\"" + class_name + "\" data-id=\"" + markdown_escape_html(node.id) + "\" data-kind=\"" + markdown_escape_html(node.kind) + "\" data-layer=\"" + markdown_escape_html(node.layer) + "\" data-z-index=\"" + node_z + "\" data-selected=\"" + selected_value + "\" aria-selected=\"" + selected_value + "\" data-component=\"" + markdown_escape_html(node.component) + "\" style=\"" + style + "\">" + markdown_escape_html(node.label) + "</div>"
        z_index = z_index + 1
    out + "</div>"

fn office_ui_design_to_sdd(design: OfficeUiDesign) -> text:
    var out: [text] = []
    out.push("graph: " + design.name)
    out.push("theme: office-ui")
    out.push("")
    out.push("nodes |id, label, css, role, shape, x, y, width, height, layer|")
    for node in design.nodes:
        val shape = if node.kind == "frame" then "frame" else: "rounded"
        val role = if node.component != "" then node.component else: node.kind
        out.push("    " + node.id + ", " + _office_ui_quote_if_space(node.label) + ", " + _office_ui_quote_if_space(node.css) + ", " + role + ", " + shape + ", " + node.x + ", " + node.y + ", " + node.width + ", " + node.height + ", " + node.layer)
    out.push("")
    out.push("edges |from, to, label, css, kind, route, waypoints, start_anchor, end_anchor|")
    out.join("\n") + "\n"

fn office_ui_design_update_label_checked(design: OfficeUiDesign, node_id: text, expected: text, replacement: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.label != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node " + node_id + " @@\nexpected: " + expected + "\nactual: " + current.label + "\nrejected: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.label = replacement
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node " + node_id + " @@\nexpected: " + expected + "\nactual: <missing>\nrejected: " + replacement, design: design)

fn office_ui_design_update_layout_checked(design: OfficeUiDesign, node_id: text, expected_x: text, expected_y: text, expected_width: text, expected_height: text, new_x: text, new_y: text, new_width: text, new_height: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            val actual = current.x + "," + current.y + "," + current.width + "," + current.height
            val expected = expected_x + "," + expected_y + "," + expected_width + "," + expected_height
            val replacement = new_x + "," + new_y + "," + new_width + "," + new_height
            if actual != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-layout " + node_id + " @@\nexpected: " + expected + "\nactual: " + actual + "\nrejected: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.x = new_x
            updated.y = new_y
            updated.width = new_width
            updated.height = new_height
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-layout " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-layout " + node_id + " @@\nexpected: " + expected_x + "," + expected_y + "," + expected_width + "," + expected_height + "\nactual: <missing>\nrejected: " + new_x + "," + new_y + "," + new_width + "," + new_height, design: design)

fn office_ui_design_update_layer_checked(design: OfficeUiDesign, node_id: text, expected_layer: text, new_layer: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.layer != expected_layer:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-layer " + node_id + " @@\nexpected: " + expected_layer + "\nactual: " + current.layer + "\nrejected: " + new_layer, design: design)
            var updated = _office_ui_clone_node(current)
            updated.layer = new_layer
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-layer " + node_id + " @@\n- " + expected_layer + "\n+ " + new_layer, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-layer " + node_id + " @@\nexpected: " + expected_layer + "\nactual: <missing>\nrejected: " + new_layer, design: design)

fn office_ui_design_update_css_checked(design: OfficeUiDesign, node_id: text, expected_css: text, new_css: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.css != expected_css:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-css " + node_id + " @@\nexpected: " + expected_css + "\nactual: " + current.css + "\nrejected: " + new_css, design: design)
            var updated = _office_ui_clone_node(current)
            updated.css = new_css
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-css " + node_id + " @@\n- " + expected_css + "\n+ " + new_css, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-css " + node_id + " @@\nexpected: " + expected_css + "\nactual: <missing>\nrejected: " + new_css, design: design)

fn office_ui_design_update_style_token_checked(design: OfficeUiDesign, node_id: text, expected_token: text, new_token: text) -> OfficeUiEditResult:
    office_ui_design_update_css_checked(design, node_id, expected_token, new_token)

fn office_ui_design_read_style_token(design: OfficeUiDesign, node_id: text) -> OfficeUiInspector:
    office_ui_design_inspect_node(design, node_id)

fn office_ui_design_geometry_signature(design: OfficeUiDesign, node_ids: [text]) -> text:
    var parts: [text] = []
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            parts.push(node.id + ":" + node.x + "," + node.y + "," + node.width + "," + node.height)
    parts.join(";")

fn office_ui_design_align_checked(design: OfficeUiDesign, node_ids: [text], expected_signature: text, mode: text) -> OfficeUiEditResult:
    val actual_signature = office_ui_design_geometry_signature(design, node_ids)
    if actual_signature != expected_signature:
        return OfficeUiEditResult(accepted: false, reason: "stale-selection", diff: "@@ ui-align " + mode + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, design: design)
    if node_ids.len() < 2:
        return OfficeUiEditResult(accepted: false, reason: "invalid-selection", diff: "@@ ui-align " + mode + " @@\nexpected: at least 2 nodes\nactual: " + node_ids.len().to_text(), design: design)
    val selected_count = _office_ui_selected_count(design, node_ids)
    if selected_count != node_ids.len():
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-align " + mode + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, design: design)
    if not _office_ui_align_mode_supported(mode):
        return OfficeUiEditResult(accepted: false, reason: "unsupported-align-mode", diff: "@@ ui-align " + mode + " @@\nexpected: left|center|right|top|middle|bottom\nactual: " + mode, design: design)
    val bounds = _office_ui_selected_bounds(design, node_ids)
    if not bounds.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _office_ui_id_in_list(node.id, node_ids):
            val aligned = _office_ui_align_node(node, mode, bounds)
            if not aligned.ok:
                return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
            out.nodes[i] = aligned.node
        i = i + 1
    val new_signature = office_ui_design_geometry_signature(out, node_ids)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-align " + mode + " @@\n- " + expected_signature + "\n+ " + new_signature, design: out)

fn office_ui_design_distribute_checked(design: OfficeUiDesign, node_ids: [text], expected_signature: text, axis: text) -> OfficeUiEditResult:
    val actual_signature = office_ui_design_geometry_signature(design, node_ids)
    if actual_signature != expected_signature:
        return OfficeUiEditResult(accepted: false, reason: "stale-selection", diff: "@@ ui-distribute " + axis + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, design: design)
    if node_ids.len() < 3:
        return OfficeUiEditResult(accepted: false, reason: "invalid-selection", diff: "@@ ui-distribute " + axis + " @@\nexpected: at least 3 nodes\nactual: " + node_ids.len().to_text(), design: design)
    val selected_count = _office_ui_selected_count(design, node_ids)
    if selected_count != node_ids.len():
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-distribute " + axis + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, design: design)
    if axis != "horizontal" and axis != "vertical":
        return OfficeUiEditResult(accepted: false, reason: "unsupported-distribute-axis", diff: "@@ ui-distribute " + axis + " @@\nexpected: horizontal|vertical\nactual: " + axis, design: design)
    val bounds = _office_ui_selected_bounds(design, node_ids)
    if not bounds.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    val total_span = _office_ui_selected_axis_size(design, node_ids, axis)
    if not total_span.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    val available = if axis == "horizontal": bounds.max_x - bounds.min_x else: bounds.max_y - bounds.min_y
    val gap = (available - total_span.value) / (selected_count - 1)
    var cursor = if axis == "horizontal": bounds.min_x else: bounds.min_y
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _office_ui_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal": _office_ui_parse_i64_result(node.width) else: _office_ui_parse_i64_result(node.height)
            if not size.ok:
                return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
            var updated = _office_ui_clone_node(node)
            if axis == "horizontal":
                updated.x = cursor.to_text()
            else:
                updated.y = cursor.to_text()
            out.nodes[i] = updated
            cursor = cursor + size.value + gap
        i = i + 1
    val new_signature = office_ui_design_geometry_signature(out, node_ids)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-distribute " + axis + " @@\n- " + expected_signature + "\n+ " + new_signature, design: out)

fn office_ui_design_inspect_node(design: OfficeUiDesign, node_id: text) -> OfficeUiInspector:
    var index = 0
    while index < design.nodes.len():
        val node = design.nodes[index]
        if node.id == node_id:
            return OfficeUiInspector(
                found: true,
                reason: "selected",
                id: node.id,
                label: node.label,
                kind: node.kind,
                css: node.css,
                x: node.x,
                y: node.y,
                width: node.width,
                height: node.height,
                layer: node.layer,
                component: node.component,
                z_index: _office_ui_layer_z_index(node.layer, index)
            )
        index = index + 1
    OfficeUiInspector(found: false, reason: "missing-node", id: node_id, label: "", kind: "", css: "", x: "", y: "", width: "", height: "", layer: "", component: "", z_index: "")

struct OfficeUiBounds:
    ok: bool
    min_x: i64
    min_y: i64
    max_x: i64
    max_y: i64

struct OfficeUiAlignedNode:
    ok: bool
    node: OfficeUiNode

fn _office_ui_clone_node(node: OfficeUiNode) -> OfficeUiNode:
    OfficeUiNode(
        id: node.id,
        label: node.label,
        kind: node.kind,
        css: node.css,
        x: node.x,
        y: node.y,
        width: node.width,
        height: node.height,
        layer: node.layer,
        component: node.component
    )

fn _office_ui_parse_dense_node(line: text) -> OfficeUiNode:
    val parts = line.split("|")
    var node = office_ui_node("", "", "component", "0", "0", "120", "40")
    if parts.len() >= 1:
        node.id = parts[0].trim()
    if parts.len() >= 2:
        node.label = parts[1].trim()
    if parts.len() >= 3:
        node.kind = parts[2].trim()
    if parts.len() >= 4:
        node.x = parts[3].trim()
    if parts.len() >= 5:
        node.y = parts[4].trim()
    if parts.len() >= 6:
        node.width = parts[5].trim()
    if parts.len() >= 7:
        node.height = parts[6].trim()
    if parts.len() >= 8:
        node.css = parts[7].trim()
    if parts.len() >= 9:
        node.layer = parts[8].trim()
    if parts.len() >= 10:
        node.component = parts[9].trim()
    node

fn _office_ui_safe_token(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        val code = ch.char_code_at(0)
        if (code >= 48 and code <= 57) or (code >= 65 and code <= 90) or (code >= 97 and code <= 122) or ch == "-" or ch == "_":
            out = out + ch
        i = i + 1
    if out == "":
        return "component"
    out

fn _office_ui_css_class(css: text) -> text:
    val safe = _office_ui_safe_token(css)
    if safe == "component" and css.trim() == "":
        return ""
    " office-ui-css-" + safe

fn _office_ui_layer_z_index(layer: text, fallback: i64) -> text:
    val trimmed = layer.trim()
    if _office_ui_is_i64_token(trimmed):
        return trimmed
    fallback.to_text()

fn _office_ui_is_i64_token(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        val code = ch.char_code_at(0)
        if i == 0 and ch == "-":
            if value.len() == 1:
                return false
        elif code < 48 or code > 57:
            return false
        i = i + 1
    true

fn _office_ui_safe_length(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        return "0px"
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        val code = ch.char_code_at(0)
        val ok = (code >= 48 and code <= 57) or ch == "." or ch == "-" or ch == "%"
        if not ok:
            if trimmed.ends_with("px") or trimmed.ends_with("em") or trimmed.ends_with("rem"):
                return trimmed
            return "0px"
        i = i + 1
    if trimmed.ends_with("%"):
        return trimmed
    trimmed + "px"

fn _office_ui_quote_if_space(value: text) -> text:
    if value.contains(" "):
        return "\"" + value + "\""
    value

fn _office_ui_id_in_list(node_id: text, node_ids: [text]) -> bool:
    for id in node_ids:
        if id == node_id:
            return true
    false

fn _office_ui_selected_count(design: OfficeUiDesign, node_ids: [text]) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            count = count + 1
    count

fn _office_ui_selected_axis_size(design: OfficeUiDesign, node_ids: [text], axis: text) -> OfficeUiI64Result:
    var total: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal": _office_ui_parse_i64_result(node.width) else: _office_ui_parse_i64_result(node.height)
            if not size.ok:
                return OfficeUiI64Result(ok: false, value: 0)
            total = total + size.value
    OfficeUiI64Result(ok: true, value: total)

fn _office_ui_align_mode_supported(mode: text) -> bool:
    mode == "left" or mode == "center" or mode == "right" or mode == "top" or mode == "middle" or mode == "bottom"

fn _office_ui_selected_bounds(design: OfficeUiDesign, node_ids: [text]) -> OfficeUiBounds:
    var initialized = false
    var min_x: i64 = 0
    var min_y: i64 = 0
    var max_x: i64 = 0
    var max_y: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            val x = _office_ui_parse_i64_result(node.x)
            val y = _office_ui_parse_i64_result(node.y)
            val w = _office_ui_parse_i64_result(node.width)
            val h = _office_ui_parse_i64_result(node.height)
            if not x.ok or not y.ok or not w.ok or not h.ok:
                return OfficeUiBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
            val right = x.value + w.value
            val bottom = y.value + h.value
            if not initialized:
                min_x = x.value
                min_y = y.value
                max_x = right
                max_y = bottom
                initialized = true
            else:
                if x.value < min_x:
                    min_x = x.value
                if y.value < min_y:
                    min_y = y.value
                if right > max_x:
                    max_x = right
                if bottom > max_y:
                    max_y = bottom
    if not initialized:
        return OfficeUiBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
    OfficeUiBounds(ok: true, min_x: min_x, min_y: min_y, max_x: max_x, max_y: max_y)

fn _office_ui_align_node(node: OfficeUiNode, mode: text, bounds: OfficeUiBounds) -> OfficeUiAlignedNode:
    val x = _office_ui_parse_i64_result(node.x)
    val y = _office_ui_parse_i64_result(node.y)
    val w = _office_ui_parse_i64_result(node.width)
    val h = _office_ui_parse_i64_result(node.height)
    if not x.ok or not y.ok or not w.ok or not h.ok:
        return OfficeUiAlignedNode(ok: false, node: node)
    var updated = _office_ui_clone_node(node)
    if mode == "left":
        updated.x = bounds.min_x.to_text()
    elif mode == "center":
        val center = (bounds.min_x + bounds.max_x) / 2
        updated.x = (center - (w.value / 2)).to_text()
    elif mode == "right":
        updated.x = (bounds.max_x - w.value).to_text()
    elif mode == "top":
        updated.y = bounds.min_y.to_text()
    elif mode == "middle":
        val middle = (bounds.min_y + bounds.max_y) / 2
        updated.y = (middle - (h.value / 2)).to_text()
    elif mode == "bottom":
        updated.y = (bounds.max_y - h.value).to_text()
    OfficeUiAlignedNode(ok: true, node: updated)

fn _office_ui_parse_i64_result(value: text) -> OfficeUiI64Result:
    val trimmed = value.trim()
    if not _office_ui_is_i64_token(trimmed):
        return OfficeUiI64Result(ok: false, value: 0)
    var negative = false
    var i = 0
    if trimmed.char_at(0) == "-":
        negative = true
        i = 1
    var out: i64 = 0
    while i < trimmed.len():
        out = out * 10 + (trimmed.char_at(i).char_code_at(0) - 48).to_i64()
        i = i + 1
    if negative:
        out = 0 - out
    OfficeUiI64Result(ok: true, value: out)
