# Office UI Editor
#
# Pure HTML design-surface substrate for office UI/document mockups. This is the
# Figma-like layer for positioned frames/components, while SDD remains the
# canonical diagram interchange format.

use std.common.markdown.inline.{markdown_escape_html}

struct OfficeUiNode:
    id: text
    label: text
    kind: text
    css: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    component: text
    parent: text
    layout_mode: text
    layout_gap: text
    layout_padding: text
    constraint_horizontal: text
    constraint_vertical: text

struct OfficeUiDesign:
    name: text
    width: text
    height: text
    nodes: [OfficeUiNode]

struct OfficeUiEditResult:
    accepted: bool
    reason: text
    diff: text
    design: OfficeUiDesign

struct OfficeUiInspector:
    found: bool
    reason: text
    id: text
    label: text
    kind: text
    css: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    component: text
    z_index: text
    parent: text
    layout_mode: text
    constraint_horizontal: text
    constraint_vertical: text

struct OfficeUiI64Result:
    ok: bool
    value: i64

fn office_ui_editor_format_name() -> text:
    "HTML UI Design Document"

fn office_ui_design_empty() -> OfficeUiDesign:
    OfficeUiDesign(name: "", width: "960", height: "540", nodes: [])

fn office_ui_node(id: text, label: text, kind: text, x: text, y: text, width: text, height: text) -> OfficeUiNode:
    OfficeUiNode(id: id, label: label, kind: kind, css: "", x: x, y: y, width: width, height: height, layer: "", component: "", parent: "", layout_mode: "off", layout_gap: "0", layout_padding: "0,0,0,0", constraint_horizontal: "left", constraint_vertical: "top")

fn office_ui_design_parse(source: text) -> OfficeUiDesign:
    var design = office_ui_design_empty()
    val lines = source.split("\n")
    for raw in lines:
        val line = raw.trim()
        if line == "" or line.starts_with("#"):
            continue
        if line.starts_with("design:"):
            design.name = line.slice(7, line.len()).trim()
        elif line.starts_with("size:"):
            val size_text = line.slice(5, line.len()).trim()
            val dims = size_text.split("x")
            if dims.len() >= 2:
                design.width = dims[0].trim()
                design.height = dims[1].trim()
        elif line.starts_with("node "):
            val node_text = line.slice(5, line.len()).trim()
            val node = _office_ui_parse_dense_node(node_text)
            design.nodes.push(node)
    design

fn office_ui_design_render_html(design: OfficeUiDesign) -> text:
    office_ui_design_render_html_with_selection(design, "")

fn office_ui_design_render_html_with_selection(design: OfficeUiDesign, selected_id: text) -> text:
    val resolved = office_ui_design_resolve_auto_layout(design)
    val w = _office_ui_safe_length(resolved.width)
    val h = _office_ui_safe_length(resolved.height)
    val frame_count = _office_ui_kind_count(resolved, "frame")
    val component_count = _office_ui_component_count(resolved)
    var out = "<div class=\"office-ui-design\" data-format=\"html-ui\" data-format-name=\"" + office_ui_editor_format_name() + "\" data-design=\"" + markdown_escape_html(resolved.name) + "\" data-node-count=\"" + resolved.nodes.len().to_text() + "\" data-frame-count=\"" + frame_count.to_text() + "\" data-component-count=\"" + component_count.to_text() + "\" data-canvas-width=\"" + markdown_escape_html(resolved.width) + "\" data-canvas-height=\"" + markdown_escape_html(resolved.height) + "\" data-selected-node-id=\"" + markdown_escape_html(selected_id) + "\" style=\"position: relative; width: " + w + "; height: " + h + "; box-sizing: border-box; background: #ffffff; border: 1px solid #d1d5db; overflow: hidden;\">"
    var z_index = 0
    for node in resolved.nodes:
        val selected = node.id == selected_id
        val selected_class = if selected then " office-ui-selected" else: ""
        val selected_value = if selected then "true" else: "false"
        val class_name = "office-ui-node office-ui-" + _office_ui_safe_token(node.kind) + _office_ui_css_class(node.css) + selected_class
        val node_z = _office_ui_layer_z_index(node.layer, z_index)
        val child_count = _office_ui_child_count(resolved, node.id)
        val has_children = if child_count > 0 then "true" else: "false"
        val style = "position: absolute; left: " + _office_ui_safe_length(node.x) + "; top: " + _office_ui_safe_length(node.y) + "; width: " + _office_ui_safe_length(node.width) + "; height: " + _office_ui_safe_length(node.height) + "; z-index: " + node_z + "; box-sizing: border-box; border: 1px solid #6b7280; background: #f9fafb; color: #111827; overflow: hidden;"
        out = out + "<div class=\"" + class_name + "\" data-id=\"" + markdown_escape_html(node.id) + "\" data-node-index=\"" + z_index.to_text() + "\" data-label=\"" + markdown_escape_html(node.label) + "\" data-kind=\"" + markdown_escape_html(node.kind) + "\" data-x=\"" + markdown_escape_html(node.x) + "\" data-y=\"" + markdown_escape_html(node.y) + "\" data-width=\"" + markdown_escape_html(node.width) + "\" data-height=\"" + markdown_escape_html(node.height) + "\" data-layer=\"" + markdown_escape_html(node.layer) + "\" data-z-index=\"" + node_z + "\" data-selected=\"" + selected_value + "\" aria-selected=\"" + selected_value + "\" data-component=\"" + markdown_escape_html(node.component) + "\" data-parent=\"" + markdown_escape_html(node.parent) + "\" data-child-count=\"" + child_count.to_text() + "\" data-has-children=\"" + has_children + "\" data-layout-mode=\"" + markdown_escape_html(node.layout_mode) + "\" data-layout-gap=\"" + markdown_escape_html(node.layout_gap) + "\" data-layout-padding=\"" + markdown_escape_html(node.layout_padding) + "\" data-constraint-h=\"" + markdown_escape_html(node.constraint_horizontal) + "\" data-constraint-v=\"" + markdown_escape_html(node.constraint_vertical) + "\" style=\"" + style + "\">" + markdown_escape_html(node.label) + _office_ui_selection_handles(selected, node.id, z_index) + "</div>"
        z_index = z_index + 1
    out + "</div>"

fn office_ui_design_layers_summary(design: OfficeUiDesign) -> text:
    var lines: [text] = []
    var index = 0
    for node in design.nodes:
        lines.push("index=" + index.to_text() + " id=" + node.id + " label=" + node.label + " kind=" + node.kind + " layer=" + node.layer + " z_index=" + _office_ui_layer_z_index(node.layer, index) + " parent=" + node.parent + " component=" + node.component)
        index = index + 1
    lines.join("\n")

fn office_ui_design_style_tokens_summary(design: OfficeUiDesign) -> text:
    var lines: [text] = ["nodes=" + design.nodes.len().to_text()]
    for node in design.nodes:
        lines.push(node.id + "=" + node.css)
    lines.join("\n")

fn _office_ui_selection_handles(selected: bool, node_id: text, node_index: i64) -> text:
    if not selected:
        return ""
    val base = "position: absolute; width: 8px; height: 8px; box-sizing: border-box; border: 1px solid #2563eb; background: #ffffff;"
    val node_attr = markdown_escape_html(node_id)
    val index_attr = node_index.to_text()
    "<span class=\"office-ui-resize-handle office-ui-resize-nw\" data-resize-handle=\"nw\" data-edit-action=\"resize-node\" data-handle-index=\"0\" data-handle-label=\"Resize northwest\" data-anchor-x=\"left\" data-anchor-y=\"top\" data-opposite-anchor-x=\"right\" data-opposite-anchor-y=\"bottom\" data-delta-x=\"-1\" data-delta-y=\"-1\" data-cursor=\"nwse-resize\" data-node=\"" + node_attr + "\" data-node-index=\"" + index_attr + "\" aria-hidden=\"true\" style=\"" + base + " left: -5px; top: -5px; cursor: nwse-resize;\"></span><span class=\"office-ui-resize-handle office-ui-resize-ne\" data-resize-handle=\"ne\" data-edit-action=\"resize-node\" data-handle-index=\"1\" data-handle-label=\"Resize northeast\" data-anchor-x=\"right\" data-anchor-y=\"top\" data-opposite-anchor-x=\"left\" data-opposite-anchor-y=\"bottom\" data-delta-x=\"1\" data-delta-y=\"-1\" data-cursor=\"nesw-resize\" data-node=\"" + node_attr + "\" data-node-index=\"" + index_attr + "\" aria-hidden=\"true\" style=\"" + base + " right: -5px; top: -5px; cursor: nesw-resize;\"></span><span class=\"office-ui-resize-handle office-ui-resize-sw\" data-resize-handle=\"sw\" data-edit-action=\"resize-node\" data-handle-index=\"2\" data-handle-label=\"Resize southwest\" data-anchor-x=\"left\" data-anchor-y=\"bottom\" data-opposite-anchor-x=\"right\" data-opposite-anchor-y=\"top\" data-delta-x=\"-1\" data-delta-y=\"1\" data-cursor=\"nesw-resize\" data-node=\"" + node_attr + "\" data-node-index=\"" + index_attr + "\" aria-hidden=\"true\" style=\"" + base + " left: -5px; bottom: -5px; cursor: nesw-resize;\"></span><span class=\"office-ui-resize-handle office-ui-resize-se\" data-resize-handle=\"se\" data-edit-action=\"resize-node\" data-handle-index=\"3\" data-handle-label=\"Resize southeast\" data-anchor-x=\"right\" data-anchor-y=\"bottom\" data-opposite-anchor-x=\"left\" data-opposite-anchor-y=\"top\" data-delta-x=\"1\" data-delta-y=\"1\" data-cursor=\"nwse-resize\" data-node=\"" + node_attr + "\" data-node-index=\"" + index_attr + "\" aria-hidden=\"true\" style=\"" + base + " right: -5px; bottom: -5px; cursor: nwse-resize;\"></span>"

fn _office_ui_kind_count(design: OfficeUiDesign, kind: text) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if node.kind == kind:
            count = count + 1
    count

fn _office_ui_component_count(design: OfficeUiDesign) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if node.component != "":
            count = count + 1
    count

fn _office_ui_child_count(design: OfficeUiDesign, parent_id: text) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if node.parent == parent_id:
            count = count + 1
    count

fn office_ui_design_to_sdd(design: OfficeUiDesign) -> text:
    val resolved = office_ui_design_resolve_auto_layout(design)
    var out: [text] = []
    out.push("graph: " + resolved.name)
    out.push("theme: office-ui")
    out.push("")
    out.push("nodes |id, label, css, role, shape, x, y, width, height, layer, parent, layout_mode, layout_gap, layout_padding, constraint_h, constraint_v|")
    for node in resolved.nodes:
        val shape = if node.kind == "frame" then "frame" else: "rounded"
        val role = if node.component != "" then node.component else: node.kind
        out.push("    " + node.id + ", " + _office_ui_quote_if_space(node.label) + ", " + _office_ui_quote_if_space(node.css) + ", " + role + ", " + shape + ", " + node.x + ", " + node.y + ", " + node.width + ", " + node.height + ", " + node.layer + ", " + node.parent + ", " + node.layout_mode + ", " + node.layout_gap + ", " + _office_ui_quote_if_space(node.layout_padding) + ", " + node.constraint_horizontal + ", " + node.constraint_vertical)
    out.push("")
    out.push("edges |from, to, label, css, kind, route, waypoints, start_anchor, end_anchor, label_x, label_y|")
    out.join("\n") + "\n"

fn office_ui_design_update_label_checked(design: OfficeUiDesign, node_id: text, expected: text, replacement: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.label != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node " + node_id + " @@\nexpected: " + expected + "\nactual: " + current.label + "\nrejected: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.label = replacement
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node " + node_id + " @@\nexpected: " + expected + "\nactual: <missing>\nrejected: " + replacement, design: design)

fn office_ui_design_update_name_checked(design: OfficeUiDesign, expected: text, replacement: text) -> OfficeUiEditResult:
    if replacement.trim() == "":
        return OfficeUiEditResult(accepted: false, reason: "invalid-name", diff: "@@ ui-design-name @@\nexpected: non-empty design name\nactual: " + replacement, design: design)
    if design.name != expected:
        return OfficeUiEditResult(accepted: false, reason: "stale-design", diff: "@@ ui-design-name @@\nexpected: " + expected + "\nactual: " + design.name + "\nrejected: " + replacement, design: design)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-design-name @@\n- " + expected + "\n+ " + replacement, design: OfficeUiDesign(name: replacement, width: design.width, height: design.height, nodes: design.nodes))

fn office_ui_design_update_canvas_checked(design: OfficeUiDesign, expected_width: text, expected_height: text, new_width: text, new_height: text) -> OfficeUiEditResult:
    val actual = design.width + "," + design.height
    val expected = expected_width + "," + expected_height
    val replacement = new_width + "," + new_height
    if actual != expected:
        return OfficeUiEditResult(accepted: false, reason: "stale-canvas", diff: "@@ ui-canvas @@\nexpected: " + expected + "\nactual: " + actual + "\nrejected: " + replacement, design: design)
    if not _office_ui_positive_i64_token(new_width) or not _office_ui_positive_i64_token(new_height):
        return OfficeUiEditResult(accepted: false, reason: "invalid-canvas", diff: "@@ ui-canvas @@\nexpected: positive width/height\nactual: " + replacement, design: design)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-canvas @@\n- " + expected + "\n+ " + replacement, design: OfficeUiDesign(name: design.name, width: new_width, height: new_height, nodes: design.nodes))

fn office_ui_design_update_layout_checked(design: OfficeUiDesign, node_id: text, expected_x: text, expected_y: text, expected_width: text, expected_height: text, new_x: text, new_y: text, new_width: text, new_height: text) -> OfficeUiEditResult:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            val actual = current.x + "," + current.y + "," + current.width + "," + current.height
            val expected = expected_x + "," + expected_y + "," + expected_width + "," + expected_height
            val replacement = new_x + "," + new_y + "," + new_width + "," + new_height
            if actual != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-layout " + node_id + " @@\nexpected: " + expected + "\nactual: " + actual + "\nrejected: " + replacement, design: design)
            if not _office_ui_is_i64_token(new_x) or not _office_ui_is_i64_token(new_y) or not _office_ui_positive_i64_token(new_width) or not _office_ui_positive_i64_token(new_height):
                return OfficeUiEditResult(accepted: false, reason: "invalid-layout", diff: "@@ ui-node-layout " + node_id + " @@\nexpected: integer x/y and positive width/height\nactual: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.x = new_x
            updated.y = new_y
            updated.width = new_width
            updated.height = new_height
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-layout " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-layout " + node_id + " @@\nexpected: " + expected_x + "," + expected_y + "," + expected_width + "," + expected_height + "\nactual: <missing>\nrejected: " + new_x + "," + new_y + "," + new_width + "," + new_height, design: design)

fn office_ui_design_add_node_checked(design: OfficeUiDesign, node: OfficeUiNode) -> OfficeUiEditResult:
    if node.id == "" or _office_ui_node_id_exists(design, node.id):
        return OfficeUiEditResult(accepted: false, reason: "duplicate-id", diff: "@@ ui-add-node @@\nexpected: unused id\nactual: " + node.id, design: design)
    if node.parent != "" and not _office_ui_node_id_exists(design, node.parent):
        return OfficeUiEditResult(accepted: false, reason: "missing-parent", diff: "@@ ui-add-node @@\nexpected-parent: " + node.parent + "\nactual: missing", design: design)
    if node.kind.trim() == "" or _office_ui_safe_token(node.kind.trim()) != node.kind.trim() or node.component.trim() == "" or _office_ui_safe_token(node.component.trim()) != node.component.trim():
        return OfficeUiEditResult(accepted: false, reason: "invalid-token", diff: "@@ ui-add-node @@\nexpected: safe kind/component\nactual: " + node.kind + "," + node.component, design: design)
    if not _office_ui_is_i64_token(node.x) or not _office_ui_is_i64_token(node.y) or not _office_ui_positive_i64_token(node.width) or not _office_ui_positive_i64_token(node.height):
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-add-node @@\nexpected: integer x/y and positive width/height\nactual: " + node.x + "," + node.y + "," + node.width + "," + node.height, design: design)
    if not _office_ui_layout_mode_supported(node.layout_mode) or not _office_ui_constraint_horizontal_supported(node.constraint_horizontal) or not _office_ui_constraint_vertical_supported(node.constraint_vertical):
        return OfficeUiEditResult(accepted: false, reason: "invalid-layout", diff: "@@ ui-add-node @@\nexpected: supported layout mode and constraints\nactual: " + node.layout_mode + "," + node.constraint_horizontal + "," + node.constraint_vertical, design: design)
    val gap = _office_ui_parse_i64_result(node.layout_gap)
    val padding = _office_ui_parse_padding(node.layout_padding)
    if not gap.ok or gap.value < 0 or not padding.ok or padding.top < 0 or padding.right < 0 or padding.bottom < 0 or padding.left < 0:
        return OfficeUiEditResult(accepted: false, reason: "invalid-layout", diff: "@@ ui-add-node @@\nexpected: nonnegative integer gap/padding\nactual: " + node.layout_gap + "," + node.layout_padding, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    out_nodes.push(_office_ui_clone_node(node))
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-add-node @@\n+ " + node.id, design: OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes))

fn office_ui_design_duplicate_node_checked(design: OfficeUiDesign, source_id: text, new_id: text, dx: text, dy: text) -> OfficeUiEditResult:
    if source_id == "" or new_id == "":
        return OfficeUiEditResult(accepted: false, reason: "invalid-id", diff: "@@ ui-duplicate-node @@\nexpected: non-empty source and new id\nactual: " + source_id + " -> " + new_id, design: design)
    if _office_ui_node_id_exists(design, new_id):
        return OfficeUiEditResult(accepted: false, reason: "duplicate-id", diff: "@@ ui-duplicate-node @@\nexpected: unused id\nactual: " + new_id, design: design)
    if _office_ui_node_id_count(design, source_id) > 1:
        return OfficeUiEditResult(accepted: false, reason: "ambiguous-source", diff: "@@ ui-duplicate-node @@\nexpected: one source node\nactual: " + source_id, design: design)
    val x_offset = _office_ui_parse_i64_result(dx)
    val y_offset = _office_ui_parse_i64_result(dy)
    if not x_offset.ok or not y_offset.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-offset", diff: "@@ ui-duplicate-node @@\nexpected: integer dx/dy\nactual: " + dx + "," + dy, design: design)
    var out_nodes: [OfficeUiNode] = []
    var found = false
    for node in design.nodes:
        out_nodes.push(_office_ui_clone_node(node))
        if node.id == source_id:
            if _office_ui_parent_layout_mode(design, node.parent) != "off":
                return OfficeUiEditResult(accepted: false, reason: "auto-layout-child", diff: "@@ ui-duplicate-node @@\nexpected: source outside auto-layout parent\nactual: " + node.parent, design: design)
            val x = _office_ui_parse_i64_result(node.x)
            val y = _office_ui_parse_i64_result(node.y)
            val width = _office_ui_parse_i64_result(node.width)
            val height = _office_ui_parse_i64_result(node.height)
            if not x.ok or not y.ok or not width.ok or width.value <= 0 or not height.ok or height.value <= 0:
                return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-duplicate-node @@\nexpected: integer source x/y and positive width/height\nactual: " + node.x + "," + node.y + "," + node.width + "," + node.height, design: design)
            var copy = _office_ui_clone_node(node)
            copy.id = new_id
            copy.x = (x.value + x_offset.value).to_text()
            copy.y = (y.value + y_offset.value).to_text()
            out_nodes.push(copy)
            found = true
    if not found:
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-duplicate-node @@\nexpected: " + source_id + "\nactual: missing", design: design)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-duplicate-node @@\n+ " + new_id, design: OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes))

fn office_ui_design_delete_node_checked(design: OfficeUiDesign, node_id: text) -> OfficeUiEditResult:
    if not _office_ui_node_id_exists(design, node_id):
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-delete-node @@\nexpected: " + node_id + "\nactual: missing", design: design)
    var out_nodes: [OfficeUiNode] = []
    var deleted: [text] = []
    for node in design.nodes:
        if node.id == node_id or _office_ui_is_descendant_of(design, node.id, node_id):
            deleted.push(node.id)
        else:
            out_nodes.push(_office_ui_clone_node(node))
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-delete-node @@\n- " + deleted.join(","), design: OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes))

fn office_ui_design_reorder_node_checked(design: OfficeUiDesign, node_id: text, position: text) -> OfficeUiEditResult:
    val idx = _office_ui_find_node_index(design, node_id)
    if idx < 0:
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-order-node @@\nexpected: " + node_id + "\nactual: missing", design: design)
    if position != "front" and position != "back":
        return OfficeUiEditResult(accepted: false, reason: "invalid-position", diff: "@@ ui-order-node @@\nexpected: front|back\nactual: " + position, design: design)
    val moving = _office_ui_clone_node(design.nodes[idx])
    var out_nodes: [OfficeUiNode] = []
    if position == "back":
        out_nodes.push(moving)
    var i = 0
    while i < design.nodes.len():
        if i != idx:
            out_nodes.push(_office_ui_clone_node(design.nodes[i]))
        i = i + 1
    if position == "front":
        out_nodes.push(moving)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-order-node @@\n" + node_id + " -> " + position, design: OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes))

fn office_ui_design_update_layer_checked(design: OfficeUiDesign, node_id: text, expected_layer: text, new_layer: text) -> OfficeUiEditResult:
    if not _office_ui_is_i64_token(new_layer):
        return OfficeUiEditResult(accepted: false, reason: "invalid-layer", diff: "@@ ui-node-layer " + node_id + " @@\nexpected: integer z-order\nactual: " + new_layer, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.layer != expected_layer:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-layer " + node_id + " @@\nexpected: " + expected_layer + "\nactual: " + current.layer + "\nrejected: " + new_layer, design: design)
            var updated = _office_ui_clone_node(current)
            updated.layer = new_layer
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-layer " + node_id + " @@\n- " + expected_layer + "\n+ " + new_layer, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-layer " + node_id + " @@\nexpected: " + expected_layer + "\nactual: <missing>\nrejected: " + new_layer, design: design)

