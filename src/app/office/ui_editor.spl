fn office_ui_design_update_style_token_checked(design: OfficeUiDesign, node_id: text, expected_token: text, new_token: text) -> OfficeUiEditResult:
    office_ui_design_update_css_checked(design, node_id, expected_token, new_token)

fn office_ui_design_update_kind_checked(design: OfficeUiDesign, node_id: text, expected_kind: text, new_kind: text) -> OfficeUiEditResult:
    val safe_kind = _office_ui_safe_token(new_kind.trim())
    if new_kind.trim() == "" or safe_kind != new_kind.trim():
        return OfficeUiEditResult(accepted: false, reason: "invalid-kind", diff: "@@ ui-node-kind " + node_id + " @@\nexpected: non-empty safe kind\nactual: " + new_kind, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.kind != expected_kind:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-kind " + node_id + " @@\nexpected: " + expected_kind + "\nactual: " + current.kind + "\nrejected: " + new_kind, design: design)
            var updated = _office_ui_clone_node(current)
            updated.kind = new_kind
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-kind " + node_id + " @@\n- " + expected_kind + "\n+ " + new_kind, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-kind " + node_id + " @@\nexpected: " + expected_kind + "\nactual: <missing>\nrejected: " + new_kind, design: design)

fn office_ui_design_update_component_checked(design: OfficeUiDesign, node_id: text, expected_component: text, new_component: text) -> OfficeUiEditResult:
