        val current = design.nodes[i]
        if current.id == node_id:
            if current.component != expected_component:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-node-component " + node_id + " @@\nexpected: " + expected_component + "\nactual: " + current.component + "\nrejected: " + new_component, design: design)
            var updated = _office_ui_clone_node(current)
            updated.component = new_component
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-node-component " + node_id + " @@\n- " + expected_component + "\n+ " + new_component, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-node-component " + node_id + " @@\nexpected: " + expected_component + "\nactual: <missing>\nrejected: " + new_component, design: design)

fn office_ui_design_read_style_token(design: OfficeUiDesign, node_id: text) -> OfficeUiInspector:
    office_ui_design_inspect_node(design, node_id)

fn office_ui_design_geometry_signature(design: OfficeUiDesign, node_ids: [text]) -> text:
    var parts: [text] = []
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            parts.push(node.id + ":" + node.x + "," + node.y + "," + node.width + "," + node.height)
    parts.join(";")

fn office_ui_design_align_checked(design: OfficeUiDesign, node_ids: [text], expected_signature: text, mode: text) -> OfficeUiEditResult:
    val actual_signature = office_ui_design_geometry_signature(design, node_ids)
    if actual_signature != expected_signature:
        return OfficeUiEditResult(accepted: false, reason: "stale-selection", diff: "@@ ui-align " + mode + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, design: design)
    if node_ids.len() < 2:
        return OfficeUiEditResult(accepted: false, reason: "invalid-selection", diff: "@@ ui-align " + mode + " @@\nexpected: at least 2 nodes\nactual: " + node_ids.len().to_text(), design: design)
    val selected_count = _office_ui_selected_count(design, node_ids)
    if selected_count != node_ids.len():
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-align " + mode + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, design: design)
    if not _office_ui_align_mode_supported(mode):
        return OfficeUiEditResult(accepted: false, reason: "unsupported-align-mode", diff: "@@ ui-align " + mode + " @@\nexpected: left|center|right|top|middle|bottom\nactual: " + mode, design: design)
    val bounds = _office_ui_selected_bounds(design, node_ids)
    if not bounds.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _office_ui_id_in_list(node.id, node_ids):
            val aligned = _office_ui_align_node(node, mode, bounds)
            if not aligned.ok:
                return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
            out.nodes[i] = aligned.node
        i = i + 1
    val new_signature = office_ui_design_geometry_signature(out, node_ids)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-align " + mode + " @@\n- " + expected_signature + "\n+ " + new_signature, design: out)

fn office_ui_design_distribute_checked(design: OfficeUiDesign, node_ids: [text], expected_signature: text, axis: text) -> OfficeUiEditResult:
    val actual_signature = office_ui_design_geometry_signature(design, node_ids)
    if actual_signature != expected_signature:
        return OfficeUiEditResult(accepted: false, reason: "stale-selection", diff: "@@ ui-distribute " + axis + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, design: design)
    if node_ids.len() < 3:
        return OfficeUiEditResult(accepted: false, reason: "invalid-selection", diff: "@@ ui-distribute " + axis + " @@\nexpected: at least 3 nodes\nactual: " + node_ids.len().to_text(), design: design)
    val selected_count = _office_ui_selected_count(design, node_ids)
    if selected_count != node_ids.len():
        return OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-distribute " + axis + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, design: design)
    if axis != "horizontal" and axis != "vertical":
        return OfficeUiEditResult(accepted: false, reason: "unsupported-distribute-axis", diff: "@@ ui-distribute " + axis + " @@\nexpected: horizontal|vertical\nactual: " + axis, design: design)
    val bounds = _office_ui_selected_bounds(design, node_ids)
    if not bounds.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    val total_span = _office_ui_selected_axis_size(design, node_ids, axis)
    if not total_span.ok:
        return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
    val available = if axis == "horizontal": bounds.max_x - bounds.min_x else: bounds.max_y - bounds.min_y
    val gap = (available - total_span.value) / (selected_count - 1)
    var cursor = if axis == "horizontal": bounds.min_x else: bounds.min_y
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _office_ui_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal": _office_ui_parse_i64_result(node.width) else: _office_ui_parse_i64_result(node.height)
            if not size.ok:
                return OfficeUiEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ ui-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, design: design)
            var updated = _office_ui_clone_node(node)
            if axis == "horizontal":
                updated.x = cursor.to_text()
            else:
                updated.y = cursor.to_text()
            out.nodes[i] = updated
            cursor = cursor + size.value + gap
        i = i + 1
    val new_signature = office_ui_design_geometry_signature(out, node_ids)
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-distribute " + axis + " @@\n- " + expected_signature + "\n+ " + new_signature, design: out)

fn office_ui_design_auto_layout_signature(design: OfficeUiDesign) -> text:
    var parts: [text] = []
    for node in design.nodes:
        parts.push(node.id + ":" + node.parent + "," + node.layout_mode + "," + node.layout_gap + "," + node.layout_padding + "," + node.constraint_horizontal + "," + node.constraint_vertical + "," + node.x + "," + node.y + "," + node.width + "," + node.height)
    parts.join(";")

fn office_ui_design_resolve_auto_layout(design: OfficeUiDesign) -> OfficeUiDesign:
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val container = out.nodes[i]
        if container.kind == "frame" and _office_ui_layout_mode_supported(container.layout_mode) and container.layout_mode != "off":
            out = _office_ui_apply_container_layout(out, container)
        i = i + 1
    out

fn office_ui_design_update_auto_layout_checked(design: OfficeUiDesign, node_id: text, expected_mode: text, expected_gap: text, expected_padding: text, new_mode: text, new_gap: text, new_padding: text) -> OfficeUiEditResult:
    val gap = _office_ui_parse_i64_result(new_gap)
    val padding = _office_ui_parse_padding(new_padding)
    if not _office_ui_layout_mode_supported(new_mode) or not gap.ok or gap.value < 0 or not padding.ok or padding.top < 0 or padding.right < 0 or padding.bottom < 0 or padding.left < 0:
        return OfficeUiEditResult(accepted: false, reason: "invalid-layout", diff: "@@ ui-auto-layout " + node_id + " @@\nexpected: off|horizontal|vertical and nonnegative integer gap/padding\nactual: " + new_mode + "," + new_gap + "," + new_padding, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            val actual = current.layout_mode + "," + current.layout_gap + "," + current.layout_padding
            val expected = expected_mode + "," + expected_gap + "," + expected_padding
            val replacement = new_mode + "," + new_gap + "," + new_padding
            if actual != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-auto-layout " + node_id + " @@\nexpected: " + expected + "\nactual: " + actual + "\nrejected: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.layout_mode = new_mode
            updated.layout_gap = new_gap
            updated.layout_padding = new_padding
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-auto-layout " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-auto-layout " + node_id + " @@\nexpected: " + expected_mode + "," + expected_gap + "," + expected_padding + "\nactual: <missing>\nrejected: " + new_mode + "," + new_gap + "," + new_padding, design: design)

fn office_ui_design_update_constraint_checked(design: OfficeUiDesign, node_id: text, expected_horizontal: text, expected_vertical: text, new_horizontal: text, new_vertical: text) -> OfficeUiEditResult:
    if not _office_ui_constraint_horizontal_supported(new_horizontal) or not _office_ui_constraint_vertical_supported(new_vertical):
        return OfficeUiEditResult(accepted: false, reason: "invalid-layout", diff: "@@ ui-constraints " + node_id + " @@\nexpected: left|right|center|stretch\nactual: " + new_horizontal + "," + new_vertical, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            val actual = current.constraint_horizontal + "," + current.constraint_vertical
            val expected = expected_horizontal + "," + expected_vertical
            val replacement = new_horizontal + "," + new_vertical
            if actual != expected:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-constraints " + node_id + " @@\nexpected: " + expected + "\nactual: " + actual + "\nrejected: " + replacement, design: design)
            var updated = _office_ui_clone_node(current)
            updated.constraint_horizontal = new_horizontal
            updated.constraint_vertical = new_vertical
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-constraints " + node_id + " @@\n- " + expected + "\n+ " + replacement, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-constraints " + node_id + " @@\nexpected: " + expected_horizontal + "," + expected_vertical + "\nactual: <missing>\nrejected: " + new_horizontal + "," + new_vertical, design: design)

fn office_ui_design_set_parent_checked(design: OfficeUiDesign, node_id: text, expected_parent: text, new_parent: text) -> OfficeUiEditResult:
    if new_parent != "" and _office_ui_find_node_index(design, new_parent) < 0:
        return OfficeUiEditResult(accepted: false, reason: "missing-parent", diff: "@@ ui-parent " + node_id + " @@\nexpected-parent: " + expected_parent + "\nactual-parent: <missing " + new_parent + ">", design: design)
    if new_parent == node_id or _office_ui_parent_chain_contains(design, new_parent, node_id):
        return OfficeUiEditResult(accepted: false, reason: "cycle-parent", diff: "@@ ui-parent " + node_id + " @@\nrejected-cycle: " + new_parent, design: design)
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var i = 0
    while i < design.nodes.len():
        val current = design.nodes[i]
        if current.id == node_id:
            if current.parent != expected_parent:
                return OfficeUiEditResult(accepted: false, reason: "stale-node", diff: "@@ ui-parent " + node_id + " @@\nexpected: " + expected_parent + "\nactual: " + current.parent + "\nrejected: " + new_parent, design: design)
            var updated = _office_ui_clone_node(current)
            updated.parent = new_parent
            out.nodes[i] = updated
            return OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-parent " + node_id + " @@\n- " + expected_parent + "\n+ " + new_parent, design: out)
        i = i + 1
    OfficeUiEditResult(accepted: false, reason: "missing-node", diff: "@@ ui-parent " + node_id + " @@\nexpected: " + expected_parent + "\nactual: <missing>\nrejected: " + new_parent, design: design)

fn office_ui_design_resolve_layout_checked(design: OfficeUiDesign, expected_signature: text) -> OfficeUiEditResult:
    val actual_signature = office_ui_design_auto_layout_signature(design)
    if actual_signature != expected_signature:
        return OfficeUiEditResult(accepted: false, reason: "stale-layout", diff: "@@ ui-auto-layout-resolve @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, design: design)
    val resolved = office_ui_design_resolve_auto_layout(design)
    val new_signature = office_ui_design_geometry_signature(resolved, _office_ui_all_node_ids(resolved))
    OfficeUiEditResult(accepted: true, reason: "updated", diff: "@@ ui-auto-layout-resolve @@\n- " + actual_signature + "\n+ " + new_signature, design: resolved)

fn office_ui_design_inspect_node(design: OfficeUiDesign, node_id: text) -> OfficeUiInspector:
    var index = 0
    while index < design.nodes.len():
        val node = design.nodes[index]
        if node.id == node_id:
            return OfficeUiInspector(
                found: true,
                reason: "selected",
                id: node.id,
                label: node.label,
                kind: node.kind,
                css: node.css,
                x: node.x,
                y: node.y,
                width: node.width,
                height: node.height,
                layer: node.layer,
                component: node.component,
                z_index: _office_ui_layer_z_index(node.layer, index),
                parent: node.parent,
                layout_mode: node.layout_mode,
                constraint_horizontal: node.constraint_horizontal,
                constraint_vertical: node.constraint_vertical
            )
        index = index + 1
    OfficeUiInspector(found: false, reason: "missing-node", id: node_id, label: "", kind: "", css: "", x: "", y: "", width: "", height: "", layer: "", component: "", z_index: "", parent: "", layout_mode: "", constraint_horizontal: "", constraint_vertical: "")

struct OfficeUiBounds:
    ok: bool
    min_x: i64
    min_y: i64
    max_x: i64
    max_y: i64

struct OfficeUiAlignedNode:
    ok: bool
    node: OfficeUiNode

struct OfficeUiPadding:
    ok: bool
    top: i64
    right: i64
    bottom: i64
    left: i64

fn _office_ui_clone_node(node: OfficeUiNode) -> OfficeUiNode:
    OfficeUiNode(
        id: node.id,
        label: node.label,
        kind: node.kind,
        css: node.css,
        x: node.x,
        y: node.y,
        width: node.width,
        height: node.height,
        layer: node.layer,
        component: node.component,
        parent: node.parent,
        layout_mode: node.layout_mode,
        layout_gap: node.layout_gap,
        layout_padding: node.layout_padding,
        constraint_horizontal: node.constraint_horizontal,
        constraint_vertical: node.constraint_vertical
    )

fn _office_ui_parse_dense_node(line: text) -> OfficeUiNode:
    val parts = line.split("|")
    var node = office_ui_node("", "", "component", "0", "0", "120", "40")
    if parts.len() >= 1:
        node.id = parts[0].trim()
    if parts.len() >= 2:
        node.label = parts[1].trim()
    if parts.len() >= 3:
        node.kind = parts[2].trim()
    if parts.len() >= 4:
        node.x = parts[3].trim()
    if parts.len() >= 5:
        node.y = parts[4].trim()
    if parts.len() >= 6:
        node.width = parts[5].trim()
    if parts.len() >= 7:
        node.height = parts[6].trim()
    if parts.len() >= 8:
        node.css = parts[7].trim()
    if parts.len() >= 9:
        node.layer = parts[8].trim()
    if parts.len() >= 10:
        node.component = parts[9].trim()
    if parts.len() >= 11:
        node.parent = parts[10].trim()
    if parts.len() >= 12:
        val mode = parts[11].trim()
        if _office_ui_layout_mode_supported(mode):
            node.layout_mode = mode
    if parts.len() >= 13:
        val gap = parts[12].trim()
        if _office_ui_parse_i64_result(gap).ok:
            node.layout_gap = gap
    if parts.len() >= 14:
        val padding = parts[13].trim()
        if _office_ui_parse_padding(padding).ok:
            node.layout_padding = padding
    if parts.len() >= 15:
        val h = parts[14].trim()
        if _office_ui_constraint_horizontal_supported(h):
            node.constraint_horizontal = h
    if parts.len() >= 16:
        val v = parts[15].trim()
        if _office_ui_constraint_vertical_supported(v):
            node.constraint_vertical = v
    node

fn _office_ui_safe_token(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        val code = ch.char_code_at(0)
        if (code >= 48 and code <= 57) or (code >= 65 and code <= 90) or (code >= 97 and code <= 122) or ch == "-" or ch == "_":
            out = out + ch
        i = i + 1
    if out == "":
        return "component"
    out

fn _office_ui_css_class(css: text) -> text:
    var out = ""
    for part in css.split(" "):
        val token = part.trim()
        if token != "" and _office_ui_is_safe_style_token(token):
            out = out + " office-ui-css-" + token
    out

fn _office_ui_is_safe_style_token(value: text) -> bool:
    if value.trim() == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        val code = ch.char_code_at(0)
        if not ((code >= 48 and code <= 57) or (code >= 65 and code <= 90) or (code >= 97 and code <= 122) or ch == "-" or ch == "_"):
            return false
        i = i + 1
    true

fn _office_ui_layer_z_index(layer: text, fallback: i64) -> text:
    val trimmed = layer.trim()
    if _office_ui_is_i64_token(trimmed):
        return trimmed
    fallback.to_text()

fn _office_ui_is_i64_token(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        val code = ch.char_code_at(0)
        if i == 0 and ch == "-":
            if value.len() == 1:
                return false
        elif code < 48 or code > 57:
            return false
        i = i + 1
    true

fn _office_ui_positive_i64_token(value: text) -> bool:
    if not _office_ui_is_i64_token(value):
        return false
    value.to_i64() > 0

fn _office_ui_safe_length(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        return "0px"
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        val code = ch.char_code_at(0)
        val ok = (code >= 48 and code <= 57) or ch == "." or ch == "-" or ch == "%"
        if not ok:
            if trimmed.ends_with("px") or trimmed.ends_with("em") or trimmed.ends_with("rem"):
                return trimmed
            return "0px"
        i = i + 1
    if trimmed.ends_with("%"):
        return trimmed
    trimmed + "px"

fn _office_ui_quote_if_space(value: text) -> text:
    if value.contains(" ") or value.contains(",") or value.contains("\""):
        return "\"" + value.replace("\"", "\"\"") + "\""
    value

fn _office_ui_id_in_list(node_id: text, node_ids: [text]) -> bool:
    for id in node_ids:
        if id == node_id:
            return true
    false

fn _office_ui_node_id_exists(design: OfficeUiDesign, node_id: text) -> bool:
    for node in design.nodes:
        if node.id == node_id:
            return true
    false

fn _office_ui_node_id_count(design: OfficeUiDesign, node_id: text) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if node.id == node_id:
            count = count + 1
    count

fn _office_ui_is_descendant_of(design: OfficeUiDesign, node_id: text, ancestor_id: text) -> bool:
    var current = node_id
    var guard = 0
    while guard < design.nodes.len():
        val idx = _office_ui_find_node_index(design, current)
        if idx < 0:
            return false
        val parent = design.nodes[idx].parent
        if parent == "":
            return false
        if parent == ancestor_id:
            return true
        current = parent
        guard = guard + 1
    false

fn _office_ui_parent_layout_mode(design: OfficeUiDesign, parent_id: text) -> text:
    if parent_id == "":
        return "off"
    val idx = _office_ui_find_node_index(design, parent_id)
    if idx < 0:
        return "off"
    design.nodes[idx].layout_mode

fn _office_ui_selected_count(design: OfficeUiDesign, node_ids: [text]) -> i64:
    var count: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            count = count + 1
    count

fn _office_ui_all_node_ids(design: OfficeUiDesign) -> [text]:
    var ids: [text] = []
    for node in design.nodes:
        ids.push(node.id)
    ids

fn _office_ui_layout_mode_supported(mode: text) -> bool:
    mode == "off" or mode == "horizontal" or mode == "vertical"

fn _office_ui_constraint_horizontal_supported(value: text) -> bool:
    value == "left" or value == "right" or value == "center" or value == "stretch"

fn _office_ui_constraint_vertical_supported(value: text) -> bool:
    value == "top" or value == "bottom" or value == "center" or value == "stretch"

fn _office_ui_find_node_index(design: OfficeUiDesign, node_id: text) -> i64:
    var i: i64 = 0
    for node in design.nodes:
        if node.id == node_id:
            return i
        i = i + 1
    -1

fn _office_ui_parent_chain_contains(design: OfficeUiDesign, start_parent: text, target_id: text) -> bool:
    var current = start_parent
    var depth = 0
    while current != "" and depth < 64:
        if current == target_id:
            return true
        val idx = _office_ui_find_node_index(design, current)
        if idx < 0:
            return false
        current = design.nodes[idx].parent
        depth = depth + 1
    false

fn _office_ui_parse_padding(value: text) -> OfficeUiPadding:
    val parts = value.split(",")
    if parts.len() != 4:
        return OfficeUiPadding(ok: false, top: 0, right: 0, bottom: 0, left: 0)
    val top = _office_ui_parse_i64_result(parts[0].trim())
    val right = _office_ui_parse_i64_result(parts[1].trim())
    val bottom = _office_ui_parse_i64_result(parts[2].trim())
    val left = _office_ui_parse_i64_result(parts[3].trim())
    if not top.ok or not right.ok or not bottom.ok or not left.ok:
        return OfficeUiPadding(ok: false, top: 0, right: 0, bottom: 0, left: 0)
    OfficeUiPadding(ok: true, top: top.value, right: right.value, bottom: bottom.value, left: left.value)

fn _office_ui_apply_container_layout(design: OfficeUiDesign, container: OfficeUiNode) -> OfficeUiDesign:
    val cx = _office_ui_parse_i64_result(container.x)
    val cy = _office_ui_parse_i64_result(container.y)
    val cw = _office_ui_parse_i64_result(container.width)
    val ch = _office_ui_parse_i64_result(container.height)
    val gap = _office_ui_parse_i64_result(container.layout_gap)
    val padding = _office_ui_parse_padding(container.layout_padding)
    if not cx.ok or not cy.ok or not cw.ok or not ch.ok or not gap.ok or not padding.ok:
        return design
    var out_nodes: [OfficeUiNode] = []
    for original in design.nodes:
        out_nodes.push(_office_ui_clone_node(original))
    var out = OfficeUiDesign(name: design.name, width: design.width, height: design.height, nodes: out_nodes)
    var cursor = if container.layout_mode == "horizontal": cx.value + padding.left else: cy.value + padding.top
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if node.parent == container.id:
            val resolved = _office_ui_resolve_child_in_container(node, container, cx.value, cy.value, cw.value, ch.value, padding, cursor)
            if resolved.ok:
                out.nodes[i] = resolved.node
                val size = if container.layout_mode == "horizontal": _office_ui_parse_i64_result(resolved.node.width) else: _office_ui_parse_i64_result(resolved.node.height)
                if size.ok:
                    cursor = cursor + size.value + gap.value
            else:
                return design
        i = i + 1
    out

fn _office_ui_resolve_child_in_container(node: OfficeUiNode, container: OfficeUiNode, cx: i64, cy: i64, cw: i64, ch: i64, padding: OfficeUiPadding, cursor: i64) -> OfficeUiAlignedNode:
    val w = _office_ui_parse_i64_result(node.width)
    val h = _office_ui_parse_i64_result(node.height)
    if not w.ok or not h.ok:
        return OfficeUiAlignedNode(ok: false, node: node)
    var updated = _office_ui_clone_node(node)
    val inner_x = cx + padding.left
    val inner_y = cy + padding.top
    val inner_w = cw - padding.left - padding.right
    val inner_h = ch - padding.top - padding.bottom
    if inner_w < 0 or inner_h < 0:
        return OfficeUiAlignedNode(ok: false, node: node)
    if container.layout_mode == "horizontal":
        updated.x = cursor.to_text()
        updated = _office_ui_apply_cross_axis_constraint(updated, "vertical", inner_x, inner_y, inner_w, inner_h)
    elif container.layout_mode == "vertical":
        updated.y = cursor.to_text()
        updated = _office_ui_apply_cross_axis_constraint(updated, "horizontal", inner_x, inner_y, inner_w, inner_h)
    OfficeUiAlignedNode(ok: true, node: updated)

fn _office_ui_apply_cross_axis_constraint(node: OfficeUiNode, axis: text, inner_x: i64, inner_y: i64, inner_w: i64, inner_h: i64) -> OfficeUiNode:
    var updated = _office_ui_clone_node(node)
    val w = _office_ui_parse_i64_result(node.width)
    val h = _office_ui_parse_i64_result(node.height)
    if axis == "horizontal":
        if node.constraint_horizontal == "right":
            updated.x = (inner_x + inner_w - w.value).to_text()
        elif node.constraint_horizontal == "center":
            updated.x = (inner_x + ((inner_w - w.value) / 2)).to_text()
        elif node.constraint_horizontal == "stretch":
            updated.x = inner_x.to_text()
            updated.width = inner_w.to_text()
        else:
            updated.x = inner_x.to_text()
    else:
        if node.constraint_vertical == "bottom":
            updated.y = (inner_y + inner_h - h.value).to_text()
        elif node.constraint_vertical == "center":
            updated.y = (inner_y + ((inner_h - h.value) / 2)).to_text()
        elif node.constraint_vertical == "stretch":
            updated.y = inner_y.to_text()
            updated.height = inner_h.to_text()
        else:
            updated.y = inner_y.to_text()
    updated

fn _office_ui_selected_axis_size(design: OfficeUiDesign, node_ids: [text], axis: text) -> OfficeUiI64Result:
    var total: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal": _office_ui_parse_i64_result(node.width) else: _office_ui_parse_i64_result(node.height)
            if not size.ok:
                return OfficeUiI64Result(ok: false, value: 0)
            total = total + size.value
    OfficeUiI64Result(ok: true, value: total)

fn _office_ui_align_mode_supported(mode: text) -> bool:
    mode == "left" or mode == "center" or mode == "right" or mode == "top" or mode == "middle" or mode == "bottom"

fn _office_ui_selected_bounds(design: OfficeUiDesign, node_ids: [text]) -> OfficeUiBounds:
    var initialized = false
    var min_x: i64 = 0
    var min_y: i64 = 0
    var max_x: i64 = 0
    var max_y: i64 = 0
    for node in design.nodes:
        if _office_ui_id_in_list(node.id, node_ids):
            val x = _office_ui_parse_i64_result(node.x)
            val y = _office_ui_parse_i64_result(node.y)
            val w = _office_ui_parse_i64_result(node.width)
            val h = _office_ui_parse_i64_result(node.height)
            if not x.ok or not y.ok or not w.ok or not h.ok:
                return OfficeUiBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
            val right = x.value + w.value
            val bottom = y.value + h.value
            if not initialized:
                min_x = x.value
                min_y = y.value
                max_x = right
                max_y = bottom
                initialized = true
            else:
                if x.value < min_x:
                    min_x = x.value
                if y.value < min_y:
                    min_y = y.value
                if right > max_x:
                    max_x = right
                if bottom > max_y:
                    max_y = bottom
    if not initialized:
        return OfficeUiBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
    OfficeUiBounds(ok: true, min_x: min_x, min_y: min_y, max_x: max_x, max_y: max_y)

fn _office_ui_align_node(node: OfficeUiNode, mode: text, bounds: OfficeUiBounds) -> OfficeUiAlignedNode:
    val x = _office_ui_parse_i64_result(node.x)
    val y = _office_ui_parse_i64_result(node.y)
    val w = _office_ui_parse_i64_result(node.width)
    val h = _office_ui_parse_i64_result(node.height)
    if not x.ok or not y.ok or not w.ok or not h.ok:
        return OfficeUiAlignedNode(ok: false, node: node)
    var updated = _office_ui_clone_node(node)
    if mode == "left":
        updated.x = bounds.min_x.to_text()
    elif mode == "center":
        val center = (bounds.min_x + bounds.max_x) / 2
        updated.x = (center - (w.value / 2)).to_text()
    elif mode == "right":
        updated.x = (bounds.max_x - w.value).to_text()
    elif mode == "top":
        updated.y = bounds.min_y.to_text()
    elif mode == "middle":
        val middle = (bounds.min_y + bounds.max_y) / 2
        updated.y = (middle - (h.value / 2)).to_text()
    elif mode == "bottom":
        updated.y = (bounds.max_y - h.value).to_text()
    OfficeUiAlignedNode(ok: true, node: updated)

fn _office_ui_parse_i64_result(value: text) -> OfficeUiI64Result:
    val trimmed = value.trim()
    if not _office_ui_is_i64_token(trimmed):
        return OfficeUiI64Result(ok: false, value: 0)
    var negative = false
    var i = 0
    if trimmed.char_at(0) == "-":
        negative = true
        i = 1
    var out: i64 = 0
    while i < trimmed.len():
        out = out * 10 + (trimmed.char_at(i).char_code_at(0) - 48).to_i64()
        i = i + 1
    if negative:
        out = 0 - out
    OfficeUiI64Result(ok: true, value: out)
