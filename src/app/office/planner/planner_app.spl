# Simple Planner Application
#
# Task and project management with kanban, list, calendar, and timeline views.

use common.ui.widget.{WidgetNode, UITree, UIEvent}
use common.ui.builder.{column, row, panel, label, button, statusbar, build_tree_with_title, with_flex}
use common.ui.ios.builder.{navigation_bar, segmented_control, search_bar}
use app.office.planner.task.{Task, TaskStatus, TaskPriority, new_task, status_name}
use app.office.planner.board.{Project, Board, empty_project, tasks_in_column, move_task, add_task_to_project}
use app.office.planner.kanban.{build_kanban_view}
use app.office.planner.list_view.{build_list_view}
use app.office.planner.calendar_view.{build_calendar_view}
use app.office.planner.timeline.{build_timeline_view}

# =========================================================================
# Application Class
# =========================================================================

class PlannerApp:
    project: Project
    active_view: text
    selected_task: text
    calendar_year: i32
    calendar_month: i32
    search_query: text
    modified: bool
    file_path: text

impl PlannerApp:

    static fn new() -> PlannerApp:
        """Create a new Planner app with an empty project and kanban view."""
        return PlannerApp(
            project: empty_project("My Project"),
            active_view: "kanban",
            selected_task: "",
            calendar_year: 2026,
            calendar_month: 1,
            search_query: "",
            modified: false,
            file_path: ""
        )

    fn build_ui() -> UITree:
        """Build the full Planner UI with toolbar, active view, and status bar."""
        # Navigation bar
        val add_task_btn = button("btn_add_task", "+ Task", "add_task")
        val nav = navigation_bar("nav", "Simple Planner", [], [add_task_btn])

        # Toolbar: view switcher + search
        val view_index = _view_to_index(self.active_view)
        val view_control = segmented_control("view_control",
            ["Board", "List", "Calendar", "Timeline"],
            view_index
        )
        val search = search_bar("search", "Search tasks...", self.search_query)
        val toolbar = row("toolbar", [view_control, search])

        # Active view content
        val filtered_project = self._filtered_project()
        val content = match self.active_view:
            "kanban":
                build_kanban_view(filtered_project)
            "list":
                build_list_view(filtered_project)
            "calendar":
                build_calendar_view(filtered_project, self.calendar_year, self.calendar_month)
            "timeline":
                build_timeline_view(filtered_project)
            _:
                build_kanban_view(filtered_project)

        # Task counts for status bar
        val total = _count_tasks(self.project.tasks)
        val in_progress = _count_tasks(tasks_in_column(self.project, "In Progress"))
        val done = _count_tasks(tasks_in_column(self.project, "Done"))

        val status = statusbar("statusbar",
            "{total} tasks | {in_progress} in progress | {done} done",
            if self.modified: "Modified" else: "Saved"
        )

        val root = column("root", [nav, toolbar, content, status])
        return build_tree_with_title(root, "Simple Planner", "ios_light")

    me handle_event(event: UIEvent):
        """Handle UI events for the Planner app."""
        match event:
            UIEvent.Action(name):
                match name:
                    "add_task":
                        self.add_task("New Task")
                    "save":
                        self.modified = false
                    _:
                        if name.starts_with("select_task_"):
                            self.selected_task = name.substring(12)
                        elif name.starts_with("move_task_"):
                            val rest = name.substring(10)
                            val parts = rest.split("_to_")
                            if parts.len() == 2:
                                self.move_task(parts[0], parts[1])
                        elif name.starts_with("switch_view_"):
                            val view = name.substring(12)
                            self.switch_view(view)
                        elif name == "prev_month":
                            self._prev_month()
                        elif name == "next_month":
                            self._next_month()
            _:
                pass_dn

    me switch_view(view: text):
        """Switch the active view to kanban, list, calendar, or timeline."""
        match view:
            "kanban":
                self.active_view = "kanban"
            "list":
                self.active_view = "list"
            "calendar":
                self.active_view = "calendar"
            "timeline":
                self.active_view = "timeline"
            _:
                pass_dn

    me add_task(title: text):
        """Add a new task with the given title to the project."""
        val task_id = "task_{_count_tasks(self.project.tasks)}"
        val task = new_task(task_id, title)
        self.project = add_task_to_project(self.project, task)
        self.modified = true

    me move_task(task_id: text, to_column: text):
        """Move a task to a different column on the board."""
        self.project = move_task(self.project, task_id, to_column)
        self.modified = true

    fn _filtered_project() -> Project:
        """Return a project with tasks filtered by search query."""
        if self.search_query == "":
            return self.project
        val q = self.search_query.to_lower()
        var filtered_tasks: [Task] = []
        for task in self.project.tasks:
            val matches = (task.title.to_lower().contains(q) or
                task.description.to_lower().contains(q) or
                task.assignee.to_lower().contains(q))
            if matches:
                filtered_tasks = filtered_tasks.push(task)
        return Project(
            title: self.project.title,
            tasks: filtered_tasks,
            board: self.project.board
        )

    me _prev_month():
        """Navigate calendar to the previous month."""
        if self.calendar_month == 1:
            self.calendar_month = 12
            self.calendar_year = self.calendar_year - 1
        else:
            self.calendar_month = self.calendar_month - 1

    me _next_month():
        """Navigate calendar to the next month."""
        if self.calendar_month == 12:
            self.calendar_month = 1
            self.calendar_year = self.calendar_year + 1
        else:
            self.calendar_month = self.calendar_month + 1

# =========================================================================
# Module Helpers
# =========================================================================

fn _view_to_index(view: text) -> i32:
    """Convert view name to segmented control index."""
    match view:
        "kanban": return 0
        "list": return 1
        "calendar": return 2
        "timeline": return 3
        _: return 0

fn _count_tasks(tasks: [Task]) -> i32:
    """Count items in a task list."""
    var count: i32 = 0
    for t in tasks:
        count = count + 1
    return count
