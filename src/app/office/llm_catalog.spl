# LLM-readable Office feature catalog.
#
# This is pure metadata over existing app owners. It gives agents one stable
# surface for app features and edit actions without importing GUI/browser/host
# paths or duplicating implementation logic.

struct OfficeLlmFeature:
    app_name: text
    component: text
    owner_module: text
    features: [text]
    actions: [text]
    evidence_key: text

fn office_llm_feature_catalog() -> [OfficeLlmFeature]:
    var rows: [OfficeLlmFeature] = []
    rows.push(OfficeLlmFeature(
        app_name: "Markdown",
        component: "markdown",
        owner_module: "app.office.md_wysiwyg",
        features: ["source-lines", "styled-preview", "html-render", "guarded-edit", "stale-reject"],
        actions: ["render-markdown-preview-html", "md-edit"],
        evidence_key: "md_wysiwyg_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Writer",
        component: "word",
        owner_module: "app.office.word.html_render",
        features: ["markdown-source", "source-summary", "document-stats", "document-search", "document-range-read", "document-replace", "document-insert", "document-delete", "document-outline", "document-blocks", "headings", "lists", "ordered-lists", "task-lists", "blockquotes", "fenced-code", "thematic-breaks", "tables", "table-alignment", "images", "inline-links", "url-sanitize", "html-render"],
        actions: ["render-writer-markdown-html", "writer-markdown-summary", "writer-markdown-stats", "writer-markdown-search", "writer-markdown-range", "writer-markdown-replace", "writer-markdown-insert", "writer-markdown-delete", "writer-markdown-outline"],
        evidence_key: "word/html_render_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Calc",
        component: "sheets",
        owner_module: "app.office.sheets",
        features: ["cells", "ranges", "formulas", "formula-evaluate-read", "formula-counta", "formula-text-functions", "formula-vlookup", "formula-display-recalc", "cell-format-display", "guarded-edit", "stale-reject"],
        actions: ["sheet-edit", "format-cell-value", "evaluate-sheet-formula"],
        evidence_key: "office_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Impress",
        component: "slides",
        owner_module: "app.office.slides",
        features: ["markdown-source", "slide-elements", "outline", "outline-readback", "css-like-design", "guarded-edit", "html-render", "ppt-html", "slide-count-metadata", "safe-css", "positioned-elements", "element-metadata", "css-class-sanitize", "text-escape"],
        actions: ["render-ppt-markdown-html", "ppt-markdown-outline", "slide-edit"],
        evidence_key: "ide_office_plugin_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Draw",
        component: "draw",
        owner_module: "std.editor.services.sdn_graph",
        features: ["sdd-source", "document-summary", "canonical-export", "geometry", "connectors", "waypoints", "connector-paths", "edge-path-readback", "edge-segments-readback", "group-containers", "style-rule-edit", "style-rule-delete", "style-rule-inspector", "node-create", "node-label-edit", "node-geometry-edit", "node-geometry-readback", "node-delete", "edge-create", "edge-duplicate", "edge-label-edit", "edge-label-readback", "edge-label-point-edit", "edge-label-point-readback", "edge-style-edit", "edge-style-readback", "edge-kind-edit", "edge-kind-readback", "edge-reconnect-edit", "edge-route-readback", "edge-endpoints-readback", "edge-delete", "node-shape-edit", "node-shape-readback", "node-style-edit", "node-style-readback", "node-layer-edit", "node-layer-readback", "node-order-edit", "node-parent-readback", "node-role-edit", "node-role-readback", "node-duplicate", "canvas-metadata", "canvas-readback", "selection", "selection-geometry", "layers-readback", "inspector", "align-layout", "distribute-layout", "html-render", "game-sprite-export"],
        actions: ["render-sdd-html", "sdd-document-summary", "render-sdd-html-with-selection", "export-sdd-canonical", "export-sdd-game-sprites", "reroute-sdd-connector", "edit-sdd-style-rule", "delete-sdd-style-rule", "inspect-sdd-style-rule", "add-sdd-node", "add-sdd-edge", "duplicate-sdd-edge", "edit-sdd-edge-label", "sdd-edge-label-read", "edit-sdd-edge-label-point", "sdd-edge-label-point-read", "edit-sdd-edge-style", "sdd-edge-style-read", "edit-sdd-edge-kind", "sdd-edge-kind-read", "sdd-edge-route-read", "sdd-edge-path-read", "sdd-edge-segments-read", "sdd-edge-endpoints-read", "edit-sdd-edge-endpoints", "delete-sdd-edge", "delete-sdd-node", "edit-sdd-node-label", "edit-sdd-node-geometry", "sdd-node-geometry-read", "edit-sdd-node-parent", "sdd-node-parent-read", "edit-sdd-node-shape", "sdd-node-shape-read", "edit-sdd-node-style", "sdd-node-style-read", "edit-sdd-node-layer", "sdd-node-layer-read", "order-sdd-node", "edit-sdd-node-role", "sdd-node-role-read", "duplicate-sdd-node", "edit-sdd-canvas", "sdd-canvas-read", "sdd-selection-geometry", "sdd-list-layers", "align-sdd-selection", "distribute-sdd-selection", "inspect-sdd-node", "inspect-sdd-edge"],
        evidence_key: "editor/services/sdn_graph_diagram_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Designer",
        component: "ui",
        owner_module: "app.office.ui_editor",
        features: ["html-ui-source", "frames", "components", "name-edit", "canvas-edit", "canvas-readback", "kind-edit", "component-edit", "positioned-layout", "selection", "selection-geometry", "selected-html-render", "selected-resize-handles", "resize-handle-metadata", "inspector", "layers-readback", "style-tokens", "css-edit", "auto-layout", "auto-layout-signature", "auto-layout-resolve", "resolved-layout-read", "constraints", "parent-edit", "layout-edit", "node-create", "node-duplicate", "node-delete", "node-order-edit", "align-layout", "distribute-layout", "layer-edit", "style-token-edit", "sdd-export", "guarded-edit"],
        actions: ["render-ui-html", "render-ui-html-with-selection", "export-ui-sdd", "ui-label-edit", "ui-name-edit", "ui-kind-edit", "ui-canvas-edit", "ui-canvas-read", "ui-layout-edit", "ui-resize-node", "ui-select-node", "ui-selection-geometry", "ui-add-node", "ui-duplicate-node", "ui-delete-node", "ui-order-node", "ui-auto-layout-edit", "ui-auto-layout-signature", "ui-resolve-auto-layout", "ui-resolved-layout-read", "ui-constraints-edit", "ui-parent-edit", "ui-align-selection", "ui-distribute-selection", "ui-layer-edit", "ui-component-edit", "ui-style-token-read", "ui-style-token-edit", "ui-css-edit", "ui-inspect-node", "ui-list-layers"],
        evidence_key: "ui_editor_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Base",
        component: "db",
        owner_module: "app.office.base_db",
        features: ["text-table", "table-summary", "html-render", "html-cell-coordinates", "html-escape", "insert", "schema-validation", "row-width-reject", "duplicate-column-reject", "blank-column-reject", "missing-column-errors", "select-where", "count-where", "project-column", "update-where", "delete-where", "game-state-export"],
        actions: ["query-table", "base-table-summary", "export-base-game-state", "render-base-table-html", "db-edit"],
        evidence_key: "base_db_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Math",
        component: "math",
        owner_module: "app.office.math_editor",
        features: ["mathml", "tokens", "xml-escape", "fraction", "slash-fraction", "superscript", "subscript", "square-root", "sqrt-shorthand", "fenced-group", "precedence-parser", "unary-minus", "checked-rendering", "token-limit", "malformed-fallback"],
        actions: ["render-mathml", "render-math-structure", "render-mathml-checked"],
        evidence_key: "math_editor_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Mail",
        component: "mail",
        owner_module: "app.office.mail.mail_app",
        features: ["folders", "inbox", "unread-count", "message-summary", "attachments"],
        actions: ["mail-summary"],
        evidence_key: "ide_office_plugin_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Planner",
        component: "planner",
        owner_module: "app.office.planner.planner_app",
        features: ["project-board", "kanban-view", "list-view", "calendar-view", "timeline-view", "task-count-summary"],
        actions: ["planner-summary"],
        evidence_key: "ide_office_plugin_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Counter",
        component: "counter",
        owner_module: "app.office.counter",
        features: ["increment", "decrement", "reset", "fail-closed-actions"],
        actions: ["counter-action"],
        evidence_key: "counter_route_spec"
    ))
    rows

fn office_llm_catalog_app_names() -> [text]:
    var names: [text] = []
    for row in office_llm_feature_catalog():
        names.push(row.app_name)
    names

fn office_llm_catalog_feature_count() -> i64:
    var count = 0
    for row in office_llm_feature_catalog():
        count = count + row.features.len()
    count

fn office_llm_catalog_action_count() -> i64:
    var count = 0
    for row in office_llm_feature_catalog():
        count = count + row.actions.len()
    count

fn office_llm_catalog_validate(rows: [OfficeLlmFeature]) -> text:
    var seen_apps: [text] = []
    var seen_actions: [text] = []
    for row in rows:
        if row.app_name == "":
            return "catalog error: empty app name"
        if row.component == "":
            return "catalog error: app '" + row.app_name + "' has empty component"
        if row.owner_module == "":
            return "catalog error: app '" + row.app_name + "' has empty owner module"
        if row.evidence_key == "":
            return "catalog error: app '" + row.app_name + "' has empty evidence key"
        for app_name in seen_apps:
            if app_name == row.app_name:
                return "catalog error: duplicate app '" + row.app_name + "'"
        seen_apps.push(row.app_name)
        if row.features.len() == 0:
            return "catalog error: app '" + row.app_name + "' has no features"
        for feature in row.features:
            if feature == "":
                return "catalog error: app '" + row.app_name + "' has empty feature"
        if row.actions.len() == 0:
            return "catalog error: app '" + row.app_name + "' has no actions"
        for action in row.actions:
            if action == "":
                return "catalog error: app '" + row.app_name + "' has empty action"
            for seen_action in seen_actions:
                if seen_action == action:
                    return "catalog error: duplicate action '" + action + "'"
            seen_actions.push(action)
    ""

fn office_llm_catalog_is_valid() -> bool:
    office_llm_catalog_validate(office_llm_feature_catalog()) == ""

fn office_llm_catalog_summary() -> text:
    val rows = office_llm_feature_catalog()
    "llm-catalog: apps={rows.len()} features={office_llm_catalog_feature_count()} actions={office_llm_catalog_action_count()}"

fn office_llm_action_input_schema(action: text) -> text:
    """Compact source grammar for an advertised headless Office action."""
    if action == "md-edit":
        return "line_no|expected_source|new_source\\nmarkdown_source"
    if action == "sheet-edit":
        return "cell_ref|expected_display|new_value\\nA1=value;B1=value"
    if action == "format-cell-value":
        return "numeric_value|format"
    if action == "evaluate-sheet-formula":
        return "formula_expression\\nA1=value;B1=value"
    if action == "slide-edit":
        return "element_id|expected_text|new_text\\nelement_id=value;..."
    if action == "counter-action":
        return "value|counter_increment|counter_decrement|counter_reset"
    if action == "query-table":
        return "count-where|column|value\\ntable: Name\\ncolumns: ...\\nrow: ..."
    if action == "base-table-summary":
        return "table: Name\\ncolumns: ...\\nrow: ..."
    if action == "db-edit":
        return "insert|v1,v2 or update-where|match_col|match_value|update_col|new_value or delete-where|match_col|match_value\\ntable: ..."
    if action == "ui-label-edit":
        return "node_id|expected_label|new_label\\nhtml_ui_source"
    if action == "ui-name-edit":
        return "expected_name|new_name\\nhtml_ui_source"
    if action == "ui-layout-edit" or action == "ui-resize-node":
        return "node_id|expected_x|expected_y|expected_width|expected_height|new_x|new_y|new_width|new_height\\nhtml_ui_source"
    if action == "ui-canvas-edit":
        return "expected_width|expected_height|new_width|new_height\\nhtml_ui_source"
    if action == "ui-canvas-read":
        return "html_ui_source"
    if action == "ui-select-node":
        return "node_id\\nhtml_ui_source"
    if action == "ui-auto-layout-edit":
        return "node_id|expected_mode|expected_gap|expected_padding|new_mode|new_gap|new_padding\\nhtml_ui_source"
    if action == "ui-auto-layout-signature":
        return "html_ui_source"
    if action == "ui-constraints-edit":
        return "node_id|expected_h|expected_v|new_h|new_v\\nhtml_ui_source"
    if action == "ui-parent-edit":
        return "node_id|expected_parent|new_parent\\nhtml_ui_source"
    if action == "ui-add-node":
        return "id|label|kind|x|y|width|height|css|layer|component\\nhtml_ui_source"
    if action == "ui-duplicate-node":
        return "source_id|new_id|dx|dy\\nhtml_ui_source"
    if action == "ui-delete-node":
        return "node_id\\nhtml_ui_source"
    if action == "ui-order-node":
        return "node_id|front|back\\nhtml_ui_source"
    if action == "ui-align-selection" or action == "ui-distribute-selection":
        return "mode_or_axis|id1,id2,...\\nhtml_ui_source"
    if action == "ui-selection-geometry":
        return "id1,id2,...\\nhtml_ui_source"
    if action == "ui-kind-edit" or action == "ui-layer-edit" or action == "ui-style-token-edit" or action == "ui-css-edit" or action == "ui-component-edit":
        return "node_id|expected|new\\nhtml_ui_source"
    if action == "ui-style-token-read" or action == "ui-inspect-node":
        return "node_id\\nhtml_ui_source"
    if action == "ui-list-layers":
        return "html_ui_source"
    if action == "ui-resolve-auto-layout":
        return "expected_auto_layout_signature\\nhtml_ui_source"
    if action == "ui-resolved-layout-read":
        return "html_ui_source"
    if action == "duplicate-sdd-node":
        return "source_id|new_id|dx|dy\\nsdd_source"
    if action == "add-sdd-node":
        return "id|label|css|role|shape|x|y|width|height|layer|parent\\nsdd_source"
    if action == "edit-sdd-style-rule":
        return "css|target|extends|key|value\\nsdd_source"
    if action == "delete-sdd-style-rule" or action == "inspect-sdd-style-rule":
        return "css|key\\nsdd_source"
    if action == "edit-sdd-node-geometry":
        return "node_id|x|y|width|height\\nsdd_source"
    if action == "edit-sdd-node-label" or action == "edit-sdd-node-parent" or action == "edit-sdd-node-shape" or action == "edit-sdd-node-style" or action == "edit-sdd-node-layer" or action == "edit-sdd-node-role":
        return "node_id|value\\nsdd_source"
    if action == "order-sdd-node":
        return "node_id|front|back\\nsdd_source"
    if action == "edit-sdd-canvas":
        return "width|height|grid|snap|zoom|background\\nsdd_source"
    if action == "sdd-canvas-read":
        return "sdd_source"
    if action == "add-sdd-edge":
        return "from_id|to_id|label|css|kind|route|waypoints|start|end\\nsdd_source"
    if action == "duplicate-sdd-edge" or action == "delete-sdd-edge" or action == "inspect-sdd-edge" or action == "sdd-edge-style-read" or action == "sdd-edge-kind-read" or action == "sdd-edge-label-read" or action == "sdd-edge-label-point-read" or action == "sdd-edge-endpoints-read" or action == "sdd-edge-route-read" or action == "sdd-edge-path-read" or action == "sdd-edge-segments-read":
        return "edge_index\\nsdd_source"
    if action == "edit-sdd-edge-label" or action == "edit-sdd-edge-style" or action == "edit-sdd-edge-kind":
        return "edge_index|value\\nsdd_source"
    if action == "edit-sdd-edge-label-point":
        return "edge_index|label_x|label_y\\nsdd_source"
    if action == "edit-sdd-edge-endpoints":
        return "edge_index|from_id|to_id\\nsdd_source"
    if action == "reroute-sdd-connector":
        return "edge_index|route|waypoints|start_anchor|end_anchor\\nsdd_source"
    if action == "delete-sdd-node" or action == "inspect-sdd-node" or action == "sdd-node-style-read" or action == "sdd-node-parent-read" or action == "sdd-node-geometry-read" or action == "sdd-node-shape-read" or action == "sdd-node-layer-read" or action == "sdd-node-role-read":
        return "node_id\\nsdd_source"
    if action == "align-sdd-selection" or action == "distribute-sdd-selection":
        return "mode_or_axis|id1,id2,...\\nsdd_source"
    if action == "sdd-selection-geometry":
        return "id1,id2,...\\nsdd_source"
    if action == "sdd-list-layers":
        return "sdd_source"
    if action == "render-markdown-preview-html" or action == "render-writer-markdown-html" or action == "render-ppt-markdown-html" or action == "writer-markdown-summary" or action == "writer-markdown-stats" or action == "writer-markdown-outline" or action == "ppt-markdown-outline":
        return "markdown_source"
    if action == "writer-markdown-search":
        return "query\\nmarkdown_source"
    if action == "writer-markdown-range":
        return "start|count\\nmarkdown_source"
    if action == "writer-markdown-replace":
        return "query|replacement\\nmarkdown_source"
    if action == "writer-markdown-insert":
        return "line|text\\nmarkdown_source"
    if action == "writer-markdown-delete":
        return "line\\nmarkdown_source"
    if action == "render-sdd-html-with-selection":
        return "select|node_id|edge_index\\nsdd_source"
    if action == "render-sdd-html" or action == "sdd-document-summary" or action == "export-sdd-canonical" or action == "export-sdd-game-sprites":
        return "sdd_source"
    if action == "render-ui-html-with-selection":
        return "select|node_id\\nhtml_ui_source"
    if action == "render-ui-html" or action == "export-ui-sdd":
        return "html_ui_source"
    if action == "render-base-table-html" or action == "export-base-game-state":
        return "table: Name\\ncolumns: ...\\nrow: ..."
    if action == "render-mathml" or action == "render-math-structure" or action == "render-mathml-checked":
        return "math_expression"
    if action == "mail-summary":
        return "no_input"
    if action == "planner-summary":
        return "no_input"
    ""
