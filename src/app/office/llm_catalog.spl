# LLM-readable Office feature catalog.
#
# This is pure metadata over existing app owners. It gives agents one stable
# surface for app features and edit actions without importing GUI/browser/host
# paths or duplicating implementation logic.

struct OfficeLlmFeature:
    app_name: text
    component: text
    owner_module: text
    features: [text]
    actions: [text]
    evidence_key: text

fn office_llm_feature_catalog() -> [OfficeLlmFeature]:
    var rows: [OfficeLlmFeature] = []
    rows.push(OfficeLlmFeature(
        app_name: "Markdown",
        component: "markdown",
        owner_module: "app.office.md_wysiwyg",
        features: ["source-lines", "styled-preview", "html-render", "guarded-edit", "stale-reject"],
        actions: ["render-markdown-preview-html", "md-edit"],
        evidence_key: "md_wysiwyg_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Writer",
        component: "word",
        owner_module: "app.office.word.html_render",
        features: ["markdown-source", "document-blocks", "headings", "lists", "html-render"],
        actions: ["render-writer-markdown-html"],
        evidence_key: "word/html_render_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Calc",
        component: "sheets",
        owner_module: "app.office.sheets",
        features: ["cells", "ranges", "formulas", "formula-counta", "formula-text-functions", "formula-vlookup", "formula-display-recalc", "guarded-edit", "stale-reject"],
        actions: ["sheet-edit"],
        evidence_key: "office_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Impress",
        component: "slides",
        owner_module: "app.office.slides",
        features: ["markdown-source", "slide-elements", "outline", "css-like-design", "guarded-edit", "html-render"],
        actions: ["render-ppt-markdown-html", "slide-edit"],
        evidence_key: "ide_office_plugin_suite_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Draw",
        component: "draw",
        owner_module: "std.editor.services.sdn_graph",
        features: ["sdd-source", "geometry", "connectors", "waypoints", "connector-paths", "group-containers", "style-rule-edit", "style-rule-delete", "style-rule-inspector", "node-create", "node-label-edit", "node-geometry-edit", "node-delete", "edge-create", "edge-duplicate", "edge-label-edit", "edge-label-point-edit", "edge-style-edit", "edge-kind-edit", "edge-reconnect-edit", "edge-delete", "node-shape-edit", "node-style-edit", "node-layer-edit", "node-order-edit", "node-role-edit", "node-duplicate", "canvas-metadata", "selection", "inspector", "align-layout", "distribute-layout", "html-render"],
        actions: ["render-sdd-html", "render-sdd-html-with-selection", "reroute-sdd-connector", "edit-sdd-style-rule", "delete-sdd-style-rule", "inspect-sdd-style-rule", "add-sdd-node", "add-sdd-edge", "duplicate-sdd-edge", "edit-sdd-edge-label", "edit-sdd-edge-label-point", "edit-sdd-edge-style", "edit-sdd-edge-kind", "edit-sdd-edge-endpoints", "delete-sdd-edge", "delete-sdd-node", "edit-sdd-node-label", "edit-sdd-node-geometry", "edit-sdd-node-parent", "edit-sdd-node-shape", "edit-sdd-node-style", "edit-sdd-node-layer", "order-sdd-node", "edit-sdd-node-role", "duplicate-sdd-node", "edit-sdd-canvas", "align-sdd-selection", "distribute-sdd-selection", "inspect-sdd-node", "inspect-sdd-edge"],
        evidence_key: "editor/services/sdn_graph_diagram_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Designer",
        component: "ui",
        owner_module: "app.office.ui_editor",
        features: ["html-ui-source", "frames", "components", "positioned-layout", "selection", "inspector", "style-tokens", "auto-layout", "constraints", "layout-edit", "node-duplicate", "align-layout", "distribute-layout", "layer-edit", "style-token-edit", "sdd-export", "guarded-edit"],
        actions: ["render-ui-html", "export-ui-sdd", "ui-label-edit", "ui-layout-edit", "ui-duplicate-node", "ui-auto-layout-edit", "ui-constraints-edit", "ui-align-selection", "ui-distribute-selection", "ui-layer-edit", "ui-style-token-read", "ui-style-token-edit", "ui-inspect-node"],
        evidence_key: "ui_editor_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Base",
        component: "db",
        owner_module: "app.office.base_db",
        features: ["text-table", "html-render", "insert", "schema-validation", "select-where", "count-where", "project-column", "update-where", "delete-where"],
        actions: ["query-table", "render-base-table-html", "db-edit"],
        evidence_key: "base_db_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Math",
        component: "math",
        owner_module: "app.office.math_editor",
        features: ["mathml", "tokens", "fraction", "superscript", "subscript", "square-root", "fenced-group", "precedence-parser", "checked-rendering"],
        actions: ["render-mathml", "render-math-structure", "render-mathml-checked"],
        evidence_key: "math_editor_spec"
    ))
    rows.push(OfficeLlmFeature(
        app_name: "Counter",
        component: "counter",
        owner_module: "app.office.counter",
        features: ["increment", "decrement", "reset", "fail-closed-actions"],
        actions: ["counter-action"],
        evidence_key: "counter_route_spec"
    ))
    rows

fn office_llm_catalog_app_names() -> [text]:
    var names: [text] = []
    for row in office_llm_feature_catalog():
        names.push(row.app_name)
    names

fn office_llm_catalog_feature_count() -> i64:
    var count = 0
    for row in office_llm_feature_catalog():
        count = count + row.features.len()
    count

fn office_llm_catalog_action_count() -> i64:
    var count = 0
    for row in office_llm_feature_catalog():
        count = count + row.actions.len()
    count

fn office_llm_catalog_validate(rows: [OfficeLlmFeature]) -> text:
    var seen_apps: [text] = []
    var seen_actions: [text] = []
    for row in rows:
        if row.app_name == "":
            return "catalog error: empty app name"
        if row.component == "":
            return "catalog error: app '" + row.app_name + "' has empty component"
        if row.owner_module == "":
            return "catalog error: app '" + row.app_name + "' has empty owner module"
        if row.evidence_key == "":
            return "catalog error: app '" + row.app_name + "' has empty evidence key"
        for app_name in seen_apps:
            if app_name == row.app_name:
                return "catalog error: duplicate app '" + row.app_name + "'"
        seen_apps.push(row.app_name)
        if row.features.len() == 0:
            return "catalog error: app '" + row.app_name + "' has no features"
        for feature in row.features:
            if feature == "":
                return "catalog error: app '" + row.app_name + "' has empty feature"
        if row.actions.len() == 0:
            return "catalog error: app '" + row.app_name + "' has no actions"
        for action in row.actions:
            if action == "":
                return "catalog error: app '" + row.app_name + "' has empty action"
            for seen_action in seen_actions:
                if seen_action == action:
                    return "catalog error: duplicate action '" + action + "'"
            seen_actions.push(action)
    ""

fn office_llm_catalog_is_valid() -> bool:
    office_llm_catalog_validate(office_llm_feature_catalog()) == ""

fn office_llm_catalog_summary() -> text:
    val rows = office_llm_feature_catalog()
    "llm-catalog: apps={rows.len()} features={office_llm_catalog_feature_count()} actions={office_llm_catalog_action_count()}"
