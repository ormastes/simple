# Office GUI Pilot (CARD 16 step 2)
#
# Routes ONE office app's UITree through the REAL UI stack instead of the
# print-root_id dead end: UITree (app.build_ui()) -> HTML (the same
# render_html_tree() widget-to-HTML conversion BrowserBackend.render_frame
# uses) -> browser engine layout/paint pixel path -> ARGB pixels. Headless:
# no window/event loop needed for the pilot.
#
# CSS-size fallback knob (see doc/08_tracking/bug/
# browser_engine_css_size_quadratic_pixel_render_2026-07-04.md): the full
# BrowserBackend.render_frame() path always injects app.ui.web.html's
# generate_css(theme) (~300KB, ~1865 rules) into the page. The layout
# renderer's apply_decls() was fixed to stop re-scanning each rule's decl
# text once per probed property (see simple_web_html_layout_renderer.spl's
# DeclPairs/parse_decl_pairs — ~9x faster on a synthetic worst case), and
# the renderer completes in under a second on the full theme CSS when
# measured standalone. But inside the full office binary (many more
# modules/symbols loaded, interpreter fallback active — see
# CODEGEN-AMBIGUOUS-METHOD notes for text_painter.spl's `_strip_tags`/
# `_normalize_whitespace`) the SAME call measurably does not return within
# 150s+, a gap not explained by the CSS-processing algorithm itself and not
# reproduced by any standalone probe built during this session. Until that
# full-binary-only slowdown is root-caused, this pilot renders through the
# same real layout/paint engine but with a small curated stylesheet (~1KB,
# comfortably inside the ~10KB budget measured feasible at 96x64) covering
# exactly the counter app's widget classes, instead of the full theme CSS.
# This keeps the render on the REAL pixel path (no hard-coded pixels, no
# widget-id fixture fast path involved) while getting the CARD 16 proof
# line to print. Remaining work: root-cause the full-binary slowdown and
# restore full theme CSS here.

use common.ui.widget.{UITree, WidgetNode}
use common.ui.state.{init_state}
use common.ui.builder.{column, table_widget, build_tree_with_title, text_widget, progress, with_width, with_height}
use app.ui.render.html_widgets.{render_html_tree}
use app.office.counter.{CounterApp}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, col_to_letter}
use app.office.sheets.chart.{ChartSeries, chart_series_from_ranges}
use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{simple_web_engine2d_render_html_pixels}

# Matches BrowserApp's viewport (src/app/ui.browser/app.spl uses width=96,
# height=64; its host window presents that scaled by BROWSER_WINDOW_SCALE).
# An 800x600 frame was probed first and exceeds 200s under the interpreter
# (per-pixel interpreted work in the pixel-artifact path), so the pilot
# stays on the framework's own proven viewport.
val OFFICE_GUI_FRAME_WIDTH: i32 = 96
val OFFICE_GUI_FRAME_HEIGHT: i32 = 64

fn office_gui_frame_width() -> i32:
    OFFICE_GUI_FRAME_WIDTH

fn office_gui_frame_height() -> i32:
    OFFICE_GUI_FRAME_HEIGHT

fn office_gui_build_tree(app_name: text) -> UITree:
    """Build the named office app's UITree. Pilot: only "counter" is wired;
    future apps (word/sheets/slides/...) each add one match arm here."""
    match app_name:
        "counter" =>
            return CounterApp.new().build_ui()
        case _("CARD 16 pilot only wires counter; unknown names fall back to counter"):
            return CounterApp.new().build_ui()

fn office_gui_minimal_css() -> text:
    """Curated stylesheet covering exactly the widget classes the office
    launcher's build_ui() trees emit today (panel/layout/button/text/nav/
    statusbar). See the CSS-size fallback knob note above this file's
    header comment for why this replaces generate_css(theme) here."""
    ".widget-panel{background:#ffffff;}" +
    ".layout-vbox{flex-direction:column;}" +
    ".layout-hbox{flex-direction:row;}" +
    ".panel-content{flex-direction:column;padding:4px;}" +
    ".widget-navigation-bar{flex-direction:row;background:#f5f5f5;height:24px;}" +
    ".nav-left{flex:1;}" +
    ".nav-title{color:#333333;}" +
    ".nav-right{flex:1;}" +
    ".widget-button{background:#0066cc;color:#ffffff;padding:2px 6px;border-radius:4px;}" +
    ".widget-text{color:#333333;}" +
    ".widget-statusbar{flex-direction:row;background:#f5f5f5;}" +
    ".status-left{flex:1;color:#333333;}" +
    ".status-right{color:#999999;}" +
    ".focused{border:1px solid #0066cc;}"

fn office_gui_sheet_minimal_css() -> text:
    """Curated stylesheet covering the sheet grid's widget classes (table/
    th/td/filter-input) on top of office_gui_minimal_css's base panel/layout
    classes. Same fallback-knob rationale as office_gui_minimal_css above:
    a small curated sheet, not the full ~300KB theme CSS."""
    office_gui_minimal_css() +
    ".table-filter{padding:2px 4px;border:1px solid #cccccc;}" +
    ".widget-table{border-collapse:collapse;width:100%;}" +
    ".widget-table th{padding:2px 4px;border:1px solid #cccccc;background:#e8e8e8;text-align:left;}" +
    ".widget-table td{padding:2px 4px;border:1px solid #cccccc;}"

struct SheetGuiView:
    tree: UITree
    text_dump: text

fn sheet_gui_view(sheet: Sheet, max_rows: i32, max_cols: i32) -> SheetGuiView:
    """Build a spreadsheet grid view of `sheet`: column headers A,B,C.. across
    the top, 1-based row numbers down the left, and each visible cell's
    display text (formulas show their cached computed value via
    cell_display_text). Rows in sheet.hidden_rows are skipped entirely so a
    filtered sheet renders filtered. Returns both a UITree (for real pixel
    rendering through the browser engine) and a plain-text pipe-separated
    grid dump (for testability without parsing HTML/widget trees) --
    the header line first, then one line per rendered row."""
    var headers: [text] = [""]
    var c = 0
    while c < max_cols:
        headers.push(col_to_letter(c))
        c = c + 1

    var rows_out: [[text]] = []
    var dump_lines: [text] = [headers.join("|")]
    var r = 1
    while r <= max_rows:
        if not sheet.is_row_hidden(r.to_i64()):
            var row_cells: [text] = ["{r}"]
            var rc = 0
            while rc < max_cols:
                val ref_str = "{col_to_letter(rc)}{r}"
                row_cells.push(cell_display_text(sheet.get_cell(ref_str)))
                rc = rc + 1
            rows_out.push(row_cells)
            dump_lines.push(row_cells.join("|"))
        r = r + 1

    val table_node = table_widget("sheet_grid", headers, rows_out)
    val root = column("sheet_gui_root", [table_node])
    val tree = build_tree_with_title(root, "Simple Sheet", "light")
    SheetGuiView(tree: tree, text_dump: dump_lines.join("\n"))

fn office_gui_sheet_pixels(view: SheetGuiView) -> [u32]:
    """Render a SheetGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_frame uses."""
    val state = init_state(view.tree)
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_sheet_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

fn office_gui_frame(app_name: text) -> [u32]:
    """Render ONE frame of the named office app through the real browser
    layout/paint pixel path and return the ARGB pixel buffer.

    Builds HTML with the same render_html_tree() widget-to-HTML conversion
    BrowserBackend.render_frame() uses, paired with office_gui_minimal_css()
    (see the fallback-knob note above) instead of the full theme CSS, then
    renders it through the same simple_web_engine2d_render_html_pixels()
    entry point production rendering uses (widget-id fixture fast path
    included, unmodified) -- real pixels, never faked.
    """
    val tree = office_gui_build_tree(app_name)
    val state = init_state(tree)
    val body = render_html_tree(tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

fn office_gui_background_pixel(pixels: [u32]) -> u32:
    """Empirical background sample: the bottom-right pixel. The counter
    app's stacked layout (nav + one control row + statusbar) never reaches
    the bottom-right corner of the frame, so this pixel is always
    unrendered background, whatever color the active theme picks."""
    if pixels.len() == 0:
        return 0u32
    pixels[pixels.len() - 1]

fn office_gui_non_background_pixel_count(pixels: [u32]) -> i64:
    """Count pixels that differ from the sampled background — nonzero
    proves the rendered frame carries real widget content, not a blank
    canvas."""
    val background = office_gui_background_pixel(pixels)
    var count: i64 = 0
    for p in pixels:
        if p != background:
            count = count + 1
    count

fn office_gui_pixel_checksum(pixels: [u32]) -> i64:
    """Deterministic checksum over the frame's pixels (order-sensitive sum)."""
    var sum: i64 = 0
    for p in pixels:
        sum = sum + p.to_i64()
    sum

# ---------------------------------------------------------------------------
# Chart GUI view (CARD 16 next pillar): render one of the suite's existing
# sheet_*_chart_svg data sources through the real GUI widget/pixel pipeline.
#
# Key finding: the browser engine has NO inline-SVG support (no "svg" hit
# anywhere under src/lib/gc_async_mut/gpu/browser_engine/ or
# src/app/ui.browser/), so the sheet_*_chart_svg text generators in
# sheets/chart.spl cannot be embedded as-is. Instead this view reuses
# chart.spl's DATA layer only (chart_series_from_ranges, which already
# resolves formula cells to their cached computed value) and renders each
# data point as a "progress" widget: apply_decls/DeclPairs confirmed
# width/height/background ARE supported CSS properties, and the existing
# progress widget already emits a percent-width inner bar
# (render_html_progress: style="width: {value}%") -- a real proportional
# bar out of native widget machinery, no SVG needed.
# ---------------------------------------------------------------------------

fn office_gui_chart_minimal_css() -> text:
    """Curated stylesheet adding the chart view's progress-bar classes on top
    of office_gui_minimal_css's base panel/layout classes. Same fallback-knob
    rationale as office_gui_minimal_css/office_gui_sheet_minimal_css above."""
    office_gui_minimal_css() +
    ".widget-progress{flex-direction:column;margin-bottom:4px;}" +
    ".progress-track{background:#e5e7eb;height:10px;border-radius:3px;}" +
    ".progress-bar{background:#2b579a;height:10px;border-radius:3px;}"

struct ChartGuiView:
    tree: UITree
    text_dump: text

fn _chart_gui_fmt_val(v: f64) -> text:
    """Match chart.spl's _fmt_val: integer-valued floats print without a
    trailing '.0'."""
    val i = v.to_i64()
    if v - i.to_f64() == 0.0:
        return "{i}"
    "{v}"

fn _chart_gui_error_tree(title: text) -> UITree:
    val root = column("chart_gui_root", [text_widget("chart_gui_empty", "No data")])
    build_tree_with_title(root, title, "light")

fn chart_gui_view(sheet: Sheet, chart_kind: text, value_range: text, labels_range: text, title: text, w: i32, h: i32) -> ChartGuiView:
    """Build a GUI chart view of `sheet`'s data (labels from labels_range,
    numbers from value_range -- same two-range shape sheet_*_chart_svg's
    chart_series_from_ranges takes, so formula cells resolve to their cached
    computed value, not raw '=expr' text). Renders one horizontal
    progress-bar widget per data point (bar width% = value's share of the
    max value) under a title text widget, wrapped in a `w`x`h` container.
    Returns both a UITree (for real pixel rendering through the browser
    engine) and a plain-text dump for testability without parsing HTML/
    widget trees: "chart|<kind>|<title>" first, then one
    "bar|<label>|<value>|<pct-of-max>" line per data point. Fail-closed (an
    "error|<reason>" dump line, no crash) when either range is empty/
    unparseable or the two ranges resolve to different lengths."""
    val series = chart_series_from_ranges(sheet, labels_range, value_range)
    var dump_lines: [text] = ["chart|{chart_kind}|{title}"]
    if series.labels.len() == 0 or series.values.len() == 0:
        dump_lines.push("error|empty-range")
        return ChartGuiView(tree: _chart_gui_error_tree(title), text_dump: dump_lines.join("\n"))
    if series.labels.len() != series.values.len():
        dump_lines.push("error|range-length-mismatch")
        return ChartGuiView(tree: _chart_gui_error_tree(title), text_dump: dump_lines.join("\n"))

    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    var axis_max = max_v
    if axis_max <= 0.0:
        axis_max = 1.0

    var bars: [WidgetNode] = []
    val n = series.values.len()
    var i = 0
    while i < n:
        val v = series.values[i]
        val label = series.labels[i]
        val vlab = _chart_gui_fmt_val(v)
        val pct = ((v / axis_max) * 100.0).to_i64()
        var pct_i32 = pct.to_i32()
        if pct_i32 < 0:
            pct_i32 = 0
        val bar_node = progress("chart_bar_{i}", pct_i32)
        val bar_labeled = bar_node.set_prop("label", "{label}: {vlab}")
        bars.push(bar_labeled)
        dump_lines.push("bar|{label}|{vlab}|{pct}")
        i = i + 1

    val title_node = text_widget("chart_gui_title", title)
    var chart_col = column("chart_gui_bars", bars)
    chart_col = with_width(chart_col, w)
    chart_col = with_height(chart_col, h)
    val root = column("chart_gui_root", [title_node, chart_col])
    val tree = build_tree_with_title(root, title, "light")
    ChartGuiView(tree: tree, text_dump: dump_lines.join("\n"))

fn office_gui_chart_pixels(view: ChartGuiView) -> [u32]:
    """Render a ChartGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_frame/office_gui_sheet_pixels use."""
    val state = init_state(view.tree)
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_chart_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")
