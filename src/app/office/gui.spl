# Office GUI Pilot (CARD 16 step 2)
#
# Routes ONE office app's UITree through the REAL UI stack instead of the
# print-root_id dead end: UITree (app.build_ui()) -> HTML (the same
# render_html_tree() widget-to-HTML conversion BrowserBackend.render_frame
# uses) -> browser engine layout/paint pixel path -> ARGB pixels. Headless:
# no window/event loop needed for the pilot.
#
# CSS-size fallback knob (see doc/08_tracking/bug/
# browser_engine_css_size_quadratic_pixel_render_2026-07-04.md): the full
# BrowserBackend.render_frame() path always injects app.ui.web.html's
# generate_css(theme) (~300KB, ~1865 rules) into the page. The layout
# renderer's apply_decls() was fixed to stop re-scanning each rule's decl
# text once per probed property (see simple_web_html_layout_renderer.spl's
# DeclPairs/parse_decl_pairs — ~9x faster on a synthetic worst case), and
# the renderer completes in under a second on the full theme CSS when
# measured standalone. But inside the full office binary (many more
# modules/symbols loaded, interpreter fallback active — see
# CODEGEN-AMBIGUOUS-METHOD notes for text_painter.spl's `_strip_tags`/
# `_normalize_whitespace`) the SAME call measurably does not return within
# 150s+, a gap not explained by the CSS-processing algorithm itself and not
# reproduced by any standalone probe built during this session. Until that
# full-binary-only slowdown is root-caused, this pilot renders through the
# same real layout/paint engine but with a small curated stylesheet (~1KB,
# comfortably inside the ~10KB budget measured feasible at 96x64) covering
# exactly the counter app's widget classes, instead of the full theme CSS.
# This keeps the render on the REAL pixel path (no hard-coded pixels, no
# widget-id fixture fast path involved) while getting the CARD 16 proof
# line to print. Remaining work: root-cause the full-binary slowdown and
# restore full theme CSS here.

use common.ui.widget.{UITree, WidgetNode, UIState, UIEvent, WidgetRect}
use common.ui.state.{init_state}
use common.ui.event.{process_event}
use common.ui.layout.{compute_layout, find_rect}
use common.ui.builder.{column, row, table_widget, build_tree_with_title, text_widget, progress, with_width, with_height}
use app.ui.render.html_widgets.{render_html_tree}
use app.office.counter.{CounterApp}
use app.office.word.word_app.{WordApp}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, col_to_letter, parse_cell_ref, cell_ref_to_string, CellRef, letter_to_col, CellValue}
use app.office.sheets.cell_ref.{offset_ref, parse_range}
use app.office.sheets.chart.{ChartSeries, chart_series_from_ranges}
use app.office.sheets.pivot.{pivot_build}
use app.office.sheets.cond_format.{CondRule, cond_rule_matches_cell, cond_data_bar_percent}
use app.office.sheets.cell_format.{SheetFormats, empty_sheet_formats}
use app.office.sheets.number_format.{cell_display_formatted}
use app.office.sheets.validation.{ValidationRules, validation_check}
use app.office.file_formats.{recalculate_formula_cells}
use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{simple_web_engine2d_render_html_pixels}
use app.office.slides.slide.{Slide, SlideElementKind}
use app.office.slides.deck_format.{bullet_id_level, table_row_cells, is_table_separator_line}

# Matches BrowserApp's viewport (src/app/ui.browser/app.spl uses width=96,
# height=64; its host window presents that scaled by BROWSER_WINDOW_SCALE).
# An 800x600 frame was probed first and exceeds 200s under the interpreter
# (per-pixel interpreted work in the pixel-artifact path), so the pilot
# stays on the framework's own proven viewport.
val OFFICE_GUI_FRAME_WIDTH: i32 = 96
val OFFICE_GUI_FRAME_HEIGHT: i32 = 64

fn office_gui_frame_width() -> i32:
    OFFICE_GUI_FRAME_WIDTH

fn office_gui_frame_height() -> i32:
    OFFICE_GUI_FRAME_HEIGHT

fn office_gui_build_tree(app_name: text) -> UITree:
    """Build the named office app's UITree. Pilot: only "counter" is wired;
    future apps (word/sheets/slides/...) each add one match arm here."""
    match app_name:
        "counter" =>
            return CounterApp.new().build_ui()
        "word" =>
            return WordApp.new().build_ui()
        case _("counter/word wired; unknown names fall back to counter"):
            return CounterApp.new().build_ui()

fn office_gui_minimal_css() -> text:
    """Curated stylesheet covering exactly the widget classes the office
    launcher's build_ui() trees emit today (panel/layout/button/text/nav/
    statusbar). See the CSS-size fallback knob note above this file's
    header comment for why this replaces generate_css(theme) here."""
    ".widget-panel{background:#ffffff;}" +
    ".layout-vbox{flex-direction:column;}" +
    ".layout-hbox{flex-direction:row;}" +
    ".panel-content{flex-direction:column;padding:4px;}" +
    ".widget-navigation-bar{flex-direction:row;background:#f5f5f5;height:24px;}" +
    ".nav-left{flex:1;}" +
    ".nav-title{color:#333333;}" +
    ".nav-right{flex:1;}" +
    ".widget-button{background:#0066cc;color:#ffffff;padding:2px 6px;border-radius:4px;}" +
    ".widget-text{color:#333333;}" +
    ".widget-statusbar{flex-direction:row;background:#f5f5f5;}" +
    ".status-left{flex:1;color:#333333;}" +
    ".status-right{color:#999999;}" +
    # Selected-widget class (GUI polish, styling fidelity pass): a distinct
    # background in addition to the pre-existing border, so a focused
    # widget (e.g. a selected sheet cell -- see office_gui_sheet_session_
    # pixels) is visually distinct, not just outlined. Shared across every
    # office view that ever sets UIState.focused_id -- today only the sheet
    # session path does, so this is additive, not a behavior change for
    # counter/chart/pivot.
    ".focused{border:1px solid #0066cc;background:#dbe9fa;}"

fn office_gui_sheet_minimal_css() -> text:
    """Curated stylesheet covering the sheet grid's widget classes on top of
    office_gui_minimal_css's base panel/layout classes. Same fallback-knob
    rationale as office_gui_minimal_css above: a small curated sheet, not
    the full ~300KB theme CSS.

    Two grid shapes share this stylesheet: pivot_gui_view's table_widget
    grid (widget-table/th/td rules below) and sheet_gui_view/sheet_gui_
    view_with_selection's per-cell row()/text_widget() grid (the
    #sheet_gui_sel_root-scoped rules below -- see gui.spl's sheet_gui_view
    docstring for why the plain sheet view now shares that construction
    too). Styling-fidelity rules (GUI polish pass), verified against the
    real browser-engine pixel path (nth-child, :first-child, ID selectors,
    and descendant/child combinators are all live in this exact render
    path, not just statically present in some selector-matcher source
    file -- confirmed by a scratchpad pixel probe before relying on any of
    them here):
      - header ROW (#sheet_sel_header) and header COLUMN (every row/corner
        cell, which is always the first child of its row -- scoped under
        #sheet_gui_sel_root so this never bleeds into the nav/statusbar
        chrome outside the sheet grid) get the SAME distinct gray as
        pivot's own `th` background, for a consistent header look across
        both grid shapes.
      - zebra striping alternates data ROWS (nth-child position among the
        root's row children -- the header row is nth-child(1), so data
        rows land on nth-child(even)/nth-child(odd) starting at 2): a
        light-gray/white alternation painted on each ROW container; header-
        column/corner cells paint their OWN background over it (child
        paints over parent), so the row/col headers stay solid regardless
        of which stripe they sit on.
      - the existing `.focused` class (extended above with a background)
        already gives the selected cell a distinct look with no new rule
        needed here.
      - fixed column width (sheet_gui_view_with_selection's with_width
        calls, SHEET_GUI_CELL_WIDTH/SHEET_GUI_ROWHDR_WIDTH) is layout, not
        CSS -- nothing to add here for that part."""
    office_gui_minimal_css() +
    ".table-filter{padding:2px 4px;border:1px solid #cccccc;}" +
    ".widget-table{border-collapse:collapse;width:100%;}" +
    ".widget-table th{padding:2px 4px;border:1px solid #cccccc;background:#e8e8e8;text-align:left;}" +
    ".widget-table td{padding:2px 4px;border:1px solid #cccccc;}" +
    "#sheet_gui_sel_root .layout-hbox:nth-child(even){background:#f7f7f7;}" +
    "#sheet_gui_sel_root .layout-hbox:nth-child(odd){background:#ffffff;}" +
    "#sheet_sel_header{background:#e8e8e8;}" +
    "#sheet_gui_sel_root .widget-text:first-child{background:#e8e8e8;}" +
    # Conditional-formatting classes (sheet_gui_view_with_formats / office_
    # gui_sheet_cf_pixels): one small background tint per matched rule kind,
    # and an 11-step white->#638ec6 tint ramp for the data-bar buckets 0-10
    # (the engine's bar is a linear-gradient background -- see cond_format.
    # spl's _data_bar_css -- but this render path's curated CSS keeps to the
    # solid-background rules already proven on the pixel path, so the bucket
    # ramp stands in for gradient fill width).
    ".cf-highlight{background:#fde7e9;}" +
    ".cf-above{background:#e2f0d9;}" +
    ".cf-below{background:#fbe5d5;}" +
    ".cf-dup{background:#ffd9d9;}" +
    ".cf-uniq{background:#dff0ff;}" +
    ".cf-bar-0{background:#ffffff;}" +
    ".cf-bar-1{background:#eff4f9;}" +
    ".cf-bar-2{background:#e0e8f4;}" +
    ".cf-bar-3{background:#d0ddee;}" +
    ".cf-bar-4{background:#c1d2e8;}" +
    ".cf-bar-5{background:#b1c7e3;}" +
    ".cf-bar-6{background:#a1bbdd;}" +
    ".cf-bar-7{background:#92b0d7;}" +
    ".cf-bar-8{background:#82a5d1;}" +
    ".cf-bar-9{background:#7399cc;}" +
    ".cf-bar-10{background:#638ec6;}"

struct SheetGuiView:
    tree: UITree
    text_dump: text

fn sheet_gui_view(sheet: Sheet, max_rows: i32, max_cols: i32) -> SheetGuiView:
    """Build a spreadsheet grid view of `sheet`: column headers A,B,C.. across
    the top, 1-based row numbers down the left, and each visible cell's
    display text (formulas show their cached computed value via
    cell_display_text). Rows in sheet.hidden_rows are skipped entirely so a
    filtered sheet renders filtered. Returns both a UITree (for real pixel
    rendering through the browser engine) and a plain-text pipe-separated
    grid dump (for testability without parsing HTML/widget trees) --
    the header line first, then one line per rendered row.

    Implementation note (closes residual #1 of doc/08_tracking/bug/
    office_gui_no_per_cell_click_target_2026-07-04.md): this is now a thin
    wrapper over sheet_gui_view_with_selection's per-cell "cell_<ref>"
    text_widget construction (an EMPTY selected_ref, "", never matches a
    real cell ref, so no bracket/focus ever renders) instead of a separate
    table_widget call -- the plain table_widget path is gone from the sheet
    view entirely (chart/pivot views keep table_widget, unaffected).

    Byte-compatibility: sheet_gui_view's OLD semantics scan GRID rows 1..
    max_rows and skip hidden ones with NO backfill (a hidden row simply
    produces fewer output lines) -- the OPPOSITE of sheet_gui_view_with_
    selection's own N-VISIBLE window semantics (which backfills past a
    hidden row to keep exactly N visible rows). To preserve the old
    behavior exactly, `view_rows` passed down here is the COUNT of visible
    (non-hidden) rows within 1..max_rows, not max_rows itself: since that
    count already equals the total number of visible rows in that exact
    range, the N-visible forward scan started at row 1 collects precisely
    those rows and stops at max_rows -- it has nothing left to backfill
    with. The "viewport|..." marker line sheet_gui_view_with_selection
    prepends (a concept sheet_gui_view's dump has never had) is stripped
    before returning."""
    var visible_count = 0
    var r = 1
    while r <= max_rows:
        if not sheet.is_row_hidden(r.to_i64()):
            visible_count = visible_count + 1
        r = r + 1

    val session = session_new(sheet, "")
    val view = sheet_gui_view_with_selection(session, visible_count, max_cols)
    val lines = view.text_dump.split("\n")
    var out_lines: [text] = []
    var i = 1
    while i < lines.len():
        out_lines.push(lines[i])
        i = i + 1
    SheetGuiView(tree: view.tree, text_dump: out_lines.join("\n"))

fn office_gui_sheet_pixels(view: SheetGuiView) -> [u32]:
    """Render a SheetGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_frame uses."""
    val state = init_state(view.tree)
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_sheet_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

fn office_gui_frame(app_name: text) -> [u32]:
    """Render ONE frame of the named office app through the real browser
    layout/paint pixel path and return the ARGB pixel buffer.

    Builds HTML with the same render_html_tree() widget-to-HTML conversion
    BrowserBackend.render_frame() uses, paired with office_gui_minimal_css()
    (see the fallback-knob note above) instead of the full theme CSS, then
    renders it through the same simple_web_engine2d_render_html_pixels()
    entry point production rendering uses (widget-id fixture fast path
    included, unmodified) -- real pixels, never faked.
    """
    val tree = office_gui_build_tree(app_name)
    val state = init_state(tree)
    val body = render_html_tree(tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

fn office_gui_background_pixel(pixels: [u32]) -> u32:
    """Empirical background sample: the bottom-right pixel. The counter
    app's stacked layout (nav + one control row + statusbar) never reaches
    the bottom-right corner of the frame, so this pixel is always
    unrendered background, whatever color the active theme picks."""
    if pixels.len() == 0:
        return 0u32
    pixels[pixels.len() - 1]

fn office_gui_non_background_pixel_count(pixels: [u32]) -> i64:
    """Count pixels that differ from the sampled background — nonzero
    proves the rendered frame carries real widget content, not a blank
    canvas."""
    val background = office_gui_background_pixel(pixels)
    var count: i64 = 0
    for p in pixels:
        if p != background:
            count = count + 1
    count

fn office_gui_pixel_checksum(pixels: [u32]) -> i64:
    """Deterministic checksum over the frame's pixels (order-sensitive sum)."""
    var sum: i64 = 0
    for p in pixels:
        sum = sum + p.to_i64()
    sum

# ---------------------------------------------------------------------------
# Chart GUI view (CARD 16 next pillar): render one of the suite's existing
# sheet_*_chart_svg data sources through the real GUI widget/pixel pipeline.
#
# Key finding: the browser engine has NO inline-SVG support (no "svg" hit
# anywhere under src/lib/gc_async_mut/gpu/browser_engine/ or
# src/app/ui.browser/), so the sheet_*_chart_svg text generators in
# sheets/chart.spl cannot be embedded as-is. Instead this view reuses
# chart.spl's DATA layer only (chart_series_from_ranges, which already
# resolves formula cells to their cached computed value) and renders each
# data point as a "progress" widget: apply_decls/DeclPairs confirmed
# width/height/background ARE supported CSS properties, and the existing
# progress widget already emits a percent-width inner bar
# (render_html_progress: style="width: {value}%") -- a real proportional
# bar out of native widget machinery, no SVG needed.
# ---------------------------------------------------------------------------

fn office_gui_chart_minimal_css() -> text:
    """Curated stylesheet adding the chart view's progress-bar classes on top
    of office_gui_minimal_css's base panel/layout classes. Same fallback-knob
    rationale as office_gui_minimal_css/office_gui_sheet_minimal_css above."""
    office_gui_minimal_css() +
    ".widget-progress{flex-direction:column;margin-bottom:4px;}" +
    ".progress-track{background:#e5e7eb;height:10px;border-radius:3px;}" +
    ".progress-bar{background:#2b579a;height:10px;border-radius:3px;}" +
    # Column-chart cells (chart_gui_view's "column" kind): one solid fill
    # class shared by every column cell (same proven solid-background CSS
    # the cf-* classes use), plus bottom alignment for the cell row --
    # layout_core.spl's flex pass implements align-items:flex-end (phase 5
    # cross-axis reposition), and both the panel div and its inner
    # .panel-content wrapper are covered so whichever level the engine
    # treats as the flex container aligns the cells to the baseline. The
    # text_dump contract does NOT depend on this alignment (see
    # chart_gui_view's docstring: top-aligned is the documented fallback).
    ".col-fill{background:#2b579a;}" +
    "#chart_gui_cols{align-items:flex-end;}" +
    "#chart_gui_cols .panel-content{flex-direction:row;align-items:flex-end;}" +
    "#chart_gui_pie .panel-content{flex-direction:row;}" +
    # Pie-chart segment palette (chart_gui_view's "pie" kind): 8 distinct
    # solid backgrounds cycled pie-0..pie-7 (Excel's default chart series
    # colors), one per stacked-strip segment.
    ".pie-0{background:#4472c4;}" +
    ".pie-1{background:#ed7d31;}" +
    ".pie-2{background:#a5a5a5;}" +
    ".pie-3{background:#ffc000;}" +
    ".pie-4{background:#5b9bd5;}" +
    ".pie-5{background:#70ad47;}" +
    ".pie-6{background:#264478;}" +
    ".pie-7{background:#9e480e;}"

# Column-kind cell width (px) and pie-kind strip height (the panel
# renderer's height unit) -- fixed sizes for the proportional-dimension
# charts: a column cell's WIDTH is fixed while its height carries the
# value; a pie segment's HEIGHT is fixed while its width carries the value.
val CHART_GUI_COLUMN_CELL_W: i32 = 6
val CHART_GUI_PIE_STRIP_H: i32 = 2

struct ChartGuiView:
    tree: UITree
    text_dump: text

fn _chart_gui_fmt_val(v: f64) -> text:
    """Match chart.spl's _fmt_val: integer-valued floats print without a
    trailing '.0'."""
    val i = v.to_i64()
    if v - i.to_f64() == 0.0:
        return "{i}"
    "{v}"

fn _chart_gui_error_tree(title: text) -> UITree:
    val root = column("chart_gui_root", [text_widget("chart_gui_empty", "No data")])
    build_tree_with_title(root, title, "light")

fn chart_gui_view(sheet: Sheet, chart_kind: text, value_range: text, labels_range: text, title: text, w: i32, h: i32) -> ChartGuiView:
    """Build a GUI chart view of `sheet`'s data (labels from labels_range,
    numbers from value_range -- same two-range shape sheet_*_chart_svg's
    chart_series_from_ranges takes, so formula cells resolve to their cached
    computed value, not raw '=expr' text). Three GUI-renderable kinds now
    branch here (all through the same proven widget/CSS pixel path, no SVG):
      - "column": a horizontal row of fixed-width cells whose HEIGHT is
        proportional to pct-of-max (height = pct*h/100 via with_height);
        the cell row is bottom-aligned via #chart_gui_cols align-items:
        flex-end (implemented in layout_core.spl's flex phase 5) -- if a
        render path ignores that rule the cells degrade to top-aligned,
        which the text_dump contract does not depend on. Dump lines:
        "col|<label>|<value>|<pct-of-max>".
      - "pie": one horizontal stacked strip -- per-segment cells whose
        WIDTH is proportional to the value's share of the TOTAL (not the
        max), each carrying a distinct pie-0..pie-7 background class
        (8-color cycle), with one "<label>: <value>" text line listed
        below the strip per segment. Dump lines:
        "pie|<label>|<value>|<share-pct-of-total>".
      - anything else (including "bar", the default): the original
        horizontal progress-bar rendering, byte-identical dump to the
        pre-column/pie shape -- one progress widget per data point (bar
        width% = value's share of the max value) under a title text
        widget, wrapped in a `w`x`h` container, with
        "bar|<label>|<value>|<pct-of-max>" dump lines. (Kind validity is
        chart_session_set_kind's job, not this renderer's -- an unknown
        kind reaching here renders as bars exactly as it always has, only
        the "chart|<kind>|<title>" header echoing the name.)
    Returns both a UITree (for real pixel rendering through the browser
    engine) and a plain-text dump for testability without parsing HTML/
    widget trees: "chart|<kind>|<title>" first, then the per-point lines
    above. Fail-closed (an "error|<reason>" dump line, no crash) when
    either range is empty/unparseable or the two ranges resolve to
    different lengths -- identical error dump for every kind."""
    val series = chart_series_from_ranges(sheet, labels_range, value_range)
    var dump_lines: [text] = ["chart|{chart_kind}|{title}"]
    if series.labels.len() == 0 or series.values.len() == 0:
        dump_lines.push("error|empty-range")
        return ChartGuiView(tree: _chart_gui_error_tree(title), text_dump: dump_lines.join("\n"))
    if series.labels.len() != series.values.len():
        dump_lines.push("error|range-length-mismatch")
        return ChartGuiView(tree: _chart_gui_error_tree(title), text_dump: dump_lines.join("\n"))

    val kind_lower = chart_kind.lower()

    if kind_lower == "column":
        # Vertical bars: fixed-width cells, height proportional to
        # pct-of-max (same max-based scale as the bar kind). Inlined here
        # rather than split into a helper because array fields of a struct
        # PARAMETER read 0 under variable indexing in the interpreter
        # (quirk ledger) -- series must stay a local.
        var col_max = 0.0
        for cv in series.values:
            if cv > col_max:
                col_max = cv
        var col_axis = col_max
        if col_axis <= 0.0:
            col_axis = 1.0
        var col_cells: [WidgetNode] = []
        val col_n = series.values.len()
        var ci = 0
        while ci < col_n:
            val cval = series.values[ci]
            val clabel = series.labels[ci]
            val cvlab = _chart_gui_fmt_val(cval)
            val cpct = ((cval / col_axis) * 100.0).to_i64()
            var cell_h = (cpct * h.to_i64()) / 100
            if cell_h < 1:
                # Keep every column at least 1 unit tall so a tiny-but-
                # nonzero point stays visible; the dump carries the exact
                # pct, so no information is lost to this floor.
                cell_h = 1
            var cell = column("chart_col_{ci}", [])
            cell = with_width(cell, CHART_GUI_COLUMN_CELL_W)
            cell = with_height(cell, cell_h.to_i32())
            # The widget prop store is process-global and keyed by widget
            # id (quirk ledger), so the class prop is written
            # UNCONDITIONALLY on every build -- never inherited from a
            # previous render of the same id.
            cell = cell.set_prop("class", "col-fill")
            col_cells.push(cell)
            dump_lines.push("col|{clabel}|{cvlab}|{cpct}")
            ci = ci + 1
        var col_row = row("chart_gui_cols", col_cells)
        col_row = with_width(col_row, w)
        col_row = with_height(col_row, h)
        val col_title = text_widget("chart_gui_title", title)
        val col_root = column("chart_gui_root", [col_title, col_row])
        val col_tree = build_tree_with_title(col_root, title, "light")
        return ChartGuiView(tree: col_tree, text_dump: dump_lines.join("\n"))

    if kind_lower == "pie":
        # Stacked strip: segment width proportional to share of the TOTAL
        # (not the max -- a pie's segments must sum to the whole), one
        # distinct pie-<i%8> background class per segment, labels listed
        # below the strip. Same inlining rationale as the column branch.
        var pie_total = 0.0
        for pv in series.values:
            pie_total = pie_total + pv
        var pie_denom = pie_total
        if pie_denom <= 0.0:
            pie_denom = 1.0
        var pie_segs: [WidgetNode] = []
        var pie_labels: [WidgetNode] = []
        val pie_n = series.values.len()
        var pi = 0
        while pi < pie_n:
            val pval = series.values[pi]
            val plabel = series.labels[pi]
            val pvlab = _chart_gui_fmt_val(pval)
            val pshare = ((pval / pie_denom) * 100.0).to_i64()
            var seg_w = (pshare * w.to_i64()) / 100
            if seg_w < 1:
                # Same minimum-visibility floor as the column branch; the
                # dump carries the exact share.
                seg_w = 1
            var seg = column("chart_pie_seg_{pi}", [])
            seg = with_width(seg, seg_w.to_i32())
            seg = with_height(seg, CHART_GUI_PIE_STRIP_H)
            val color_idx = pi % 8
            # Written unconditionally -- see the column branch's
            # process-global prop-store note.
            seg = seg.set_prop("class", "pie-{color_idx}")
            pie_segs.push(seg)
            pie_labels.push(text_widget("chart_pie_label_{pi}", "{plabel}: {pvlab}"))
            dump_lines.push("pie|{plabel}|{pvlab}|{pshare}")
            pi = pi + 1
        var pie_strip = row("chart_gui_pie", pie_segs)
        pie_strip = with_width(pie_strip, w)
        pie_strip = with_height(pie_strip, CHART_GUI_PIE_STRIP_H)
        val pie_title = text_widget("chart_gui_title", title)
        var pie_children: [WidgetNode] = [pie_title, pie_strip]
        for pl in pie_labels:
            pie_children.push(pl)
        val pie_root = column("chart_gui_root", pie_children)
        val pie_tree = build_tree_with_title(pie_root, title, "light")
        return ChartGuiView(tree: pie_tree, text_dump: dump_lines.join("\n"))

    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    var axis_max = max_v
    if axis_max <= 0.0:
        axis_max = 1.0

    var bars: [WidgetNode] = []
    val n = series.values.len()
    var i = 0
    while i < n:
        val v = series.values[i]
        val label = series.labels[i]
        val vlab = _chart_gui_fmt_val(v)
        val pct = ((v / axis_max) * 100.0).to_i64()
        var pct_i32 = pct.to_i32()
        if pct_i32 < 0:
            pct_i32 = 0
        val bar_node = progress("chart_bar_{i}", pct_i32)
        val bar_labeled = bar_node.set_prop("label", "{label}: {vlab}")
        bars.push(bar_labeled)
        dump_lines.push("bar|{label}|{vlab}|{pct}")
        i = i + 1

    val title_node = text_widget("chart_gui_title", title)
    var chart_col = column("chart_gui_bars", bars)
    chart_col = with_width(chart_col, w)
    chart_col = with_height(chart_col, h)
    val root = column("chart_gui_root", [title_node, chart_col])
    val tree = build_tree_with_title(root, title, "light")
    ChartGuiView(tree: tree, text_dump: dump_lines.join("\n"))

fn chart_gui_html(view: ChartGuiView) -> text:
    """Build the full page HTML for a ChartGuiView tree. render_html_panel
    has no extra-class hook (html_widgets.spl renders only its own
    layout/title/flex props and is outside this surface's owned files), so
    the column/pie cells' "class" props (col-fill / pie-<n>, attached by
    chart_gui_view) land the same way sheet_gui_cf_html's cf-* classes do:
    by rewriting the exact `class="widget-panel layout-vbox" id="<cell id>"`
    attribute pair render_html_panel emits for that cell id. The bar kind
    sets no class props (its progress widgets carry only value/label), so
    its HTML passes through this loop byte-untouched. Split out from
    office_gui_chart_pixels so specs can assert the injected classes on the
    REAL page HTML without paying for a pixel render."""
    val state = init_state(view.tree)
    val root = view.tree.root_node()
    var body = render_html_tree(root, state)
    for row_node in root.children():
        for cell_node in row_node.children():
            val cell_class = cell_node.get_prop("class")
            if cell_class != "":
                val old_attr = "class=\"widget-panel layout-vbox\" id=\"" + cell_node.id + "\""
                val new_attr = "class=\"widget-panel layout-vbox " + cell_class + "\" id=\"" + cell_node.id + "\""
                body = body.replace(old_attr, new_attr)
    "<html><head><style>" + office_gui_chart_minimal_css() + "</style></head><body>" + body + "</body></html>"

fn office_gui_chart_pixels(view: ChartGuiView) -> [u32]:
    """Render a ChartGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_frame/office_gui_sheet_pixels use,
    with the column/pie cell classes injected by chart_gui_html (see
    there; a no-op for the bar kind)."""
    val html = chart_gui_html(view)
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

# ---------------------------------------------------------------------------
# Chart GUI session (CHART GUI INTERACTIVITY): mirrors PivotGuiSession's
# session pattern above -- a small value-type struct plus copy-return op
# functions -- over chart_gui_view instead of pivot_build. No render
# duplication: chart_session_view is a thin wrapper that forwards the
# session's fields straight to the existing chart_gui_view (see that
# function's docstring above for the render/text_dump contract this reuses
# unchanged).
#
# GUI-supported kind list: chart_gui_view (see above) branches on its
# chart_kind argument for "column" (fixed-width cells with proportional
# HEIGHT) and "pie" (one stacked strip whose segment WIDTHS are shares of
# the total, pie-0..pie-7 color cycle), and renders every other kind name
# as the original horizontal progress bars. So "bar", "column", and "pie"
# are the chart_kinds whose GUI rendering genuinely matches their names;
# chart.spl itself knows several more shapes (sheet_line_chart_svg,
# sheet_area_chart_svg, sheet_scatter_chart_svg, sheet_stacked_bar_chart_
# svg, sheet_hbar_chart_svg, sheet_donut_chart_svg), but this GUI cannot
# render any of those as anything other than the bar shape today.
# chart_session_set_kind below is honest about that gap: it accepts only
# bar/column/pie and rejects every other kind name (known-to-chart.spl or
# not) with last_error = "kind-not-in-gui", rather than silently accepting
# a kind whose GUI rendering would not match what the caller asked for.
# ---------------------------------------------------------------------------

val CHART_GUI_SESSION_W: i32 = 80
val CHART_GUI_SESSION_H: i32 = 40

struct ChartGuiSession:
    sheet: Sheet
    chart_kind: text
    value_range: text
    labels_range: text
    title: text
    last_error: text   # "" = no error; else the reason the last op left the session unchanged

fn _chart_gui_kind_is_valid(kind_lower: text) -> bool:
    """The chart_kinds whose GUI rendering genuinely matches their names
    (bar/column/pie -- chart_gui_view's three render branches; see the
    "Chart GUI session" comment block above for why line/area/scatter/
    stacked_bar/hbar/donut still cannot be claimed honestly today).
    Mirrors _pivot_gui_agg_is_valid's role: called before accepting a kind
    change so an unsupported-but-known chart.spl kind can be rejected with
    an honest reason instead of silently rendering the wrong shape."""
    if kind_lower == "bar":
        return true
    if kind_lower == "column":
        return true
    kind_lower == "pie"

fn chart_session_new(sheet: Sheet, chart_kind: text, value_range: text, labels_range: text, title: text) -> ChartGuiSession:
    """Start a chart GUI session over `sheet` with the given chart_kind/
    value_range/labels_range/title -- same parameter order and meaning as
    chart_gui_view's own arguments (see that function's docstring), so an
    existing chart_gui_view call site can be lifted into a session with no
    reinterpretation of any argument."""
    ChartGuiSession(sheet: sheet, chart_kind: chart_kind, value_range: value_range, labels_range: labels_range, title: title, last_error: "")

fn chart_session_view(session: ChartGuiSession) -> ChartGuiView:
    """Render the session's current state -- forwards straight to
    chart_gui_view (no reimplementation of the series-resolution/render
    logic here, the exact same engine-reuse discipline pivot_session_view
    follows for pivot_gui_view). Uses a fixed CHART_GUI_SESSION_W x
    CHART_GUI_SESSION_H progress-bar container size (matching `office
    chart-gui`'s own demo call site) since ChartGuiSession has no notion of
    a caller-chosen container size -- unlike pivot's table_widget, which
    auto-sizes, chart_gui_view's bar column is explicitly sized."""
    chart_gui_view(session.sheet, session.chart_kind, session.value_range, session.labels_range, session.title, CHART_GUI_SESSION_W, CHART_GUI_SESSION_H)

fn chart_session_set_kind(session: ChartGuiSession, kind: text) -> ChartGuiSession:
    """Change the session's chart kind to `kind` (case-insensitive). "bar",
    "column", and "pie" are GUI-supported (see _chart_gui_kind_is_valid
    above) -- any other kind, INCLUDING ones chart.spl itself knows how to
    render as SVG (line/area/scatter/stacked_bar/hbar/donut), leaves the
    session UNCHANGED (chart_kind untouched) except `last_error`, set to
    "kind-not-in-gui" -- documented fail-closed, honest about what this GUI
    actually renders rather than accepting a kind name it would silently
    ignore. A valid kind clears last_error back to "". Returns a NEW
    session (copy semantics) -- callers must reassign."""
    val kind_lower = kind.lower()
    if not _chart_gui_kind_is_valid(kind_lower):
        return ChartGuiSession(sheet: session.sheet, chart_kind: session.chart_kind, value_range: session.value_range, labels_range: session.labels_range, title: session.title, last_error: "kind-not-in-gui")
    ChartGuiSession(sheet: session.sheet, chart_kind: kind, value_range: session.value_range, labels_range: session.labels_range, title: session.title, last_error: "")

fn chart_session_set_value_range(session: ChartGuiSession, range_a1: text) -> ChartGuiSession:
    """Re-point the session's data range to `range_a1` (e.g. Excel's
    "Select Data" range re-point, modeled here as swapping value_range on
    an otherwise-unchanged session -- the next chart_session_view call
    reads whatever column `range_a1` names). An unparseable/empty
    `range_a1` (parse_range returns nil) leaves the session UNCHANGED
    (value_range untouched) except last_error, set to "empty-range" --
    mirrors chart_gui_view's own "error|empty-range" dump line and
    pivot_session_set_value_col's fail-closed discipline above. A valid
    range clears last_error back to "". Returns a NEW session (copy
    semantics) -- callers must reassign."""
    val range_val = parse_range(range_a1)
    if range_val == nil:
        return ChartGuiSession(sheet: session.sheet, chart_kind: session.chart_kind, value_range: session.value_range, labels_range: session.labels_range, title: session.title, last_error: "empty-range")
    ChartGuiSession(sheet: session.sheet, chart_kind: session.chart_kind, value_range: range_a1, labels_range: session.labels_range, title: session.title, last_error: "")

fn chart_session_set_title(session: ChartGuiSession, title: text) -> ChartGuiSession:
    """Change the session's chart title to `title` -- always succeeds (no
    validity constraint on a title string), clearing last_error back to
    "". Returns a NEW session (copy semantics) -- callers must reassign."""
    ChartGuiSession(sheet: session.sheet, chart_kind: session.chart_kind, value_range: session.value_range, labels_range: session.labels_range, title: title, last_error: "")

# ---------------------------------------------------------------------------
# Chart GUI key-driven step (mirrors pivot_gui_step's quit modeling -- see
# the "Live loop bridge" comment block below GuiLiveStepResult/run_gui_
# live_step -- so a later live loop over ChartGuiSession can reuse the SAME
# per-keystroke shape; per this round's scope, no live CLI or
# interactive.spl change is added yet).
# ---------------------------------------------------------------------------

struct ChartGuiStepResult:
    session: ChartGuiSession
    quit: bool

fn _chart_gui_next_kind(kind_lower: text) -> text:
    """Cycle order across the GUI-supported kind list: bar -> column ->
    pie -> bar (see _chart_gui_kind_is_valid above). Falls back to "bar"
    for any kind_lower outside the supported list (defensive only -- every
    ChartGuiSession.chart_kind reaching here already passed
    chart_session_set_kind's validity check)."""
    if kind_lower == "bar":
        return "column"
    if kind_lower == "column":
        return "pie"
    "bar"

fn chart_gui_step(session: ChartGuiSession, key: text) -> ChartGuiStepResult:
    """One decoded key name -> one ChartGuiSession transition: "k" cycles
    chart_kind through the GUI-supported kind list (via _chart_gui_next_
    kind + chart_session_set_kind -- always a valid kind, so last_error is
    always cleared by this branch); "t" appends "*" to title (via
    chart_session_set_title -- a demo-visible mutation with no validity
    constraint); "q", "ctrl_c" (Ctrl-C), and "eof" (stdin closed) signal
    quit via ChartGuiStepResult.quit rather than raising/exiting -- mirrors
    pivot_gui_step/run_gui_live_step's quit modeling exactly, so the
    session returned alongside a quit is the session UNCHANGED from just
    before the quit key. Any other key is a no-op (session unchanged, quit
    false)."""
    if key == "q" or key == "ctrl_c" or key == "eof":
        return ChartGuiStepResult(session: session, quit: true)
    if key == "k":
        val next_kind = _chart_gui_next_kind(session.chart_kind.lower())
        return ChartGuiStepResult(session: chart_session_set_kind(session, next_kind), quit: false)
    if key == "t":
        return ChartGuiStepResult(session: chart_session_set_title(session, "{session.title}*"), quit: false)
    ChartGuiStepResult(session: session, quit: false)

# ---------------------------------------------------------------------------
# Pivot-table GUI view (CARD 16 third pillar): render the suite's existing
# pivot_build engine (sheets/pivot.spl) through the same table_widget
# machinery sheet_gui_view uses -- no reimplementation of the grouping/
# aggregation logic here, only the GUI-view/text_dump wrapper.
#
# Engine-reuse notes: pivot_gui_view's (sheet, data_range, row_field_col,
# col_field_col, value_col, agg_name, title) parameter list maps directly
# onto pivot_build(sheet, range_a1, row_key_col, col_key_col, value_col, agg)
# -- same order, same meaning -- so no adaptation was needed at the call
# site beyond the extra `title` (GUI framing only, same role as
# chart_gui_view's `title`). pivot_build's own agg-name validity list
# (sum/count/average/min/max) is private to pivot.spl (not exported), so
# `_pivot_gui_agg_is_valid` below duplicates that same 5-name check purely
# to produce a distinct "unknown-agg" dump line before calling the engine
# (pivot_build itself already fails closed on a bad agg name by returning
# `[]`, but folds that outcome together with several other invalid-input
# cases under one empty result).
# ---------------------------------------------------------------------------

struct PivotGuiView:
    tree: UITree
    text_dump: text

fn _pivot_gui_agg_is_valid(agg_lower: text) -> bool:
    """Mirrors pivot.spl's private _agg_is_valid (sum/count/average/min/max,
    case-insensitive) -- duplicated here only so an unknown agg name can be
    reported as its own "unknown-agg" dump line before calling pivot_build."""
    (agg_lower == "sum" or agg_lower == "count" or agg_lower == "average" or
     agg_lower == "min" or agg_lower == "max")

fn _pivot_gui_error_tree(title: text) -> UITree:
    val root = column("pivot_gui_root", [text_widget("pivot_gui_empty", "No data")])
    build_tree_with_title(root, title, "light")

fn pivot_gui_view(sheet: Sheet, data_range: text, row_field_col: i32, col_field_col: i32, value_col: i32, agg_name: text, title: text) -> PivotGuiView:
    """Build a GUI pivot-table view of `sheet`'s data: runs the existing
    pivot_build engine over `data_range` (grouping by `row_field_col` and,
    when `col_field_col >= 0`, cross-tabulating by `col_field_col`,
    aggregating `value_col` with `agg_name`), then renders the resulting
    grid through the same table_widget machinery sheet_gui_view uses --
    the engine's own header row (row-key label + column keys + "Grand
    Total") becomes the table's headers, and every remaining row (each
    row-key row plus the engine's own grand-total row) becomes a table
    row, exactly as pivot_build lays them out (see sheets/pivot.spl).

    Returns both a UITree (for real pixel rendering through the browser
    engine) and a plain-text dump for testability without parsing HTML/
    widget trees: "pivot|<agg>|<title>" first, then one pipe-joined line
    per row of the engine's result grid (its column-keys header row, each
    data row, and its grand-total row -- totals row/col exactly as the
    engine provides them). Fail-closed (an "error|<reason>" dump line, no
    crash) when `agg_name` is not one of sum/count/average/min/max, or when
    `data_range` is empty/unparseable/out-of-bounds (pivot_build itself
    returns `[]` for all of these -- reported here as "empty-range")."""
    var dump_lines: [text] = ["pivot|{agg_name}|{title}"]
    val agg_lower = agg_name.lower()
    if not _pivot_gui_agg_is_valid(agg_lower):
        dump_lines.push("error|unknown-agg")
        return PivotGuiView(tree: _pivot_gui_error_tree(title), text_dump: dump_lines.join("\n"))

    val result = pivot_build(sheet, data_range, row_field_col, col_field_col, value_col, agg_name)
    if result.len() == 0:
        dump_lines.push("error|empty-range")
        return PivotGuiView(tree: _pivot_gui_error_tree(title), text_dump: dump_lines.join("\n"))

    var r = 0
    while r < result.len():
        val row = result[r]
        dump_lines.push(row.join("|"))
        r = r + 1

    val headers = result[0]
    var rows_out: [[text]] = []
    var r2 = 1
    while r2 < result.len():
        rows_out.push(result[r2])
        r2 = r2 + 1

    val table_node = table_widget("pivot_grid", headers, rows_out)
    val root = column("pivot_gui_root", [table_node])
    val tree = build_tree_with_title(root, title, "light")
    PivotGuiView(tree: tree, text_dump: dump_lines.join("\n"))

fn office_gui_pivot_pixels(view: PivotGuiView) -> [u32]:
    """Render a PivotGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_sheet_pixels uses -- reuses
    office_gui_sheet_minimal_css since a pivot grid is rendered through the
    exact same table_widget/widget-table CSS classes as the sheet grid."""
    val state = init_state(view.tree)
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_sheet_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

# ---------------------------------------------------------------------------
# Pivot GUI session (PIVOT-TABLE INTERACTIVITY): mirrors SheetGuiSession's
# session pattern below -- a small value-type struct plus copy-return op
# functions -- over pivot_gui_view/pivot_build instead of the sheet grid.
# No render duplication: pivot_session_view is a thin wrapper that forwards
# the session's fields straight to the existing pivot_gui_view (see that
# function's docstring above for the render/text_dump contract this reuses
# unchanged).
# ---------------------------------------------------------------------------

struct PivotGuiSession:
    sheet: Sheet
    data_range: text
    row_field_col: i32
    col_field_col: i32
    value_col: i32
    agg_name: text
    title: text
    last_error: text   # "" = no error; else the reason the last op left the session unchanged

fn pivot_session_new(sheet: Sheet, data_range: text, row_field_col: i32, col_field_col: i32, value_col: i32, agg_name: text, title: text) -> PivotGuiSession:
    """Start a pivot GUI session over `sheet` with the given data_range/
    row_field_col/col_field_col/value_col/agg_name/title -- same parameter
    order and meaning as pivot_gui_view's own arguments (see that function's
    docstring), so an existing pivot_gui_view call site can be lifted into a
    session with no reinterpretation of any argument."""
    PivotGuiSession(sheet: sheet, data_range: data_range, row_field_col: row_field_col, col_field_col: col_field_col, value_col: value_col, agg_name: agg_name, title: title, last_error: "")

fn pivot_session_view(session: PivotGuiSession) -> PivotGuiView:
    """Render the session's current state -- forwards straight to
    pivot_gui_view (no reimplementation of the grouping/aggregation/render
    logic here, the exact same engine-reuse discipline pivot_gui_view
    itself follows for pivot_build)."""
    pivot_gui_view(session.sheet, session.data_range, session.row_field_col, session.col_field_col, session.value_col, session.agg_name, session.title)

fn pivot_session_set_agg(session: PivotGuiSession, agg: text) -> PivotGuiSession:
    """Change the session's aggregation to `agg` (sum/count/average/min/max,
    case-insensitive -- same validity list as pivot_gui_view/pivot_build's
    own agg-name check, mirrored here by _pivot_gui_agg_is_valid above). An
    invalid `agg` name leaves the session UNCHANGED (agg_name untouched)
    except for `last_error`, set to "unknown-agg" -- documented fail-closed,
    mirrors pivot_gui_view's own "error|unknown-agg" dump line rather than
    crashing or silently substituting a default. A valid `agg` clears
    last_error back to "". Returns a NEW session (copy semantics) -- callers
    must reassign."""
    val agg_lower = agg.lower()
    if not _pivot_gui_agg_is_valid(agg_lower):
        return PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: session.value_col, agg_name: session.agg_name, title: session.title, last_error: "unknown-agg")
    PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: session.value_col, agg_name: agg, title: session.title, last_error: "")

fn pivot_session_swap_fields(session: PivotGuiSession) -> PivotGuiSession:
    """Transpose the pivot: row_field_col and col_field_col trade places, so
    the next pivot_session_view renders with the old column-keys as the new
    row keys and vice versa (the engine's own row/col cross-tab, just fed
    swapped field indices -- see pivot_build's row_key_col/col_key_col
    parameters). Swapping a 1D pivot (col_field_col == -1, no cross-tab
    field to swap in) leaves the session UNCHANGED except for last_error,
    set to "no-col-field" -- documented fail-closed rather than producing an
    invalid row_field_col == -1 that pivot_build would reject outright.
    Returns a NEW session (copy semantics) -- callers must reassign."""
    if session.col_field_col == -1:
        return PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: session.value_col, agg_name: session.agg_name, title: session.title, last_error: "no-col-field")
    PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.col_field_col, col_field_col: session.row_field_col, value_col: session.value_col, agg_name: session.agg_name, title: session.title, last_error: "")

fn pivot_session_set_value_col(session: PivotGuiSession, col_letter: text) -> PivotGuiSession:
    """Change the session's value column to `col_letter`'s (e.g. "C")
    ABSOLUTE sheet column, converted to the 0-based-WITHIN-data_range index
    pivot_build's value_col parameter expects (column 0 = data_range's
    leftmost column -- see pivot_build's docstring above sheets/pivot.spl).
    An unparseable data_range, or a `col_letter` left of the range's own
    leftmost column, leaves the session UNCHANGED except for last_error
    ("empty-range" / "bad-col" respectively) -- documented fail-closed, same
    discipline as pivot_session_set_agg above. Returns a NEW session (copy
    semantics) -- callers must reassign."""
    val range_val = parse_range(session.data_range)
    if range_val == nil:
        return PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: session.value_col, agg_name: session.agg_name, title: session.title, last_error: "empty-range")
    val min_col = if range_val.start.col < range_val.end_ref.col: range_val.start.col else: range_val.end_ref.col
    val new_value_col = letter_to_col(col_letter) - min_col
    if new_value_col < 0:
        return PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: session.value_col, agg_name: session.agg_name, title: session.title, last_error: "bad-col")
    PivotGuiSession(sheet: session.sheet, data_range: session.data_range, row_field_col: session.row_field_col, col_field_col: session.col_field_col, value_col: new_value_col, agg_name: session.agg_name, title: session.title, last_error: "")

fn pivot_session_field_letters(session: PivotGuiSession) -> (text, text):
    """Column letters for the session's current row_field_col/col_field_col,
    computed against data_range's own leftmost column -- for human-readable
    step logging only (e.g. `office pivot-gui`'s scripted step dump);
    pivot_session_view/pivot_gui_view pass the raw 0-based-within-range
    indices straight to pivot_build unchanged, never these letters.
    col_field_col == -1 (1D pivot) renders its half of the pair as "-"; an
    unparseable data_range renders both halves as "?" rather than
    crashing."""
    val range_val = parse_range(session.data_range)
    if range_val == nil:
        return ("?", "?")
    val min_col = if range_val.start.col < range_val.end_ref.col: range_val.start.col else: range_val.end_ref.col
    val row_letter = col_to_letter(min_col + session.row_field_col)
    var col_letter = "-"
    if session.col_field_col != -1:
        col_letter = col_to_letter(min_col + session.col_field_col)
    (row_letter, col_letter)

# ---------------------------------------------------------------------------
# Pivot GUI key-driven step (mirrors run_gui_live_step's quit modeling below
# -- see the "Live loop bridge" comment block above GuiLiveStepResult/
# run_gui_live_step -- so a later live loop over PivotGuiSession can reuse
# the SAME per-keystroke shape; per this round's scope, no live CLI or
# interactive.spl change is added yet).
# ---------------------------------------------------------------------------

struct PivotGuiStepResult:
    session: PivotGuiSession
    quit: bool

fn _pivot_gui_next_agg(agg_lower: text) -> text:
    """Cycle order sum -> count -> average -> min -> max -> sum (wraps).
    Falls back to "sum" for any agg_lower outside the 5 known names
    (defensive only -- every PivotGuiSession.agg_name reaching here already
    passed _pivot_gui_agg_is_valid, via pivot_session_new or
    pivot_session_set_agg)."""
    if agg_lower == "sum":
        return "count"
    if agg_lower == "count":
        return "average"
    if agg_lower == "average":
        return "min"
    if agg_lower == "min":
        return "max"
    if agg_lower == "max":
        return "sum"
    "sum"

fn pivot_gui_step(session: PivotGuiSession, key: text) -> PivotGuiStepResult:
    """One decoded key name -> one PivotGuiSession transition: "a" cycles
    agg_name through sum/count/average/min/max in order (via
    _pivot_gui_next_agg + pivot_session_set_agg -- always a valid agg, so
    last_error is always cleared by this branch); "s" swaps row_field_col/
    col_field_col (pivot_session_swap_fields); "q", "ctrl_c" (Ctrl-C), and
    "eof" (stdin closed) signal quit via PivotGuiStepResult.quit rather than
    raising/exiting -- mirrors run_gui_live_step's quit modeling exactly (see
    GuiLiveStepResult below), so the session returned alongside a quit is the
    session UNCHANGED from just before the quit key. Any other key is a
    no-op (session unchanged, quit false)."""
    if key == "q" or key == "ctrl_c" or key == "eof":
        return PivotGuiStepResult(session: session, quit: true)
    if key == "a":
        val next_agg = _pivot_gui_next_agg(session.agg_name.lower())
        return PivotGuiStepResult(session: pivot_session_set_agg(session, next_agg), quit: false)
    if key == "s":
        return PivotGuiStepResult(session: pivot_session_swap_fields(session), quit: false)
    PivotGuiStepResult(session: session, quit: false)

# ---------------------------------------------------------------------------
# Sheet GUI session (first INTERACTION pillar): cell selection + cell edit +
# recalculation.
#
# Capability-probe finding (see doc/08_tracking/bug/
# office_gui_no_per_cell_click_target_2026-07-04.md for the full writeup):
# common.ui.event.process_event / handle_pointer IS a real event-dispatch
# machine (hit-tests a laid-out tree at (x,y), moves state.focused_id,
# routes key presses to the focused widget -- see src/lib/common/ui/
# event.spl:37-250). But office/gui.spl's render path never calls it (each
# office-gui frame is built and painted once, no loop), and more
# fundamentally sheet_gui_view's grid is built by builder.spl's
# table_widget(), which folds every row's cells into ONE child text node
# whose "label" prop is a single pipe-joined string
# (src/lib/common/ui/builder.spl:259-288); html_widgets.spl's
# render_html_table() splits that string back into plain "<td>{cell}</td>"
# tags with no id/data-action per cell (src/app/ui.render/html_widgets.spl:
# 268-307). There is no per-cell widget id to hit-test, click, or focus --
# real click-to-select on today's sheet_gui_view table is not wired and
# cannot be added without changing shared table_widget/render_html_table
# (outside this lane's owned files).
#
# What DOES work today, reused as-is (no framework changes): render_html_
# widget already computes a real per-widget "focused" CSS class by comparing
# node.id to state.focused_id (html_widgets.spl:71-72), and .focused is
# already defined in office_gui_minimal_css. sheet_gui_view_with_selection
# below builds the grid as one row()/text_widget() panel per sheet row (each
# cell a real widget with id "cell_<ref>") instead of table_widget's
# single-string-per-row shape, so the selected cell's widget id can be
# matched by state.focused_id and get a REAL distinct CSS class through the
# existing mechanism -- honest MVP: the full session/state/edit/recalc/
# re-render loop is real, only the input-DEVICE layer (mouse/keyboard event
# source feeding process_event) is stubbed by scripting session_select/
# session_edit calls directly instead of routing OS events through
# handle_pointer/handle_keypress.
# ---------------------------------------------------------------------------

# Fixed per-cell pixel widths (GUI polish, styling fidelity pass): every
# data/header-letter cell gets the SAME width, and every row-number/corner
# cell gets its own (narrower) SAME width, so columns visually align
# instead of each text_widget auto-sizing to its own content.
val SHEET_GUI_CELL_WIDTH: i32 = 18
val SHEET_GUI_ROWHDR_WIDTH: i32 = 10

struct SheetGuiSession:
    sheet: Sheet
    selected_ref: text
    pending_input: text   # uncommitted typed buffer for selected_ref; "" = none
    view_top_row: i32     # 1-based first GRID row of the current viewport window
    view_left_col: i32    # 1-based first GRID column of the window (1 = column A)

fn session_new(sheet: Sheet, selected_ref: text) -> SheetGuiSession:
    """Start a GUI session over `sheet` with `selected_ref` (e.g. "D2")
    already selected, and the viewport window anchored at the top-left
    corner (view_top_row=1, view_left_col=1 -- column A). That default
    anchor is what keeps every pre-viewport caller's behavior EXACTLY
    unchanged: as long as the window (max_rows x max_cols passed to
    sheet_gui_view_with_selection/session_key/session_select) covers the
    whole sheet, no scroll ever triggers."""
    SheetGuiSession(sheet: sheet, selected_ref: selected_ref, pending_input: "", view_top_row: 1, view_left_col: 1)

fn session_select(session: SheetGuiSession, ref_str: text, view_rows: i32, view_cols: i32) -> SheetGuiSession:
    """Move the selection to `ref_str`. Discards any uncommitted pending
    buffer (a selection change abandons in-progress typing, same as an
    arrow-key move via session_key -- only "enter" commits). `view_rows`/
    `view_cols` is the viewport window's SIZE (visible rows/cols, matching
    the same values passed to sheet_gui_view_with_selection) -- if
    `ref_str` falls outside the CURRENT window, the viewport scrolls the
    minimum amount needed to bring it into view (see _sheet_gui_scroll_to_
    show_row/_col below); already-visible refs leave the viewport
    untouched. Returns a NEW session (copy semantics) -- callers must
    reassign."""
    var new_top = session.view_top_row
    var new_left = session.view_left_col
    val parsed = parse_cell_ref(ref_str)
    if parsed != nil:
        new_top = _sheet_gui_scroll_to_show_row(session.sheet, session.view_top_row, view_rows, parsed.row + 1)
        val new_left0 = _sheet_gui_scroll_to_show_col(session.view_left_col - 1, view_cols, parsed.col)
        new_left = new_left0 + 1
    SheetGuiSession(sheet: session.sheet, selected_ref: ref_str, pending_input: "", view_top_row: new_top, view_left_col: new_left)

fn session_edit(session: SheetGuiSession, ref_str: text, new_text: text) -> SheetGuiSession:
    """Set `ref_str`'s raw content to `new_text` (replacing whatever was
    there before, formula or literal), recalculate every formula cell in the
    sheet, and return a NEW session with the recalculated sheet. The
    selection, any pending typed buffer, and the current viewport window
    are all preserved across the edit -- callers must reassign."""
    var sheet = session.sheet
    sheet.set_value(ref_str, new_text)
    sheet = recalculate_formula_cells(sheet)
    SheetGuiSession(sheet: sheet, selected_ref: session.selected_ref, pending_input: session.pending_input, view_top_row: session.view_top_row, view_left_col: session.view_left_col)

# ---------------------------------------------------------------------------
# Validation-enforced editing (Excel data-validation parity at ENTRY time).
#
# Why a composite outcome struct instead of a last_error FIELD on
# SheetGuiSession (the chart/pivot sessions' pattern): sheet_gui_session_
# spec.spl constructs SheetGuiSession(...) DIRECTLY with today's five fields
# at three sites, and struct default-field omission is broken in interpreter
# mode (quirk ledger) -- adding a sixth field would break those existing
# specs. So the session struct stays untouched and the validated entry
# points below return SheetEditOutcome pairing the (possibly unchanged)
# session with the validation verdict; plain session_edit/session_key keep
# their exact signatures and behavior for every existing call site.
# ---------------------------------------------------------------------------

struct SheetEditOutcome:
    session: SheetGuiSession
    last_error: text   # "" = the edit committed; else the validation message and the session is UNCHANGED

fn session_edit_validated(session: SheetGuiSession, ref_str: text, new_text: text, vrules: ValidationRules) -> SheetEditOutcome:
    """session_edit with Excel-style data validation enforced at entry:
    `new_text` is checked against `vrules` (validation.spl's own
    validation_check -- cell-exact or column rules, nothing re-decided
    here) BEFORE it touches the sheet. Invalid input REJECTS the edit the
    way Excel's validation dialog does: the returned outcome's session is
    the input session UNCHANGED (cell keeps its old value, no
    recalculation, same selection/buffer/viewport -- a re-render dumps
    byte-identically) and last_error carries the rule's message. Valid
    input commits through session_edit exactly as an unvalidated edit
    would, with last_error "". An EMPTY rules container accepts
    everything -- session_edit_validated(s, r, t, empty_validation_rules())
    is session_edit(s, r, t). Callers must use the returned outcome's
    session (copy semantics)."""
    val check_result = validation_check(vrules, session.sheet, ref_str, new_text)
    if not check_result.ok:
        return SheetEditOutcome(session: session, last_error: check_result.message)
    SheetEditOutcome(session: session_edit(session, ref_str, new_text), last_error: "")

fn session_key_validated(session: SheetGuiSession, key: text, max_rows: i32, max_cols: i32, view_rows: i32, view_cols: i32, vrules: ValidationRules) -> SheetEditOutcome:
    """session_key with data validation enforced on the ONLY key that
    commits cell content: "enter" with a non-empty pending buffer runs the
    buffer through validation_check against the selected cell first --
    invalid input leaves the session ENTIRELY unchanged (the pending
    buffer is RETAINED, mirroring Excel's validation dialog keeping you in
    the cell to fix the entry; a re-render still shows the mid-typing
    "<ref>:<buffer>" form) and sets last_error to the rule's message;
    valid input commits through session_key's own enter path. Every other
    key (arrows, typing, escape, backspace, empty-buffer enter) is
    delegated to session_key untouched with last_error "" -- validation
    gates COMMITTED values only, never typing in progress. Callers must
    use the returned outcome's session (copy semantics)."""
    if key == "enter" and session.pending_input != "":
        val check_result = validation_check(vrules, session.sheet, session.selected_ref, session.pending_input)
        if not check_result.ok:
            return SheetEditOutcome(session: session, last_error: check_result.message)
    SheetEditOutcome(session: session_key(session, key, max_rows, max_cols, view_rows, view_cols), last_error: "")

# ---------------------------------------------------------------------------
# UNDO/REDO (core Office behavior the session previously lacked).
#
# Same extension rule as SheetEditOutcome above: SheetGuiSession is
# constructed DIRECTLY in existing specs, so it gains no fields -- edit
# history lives in a separate SheetGuiHistory value threaded through the
# *_undoable entry points via SheetEditUndoOutcome.
#
# Why parallel text arrays instead of reusing common.office.undo's
# UndoStack: UndoStack.undo/redo return Option<UndoEntry>, which fails HIR
# lowering ("Unknown variable: Option while lowering UndoStack.undo" --
# probe-verified 2026-07-04) and drags every importing module to the
# interpreter. Parallel arrays + a cursor need no Option and no
# Dict-in-struct (quirk ledger item 7), and probe clean under the
# interpreter.
#
# History model: refs/old_texts/new_texts are index-aligned; `cursor`
# points PAST the last APPLIED entry, so entries at index >= cursor are the
# redo tail. Recording a new edit TRUNCATES that tail first (Excel parity:
# a fresh edit after undo discards the redo branch). Undo/redo re-apply the
# stored RAW cell text through session_edit's set+recalculate path, so
# formula cells come back as live formula TEXT (never the cached display
# value) and every dependent recalculates.
# ---------------------------------------------------------------------------

struct SheetGuiHistory:
    refs: [text]        # cell ref per recorded edit ("B2")
    old_texts: [text]   # raw content BEFORE the edit (formula TEXT, not cached value)
    new_texts: [text]   # raw content the edit committed
    cursor: i64         # points past the last APPLIED entry; >= cursor = redo tail

fn history_new() -> SheetGuiHistory:
    """Empty edit history: nothing to undo, nothing to redo."""
    SheetGuiHistory(refs: [], old_texts: [], new_texts: [], cursor: 0)

fn history_can_undo(h: SheetGuiHistory) -> bool:
    h.cursor > 0

fn history_can_redo(h: SheetGuiHistory) -> bool:
    h.cursor < h.refs.len()

fn history_record(h: SheetGuiHistory, ref_str: text, old_text: text, new_text: text) -> SheetGuiHistory:
    """Append one committed edit, truncating any redo tail beyond the
    cursor first (a new edit after undo discards the redo branch, matching
    Excel). Returns a NEW history (copy semantics) -- callers reassign."""
    var refs: [text] = []
    var olds: [text] = []
    var news: [text] = []
    var i = 0
    while i < h.cursor:
        refs.push(h.refs[i])
        olds.push(h.old_texts[i])
        news.push(h.new_texts[i])
        i = i + 1
    refs.push(ref_str)
    olds.push(old_text)
    news.push(new_text)
    SheetGuiHistory(refs: refs, old_texts: olds, new_texts: news, cursor: refs.len())

fn _sheet_gui_cell_raw_text(sheet: Sheet, ref_str: text) -> text:
    """Raw EDITABLE content of `ref_str` -- what you would type to recreate
    the cell via set_value: formula cells give back "=<expr>" (the formula
    TEXT, never the cached display value), empty cells "", everything else
    its display text. Cells written through session_edit always carry the
    default general style, so the display text round-trips through
    set_value unchanged."""
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.FormulaVal(expr, cached_display):
            return "={expr}"
        CellValue.Empty:
            return ""
        CellValue.TextVal(value):
            return value
        CellValue.NumberVal(value):
            return cell_display_text(cell)
        CellValue.BoolVal(value):
            return cell_display_text(cell)
        CellValue.ErrorVal(message):
            return cell_display_text(cell)
    ""

struct SheetEditUndoOutcome:
    session: SheetGuiSession
    history: SheetGuiHistory
    last_error: text   # "" = op applied; else message and session+history UNCHANGED

fn session_edit_undoable(session: SheetGuiSession, history: SheetGuiHistory, ref_str: text, new_text: text, vrules: ValidationRules) -> SheetEditUndoOutcome:
    """session_edit_validated with undo history: validation is still
    enforced first, and ONLY a validly COMMITTED edit records a history
    entry (a rejected edit changes neither session nor history, so undo
    depth is exactly the number of real changes). The recorded old value is
    the cell's raw text BEFORE the edit -- for a formula cell that is the
    formula text itself, so undo restores a live formula, not its cached
    number. Callers reassign both outcome.session and outcome.history."""
    val old_text = _sheet_gui_cell_raw_text(session.sheet, ref_str)
    val outcome = session_edit_validated(session, ref_str, new_text, vrules)
    if outcome.last_error != "":
        return SheetEditUndoOutcome(session: session, history: history, last_error: outcome.last_error)
    val recorded = history_record(history, ref_str, old_text, new_text)
    SheetEditUndoOutcome(session: outcome.session, history: recorded, last_error: "")

fn session_undo(session: SheetGuiSession, history: SheetGuiHistory) -> SheetEditUndoOutcome:
    """Revert the newest applied history entry by writing its OLD raw text
    back through session_edit (the same set+recalculate path as a normal
    edit, so every dependent formula recalculates) and moving the cursor
    back one; the entry stays in the arrays as the redo tail. At the
    beginning of history this is a fail-closed no-op: the outcome carries
    the session and history UNCHANGED with last_error "nothing-to-undo"."""
    if not history_can_undo(history):
        return SheetEditUndoOutcome(session: session, history: history, last_error: "nothing-to-undo")
    val idx = history.cursor - 1
    val ref_str = history.refs[idx]
    val old_text = history.old_texts[idx]
    val reverted = session_edit(session, ref_str, old_text)
    val moved = SheetGuiHistory(refs: history.refs, old_texts: history.old_texts, new_texts: history.new_texts, cursor: idx)
    SheetEditUndoOutcome(session: reverted, history: moved, last_error: "")

fn session_redo(session: SheetGuiSession, history: SheetGuiHistory) -> SheetEditUndoOutcome:
    """Re-apply the first redo-tail entry by writing its NEW raw text back
    through session_edit (set+recalculate, dependents update) and moving
    the cursor forward one. At the end of history this is a fail-closed
    no-op: session and history come back UNCHANGED with last_error
    "nothing-to-redo"."""
    if not history_can_redo(history):
        return SheetEditUndoOutcome(session: session, history: history, last_error: "nothing-to-redo")
    val idx = history.cursor
    val ref_str = history.refs[idx]
    val new_text = history.new_texts[idx]
    val reapplied = session_edit(session, ref_str, new_text)
    val moved = SheetGuiHistory(refs: history.refs, old_texts: history.old_texts, new_texts: history.new_texts, cursor: idx + 1)
    SheetEditUndoOutcome(session: reapplied, history: moved, last_error: "")

fn session_key_undoable(session: SheetGuiSession, history: SheetGuiHistory, key: text, max_rows: i32, max_cols: i32, view_rows: i32, view_cols: i32, vrules: ValidationRules) -> SheetEditUndoOutcome:
    """session_key_validated with undo history and two extra keys:
    "ctrl_z" runs session_undo and "ctrl_y" runs session_redo (fail-closed
    "nothing-to-undo"/"nothing-to-redo" at the ends). "enter" with a
    non-empty pending buffer is the ONLY key that commits cell content, so
    it is the only key that records history -- and only when validation
    accepts the buffer (a rejected enter keeps the buffer, sets last_error,
    and records nothing, exactly session_key_validated's semantics). Every
    other key delegates to session_key_validated with the history passed
    through untouched."""
    if key == "ctrl_z":
        return session_undo(session, history)
    if key == "ctrl_y":
        return session_redo(session, history)
    if key == "enter" and session.pending_input != "":
        val ref_str = session.selected_ref
        val pending = session.pending_input
        val old_text = _sheet_gui_cell_raw_text(session.sheet, ref_str)
        val commit_outcome = session_key_validated(session, key, max_rows, max_cols, view_rows, view_cols, vrules)
        if commit_outcome.last_error != "":
            return SheetEditUndoOutcome(session: commit_outcome.session, history: history, last_error: commit_outcome.last_error)
        val recorded = history_record(history, ref_str, old_text, pending)
        return SheetEditUndoOutcome(session: commit_outcome.session, history: recorded, last_error: "")
    val pass_outcome = session_key_validated(session, key, max_rows, max_cols, view_rows, view_cols, vrules)
    SheetEditUndoOutcome(session: pass_outcome.session, history: history, last_error: pass_outcome.last_error)

fn _sheet_gui_selection_cell_id(ref_str: text) -> text:
    "cell_{ref_str}"

# ---------------------------------------------------------------------------
# Viewport/scroll arithmetic (second INTERACTION pillar: navigable window
# over a sheet larger than the rendered grid, with selection-follows-scroll).
#
# Window semantics -- N-VISIBLE, not N-grid rows: `max_rows`/`view_rows`
# below always means "how many VISIBLE (non-hidden) rows the window shows",
# never "how many consecutive grid row NUMBERS to scan". A hidden row costs
# no space in the viewport: scrolling a 5-row window to start at row 10 with
# row 12 hidden shows rows 10,11,13,14,15 (backfilling the one hidden row
# cost by pulling in row 15) -- exactly Excel's own scrolling behavior,
# where hiding a row does not shrink the screen's row count. Columns have no
# hidden-column concept anywhere in this sheet engine today, so the column
# axis is plain consecutive-index arithmetic (no backfill needed).
# ---------------------------------------------------------------------------

val OFFICE_GUI_SHEET_SCROLL_SCAN_LIMIT: i32 = 2000

fn _sheet_gui_visible_rows(sheet: Sheet, start_row: i32, count: i32) -> [i32]:
    """Forward-scan from `start_row` (inclusive), collecting up to `count`
    VISIBLE 1-based grid row numbers (skipping every sheet.is_row_hidden
    row). This is the core "N-visible window" primitive: the returned list
    IS the window's actual rendered row set, in grid order, however far
    forward it had to backfill past hidden rows. Bounded by
    OFFICE_GUI_SHEET_SCROLL_SCAN_LIMIT rows past `start_row` so a
    pathological all-hidden sheet cannot loop forever."""
    var collected: [i32] = []
    var scan_row = start_row
    val cap = start_row + OFFICE_GUI_SHEET_SCROLL_SCAN_LIMIT
    while collected.len() < count and scan_row <= cap and scan_row >= 1:
        if not sheet.is_row_hidden(scan_row.to_i64()):
            collected.push(scan_row)
        scan_row = scan_row + 1
    collected

fn _sheet_gui_visible_rows_before(sheet: Sheet, end_row: i32, count: i32) -> [i32]:
    """Backward-scan from `end_row` (inclusive) down to row 1, collecting up
    to `count` VISIBLE row numbers, then returned in ASCENDING (grid) order
    -- i.e. the window of up to `count` visible rows that ENDS at
    `end_row`. Used to compute "scroll backward just enough to reveal this
    row at the BOTTOM of the window" (page-up / arrow-up past the top
    edge). Returns fewer than `count` entries near the top of the sheet."""
    var collected: [i32] = []
    var scan_row = end_row
    while collected.len() < count and scan_row >= 1:
        if not sheet.is_row_hidden(scan_row.to_i64()):
            collected.push(scan_row)
        scan_row = scan_row - 1
    var ascending: [i32] = []
    var j = collected.len() - 1
    while j >= 0:
        ascending.push(collected[j])
        j = j - 1
    ascending

fn _sheet_gui_next_visible_row(sheet: Sheet, after_row: i32) -> i32:
    """First VISIBLE row strictly after `after_row` (skips hidden rows).
    Falls back to after_row + 1 if none is found within the scroll scan
    limit (degenerate all-hidden case)."""
    var scan_row = after_row + 1
    val cap = after_row + OFFICE_GUI_SHEET_SCROLL_SCAN_LIMIT
    while scan_row <= cap:
        if not sheet.is_row_hidden(scan_row.to_i64()):
            return scan_row
        scan_row = scan_row + 1
    after_row + 1

fn _sheet_gui_prev_visible_row(sheet: Sheet, before_row: i32) -> i32:
    """First VISIBLE row strictly before `before_row` (skips hidden rows),
    scanning back to row 1. Falls back to row 1 if none is found."""
    var scan_row = before_row - 1
    while scan_row >= 1:
        if not sheet.is_row_hidden(scan_row.to_i64()):
            return scan_row
        scan_row = scan_row - 1
    1

fn _sheet_gui_scroll_to_show_row(sheet: Sheet, view_top_row: i32, view_rows: i32, target_row: i32) -> i32:
    """New view_top_row so `target_row` is visible in a `view_rows`-tall
    N-visible window -- the MINIMAL scroll: unchanged if `target_row` is
    already in the current window; otherwise the target becomes the window's
    new TOP row (target above the window) or its new BOTTOM row (target
    below the window), never overshooting further than needed."""
    val current = _sheet_gui_visible_rows(sheet, view_top_row, view_rows)
    var i = 0
    var already_visible = false
    while i < current.len():
        val cur_row = current[i]
        if cur_row == target_row:
            already_visible = true
        i = i + 1
    if already_visible:
        return view_top_row
    if current.len() > 0:
        val first_visible = current[0]
        if target_row < first_visible:
            return target_row
    else:
        return target_row
    val ending_here = _sheet_gui_visible_rows_before(sheet, target_row, view_rows)
    if ending_here.len() > 0:
        return ending_here[0]
    target_row

fn _sheet_gui_scroll_to_show_col(view_left_col0: i32, view_cols: i32, target_col0: i32) -> i32:
    """New 0-based view_left_col so `target_col0` (0-based) is visible in a
    `view_cols`-wide window -- minimal scroll, no hidden-column backfill
    (this sheet engine has no hidden-column concept)."""
    if target_col0 >= view_left_col0 and target_col0 < view_left_col0 + view_cols:
        return view_left_col0
    if target_col0 < view_left_col0:
        return target_col0
    target_col0 - view_cols + 1

fn sheet_gui_view_with_selection(session: SheetGuiSession, max_rows: i32, max_cols: i32) -> SheetGuiView:
    """Like sheet_gui_view, but each cell is its own text_widget (id
    "cell_<ref>") inside per-row row() panels instead of a single
    table_widget -- so the selected cell's widget id can pick up a real
    "focused" CSS class via office_gui_sheet_session_pixels below. The
    selected cell's display text is also bracketed ("[80]") in both the
    widget content and the text_dump, so selection is observable without
    parsing HTML or pixels. When session.pending_input is non-empty (a
    session_key typing sequence in progress on the selected cell, not yet
    committed via "enter"), the selected cell's text is shown as
    "<ref>:<buffer>" instead of the bracket form, so specs can assert
    mid-typing state without parsing HTML/pixels either.

    Viewport: `max_rows`/`max_cols` are the window's SIZE in VISIBLE rows/
    columns (see the "Viewport/scroll arithmetic" comment above for why
    N-visible, not N-grid, is the chosen semantics), and the window starts
    at session.view_top_row/view_left_col (both 1-based; view_left_col=1 is
    column A) instead of always starting at row 1/column A -- so the SAME
    grid a plain (non-session) sheet_gui_view would show is what renders
    when view_top_row=1 and view_left_col=1 (session_new's defaults),
    keeping every pre-viewport caller's behavior byte-for-byte unchanged.
    Column/row headers show the window's ACTUAL letters/numbers (e.g. C..F
    over rows 10..14), not the 0-based/1-based window-relative position.
    text_dump's FIRST line is a viewport marker, "viewport|<top_ref>:
    <bottom_right_ref>", so specs can assert the window's exact position
    without re-deriving it from the header/row lines.

    Implementation: a thin wrapper over sheet_gui_view_with_formats with an
    EMPTY rule list -- no conditional-formatting rule ever matches, so the
    tree and text_dump stay byte-for-byte what this function has always
    produced (the cf marker/class code is a no-op on every cell)."""
    val no_rules: [CondRule] = []
    sheet_gui_view_with_formats(session, no_rules, max_rows, max_cols)

fn _sheet_gui_cf_marker(sheet: Sheet, rules: [CondRule], ref_str: text) -> text:
    """First-match conditional-format marker for one cell, "" when no rule
    matches. Rule matching is 100% the engine's own (cond_format.spl's
    cond_rule_matches_cell / cond_data_bar_percent wrappers) in the SAME
    first-match-wins rule order as the engine's cond_css_for_cell -- this
    layer only names the match. Kind -> marker: data_bar -> "bar<N>" where
    N is the engine's fill-percent bucketed to percent/10 (0..10: range
    minimum = bar0, maximum = bar10); above_average -> "above";
    below_average -> "below"; duplicate -> "dup"; unique -> "uniq"; the
    plain highlight kinds (cell_value/top_n/color_scale) -> "hi"."""
    var i = 0
    while i < rules.len():
        val rule = rules[i]
        if cond_rule_matches_cell(sheet, rule, ref_str):
            if rule.kind == "data_bar":
                val p = cond_data_bar_percent(sheet, rule, ref_str)
                val bucket = p / 10
                return "bar{bucket}"
            if rule.kind == "above_average":
                return "above"
            if rule.kind == "below_average":
                return "below"
            if rule.kind == "duplicate":
                return "dup"
            if rule.kind == "unique":
                return "uniq"
            return "hi"
        i = i + 1
    ""

fn _sheet_gui_cf_class(marker: text) -> text:
    """Map a _sheet_gui_cf_marker marker to its office_gui_sheet_minimal_css
    class: "" -> ""; "bar<N>" -> "cf-bar-<N>"; "above"/"below"/"dup"/
    "uniq" -> "cf-above"/"cf-below"/"cf-dup"/"cf-uniq"; "hi" ->
    "cf-highlight"."""
    if marker == "":
        return ""
    if marker.starts_with("bar"):
        val n = marker.slice(3, marker.len())
        return "cf-bar-" + n
    if marker == "above":
        return "cf-above"
    if marker == "below":
        return "cf-below"
    if marker == "dup":
        return "cf-dup"
    if marker == "uniq":
        return "cf-uniq"
    "cf-highlight"

fn sheet_gui_view_with_formats(session: SheetGuiSession, rules: [CondRule], max_rows: i32, max_cols: i32) -> SheetGuiView:
    """sheet_gui_view_with_selection's exact grid construction (per-cell
    "cell_<ref>" text_widgets, selection bracket/pending-buffer forms,
    N-visible viewport window, "viewport|..." marker line -- see that
    function's docstring; it now delegates here) plus LIVE conditional
    formatting, Excel-style: every cell is checked against `rules` (first
    match wins, the engine's own cond_css_for_cell order) via cond_format.
    spl's evaluation wrappers. A matched cell gets
      - a "class" prop on its cell widget carrying the cf-* CSS class
        (cf-highlight / cf-bar-0..10 / cf-above / cf-below / cf-dup /
        cf-uniq -- see _sheet_gui_cf_marker/_sheet_gui_cf_class), painted
        on the real pixel path by office_gui_sheet_cf_pixels below;
      - a "!<marker>" suffix on its text_dump cell (e.g. "42!bar7",
        "8!above") so specs assert matches without parsing pixels or HTML.
        The widget's visible TEXT stays clean (formatting is a style, not
        cell content -- only the dump carries the marker).
    An empty `rules` list renders byte-identically to
    sheet_gui_view_with_selection.

    Implementation: a thin wrapper over sheet_gui_view_full with an EMPTY
    SheetFormats container -- formats_get on an empty container returns the
    general/default spec (num_fmt "") for every cell, so
    cell_display_formatted falls back to cell_display_text on every cell
    and the tree and text_dump stay byte-for-byte what this function has
    always produced."""
    sheet_gui_view_full(session, rules, empty_sheet_formats(), max_rows, max_cols)

fn sheet_gui_view_full(session: SheetGuiSession, rules: [CondRule], formats: SheetFormats, max_rows: i32, max_cols: i32) -> SheetGuiView:
    """sheet_gui_view_with_formats' exact grid construction (per-cell
    "cell_<ref>" text_widgets, selection bracket/pending-buffer forms,
    N-visible viewport window, "viewport|..." marker line, live cf-* rule
    classes/"!<marker>" dump suffixes -- see that function's docstring; it
    now delegates here) plus NUMBER-FORMAT-AWARE display, Excel-style:
    every cell's display text comes from number_format.spl's
    cell_display_formatted(sheet, formats, ref) instead of the raw
    cell_display_text, so a cell whose FormatSpec carries a num_fmt code
    (e.g. "$#,##0.00") renders its formatted string ("$1,234.50") in BOTH
    the cell widget's text and the text_dump line. Cells without a format
    entry (or with num_fmt "") fall back to cell_display_text inside
    cell_display_formatted itself, so they render byte-identically to
    sheet_gui_view_with_formats -- passing empty_sheet_formats() IS
    sheet_gui_view_with_formats. The selection bracket ("[...]") and
    pending-buffer ("<ref>:<buffer>") forms wrap the FORMATTED text, same
    as they wrap the raw text today, and cf "!<marker>" dump suffixes
    attach after the formatted text ("$42.00!hi")."""
    val sheet = session.sheet
    val left_col0 = session.view_left_col - 1
    val visible_rows = _sheet_gui_visible_rows(sheet, session.view_top_row, max_rows)

    var headers: [text] = [""]
    var corner_cell = text_widget("sheet_sel_hdr_corner", "")
    corner_cell = with_width(corner_cell, SHEET_GUI_ROWHDR_WIDTH)
    var header_cells: [WidgetNode] = [corner_cell]
    var c = 0
    while c < max_cols:
        val letter = col_to_letter(left_col0 + c)
        headers.push(letter)
        var hdr_cell = text_widget("sheet_sel_hdr_{letter}", letter)
        hdr_cell = with_width(hdr_cell, SHEET_GUI_CELL_WIDTH)
        header_cells.push(hdr_cell)
        c = c + 1
    val header_row = row("sheet_sel_header", header_cells)

    var row_nodes: [WidgetNode] = [header_row]
    var dump_lines: [text] = [headers.join("|")]
    var ri = 0
    while ri < visible_rows.len():
        val r = visible_rows[ri]
        var rowhdr_cell = text_widget("sheet_sel_rowhdr_{r}", "{r}")
        rowhdr_cell = with_width(rowhdr_cell, SHEET_GUI_ROWHDR_WIDTH)
        var row_cells: [WidgetNode] = [rowhdr_cell]
        var dump_cells: [text] = ["{r}"]
        var rc = 0
        while rc < max_cols:
            val ref_str = "{col_to_letter(left_col0 + rc)}{r}"
            var cell_text = cell_display_formatted(sheet, formats, ref_str)
            if ref_str == session.selected_ref:
                if session.pending_input != "":
                    cell_text = "{ref_str}:{session.pending_input}"
                else:
                    cell_text = "[{cell_text}]"
            var data_cell = text_widget(_sheet_gui_selection_cell_id(ref_str), cell_text)
            data_cell = with_width(data_cell, SHEET_GUI_CELL_WIDTH)
            val cf_marker = _sheet_gui_cf_marker(sheet, rules, ref_str)
            var dump_text = cell_text
            if cf_marker != "":
                dump_text = cell_text + "!" + cf_marker
            # The widget prop store is process-global and keyed by widget id,
            # so the class prop is written UNCONDITIONALLY ("" when no rule
            # matches): a cell that stops matching on a later render (value
            # edited, rule removed) must CLEAR its stale cf class, not keep
            # painting last render's tint.
            data_cell = data_cell.set_prop("class", _sheet_gui_cf_class(cf_marker))
            row_cells.push(data_cell)
            dump_cells.push(dump_text)
            rc = rc + 1
        row_nodes.push(row("sheet_sel_row_{r}", row_cells))
        dump_lines.push(dump_cells.join("|"))
        ri = ri + 1

    var top_row = session.view_top_row
    var bottom_row = session.view_top_row
    if visible_rows.len() > 0:
        top_row = visible_rows[0]
        bottom_row = visible_rows[visible_rows.len() - 1]
    val top_ref = "{col_to_letter(left_col0)}{top_row}"
    val bottom_right_ref = "{col_to_letter(left_col0 + max_cols - 1)}{bottom_row}"
    var marked_dump_lines: [text] = ["viewport|{top_ref}:{bottom_right_ref}"]
    var di = 0
    while di < dump_lines.len():
        marked_dump_lines.push(dump_lines[di])
        di = di + 1

    val root = column("sheet_gui_sel_root", row_nodes)
    val tree = build_tree_with_title(root, "Simple Sheet", "light")
    SheetGuiView(tree: tree, text_dump: marked_dump_lines.join("\n"))

fn office_gui_sheet_session_pixels(view: SheetGuiView, selected_ref: text) -> [u32]:
    """Render a sheet_gui_view_with_selection tree to ARGB pixels, with the
    selected cell's widget carrying a real "focused" CSS class: builds
    UIState directly with focused_id set to the selected cell's widget id
    ("cell_<ref>") instead of the unfocused default from init_state, so
    render_html_widget's existing node.id == state.focused_id check (see
    html_widgets.spl) applies .focused for real -- no bespoke class hook."""
    val base_state = init_state(view.tree)
    val state = UIState(
        tree: base_state.tree,
        mode: base_state.mode,
        focused_id: _sheet_gui_selection_cell_id(selected_ref),
        command_buffer: base_state.command_buffer
    )
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_sheet_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

fn sheet_gui_cf_html(view: SheetGuiView, selected_ref: text) -> text:
    """Build the full page HTML for a sheet_gui_view_with_formats tree:
    office_gui_sheet_session_pixels' exact HTML construction (same
    render_html_tree conversion, same focused-cell state, same
    office_gui_sheet_minimal_css stylesheet) plus each matched cell's cf-*
    class (attached by the view builder as the cell widget's "class" prop)
    injected into that cell's rendered class attribute, so the stylesheet's
    cf rules paint it. render_html_text has no extra-class hook
    (html_widgets.spl renders only content/label props and is outside this
    surface's owned files), so the class lands by rewriting the exact
    `class="widget-text" id="cell_<ref>"` attribute pair render_html_text
    emits for that cell id. The FOCUSED cell renders
    `class="widget-text focused"` instead and is deliberately left
    untouched -- selection styling wins over cf tinting, matching Excel's
    selection overlay drawing over conditional fills. Split out from
    office_gui_sheet_cf_pixels so specs can assert the injected classes on
    the REAL page HTML without paying for a pixel render."""
    val base_state = init_state(view.tree)
    val state = UIState(
        tree: base_state.tree,
        mode: base_state.mode,
        focused_id: _sheet_gui_selection_cell_id(selected_ref),
        command_buffer: base_state.command_buffer
    )
    val root = view.tree.root_node()
    var body = render_html_tree(root, state)
    for row_node in root.children():
        for cell_node in row_node.children():
            val cf_class = cell_node.get_prop("class")
            if cf_class != "":
                val old_attr = "class=\"widget-text\" id=\"" + cell_node.id + "\""
                val new_attr = "class=\"widget-text " + cf_class + "\" id=\"" + cell_node.id + "\""
                body = body.replace(old_attr, new_attr)
    "<html><head><style>" + office_gui_sheet_minimal_css() + "</style></head><body>" + body + "</body></html>"

fn office_gui_sheet_cf_pixels(view: SheetGuiView, selected_ref: text) -> [u32]:
    """Render a sheet_gui_view_with_formats tree to ARGB pixels through the
    same real layout/paint pixel path office_gui_sheet_session_pixels uses,
    with the cf-* classes injected by sheet_gui_cf_html (see there)."""
    val html = sheet_gui_cf_html(view, selected_ref)
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

# ---------------------------------------------------------------------------
# Pointer click -> real event dispatch (closes the gap in doc/08_tracking/
# bug/office_gui_no_per_cell_click_target_2026-07-04.md).
#
# The bug doc's remaining concern was about builder.spl's table_widget(),
# which folds a whole sheet row into ONE child text node (no per-cell id).
# sheet_gui_view_with_selection above already sidesteps that: it builds one
# text_widget per cell with id "cell_<ref>" via row()/column() panels. That
# means the per-cell widgets are ALREADY real, addressable, hit-testable
# targets -- common.ui.widget_hit.widget_hit_test/widget_dispatch_click
# (event.spl:230 handle_pointer's callee) hit-test EVERY widget's laid-out
# rect, with no separate "clickable" flag or registered action required
# (widget_hit.spl:80-98: widget_dispatch_click always returns the hit widget
# id; it only does EXTRA prop work for checkbox/input/textfield kinds). So
# no framework change was needed to make cells clickable -- what was missing
# was an office/gui.spl entry point that actually ROUTES a pointer event
# through process_event/handle_pointer instead of calling session_select
# directly, plus a way to compute where a cell lands on screen.
#
# Layout/bounds requirement: widget_hit_test computes rects on demand via
# common.ui.layout.compute_layout(root, 0, 0, w, h) -- there is no
# precomputed/cached layout tree; every hit-test (and every click below)
# re-runs the SAME layout pass render_html_tree's callers already trigger.
# So a click's (x, y) must be interpreted against a chosen viewport (w, h),
# and that viewport must be set via UIEvent.Resize (the framework's own
# mechanism, event.spl:58-61) BEFORE the pointer event -- not a bespoke
# side-channel -- so handle_pointer's _viewport_dim reads it back correctly.
# ---------------------------------------------------------------------------

fn _sheet_gui_cell_ref_from_id(widget_id: text) -> text:
    """Reverse of _sheet_gui_selection_cell_id: "cell_<ref>" -> "<ref>".
    Returns "" for anything that isn't a per-cell widget id (header/
    row-header ids, or the empty id handle_pointer returns when the click
    landed on no widget at all) -- callers use "" to mean "no selection
    change"."""
    if widget_id.starts_with("cell_"):
        return widget_id.slice(5, widget_id.len())
    ""

fn sheet_gui_cell_rect(view: SheetGuiView, ref_str: text, viewport_w: i32, viewport_h: i32) -> WidgetRect?:
    """Look up `ref_str`'s cell widget's laid-out rect at (viewport_w x
    viewport_h), using the SAME common.ui.layout.compute_layout pass
    widget_dispatch_click's hit-test runs internally. Returns nil when the
    cell isn't part of the rendered tree at all (outside max_rows/max_cols,
    or on a hidden row)."""
    val rects = compute_layout(view.tree.root_node(), 0, 0, viewport_w, viewport_h)
    find_rect(rects, _sheet_gui_selection_cell_id(ref_str))

fn sheet_gui_cell_click_point(view: SheetGuiView, ref_str: text, viewport_w: i32, viewport_h: i32) -> (i32, i32):
    """Center point (x, y) of `ref_str`'s cell widget's rect at the given
    viewport -- the coordinates a real pointer click needs to land on that
    cell. Returns (-1, -1) when the cell isn't present in the tree at this
    viewport (see sheet_gui_cell_rect)."""
    match sheet_gui_cell_rect(view, ref_str, viewport_w, viewport_h):
        case Some(r):
            return (r.x + r.w / 2, r.y + r.h / 2)
        case _:
            return (-1, -1)

fn session_click(session: SheetGuiSession, x: i32, y: i32, max_rows: i32, max_cols: i32, viewport_w: i32, viewport_h: i32) -> SheetGuiSession:
    """Real pointer-click path: builds the sheet_gui_view_with_selection tree,
    sets the hit-test viewport via a genuine UIEvent.Resize, then routes a
    genuine UIEvent.MouseEvent("down") through common.ui.event's
    process_event/handle_pointer -- the SAME coordinate hit-test machinery
    (widget_dispatch_click) every other real UI surface in this codebase
    uses; no parallel/bespoke coordinate mapper. handle_pointer moves
    state.focused_id to whichever "cell_<ref>" widget the (x, y) point lands
    on; that id is mapped back to a sheet ref and becomes the new selection.
    Clicking on a point with no per-cell widget under it (empty space, or the
    header/row-header widgets, which carry non-"cell_" ids) leaves the
    selection UNCHANGED -- real click-miss semantics from handle_pointer
    returning the id it actually hit, not a fallback stub. Returns a NEW
    session (copy semantics) -- callers must reassign."""
    val view = sheet_gui_view_with_selection(session, max_rows, max_cols)
    var state = init_state(view.tree)
    state = process_event(state, UIEvent.Resize(width: viewport_w, height: viewport_h))
    state = process_event(state, UIEvent.MouseEvent(x: x.to_f64(), y: y.to_f64(), button: "left", kind: "down"))
    val ref_str = _sheet_gui_cell_ref_from_id(state.focused_id)
    if ref_str == "":
        return session
    # A click can only hit a cell that WAS rendered inside the (max_rows x
    # max_cols) window just built above, so the resulting ref is already
    # inside the viewport -- passing this call's own max_rows/max_cols as
    # session_select's view_rows/view_cols is a guaranteed no-op scroll,
    # not a coincidence.
    session_select(session, ref_str, max_rows, max_cols)

# ---------------------------------------------------------------------------
# Keyboard interaction: arrow-key grid navigation + typed-buffer cell edit.
#
# Capability-probe finding (see doc/08_tracking/bug/
# office_gui_no_per_cell_click_target_2026-07-04.md's keyboard addendum for
# the full writeup): common.ui.event.process_event DOES have a real key-
# dispatch path (UIEvent.KeyPress(key) -> handle_keypress -> per-mode
# handlers, event.spl:37-138) and a real direct-focus event
# (UIEvent.FocusEvent(target_id, "focus") -> handle_focus_event, event.spl:
# 260-271) -- this is not a "zero key support" framework. But neither
# primitive fits this feature without changes outside this lane's owned
# files:
#   - Normal-mode movement (handle_normal_key, event.spl:97-109) only
#     recognizes "j"/"k" (linear focus_next/focus_prev over
#     tree.all_widget_ids() in DOM order) -- there is no "up"/"down"/"left"/
#     "right" key name anywhere in process_event, and no 2D row/column
#     concept at all: focus_next/focus_prev cannot express "same column,
#     next visible row" or "skip a hidden row" without knowing the grid's
#     shape, which lives in this sheet lane, not the framework.
#   - Typed-character routing (handle_insert_key -> widget_hit.spl's
#     widget_dispatch_key, widget_hit.spl:141-158) only acts on widgets
#     whose kind is "input" or "textfield" (checked by name, hard-coded);
#     sheet_gui_view_with_selection's per-cell widgets are text_widgets
#     (kind "text"), so widget_dispatch_key is a silent no-op on them today.
#     Making cells accept typed input through that exact real path would
#     mean changing builder.spl/widget_hit.spl's kind dispatch -- shared
#     framework code, outside src/app/office/gui.spl's owned scope, exactly
#     the same shape of gap the click bug doc already documented for
#     table_widget.
# Unlike session_click (which genuinely NEEDS process_event/handle_pointer:
# there is no way to know which widget a raw (x, y) point lands on without
# running the real hit-test over a laid-out tree), arrow-key navigation has
# no such geometry dependency -- the target ref is fully determined by
# grid arithmetic (current ref + direction + hidden-row skip + clamp).
# Routing that arithmetic through process_event/UIEvent.FocusEvent would
# not reuse any framework behavior, since nothing in process_event
# participates in computing WHICH ref is next -- it would just be a
# build-tree-and-discard-the-result detour. So, per the "zero matching
# key-dispatch primitive for this shape" finding above, session_key below
# is the thin session-level translator the task's fallback path calls for,
# not a workaround for a framework that has no key machinery at all.
# ---------------------------------------------------------------------------

fn _sheet_gui_move_within_bounds(ref_str: text, key: text, max_rows: i32, max_cols: i32, sheet: Sheet) -> text:
    """One arrow-key step from `ref_str`, clamped to the max_rows x max_cols
    grid and never landing on a hidden row. Reuses cell_ref.spl's offset_ref
    (the sheet engine's existing CellRef-delta helper) for the raw column/
    row arithmetic instead of reimplementing it; offset_ref only clamps a
    negative result to 0, so the upper-bound clamp and the hidden-row skip
    loop below are the only new logic (offset_ref has no concept of a grid's
    caller-chosen size or of a sheet's hidden rows)."""
    val parsed = parse_cell_ref(ref_str)
    if parsed == nil:
        return ref_str

    var d_col = 0
    var d_row = 0
    if key == "left":
        d_col = -1
    elif key == "right":
        d_col = 1
    elif key == "up":
        d_row = -1
    elif key == "down":
        d_row = 1
    else:
        return ref_str

    val moved = offset_ref(parsed, d_col, d_row)
    var col = moved.col
    if col >= max_cols:
        col = max_cols - 1
    var row = moved.row
    if row >= max_rows:
        row = max_rows - 1

    if d_row != 0:
        # Hidden-row skip: keep stepping in the same row direction until a
        # visible row is found, or clamp back to the original ref if the
        # grid edge is hit before one is (never wraps around).
        while row >= 0 and row < max_rows and sheet.is_row_hidden((row + 1).to_i64()):
            row = row + d_row
        if row < 0 or row >= max_rows:
            return ref_str

    cell_ref_to_string(CellRef(col: col, row: row))

fn session_key(session: SheetGuiSession, key: text, max_rows: i32, max_cols: i32, view_rows: i32, view_cols: i32) -> SheetGuiSession:
    """Session-level keyboard translator (see the "Keyboard interaction"
    comment block above for why this isn't routed through common.ui.event.
    process_event): "up"/"down"/"left"/"right" move selected_ref within the
    max_rows x max_cols GRID via _sheet_gui_move_within_bounds (clamped at
    the edges, skipping hidden rows -- the selection can never land on a
    hidden row), auto-scroll the view_rows x view_cols VIEWPORT the minimal
    amount needed if that move steps outside the current window (see
    _sheet_gui_scroll_to_show_row/_col), and discard any uncommitted
    pending buffer (same rule as session_select); "enter" commits a
    non-empty pending buffer into selected_ref via session_edit
    (recalculation runs) and clears the buffer, or is a no-op when the
    buffer is already empty; "escape" discards the pending buffer without
    committing; "backspace" trims the last character off the buffer; any
    other single-character key appends to the buffer (mirrors widget_hit.
    spl's widget_dispatch_key single-char convention -- the same
    "printable" definition the framework's own key sink uses, just applied
    to a text_widget cell instead of an input/textfield one, since
    widget_dispatch_key only acts on those two kinds). Every branch below
    carries the viewport (view_top_row/view_left_col) through unchanged
    except the arrow-key branch, which is the only one that can move the
    selection. Returns a NEW session (copy semantics) -- callers must
    reassign."""
    if key == "up" or key == "down" or key == "left" or key == "right":
        val moved_ref = _sheet_gui_move_within_bounds(session.selected_ref, key, max_rows, max_cols, session.sheet)
        var new_top = session.view_top_row
        var new_left = session.view_left_col
        val parsed = parse_cell_ref(moved_ref)
        if parsed != nil:
            new_top = _sheet_gui_scroll_to_show_row(session.sheet, session.view_top_row, view_rows, parsed.row + 1)
            val new_left0 = _sheet_gui_scroll_to_show_col(session.view_left_col - 1, view_cols, parsed.col)
            new_left = new_left0 + 1
        return SheetGuiSession(sheet: session.sheet, selected_ref: moved_ref, pending_input: "", view_top_row: new_top, view_left_col: new_left)
    if key == "enter":
        if session.pending_input == "":
            return session
        val committed = session_edit(session, session.selected_ref, session.pending_input)
        return SheetGuiSession(sheet: committed.sheet, selected_ref: committed.selected_ref, pending_input: "", view_top_row: session.view_top_row, view_left_col: session.view_left_col)
    if key == "escape":
        return SheetGuiSession(sheet: session.sheet, selected_ref: session.selected_ref, pending_input: "", view_top_row: session.view_top_row, view_left_col: session.view_left_col)
    if key == "backspace":
        var buf = session.pending_input
        if buf.len() > 0:
            buf = buf.slice(0, buf.len() - 1)
        return SheetGuiSession(sheet: session.sheet, selected_ref: session.selected_ref, pending_input: buf, view_top_row: session.view_top_row, view_left_col: session.view_left_col)
    if key.len() == 1:
        val buf = "{session.pending_input}{key}"
        return SheetGuiSession(sheet: session.sheet, selected_ref: session.selected_ref, pending_input: buf, view_top_row: session.view_top_row, view_left_col: session.view_left_col)
    session

fn session_scroll(session: SheetGuiSession, direction: text, view_rows: i32, view_cols: i32) -> SheetGuiSession:
    """Explicit page move over a view_rows x view_cols viewport:
    "page_down"/"page_up" jump the window by one full page of VISIBLE rows
    (the next/previous view_rows-tall N-visible window, backfilling past
    hidden rows exactly like sheet_gui_view_with_selection's rendering
    does); "page_left"/"page_right" jump it by view_cols columns (no
    hidden-column concept to backfill). Selection follows the page move
    (mirrors Excel's own Page Down/Up/Left/Right, which move the active
    cell along with the viewport): the selected cell keeps the SAME
    relative position inside the window (same row-within-window for a
    vertical page, same column-within-window for a horizontal page) so it
    is never left scrolled out of view. Unknown directions are a no-op.
    Returns a NEW session (copy semantics) -- callers must reassign."""
    if direction == "page_down" or direction == "page_up":
        val old_visible = _sheet_gui_visible_rows(session.sheet, session.view_top_row, view_rows)
        val parsed_sel = parse_cell_ref(session.selected_ref)
        var sel_col0 = 0
        var sel_row = session.view_top_row
        if parsed_sel != nil:
            sel_col0 = parsed_sel.col
            sel_row = parsed_sel.row + 1
        var offset = 0
        var i = 0
        while i < old_visible.len():
            val cur_row = old_visible[i]
            if cur_row == sel_row:
                offset = i
            i = i + 1
        var new_top = session.view_top_row
        if direction == "page_down" and old_visible.len() > 0:
            val last_row = old_visible[old_visible.len() - 1]
            new_top = _sheet_gui_next_visible_row(session.sheet, last_row)
        if direction == "page_up" and old_visible.len() > 0:
            val first_row = old_visible[0]
            val prev_row = _sheet_gui_prev_visible_row(session.sheet, first_row)
            val prior_page = _sheet_gui_visible_rows_before(session.sheet, prev_row, view_rows)
            if prior_page.len() > 0:
                new_top = prior_page[0]
            else:
                new_top = 1
        val new_visible = _sheet_gui_visible_rows(session.sheet, new_top, view_rows)
        var new_sel_row = new_top
        if new_visible.len() > 0:
            if offset < new_visible.len():
                new_sel_row = new_visible[offset]
            else:
                new_sel_row = new_visible[new_visible.len() - 1]
        val new_ref = cell_ref_to_string(CellRef(col: sel_col0, row: new_sel_row - 1))
        return SheetGuiSession(sheet: session.sheet, selected_ref: new_ref, pending_input: "", view_top_row: new_top, view_left_col: session.view_left_col)
    if direction == "page_left" or direction == "page_right":
        val old_left0 = session.view_left_col - 1
        val parsed_sel = parse_cell_ref(session.selected_ref)
        var sel_row0 = 0
        var sel_col0 = old_left0
        if parsed_sel != nil:
            sel_row0 = parsed_sel.row
            sel_col0 = parsed_sel.col
        var new_left0 = old_left0
        if direction == "page_right":
            new_left0 = old_left0 + view_cols
        else:
            new_left0 = old_left0 - view_cols
            if new_left0 < 0:
                new_left0 = 0
        val col_offset = sel_col0 - old_left0
        var new_sel_col0 = new_left0 + col_offset
        if new_sel_col0 < 0:
            new_sel_col0 = new_left0
        val new_ref = cell_ref_to_string(CellRef(col: new_sel_col0, row: sel_row0))
        return SheetGuiSession(sheet: session.sheet, selected_ref: new_ref, pending_input: "", view_top_row: session.view_top_row, view_left_col: new_left0 + 1)
    session

# ---------------------------------------------------------------------------
# Live loop bridge (closes doc/08_tracking/bug/office_gui_no_per_cell_click_
# target_2026-07-04.md's residual #4, terminal-input half): interactive.spl's
# run_sheet_gui_live drives a REAL termios raw-mode keystroke loop against a
# SheetGuiSession, re-rendering through the real pixel path per keystroke.
# A live raw-mode loop can't itself be exercised from a spec (it blocks on
# stdin), so run_gui_live_step below is the loop's per-keystroke core pulled
# out into a pure, directly spec-testable function -- see
# test/01_unit/app/office/sheet_gui_session_spec.spl's "live loop step"
# describe block.
# ---------------------------------------------------------------------------

struct GuiLiveStepResult:
    session: SheetGuiSession
    quit: bool

fn run_gui_live_step(session: SheetGuiSession, key: text, max_rows: i32, max_cols: i32, view_rows: i32, view_cols: i32) -> GuiLiveStepResult:
    """One decoded key name -> one session transition, for the live sheet-GUI
    loop. "q", "ctrl_c" (Ctrl-C), and "eof" (stdin closed) signal quit via
    GuiLiveStepResult.quit rather than raising/exiting -- the session
    returned alongside a quit is the session UNCHANGED from just before the
    quit key, so quitting can never silently drop an in-progress typed
    buffer. Every other key (arrows/chars/enter/backspace/escape) is
    forwarded to session_key unchanged -- this function adds no new key
    semantics of its own beyond the quit-signal wrapper session_key itself
    has no concept of."""
    if key == "q" or key == "ctrl_c" or key == "eof":
        return GuiLiveStepResult(session: session, quit: true)
    GuiLiveStepResult(session: session_key(session, key, max_rows, max_cols, view_rows, view_cols), quit: false)

# ---------------------------------------------------------------------------
# Slide presenter GUI view (SLIDE PRESENTER SURFACE, fourth pillar): render
# ONE slide of a deck ([Slide], the exact shape deck_format.spl's parse_deck
# returns and pptx_export/html_render already consume) through the same
# session pattern proven for sheet/chart/pivot above.
#
# Honest ceilings: the browser-engine widget path this pilot renders through
# has plain text widgets only -- no <img> bitmap decoding and no per-cell
# table widget wired for slides -- so table elements render as a
# "[table <rows>x<cols>]" placeholder text line and image elements as
# "[image <alt>]" (shape elements, which only PPTX import produces today,
# as "[shape <type>]"). Bullets DO carry their real nesting level (indent
# spaces in the widget text, the level itself in the dump). The full-fidelity
# slide surface stays html_render.spl's render_slide_html; this view is the
# GUI/presenter projection of the same model.
# ---------------------------------------------------------------------------

struct SlideGuiView:
    tree: UITree
    text_dump: text

fn _slide_gui_deck_len(deck: [Slide]) -> i32:
    """Slide count of a deck as i32 (mirrors slide.spl's slide_count, which
    only exists for Presentation, not a bare [Slide] list)."""
    var count: i32 = 0
    for s in deck:
        count = count + 1
    count

fn _slide_gui_table_dim_label(rows_text: text) -> text:
    """"<rows>x<cols>" label for a TableEl's canonical newline-joined
    markdown rows: rows = every non-separator line (header + data rows),
    cols = cell count of the first row. Counts manually (deck_format's
    _table_ncols idiom) rather than trusting len() arithmetic across the
    row-cells array."""
    var nrows = 0
    var ncols = 0
    val lines = rows_text.split("\n")
    for line in lines:
        if not is_table_separator_line(line):
            nrows = nrows + 1
            if nrows == 1:
                val cells = table_row_cells(line)
                for c in cells:
                    ncols = ncols + 1
    "{nrows}x{ncols}"

fn _slide_gui_bullet_indent(level: i32) -> text:
    """Two spaces per bullet nesting level, for the widget text (the dump
    line carries the raw level instead)."""
    var indent = ""
    var i = 0
    while i < level:
        indent = "{indent}  "
        i = i + 1
    indent

fn _slide_gui_error_tree() -> UITree:
    val root = column("slide_gui_root", [text_widget("slide_gui_empty", "No slide")])
    build_tree_with_title(root, "Simple Slides", "light")

fn slide_gui_view(deck: [Slide], slide_index: i32) -> SlideGuiView:
    """Build a GUI view of ONE slide of `deck` (0-based `slide_index`): the
    slide's title (its first element, when that element is a text box -- the
    same index-0-is-title rule html_render.spl's style tagging uses, and the
    slot parse_deck always fills first) as a title text widget, then one text
    widget per remaining element -- bullets indented two spaces per nesting
    level (level from the bullet<level>_<n> id, via deck_format's
    bullet_id_level), plain body text as-is, and tables/images/shapes as
    honest placeholder lines ("[table 2x3]" / "[image alt]" / "[shape rect]"
    -- see the ceiling note in the section comment above).

    Returns both a UITree (for real pixel rendering through the browser
    engine, office_gui_slide_pixels below) and a plain-text dump for
    testability without parsing HTML/widget trees:
    "slide|<index+1>/<total>|<title>" first, then one line per element:
    "bullet|<level>|<text>", "text|<text>", "table|<rows>x<cols>",
    "image|<alt>", "shape|<type>". Fail-closed (an "error|bad-index" dump
    line, no crash) when `slide_index` is outside the deck."""
    val total = _slide_gui_deck_len(deck)
    if slide_index < 0 or slide_index >= total:
        val err_dump = "slide|{slide_index + 1}/{total}|\nerror|bad-index"
        return SlideGuiView(tree: _slide_gui_error_tree(), text_dump: err_dump)
    val slide = deck[slide_index]
    var title = ""
    var start_idx = 0
    if slide.elements.len() > 0:
        val first = slide.elements[0]
        match first.kind:
            SlideElementKind.TextBox(content: content):
                title = content
                start_idx = 1
            _:
                pass_do_nothing("a non-text first element stays a content line")
    var dump_lines: [text] = ["slide|{slide_index + 1}/{total}|{title}"]
    var widgets: [WidgetNode] = [text_widget("slide_gui_title", title)]
    var i = start_idx
    while i < slide.elements.len():
        val el = slide.elements[i]
        match el.kind:
            SlideElementKind.TextBox(content: content):
                if el.id.starts_with("bullet"):
                    val level = bullet_id_level(el.id)
                    dump_lines.push("bullet|{level}|{content}")
                    val indent = _slide_gui_bullet_indent(level)
                    widgets.push(text_widget("slide_gui_el_{i}", "{indent}- {content}"))
                else:
                    dump_lines.push("text|{content}")
                    widgets.push(text_widget("slide_gui_el_{i}", content))
            SlideElementKind.TableEl(rows: rows):
                val dims = _slide_gui_table_dim_label(rows)
                dump_lines.push("table|{dims}")
                widgets.push(text_widget("slide_gui_el_{i}", "[table {dims}]"))
            SlideElementKind.ImageEl(src: src, alt: alt):
                dump_lines.push("image|{alt}")
                widgets.push(text_widget("slide_gui_el_{i}", "[image {alt}]"))
            SlideElementKind.ShapeEl(shape_type: shape_type, fill_color: fill_color):
                dump_lines.push("shape|{shape_type}")
                widgets.push(text_widget("slide_gui_el_{i}", "[shape {shape_type}]"))
        i = i + 1
    val root = column("slide_gui_root", widgets)
    val tree = build_tree_with_title(root, "Simple Slides", "light")
    SlideGuiView(tree: tree, text_dump: dump_lines.join("\n"))

fn office_gui_slide_pixels(view: SlideGuiView) -> [u32]:
    """Render a SlideGuiView's tree to ARGB pixels via the same real
    layout/paint pixel path office_gui_frame uses -- the slide view emits
    only text widgets inside column panels, all covered by
    office_gui_minimal_css's base classes."""
    val state = init_state(view.tree)
    val body = render_html_tree(view.tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_FRAME_WIDTH, OFFICE_GUI_FRAME_HEIGHT, "software")

# ---------------------------------------------------------------------------
# Slide GUI session (presenter navigation): mirrors ChartGuiSession/
# PivotGuiSession's session pattern -- a small value-type struct plus
# copy-return op functions -- over slide_gui_view. No render duplication:
# slide_session_view forwards straight to slide_gui_view.
# ---------------------------------------------------------------------------

struct SlideGuiSession:
    deck: [Slide]
    current_index: i32
    last_error: text   # "" = no error; else the reason the last op left the session unchanged

struct SlideGuiStepResult:
    session: SlideGuiSession
    quit: bool

fn slide_session_new(deck: [Slide]) -> SlideGuiSession:
    """Start a presenter session over `deck`, positioned on the first slide
    (current_index 0). The deck is the exact [Slide] list parse_deck
    returns, so a deck.md load site lifts into a session with no adaptation."""
    SlideGuiSession(deck: deck, current_index: 0, last_error: "")

fn slide_session_view(session: SlideGuiSession) -> SlideGuiView:
    """Render the session's current slide -- forwards straight to
    slide_gui_view (the same engine-reuse discipline chart_session_view/
    pivot_session_view follow)."""
    slide_gui_view(session.deck, session.current_index)

fn slide_session_next(session: SlideGuiSession) -> SlideGuiSession:
    """Advance to the next slide, CLAMPING at the last slide (advancing past
    the end is not an error -- it just stays on the last slide, the same
    silent edge-clamp discipline session_key's arrow moves use -- so
    last_error clears to ""). Returns a NEW session (copy semantics) --
    callers must reassign."""
    val total = _slide_gui_deck_len(session.deck)
    var idx = session.current_index + 1
    if idx > total - 1:
        idx = total - 1
    if idx < 0:
        idx = 0
    SlideGuiSession(deck: session.deck, current_index: idx, last_error: "")

fn slide_session_prev(session: SlideGuiSession) -> SlideGuiSession:
    """Step back to the previous slide, CLAMPING at the first slide (same
    silent edge-clamp as slide_session_next; last_error clears to "").
    Returns a NEW session (copy semantics) -- callers must reassign."""
    var idx = session.current_index - 1
    if idx < 0:
        idx = 0
    SlideGuiSession(deck: session.deck, current_index: idx, last_error: "")

fn slide_session_goto(session: SlideGuiSession, n: i32) -> SlideGuiSession:
    """Jump to slide `n` (1-BASED, the number a presenter reads off the
    "slide|<n>/<total>|..." header). An out-of-range `n` (< 1 or > total)
    leaves the session UNCHANGED (current_index untouched) except
    last_error, set to "bad-index" -- documented fail-closed, mirrors
    slide_gui_view's own "error|bad-index" dump line and the fail-closed
    discipline of pivot_session_set_agg/chart_session_set_kind above. A
    valid `n` clears last_error back to "". Returns a NEW session (copy
    semantics) -- callers must reassign."""
    val total = _slide_gui_deck_len(session.deck)
    if n < 1 or n > total:
        return SlideGuiSession(deck: session.deck, current_index: session.current_index, last_error: "bad-index")
    SlideGuiSession(deck: session.deck, current_index: n - 1, last_error: "")

fn _slide_gui_digit(key: text) -> i32:
    """1-based slide number for a single-digit key name "1".."9"; 0 for
    anything else (0 is never a valid 1-based goto target, so callers can
    use it as the not-a-digit sentinel)."""
    if key == "1":
        return 1
    if key == "2":
        return 2
    if key == "3":
        return 3
    if key == "4":
        return 4
    if key == "5":
        return 5
    if key == "6":
        return 6
    if key == "7":
        return 7
    if key == "8":
        return 8
    if key == "9":
        return 9
    0

fn slide_gui_step(session: SlideGuiSession, key: text) -> SlideGuiStepResult:
    """One decoded key name -> one SlideGuiSession transition, mirroring
    chart_gui_step/pivot_gui_step's quit modeling exactly: "n"/"right"/
    "space" advance (slide_session_next, clamped), "p"/"left" step back
    (slide_session_prev, clamped), a single digit "1".."9" jumps to that
    1-based slide (slide_session_goto -- out-of-range digits fail closed
    with last_error "bad-index", session otherwise unchanged); "q",
    "ctrl_c" (Ctrl-C), and "eof" (stdin closed) signal quit via
    SlideGuiStepResult.quit rather than raising/exiting, with the session
    UNCHANGED from just before the quit key. Any other key is a no-op
    (session unchanged, quit false)."""
    if key == "q" or key == "ctrl_c" or key == "eof":
        return SlideGuiStepResult(session: session, quit: true)
    if key == "n" or key == "right" or key == "space":
        return SlideGuiStepResult(session: slide_session_next(session), quit: false)
    if key == "p" or key == "left":
        return SlideGuiStepResult(session: slide_session_prev(session), quit: false)
    val digit = _slide_gui_digit(key)
    if digit > 0:
        return SlideGuiStepResult(session: slide_session_goto(session, digit), quit: false)
    SlideGuiStepResult(session: session, quit: false)
