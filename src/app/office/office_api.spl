# Office Macro API
#
# Simple IS the office suite's macro language (its "VBA"). A macro is a plain
# Simple script that imports this module and drives documents, sheets, and
# decks through a small, stable object model:
#
#     use app.office.office_api.{macro_open_sheet, macro_set_cell, macro_recalc,
#                                macro_save_sheet, macro_export_html}
#
#     fn main() -> i64:
#         var sh = macro_open_sheet("budget.csv")
#         sh = macro_set_cell(sh, "D1", "=SUM(B1:C1)")
#         sh = macro_recalc(sh)
#         macro_save_sheet(sh, "budget_out.csv")
#         macro_export_html("sheets", "budget_out.csv", "budget.html")
#         0
#
# Run with `bin/simple run my_macro.spl` — no separate engine, no sandboxed
# dialect: the full language, stdlib, and office model are the macro surface.
# Every mutator RETURNS the updated object; callers must reassign (the
# interpreter can pass aggregates by copy).

use std.io_runtime.{read_file, write_file, file_exists}
use common.rich_text.attributed_text.{RichDocument, DocBlock, BlockKind}
use app.office.file_formats.{parse_markdown_document, document_to_markdown, parse_csv_sheet, sheet_to_csv, recalculate_formula_cells, parse_inline_spans}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.slides.slide.{Slide, blank_slide, add_text_box}
use app.office.slides.deck_format.{parse_deck, deck_to_text}
use app.office.render_adapter.{office_render_source}
use app.office.sheets.chart.{sheet_bar_chart_svg}
use app.office.sheets.data_ops.{sheet_sort_range, sheet_filter_rows}
use app.office.word.edit_ops.{document_find, document_replace, document_stats, document_word_count_new, document_character_count, document_paragraph_count}
use app.office.word.mail_merge.{merge_fields, merge_all_markdown}
use app.office.sheets.cond_format.{CondRule, cond_css_for_cell}

# =========================================================================
# Writer documents (markdown-backed)
# =========================================================================

fn macro_open_document(path: text) -> RichDocument:
    """Open a markdown document; a missing file yields an empty document."""
    if not file_exists(path):
        return RichDocument.new(path)
    parse_markdown_document(read_file(path), path)

fn macro_new_document(title: text) -> RichDocument:
    RichDocument.new(title)

fn _doc_push(doc: RichDocument, kind: BlockKind, content: text) -> RichDocument:
    var d = doc
    d.blocks.push(DocBlock(kind: kind, spans: parse_inline_spans(content)))
    d

fn macro_add_heading(doc: RichDocument, level: i32, content: text) -> RichDocument:
    """Append a heading (level 1-3). Inline **bold**/*italic*/`code` parse."""
    if level <= 1:
        return _doc_push(doc, BlockKind.Heading1, content)
    if level == 2:
        return _doc_push(doc, BlockKind.Heading2, content)
    _doc_push(doc, BlockKind.Heading3, content)

fn macro_add_paragraph(doc: RichDocument, content: text) -> RichDocument:
    _doc_push(doc, BlockKind.Paragraph, content)

fn macro_add_bullet(doc: RichDocument, content: text) -> RichDocument:
    _doc_push(doc, BlockKind.BulletItem, content)

fn macro_save_document(doc: RichDocument, path: text) -> bool:
    """Serialize the document to markdown and write it to disk."""
    write_file(path, document_to_markdown(doc))

# =========================================================================
# Calc sheets (CSV-backed)
# =========================================================================

fn macro_open_sheet(path: text) -> Sheet:
    """Open a CSV sheet (formulas compute); missing file yields an empty sheet."""
    if not file_exists(path):
        return Sheet.new(path)
    parse_csv_sheet(read_file(path), path)

fn macro_new_sheet(name: text) -> Sheet:
    Sheet.new(name)

fn macro_set_cell(sheet: Sheet, ref_str: text, value: text) -> Sheet:
    """Set a cell ('=SUM(A1:A3)' formulas, numbers, text). Returns the sheet."""
    var sh = sheet
    sh.set_value(ref_str, value)
    sh

fn macro_get_cell(sheet: Sheet, ref_str: text) -> text:
    """The display text of a cell (computed value for recalced formulas)."""
    cell_display_text(sheet.get_cell(ref_str))

fn macro_recalc(sheet: Sheet) -> Sheet:
    """Recompute every formula cell. Reassign the result."""
    recalculate_formula_cells(sheet)

fn macro_save_sheet(sheet: Sheet, path: text) -> bool:
    """Serialize the sheet's used range to CSV and write it to disk."""
    write_file(path, sheet_to_csv(sheet))

# =========================================================================
# Impress decks (deck-format-backed)
# =========================================================================

fn macro_open_deck(path: text) -> [Slide]:
    """Open a '---'-separated deck file; missing file yields an empty deck."""
    if not file_exists(path):
        return []
    parse_deck(read_file(path))

fn macro_add_slide(deck: [Slide], title: text, body: text) -> [Slide]:
    """Append a slide with a title box and one body box. Returns the deck."""
    var slides = deck
    var s = blank_slide("slide{slides.len() + 1}")
    s = add_text_box(s, "title", title, 60, 60, 840, 120)
    if body != "":
        s = add_text_box(s, "body1", body, 60, 220, 840, 80)
    slides.push(s)
    slides

fn macro_save_deck(deck: [Slide], path: text) -> bool:
    """Serialize the deck back to deck-format text and write it to disk."""
    write_file(path, deck_to_text(deck))

fn macro_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    """An SVG bar chart from two sheet ranges (labels, values)."""
    sheet_bar_chart_svg(sheet, label_range, value_range, title)

fn macro_export_chart(sheet: Sheet, label_range: text, value_range: text, title: text, out_path: text) -> bool:
    """Write an SVG bar chart built from sheet ranges to disk."""
    write_file(out_path, sheet_bar_chart_svg(sheet, label_range, value_range, title))

fn macro_sort_range(sheet: Sheet, range_a1: text, key_col: i32, ascending: bool, has_header: bool) -> Sheet:
    """Sort a range of cells by a key column. Returns the updated sheet.

    Example macro: `sh = macro_sort_range(sh, "A1:C10", 0, true, true)`
    """
    sheet_sort_range(sheet, range_a1, key_col, ascending, has_header)

fn macro_filter_rows(sheet: Sheet, range_a1: text, col: i32, criteria: text) -> [i64]:
    """Filter rows in a range by criteria in a column. Returns 1-based row numbers.

    Example macro: `rows = macro_filter_rows(sh, "A1:C10", 1, ">100")`
    """
    sheet_filter_rows(sheet, range_a1, col, criteria)

fn macro_cond_css(sheet: Sheet, rules: [CondRule], cell_a1: text) -> text:
    """Evaluate conditional formatting rules for a cell. Returns CSS string.

    Example macro:
    ```
    val rule = CondRule(range: "A1:C10", kind: "cell_value", criteria: ">50",
                        n: 0i64, css: "background:#fde7e9")
    val css = macro_cond_css(sh, [rule], "A1")
    ```
    """
    cond_css_for_cell(sheet, rules, cell_a1)

# =========================================================================
# Writer documents (extended)
# =========================================================================

fn macro_find(doc: RichDocument, needle: text) -> [text]:
    """Search document for text. Returns hit locations as 'blockIndex:offset' strings.

    Example macro: `hits = macro_find(doc, "invoice")`
    """
    document_find(doc, needle)

fn macro_replace(doc: RichDocument, needle: text, replacement: text) -> RichDocument:
    """Replace all occurrences of text in a document. Returns updated document.

    Example macro: `doc = macro_replace(doc, "2025", "2026")`
    """
    document_replace(doc, needle, replacement)

fn macro_word_count(doc: RichDocument) -> i64:
    """Count words in a document (whitespace-separated tokens).

    Example macro: `count = macro_word_count(doc)`
    """
    document_word_count_new(doc)

fn macro_character_count(doc: RichDocument) -> i64:
    """Count characters in a document (excluding newlines).

    Example macro: `count = macro_character_count(doc)`
    """
    document_character_count(doc)

fn macro_paragraph_count(doc: RichDocument) -> i64:
    """Count paragraphs in a document (non-empty text blocks).

    Example macro: `count = macro_paragraph_count(doc)`
    """
    document_paragraph_count(doc)

fn macro_merge_fields(doc: RichDocument) -> [text]:
    """Extract mail-merge field names ({{name}}) from document.

    Example macro: `fields = macro_merge_fields(doc)`
    """
    merge_fields(doc)

fn macro_merge_all_markdown(doc: RichDocument, sheet: Sheet) -> text:
    """Merge document against all data rows in sheet, return markdown.

    Example macro: `merged_text = macro_merge_all_markdown(doc, sheet_data)`
    """
    merge_all_markdown(doc, sheet)

# =========================================================================
# Export
# =========================================================================

fn macro_export_html(surface: text, in_path: text, out_path: text) -> bool:
    """Render a document/sheet/deck file to a styled HTML page on disk."""
    if not file_exists(in_path):
        return false
    val result = office_render_source(surface, in_path, read_file(in_path))
    write_file(out_path, result.html_output)
