# Markdown WYSIWYG View
#
# A side-by-side editor view-model: each editable markdown source line is paired
# with its rendered styled-HTML preview (via the shared office style resolver),
# so an IDE can show a WYSIWYG preview *beside* line-by-line source editing.
#
# This is a pure model→view transform (no GUI dependency), so the IDE's TUI and
# GUI surfaces can both consume it.

use std.common.markdown.render.{render_markdown_line_styled_html}

# One editor row: the source line and its rendered preview.
struct WysiwygLine:
    line_no: i32
    source: text
    rendered: text

# The full side-by-side view: source lines paired with previews.
struct WysiwygView:
    lines: [WysiwygLine]

fn build_wysiwyg_view(source: text) -> WysiwygView:
    """Split markdown source into lines and pair each with its styled preview."""
    var lines: [WysiwygLine] = []
    val raw_lines = source.split("\n")
    var n = 0
    for ln in raw_lines:
        lines.push(WysiwygLine(line_no: n, source: ln, rendered: render_markdown_line_styled_html(ln)))
        n = n + 1
    WysiwygView(lines: lines)

fn wysiwyg_line_count(view: WysiwygView) -> i32:
    """Number of editor rows."""
    view.lines.len()

fn wysiwyg_source_pane(view: WysiwygView) -> text:
    """The left (source) pane: the original markdown, line by line."""
    var out: [text] = []
    for l in view.lines:
        out.push(l.source)
    out.join("\n")

fn wysiwyg_preview_pane(view: WysiwygView) -> text:
    """The right (preview) pane: the rendered styled HTML for all lines."""
    var out = "<div class=\"wysiwyg-preview\">"
    for l in view.lines:
        out = "{out}{l.rendered}"
    "{out}</div>"

fn wysiwyg_update_line(view: WysiwygView, line_no: i32, new_source: text) -> WysiwygView:
    """Return a new view with one source line edited and its preview re-rendered,
    leaving the other rows untouched — the core of beside-the-line editing."""
    var lines: [WysiwygLine] = []
    for l in view.lines:
        if l.line_no == line_no:
            lines.push(WysiwygLine(line_no: l.line_no, source: new_source, rendered: render_markdown_line_styled_html(new_source)))
        else:
            lines.push(l)
    WysiwygView(lines: lines)
