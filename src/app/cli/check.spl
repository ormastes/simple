# Check command - parse and validate Simple source files

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

class CheckLogOptions:
    log_mode: text
    progress: text
    valid: bool
    error: text

    static fn defaults() -> CheckLogOptions:
        CheckLogOptions(
            log_mode: "human",
            progress: "summary",
            valid: true,
            error: ""
        )

fn log_options_help() -> [text]:
    [
        "--log-mode <human|llm|json>  Select log rendering mode",
        "--human | --llm | --json     Shorthand log modes",
        "--progress <summary|count|dot|none>",
        "--dots | --count | --no-progress",
        "--quiet | --verbose"
    ]

fn parse_log_options(args: [text]) -> CheckLogOptions:
    var opts = CheckLogOptions.defaults()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--json":
            opts.log_mode = "json"
        elif arg == "--human":
            opts.log_mode = "human"
        elif arg == "--llm":
            opts.log_mode = "llm"
        elif arg == "--dots":
            opts.progress = "dot"
        elif arg == "--count":
            opts.progress = "count"
        elif arg == "--quiet" or arg == "--no-progress":
            opts.progress = "none"
        elif arg.starts_with("--log-mode="):
            opts.log_mode = arg.slice(11, arg.len())
        elif arg == "--log-mode":
            if i + 1 < args.len():
                opts.log_mode = args[i + 1]
                i = i + 1
            else:
                opts.valid = false
                opts.error = "missing --log-mode value"
        elif arg.starts_with("--progress="):
            opts.progress = arg.slice(11, arg.len())
        elif arg == "--progress":
            if i + 1 < args.len():
                opts.progress = args[i + 1]
                i = i + 1
            else:
                opts.valid = false
                opts.error = "missing --progress value"
        i = i + 1
    opts

fn render_progress(mode: text, done: i64, total: i64, label: text) -> text:
    if mode == "none" or mode == "summary":
        return ""
    if mode == "dot":
        return "."
    if label == "":
        return "{done}/{total}"
    "{label}: {done}/{total}"

fn _print_help():
    print "Usage: simple check <file.spl> [file2.spl ...]"
    print ""
    print "Parse and validate Simple source files."
    print ""
    print "Options:"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help       Show this help"

fn _is_log_option(arg: text) -> bool:
    if arg == "--human":
        return true
    if arg == "--llm":
        return true
    if arg == "--json":
        return true
    if arg == "--tui":
        return true
    if arg == "--stdout":
        return true
    if arg == "--quiet":
        return true
    if arg == "--verbose":
        return true
    if arg == "--dots":
        return true
    if arg == "--count":
        return true
    if arg == "--no-progress":
        return true
    if arg == "--log-mode":
        return true
    if arg == "--surface":
        return true
    if arg == "--progress":
        return true
    if arg.starts_with("--log-mode="):
        return true
    if arg.starts_with("--surface="):
        return true
    arg.starts_with("--progress=")

fn _status_name(total_errors: i64) -> text:
    if total_errors == 0:
        return "ok"
    "error"

fn _shell(command: text) -> (text, text, i64):
    rt_process_run("/bin/sh", ["-c", command])

fn _shell_quote(path: text) -> text:
    "'" + path + "'"

fn _path_is_dir(path: text) -> bool:
    val (_, _, code) = _shell("test -d " + _shell_quote(path))
    code == 0

fn _collect_spl_files(path: text) -> [text]:
    if _path_is_dir(path):
        val (out, _, code) = _shell("find " + _shell_quote(path) + " -type f -name '*.spl' | sort")
        if code != 0:
            return []
        var files: [text] = []
        for line in out.split("\n"):
            val trimmed = line.trim()
            if trimmed != "":
                files.push(trimmed)
        return files
    if rt_file_exists(path):
        return [path]
    []

fn _lint_has_errors(output: text) -> bool:
    for line in output.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("Total: "):
            return not trimmed.starts_with("Total: 0 error(s)")
    false

fn _check_path(path: text, as_json: bool) -> i64:
    val (stdout_text, stderr_text, code) = rt_process_run("bin/release/x86_64-unknown-linux-gnu/simple", ["lint", path])
    if code == 0 and not _lint_has_errors(stdout_text):
        return 0
    if not as_json:
        val detail = stderr_text.trim()
        if detail == "" and stdout_text.trim() != "":
            detail = stdout_text.trim()
        if detail != "":
            print "ERROR: {path}: check failed"
            print detail
        else:
            print "ERROR: {path}: check failed"
    1

fn run_check(args: [text]) -> i64:
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        print "ERROR: {log_opts.error}"
        return 1

    var file_args: [text] = []
    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            _print_help()
            return 0
        elif arg == "check":
            ai = ai
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            ai = ai
        elif not arg.starts_with("-"):
            file_args.push(arg)
        ai = ai + 1

    val as_json = log_opts.log_mode == "json"
    if file_args.len() == 0:
        if as_json:
            print "{\"command\":\"check\",\"status\":\"error\",\"checked\":0,\"files\":0,\"errors\":1,\"files_with_errors\":0}"
        else:
            _print_help()
        return 1

    var total_errors: i64 = 0
    var files_checked: i64 = 0
    var files_with_errors: i64 = 0

    for arg in file_args:
        val source_files = _collect_spl_files(arg)
        if source_files.len() == 0:
            if not as_json:
                print "ERROR: file not found: {arg}"
            total_errors = total_errors + 1
            files_with_errors = files_with_errors + 1
            continue

        files_checked = files_checked + source_files.len()
        val failed = _check_path(arg, as_json)
        if failed != 0:
            total_errors = total_errors + failed
            files_with_errors = files_with_errors + 1

    if files_with_errors == 0:
        if log_opts.progress != "summary" and not as_json:
            val progress_line = render_progress(log_opts.progress, file_args.len(), file_args.len(), "check")
            if progress_line != "":
                print progress_line
        if as_json:
            print "{\"command\":\"check\",\"status\":\"ok\",\"checked\":{files_checked},\"files\":{file_args.len()},\"errors\":0,\"files_with_errors\":0}"
            return 0
        print "OK: {files_checked} file(s) checked, no errors"
        return 0

    if log_opts.progress != "summary" and not as_json:
        val progress_line = render_progress(log_opts.progress, file_args.len(), file_args.len(), "check")
        if progress_line != "":
            print progress_line
    if as_json:
        val status = _status_name(total_errors)
        print "{\"command\":\"check\",\"status\":\"{status}\",\"checked\":{files_checked},\"files\":{file_args.len()},\"errors\":{total_errors},\"files_with_errors\":{files_with_errors}}"
        return 1
    print "\n{total_errors} error(s) in {files_with_errors} of {files_checked} file(s)"
    1
