# Check command - parse and validate Simple source files
#
# Runs bounded parse/source validation on each target file. The full compiler
# driver import path loads the whole compiler graph before main() and has been
# observed to terminate ordinary single-file checks, so this command stays on
# the lightweight parser path.
#
# Earlier revisions shelled out to a hardcoded Linux binary path via a raw
# runtime process call, which
# (a) never resolved on non-Linux hosts and (b) routed through a tuple-returning
# extern chain that aborted with no output under the native build. A shell-out
# would also self-delegate: query_diagnostics._run_simple_check already shells
# out to `simple check`, i.e. to this very handler, so check must do the work
# in-process. Both problems are removed here.

use compiler.core.parser.{parse_module, parser_has_errors, parser_get_errors}
use compiler.core.ast.{ast_reset}
use std.nogc_sync_mut.io.file_ops.{file_exists}
use std.nogc_sync_mut.io.file_discovery.{find_spl_files}
use app.cli.query_rich_common.{query_file_read_rich}
use app.cli.repo_hygiene_gate.{run_repo_hygiene_gate}
use app.cli.check_options.{check_option_error}
use app.check.sspec_source.{check_sspec_guidance}

class CheckLogOptions:
    log_mode: text
    progress: text
    valid: bool
    error: text

    static fn defaults() -> CheckLogOptions:
        CheckLogOptions(
            log_mode: "human",
            progress: "summary",
            valid: true,
            error: ""
        )

fn log_options_help() -> [text]:
    [
        "--log-mode <human|llm|json>  Select log rendering mode",
        "--human | --llm | --json     Shorthand log modes",
        "--progress <summary|count|dot|none>",
        "--dots | --count | --no-progress",
        "--quiet | --verbose"
    ]

fn parse_log_options(args: [text]) -> CheckLogOptions:
    var opts = CheckLogOptions.defaults()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--json":
            opts.log_mode = "json"
        elif arg == "--human":
            opts.log_mode = "human"
        elif arg == "--llm":
            opts.log_mode = "llm"
        elif arg == "--dots":
            opts.progress = "dot"
        elif arg == "--count":
            opts.progress = "count"
        elif arg == "--quiet" or arg == "--no-progress":
            opts.progress = "none"
        elif arg.starts_with("--log-mode="):
            opts.log_mode = arg.slice(11, arg.len())
        elif arg == "--log-mode":
            if i + 1 < args.len():
                opts.log_mode = args[i + 1]
                i = i + 1
            else:
                opts.valid = false
                opts.error = "missing --log-mode value"
        elif arg.starts_with("--progress="):
            opts.progress = arg.slice(11, arg.len())
        elif arg == "--progress":
            if i + 1 < args.len():
                opts.progress = args[i + 1]
                i = i + 1
            else:
                opts.valid = false
                opts.error = "missing --progress value"
        i = i + 1
    opts

fn render_progress(mode: text, done: i64, total: i64, label: text) -> text:
    if mode == "none" or mode == "summary":
        return ""
    if mode == "dot":
        return "."
    if label == "":
        return "{done}/{total}"
    "{label}: {done}/{total}"

fn _print_help():
    print "Usage: simple check <file.spl> [file2.spl ...]"
    print ""
    print "Parse and validate Simple source files."
    print ""
    print "Options:"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help       Show this help"

fn _is_log_option(arg: text) -> bool:
    if arg == "--human":
        return true
    if arg == "--llm":
        return true
    if arg == "--json":
        return true
    if arg == "--tui":
        return true
    if arg == "--stdout":
        return true
    if arg == "--quiet":
        return true
    if arg == "--verbose":
        return true
    if arg == "--dots":
        return true
    if arg == "--count":
        return true
    if arg == "--no-progress":
        return true
    if arg == "--log-mode":
        return true
    if arg == "--surface":
        return true
    if arg == "--progress":
        return true
    if arg.starts_with("--log-mode="):
        return true
    if arg.starts_with("--surface="):
        return true
    arg.starts_with("--progress=")

fn _status_name(total_errors: i64) -> text:
    if total_errors == 0:
        return "ok"
    "error"

fn _collect_spl_files(path: text) -> [text]:
    if file_exists(path):
        if path.ends_with(".spl") or path.ends_with(".spipe"):
            return [path]
        # Path exists but is not a Simple source file: treat as a directory
        # and gather any .spl files it directly contains.
        val files = find_spl_files(path)
        if files.len() > 0:
            return files
        return [path]
    # Not an existing file: try directory discovery.
    find_spl_files(path)

fn _host_gpu_lane_lint_errors(source: text) -> [text]:
    """Source-level guard for target.later(...) gpu \\: semantic ownership."""
    var msgs: [text] = []
    var in_gpu_lane = false
    val lines = source.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.contains(" gpu \\:"):
            in_gpu_lane = true
        elif trimmed.contains(" host \\:"):
            in_gpu_lane = false
        elif trimmed.len() > 0 and not line.starts_with(" ") and not line.starts_with("\t"):
            in_gpu_lane = false
        if in_gpu_lane and trimmed.contains(".checked ="):
            msgs.push("error[HGL-SEMANTIC]: GPU lambda cannot mutate host semantic field `checked`. Use target.later(...) host \\: or return a host proposal.")
    msgs

fn _host_gpu_lane_lint_warnings(source: text) -> [text]:
    """Warn when target.later(...) gpu \\: appears as per-widget loop dispatch."""
    var msgs: [text] = []
    var in_loop = false
    val lines = source.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("for "):
            in_loop = true
        elif trimmed.len() > 0 and not line.starts_with(" ") and not line.starts_with("\t"):
            in_loop = false
        if in_loop and trimmed.contains(" gpu \\:") and trimmed.contains("later"):
            msgs.push("warning[HGL-BATCH]: per-widget GPU later() call inside loop. Use frame-level Draw IR batch, instance buffer, or DisplayGraphIR delta.")
    msgs

fn _import_line_has_symbol(trimmed: text, owner: text, symbol: text) -> bool:
    if not trimmed.starts_with("use {owner}."):
        return false
    var normalized = trimmed.replace(" ", "")
    normalized = normalized.replace("\t", "")
    normalized = normalized.replace("{", ",")
    normalized = normalized.replace("}", ",")
    normalized.contains(",{symbol},")

fn _concurrency_import_error(owner: text, symbol: text, expected: text) -> text:
    "error[E-PAR-003]: {symbol} belongs to {expected}, not {owner}. import {symbol} from {expected}"

fn _concurrency_api_lint_errors(source: text) -> [text]:
    var msgs: [text] = []
    val lines = source.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("extern fn rt_pool_"):
            msgs.push("error[E-PAR-005]: direct rt_pool_* access bypasses the public multicore_green facade")
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "thread_spawn2"):
            msgs.push("error[E-PAR-002]: thread_spawn2 is a numbered name and is not a public API. use thread_spawn_with_args")
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "spawn_isolated2"):
            msgs.push("error[E-PAR-002]: spawn_isolated2 is a numbered name and is not a public API. use spawn_isolated_with_args")
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "spawn_limited2"):
            msgs.push("error[E-PAR-002]: spawn_limited2 is a numbered name and is not a public API. use spawn_limited_with_args")
        if _import_line_has_symbol(trimmed, "std.concurrent.cooperative_green", "thread_spawn_with_args"):
            msgs.push(_concurrency_import_error("std.concurrent.cooperative_green", "thread_spawn_with_args", "std.concurrent.thread"))
        if _import_line_has_symbol(trimmed, "std.concurrent.cooperative_green", "thread_spawn"):
            msgs.push(_concurrency_import_error("std.concurrent.cooperative_green", "thread_spawn", "std.concurrent.thread"))
        if _import_line_has_symbol(trimmed, "std.concurrent.multicore_green", "thread_spawn"):
            msgs.push(_concurrency_import_error("std.concurrent.multicore_green", "thread_spawn", "std.concurrent.thread"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "green_spawn"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "green_spawn", "std.concurrent.green_thread"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "cooperative_green_spawn_value"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "cooperative_green_spawn_value", "std.concurrent.cooperative_green"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "cooperative_green_run_all"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "cooperative_green_run_all", "std.concurrent.cooperative_green"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "cooperative_green_spawn"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "cooperative_green_spawn", "std.concurrent.cooperative_green"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "multicore_green_spawn_sliced"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "multicore_green_spawn_sliced", "std.concurrent.multicore_green"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "multicore_green_spawn"):
            msgs.push(_concurrency_import_error("std.concurrent.thread", "multicore_green_spawn", "std.concurrent.multicore_green"))
        if _import_line_has_symbol(trimmed, "std.concurrent.thread", "task_spawn"):
            msgs.push("error[E-PAR-001]: task_spawn is not part of the OS-thread facade. import task_spawn from std.nogc_async_mut.thread_pool")
        if trimmed.contains("thread_spawn(42)") or trimmed.contains("thread_spawn(\\: 1, \\: 2)"):
            msgs.push("error[E-PAR-004]: thread_spawn expects one zero-argument closure")
        if trimmed.contains("green_spawn(42)") or trimmed.contains("green_spawn(\\: 1, \\: 2)") or trimmed.contains("green_spawn(do:"):
            msgs.push("error[E-PAR-004]: green_spawn expects one share-nothing zero-argument closure")
        if trimmed.contains("cooperative_green_spawn(42)") or trimmed.contains("cooperative_green_spawn(\\: 1, \\: 2)"):
            msgs.push("error[E-PAR-004]: cooperative_green_spawn expects one share-nothing zero-argument closure")
        if trimmed.contains("multicore_green_spawn(42)") or trimmed.contains("multicore_green_spawn(\\: 1, \\: 2)"):
            msgs.push("error[E-PAR-004]: multicore_green_spawn expects one share-nothing zero-argument closure")
        if trimmed.contains("multicore_green_set_parallelism(\""):
            msgs.push("error[E-PAR-004]: multicore_green_set_parallelism expects an integer worker count")
        if trimmed.contains("multicore_green_spawn_sliced(0)") or trimmed.contains("multicore_green_spawn_sliced(\""):
            msgs.push("error[E-PAR-004]: multicore_green_spawn_sliced expects integer state and step function")
        if trimmed.contains("multicore_green_spawn_sliced(0, 42)"):
            msgs.push("error[E-PAR-004]: multicore_green_spawn_sliced expects a step function as the second argument")
    if source.contains("var shared_total") and source.contains("green_spawn(\\:"):
        msgs.push("error[E-PAR-006]: green_spawn closure must not capture shared mutable state")
    if source.contains("var local_count") and source.contains("cooperative_green_spawn(\\:"):
        msgs.push("error[E-PAR-006]: cooperative_green_spawn closure must not capture shared mutable state")
    if source.contains("var shared_sum") and source.contains("multicore_green_spawn(\\:"):
        msgs.push("error[E-PAR-006]: multicore_green_spawn closure must not capture shared mutable state")
    if source.contains("var shared_state") and source.contains("multicore_green_spawn_sliced(0, \\state:"):
        msgs.push("error[E-PAR-006]: multicore_green_spawn_sliced closure must not capture shared mutable state")
    msgs

fn _check_path(path: text, as_json: bool) -> i64:
    if not file_exists(path):
        if not as_json:
            print "ERROR: {path}: file not found"
        return 1

    val source = query_file_read_rich(path) ?? ""
    val sspec_guidance = check_sspec_guidance(source, path)
    if sspec_guidance != "":
        if not as_json:
            print sspec_guidance
        return 1
    ast_reset()
    parse_module(source, path)
    val errors = parser_get_errors()
    val host_gpu_errors = _host_gpu_lane_lint_errors(source)
    val host_gpu_warnings = _host_gpu_lane_lint_warnings(source)
    val concurrency_errors = _concurrency_api_lint_errors(source)

    if errors.len() == 0 and host_gpu_errors.len() == 0 and concurrency_errors.len() == 0 and not parser_has_errors():
        if not as_json:
            for warning in host_gpu_warnings:
                print "{path}: {warning}"
        return 0

    if not as_json:
        for err in errors:
            print "{path}: {err}"
        for host_gpu_err in host_gpu_errors:
            print "{path}: {host_gpu_err}"
        for concurrency_err in concurrency_errors:
            print "{path}: {concurrency_err}"
        for host_gpu_warning in host_gpu_warnings:
            print "{path}: {host_gpu_warning}"
        if errors.len() == 0 and host_gpu_errors.len() == 0 and concurrency_errors.len() == 0:
            print "{path}: check failed"
    val total = errors.len() + host_gpu_errors.len() + concurrency_errors.len()
    if total > 0: total else: 1

fn run_check(args: [text]) -> i64:
    val option_error = check_option_error(args)
    if option_error != "":
        print "ERROR: {option_error}"
        return 2
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        print "ERROR: {log_opts.error}"
        return 1

    var file_args: [text] = []
    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            _print_help()
            return 0
        elif arg == "check":
            ai = ai
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            ai = ai
        elif not arg.starts_with("-"):
            file_args.push(arg)
        ai = ai + 1

    val as_json = log_opts.log_mode == "json"
    if file_args.len() == 0:
        if as_json:
            print "{\"command\":\"check\",\"status\":\"error\",\"checked\":0,\"files\":0,\"errors\":1,\"files_with_errors\":0}"
        else:
            _print_help()
        return 1

    var total_errors: i64 = 0
    var files_checked: i64 = 0
    var files_with_errors: i64 = 0

    for arg in file_args:
        val source_files = _collect_spl_files(arg)
        if source_files.len() == 0:
            if not as_json:
                print "ERROR: file not found: {arg}"
            total_errors = total_errors + 1
            files_with_errors = files_with_errors + 1
            continue

        for source_file in source_files:
            files_checked = files_checked + 1
            if not as_json:
                print "Checking {source_file}... "
            val failed = _check_path(source_file, as_json)
            if failed != 0:
                total_errors = total_errors + failed
                files_with_errors = files_with_errors + 1
            elif not as_json:
                print "OK"

    # Run repo hygiene gate (forbidden file types, naming, secrets)
    if not as_json:
        print "\nRunning repo hygiene gate..."
    val hygiene_exit = run_repo_hygiene_gate()
    if hygiene_exit != 0:
        total_errors = total_errors + 1
        files_with_errors = files_with_errors + 1

    if files_with_errors == 0:
        if log_opts.progress != "summary" and not as_json:
            val progress_line = render_progress(log_opts.progress, file_args.len(), file_args.len(), "check")
            if progress_line != "":
                print progress_line
        if as_json:
            print "{\"command\":\"check\",\"status\":\"ok\",\"checked\":{files_checked},\"files\":{file_args.len()},\"errors\":0,\"files_with_errors\":0}"
            return 0
        print "\n✓ All checks passed ({files_checked} file(s))"
        return 0

    if log_opts.progress != "summary" and not as_json:
        val progress_line = render_progress(log_opts.progress, file_args.len(), file_args.len(), "check")
        if progress_line != "":
            print progress_line
    if as_json:
        val status = _status_name(total_errors)
        print "{\"command\":\"check\",\"status\":\"{status}\",\"checked\":{files_checked},\"files\":{file_args.len()},\"errors\":{total_errors},\"files_with_errors\":{files_with_errors}}"
        return 1
    print "\n✗ {total_errors} error(s) found in {files_with_errors} of {files_checked} file(s)"
    1
