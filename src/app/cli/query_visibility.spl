# Query CLI - LSP visibility JSON adapters
#
# Wraps the existing text-oriented query commands and enriches them with
# lightweight visibility metadata derived from file/module boundaries.

# Split from src/app/cli/query_visibility.spl to keep module cohesion under the 800-line source limit.
export use app.cli._QueryVisibility.query_commands.*
export use app.cli._QueryVisibility.symbol_resolution.*

# Entry point when run directly as a CLI (e.g. the LSP MCP server invokes
# `simple query_visibility.spl <subcmd> ...`). Mirrors lsp_query.spl, which
# dispatches via a top-level call. Top-level statements only execute when this
# file is the run target, not when it is imported as a module.
query_visibility_main()
