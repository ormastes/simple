#![allow(unnamed_duplicate_typed_args)]
# Query CLI - LSP visibility JSON adapters
#
# Wraps the existing text-oriented query commands and enriches them with
# lightweight visibility metadata derived from file/module boundaries.

use app.cli.query_rich_common.{query_file_read_rich, query_file_exists, query_process_run, query_cli_get_args}
use app.cli.query_sanitize.{sanitize_path, sanitize_symbol}

fn query_visibility_main() -> i64:
    val all_args = query_cli_get_args()
    var args: [text] = []
    var start_idx = 0
    if all_args.len() >= 2 and all_args[1].ends_with(".spl"):
        start_idx = 2
    elif all_args.len() >= 1 and all_args[0].ends_with(".spl"):
        start_idx = 1
    var i = 0
    for arg in all_args:
        if i >= start_idx:
            args = args.push(arg)
        i = i + 1
    if args.len() == 0:
        return 0
    val subcmd = args[0]
    if subcmd == "hover" and args.len() >= 4:
        return query_visibility_hover(args[1], args[2].to_int(), args[3].to_int())
    if subcmd == "completions" and args.len() >= 4:
        return query_visibility_completions(args[1], args[2].to_int(), args[3].to_int())
    if subcmd == "symbols" and args.len() >= 2:
        var requester = args[1]
        if args.len() >= 4 and args[2] == "--requester":
            requester = args[3]
        return query_visibility_symbols(args[1], requester)
    if subcmd == "workspace-symbols":
        var query = ""
        var requester = ""
        var j = 1
        while j < args.len():
            if args[j] == "--query" and j + 1 < args.len():
                query = args[j + 1]
            elif args[j] == "--requester" and j + 1 < args.len():
                requester = args[j + 1]
            j = j + 1
        return query_visibility_workspace_symbols(query, requester)
    if subcmd == "semantic-tokens" and args.len() >= 2:
        var start_line = 0
        var end_line = 0
        var j = 2
        while j < args.len():
            if args[j] == "--start-line" and j + 1 < args.len():
                start_line = args[j + 1].to_int()
            elif args[j] == "--end-line" and j + 1 < args.len():
                end_line = args[j + 1].to_int()
            j = j + 1
        return query_visibility_semantic_tokens(args[1], start_line, end_line)
    1

query_visibility_main()

fn query_visibility_hover(file: text, line_num: i64, col: i64) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "null"
        return 1
    val symbol = extract_symbol_at(clean_file, line_num, col)
    if symbol == "":
        print "null"
        return 1
    val resolved = resolve_symbol_file(clean_file, symbol)
    val hover = declaration_line(symbol, resolved)
    val vis = visibility_json(symbol, resolved, clean_file)
    var lines: [text] = []
    if hover != "":
        lines = lines.push(hover)
    lines = lines.push("")
    lines = lines.push("Visibility: **" + visibility_display(symbol, resolved) + "**")
    val boundary = boundary_module(resolved)
    if boundary != "":
        lines = lines.push("Boundary: `" + boundary + "` (" + boundary_kind(resolved) + ")")
    val exported = exported_by(symbol, resolved)
    if exported != "":
        lines = lines.push("Exported by: `" + exported + "`")
    print "{\"contents\":{\"kind\":\"markdown\",\"value\":" + json_text(lines.join("\n")) + "},\"simpleVisibility\":" + vis + "}"
    0

fn query_visibility_completions(file: text, line_num: i64, col: i64) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "[]"
        return 1
    var items: [text] = []
    val prefix = extract_symbol_at(clean_file, line_num, col)
    val local_symbols = parse_symbols_in_file(clean_file)
    for sym in local_symbols:
        if prefix != "" and not sym.name.starts_with(prefix):
            continue
        val vis = visibility_json(sym.name, clean_file, clean_file)
        if not visibility_reachable(sym.name, clean_file, clean_file):
            continue
        val detail = "[" + visibility_display(sym.name, clean_file) + "] " + sym.kind
        items = items.push("{\"label\":" + json_text(sym.name) + ",\"kind\":6,\"detail\":" + json_text(detail) + ",\"data\":{\"simpleVisibility\":" + vis + "}" + "}")
    val imports = parse_imported_modules(clean_file)
    for module_path in imports:
        val imported_file = resolve_module_path(module_path)
        if imported_file == "":
            continue
        val imported_symbols = parse_symbols_in_file(imported_file)
        for sym in imported_symbols:
            if prefix != "" and not sym.name.starts_with(prefix):
                continue
            if not visibility_reachable(sym.name, imported_file, clean_file):
                continue
            val vis = visibility_json(sym.name, imported_file, clean_file)
            val detail = "[" + visibility_display(sym.name, imported_file) + "] " + sym.kind
            items = items.push("{\"label\":" + json_text(sym.name) + ",\"kind\":6,\"detail\":" + json_text(detail) + ",\"data\":{\"simpleVisibility\":" + vis + "}" + "}")
    val keywords = matching_keywords(prefix)
    for kw in keywords:
        items = items.push("{\"label\":" + json_text(kw) + ",\"kind\":14,\"detail\":\"[public]\",\"data\":{\"simpleVisibility\":{\"display\":\"public\",\"reachable\":true,\"boundaryKind\":\"open\"}" + "}" + "}")
    print "[" + items.join(",") + "]"
    0

fn query_visibility_symbols(file: text, requester_file: text) -> i64:
    val clean_file = sanitize_path(file)
    val requester = sanitize_path(requester_file)
    if clean_file == "":
        print "[]"
        return 1
    var items: [text] = []
    val symbols = parse_symbols_in_file(clean_file)
    for parsed in symbols:
        val vis = visibility_json(parsed.name, clean_file, requester)
        val line_idx = if parsed.line_num > 0: parsed.line_num - 1 else: 0
        val range = "{\"start\":{\"line\":" + str(line_idx) + ",\"character\":0},\"end\":{\"line\":" + str(line_idx) + ",\"character\":0}" + "}"
        items = items.push("{\"name\":" + json_text(parsed.name) + ",\"kind\":" + str(symbol_kind_number(parsed.kind)) + ",\"detail\":" + json_text("[" + visibility_display(parsed.name, clean_file) + "]") + ",\"range\":" + range + ",\"selectionRange\":" + range + ",\"simpleVisibility\":" + vis + "}")
    print "[" + items.join(",") + "]"
    0

fn query_visibility_workspace_symbols(query: text, requester_file: text) -> i64:
    val requester = sanitize_path(requester_file)
    val clean_query = sanitize_symbol(query.trim())
    if clean_query == "":
        print "[]"
        return 0
    var items: [text] = []
    val candidates = grep_workspace_symbol_candidates("src", clean_query)
    var visible: [ParsedSymbol] = []
    for candidate in candidates:
        if candidate.name == "" or not candidate.name.to_lower().contains(clean_query.to_lower()):
            continue
        if not visibility_reachable(candidate.name, candidate.file_path, requester):
            continue
        visible = visible.push(candidate)
    val ranked = sort_workspace_symbol_candidates(visible, clean_query, requester)
    for entry in ranked:
        val candidate = entry.symbol
        val vis = visibility_json(candidate.name, candidate.file_path, requester)
        val line_idx = if candidate.line_num > 0: candidate.line_num - 1 else: 0
        val range = "{\"start\":{\"line\":" + str(line_idx) + ",\"character\":0},\"end\":{\"line\":" + str(line_idx) + ",\"character\":0}" + "}"
        items = items.push("{\"name\":" + json_text(candidate.name) + ",\"kind\":" + str(symbol_kind_number(candidate.kind)) + ",\"location\":{\"uri\":" + json_text("file://" + candidate.file_path) + ",\"range\":" + range + "},\"simpleVisibility\":" + vis + "}")
        if items.len() >= 100:
            break
    print "[" + items.join(",") + "]"
    0

fn query_visibility_semantic_tokens(file: text, start_line: i64, end_line: i64) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "{\"data\":[]}"
        return 1
    var public_names: [text] = []
    var boundary_names: [text] = []
    var private_names: [text] = []
    val parsed_symbols = parse_symbols_in_file(clean_file)
    for parsed in parsed_symbols:
        val display = visibility_display(parsed.name, clean_file)
        if display == "public":
            public_names = public_names.push(parsed.name)
        elif display == "private":
            private_names = private_names.push(parsed.name)
        else:
            boundary_names = boundary_names.push(parsed.name)
    val lines = scan_semantic_tokens(clean_file, start_line, end_line)
    var data: [text] = []
    var prev_line = 0
    var prev_col = 0
    for line in lines:
        val parts = line.split(":")
        if parts.len() < 4:
            continue
        val token_line = parts[0].to_int() - 1
        val token_col = parts[1].to_int()
        val token_len = parts[2].to_int()
        val token_type = semantic_token_type_number(parts[3])
        val name = token_name_at(clean_file, token_line, token_col, token_len)
        var modifiers = 0
        if list_has_text(public_names, name):
            modifiers = 512
        elif list_has_text(boundary_names, name):
            modifiers = 1024
        elif list_has_text(private_names, name):
            modifiers = 2048
        val delta_line = token_line - prev_line
        val delta_col = if delta_line == 0: token_col - prev_col else: token_col
        data = data.push(str(delta_line))
        data = data.push(str(delta_col))
        data = data.push(str(token_len))
        data = data.push(str(token_type))
        data = data.push(str(modifiers))
        prev_line = token_line
        prev_col = token_col
    print "{\"data\":[" + data.join(",") + "]}"
    0

struct ParsedSymbol:
    name: text
    kind: text
    line_num: i64
    file_path: text

struct ScoredSymbol:
    symbol: ParsedSymbol
    score: i64

fn parse_symbols_in_file(file_path: text) -> [ParsedSymbol]:
    if not query_file_exists(file_path):
        return []
    val content = query_file_read_rich(file_path) ?? ""
    val lines = content.split("\n")
    var items: [ParsedSymbol] = []
    var line_num = 1
    for line in lines:
        val trimmed = line.trim()
        val kind = declaration_kind(trimmed)
        val name = declaration_name(trimmed)
        if name != "" and kind != "":
            items = items.push(ParsedSymbol(name: name, kind: kind, line_num: line_num, file_path: file_path))
        line_num = line_num + 1
    items

fn visibility_json(symbol: text, owner_file: text, requester_file: text) -> text:
    var parts: [text] = []
    parts = parts.push("\"display\":" + json_text(visibility_display(symbol, owner_file)))
    parts = parts.push("\"reachable\":" + bool_json(visibility_reachable(symbol, owner_file, requester_file)))
    parts = parts.push("\"boundaryKind\":" + json_text(boundary_kind(owner_file)))
    val boundary = boundary_module(owner_file)
    if boundary != "":
        parts = parts.push("\"boundaryModule\":" + json_text(boundary))
    val declared = declared_visibility(symbol, owner_file)
    parts = parts.push("\"declared\":" + json_text(declared))
    val exported = exported_by(symbol, owner_file)
    if exported != "":
        parts = parts.push("\"exportedBy\":" + json_text(exported))
    val friends = friend_packages(owner_file)
    if friends.len() > 0:
        parts = parts.push("\"friendPackages\":[" + json_text_array(friends) + "]")
    val capsule = capsule_name(owner_file)
    if capsule != "":
        parts = parts.push("\"capsuleName\":" + json_text(capsule))
        parts = parts.push("\"capsuleVisibility\":\"internal\"")
    "{" + parts.join(",") + "}"

fn grep_workspace_symbol_candidates(root: text, query: text) -> [ParsedSymbol]:
    val pattern = "^(pub\\(peer\\)|pub\\(up\\)|pub\\(friend\\)|pub\\(package\\)|pub|pri)?[[:space:]]*(fn|me|class|struct|enum|trait|val|var)[[:space:]]+.*" + query
    val (stdout, stderr, code) = query_process_run("grep", ["-RInE", pattern, root, "--include=*.spl"])
    if stdout.trim() == "":
        return []
    var items: [ParsedSymbol] = []
    val lines = stdout.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parsed = parse_grep_symbol_candidate(trimmed)
        if parsed.name != "" and parsed.kind != "":
            items = items.push(parsed)
            if items.len() >= 200:
                break
    items

fn parse_grep_symbol_candidate(line: text) -> ParsedSymbol:
    val chars = text_chars(line)
    var first_colon = -1
    var second_colon = -1
    var idx = 0
    while idx < chars.len():
        if chars[idx] == ":":
            if first_colon < 0:
                first_colon = idx
            elif second_colon < 0:
                second_colon = idx
                break
        idx = idx + 1
    if first_colon < 0 or second_colon < 0:
        return ParsedSymbol(name: "", kind: "", line_num: 0, file_path: "")
    val file_path = join_char_slice(chars, 0, first_colon)
    val line_num_str = join_char_slice(chars, first_colon + 1, second_colon)
    val source_line = join_char_slice(chars, second_colon + 1, chars.len())
    val trimmed = source_line.trim()
    val kind = declaration_kind(trimmed)
    val name = declaration_name(trimmed)
    ParsedSymbol(name: name, kind: kind, line_num: line_num_str.to_int(), file_path: file_path)

fn rank_workspace_symbol_candidate(candidate: ParsedSymbol, query: text, requester: text) -> i64:
    var score = 1000
    val name_lower = candidate.name.to_lower()
    val query_lower = query.to_lower()
    if candidate.name == query:
        score = score - 300
    elif name_lower == query_lower:
        score = score - 280
    elif candidate.name.starts_with(query):
        score = score - 220
    elif name_lower.starts_with(query_lower):
        score = score - 200
    elif name_lower.contains(query_lower):
        score = score - 120
    else:
        score = score - 20
    score = score + visibility_rank_for_display(visibility_display(candidate.name, candidate.file_path))
    score = score + kind_rank(candidate.kind)
    score = score + candidate.line_num
    score

fn sort_workspace_symbol_candidates(items: [ParsedSymbol], query: text, requester: text) -> [ScoredSymbol]:
    if items.len() == 0:
        return []
    var sorted: [ScoredSymbol] = []
    for item in items:
        val item_rank = rank_workspace_symbol_candidate(item, query, requester)
        var inserted = false
        var next: [ScoredSymbol] = []
        for existing in sorted:
            if not inserted and item_rank < existing.score:
                next = next.push(ScoredSymbol(symbol: item, score: item_rank))
                inserted = true
            next = next.push(existing)
        if not inserted:
            next = next.push(ScoredSymbol(symbol: item, score: item_rank))
        sorted = next
    sorted

fn visibility_rank_for_display(display: text) -> i64:
    if display == "public":
        return 0
    if display == "peer":
        return 6
    if display == "up":
        return 8
    if display == "boundary":
        return 10
    20

fn kind_rank(kind: text) -> i64:
    if kind == "fn" or kind == "method":
        return 0
    if kind == "class" or kind == "struct" or kind == "trait" or kind == "enum":
        return 5
    10

fn visibility_display(symbol: text, owner_file: text) -> text:
    val declared = declared_visibility(symbol, owner_file)
    if declared == "peer":
        return "peer"
    if declared == "up":
        return "up"
    val boundary = boundary_kind(owner_file)
    if declared == "private":
        return "private"
    if boundary == "open" or boundary == "bypass":
        if declared == "public":
            return "public"
        return "boundary"
    if declared == "public" and exported_by(symbol, owner_file) != "":
        return "public"
    "boundary"

fn visibility_reachable(symbol: text, owner_file: text, requester_file: text) -> bool:
    if requester_file == "" or requester_file == owner_file:
        return true
    val declared = declared_visibility(symbol, owner_file)
    if declared == "peer":
        return same_peer_path(requester_file, owner_file)
    if declared == "up":
        return is_parent_facade_requester(requester_file, owner_file)
    val display = visibility_display(symbol, owner_file)
    if display == "public":
        return true
    if display == "private":
        return false
    if same_boundary(requester_file, owner_file):
        return true
    val owner_pkg = package_name(owner_file)
    val requester_pkg = package_name(requester_file)
    if declared == "package":
        return owner_pkg == requester_pkg
    if declared == "internal":
        if owner_pkg == requester_pkg:
            return true
        return list_has_text(friend_packages(owner_file), requester_pkg)
    false

fn declared_visibility(symbol: text, owner_file: text) -> text:
    val line = declaration_line(symbol, owner_file).trim()
    if line.starts_with("pub(peer)") or line.contains(" pub(peer) "):
        return "peer"
    if line.starts_with("pub(up)") or line.contains(" pub(up) "):
        return "up"
    if line.starts_with("pub(friend)") or line.contains(" pub(friend) "):
        return "internal"
    if line.starts_with("pub(package)") or line.contains(" pub(package) "):
        return "package"
    if line.starts_with("pri ") or line.contains(" pri "):
        return "private"
    if line.starts_with("pub "):
        return "public"
    "private"

fn declaration_line(symbol: text, owner_file: text) -> text:
    if not query_file_exists(owner_file):
        return ""
    val content = query_file_read_rich(owner_file) ?? ""
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if declaration_name(trimmed) == symbol:
            return trimmed
    ""

fn declaration_kind(line: text) -> text:
    val trimmed = strip_visibility_prefix(line.trim())
    if trimmed.starts_with("fn "):
        return "fn"
    if trimmed.starts_with("me "):
        return "method"
    if trimmed.starts_with("class "):
        return "class"
    if trimmed.starts_with("struct "):
        return "struct"
    if trimmed.starts_with("enum "):
        return "enum"
    if trimmed.starts_with("trait "):
        return "trait"
    if trimmed.starts_with("val ") or trimmed.starts_with("var "):
        return "var"
    ""

fn declaration_name(line: text) -> text:
    var trimmed = strip_visibility_prefix(line.trim())
    if trimmed.starts_with("static "):
        trimmed = trimmed.substring(7).trim()
    if trimmed.starts_with("async "):
        trimmed = trimmed.substring(6).trim()
    if trimmed.starts_with("extern "):
        trimmed = trimmed.substring(7).trim()
    if trimmed.starts_with("const "):
        trimmed = trimmed.substring(6).trim()
    if trimmed.starts_with("kernel "):
        trimmed = trimmed.substring(7).trim()
    val prefixes = ["fn ", "me ", "class ", "struct ", "enum ", "trait ", "val ", "var "]
    for prefix in prefixes:
        if trimmed.starts_with(prefix):
            trimmed = trimmed.substring(prefix.len())
            break
    var chars: [text] = []
    for ch in trimmed:
        if is_ident_char(ch):
            chars = chars.push(ch)
        else:
            break
    chars.join("")

fn strip_visibility_prefix(line: text) -> text:
    var trimmed = line
    if trimmed.starts_with("pub(peer)"):
        return trimmed.substring(9).trim()
    if trimmed.starts_with("pub(up)"):
        return trimmed.substring(7).trim()
    if trimmed.starts_with("pub(friend)"):
        return trimmed.substring(11).trim()
    if trimmed.starts_with("pub(package)"):
        return trimmed.substring(12).trim()
    if trimmed.starts_with("pub "):
        return trimmed.substring(4).trim()
    if trimmed.starts_with("pri "):
        return trimmed.substring(4).trim()
    trimmed

fn boundary_kind(owner_file: text) -> text:
    val dir = nearest_boundary_dir(owner_file)
    if dir == "":
        return "open"
    val manifest = dir + "/__init__.spl"
    if not query_file_exists(manifest):
        return "open"
    val content = query_file_read_rich(manifest) ?? ""
    if content.contains("#[bypass]"):
        return "bypass"
    "boundary"

fn same_peer_path(requester_file: text, owner_file: text) -> bool:
    if requester_file == "" or owner_file == "":
        return false
    if not same_boundary(requester_file, owner_file):
        return false
    val owner_tail = peer_path_tail(owner_file)
    val requester_tail = peer_path_tail(requester_file)
    if owner_tail == "" or requester_tail == "":
        return false
    if owner_tail != requester_tail:
        return false
    val owner_layer = layer_dir_name(owner_file)
    val requester_layer = layer_dir_name(requester_file)
    if owner_layer == "" or requester_layer == "":
        return false
    owner_layer != requester_layer

fn is_parent_facade_requester(requester_file: text, owner_file: text) -> bool:
    if requester_file == "" or owner_file == "":
        return false
    val owner_dir = parent_dir(owner_file)
    if owner_dir == "":
        return false
    requester_file == owner_dir + "/__init__.spl"

fn peer_path_tail(file_path: text) -> text:
    val rel = relative_to_src(file_path)
    if rel == "":
        return ""
    val parts = rel.split("/")
    if parts.len() >= 3 and parts[0] == "compiler":
        return parts[2..].join("/")
    if parts.len() >= 2:
        return parts[1..].join("/")
    rel

fn layer_dir_name(file_path: text) -> text:
    val rel = relative_to_src(file_path)
    if rel == "":
        return ""
    val parts = rel.split("/")
    if parts.len() >= 2 and parts[0] == "compiler":
        return parts[1]
    if parts.len() >= 1:
        return parts[0]
    ""

fn boundary_module(owner_file: text) -> text:
    val dir = nearest_boundary_dir(owner_file)
    if dir == "":
        return ""
    relative_to_src(dir).replace("/", ".")

fn exported_by(symbol: text, owner_file: text) -> text:
    val dir = nearest_boundary_dir(owner_file)
    if dir == "":
        return ""
    val manifest = dir + "/__init__.spl"
    if not query_file_exists(manifest):
        return ""
    val content = query_file_read_rich(manifest) ?? ""
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("export use ") and contains_symbol_token(trimmed, symbol):
            return manifest
    ""

fn friend_packages(owner_file: text) -> [text]:
    val dir = nearest_boundary_dir(owner_file)
    if dir == "":
        return []
    val manifest = dir + "/__init__.spl"
    if not query_file_exists(manifest):
        return []
    val content = query_file_read_rich(manifest) ?? ""
    val lines = content.split("\n")
    var friends: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("friend "):
            friends = friends.push(trimmed.substring(7).trim())
    friends

fn nearest_boundary_dir(file_path: text) -> text:
    var current = parent_dir(file_path)
    while current != "":
        val manifest = current + "/__init__.spl"
        if query_file_exists(manifest):
            return current
        val next = parent_dir(current)
        if next == current:
            break
        current = next
    ""

fn same_boundary(a: text, b: text) -> bool:
    val a_boundary = nearest_boundary_dir(a)
    val b_boundary = nearest_boundary_dir(b)
    if a_boundary != "" and b_boundary != "":
        return a_boundary == b_boundary
    parent_dir(a) == parent_dir(b)

fn package_name(file_path: text) -> text:
    val rel = relative_to_src(file_path)
    if rel == "":
        return ""
    val parts = rel.split("/")
    if parts.len() == 0:
        return ""
    if parts[0] == "compiler" and parts.len() > 1:
        val layer = parts[1]
        val dot = layer.index_of(".") ?? -1
        if dot >= 0 and dot + 1 < layer.len():
            return layer.substring(dot + 1)
        return layer
    parts[0]

fn capsule_name(file_path: text) -> text:
    val idx = file_path.index_of("/85.mdsoc/") ?? -1
    if idx < 0:
        return ""
    val rest = file_path.substring(idx + 10)
    val parts = rest.split("/")
    if parts.len() >= 2:
        return parts[0] + "." + parts[1]
    if parts.len() >= 1:
        return parts[0]
    ""

fn resolve_symbol_file(current_file: text, symbol: text) -> text:
    if declaration_line(symbol, current_file) != "":
        return current_file
    val imports = parse_imported_modules(current_file)
    for module_path in imports:
        val resolved = resolve_module_path(module_path)
        if resolved != "" and declaration_line(symbol, resolved) != "":
            return resolved
    current_file

fn parse_imported_modules(file_path: text) -> [text]:
    if not query_file_exists(file_path):
        return []
    val content = query_file_read_rich(file_path) ?? ""
    val lines = content.split("\n")
    var modules: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("use "):
            val rest = trimmed.substring(4)
            val end_idx = rest.index_of("{") ?? -1
            if end_idx >= 0:
                modules = modules.push(rest.substring(0, end_idx).trim().trim_end("."))
            else:
                val star_idx = rest.index_of("*") ?? -1
                if star_idx >= 0:
                    modules = modules.push(rest.substring(0, star_idx).trim().trim_end("."))
                else:
                    modules = modules.push(rest.trim())
    modules

fn resolve_module_path(mod_path: text) -> text:
    if mod_path.contains("/"):
        val slash_parts = mod_path.split("/")
        if slash_parts.len() >= 2 and slash_parts[0].contains("-"):
            val type_base = "type/" + slash_parts[0].replace("-", "_") + "/" + slash_parts[1..].join("/")
            val type_mod = type_base + "/mod.spl"
            if query_file_exists(type_mod):
                return type_mod
            val type_direct = type_base + ".spl"
            if query_file_exists(type_direct):
                return type_direct

    if not mod_path.contains("."):
        val type_base = "type/simple_lang/" + mod_path
        val type_mod = type_base + "/mod.spl"
        if query_file_exists(type_mod):
            return type_mod
        val type_direct = type_base + ".spl"
        if query_file_exists(type_direct):
            return type_direct

    var path = mod_path
    if path.starts_with("std."):
        path = "lib." + path.substring(4)
    elif path.starts_with("lib.") or path.starts_with("app.") or path.starts_with("compiler."):
        path = path
    else:
        path = "lib." + path
    val file_base = "src/" + path.split(".").join("/")
    val mod_file = file_base + "/mod.spl"
    if query_file_exists(mod_file):
        return mod_file
    val direct_file = file_base + ".spl"
    if query_file_exists(direct_file):
        return direct_file
    ""

fn extract_symbol_at(file: text, line_num: i64, col: i64) -> text:
    val content = query_file_read_rich(file) ?? ""
    if content == "":
        return ""
    val lines = content.split("\n")
    if line_num < 1 or line_num > lines.len():
        return ""
    val target = lines[line_num - 1]
    val declared = declaration_name(target)
    if declared != "":
        return declared
    val chars = text_chars(target)
    if col > 0 and col <= chars.len():
        var idx = col - 1
        if idx >= chars.len():
            idx = chars.len() - 1
        if idx >= 0 and idx < chars.len() and not is_ident_char(chars[idx]) and idx > 0 and is_ident_char(chars[idx - 1]):
            idx = idx - 1
        if idx >= 0 and idx < chars.len() and is_ident_char(chars[idx]):
            var start = idx
            var end_pos = idx
            while start > 0 and is_ident_char(chars[start - 1]):
                start = start - 1
            while end_pos + 1 < chars.len() and is_ident_char(chars[end_pos + 1]):
                end_pos = end_pos + 1
            var parts: [text] = []
            var i = start
            while i <= end_pos:
                parts = parts.push(chars[i])
                i = i + 1
            return parts.join("")
    return ""

fn token_name_at(file: text, line_num: i64, col: i64, length: i64) -> text:
    val content = query_file_read_rich(file) ?? ""
    if content == "":
        return ""
    val lines = content.split("\n")
    if line_num < 0 or line_num >= lines.len():
        return ""
    val chars = text_chars(lines[line_num])
    if col < 0 or col + length > chars.len():
        return ""
    var parts: [text] = []
    var i = col
    while i < col + length:
        parts = parts.push(chars[i])
        i = i + 1
    return parts.join("")

fn semantic_token_type_number(name: text) -> i64:
    if name == "namespace":
        return 0
    elif name == "type":
        return 1
    elif name == "class":
        return 2
    elif name == "enum":
        return 3
    elif name == "struct":
        return 4
    elif name == "function":
        return 5
    elif name == "method":
        return 6
    elif name == "property":
        return 7
    elif name == "variable":
        return 8
    elif name == "parameter":
        return 9
    elif name == "enumMember":
        return 10
    elif name == "keyword":
        return 11
    elif name == "comment":
        return 12
    elif name == "string":
        return 13
    elif name == "number":
        return 14
    elif name == "operator":
        return 15
    8

fn symbol_kind_number(kind: text) -> i64:
    if kind == "fn" or kind == "function" or kind == "extern_fn":
        return 12
    elif kind == "method" or kind == "static_method":
        return 6
    elif kind == "class":
        return 5
    elif kind == "struct":
        return 23
    elif kind == "enum":
        return 10
    elif kind == "trait":
        return 11
    elif kind == "module":
        return 2
    13

fn parent_dir(path: text) -> text:
    val idx = path.last_index_of("/") ?? -1
    if idx <= 0:
        return ""
    path.substring(0, idx)

fn relative_to_src(path: text) -> text:
    val idx = path.index_of("/src/") ?? -1
    if idx >= 0:
        return path.substring(idx + 5)
    if path.starts_with("src/"):
        return path.substring(4)
    path

fn contains_symbol_token(line: text, symbol: text) -> bool:
    val chars = text_chars(line)
    val symbol_chars = text_chars(symbol)
    if symbol_chars.len() == 0 or chars.len() < symbol_chars.len():
        return false
    var pos = 0
    while pos <= chars.len() - symbol_chars.len():
        var matches = true
        var j = 0
        while j < symbol_chars.len():
            if chars[pos + j] != symbol_chars[j]:
                matches = false
                break
            j = j + 1
        if matches:
            val left_ok = if pos == 0: true else: not is_ident_char(chars[pos - 1])
            val right_ok = if pos + symbol_chars.len() >= chars.len(): true else: not is_ident_char(chars[pos + symbol_chars.len()])
            if left_ok and right_ok:
                return true
        pos = pos + 1
    false

fn is_ident_char(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"

fn list_has_text(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn bool_json(value: bool) -> text:
    if value:
        return "true"
    "false"

fn json_text_array(items: [text]) -> text:
    var encoded: [text] = []
    for item in items:
        encoded = encoded.push(json_text(item))
    encoded.join(",")

fn json_text(value: text) -> text:
    "\"" + escape_json(value) + "\""

fn escape_json(value: text) -> text:
    var out = value.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    out

fn find_spl_files(root: text) -> [text]:
    val (stdout, stderr, code) = query_process_run("/bin/sh", ["-c", "find " + root + " -type f -name '*.spl' | sort"])
    if code != 0 or stdout.trim() == "":
        return []
    var result: [text] = []
    val lines = stdout.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        result = result.push(trimmed)
    result

fn matching_keywords(prefix: text) -> [text]:
    val all = ["fn", "val", "var", "class", "struct", "enum", "trait", "impl", "if", "elif", "else", "for", "while", "match", "case", "return", "break", "continue", "use", "import", "export", "extern", "static", "me", "in", "not", "and", "or", "true", "false", "nil", "self"]
    var items: [text] = []
    for kw in all:
        if prefix == "" or kw.starts_with(prefix):
            items = items.push(kw)
    items

fn scan_semantic_tokens(file_path: text, start_line: i64, end_line: i64) -> [text]:
    if not query_file_exists(file_path):
        return []
    val content = query_file_read_rich(file_path) ?? ""
    val lines = content.split("\n")
    var fn_names: [text] = []
    var type_names: [text] = []
    var param_names: [text] = []
    val parsed = parse_symbols_in_file(file_path)
    for sym in parsed:
        if sym.kind == "fn" or sym.kind == "method":
            fn_names = fn_names.push(sym.name)
        elif sym.kind == "class" or sym.kind == "struct" or sym.kind == "enum" or sym.kind == "trait":
            type_names = type_names.push(sym.name)
    var results: [text] = []
    var line_idx = 1
    var last_line = end_line
    if last_line <= 0 or last_line > lines.len():
        last_line = lines.len()
    for line in lines:
        if line_idx < start_line and start_line > 0:
            line_idx = line_idx + 1
            continue
        if line_idx > last_line:
            break
        val chars = text_chars(line)
        var ci = 0
        while ci < chars.len():
            val ch = chars[ci]
            if ch == " " or ch == "\t":
                ci = ci + 1
                continue
            if ch == "#":
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(chars.len() - ci) + ":comment")
                break
            if ch == "\"":
                var si = ci + 1
                while si < chars.len():
                    val current = chars[si]
                    if current == "\"":
                        si = si + 1
                        break
                    si = si + 1
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(si - ci) + ":string")
                ci = si
                continue
            if ch >= "0" and ch <= "9":
                var ni = ci + 1
                while ni < chars.len():
                    val current = chars[ni]
                    if not ((current >= "0" and current <= "9") or current == "."):
                        break
                    ni = ni + 1
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(ni - ci) + ":number")
                ci = ni
                continue
            if is_ident_char(ch):
                var wi = ci + 1
                while wi < chars.len():
                    val current = chars[wi]
                    if not is_ident_char(current):
                        break
                    wi = wi + 1
                var word_parts: [text] = []
                var wj = ci
                while wj < wi:
                    word_parts = word_parts.push(chars[wj])
                    wj = wj + 1
                val word = word_parts.join("")
                var token_type = "variable"
                if list_has_text(matching_keywords(word), word):
                    token_type = "keyword"
                elif list_has_text(fn_names, word):
                    token_type = "function"
                elif list_has_text(type_names, word):
                    token_type = "type"
                elif list_has_text(param_names, word):
                    token_type = "parameter"
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(wi - ci) + ":" + token_type)
                ci = wi
                continue
            if ci + 1 < chars.len():
                val op = chars[ci] + chars[ci + 1]
                if op == "->" or op == ":=" or op == "==" or op == "!=" or op == ">=" or op == "<=":
                    results = results.push(str(line_idx) + ":" + str(ci) + ":2:operator")
                    ci = ci + 2
                    continue
            ci = ci + 1
        line_idx = line_idx + 1
    results

fn text_chars(value: text) -> [text]:
    var chars: [text] = []
    val parts = value.split("")
    for part in parts:
        if part != "":
            chars = chars.push(part)
    chars

fn join_char_slice(chars: [text], start_idx: i64, end_idx: i64) -> text:
    var out: [text] = []
    var i = start_idx
    while i < end_idx and i < chars.len():
        out = out.push(chars[i])
        i = i + 1
    out.join("")
