# Simple Language - Query CLI Rich Subcommands
#
# Complex/rich query command implementations.
# Handles rename, code-actions, workspace-symbols, call-hierarchy,
# type-hierarchy, semantic-tokens, inlay-hints, selection-range,
# document-formatting, ast-query, sem-query, query-schema,
# workspace-diagnostics.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

use app.cli.query_sanitize.{sanitize_path, sanitize_symbol, safe_grep, safe_grep_file, safe_process}
use app.cli.query_engine.{engine_signature_help}
use app.cli.query_ast_query.{engine_ast_query}
use app.cli.query_sem_query.{engine_sem_query}
use app.cli.query_schema.{engine_query_schema}
use app.cli.query_helpers.{_has_flag, _replace_word, _collect_symbol_sets, _classify_token, _collect_fn_return_types, _infer_type_from_rhs, _count_indent, _extract_flag, _extract_call_name}
use compiler.driver.driver_api_core.{check_file}
use compiler.driver.driver_types.{CompileResult}
use compiler.tools.fix.main.{collect_fixes_from_source}
use compiler.tools.formatter.main.{make_formatter}
use std.report.emitter.lsp.{LspEmitter, LspDiagnostic, LspCodeAction, LspTextEdit}

# AST-based lint pass imports
use compiler.core.ast.{ast_reset, module_get_decls}
use compiler.core.parser.{parse_module}
use compiler.semantics.lint.argument_count.{check_argument_count}
use compiler.semantics.lint.collection_patterns.{check_collection_patterns}
use compiler.semantics.lint.duplicate_typed_args.{check_duplicate_typed_args}
use compiler.semantics.lint.stub_impl.{check_stub_impl}
use compiler.semantics.lint.star_import.{check_star_import_file}
use compiler.semantics.lint.wide_public.{check_wide_public_file}

# Module-level diagnostic accumulator for JSON collection mode
var _DIAG_COLLECT_MODE = false
var _DIAG_COLLECTED: [text] = []

fn _diag_emit_or_collect(json_str: text):
    """Either print or collect a JSON diagnostic string depending on mode."""
    if _DIAG_COLLECT_MODE:
        _DIAG_COLLECTED.push(json_str)
    else:
        print json_str

fn query_file_read_rich(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn query_signature_help(symbol: text, file: text, line_num: i64, col: i64) -> i64:
    val clean_sym = sanitize_symbol(symbol)
    if clean_sym == "":
        print "Error: invalid symbol name"
        return 1
    engine_signature_help(file, line_num, col, clean_sym)

fn query_rename(symbol: text, file: text, line_num: i64, cmd_args: [text]) -> i64:
    val new_name = _extract_flag(cmd_args, "--new-name", "")
    if new_name == "":
        print "Error: --new-name <name> is required for rename"
        return 1

    val clean_sym = sanitize_symbol(symbol)
    val clean_new = sanitize_symbol(new_name)
    if clean_sym == "" or clean_new == "":
        print "Error: invalid symbol names"
        return 1

    val apply = _has_flag(cmd_args, "--apply")

    # Find all occurrences with safe_grep
    val (out, _) = safe_grep("\\b" + clean_sym + "\\b", "src/", "*.spl")
    if out.trim() == "":
        print "No occurrences found for: {clean_sym}"
        return 1

    val result_lines = out.split("\n")
    var count = 0
    var edits: [text] = []
    for line in result_lines:
        val trimmed = line.trim()
        if trimmed != "":
            # Parse file:line:content
            var colon1 = -1
            var colon2 = -1
            var ci = 0
            while ci < trimmed.len():
                if trimmed.substring(ci, ci + 1) == ":":
                    if colon1 == -1:
                        colon1 = ci
                    elif colon2 == -1:
                        colon2 = ci
                        break
                ci = ci + 1
            if colon1 > 0 and colon2 > colon1:
                val edit_file = trimmed.substring(0, colon1)
                val edit_line = trimmed.substring(colon1 + 1, colon2)
                val edit_content = trimmed.substring(colon2 + 1)
                print "{edit_file}:{edit_line}: {clean_sym} -> {clean_new}"
                edits.push(edit_file)
            else:
                print trimmed
            count = count + 1

    print ""
    print "Total occurrences: {count}"

    if apply:
        # Apply edits using safe sed-like replacement via rt_process_run
        var edited_files: [text] = []
        for edit_file in edits:
            var already_done = false
            for done in edited_files:
                if done == edit_file:
                    already_done = true
                    break
            if not already_done:
                val content = rt_file_read_text(edit_file) ?? ""
                if content != "":
                    val updated = _replace_word(content, clean_sym, clean_new)
                    rt_file_write_text(edit_file, updated)
                    edited_files.push(edit_file)
                    print "Applied: {edit_file}"
        print ""
        print "Rename applied to {edited_files.len()} files"
    else:
        print "Rename: {clean_sym} -> {clean_new} (dry-run, use --apply to write)"
    0

fn query_code_actions(file: text, line_num: i64, cmd_args: [text]) -> i64:
    val format = _extract_flag(cmd_args, "--format", "text")
    val line_str = "{line_num}"
    val emitter = LspEmitter.default_emitter()

    var actions: [text] = []

    # Run type-check pass to collect diagnostics
    var has_diagnostics = false
    val check_result = check_file(file)
    match check_result:
        case CompileResult.Success(_):
            val _ = 0
        case _:
            has_diagnostics = true
            if format == "json":
                val errors = check_result.get_errors()
                for err in errors:
                    val parsed = _parse_error_location(err)
                    val err_line = parsed.0
                    val err_col = parsed.1
                    val err_msg = parsed.2
                    # Only include errors on the requested line
                    if err_line == line_num:
                        var parts: [text] = []
                        parts.push("{\"title\":{emitter.encode_string(\"Fix: \" + err_msg)}")
                        parts.push(",\"kind\":\"quickfix\"")
                        parts.push(",\"isPreferred\":false")
                        parts.push(",\"diagnostics\":[{\"message\":{emitter.encode_string(err_msg)},\"line\":{err_line},\"col\":{err_col}}]")
                        parts.push("}")
                        actions.push(parts.join(""))

    # Run fix tool to collect suggested fixes with text edits
    var has_fixes = false
    if rt_file_exists(file):
        val source = rt_file_read_text(file) ?? ""
        if source != "":
            val fixes = collect_fixes_from_source(file, source)
            if fixes.len() > 0:
                for fix in fixes:
                    has_fixes = true
                    if format == "json":
                        var parts: [text] = []
                        parts.push("{\"title\":{emitter.encode_string(fix.description)}")
                        # Determine action kind based on fix ID
                        val action_kind = if fix.id.starts_with("L:"): "quickfix" else: "refactor"
                        parts.push(",\"kind\":{emitter.encode_string(action_kind)}")
                        val is_safe = fix.is_safe()
                        if is_safe:
                            parts.push(",\"isPreferred\":true")
                        else:
                            parts.push(",\"isPreferred\":false")
                        # Include text edits from replacements
                        if fix.replacements.len() > 0:
                            var edit_parts: [text] = []
                            for rep in fix.replacements:
                                var ep: [text] = []
                                ep.push("{\"range\":{")
                                ep.push("\"start\":{\"line\":{rep.line},\"character\":{rep.column}},")
                                ep.push("\"end\":{\"line\":{rep.line},\"character\":{rep.column + (rep.end - rep.start)}}")
                                ep.push("},\"newText\":{emitter.encode_string(rep.new_text)}}")
                                edit_parts.push(ep.join(""))
                            parts.push(",\"edit\":{\"changes\":{")
                            parts.push("{emitter.encode_string(file)}:[")
                            parts.push(edit_parts.join(","))
                            parts.push("]}}")
                        parts.push("}")
                        actions.push(parts.join(""))

            # Also run source-level lint to surface EasyFix actions
            val source_lines = source.split("\n")
            var sli = 0
            while sli < source_lines.len():
                val sline = source_lines[sli]
                val strimmed = sline.trim()
                val sline_num = sli + 1

                # Only check the requested line
                if sline_num == line_num:
                    # DEPR002: .new() -> suggest StructName(field: value)
                    if strimmed.contains(".new("):
                        if format == "json":
                            actions.push("{\"title\":\"Replace .new() with constructor syntax\",\"kind\":\"quickfix\",\"isPreferred\":true}")
                        else:
                            has_fixes = true

                    # DEPR003: bare pass -> suggest pass_do_nothing
                    if (strimmed == "pass" or strimmed.starts_with("pass ") or strimmed.starts_with("pass#")):
                        if not strimmed.starts_with("pass_"):
                            if format == "json":
                                val indent_len = sline.len() - strimmed.len()
                                var ep: [text] = []
                                ep.push("{\"title\":\"Replace 'pass' with 'pass_do_nothing'\",\"kind\":\"quickfix\",\"isPreferred\":true")
                                ep.push(",\"edit\":{\"changes\":{")
                                ep.push("{emitter.encode_string(file)}:[")
                                ep.push("{\"range\":{\"start\":{\"line\":{sli},\"character\":{indent_len}},\"end\":{\"line\":{sli},\"character\":{indent_len + 4}}},\"newText\":\"pass_do_nothing\"}")
                                ep.push("]}}}")
                                actions.push(ep.join(""))
                            else:
                                has_fixes = true

                sli = sli + 1

    if format == "json":
        print "[{actions.join(\",\")}]"
    else:
        if has_diagnostics:
            print "--- Diagnostics ---"
            print "{file}:{line_str}: type check reported issues"
            val errors = check_result.get_errors()
            for err in errors:
                print "  {err}"

        if has_fixes:
            print ""
            print "--- Suggested Fixes ---"
            if rt_file_exists(file):
                val source2 = rt_file_read_text(file) ?? ""
                if source2 != "":
                    val fixes2 = collect_fixes_from_source(file, source2)
                    for fix in fixes2:
                        print "[{fix.id}] {fix.description}"

        if not has_diagnostics and not has_fixes:
            print "No code actions available at {file}:{line_num}"
    0

fn query_workspace_symbols(cmd_args: [text]) -> i64:
    val query = _extract_flag(cmd_args, "--query", "")
    val kind = _extract_flag(cmd_args, "--kind", "")

    if query == "" and kind == "":
        print "Error: --query <pattern> or --kind <kind> required"
        print "Kinds: fn, class, struct, enum, trait"
        return 1

    val clean_query = sanitize_symbol(query)

    var grep_pattern = ""
    if kind != "":
        val clean_kind = sanitize_symbol(kind)
        if clean_kind == "":
            print "Error: invalid kind"
            return 1
        if clean_query != "":
            grep_pattern = "^" + clean_kind + " " + clean_query
        else:
            grep_pattern = "^" + clean_kind + " "
    else:
        grep_pattern = "^fn " + clean_query + "\\|^class " + clean_query + "\\|^struct " + clean_query + "\\|^enum " + clean_query + "\\|^trait " + clean_query

    val (out, _) = safe_grep(grep_pattern, "src/", "*.spl")
    if out.trim() == "":
        print "No workspace symbols found"
        return 0

    # Limit output to 50 lines
    val result_lines = out.split("\n")
    var count = 0
    for rline in result_lines:
        if rline.trim() != "" and count < 50:
            print rline
            count = count + 1
    0

fn query_call_hierarchy(symbol: text, file: text, cmd_args: [text]) -> i64:
    val direction = _extract_flag(cmd_args, "--direction", "incoming")
    val clean_sym = sanitize_symbol(symbol)
    if clean_sym == "":
        print "Error: invalid symbol name"
        return 1

    if direction == "incoming":
        val (out, _) = safe_grep("\\b" + clean_sym + "(", "src/", "*.spl")
        if out.trim() == "":
            print "No incoming calls found for: {clean_sym}"
            return 0
        print "--- Incoming calls to {clean_sym} ---"
        val result_lines = out.split("\n")
        var count = 0
        for rline in result_lines:
            if rline.trim() != "" and count < 50:
                print rline
                count = count + 1
    elif direction == "outgoing":
        val content = query_file_read_rich(file)
        if content == "":
            print "Could not read file: {file}"
            return 1

        val lines = content.split("\n")
        var fn_start = -1
        var li = 0
        while li < lines.len():
            val line = lines[li]
            val tl = line.trim()
            if (tl.starts_with("fn " + clean_sym + "(") or
                tl.starts_with("fn " + clean_sym + " (")):
                fn_start = li
                break
            li = li + 1

        if fn_start == -1:
            print "Could not find function body for: {clean_sym}"
            return 1

        # Extract function calls from body lines
        var seen_calls: [text] = []
        var bi = fn_start + 1
        while bi < lines.len():
            val bline = lines[bi]
            if bline.len() == 0:
                bi = bi + 1
                continue
            val first_ch = bline.substring(0, 1)
            if first_ch != " " and first_ch != "\t":
                break
            # Scan for identifier( patterns
            var ci = 0
            while ci < bline.len():
                val ch = bline.substring(ci, ci + 1)
                val is_alpha = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
                if is_alpha:
                    var end_ci = ci + 1
                    while end_ci < bline.len():
                        val wc = bline.substring(end_ci, end_ci + 1)
                        val ww = (wc >= "a" and wc <= "z") or (wc >= "A" and wc <= "Z") or (wc >= "0" and wc <= "9") or wc == "_"
                        if not ww:
                            break
                        end_ci = end_ci + 1
                    if end_ci < bline.len() and bline.substring(end_ci, end_ci + 1) == "(":
                        val call_name = bline.substring(ci, end_ci)
                        var already = false
                        for s in seen_calls:
                            if s == call_name:
                                already = true
                                break
                        if not already:
                            seen_calls.push(call_name)
                    ci = end_ci
                else:
                    ci = ci + 1
            bi = bi + 1

        if seen_calls.len() == 0:
            print "No outgoing calls found from: {clean_sym}"
            return 0
        print "--- Outgoing calls from {clean_sym} ---"
        for call_name in seen_calls:
            print call_name
    else:
        print "Error: --direction must be 'incoming' or 'outgoing'"
        return 1
    0

fn query_type_hierarchy(symbol: text, file: text, cmd_args: [text]) -> i64:
    val direction = _extract_flag(cmd_args, "--direction", "supertypes")
    val clean_sym = sanitize_symbol(symbol)
    if clean_sym == "":
        print "Error: invalid symbol name"
        return 1

    if direction == "supertypes":
        val (out, _) = safe_grep("impl.*" + clean_sym, "src/", "*.spl")
        if out.trim() == "":
            print "No supertypes found for: {clean_sym}"
            return 0
        print "--- Supertypes (trait impls) for {clean_sym} ---"
        val result_lines = out.split("\n")
        var count = 0
        for rline in result_lines:
            if rline.trim() != "" and count < 30:
                print rline
                count = count + 1
    elif direction == "subtypes":
        val (trait_out, _) = safe_grep("^trait " + clean_sym, "src/", "*.spl")
        if trait_out.trim() == "":
            print "No trait definition found for: {clean_sym}"
            return 0
        val (impls_out, _2) = safe_grep("impl " + clean_sym + " ", "src/", "*.spl")
        if impls_out.trim() == "":
            print "No subtypes (implementors) found for trait: {clean_sym}"
            return 0
        print "--- Subtypes (implementors) of trait {clean_sym} ---"
        val impl_lines = impls_out.split("\n")
        var count = 0
        for rline in impl_lines:
            if rline.trim() != "" and count < 30:
                print rline
                count = count + 1
    else:
        print "Error: --direction must be 'supertypes' or 'subtypes'"
        return 1
    0

fn query_semantic_tokens(file: text, cmd_args: [text]) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "Error: invalid file path"
        return 1
    val start_line_str = _extract_flag(cmd_args, "--start-line", "1")
    val end_line_str = _extract_flag(cmd_args, "--end-line", "0")
    val start_line = start_line_str.to_int()
    var end_line = end_line_str.to_int()

    val content = query_file_read_rich(clean_file)
    if content == "":
        print "Could not read file: {clean_file}"
        return 1

    val lines = content.split("\n")
    if end_line <= 0 or end_line > lines.len():
        end_line = lines.len()

    # Build symbol sets from outline for classification
    var fn_names: [text] = []
    var type_names: [text] = []
    var param_names: [text] = []
    _collect_symbol_sets(content, fn_names, type_names, param_names)

    val keywords = "fn,class,struct,enum,trait,if,elif,else,for,while,match,case,return,val,var,use,import,export,extern,static,me,break,continue,in,not,and,or,true,false,nil,self,impl,type,alias"
    val kw_list = keywords.split(",")

    val operators = "->,:=,==,!=,>=,<=,|>,>>,~>,**,+=,-=,*=,/=,%=,??,?.,.?"
    val op_list = operators.split(",")

    var token_count = 0
    var li = start_line
    while li <= end_line and li <= lines.len():
        val line = lines[li - 1]
        var ci = 0
        while ci < line.len() and token_count < 500:
            val ch = line.substring(ci, ci + 1)

            if ch == " " or ch == "\t":
                ci = ci + 1
                continue

            # Comment
            if ch == "#":
                val comment_len = line.len() - ci
                print "{li}:{ci}:{comment_len}:comment"
                token_count = token_count + 1
                break

            # String literal
            if ch == "\"":
                var si = ci + 1
                while si < line.len():
                    val sc = line.substring(si, si + 1)
                    if sc == "\\":
                        si = si + 2
                        continue
                    if sc == "\"":
                        si = si + 1
                        break
                    si = si + 1
                val str_len = si - ci
                print "{li}:{ci}:{str_len}:string"
                token_count = token_count + 1
                ci = si
                continue

            # Number
            val is_digit = ch >= "0" and ch <= "9"
            if is_digit:
                var ni = ci + 1
                while ni < line.len():
                    val nc = line.substring(ni, ni + 1)
                    val nd = nc >= "0" and nc <= "9"
                    if (not nd and nc != "." and nc != "_" and
                        nc != "x" and nc != "b" and nc != "o" and
                        nc != "a" and nc != "c" and nc != "d" and
                        nc != "e" and nc != "f" and nc != "A" and
                        nc != "B" and nc != "C" and nc != "D" and
                        nc != "E" and nc != "F"):
                        break
                    ni = ni + 1
                val num_len = ni - ci
                print "{li}:{ci}:{num_len}:number"
                token_count = token_count + 1
                ci = ni
                continue

            # Identifier or keyword
            val is_alpha = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
            if is_alpha:
                var wi = ci + 1
                while wi < line.len():
                    val wc = line.substring(wi, wi + 1)
                    val ww = (wc >= "a" and wc <= "z") or (wc >= "A" and wc <= "Z") or (wc >= "0" and wc <= "9") or wc == "_"
                    if not ww:
                        break
                    wi = wi + 1
                val word = line.substring(ci, wi)
                val word_len = wi - ci

                val token_type = _classify_token(word, ci, line, kw_list, fn_names, type_names, param_names)
                print "{li}:{ci}:{word_len}:{token_type}"
                token_count = token_count + 1
                ci = wi
                continue

            # Operator (multi-char)
            if ci + 1 < line.len():
                val two = line.substring(ci, ci + 2)
                var is_op = false
                for op in op_list:
                    if two == op:
                        is_op = true
                        break
                if is_op:
                    print "{li}:{ci}:2:operator"
                    token_count = token_count + 1
                    ci = ci + 2
                    continue

            ci = ci + 1

        li = li + 1

    if token_count >= 500:
        print "# (truncated at 500 tokens)"
    0

fn query_inlay_hints(file: text, cmd_args: [text]) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "Error: invalid file path"
        return 1
    val start_line_str = _extract_flag(cmd_args, "--start-line", "1")
    val end_line_str = _extract_flag(cmd_args, "--end-line", "0")
    val start_line = start_line_str.to_int()
    var end_line = end_line_str.to_int()
    val format = _extract_flag(cmd_args, "--format", "text")

    val content = query_file_read_rich(clean_file)
    if content == "":
        print "Could not read file: {clean_file}"
        return 1

    val lines = content.split("\n")
    if end_line <= 0 or end_line > lines.len():
        end_line = lines.len()

    # Build function return type map from outline for better inference
    var fn_names: [text] = []
    var fn_returns: [text] = []
    _collect_fn_return_types(content, fn_names, fn_returns)

    # Build function parameter name map for parameter hints
    var fn_param_map_names: [text] = []
    var fn_param_map_params: [text] = []
    _collect_fn_param_names(content, fn_param_map_names, fn_param_map_params)

    var hint_count = 0
    var li = start_line
    while li <= end_line and li <= lines.len():
        val line = lines[li - 1]
        val trimmed = line.trim()

        # --- Type hints for val/var bindings ---
        var binding_prefix = ""
        var name_start = 0
        if trimmed.starts_with("val "):
            binding_prefix = "val"
            name_start = 4
        elif trimmed.starts_with("var "):
            binding_prefix = "var"
            name_start = 4

        if binding_prefix != "":
            val after_kw = trimmed.substring(name_start)
            var name_chars: [text] = []
            var ni = 0
            for nc in after_kw:
                val nw = (nc >= "a" and nc <= "z") or (nc >= "A" and nc <= "Z") or (nc >= "0" and nc <= "9") or nc == "_"
                if not nw:
                    break
                name_chars.push(nc)
                ni = ni + 1
            val var_name = name_chars.join("")

            if var_name != "":
                val after_name = after_kw.substring(ni).trim()
                var has_annotation = false
                if after_name.starts_with(":"):
                    if after_name.len() > 1:
                        val next = after_name.substring(1, 2)
                        if next != "=":
                            has_annotation = true

                if not has_annotation and after_name.contains("="):
                    var eq_pos = 0
                    var found_eq = false
                    var eqi = 0
                    for ec in after_name:
                        if ec == "=" and not found_eq:
                            eq_pos = eqi
                            found_eq = true
                            break
                        eqi = eqi + 1
                    if found_eq:
                        val rhs = after_name.substring(eq_pos + 1).trim()
                        val inferred = _infer_type_from_rhs(rhs, fn_names, fn_returns)
                        if inferred != "":
                            val indent_len = line.len() - trimmed.len()
                            val col_pos = indent_len + name_start + var_name.len()
                            if format == "json":
                                print "{\"line\":{li},\"col\":{col_pos},\"label\":\": {inferred}\",\"kind\":\"type\"}"
                            else:
                                print "{li}:{col_pos}: {var_name}: {inferred} [type]"
                            hint_count = hint_count + 1

        # --- Parameter name hints at call sites ---
        hint_count = hint_count + _emit_param_hints_for_line(line, li, fn_param_map_names, fn_param_map_params, format)

        li = li + 1

    if hint_count == 0:
        print "No inlay hints in range"
    0

fn _collect_fn_param_names(content: text, fn_names: [text], fn_params: [text]):
    """Collect function names and their parameter lists from source outline.
    fn_params stores comma-separated parameter names (without types) for each function.
    """
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        var rest = ""
        if trimmed.starts_with("fn "):
            rest = trimmed.substring(3)
        elif trimmed.starts_with("static fn "):
            rest = trimmed.substring(10)
        elif trimmed.starts_with("me "):
            rest = trimmed.substring(3)
        elif trimmed.starts_with("extern fn "):
            rest = trimmed.substring(10)
        if rest != "":
            val name = _extract_ident_from_str(rest)
            if name != "":
                val params_str = _extract_param_names_from(rest)
                fn_names.push(name)
                fn_params.push(params_str)

fn _extract_ident_from_str(s: text) -> text:
    """Extract leading identifier from a string."""
    var end_pos = 0
    while end_pos < s.len():
        val ch = s.substring(end_pos, end_pos + 1)
        val ok = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
        if not ok:
            break
        end_pos = end_pos + 1
    if end_pos == 0:
        return ""
    s.substring(0, end_pos)

fn _extract_param_names_from(s: text) -> text:
    """Extract parameter names (without types) from a function signature string.
    Returns comma-separated names like 'x,y,z'.
    """
    # Find opening paren
    var paren_start = -1
    var pi = 0
    while pi < s.len():
        if s.substring(pi, pi + 1) == "(":
            paren_start = pi
            break
        pi = pi + 1
    if paren_start < 0:
        return ""
    # Find matching close paren
    var depth = 0
    var paren_end = -1
    var qi = paren_start
    while qi < s.len():
        val ch = s.substring(qi, qi + 1)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                paren_end = qi
                break
        qi = qi + 1
    if paren_end < 0:
        return ""
    val inner = s.substring(paren_start + 1, paren_end)
    if inner.trim() == "":
        return ""
    # Split by commas and extract each param name
    val params = inner.split(",")
    var names: [text] = []
    for param in params:
        val pt = param.trim()
        if pt == "":
            continue
        val pname = _extract_ident_from_str(pt)
        if pname != "" and pname != "self":
            names.push(pname)
    names.join(",")

fn _emit_param_hints_for_line(line: text, line_num: i64, fn_names: [text], fn_params: [text], format: text) -> i64:
    """Scan a line for function calls and emit parameter name hints.
    Returns the number of hints emitted.
    """
    var count = 0
    var ci = 0
    while ci < line.len():
        val ch = line.substring(ci, ci + 1)
        val is_alpha = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
        if is_alpha:
            var end_ci = ci + 1
            while end_ci < line.len():
                val wc = line.substring(end_ci, end_ci + 1)
                val ww = (wc >= "a" and wc <= "z") or (wc >= "A" and wc <= "Z") or (wc >= "0" and wc <= "9") or wc == "_"
                if not ww:
                    break
                end_ci = end_ci + 1
            val call_name = line.substring(ci, end_ci)
            # Check if followed by (
            if end_ci < line.len() and line.substring(end_ci, end_ci + 1) == "(":
                # Look up parameter names for this function
                val param_str = _lookup_params(call_name, fn_names, fn_params)
                if param_str != "":
                    val param_list = param_str.split(",")
                    # Find the arguments in the call
                    val args_info = _extract_call_arg_positions(line, end_ci)
                    var ai = 0
                    while ai < args_info.len() and ai < param_list.len():
                        val arg_col = args_info[ai]
                        val pname = param_list[ai]
                        # Only emit if the argument doesn't already have a named label
                        val arg_text = _get_arg_text_at(line, arg_col)
                        if not arg_text.contains(pname + ":"):
                            if format == "json":
                                print "{\"line\":{line_num},\"col\":{arg_col},\"label\":\"{pname}:\",\"kind\":\"parameter\"}"
                            else:
                                print "{line_num}:{arg_col}: {pname}: [parameter]"
                            count = count + 1
                        ai = ai + 1
            ci = end_ci
        else:
            ci = ci + 1
    count

fn _lookup_params(fn_name: text, fn_names: [text], fn_params: [text]) -> text:
    """Look up parameter names for a function by name."""
    var i = 0
    while i < fn_names.len():
        if fn_names[i] == fn_name and i < fn_params.len():
            return fn_params[i]
        i = i + 1
    ""

fn _extract_call_arg_positions(line: text, paren_pos: i64) -> [i64]:
    """Extract the column positions where each argument starts in a function call.
    paren_pos is the position of the opening parenthesis.
    Returns a list of 0-based column positions.
    """
    var positions: [i64] = []
    var depth = 0
    var ci = paren_pos
    var in_string = false
    while ci < line.len():
        val ch = line.substring(ci, ci + 1)
        if ch == "\"" and not in_string:
            in_string = true
            ci = ci + 1
            continue
        if ch == "\"" and in_string:
            in_string = false
            ci = ci + 1
            continue
        if ch == "\\" and in_string:
            ci = ci + 2
            continue
        if in_string:
            ci = ci + 1
            continue

        if ch == "(":
            depth = depth + 1
            if depth == 1:
                # Start of first argument
                val arg_start = _skip_whitespace(line, ci + 1)
                if arg_start < line.len() and line.substring(arg_start, arg_start + 1) != ")":
                    positions.push(arg_start)
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                break
        elif ch == "," and depth == 1:
            val arg_start = _skip_whitespace(line, ci + 1)
            positions.push(arg_start)
        ci = ci + 1
    positions

fn _skip_whitespace(line: text, pos: i64) -> i64:
    """Skip whitespace characters starting at pos. Returns the new position."""
    var ci = pos
    while ci < line.len():
        val ch = line.substring(ci, ci + 1)
        if ch != " " and ch != "\t":
            break
        ci = ci + 1
    ci

fn _get_arg_text_at(line: text, col: i64) -> text:
    """Get a short preview of the argument text at a column position."""
    if col >= line.len():
        return ""
    val end_pos = if col + 30 < line.len(): col + 30 else: line.len()
    line.substring(col, end_pos)

fn query_selection_range(file: text, line_num: i64, col: i64) -> i64:
    val content = query_file_read_rich(file)
    if content == "":
        print "Could not read file: {file}"
        return 1

    val lines = content.split("\n")
    if line_num < 1 or line_num > lines.len():
        print "Line {line_num} out of range (file has {lines.len()} lines)"
        return 1

    val target_line = lines[line_num - 1]
    val target_indent = _count_indent(target_line)

    # 1. Word at cursor
    var word_start = col - 1
    var word_end = col - 1
    if col > 0 and col <= target_line.len():
        for _i in range(0, col):
            if word_start <= 0:
                break
            val ch = target_line.substring(word_start - 1, word_start)
            val iw = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
            if not iw:
                break
            word_start = word_start - 1
        for _i in range(0, 200):
            if word_end >= target_line.len():
                break
            val ch = target_line.substring(word_end, word_end + 1)
            val iw = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
            if not iw:
                break
            word_end = word_end + 1
    print "Range: {line_num}:{word_start} - {line_num}:{word_end} (word)"

    # 2. Full line (trimmed content)
    val trim_start = target_indent
    val trim_end = target_line.len()
    print "Range: {line_num}:{trim_start} - {line_num}:{trim_end} (expression)"

    # 3. Full line including indent
    print "Range: {line_num}:0 - {line_num}:{target_line.len()} (line)"

    # 4. Block at same or deeper indent level
    var block_start = line_num
    var bi = line_num - 2
    while bi >= 0:
        val bl = lines[bi]
        if bl.trim() == "":
            bi = bi - 1
            continue
        val bi_indent = _count_indent(bl)
        if bi_indent < target_indent:
            break
        block_start = bi + 1
        bi = bi - 1
    var block_end = line_num
    var bj = line_num
    while bj < lines.len():
        val bl = lines[bj]
        if bl.trim() == "":
            bj = bj + 1
            continue
        val bj_indent = _count_indent(bl)
        if bj_indent < target_indent:
            break
        block_end = bj + 1
        bj = bj + 1
    print "Range: {block_start}:0 - {block_end}:{lines[block_end - 1].len()} (block)"

    # 5. Enclosing function or class
    var enclosing_start = -1
    var ei = line_num - 2
    while ei >= 0:
        val el = lines[ei]
        val et = el.trim()
        val starts_fn = et.starts_with("fn ")
        val starts_class = et.starts_with("class ")
        val starts_struct = et.starts_with("struct ")
        if starts_fn or starts_class or starts_struct:
            enclosing_start = ei + 1
            break
        ei = ei - 1
    if enclosing_start > 0:
        # Find end of enclosing block
        var enc_end = enclosing_start
        var ej = enclosing_start
        while ej < lines.len():
            val el = lines[ej]
            if el.trim() == "":
                ej = ej + 1
                continue
            val ej_indent = _count_indent(el)
            if ej > enclosing_start and ej_indent == 0:
                break
            enc_end = ej + 1
            ej = ej + 1
        print "Range: {enclosing_start}:0 - {enc_end}:{lines[enc_end - 1].len()} (function)"

    # 6. Entire file
    print "Range: 1:0 - {lines.len()}:{lines[lines.len() - 1].len()} (file)"
    0

fn query_document_formatting(file: text) -> i64:
    val clean_file = sanitize_path(file)
    if clean_file == "":
        print "Error: invalid file path"
        return 1

    # Format file in-process using the Formatter
    val fmt = make_formatter()
    val result = fmt.format_file(clean_file)
    match result:
        case Ok(formatted):
            print formatted
            return 0
        case Err(e):
            print "Formatting failed for: {clean_file}"
            print "Error: {e}"
            return 1

fn query_ast_query(cmd_args: [text]) -> i64:
    if cmd_args.len() < 2:
        print "Error: ast-query requires a pattern argument"
        print "Usage: simple query ast-query '(node_kind pred: \"value\")' [--files path] [--format text|json|compact]"
        return 1
    val query_str = cmd_args[1]
    val files_arg = _extract_flag(cmd_args, "--files", "src/")
    val format_str = _extract_flag(cmd_args, "--format", "text")
    var files: [text] = [files_arg]
    engine_ast_query(query_str, files, format_str)

fn query_sem_query(cmd_args: [text]) -> i64:
    if cmd_args.len() < 2:
        print "Error: sem-query requires a query argument"
        print "Usage: simple query sem-query 'FIND <target> WHERE <pred>' [--files path] [--format text|json|compact]"
        return 1
    val query_str = cmd_args[1]
    val files_arg = _extract_flag(cmd_args, "--files", "src/")
    val format_str = _extract_flag(cmd_args, "--format", "text")
    var files: [text] = [files_arg]
    engine_sem_query(query_str, files, format_str)

fn query_query_schema(cmd_args: [text]) -> i64:
    var kind = ""
    if cmd_args.len() >= 2:
        kind = cmd_args[1]
    engine_query_schema(kind)

fn query_check(file: text, cmd_args: [text]) -> i64:
    val format = _extract_flag(cmd_args, "--format", "text")
    # In JSON mode, collect diagnostics and wrap in MCP-compatible structure
    if format == "json":
        _DIAG_COLLECT_MODE = true
        _DIAG_COLLECTED = []
    val result = check_file(file)
    match result:
        case CompileResult.Success(_):
            # Run source-based lint checks for additional diagnostics
            if rt_file_exists(file):
                val source = rt_file_read_text(file) ?? ""
                if source != "":
                    _emit_source_lint_diagnostics(file, source, format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 0
        case CompileResult.TypeError(errors):
            _emit_check_errors(file, errors, "TypeError", format)
            _emit_lint_if_readable(file, format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.ParseError(errors):
            _emit_check_errors(file, errors, "ParseError", format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.BlockError(errors):
            _emit_check_errors(file, errors, "BlockError", format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.ResolveError(errors):
            _emit_check_errors(file, errors, "ResolveError", format)
            _emit_lint_if_readable(file, format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.BorrowError(errors):
            _emit_check_errors(file, errors, "BorrowError", format)
            _emit_lint_if_readable(file, format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.CodegenError(msg):
            _emit_check_errors(file, [msg], "CodegenError", format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case CompileResult.RuntimeError(msg):
            _emit_check_errors(file, [msg], "RuntimeError", format)
            if format == "json":
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            return 1
        case _:
            if format == "json":
                _DIAG_COLLECTED.push("{\"severity\":1,\"code\":\"E0000\",\"message\":\"check failed\",\"line\":1,\"col\":1,\"end_line\":1,\"end_col\":1,\"tags\":[],\"source\":\"simple\"}")
                _emit_mcp_diagnostics_wrapper(_DIAG_COLLECTED)
                _DIAG_COLLECT_MODE = false
            else:
                print "{file}:1:1: error: check failed"
            return 1

fn _emit_mcp_diagnostics_wrapper(diagnostics: [text]):
    """Wrap collected diagnostics in MCP-compatible structured content format."""
    val count = diagnostics.len()
    val diags_array = "[" + diagnostics.join(",") + "]"
    val summary = str(count) + " diagnostics found"
    # Build MCP-compatible output:
    # {"content":[{"type":"text","text":"N diagnostics found"}],
    #  "structuredContent":{"diagnostics":[...],"count":N},
    #  "isError":false}
    var parts: [text] = []
    parts.push("{\"content\":[{\"type\":\"text\",\"text\":\"" + summary + "\"}]")
    parts.push(",\"structuredContent\":{\"diagnostics\":" + diags_array + ",\"count\":" + str(count) + "}")
    parts.push(",\"isError\":false}")
    print parts.join("")

fn _emit_check_errors(file: text, errors: [text], error_kind: text, format: text):
    """Emit compiler errors in text or JSON format.

    Supports structured error strings with related information:
    - "|||RELATED:line:col:message" segments are emitted as relatedInformation
    - "|||HELP:message" segments are appended to the diagnostic message
    """
    if format == "json":
        val emitter = LspEmitter.default_emitter()
        for err in errors:
            # Split structured metadata from the core error
            val structured = _split_structured_error(err)
            val core_err = structured.0
            val related_items = structured.1
            val help_text = structured.2

            val parsed = _parse_error_location(core_err)
            val line = parsed.0
            val col = parsed.1
            var msg = parsed.2
            # Append help text to message if present
            if help_text != "":
                msg = "{msg} (help: {help_text})"
            val code = _extract_error_code(msg, error_kind)
            var parts: [text] = []
            parts.push("{\"severity\":1")
            parts.push(",\"code\":{emitter.encode_string(code)}")
            parts.push(",\"message\":{emitter.encode_string(msg)}")
            parts.push(",\"line\":{line}")
            parts.push(",\"col\":{col}")
            parts.push(",\"end_line\":{line}")
            parts.push(",\"end_col\":{col}")
            parts.push(",\"tags\":[]")
            parts.push(",\"source\":\"simple\"")
            # Emit relatedInformation if present
            if related_items.len() > 0:
                var info_parts: [text] = []
                for item in related_items:
                    val rel_parsed = _parse_error_location(item)
                    val rel_line = rel_parsed.0
                    val rel_col = rel_parsed.1
                    val rel_msg = rel_parsed.2
                    info_parts.push("{\"location\":{\"uri\":{emitter.encode_string(file)},\"range\":{\"start\":{\"line\":{rel_line - 1},\"character\":{rel_col - 1}},\"end\":{\"line\":{rel_line - 1},\"character\":{rel_col}}}},\"message\":{emitter.encode_string(rel_msg)}}")
                parts.push(",\"relatedInformation\":[{info_parts.join(\",\")}]")
            parts.push("}")
            _diag_emit_or_collect(parts.join(""))
    else:
        for err in errors:
            # Strip structured metadata for text format
            val structured = _split_structured_error(err)
            val core_err = structured.0
            val help_text = structured.2
            if help_text != "":
                print "{file}:{core_err}"
                print "  = help: {help_text}"
            else:
                print "{file}:{core_err}"

fn _parse_error_location(err: text) -> (i64, i64, text):
    """Parse line:col:message from an error string. Returns (line, col, message)."""
    var colon1 = -1
    var colon2 = -1
    var ci = 0
    while ci < err.len():
        if err.substring(ci, ci + 1) == ":":
            if colon1 == -1:
                colon1 = ci
            elif colon2 == -1:
                colon2 = ci
                break
        ci = ci + 1
    if colon1 > 0 and colon2 > colon1:
        val line_str = err.substring(0, colon1)
        val col_str = err.substring(colon1 + 1, colon2)
        val msg = err.substring(colon2 + 1).trim()
        val line = line_str.to_int()
        val col = col_str.to_int()
        if line > 0:
            return (line, if col > 0: col else: 1, msg)
    (1, 1, err)

fn _split_structured_error(err: text) -> (text, [text], text):
    """Split a structured error string into (core_error, related_items, help_text).

    Structured error format uses '|||' as segment separator:
    - "core_error|||RELATED:line:col:message|||HELP:message"
    - Multiple RELATED segments are allowed
    - HELP segment is optional

    Returns (core_error, [related_items as "line:col:message"], help_text).
    """
    var core = err
    var related: [text] = []
    var help = ""

    # Check for structured metadata
    val sep = "|||"
    val sep_idx = _find_in_line_from(err, sep, 0)
    if sep_idx < 0:
        return (err, related, help)

    # Split on the first ||| to get core error
    core = err.substring(0, sep_idx)
    val rest = err.substring(sep_idx)

    # Parse remaining segments
    val segments = rest.split(sep)
    for segment in segments:
        val trimmed = segment.trim()
        if trimmed == "":
            continue
        if trimmed.starts_with("RELATED:"):
            val rel_content = trimmed.substring(8)
            related = related.push(rel_content)
        elif trimmed.starts_with("HELP:"):
            help = trimmed.substring(5)

    (core, related, help)

fn _extract_error_code(msg: text, error_kind: text) -> text:
    """Extract an E-code from an error message or infer one from the error kind.

    Strategy:
    1. Check if the message already contains an explicit error code (e.g. error[E1001])
    2. Pattern-match common error message phrases to known E-codes
    3. Fall back to a generic code based on error_kind
    """
    # --- Strategy 1: explicit error code in message ---
    # Look for pattern: error[Exxxx] or [Exxxx] or just Exxxx at start
    # Use _find_in_line_from (returns -1 on miss) instead of _find_in_line (returns 0)
    val bracket_idx = _find_in_line_from(msg, "[E", 0)
    if bracket_idx >= 0:
        # Extract code between [ and ]
        val close_idx = _find_in_line_from(msg, "]", bracket_idx)
        if close_idx > bracket_idx + 1:
            return msg.substring(bracket_idx + 1, close_idx)

    # Check for "Exxxx:" at the start of the message
    if msg.len() >= 5 and msg.substring(0, 1) == "E":
        val maybe_code = msg.substring(0, 5)
        if _is_error_code(maybe_code):
            return maybe_code

    # --- Strategy 2: pattern-match message content to known E-codes ---
    # Semantic errors (E10xx)
    if (msg.contains("not found in this scope") or msg.contains("not defined")) and msg.contains("variable"):
        return "E1001"
    if (msg.contains("not found") or msg.contains("cannot find")) and msg.contains("function"):
        return "E1002"
    if msg.contains("expected type") and msg.contains("found"):
        return "E1003"
    if msg.contains("type mismatch") or msg.contains("incompatible type"):
        return "E1003"
    if msg.contains("cannot assign") or msg.contains("invalid assignment"):
        return "E1004"
    if msg.contains("cannot apply operator"):
        return "E1005"
    if msg.contains("invalid pattern"):
        return "E1006"
    if msg.contains("missing field") or msg.contains("missing required field"):
        return "E1007"
    if msg.contains("duplicate definition") or msg.contains("already defined"):
        return "E1008"
    if msg.contains("circular dependency") or msg.contains("circular import"):
        return "E1009"
    if msg.contains("module") and msg.contains("not found"):
        return "E1010"
    if msg.contains("type") and msg.contains("not found") and not msg.contains("function"):
        return "E1011"
    if msg.contains("no field named"):
        return "E1012"
    if msg.contains("no method named"):
        return "E1013"
    if msg.contains("unknown class"):
        return "E1014"
    if msg.contains("unknown enum"):
        return "E1015"
    if msg.contains("expected") and msg.contains("argument"):
        return "E1020"
    if msg.contains("missing") and msg.contains("struct field"):
        return "E1021"
    if msg.contains("duplicate") and msg.contains("method"):
        return "E1025"
    if msg.contains("missing") and msg.contains("trait") and msg.contains("method"):
        return "E1031"
    if msg.contains("self") and msg.contains("static"):
        return "E1032"
    if msg.contains("unresolved import"):
        return "E1034"
    if msg.contains("private") and msg.contains("field"):
        return "E1046"
    if msg.contains("not callable") or msg.contains("is not callable"):
        return "E1048"
    if msg.contains("inconsistent bindings"):
        return "E1068"

    # Control flow errors (E11xx / E1057)
    if msg.contains("break") and msg.contains("outside") and msg.contains("loop"):
        return "E1101"
    if msg.contains("continue") and msg.contains("outside") and msg.contains("loop"):
        return "E1102"
    if msg.contains("return") and msg.contains("outside") and msg.contains("function"):
        return "E1103"
    if msg.contains("return") and msg.contains("closure"):
        return "E1104"
    if msg.contains("yield") and msg.contains("outside") and msg.contains("generator"):
        return "E1057"
    if msg.contains("await") and msg.contains("outside") and msg.contains("async"):
        return "E1105"

    # Actor/concurrency errors (E12xx)
    if msg.contains("actor") and msg.contains("send"):
        return "E1201"
    if msg.contains("actor") and msg.contains("recv"):
        return "E1202"
    if msg.contains("channel closed"):
        return "E1203"
    if msg.contains("deadlock"):
        return "E1204"

    # Capability errors (E13xx)
    if msg.contains("capability") and msg.contains("violation"):
        return "E1301"
    if msg.contains("isolation") and msg.contains("violation"):
        return "E1302"
    if msg.contains("borrow") and msg.contains("violation"):
        return "E1303"

    # Macro errors (E14xx)
    if msg.contains("unknown macro"):
        return "E1401"
    if msg.contains("macro") and msg.contains("before definition"):
        return "E1402"
    if msg.contains("macro") and msg.contains("invocation failed"):
        return "E1401"

    # AOP errors (E15xx)
    if msg.contains("pointcut") and msg.contains("syntax"):
        return "E1501"
    if msg.contains("joinpoint") and msg.contains("undefined"):
        return "E1502"
    if msg.contains("advice") and msg.contains("invalid"):
        return "E1503"
    if msg.contains("weaving") and msg.contains("target"):
        return "E1505"
    if msg.contains("aspect") and msg.contains("circular"):
        return "E1506"

    # Mixin errors (E17xx)
    if msg.contains("mixin") and msg.contains("not found"):
        return "E1701"
    if msg.contains("mixin") and msg.contains("conflict"):
        return "E1702"

    # Codegen errors (E20xx)
    if msg.contains("unsupported feature"):
        return "E2001"
    if msg.contains("FFI error"):
        return "E2002"

    # Runtime errors (E30xx)
    if msg.contains("division by zero"):
        return "E3001"
    if msg.contains("index") and msg.contains("out of bounds"):
        return "E3002"
    if msg.contains("stack overflow"):
        return "E3003"
    if msg.contains("assertion failed"):
        return "E3004"

    # Method resolution special case
    if msg.contains("Method resolution"):
        return "E1013"

    # Type inference errors
    if msg.contains("infinite type") or msg.contains("occurs in"):
        return "E0391"
    if msg.contains("trait not implemented") or msg.contains("does not implement"):
        return "E0277"

    # Dimension constraint errors (E05xx from dim_constraints_types)
    if msg.contains("dimension mismatch"):
        return "E0501"
    if msg.contains("layer dimension mismatch"):
        return "E0502"
    if msg.contains("tensor rank mismatch"):
        return "E0503"
    if msg.contains("matrix multiplication dimension"):
        return "E0504"
    if msg.contains("shapes cannot be broadcast"):
        return "E0505"
    if msg.contains("batch dimension mismatch"):
        return "E0506"
    if msg.contains("channel dimension mismatch"):
        return "E0507"
    if msg.contains("sequence length mismatch"):
        return "E0508"

    # Borrow checking errors
    if msg.contains("cannot borrow") or msg.contains("also borrowed"):
        return "E0502"
    if msg.contains("cannot use") and msg.contains("mutably borrowed"):
        return "E0503"
    if msg.contains("cannot move") and msg.contains("borrowed"):
        return "E0505"
    if msg.contains("borrow") and msg.contains("still be active at return"):
        return "E0515"

    # Trait coherence errors
    if msg.contains("foreign trait") and msg.contains("foreign type"):
        return "E0117"
    if msg.contains("Overlapping implementations"):
        return "E0119"
    if msg.contains("Blanket implementation") and msg.contains("conflicts"):
        return "E0119"
    if msg.contains("Conflicting associated type"):
        return "E0271"

    # Trait validation errors
    if msg.contains("ambiguous trait impl"):
        return "E0283"
    if msg.contains("overlapping impls"):
        return "E0119"
    if msg.contains("missing method") and msg.contains("impl"):
        return "E0046"
    if msg.contains("cyclic trait bound"):
        return "E0275"
    if msg.contains("undefined trait"):
        return "E0405"
    if msg.contains("missing associated type"):
        return "E0191"
    if msg.contains("associated type mismatch"):
        return "E0271"

    # --- Strategy 3: fall back to generic code based on error_kind ---
    match error_kind:
        "TypeError": "E1003"
        "ParseError": "E0001"
        "BlockError": "E1601"
        "ResolveError": "E1013"
        "BorrowError": "E1303"
        "CodegenError": "E2001"
        "RuntimeError": "E3001"
        _: "E0000"

fn _is_error_code(s: text) -> bool:
    """Check if a string looks like an error code (E followed by 4 digits)."""
    if s.len() < 5:
        return false
    if s.substring(0, 1) != "E":
        return false
    var i = 1
    while i < 5:
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    true

fn _find_in_line_from(line: text, needle: text, start: i64) -> i64:
    """Find needle in line starting from a given position. Returns -1 if not found."""
    var i = start
    val nlen = needle.len()
    while i <= line.len() - nlen:
        if line.substring(i, i + nlen) == needle:
            return i
        i = i + 1
    -1

fn _compile_result_error_kind(result: CompileResult) -> text:
    """Extract the error kind name from a CompileResult variant."""
    match result:
        case CompileResult.Success(_): "Success"
        case CompileResult.TypeError(_): "TypeError"
        case CompileResult.ParseError(_): "ParseError"
        case CompileResult.BlockError(_): "BlockError"
        case CompileResult.ResolveError(_): "ResolveError"
        case CompileResult.BorrowError(_): "BorrowError"
        case CompileResult.CodegenError(_): "CodegenError"
        case CompileResult.RuntimeError(_): "RuntimeError"
        case _: "Unknown"

fn _emit_lint_if_readable(file: text, format: text):
    """Emit lint diagnostics if the file is readable."""
    if rt_file_exists(file):
        val source = rt_file_read_text(file) ?? ""
        if source != "":
            _emit_source_lint_diagnostics(file, source, format)

fn _emit_source_lint_diagnostics(file: text, source: text, format: text) -> i64:
    """Run lint checks and emit diagnostics.

    Performs text-level analysis for:
    - Unused variables/imports (text heuristic: val/var declarations not referenced)
    - Deprecated patterns (Type__method syntax, .new() constructors, bare pass)
    - Unreachable code (statements after return)
    - Match exhaustiveness (match without wildcard arm)

    Then runs AST-based lint passes for:
    - ARG001/ARG002: argument count (>7 warn, >12 error)
    - COLL001-008: collection efficiency anti-patterns
    - DTYP001: duplicate typed argument detection
    - STUB001/002: stub implementation detection
    - W0406: star import warnings
    - W0404: wide public API warnings

    Returns the number of diagnostics emitted.
    """
    val lines = source.split("\n")
    var count = 0
    val emitter = LspEmitter.default_emitter()

    # --- Deprecated pattern detection (text-based) ---
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1

        # DEPR001: Type__method() calls — identifier containing __ not at start/end
        count = count + _check_deprecated_double_underscore(trimmed, line_num, file, format, emitter)

        # DEPR002: .new() constructor calls
        if trimmed.contains(".new("):
            if format == "json":
                val col = _find_in_line(trimmed, ".new(") + 1
                _diag_emit_or_collect("{\"severity\":2,\"code\":\"DEPR002\",\"message\":\"'.new()' constructor is deprecated, use StructName(field: value) syntax\",\"line\":{line_num},\"col\":{col},\"end_line\":{line_num},\"end_col\":{col + 5},\"tags\":[2],\"source\":\"simple-lint\"}")
            else:
                print "{file}:{line_num}: warning[DEPR002]: '.new()' constructor is deprecated"
            count = count + 1

        # DEPR003: Bare 'pass' (not pass_todo, pass_do_nothing, pass_dn)
        if (trimmed == "pass" or trimmed.starts_with("pass ") or trimmed.starts_with("pass#")):
            if not trimmed.starts_with("pass_"):
                if format == "json":
                    _diag_emit_or_collect("{\"severity\":2,\"code\":\"DEPR003\",\"message\":\"bare 'pass' is deprecated, use pass_do_nothing or pass_todo\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":5,\"tags\":[2],\"source\":\"simple-lint\"}")
                else:
                    print "{file}:{line_num}: warning[DEPR003]: bare 'pass' is deprecated"
                count = count + 1

        # UNREACH: Statements after return in same block
        if _is_return_statement(trimmed):
            val next_unreachable = _find_next_statement_in_block(lines, li)
            if next_unreachable > 0:
                if format == "json":
                    _diag_emit_or_collect("{\"severity\":2,\"code\":\"UNREACH001\",\"message\":\"unreachable code after return\",\"line\":{next_unreachable},\"col\":1,\"end_line\":{next_unreachable},\"end_col\":1,\"tags\":[1],\"source\":\"simple-lint\"}")
                else:
                    print "{file}:{next_unreachable}: warning[UNREACH001]: unreachable code after return"
                count = count + 1

        li = li + 1

    # --- Unused variable detection (text-based heuristic) ---
    count = count + _check_unused_vars_text(lines, file, format, emitter)

    # --- Match exhaustiveness (text-based heuristic) ---
    count = count + _check_match_exhaustiveness_text(lines, file, format, emitter)

    # --- Closure capture warning (text-based heuristic) ---
    count = count + _check_closure_capture_text(lines, file, format, emitter)

    # --- Ignored return value (text-based heuristic) ---
    count = count + _check_ignored_return_text(lines, file, format, emitter)

    # --- Multiline boolean without parens (text-based heuristic) ---
    count = count + _check_multiline_bool_text(lines, file, format, emitter)

    # --- Safety: unsafe operations outside unsafe block (text-based heuristic) ---
    count = count + _check_safety_text(lines, file, format, emitter)

    # --- Visibility: private access across modules (text-based heuristic) ---
    count = count + _check_visibility_text(lines, file, format, emitter)

    # --- AST-based lint passes (argument count, collection patterns, etc.) ---
    count = count + _run_ast_lint_passes(source, file, format, emitter)

    count

fn _find_fn_line_in_source(lines: [text], fn_name: text) -> i64:
    """Find the 1-based line number of a function definition by name.
    Searches for 'fn <name>(' or 'me <name>(' patterns.
    Returns 1 if not found.
    """
    var li = 0
    while li < lines.len():
        val trimmed = lines[li].trim()
        if (trimmed.contains("fn {fn_name}(") or
            trimmed.contains("me {fn_name}(") or
            trimmed.contains("fn {fn_name} (") or
            trimmed.starts_with("fn {fn_name}:") or
            trimmed.starts_with("me {fn_name}:")):
            return li + 1
        li = li + 1
    1

fn _find_use_line_in_source(lines: [text], module_path: text) -> i64:
    """Find the 1-based line number of a use/import statement by module path.
    Returns 1 if not found.
    """
    var li = 0
    while li < lines.len():
        val trimmed = lines[li].trim()
        if trimmed.starts_with("use ") and trimmed.contains(module_path):
            return li + 1
        if trimmed.starts_with("import ") and trimmed.contains(module_path):
            return li + 1
        li = li + 1
    1

fn _severity_text_to_json(severity: text) -> i64:
    """Convert severity string to LSP severity number.
    1=Error, 2=Warning, 3=Information, 4=Hint
    """
    if severity == "error" or severity == "ERROR" or severity == "CRITICAL":
        return 1
    if severity == "WARNING" or severity == "warning":
        return 2
    if severity == "INFO" or severity == "info" or severity == "MEDIUM":
        return 3
    if severity == "HIGH":
        return 2
    2

fn _run_ast_lint_passes(source: text, file: text, format: text, emitter: LspEmitter) -> i64:
    """Parse source into AST and run all AST-based lint passes.

    Runs the following checks after parsing the source:
    - ARG001/ARG002: argument count (>7 warn, >12 error)
    - COLL001-008: collection efficiency anti-patterns
    - DTYP001: duplicate typed argument detection
    - STUB001/002: stub implementation detection
    - W0406: star import warnings
    - W0404: wide public API warnings

    Returns the number of diagnostics emitted.
    """
    var count = 0
    val lines = source.split("\n")

    # Parse source into AST arena
    ast_reset()
    parse_module(source, file)
    val decl_indices = module_get_decls()

    if decl_indices.len() == 0:
        return 0

    # --- C1: ARG001/ARG002 — argument count checks ---
    val arg_warnings = check_argument_count(decl_indices)
    for w in arg_warnings:
        val line_num = _find_fn_line_in_source(lines, w.fn_name)
        val sev = _severity_text_to_json(w.severity)
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":{sev},\"code\":\"{w.code}\",\"message\":\"{msg}\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":1,\"tags\":[],\"source\":\"simple-lint\"}")
        else:
            print "{file}:{line_num}: {w.severity}[{w.code}]: {w.message}"
        count = count + 1

    # --- C2: COLL001-008 — collection efficiency patterns ---
    val coll_warnings = check_collection_patterns(decl_indices)
    for w in coll_warnings:
        val line_num = _find_fn_line_in_source(lines, w.item_name)
        val sev = _severity_text_to_json(w.severity)
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":{sev},\"code\":\"{w.code}\",\"message\":\"{msg}\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":1,\"tags\":[],\"source\":\"simple-lint\"}")
        else:
            print "{file}:{line_num}: {w.severity}[{w.code}]: {w.message}"
        count = count + 1

    # --- C3: DTYP001 — duplicate typed argument detection ---
    val dtyp_warnings = check_duplicate_typed_args(decl_indices)
    for w in dtyp_warnings:
        val line_num = _find_fn_line_in_source(lines, w.fn_name)
        val sev = _severity_text_to_json(w.severity)
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":{sev},\"code\":\"{w.code}\",\"message\":\"{msg}\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":1,\"tags\":[],\"source\":\"simple-lint\"}")
        else:
            print "{file}:{line_num}: {w.severity}[{w.code}]: {w.message}"
        count = count + 1

    # --- C4: STUB001/002 — stub implementation detection ---
    val stub_warnings = check_stub_impl(decl_indices)
    for w in stub_warnings:
        val line_num = _find_fn_line_in_source(lines, w.fn_name)
        val sev = _severity_text_to_json(w.severity)
        # STUB warnings get Unnecessary tag (faded rendering in IDE)
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":{sev},\"code\":\"{w.code}\",\"message\":\"{msg}\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":1,\"tags\":[1],\"source\":\"simple-lint\"}")
        else:
            print "{file}:{line_num}: {w.severity}[{w.code}]: {w.message}"
        count = count + 1

    # --- C5a: Star import warnings (W0406) ---
    val star_warnings = check_star_import_file(decl_indices, file)
    for w in star_warnings:
        val line_num = _find_use_line_in_source(lines, w.module_path)
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":2,\"code\":\"{w.code}\",\"message\":\"{msg}\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":1,\"tags\":[],\"source\":\"simple-lint\"}")
        else:
            print "{file}:{line_num}: warning[{w.code}]: {w.message}"
        count = count + 1

    # --- C5b: Wide public API warnings (W0404) ---
    val wide_warnings = check_wide_public_file(decl_indices, file)
    for w in wide_warnings:
        # Module-level warning, report on line 1
        if format == "json":
            val msg = emitter.escape_string(w.message)
            _diag_emit_or_collect("{\"severity\":2,\"code\":\"{w.code}\",\"message\":\"{msg} ({w.export_count} symbols, threshold {w.threshold})\",\"line\":1,\"col\":1,\"end_line\":1,\"end_col\":1,\"tags\":[],\"source\":\"simple-lint\"}")
        else:
            print "{file}:1: warning[{w.code}]: {w.message} ({w.export_count} symbols, threshold {w.threshold})"
        count = count + 1

    count

fn _check_deprecated_double_underscore(trimmed: text, line_num: i64, file: text, format: text, emitter: LspEmitter) -> i64:
    """Check for Type__method() deprecated call pattern in a line."""
    # Look for identifier__identifier( pattern
    var ci = 0
    var found = 0
    while ci < trimmed.len() - 3:
        val ch = trimmed.substring(ci, ci + 1)
        val is_alpha = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
        if is_alpha:
            var end_ci = ci + 1
            while end_ci < trimmed.len():
                val wc = trimmed.substring(end_ci, end_ci + 1)
                val ww = (wc >= "a" and wc <= "z") or (wc >= "A" and wc <= "Z") or (wc >= "0" and wc <= "9") or wc == "_"
                if not ww:
                    break
                end_ci = end_ci + 1
            val word = trimmed.substring(ci, end_ci)
            # Check for __ in the middle (not at start/end, not dunder)
            if (word.len() > 4 and not word.starts_with("__") and
                not word.ends_with("__") and word.contains("__")):
                # Check if followed by (
                if end_ci < trimmed.len() and trimmed.substring(end_ci, end_ci + 1) == "(":
                    if format == "json":
                        _diag_emit_or_collect("{\"severity\":2,\"code\":\"DEPR001\",\"message\":\"'{word}()' uses deprecated Type__method() syntax\",\"line\":{line_num},\"col\":{ci + 1},\"end_line\":{line_num},\"end_col\":{end_ci + 1},\"tags\":[2],\"source\":\"simple-lint\"}")
                    else:
                        print "{file}:{line_num}: warning[DEPR001]: '{word}()' uses deprecated Type__method() syntax"
                    found = found + 1
            ci = end_ci
        else:
            ci = ci + 1
    found

fn _is_return_statement(trimmed: text) -> bool:
    """Check if a trimmed line is a return statement."""
    (trimmed == "return" or trimmed.starts_with("return "))

fn _find_next_statement_in_block(lines: [text], return_idx: i64) -> i64:
    """Find the next non-empty statement at the same indentation level after a return.
    Returns the 1-based line number, or 0 if no unreachable code found.
    """
    if return_idx >= lines.len() - 1:
        return 0
    val return_line = lines[return_idx]
    val return_indent = _count_indent(return_line)

    var ni = return_idx + 1
    while ni < lines.len():
        val next_line = lines[ni]
        val next_trimmed = next_line.trim()
        if next_trimmed == "":
            ni = ni + 1
            continue
        val next_indent = _count_indent(next_line)
        # If indentation decreased, we left the block
        if next_indent < return_indent:
            return 0
        # If at same indent, it's unreachable code in the same block
        if next_indent == return_indent:
            return ni + 1
        ni = ni + 1
    0

fn _check_unused_vars_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for unused variable detection.

    Scans for val/var declarations with _ prefix convention NOT used,
    and checks if the declared name appears elsewhere in the function body.
    """
    var count = 0
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()

        # Look for val/var declarations (not _-prefixed names)
        var decl_name = ""
        if trimmed.starts_with("val "):
            decl_name = _extract_decl_name(trimmed.substring(4))
        elif trimmed.starts_with("var "):
            decl_name = _extract_decl_name(trimmed.substring(4))

        if decl_name != "" and not decl_name.starts_with("_"):
            # Find the enclosing function boundaries
            val fn_range = _find_enclosing_fn_range(lines, li)
            if fn_range.0 >= 0:
                # Check if decl_name is referenced elsewhere in the function
                var referenced = false
                var ri = fn_range.0
                while ri <= fn_range.1 and ri < lines.len():
                    if ri != li:
                        val rline = lines[ri]
                        if _word_occurs_in(rline, decl_name):
                            referenced = true
                            break
                    ri = ri + 1
                if not referenced:
                    val line_num = li + 1
                    if format == "json":
                        val col = _find_in_line(trimmed, decl_name) + 1
                        val end_col = col + decl_name.len()
                        _diag_emit_or_collect("{\"severity\":2,\"code\":\"UNUSED001\",\"message\":\"variable '{decl_name}' is declared but never used\",\"line\":{line_num},\"col\":{col},\"end_line\":{line_num},\"end_col\":{end_col},\"tags\":[1],\"source\":\"simple-lint\"}")
                    else:
                        print "{file}:{line_num}: warning[UNUSED001]: variable '{decl_name}' is declared but never used"
                    count = count + 1
        li = li + 1
    count

fn _extract_decl_name(after_kw: text) -> text:
    """Extract the variable name from text after val/var keyword."""
    var name_chars: [text] = []
    for ch in after_kw:
        val ok = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
        if not ok:
            break
        name_chars.push(ch)
    name_chars.join("")

fn _find_enclosing_fn_range(lines: [text], target_idx: i64) -> (i64, i64):
    """Find the start and end line indices of the enclosing function body.
    Returns (-1, -1) if not inside a function.
    """
    val target_indent = _count_indent(lines[target_idx])
    # Find function header above
    var fn_start = -1
    var si = target_idx - 1
    while si >= 0:
        val sline = lines[si]
        val st = sline.trim()
        if (st.starts_with("fn ") or st.starts_with("me ") or
            st.starts_with("static fn ")):
            fn_start = si
            break
        # If we hit a line at indent 0 that is not blank and not a comment, stop
        val sindent = _count_indent(sline)
        if sindent == 0 and st != "" and not st.starts_with("#"):
            if (not st.starts_with("fn ") and not st.starts_with("me ") and
                not st.starts_with("static fn ")):
                break
        si = si - 1
    if fn_start < 0:
        return (-1, -1)

    # Find function end (where indent returns to 0 or less than body)
    var fn_end = fn_start
    var ei = fn_start + 1
    while ei < lines.len():
        val eline = lines[ei]
        val et = eline.trim()
        if et == "":
            ei = ei + 1
            continue
        val eindent = _count_indent(eline)
        if eindent == 0:
            break
        fn_end = ei
        ei = ei + 1
    (fn_start, fn_end)

fn _word_occurs_in(line: text, word: text) -> bool:
    """Check if a word occurs as a whole word in a line."""
    if line.len() < word.len():
        return false
    var pos = 0
    while pos <= line.len() - word.len():
        val candidate = line.substring(pos, pos + word.len())
        if candidate == word:
            var left_ok = true
            var right_ok = true
            if pos > 0:
                val lch = line.substring(pos - 1, pos)
                val lw = (lch >= "a" and lch <= "z") or (lch >= "A" and lch <= "Z") or (lch >= "0" and lch <= "9") or lch == "_"
                if lw:
                    left_ok = false
            if pos + word.len() < line.len():
                val rch = line.substring(pos + word.len(), pos + word.len() + 1)
                val rw = (rch >= "a" and rch <= "z") or (rch >= "A" and rch <= "Z") or (rch >= "0" and rch <= "9") or rch == "_"
                if rw:
                    right_ok = false
            if left_ok and right_ok:
                return true
        pos = pos + 1
    false

fn _check_match_exhaustiveness_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for match exhaustiveness.
    Checks if match expressions have a wildcard/default arm.
    """
    var count = 0
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()

        if trimmed.starts_with("match ") and trimmed.ends_with(":"):
            val match_indent = _count_indent(line)
            # Scan case arms
            var has_wildcard = false
            var arm_count = 0
            var ai = li + 1
            while ai < lines.len():
                val aline = lines[ai]
                val at = aline.trim()
                if at == "":
                    ai = ai + 1
                    continue
                val aindent = _count_indent(aline)
                if aindent <= match_indent:
                    break
                if at.starts_with("case _:") or at.starts_with("case _\n") or at == "case _":
                    has_wildcard = true
                arm_count = arm_count + 1
                ai = ai + 1

            if arm_count > 0 and not has_wildcard:
                val line_num = li + 1
                if format == "json":
                    _diag_emit_or_collect("{\"severity\":2,\"code\":\"MEXH002\",\"message\":\"match expression has no wildcard/default case\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":{trimmed.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                else:
                    print "{file}:{line_num}: warning[MEXH002]: match expression has no wildcard/default case"
                count = count + 1

        li = li + 1
    count

fn _find_in_line(line: text, pattern: text) -> i64:
    """Find the 0-based position of pattern in line. Returns 0 if not found."""
    var pos = 0
    while pos <= line.len() - pattern.len():
        if line.substring(pos, pos + pattern.len()) == pattern:
            return pos
        pos = pos + 1
    0

# ============================================================================
# CLOS001: Closure modifies outer variable (text-based heuristic)
# ============================================================================

fn _check_closure_capture_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for closure capture modification detection."""
    var count = 0
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        if (trimmed.starts_with("fn ") or trimmed.starts_with("me ")):
            val fn_indent = _count_indent(line)
            if fn_indent > 0:
                var outer_vars: [text] = []
                _collect_outer_vars_clos(lines, li, fn_indent, outer_vars)
                var body_start = li + 1
                while body_start < lines.len():
                    val bline = lines[body_start]
                    val bt = bline.trim()
                    if bt == "":
                        body_start = body_start + 1
                        continue
                    val bindent = _count_indent(bline)
                    if bindent <= fn_indent:
                        break
                    for ovar in outer_vars:
                        if _is_assign_to_clos(bt, ovar):
                            val bline_num = body_start + 1
                            if format == "json":
                                _diag_emit_or_collect("{\"severity\":2,\"code\":\"CLOS001\",\"message\":\"closure modifies outer variable '{ovar}' — changes won't persist (capture-by-value)\",\"line\":{bline_num},\"col\":1,\"end_line\":{bline_num},\"end_col\":{bt.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                            else:
                                print "{file}:{bline_num}: warning[CLOS001]: closure modifies outer variable '{ovar}'"
                            count = count + 1
                    body_start = body_start + 1
        li = li + 1
    count

fn _collect_outer_vars_clos(lines: [text], fn_line: i64, fn_indent: i64, vars: [text]):
    """Collect var declarations from the enclosing scope above fn_line."""
    var si = fn_line - 1
    while si >= 0:
        val sline = lines[si]
        val st = sline.trim()
        val sindent = _count_indent(sline)
        if sindent < fn_indent and st != "" and not st.starts_with("#"):
            if (st.starts_with("fn ") or st.starts_with("me ") or
                st.starts_with("static fn ") or st.starts_with("class ") or
                st.starts_with("struct ")):
                break
        if st.starts_with("var ") and sindent <= fn_indent:
            val var_name = _extract_decl_name(st.substring(4))
            if var_name != "":
                vars.push(var_name)
        si = si - 1

fn _is_assign_to_clos(trimmed: text, var_name: text) -> bool:
    """Check if a trimmed line assigns to the given variable name."""
    if trimmed.starts_with(var_name):
        val after = trimmed.substring(var_name.len())
        val at = after.trim()
        if at.starts_with("= ") or at.starts_with("=\t") or at == "=":
            return true
        if (at.starts_with("+= ") or at.starts_with("-= ") or
            at.starts_with("*= ") or at.starts_with("/= ")):
            return true
    false

# ============================================================================
# RET001: Ignored function return value (text-based heuristic)
# ============================================================================

fn _check_ignored_return_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for ignored return value detection."""
    var count = 0
    val side_effects: [text] = [
        "print", "println", "eprint", "eprintln",
        "push", "pop", "clear", "sort", "reverse", "remove", "insert",
        "write", "close", "flush", "set", "delete", "reset", "append",
        "log", "info", "warn", "error", "debug", "trace",
        "sleep", "exit", "abort", "send", "emit", "notify",
        "lock", "unlock", "continue", "break", "return",
        "pass_todo", "pass_do_nothing", "pass_dn"
    ]
    val side_prefixes: [text] = [
        "set_", "add_", "remove_", "delete_", "clear_", "reset_",
        "push_", "init_", "register_", "emit_", "on_", "handle_",
        "log_", "print_", "write_", "assert", "expect", "check_", "_"
    ]
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1
        val indent = _count_indent(line)
        if indent > 0 and trimmed.len() > 0:
            val call_name = _extract_call_name_ret(trimmed)
            if call_name != "":
                if (not trimmed.starts_with("val ") and not trimmed.starts_with("var ") and
                    not _is_any_assign_ret(trimmed)):
                    var is_side_effect = false
                    for se in side_effects:
                        if call_name == se:
                            is_side_effect = true
                            break
                    if not is_side_effect:
                        for prefix in side_prefixes:
                            if call_name.starts_with(prefix):
                                is_side_effect = true
                                break
                    if not is_side_effect:
                        if not _is_last_stmt_ret(lines, li):
                            if format == "json":
                                _diag_emit_or_collect("{\"severity\":3,\"code\":\"RET001\",\"message\":\"return value of '{call_name}()' is discarded\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":{trimmed.len()},\"tags\":[1],\"source\":\"simple-lint\"}")
                            else:
                                print "{file}:{line_num}: info[RET001]: return value of '{call_name}()' is discarded"
                            count = count + 1
        li = li + 1
    count

fn _extract_call_name_ret(trimmed: text) -> text:
    """Extract function/method call name from a trimmed line."""
    val paren_pos = _find_in_line_from(trimmed, "(", 0)
    if paren_pos <= 0:
        return ""
    val before_paren = trimmed.substring(0, paren_pos)
    if (before_paren == "if" or before_paren == "while" or before_paren == "for" or
        before_paren == "match" or before_paren == "return" or before_paren == "elif"):
        return ""
    var end_idx = before_paren.len()
    var start_idx = end_idx - 1
    while start_idx >= 0:
        val ch = before_paren.substring(start_idx, start_idx + 1)
        val is_id = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
        if not is_id:
            break
        start_idx = start_idx - 1
    start_idx = start_idx + 1
    if start_idx >= end_idx:
        return ""
    before_paren.substring(start_idx, end_idx)

fn _is_any_assign_ret(trimmed: text) -> bool:
    """Check if a line contains an assignment before a function call."""
    val eq_pos = _find_in_line_from(trimmed, " = ", 0)
    val paren_pos = _find_in_line_from(trimmed, "(", 0)
    if eq_pos >= 0 and (paren_pos < 0 or eq_pos < paren_pos):
        return true
    val walrus_pos = _find_in_line_from(trimmed, ":=", 0)
    if walrus_pos >= 0 and (paren_pos < 0 or walrus_pos < paren_pos):
        return true
    false

fn _is_last_stmt_ret(lines: [text], idx: i64) -> bool:
    """Check if the line at idx is the last non-empty statement at its indent level."""
    val target_indent = _count_indent(lines[idx])
    var ni = idx + 1
    while ni < lines.len():
        val next_line = lines[ni]
        val nt = next_line.trim()
        if nt == "":
            ni = ni + 1
            continue
        val next_indent = _count_indent(next_line)
        if next_indent < target_indent:
            return true
        if next_indent == target_indent:
            return false
        ni = ni + 1
    true

# ============================================================================
# BOOL001: Multiline boolean without parentheses (text-based heuristic)
# ============================================================================

fn _check_multiline_bool_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for multiline boolean detection."""
    var count = 0
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1
        var keyword = ""
        var cond_start = ""
        if trimmed.starts_with("if "):
            keyword = "if"
            cond_start = trimmed.substring(3)
        elif trimmed.starts_with("elif "):
            keyword = "elif"
            cond_start = trimmed.substring(5)
        elif trimmed.starts_with("while "):
            keyword = "while"
            cond_start = trimmed.substring(6)
        if keyword != "":
            val cs = cond_start.trim()
            var stripped = trimmed
            if stripped.ends_with(":"):
                stripped = stripped.substring(0, stripped.len() - 1).trim()
            val ends_with_bool = (stripped.ends_with(" and") or stripped.ends_with(" or"))
            var next_starts_bool = false
            if li + 1 < lines.len():
                val next_t = lines[li + 1].trim()
                next_starts_bool = (next_t.starts_with("and ") or next_t.starts_with("or "))
            if ends_with_bool or next_starts_bool:
                if not cs.starts_with("("):
                    if format == "json":
                        _diag_emit_or_collect("{\"severity\":2,\"code\":\"BOOL001\",\"message\":\"multiline boolean in '{keyword}' without parentheses — may parse incorrectly\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":{trimmed.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                    else:
                        print "{file}:{line_num}: warning[BOOL001]: multiline boolean in '{keyword}' without parentheses"
                    count = count + 1
        li = li + 1
    count

# ============================================================================
# SAFE001/SAFE003: Safety violations (text-based heuristic)
# ============================================================================

fn _check_safety_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for safety checking."""
    var count = 0
    var in_unsafe = false
    var unsafe_indent = -1
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1
        val indent = _count_indent(line)
        if trimmed.starts_with("unsafe:") or trimmed.starts_with("unsafe {"):
            in_unsafe = true
            unsafe_indent = indent
        if in_unsafe and indent <= unsafe_indent and trimmed != "" and not trimmed.starts_with("unsafe"):
            in_unsafe = false
            unsafe_indent = -1
        if not in_unsafe and indent > 0:
            if trimmed.starts_with("asm ") or trimmed.starts_with("asm(") or trimmed == "asm":
                if format == "json":
                    _diag_emit_or_collect("{\"severity\":1,\"code\":\"SAFE001\",\"message\":\"inline assembly outside unsafe block\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":{trimmed.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                else:
                    print "{file}:{line_num}: error[SAFE001]: inline assembly outside unsafe block"
                count = count + 1
            if (trimmed.contains("ptr_read(") or trimmed.contains("ptr_write(") or
                trimmed.contains("ptr_cast(") or trimmed.contains("ptr_offset(") or
                trimmed.contains("mem_copy(") or trimmed.contains("mem_set(")):
                if format == "json":
                    _diag_emit_or_collect("{\"severity\":1,\"code\":\"SAFE003\",\"message\":\"raw pointer operation outside unsafe block\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":{trimmed.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                else:
                    print "{file}:{line_num}: error[SAFE003]: raw pointer operation outside unsafe block"
                count = count + 1
        li = li + 1
    count

# ============================================================================
# W0401: Visibility violations (text-based heuristic)
# ============================================================================

fn _check_visibility_text(lines: [text], file: text, format: text, emitter: LspEmitter) -> i64:
    """Text-based heuristic for visibility checking."""
    var count = 0
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1
        if trimmed.starts_with("use ") and trimmed.contains(".{"):
            val brace_start = _find_in_line_from(trimmed, "{", 0)
            val brace_end = _find_in_line_from(trimmed, "}", 0)
            if brace_start >= 0 and brace_end > brace_start:
                val imports_str = trimmed.substring(brace_start + 1, brace_end)
                val imports = imports_str.split(",")
                for imp in imports:
                    val imp_name = imp.trim()
                    if (imp_name.starts_with("_") and not imp_name.starts_with("__") and
                        imp_name.len() > 1):
                        if format == "json":
                            val col = _find_in_line(trimmed, imp_name) + 1
                            _diag_emit_or_collect("{\"severity\":2,\"code\":\"W0401\",\"message\":\"importing private symbol '{imp_name}' from another module\",\"line\":{line_num},\"col\":{col},\"end_line\":{line_num},\"end_col\":{col + imp_name.len()},\"tags\":[],\"source\":\"simple-lint\"}")
                        else:
                            print "{file}:{line_num}: warning[W0401]: importing private symbol '{imp_name}' from another module"
                        count = count + 1
        li = li + 1
    count

# ============================================================================
# Task 2d: Workspace Diagnostics
# ============================================================================

fn query_workspace_diagnostics(dir_path: text, cmd_args: [text]) -> i64:
    """Run diagnostics on all .spl files in a directory.

    Outputs diagnostics grouped by file. Supports --format=json for
    structured JSON output suitable for LSP workspace diagnostics.
    """
    val format = _extract_flag(cmd_args, "--format", "text")
    val clean_dir = sanitize_path(dir_path)
    if clean_dir == "":
        print "Error: invalid directory path"
        return 1

    # Collect all .spl files recursively
    var spl_files: [text] = []
    _collect_spl_files(clean_dir, spl_files)

    if spl_files.len() == 0:
        if format == "json":
            print "[]"
        else:
            print "No .spl files found in: {clean_dir}"
        return 0

    var total_diagnostics = 0
    var files_with_issues = 0
    var json_file_entries: [text] = []

    for spl_file in spl_files:
        val result = check_file(spl_file)
        var file_has_issues = false
        var file_diag_count = 0

        val ws_error_kind = _compile_result_error_kind(result)

        match result:
            case CompileResult.Success(_):
                pass_do_nothing
            case _:
                file_has_issues = true
                val errors = result.get_errors()
                if format == "json":
                    val emitter = LspEmitter.default_emitter()
                    var diag_parts: [text] = []
                    for err in errors:
                        # Parse structured error metadata
                        val structured = _split_structured_error(err)
                        val core_err = structured.0
                        val related_items = structured.1
                        val help_text = structured.2

                        val parsed = _parse_error_location(core_err)
                        val err_line = parsed.0
                        val err_col = parsed.1
                        var err_msg = parsed.2
                        if help_text != "":
                            err_msg = "{err_msg} (help: {help_text})"
                        val err_code = _extract_error_code(err_msg, ws_error_kind)
                        var parts: [text] = []
                        parts.push("{\"severity\":1")
                        parts.push(",\"code\":{emitter.encode_string(err_code)}")
                        parts.push(",\"message\":{emitter.encode_string(err_msg)}")
                        parts.push(",\"line\":{err_line}")
                        parts.push(",\"col\":{err_col}")
                        parts.push(",\"end_line\":{err_line}")
                        parts.push(",\"end_col\":{err_col}")
                        parts.push(",\"tags\":[]")
                        parts.push(",\"source\":\"simple\"")
                        # Emit relatedInformation if present
                        if related_items.len() > 0:
                            var info_parts: [text] = []
                            for item in related_items:
                                val rel_parsed = _parse_error_location(item)
                                val rel_line = rel_parsed.0
                                val rel_col = rel_parsed.1
                                val rel_msg = rel_parsed.2
                                info_parts.push("{\"location\":{\"uri\":{emitter.encode_string(spl_file)},\"range\":{\"start\":{\"line\":{rel_line - 1},\"character\":{rel_col - 1}},\"end\":{\"line\":{rel_line - 1},\"character\":{rel_col}}}},\"message\":{emitter.encode_string(rel_msg)}}")
                            parts.push(",\"relatedInformation\":[{info_parts.join(\",\")}]")
                        parts.push("}")
                        diag_parts.push(parts.join(""))
                        file_diag_count = file_diag_count + 1
                    json_file_entries.push("{\"file\":{emitter.encode_string(spl_file)},\"diagnostics\":[{diag_parts.join(\",\")}]}")
                else:
                    for err in errors:
                        val structured = _split_structured_error(err)
                        val core_err = structured.0
                        val help_text = structured.2
                        if help_text != "":
                            print "{spl_file}:{core_err}"
                            print "  = help: {help_text}"
                        else:
                            print "{spl_file}:{core_err}"
                        file_diag_count = file_diag_count + 1

        # Also run source-level lint checks
        if rt_file_exists(spl_file):
            val source = rt_file_read_text(spl_file) ?? ""
            if source != "":
                if format == "json":
                    # Capture lint diagnostics for this file
                    val lint_count = _collect_lint_diagnostics_json(spl_file, source)
                    if lint_count.0 > 0:
                        file_has_issues = true
                        file_diag_count = file_diag_count + lint_count.0
                        json_file_entries.push("{\"file\":\"{spl_file}\",\"diagnostics\":[{lint_count.1}]}")
                else:
                    val lint_count = _emit_source_lint_diagnostics(spl_file, source, format)
                    if lint_count > 0:
                        file_has_issues = true
                        file_diag_count = file_diag_count + lint_count

        if file_has_issues:
            files_with_issues = files_with_issues + 1
        total_diagnostics = total_diagnostics + file_diag_count

    if format == "json":
        print "[{json_file_entries.join(\",\")}]"
    else:
        print ""
        print "--- Summary ---"
        print "Files scanned: {spl_files.len()}"
        print "Files with issues: {files_with_issues}"
        print "Total diagnostics: {total_diagnostics}"

    if total_diagnostics > 0:
        return 1
    0

fn _collect_spl_files(dir: text, files: [text]):
    """Recursively collect all .spl files in a directory."""
    val entries = rt_dir_list(dir)
    for entry in entries:
        if entry == "." or entry == "..":
            continue
        val full_path = if dir.ends_with("/"): dir + entry else: dir + "/" + entry
        if entry.ends_with(".spl"):
            files.push(full_path)
        # Recurse into subdirectories (heuristic: no extension = directory)
        elif not entry.contains("."):
            _collect_spl_files(full_path, files)

fn _collect_lint_diagnostics_json(file: text, source: text) -> (i64, text):
    """Run source-based lint checks and return (count, json_diagnostics_string).
    This captures diagnostics as JSON strings instead of printing them.
    """
    val lines = source.split("\n")
    var count = 0
    var parts: [text] = []
    val emitter = LspEmitter.default_emitter()

    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val line_num = li + 1

        # DEPR002: .new() calls
        if trimmed.contains(".new("):
            val col = _find_in_line(trimmed, ".new(") + 1
            parts.push("{\"severity\":2,\"code\":\"DEPR002\",\"message\":\"'.new()' constructor is deprecated\",\"line\":{line_num},\"col\":{col},\"end_line\":{line_num},\"end_col\":{col + 5},\"tags\":[2],\"source\":\"simple-lint\"}")
            count = count + 1

        # DEPR003: Bare pass
        if (trimmed == "pass" or trimmed.starts_with("pass ") or trimmed.starts_with("pass#")):
            if not trimmed.starts_with("pass_"):
                parts.push("{\"severity\":2,\"code\":\"DEPR003\",\"message\":\"bare 'pass' is deprecated\",\"line\":{line_num},\"col\":1,\"end_line\":{line_num},\"end_col\":5,\"tags\":[2],\"source\":\"simple-lint\"}")
                count = count + 1

        # UNREACH: After return
        if _is_return_statement(trimmed):
            val next_unreachable = _find_next_statement_in_block(lines, li)
            if next_unreachable > 0:
                parts.push("{\"severity\":2,\"code\":\"UNREACH001\",\"message\":\"unreachable code after return\",\"line\":{next_unreachable},\"col\":1,\"end_line\":{next_unreachable},\"end_col\":1,\"tags\":[1],\"source\":\"simple-lint\"}")
                count = count + 1

        li = li + 1

    # Run text-based new lint checks and collect their JSON output
    # These use _diag_emit_or_collect which collects to _DIAG_COLLECTED when in collect mode
    val prev_mode = _DIAG_COLLECT_MODE
    _DIAG_COLLECT_MODE = true
    val prev_collected = _DIAG_COLLECTED
    _DIAG_COLLECTED = []

    val clos_count = _check_closure_capture_text(lines, file, "json", emitter)
    val ret_count = _check_ignored_return_text(lines, file, "json", emitter)
    val bool_count = _check_multiline_bool_text(lines, file, "json", emitter)
    val safe_count = _check_safety_text(lines, file, "json", emitter)
    val vis_count = _check_visibility_text(lines, file, "json", emitter)

    for d in _DIAG_COLLECTED:
        parts.push(d)
    count = count + clos_count + ret_count + bool_count + safe_count + vis_count

    _DIAG_COLLECT_MODE = prev_mode
    _DIAG_COLLECTED = prev_collected

    (count, parts.join(","))
