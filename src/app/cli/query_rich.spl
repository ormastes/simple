# Simple Language - Query CLI Rich Subcommands
#
# Main entry point that imports and re-exports from split modules.
# Complex/rich query command implementations.
# Handles rename, code-actions, workspace-symbols, call-hierarchy,
# type-hierarchy, semantic-tokens, inlay-hints, selection-range,
# document-formatting, ast-query, sem-query, query-schema,
# workspace-diagnostics.

# Re-export common utilities
use app.cli.query_rich_common.{_diag_emit_or_collect, query_file_read_rich, _find_in_line, _find_in_line_from, _parse_error_location, _extract_decl_name, _DIAG_COLLECT_MODE, _DIAG_COLLECTED}

# Re-export navigation functions
use app.cli.query_navigation.{query_rename, query_code_actions, query_workspace_symbols, query_call_hierarchy, query_type_hierarchy, query_selection_range}

# Re-export token functions
use app.cli.query_tokens.{query_semantic_tokens, query_inlay_hints}

# Re-export formatting/dispatch functions
use app.cli.query_formatting.{query_signature_help, query_document_formatting, query_ast_query, query_sem_query, query_query_schema}
