# CLI Subcommand: baremetal
#
# Entry point for `bin/simple baremetal terminal --config <path>`

use std.nogc_sync_mut.baremetal.config.parse_hostcomm_config
use std.nogc_sync_mut.baremetal.host_comm.HostComm
use std.nogc_sync_mut.baremetal.terminal.HostTerminal
use std.nogc_sync_mut.baremetal.types.{TransportKind, transport_kind_to_text}

extern fn rt_print(msg: text)
extern fn rt_print_err(msg: text)
extern fn rt_exit(code: i32)

# Parse CLI args and dispatch to the appropriate subcommand
fn baremetal_main(args: [text]):
    if args.len() < 1:
        print_usage()
        rt_exit(1)
        return

    val subcmd = args[0]

    match subcmd:
        "terminal":
            run_terminal(args[1:])
        "status":
            run_status(args[1:])
        "help":
            print_usage()
        _:
            rt_print_err("Unknown subcommand: {subcmd}")
            print_usage()
            rt_exit(1)

fn run_terminal(args: [text]):
    var config_path = "config/baremetal/default.sdn"

    # Parse args
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config" or arg == "-c":
            if i + 1 < args.len():
                config_path = args[i + 1]
                i = i + 2
                continue
            else:
                rt_print_err("--config requires a path argument")
                rt_exit(1)
                return
        i = i + 1

    # Load config
    val config_result = parse_hostcomm_config(config_path)
    match config_result:
        Ok(config):
            rt_print("Config loaded: {transport_kind_to_text(config.transport)} transport")
            val comm = HostComm.create(config)
            var terminal = HostTerminal.create(comm)
            val result = terminal.run()
            match result:
                Ok(msg): rt_print(msg)
                Err(e):
                    rt_print_err("Terminal error: {e}")
                    rt_exit(1)
        Err(e):
            rt_print_err("Config error: {e}")
            rt_exit(1)

fn run_status(args: [text]):
    var config_path = "config/baremetal/default.sdn"

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config" or arg == "-c":
            if i + 1 < args.len():
                config_path = args[i + 1]
                i = i + 2
                continue
        i = i + 1

    val config_result = parse_hostcomm_config(config_path)
    match config_result:
        Ok(config):
            rt_print("Transport: {transport_kind_to_text(config.transport)}")
            rt_print("Timeout:   {config.timeout_ms} ms")
        Err(e):
            rt_print_err("Config error: {e}")
            rt_exit(1)

fn print_usage():
    rt_print("Usage: bin/simple baremetal <subcommand> [options]")
    rt_print("")
    rt_print("Subcommands:")
    rt_print("  terminal  - Start interactive terminal session")
    rt_print("  status    - Show connection configuration")
    rt_print("  help      - Show this help")
    rt_print("")
    rt_print("Options:")
    rt_print("  --config, -c <path>  - Config file path (default: config/baremetal/default.sdn)")
