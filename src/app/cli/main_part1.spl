# =========================================================================
# SimpleOS wrapper path
# =========================================================================

fn os_parse_arch_arg(args: [text]) -> text:
    """Extract --arch=<name> or --target=<name> from args. Returns x86_64 by default."""
    for arg in args:
        if arg.starts_with("--arch="):
            val value = arg[7:]
            return if value == "": "__missing_arch__" else: value
        if arg.starts_with("--target="):
            val value = arg[9:]
            return if value == "": "__missing_arch__" else: value
    var i = 0
    while i < args.len():
        if args[i] == "--arch" or args[i] == "--target":
            if i + 1 >= args.len():
                return "__missing_arch__"
            val value = args[i + 1]
            if value.starts_with("-"):
                return "__missing_arch__"
            return value
        i = i + 1
    "x86_64"

fn os_has_flag(args: [text], flag: text) -> bool:
    for arg in args:
        if arg == flag:
            return true
    false

fn os_parse_log_arg(args: [text]) -> text:
    var mode = "on"
    var seen = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--log="):
            val value = arg[6:]
            if value == "":
                return "__missing__"
            if value != "on" and value != "off":
                return "__invalid__:{value}"
            mode = value
            seen = true
        elif arg == "--log":
            if i + 1 >= args.len():
                return "__missing__"
            val value = args[i + 1]
            if value.starts_with("-"):
                return "__missing__"
            if value != "on" and value != "off":
                return "__invalid__:{value}"
            mode = value
            seen = true
            i = i + 1
        elif arg.starts_with("--log"):
            return "__invalid_option__:{arg}"
        i = i + 1
    if seen:
        return mode
    "on"

fn os_log_arg_error(log_mode: text) -> text:
    if log_mode == "__missing__":
        return "Error: --log requires a value ('on' or 'off')"
    if log_mode.starts_with("__invalid_option__:"):
        val arg = log_mode[19:]
        return "Error: invalid log option '{arg}' (expected --log or --log=<on|off>)"
    if log_mode.starts_with("__invalid__:"):
        val value = log_mode[12:]
        return "Error: invalid --log value '{value}' (expected 'on' or 'off')"
    ""

fn print_os_help():
    print "SimpleOS — Multi-Architecture OS Build & Run"
    print ""
    print "Usage:"
    print "  simple os <command> [options]"
    print ""
    print "Commands:"
    print "  build              Build the OS kernel"
    print "  run                Build and run in QEMU"
    print "  test               Build and run boot smoke test"
    print "  targets            List supported architectures"
    print ""
    print "Options:"
    print "  --arch=<name>      Target architecture (default: x86_64)"
    print "  --target=<name>    Alias for --arch"
    print "  --all              Test all architectures (with 'test' command)"
    print "  --scenario=<name>  Named QEMU scenario (for run/test/build)"
    print "  --debug-gui        Keep GUI targets windowed while exposing serial logs"
    print "  --log=<on|off>     Compile normal OS logging in or out (default: on)"
    print ""
    print "Architectures:"
    print "  x86_64   x86_32   riscv64   riscv32   arm64   arm32"

fn print_os_targets():
    print "Supported SimpleOS architectures:"
    print ""
    val targets: [OsTarget] = get_all_targets()
    for target in targets:
        val name = arch_display_name(target.arch)
        print "  {name}  ->  {target.target_triple}  ({target.qemu_system})"
    print ""
    print "Default: x86_64"

fn _export_os_log_mode_inline(log_mode: text) -> bool:
    if env_set("SIMPLE_OS_LOG_MODE", log_mode):
        return true
    print "Error: could not export SIMPLE_OS_LOG_MODE={log_mode}"
    false

fn _restore_os_log_mode_inline(old_log_mode: text):
    env_set("SIMPLE_OS_LOG_MODE", old_log_mode)

fn os_parse_scenario_arg(args: [text]) -> text:
    for arg in args:
        if arg.starts_with("--scenario="):
            val value = arg[11:]
            return if value == "": "__missing_scenario__" else: value
    var i = 0
    while i < args.len():
        if args[i] == "--scenario":
            if i + 1 >= args.len():
                return "__missing_scenario__"
            val value = args[i + 1]
            if value.starts_with("-"):
                return "__missing_scenario__"
            return value
        i = i + 1
    ""

fn _os_arch_arg_error(arch_name: text) -> text:
    if arch_name == "__missing_arch__":
        return "Error: --arch/--target requires a value"
    ""

fn _os_scenario_arg_error(scenario_name: text) -> text:
    if scenario_name == "__missing_scenario__":
        return "Error: --scenario requires a value"
    ""

fn handle_os_build_inline(args: [text]) -> i64:
    val log_mode = os_parse_log_arg(args)
    val log_error = os_log_arg_error(log_mode)
    if log_error != "":
        print log_error
        return 1
    val old_log_mode = env_get("SIMPLE_OS_LOG_MODE") ?? ""
    if not _export_os_log_mode_inline(log_mode):
        return 1
    val scenario_name = os_parse_scenario_arg(args)
    val scenario_error = _os_scenario_arg_error(scenario_name)
    if scenario_error != "":
        _restore_os_log_mode_inline(old_log_mode)
        print scenario_error
        return 1
    if scenario_name != "":
        val scenario = get_scenario(scenario_name)
        if scenario == nil:
            _restore_os_log_mode_inline(old_log_mode)
            print "Error: unknown scenario '{scenario_name}'"
            return 1
        val ok = build_scenario(scenario)
        _restore_os_log_mode_inline(old_log_mode)
        return if ok: 0 else: 1

    val arch_name = os_parse_arch_arg(args)
    val arch_error = _os_arch_arg_error(arch_name)
    if arch_error != "":
        _restore_os_log_mode_inline(old_log_mode)
        print arch_error
        return 1
    val arch = arch_from_name(arch_name)
    if arch.?:
        val target = get_qemu_target(arch.unwrap())
        val ok = build_os(target)
        _restore_os_log_mode_inline(old_log_mode)
        if ok: 0 else: 1
    else:
        _restore_os_log_mode_inline(old_log_mode)
        print "Error: unknown architecture '{arch_name}'"
        print "Run 'simple os targets' for supported architectures."
        1

fn handle_os_run_inline(args: [text]) -> i64:
    val log_mode = os_parse_log_arg(args)
    val log_error = os_log_arg_error(log_mode)
    if log_error != "":
        print log_error
        return 1
    val old_log_mode = env_get("SIMPLE_OS_LOG_MODE") ?? ""
    if not _export_os_log_mode_inline(log_mode):
        return 1
    val scenario_name = os_parse_scenario_arg(args)
    val scenario_error = _os_scenario_arg_error(scenario_name)
    if scenario_error != "":
        _restore_os_log_mode_inline(old_log_mode)
        print scenario_error
        return 1
    if scenario_name != "":
        val scenario = get_scenario(scenario_name)
        if scenario == nil:
            _restore_os_log_mode_inline(old_log_mode)
            print "Error: unknown scenario '{scenario_name}'"
            return 1
        val built = build_scenario(scenario)
        if not built:
            _restore_os_log_mode_inline(old_log_mode)
            print "Error: build failed for scenario {scenario_name}"
            return 1
        val ok = run_scenario(scenario)
        _restore_os_log_mode_inline(old_log_mode)
        return if ok: 0 else: 1

    val arch_name = os_parse_arch_arg(args)
    val arch_error = _os_arch_arg_error(arch_name)
    if arch_error != "":
        _restore_os_log_mode_inline(old_log_mode)
        print arch_error
        return 1
    val debug_gui = os_has_flag(args, "--debug-gui")
    val arch = arch_from_name(arch_name)
    if arch.?:
        val target = get_qemu_target(arch.unwrap())
        val built = build_os(target)
        if not built:
            _restore_os_log_mode_inline(old_log_mode)
            print "Error: build failed for {arch_display_name(target.arch)}"
            return 1
        val ok = if debug_gui: run_os_debug_gui(target) else: run_os(target)
        _restore_os_log_mode_inline(old_log_mode)
        if ok: 0 else: 1
    else:
        _restore_os_log_mode_inline(old_log_mode)
        print "Error: unknown architecture '{arch_name}'"
        print "Run 'simple os targets' for supported architectures."
        1

fn handle_os_test_inline(args: [text]) -> i64:
    val log_mode = os_parse_log_arg(args)
    val log_error = os_log_arg_error(log_mode)
    if log_error != "":
        print log_error
        return 1
    val old_log_mode = env_get("SIMPLE_OS_LOG_MODE") ?? ""
    if not _export_os_log_mode_inline(log_mode):
        return 1
    if os_has_flag(args, "--all"):
        val ok = test_all_architectures()
        _restore_os_log_mode_inline(old_log_mode)
        if ok: 0 else: 1
    else:
        val scenario_name = os_parse_scenario_arg(args)
        val scenario_error = _os_scenario_arg_error(scenario_name)
        if scenario_error != "":
            _restore_os_log_mode_inline(old_log_mode)
            print scenario_error
            return 1
        if scenario_name != "":
            val scenario = get_scenario(scenario_name)
            if scenario == nil:
                _restore_os_log_mode_inline(old_log_mode)
                print "Error: unknown scenario '{scenario_name}'"
                return 1
            val built = build_scenario(scenario)
            if not built:
                _restore_os_log_mode_inline(old_log_mode)
                print "Error: build failed for scenario {scenario_name}"
                return 1
            val ok = test_scenario(scenario, scenario_test_timeout_ms(scenario))
            _restore_os_log_mode_inline(old_log_mode)
            return if ok: 0 else: 1

        val arch_name = os_parse_arch_arg(args)
        val arch_error = _os_arch_arg_error(arch_name)
        if arch_error != "":
            _restore_os_log_mode_inline(old_log_mode)
            print arch_error
            return 1
        val arch = arch_from_name(arch_name)
        if arch.?:
            val target = get_qemu_target(arch.unwrap())
            val built = build_os(target)
            if not built:
                _restore_os_log_mode_inline(old_log_mode)
                print "Error: build failed for {arch_display_name(target.arch)}"
                return 1
            val ok = test_os(target, 10000)
            _restore_os_log_mode_inline(old_log_mode)
            if ok: 0 else: 1
        else:
            _restore_os_log_mode_inline(old_log_mode)
            print "Error: unknown architecture '{arch_name}'"
            print "Run 'simple os targets' for supported architectures."
            1

fn handle_os_inline(args: [text]) -> i64:
    if args.len() == 0:
        print_os_help()
        return 0

    val subcmd = args[0]
    val rest = if args.len() > 1: args[1:] else: []
    match subcmd:
        "build":
            handle_os_build_inline(rest)
        "run":
            handle_os_run_inline(rest)
        "test":
            handle_os_test_inline(rest)
        "targets":
            print_os_targets()
            0
        "-h" | "--help" | "help":
            print_os_help()
            0
        _:
            print "Error: unknown os subcommand '{subcmd}'"
            print ""
            print_os_help()
            1

