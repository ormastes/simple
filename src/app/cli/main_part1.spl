extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text

# Extract CLI args, skipping program name and script path
fn get_cli_args() -> [text]:
    val raw_args = cli_get_args()
    var all_args: [text] = []
    if raw_args != nil:
        all_args = raw_args
    var start_idx = 1
    if all_args.len() > 1 and all_args[1].ends_with("main.spl"):
        start_idx = 2
    var args: [text] = []
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

# =========================================================================
# Version and Help - implemented in Simple
# =========================================================================
fn get_version() -> text:
    val version = env_get("SIMPLE_VERSION")
    if version != "" and version != nil:
        return version
    if cli_file_exists("VERSION"):
        val v = rt_file_read_text("VERSION")
        if v != "" and v != nil:
            return v.trim()
    "0.9.8"

fn print_version():
    val v = get_version()
    print "Simple v{v}"

