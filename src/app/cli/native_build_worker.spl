use app.io.cli_ops.{cli_get_args, cli_env_get, cli_exit}
use app.io._CliCompile.compile_targets.{cli_native_build}

fn native_build_entry_args() -> [text]:
    val raw_args = cli_get_args()
    var start_idx = 1
    var i = 0
    while i < raw_args.len():
        if raw_args[i].ends_with("native_build_worker.spl"):
            start_idx = i + 1
            break
        i = i + 1
    var args: [text] = []
    i = start_idx
    while i < raw_args.len():
        args = args.push(raw_args[i])
        i = i + 1
    args

fn main() -> i64:
    if (cli_env_get("SIMPLE_NATIVE_BUILD_WORKER") ?? "") != "1":
        print "error: native_build_worker.spl is an internal entrypoint"
        cli_exit(1)
    cli_native_build(native_build_entry_args())
