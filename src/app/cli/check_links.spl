# CLI handler for `bin/simple check-links`
#
# Displays resolved link dependencies and checks library availability.

use std.io_runtime.{host_os, host_arch}
use compiler.backend.linker.link_deps.{resolve_link_deps, check_links, ResolvedLinkDeps, LinkCheckResult}

fn cli_check_links(args: [text]) -> i64:
    val verbose = args_contain(args, "--verbose") or args_contain(args, "-v")
    val os = host_os()
    val arch = host_arch()

    print "Link Dependency Check"
    print "====================="
    print "Platform: {os}/{arch}"
    print ""

    # Resolve dependencies
    val deps = resolve_link_deps()

    # Show resolved libraries
    print "Libraries ({deps.libraries.len()}):"
    for lib in deps.libraries:
        print "  - {lib}"
    print ""

    # Show library directories
    if deps.library_dirs.len() > 0:
        print "Library directories ({deps.library_dirs.len()}):"
        for dir in deps.library_dirs:
            print "  - {dir}"
        print ""

    # Show CRT search dirs
    if verbose and deps.crt_search_dirs.len() > 0:
        print "CRT search directories ({deps.crt_search_dirs.len()}):"
        for dir in deps.crt_search_dirs:
            print "  - {dir}"
        print ""

    # Show dynamic linker candidates
    if verbose and deps.dynamic_linker_candidates.len() > 0:
        print "Dynamic linker candidates ({deps.dynamic_linker_candidates.len()}):"
        for path in deps.dynamic_linker_candidates:
            print "  - {path}"
        print ""

    # Show extra flags
    if deps.extra_link_flags.len() > 0:
        print "Extra link flags ({deps.extra_link_flags.len()}):"
        for flag in deps.extra_link_flags:
            print "  - {flag}"
        print ""

    if deps.no_default_libs:
        print "Note: no-default-libs is set, platform defaults are excluded."
        print ""

    # Check library availability
    print "Library availability:"
    val results = check_links()
    var all_found = true
    for result in results:
        if result.found:
            print "  [OK]   {result.library} -> {result.path}"
        else:
            print "  [MISS] {result.library}"
            all_found = false
    print ""

    if all_found:
        print "All libraries found."
        return 0
    else:
        print "Some libraries are missing. Linking may fail."
        return 1

fn args_contain(args: [text], flag: text) -> bool:
    for arg in args:
        if arg == flag:
            return true
    false
