# Simple Language - CLI Keyword Migration
#
# This file shows the planned migration of main.spl from manual arg parsing
# to the `cli` keyword. Apply this AFTER rebuilding with cli keyword support.
#
# Migration removes:
#   - GlobalFlags struct (~14 lines)
#   - parse_global_flags() (~118 lines)
#   - filter_internal_flags() (~13 lines)
#
# Migration adds:
#   - cli Args: block (~40 lines)
#
# Net savings: ~105 lines

# =========================================================================
# CLI Declaration (replaces GlobalFlags + parse_global_flags + filter_internal_flags)
# =========================================================================

cli Args:
    """Simple Language Compiler"""
    -g gc_log = false              """Enable GC logging"""
    gc_off = false                 """Disable garbage collection"""
    notui = false                  """Disable TUI mode"""
    interpret = false              """Force interpreter mode"""
    interpret_optimized = false    """Force optimized interpreter"""
    no_jit = false                 """Disable JIT compilation"""
    jit_threshold = 10             """JIT compilation threshold"""
    interpreter_mode = "optimized" """Interpreter mode: optimized|classic"""
    run_config = ""                """Run config: shared|interpreter|compiler|legacy"""
    -b backend = "auto"            """JIT backend: auto|cranelift|llvm"""
    stack_overflow_detection = false """Enable stack overflow detection"""
    no_stack_overflow_detection = false """Disable stack overflow detection"""
    max_recursion_depth = 0        """Maximum recursion depth"""
    timeout = 0                    """Execution timeout in seconds"""
    execution_limit = 0            """Execution statement limit"""
    file: ".spl"
    prefetch: true
    default: .repl
    sub test:
        """Run test suite"""
        -l list_only = false       """List tests without running"""
        only_slow = false          """Run only slow tests"""
    sub build:
        """Build project"""
        release = false            """Release mode"""
        warn_docs = false          """Check documentation coverage"""
    sub compile:
        """Compile source file"""
        -o output = ""             """Output path"""
        target = ""                """Target architecture"""
        linker = ""                """Linker: mold|lld|ld"""
    sub lint, fmt, fix, check, watch, lex, mcp, lsp, diff
    sub init, verify, stats, info, query
    sub diagram, web, run, env, cache, lock
    sub targets, linkers

