use app.io.cli_ops.{cli_get_args}
use app.io.cli_compile.{cli_native_build}

fn native_build_entry_args() -> [text]:
    val raw_args = cli_get_args()
    var start_idx = 1
    if raw_args.len() > 1 and raw_args[1].ends_with("native_build_main.spl"):
        start_idx = 2
    var args: [text] = []
    var i = start_idx
    while i < raw_args.len():
        args.push(raw_args[i])
        i = i + 1
    args

fn main() -> i64:
    cli_native_build(native_build_entry_args())
