# Pure Simple entrypoint for `simple electron`.

use std.cli.cli_util.{get_cli_args}
use app.io.process_ops.{process_run_timeout}

val OUTPUT_LIMIT = 12000

fn args_after_command() -> [text]:
    val raw = get_cli_args()
    var args: [text] = []
    var start = 1
    var i = 0
    while i < raw.len():
        if raw[i].ends_with("electron_entry.spl") or raw[i] == "electron":
            start = i + 1
            break
        i = i + 1
    i = start
    while i < raw.len():
        args.push(raw[i])
        i = i + 1
    args

fn print_help():
    print "Usage: simple electron <build|package> [options]"
    print ""
    print "Commands:"
    print "  build <source.spl>      Validate Electron shell wiring"
    print "  package [dir]           Not available without a pure Simple packager"

fn print_bounded(output: text):
    if output.len() == 0:
        return
    if output.len() <= OUTPUT_LIMIT:
        print output
        return
    print output[0:OUTPUT_LIMIT]
    print "[output truncated by electron entry]"

fn eprint_bounded(output: text):
    if output.len() == 0:
        return
    if output.len() <= OUTPUT_LIMIT:
        eprint output
        return
    eprint output[0:OUTPUT_LIMIT]
    eprint "[stderr truncated by electron entry]"

fn run_shell(command: text) -> i64:
    val (stdout, stderr, code) = process_run_timeout("sh", ["-c", command], 120000)
    print_bounded(stdout)
    eprint_bounded(stderr)
    code as i64

fn main() -> i64:
    val args = args_after_command()
    if args.len() == 0 or args.contains("-h") or args.contains("--help"):
        print_help()
        if args.len() == 0:
            return 1
        return 0

    val sub = args[0]
    if sub == "build":
        if args.len() < 2:
            eprint "error: electron build requires a source file"
            return 1
        return run_shell("npm --prefix tools/electron-shell run smoke")
    if sub == "package":
        eprint "error: electron package has no pure Simple packager wired yet"
        return 1

    eprint "error: unknown electron subcommand '{sub}'"
    1
