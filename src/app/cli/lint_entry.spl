# Lightweight lint/fmt/fix entry point for `simple lint|fmt|fix`.
#
# Keep this wrapper thin: command-specific work lives in app.io.cli_lint_commands
# so help/error paths do not import the old compiler CLI surface.

use std.cli.cli_util (get_cli_args)
use app.io.cli_lint_commands.{run_lint_command, run_fmt_command, run_fix_command}

fn print_command_help(command: text):
    if command == "lint":
        print "Usage: simple lint <file-or-directory> [more-targets...] [--mcp-perf] [--simd]"
        print ""
        print "Runs lint passes on Simple source files."
        print "--mcp-perf currently fails closed until its repository scanner has a production owner."
    elif command == "fmt":
        print "Usage: simple fmt <file.spl> [--check] [--write] [--diff]"
        print ""
        print "Options:"
        print "  --check  Check if file is formatted (exit 1 if not)"
        print "  --write  Format file in place"
        print "  --diff   Show formatting diff"
    elif command == "fix":
        print "Usage: simple fix <file.spl> [--dry-run] [--fix-all]"
        print ""
        print "Options:"
        print "  --dry-run   Show what would be fixed without applying"
        print "  --fix-all   Apply all fixes regardless of confidence"
        print "  --fix-id=ID Apply only fixes matching ID prefix"
    else:
        print "Usage: simple lint|fmt|fix [options] [path]"

fn args_request_help(args: [text]) -> bool:
    if args.len() == 1:
        return true
    args.len() == 2 and (args[1] == "--help" or args[1] == "-h")

fn main() -> i64:
    val all_args = get_cli_args()

    var filtered_args = []
    var i = 0
    if all_args.len() > 0 and all_args[0].ends_with("lint_entry.spl"):
        i = 1

    while i < all_args.len():
        filtered_args.push(all_args[i])
        i = i + 1

    if filtered_args.len() == 0:
        print "Usage: simple lint|fmt|fix [options] [path]"
        return 1

    val command = filtered_args[0]

    if command != "lint" and command != "fmt" and command != "fix":
        print "Unknown command: {command}"
        return 1

    if args_request_help(filtered_args):
        print_command_help(command)
        return 0

    if command == "lint":
        return run_lint_command(filtered_args)
    if command == "fmt":
        return run_fmt_command(filtered_args)
    run_fix_command(filtered_args)
