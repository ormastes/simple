fn mcp_tool_names() -> [text]:
    var names: [text] = []
    val tools = all_mcp_tools()
    for t in tools:
        names.push(t.name)
    names

fn mcp_tools_in_category(cat: text) -> [text]:
    var names: [text] = []
    val tools = all_mcp_tools()
    for t in tools:
        if t.category == cat:
            names.push(t.name)
    names

fn mcp_categories() -> [text]:
    ["debug", "debug-log", "diagnostics", "vcs", "cli", "query", "task", "test-daemon"]

fn mcp_tools_with_cli_equivalent() -> [text]:
    var names: [text] = []
    val tools = all_mcp_tools()
    for t in tools:
        if t.cli_equivalent != "":
            names.push(t.name)
    names

fn mcp_only_tools() -> [text]:
    var names: [text] = []
    val tools = all_mcp_tools()
    for t in tools:
        if t.cli_equivalent == "":
            names.push(t.name)
    names

# ============================================================================
# Alignment Matrix
# ============================================================================

class SurfaceAlignmentEntry:
    cli_command: text       # CLI command name, or "" if MCP-only
    mcp_tool: text          # MCP tool name, or "" if CLI-only
    direction: text         # "both" | "cli_only" | "mcp_only"
    semantic_match: bool    # true if they do the same thing

fn alignment_entry(cli: text, mcp: text, dir: text, sem: bool) -> SurfaceAlignmentEntry:
    SurfaceAlignmentEntry(cli_command: cli, mcp_tool: mcp, direction: dir, semantic_match: sem)

class AlignmentReport:
    entries: [SurfaceAlignmentEntry]
    both_count: i64
    cli_only_count: i64
    mcp_only_count: i64
    total_cli: i64
    total_mcp: i64

fn build_alignment_matrix() -> AlignmentReport:
    var entries: [SurfaceAlignmentEntry] = []
    var both_count = 0
    var cli_only_count = 0
    var mcp_only_count = 0

    # Build lookup of MCP tools -> cli equivalents
    val tools = all_mcp_tools()
    val cli_cmds = all_cli_commands()

    # Track which CLI commands have MCP equivalents
    var cli_covered: [text] = []

    # First: all MCP tools with CLI equivalents
    for t in tools:
        if t.cli_equivalent != "":
            entries.push(alignment_entry(t.cli_equivalent, t.name, "both", true))
            both_count = both_count + 1
            if not cli_covered.contains(t.cli_equivalent):
                cli_covered.push(t.cli_equivalent)

    # Second: CLI-only commands (no MCP equivalent)
    for c in cli_cmds:
        if not cli_covered.contains(c.name):
            entries.push(alignment_entry(c.name, "", "cli_only", false))
            cli_only_count = cli_only_count + 1

    # Third: MCP-only tools (no CLI equivalent)
    for t in tools:
        if t.cli_equivalent == "":
            entries.push(alignment_entry("", t.name, "mcp_only", false))
            mcp_only_count = mcp_only_count + 1

    AlignmentReport(
        entries: entries,
        both_count: both_count,
        cli_only_count: cli_only_count,
        mcp_only_count: mcp_only_count,
        total_cli: cli_cmds.len(),
        total_mcp: tools.len()
    )

fn cli_commands_without_mcp() -> [text]:
    val report = build_alignment_matrix()
    var result: [text] = []
    for e in report.entries:
        if e.direction == "cli_only":
            result.push(e.cli_command)
    result

fn mcp_tools_without_cli() -> [text]:
    val report = build_alignment_matrix()
    var result: [text] = []
    for e in report.entries:
        if e.direction == "mcp_only":
            result.push(e.mcp_tool)
    result

# ============================================================================
# Drift Detection Helpers
# ============================================================================

# Expected counts — update these when adding new commands/tools.
# Drift tests compare against these to detect unclassified additions.
fn expected_cli_command_count() -> i64:
    70

fn expected_mcp_tool_count() -> i64:
    99

fn expected_mcp_category_count() -> i64:
    8

fn check_cli_drift(actual_dispatch_count: i64) -> bool:
    # Returns true if no drift detected (counts match)
    val classified = all_cli_commands()
    classified.len() == actual_dispatch_count

fn check_mcp_drift(actual_tool_count: i64) -> bool:
    # Returns true if no drift detected (counts match)
    val classified = all_mcp_tools()
    classified.len() == actual_tool_count
