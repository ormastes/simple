#![allow(unnamed_duplicate_typed_args)]
# Surface Alignment — CLI/MCP bi-directional alignment verification
#
# Phase 2 of CLI/MCP Completeness (F13).
# Provides:
#   - Canonical CLI command inventory
#   - Canonical MCP tool inventory
#   - Bi-directional alignment matrix
#   - Drift detection helpers
#   - Category completeness verification

# ============================================================================
# CLI Command Classification
# ============================================================================

class CommandClassification:
    name: text
    kind: text            # "direct" | "file_delegation" | "shell_wrapper" | "experimental" | "built_in"
    handler_status: text  # "implemented" | "experimental" | "placeholder"
    family: text          # "execution" | "testing" | "quality" | "build" | "llm" | "docgen" | "package" | "verify" | "ffi" | "i18n" | "other"

fn command_class(name: text, kind: text, status: text, family: text) -> CommandClassification:
    CommandClassification(name: name, kind: kind, handler_status: status, family: family)

fn all_cli_commands() -> [CommandClassification]:
    var cmds: [CommandClassification] = []
    # Execution family (5)
    cmds.push(command_class("compile", "direct", "implemented", "execution"))
    cmds.push(command_class("run", "direct", "implemented", "execution"))
    cmds.push(command_class("watch", "direct", "implemented", "execution"))
    cmds.push(command_class("watch-daemon", "direct", "implemented", "execution"))
    cmds.push(command_class("targets", "direct", "implemented", "execution"))
    # Testing family (3)
    cmds.push(command_class("test", "file_delegation", "implemented", "testing"))
    cmds.push(command_class("test-daemon", "direct", "implemented", "testing"))
    cmds.push(command_class("spec-coverage", "file_delegation", "implemented", "testing"))
    # Code quality family (12)
    cmds.push(command_class("lex", "direct", "implemented", "quality"))
    cmds.push(command_class("lint", "direct", "implemented", "quality"))
    cmds.push(command_class("fix", "direct", "implemented", "quality"))
    cmds.push(command_class("fmt", "direct", "implemented", "quality"))
    cmds.push(command_class("check", "direct", "implemented", "quality"))
    cmds.push(command_class("duplicate-check", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("doc-coverage", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("traceability-check", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("check-arch", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("check-dbs", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("fix-dbs", "file_delegation", "implemented", "quality"))
    cmds.push(command_class("grammar-doc", "file_delegation", "implemented", "quality"))
    # Build family (3)
    cmds.push(command_class("build", "direct", "implemented", "build"))
    cmds.push(command_class("native-build", "direct", "implemented", "build"))
    cmds.push(command_class("linkers", "direct", "implemented", "build"))
    # LLM tools family (8)
    cmds.push(command_class("mcp", "shell_wrapper", "implemented", "llm"))
    cmds.push(command_class("lsp", "file_delegation", "implemented", "llm"))
    cmds.push(command_class("dap", "file_delegation", "implemented", "llm"))
    cmds.push(command_class("diff", "direct", "implemented", "llm"))
    cmds.push(command_class("constr", "direct", "experimental", "llm"))
    cmds.push(command_class("query", "file_delegation", "implemented", "llm"))
    cmds.push(command_class("info", "direct", "implemented", "llm"))
    cmds.push(command_class("brief", "direct", "implemented", "llm"))
    cmds.push(command_class("context", "file_delegation", "implemented", "llm"))
    # Doc generation family (8)
    cmds.push(command_class("feature-gen", "file_delegation", "implemented", "docgen"))
    cmds.push(command_class("task-gen", "file_delegation", "implemented", "docgen"))
    cmds.push(command_class("spec-gen", "file_delegation", "implemented", "docgen"))
