# Lightweight test entry point for `simple test`
#
# This file loads only the minimal imports needed to run tests,
# avoiding the overhead of loading the full CLI with all its modules
# (build system, type checker, stats, etc.).
#
# Usage:
#   bin/simple run src/app/cli/test_entry.spl test [options] [path]
#
# Performance:
#   Full CLI (main.spl): ~460ms overhead
#   This entry (test_entry.spl): ~220ms overhead
#   Direct runtime: ~90ms

use std.nogc_sync_mut.sffi.cli (cli_get_args, cli_run_tests)
use std.nogc_sync_mut.sffi.system (env_get, env_set)

extern fn rt_fault_set_stack_overflow_detection(enabled: bool)
extern fn rt_fault_set_max_recursion_depth(depth: i64)
extern fn rt_fault_set_timeout(secs: i64)
extern fn rt_fault_set_execution_limit(limit: i64)

# Maximum nesting depth for `simple test` invocations.
# A depth of 1 means only the outermost call is allowed; any nested
# `simple test` launched from within a spec or script is refused.
val SIMPLE_TEST_MAX_DEPTH = 1

fn parse_test_entry_nonnegative_or_default(value: text, default_value: i64) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return default_value
    for ch in trimmed:
        if ch < "0" or ch > "9":
            return default_value
    return trimmed.to_int() ?? default_value

fn main() -> i64:
    # Recursion guard: refuse if a parent `simple test` is already running.
    val depth_str = env_get("SIMPLE_TEST_DEPTH")
    val depth = parse_test_entry_nonnegative_or_default(depth_str, 0)
    if depth >= SIMPLE_TEST_MAX_DEPTH:
        print "ERROR: simple test recursion guard triggered (SIMPLE_TEST_DEPTH={depth_str})"
        print "  Nested `bin/simple test` invocations are not allowed."
        print "  A spec or script is calling `bin/simple test` from inside a test run."
        return 1
    env_set("SIMPLE_TEST_DEPTH", (depth + 1).to_text())

    val all_args = cli_get_args()
    val arg_count = all_args.len()

    # Strip script path and "test" command from args
    # cli_get_args() returns: [program, "test", ...test_args...]
    var test_args = []
    var gc_log = false
    var gc_off = false
    var i = 0

    # Skip script path (first arg)
    if arg_count > 0:
        i = 1

    # Skip "test" command if present
    if i < arg_count and all_args[i] == "test":
        i = i + 1

    # Parse remaining args, extracting global flags
    while i < arg_count:
        val arg = all_args[i]
        if arg == "--gc-log":
            gc_log = true
        elif arg == "--gc-off" or arg == "--gc=off":
            gc_off = true
        elif arg.starts_with("--max-recursion-depth="):
            val depth = parse_test_entry_nonnegative_or_default(arg[21:], 0)
            rt_fault_set_max_recursion_depth(depth)
            rt_fault_set_stack_overflow_detection(true)
        elif arg.starts_with("--timeout="):
            val secs = parse_test_entry_nonnegative_or_default(arg[10:], 0)
            rt_fault_set_timeout(secs)
        elif arg.starts_with("--execution-limit="):
            val limit = parse_test_entry_nonnegative_or_default(arg[18:], 0)
            rt_fault_set_execution_limit(limit)
        elif arg == "--stack-overflow-detection":
            rt_fault_set_stack_overflow_detection(true)
        else:
            test_args.push(arg)
        i = i + 1

    cli_run_tests(test_args, gc_log, gc_off)
