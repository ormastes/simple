#![allow(unnamed_duplicate_typed_args)]
# Database Sanity Check Command
#
# Loads all SDN databases and runs validation checks.
# Reports issues by severity (error, warning, info).
#
# Usage:
#   simple check-dbs                  Check all databases
#   simple check-dbs bugs             Check specific DB
#   simple check-dbs bugs features    Check multiple
#   simple check-dbs --json           JSON output
#   simple check-dbs --strict         Exit 1 on warnings too

use std.database.bug.{load_bug_database}
use std.database.test.{load_test_database}
use std.database.feature.{load_feature_database}
use std.database.todo.{load_todo_database}
use std.database.task.{load_task_database}
use std.database.checker.{DbIssue, count_by_severity, format_issue}

extern fn rt_file_exists(path: text) -> bool
fn file_exists(path: text) -> bool:
    rt_file_exists(path)

# ============================================================================
# Database path + unified check
# ============================================================================

fn db_path(db_type: text) -> text: "data/db/{db_type}_db.sdn"

fn check_db(db_type: text) -> [DbIssue]:
    val path = db_path(db_type)
    if not file_exists(path):
        return [DbIssue(db_name: db_type, severity: "error", issue_type: "file_missing",
            message: "Database file not found: {path}", auto_fixable: false)]
    match db_type:
        "bug":
            val db_opt = load_bug_database(path)
            if not db_opt.?:
                return [DbIssue(db_name: db_type, severity: "error", issue_type: "parse_error",
                    message: "Failed to parse {db_type} database: {path}", auto_fixable: false)]
            db_opt.unwrap().validate()
        "test":
            val db_opt = load_test_database(path)
            if not db_opt.?:
                return [DbIssue(db_name: db_type, severity: "error", issue_type: "parse_error",
                    message: "Failed to parse {db_type} database: {path}", auto_fixable: false)]
            db_opt.unwrap().validate()
        "feature":
            val db_opt = load_feature_database(path)
            if not db_opt.?:
                return [DbIssue(db_name: db_type, severity: "error", issue_type: "parse_error",
                    message: "Failed to parse {db_type} database: {path}", auto_fixable: false)]
            db_opt.unwrap().validate()
        "todo":
            val db_opt = load_todo_database(path)
            if not db_opt.?:
                return [DbIssue(db_name: db_type, severity: "error", issue_type: "parse_error",
                    message: "Failed to parse {db_type} database: {path}", auto_fixable: false)]
            db_opt.unwrap().validate()
        "task":
            val db_opt = load_task_database(path)
            if not db_opt.?:
                return [DbIssue(db_name: db_type, severity: "error", issue_type: "parse_error",
                    message: "Failed to parse {db_type} database: {path}", auto_fixable: false)]
            db_opt.unwrap().validate()
        _:
            [DbIssue(db_name: db_type, severity: "error", issue_type: "unknown_db",
                message: "Unknown database type: {db_type}", auto_fixable: false)]

# ============================================================================
# Output formatting
# ============================================================================

fn severity_icon(severity: text) -> text:
    match severity:
        "error": "ERROR"
        "warning": "WARNING"
        "info": "INFO"
        _: severity

fn print_db_section(db_name: text, path: text, issues: [DbIssue]):
    val errors = count_by_severity(issues, "error")
    val warnings = count_by_severity(issues, "warning")
    val infos = count_by_severity(issues, "info")

    print "[{db_name}] {path}"
    if errors == 0 and warnings == 0:
        print "  OK"
    for issue in issues:
        print "  {severity_icon(issue.severity)}: {issue.message}"
        if issue.auto_fixable:
            print "    (auto-fixable with: simple fix-dbs {db_name})"
    print ""

fn print_json_output(all_issues: [DbIssue]):
    print "["
    var first = true
    for issue in all_issues:
        val comma = if first: "" else: ","
        first = false
        val fixable_str = if issue.auto_fixable: "true" else: "false"
        print "{comma}  \{\"db\": \"{issue.db_name}\", \"severity\": \"{issue.severity}\", \"type\": \"{issue.issue_type}\", \"message\": \"{issue.message}\", \"auto_fixable\": {fixable_str}\}"
    print "]"

# ============================================================================
# Main entry point
# ============================================================================

fn run_check_dbs(args: [text]) -> i64:
    var json_mode = false
    var strict_mode = false
    var db_filters: [text] = []

    for arg in args:
        if arg == "--json":
            json_mode = true
        elif arg == "--strict":
            strict_mode = true
        elif not arg.starts_with("--"):
            db_filters.push(arg)

    val check_all = db_filters.len() == 0

    # All known DB types (singular)
    val all_db_types: [text] = ["bug", "test", "feature", "todo", "task"]

    # Determine which DBs to check (accept singular or plural form)
    var active_dbs: [text] = []
    for db_type in all_db_types:
        val plural = "{db_type}s"
        if check_all or db_filters.contains(db_type) or db_filters.contains(plural):
            active_dbs.push(db_type)

    var all_issues: [DbIssue] = []

    # Run checks
    for db_type in active_dbs:
        val issues = check_db(db_type)
        for issue in issues:
            all_issues.push(issue)

    # Output
    if json_mode:
        print_json_output(all_issues)
    else:
        print "Database Sanity Check"
        print "====================="
        print ""

        for db_type in active_dbs:
            val db_issues = all_issues.filter(\i: i.db_name == db_type)
            print_db_section("{db_type}s", db_path(db_type), db_issues)

        # Summary
        val total_errors = count_by_severity(all_issues, "error")
        val total_warnings = count_by_severity(all_issues, "warning")
        val total_infos = count_by_severity(all_issues, "info")
        val db_count = active_dbs.len()

        if total_errors == 0 and total_warnings == 0:
            print "Summary: All clean across {db_count} database(s)"
        else:
            print "Summary: {total_errors} error(s), {total_warnings} warning(s), {total_infos} info(s) across {db_count} database(s)"

    # Exit code
    val errors = count_by_severity(all_issues, "error")
    val warnings = count_by_severity(all_issues, "warning")
    if errors > 0:
        return 1
    if strict_mode and warnings > 0:
        return 1
    0

# ============================================================================
# Exports
# ============================================================================

