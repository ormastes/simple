# Simple Language - Unified CLI (Written in Simple)
#
# This is the main entry point for the Simple CLI, written in Simple itself.
# Most functionality is implemented in Simple; SFFI is only used for runtime operations.
#
# Usage like Python:
#   simple              - Start interactive REPL
#   simple file.spl     - Run source file
#   simple file.smf     - Run compiled binary
#   simple -c "code"    - Run code string

# Workaround: native codegen string == is broken (length-only comparison)
fn str_eq(a: text, b: text) -> bool:
    a.len() == b.len() and a.starts_with(b)

fn apply_jit_env_vars(flags: GlobalFlags):
    if flags.no_jit:
        env_set("SIMPLE_NO_JIT", "1")
    if flags.jit_threshold != 10:
        val t = "{flags.jit_threshold}"
        env_set("SIMPLE_JIT_THRESHOLD", t)
    if not str_eq(flags.backend, "auto"):
        env_set("SIMPLE_JIT_BACKEND", flags.backend)

fn run_native_build_bootstrap(args: [text]) -> i64:
    _cli_eprint("Error: native-build requires --backend=llvm-lib|llvm|cranelift in the pure Simple command path")
    _cli_eprint("The Rust seed is bootstrap-only; legacy CLI native-build fallback is disabled.")
    return 1

fn native_build_backend_supported(backend: text) -> bool:
    str_eq(backend, "llvm-lib") or str_eq(backend, "llvmlib") or str_eq(backend, "llvm") or str_eq(backend, "cranelift")

fn native_build_requests_simple_llvm(args: [text]) -> bool:
    var saw_backend = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if str_eq(arg, "--backend"):
            saw_backend = true
            if i + 1 < args.len():
                return native_build_backend_supported(args[i + 1])
            return false
        elif arg.starts_with("--backend="):
            saw_backend = true
            val backend = arg.substring(10)
            return native_build_backend_supported(backend)
        i = i + 1
    not saw_backend

fn cli_log_options_help():
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn cli_print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_cli_help()
    cli_log_options_help()

fn cli_is_log_option(arg: text) -> bool:
    str_eq(arg, "--human") or str_eq(arg, "--llm") or str_eq(arg, "--json") or
        str_eq(arg, "--tui") or str_eq(arg, "--stdout") or str_eq(arg, "--quiet") or
        str_eq(arg, "--verbose") or str_eq(arg, "--dots") or str_eq(arg, "--count") or
        str_eq(arg, "--no-progress") or str_eq(arg, "--log-mode") or str_eq(arg, "--surface") or
        str_eq(arg, "--progress") or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn cli_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if cli_is_log_option(arg):
            if str_eq(arg, "--log-mode") or str_eq(arg, "--surface") or str_eq(arg, "--progress"):
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn filter_internal_flags(args: [text]) -> [text]:
    var result = []
    var skip_next = false
    for arg in args:
        if skip_next:
            skip_next = false
        elif str_eq(arg, "--max-recursion-depth") or str_eq(arg, "--timeout") or str_eq(arg, "--execution-limit") or str_eq(arg, "--interpreter-mode") or str_eq(arg, "--run-config") or str_eq(arg, "--jit-threshold"):
            skip_next = true
        elif not arg.starts_with("--gc") and not str_eq(arg, "--notui") and not str_eq(arg, "--lang") and not str_eq(arg, "--stack-overflow-detection") and not str_eq(arg, "--no-stack-overflow-detection") and not str_eq(arg, "--interpret") and not str_eq(arg, "--interpret-optimized") and not str_eq(arg, "--no-jit") and not str_eq(arg, "--fixed-be"):
            if not arg.starts_with("--lang=") and not arg.starts_with("--max-recursion-depth=") and not arg.starts_with("--timeout=") and not arg.starts_with("--execution-limit=") and not arg.starts_with("--interpreter-mode") and not arg.starts_with("--run-config") and not arg.starts_with("--jit-threshold=") and not arg.starts_with("--fixed-be="):
                # Keep --backend flags (used by both JIT and compile commands)
                result.push(arg)
    result

fn _cli_args_from(args: [text], start_idx: i64) -> [text]:
    var tail: [text] = []
    var i = start_idx
    while i < args.len():
        tail.push(args[i])
        i = i + 1
    tail


fn main() -> i64:
    val raw_args = get_cli_args()

    # UI and play own these option names (`--surface`, `--count`, `--timeout`,
    # and `--json`). Delegate before global log/runtime filtering can consume
    # them. The later branches retain compatibility with global flags that
    # precede the command name.
    if raw_args.len() > 0 and str_eq(raw_args[0], "ui"):
        return run_ui_cli_entry()
    if raw_args.len() > 0 and str_eq(raw_args[0], "play"):
        return play_cli_main(_cli_args_from(raw_args, 1))
    if raw_args.len() > 0 and str_eq(raw_args[0], "t32"):
        return t32_cli_main(_cli_args_from(raw_args, 1))

    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        print "ERROR: {log_opts.error}"
        return 1

    val args = cli_clean_log_args(raw_args)

    if args.len() == 0:
        if str_eq(log_opts.log_mode, "json"):
            val v = get_version()
            print "{\"command\":\"cli\",\"status\":\"ready\",\"tool\":\"Simple Language CLI\",\"version\":\"{v}\"}"
            return 0
        if raw_args.len() > 0 and not str_eq(log_opts.progress, "none"):
            val progress = render_progress(log_opts.progress, 1, 1, "cli")
            if progress != "":
                print progress
            return 0
        if check_self_contained():
            return 0

    val flags = parse_global_flags(args)
    apply_fault_detection(flags)

    # native-build: pass raw args directly (bypass filter_internal_flags)
    if args.len() > 0 and str_eq(args[0], "native-build"):
        if native_build_requests_simple_llvm(args):
            return cli_native_build(args)
        return run_native_build_bootstrap(args)

    apply_jit_env_vars(flags)

    val filtered_args = filter_internal_flags(args)

    if filtered_args.len() == 0:
        return cli_run_repl(flags.gc_log, flags.gc_off)

    val first = filtered_args[0]

    if str_eq(first, "-h") or str_eq(first, "--help"):
        cli_print_help_with_progress(log_opts.progress)
        return 0
    elif str_eq(first, "-v") or str_eq(first, "--version"):
        if str_eq(log_opts.log_mode, "json"):
            val v = get_version()
            print "{\"command\":\"cli\",\"status\":\"ok\",\"version\":\"{v}\"}"
            return 0
        print_version()
        return 0
    elif str_eq(first, "-c"):
        if filtered_args.len() < 2:
            print_error("-c requires a code argument")
            return 1
        return cli_run_code(filtered_args[1], flags.gc_log, flags.gc_off)
    elif str_eq(first, "compile"):
        return cli_compile(filtered_args)
    elif str_eq(first, "targets"):
        print_targets()
        return 0
    elif str_eq(first, "linkers"):
        print_linkers()
        return 0
    elif str_eq(first, "web"):
        return cli_handle_web(filtered_args)
    elif str_eq(first, "watch"):
        if filtered_args.len() >= 2 and str_eq(filtered_args[1], "--daemon"):
            val daemon_args = if filtered_args.len() > 2: _cli_args_from(filtered_args, 2) else: ["start"]
            return cli_watch_daemon(daemon_args)
        val watch_args = _cli_args_from(filtered_args, 1)
        return cli_run_file("src/app/watch/main.spl", watch_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "test"):
        # Recursion guard: refuse nested `bin/simple test` invocations.
        # test_entry.spl applies the same guard for the lightweight path;
        # this site covers the standard `bin/simple test` dispatch path.
        val _depth_str = env_get("SIMPLE_TEST_DEPTH")
        val _depth = if _depth_str == "" or _depth_str == nil: 0 else: _depth_str.to_int() ?? 0
        if _depth >= 1:
            print "ERROR: simple test recursion guard triggered (SIMPLE_TEST_DEPTH={_depth_str})"
            print "  Nested `bin/simple test` invocations are not allowed."
            print "  A spec or script is calling `bin/simple test` from inside a test run."
            return 1
        env_set("SIMPLE_TEST_DEPTH", "{_depth + 1}")
        return pure_test_runner_main()
    elif str_eq(first, "test-daemon"):
        return cli_test_daemon(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "watch-daemon"):
        return cli_watch_daemon(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "lex"):
        if filtered_args.len() < 2:
            print_error("lex requires a source file")
            return 1
        return run_lex_command(filtered_args[1])
    elif str_eq(first, "lint"):
        # Delegation restored 2026-07-11: the 15:09 stage-4 matrix FAILED
        # (native check silent exit-3, run/-c print loss) — retire again only
        # after a deployed binary passes the native-path matrix. See
        # doc/08_tracking/bug/stage4_compiled_dict_no_growth_2026-07-11.md.
        val lint_delegate = _cli_frontend_delegate_binary()
        if lint_delegate != "":
            return _cli_run_frontend_delegate(lint_delegate, filtered_args)
        return cli_run_lint(filtered_args)
    elif str_eq(first, "duplicate-check"):
        return cli_run_file("src/compiler/90.tools/duplicate_check/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "fix"):
        return cli_run_fix(filtered_args)
    elif str_eq(first, "fmt"):
        return cli_run_fmt(filtered_args)
    elif str_eq(first, "check"):
        val check_args = _cli_args_from(filtered_args, 1)
        # Delegation restored 2026-07-11 (same matrix failure as lint above).
        val check_delegate = _cli_frontend_delegate_binary()
        if check_delegate != "":
            return _cli_run_frontend_delegate(check_delegate, filtered_args)
        return run_check(check_args)
    elif str_eq(first, "doc-coverage"):
        return run_doc_coverage(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "check-arch"):
        val arch_args = _cli_args_from(filtered_args, 1)
        return run_arch_check(arch_args)
    elif str_eq(first, "check-dbs"):
        val check_db_args = _cli_args_from(filtered_args, 1)
        return run_check_dbs(check_db_args)
    elif str_eq(first, "fix-dbs"):
        val fix_db_args = _cli_args_from(filtered_args, 1)
        return run_fix_dbs(fix_db_args)
    elif str_eq(first, "grammar-doc"):
        val grammar_args = _cli_args_from(filtered_args, 1)
        return cli_run_file("src/app/grammar_doc/mod.spl", grammar_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "i18n"):
        return cli_run_i18n(filtered_args)
    elif str_eq(first, "migrate"):
        return cli_run_migrate(filtered_args)
    elif str_eq(first, "mcp"):
        return cli_run_mcp(filtered_args)
    elif str_eq(first, "lsp"):
        return cli_run_lsp(filtered_args)
    elif str_eq(first, "dap"):
        return cli_run_file("src/lib/nogc_sync_mut/dap/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "diff"):
        return cli_run_diff(filtered_args)
    elif str_eq(first, "constr"):
        return cli_constr(filtered_args)
    elif str_eq(first, "query"):
        return cli_run_query(filtered_args)
    elif str_eq(first, "info"):
        return cli_info(filtered_args)
    elif str_eq(first, "spec-coverage"):
        return cli_run_spec_coverage(filtered_args)
    elif str_eq(first, "traceability-check"):
        return cli_run_file("src/app/traceability/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "tracking"):
        return cli_run_file("src/app/tracking/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "replay"):
        return cli_replay(filtered_args)
    elif str_eq(first, "gen-lean"):
        return cli_gen_lean(filtered_args)
    elif str_eq(first, "feature-gen"):
        return cli_run_feature_gen(filtered_args)
    elif str_eq(first, "task-gen"):
        return cli_run_task_gen(filtered_args)
    elif str_eq(first, "spec-gen"):
        return cli_run_spec_gen(filtered_args)
    elif str_eq(first, "spipe-docgen"):
        return cli_run_spipe_docgen(filtered_args)
    elif str_eq(first, "feature-doc"):
        return cli_run_feature_doc(filtered_args)
    elif str_eq(first, "todo-scan"):
        return cli_todo_scan(filtered_args)
    elif str_eq(first, "deps"):
        return cli_run_file("src/app/deps/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "todo-gen"):
        return cli_run_todo_gen(filtered_args)
    elif str_eq(first, "bug-add"):
        return cli_run_file("src/app/bug_add/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "bug-gen"):
        return cli_run_file("src/app/bug_gen/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "bug-resolve"):
        return cli_run_file("src/app/bug_resolve/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "brief"):
        return cli_run_brief(filtered_args)
    elif str_eq(first, "stats"):
        run_stats(_cli_args_from(filtered_args, 1))
        return 0
    elif str_eq(first, "ffi-gen"):
        return cli_run_sffi_gen(filtered_args)
    elif str_eq(first, "wrapper-gen"):
        return cli_run_file("src/app/wrapper_gen/mod.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "launch-meta"):
        return cli_run_file("src/app/startup/launch_meta_check.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "plugin"):
        return cli_run_file("src/app/plugin/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "desugar"):
        return cli_run_file("src/app/desugar/mod.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "dashboard"):
        return run_dashboard(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "agents"):
        return run_llm_dashboard(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "llm-runtime-control"):
        return cli_run_file("src/app/llm_runtime/control_cli.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "ios"):
        val ios_tail = _cli_args_from(filtered_args, 1)
        var ios_args: [text] = ["--ios"]
        var j = 0
        while j < ios_tail.len():
            val ios_arg = ios_tail[j]
            if not str_eq(ios_arg, "dashboard"):
                ios_args.push(ios_arg)
            j = j + 1
        return run_llm_dashboard(ios_args)
    elif str_eq(first, "office"):
        val office_args = _cli_args_from(filtered_args, 1)
        return cli_run_file("src/app/office/mod.spl", office_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "verify"):
        return cli_run_verify(filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "md-diagram-update"):
        return cli_run_file("src/app/md_diagram_update/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "diagram"):
        return cli_handle_diagram(filtered_args)
    elif str_eq(first, "build"):
        val build_args = _cli_args_from(filtered_args, 1)
        return handle_build(build_args)
    elif str_eq(first, "init"):
        return handle_init(filtered_args)
    elif str_eq(first, "add"):
        return cli_run_file("src/app/add/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "remove"):
        return cli_run_file("src/app/remove/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "pkg"):
        return cli_run_file("src/app/pkg/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "snpm"):
        return cli_run_file("src/app/snpm/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "install"):
        return cli_run_file("src/app/install/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "publish"):
        return cli_run_file("src/app/publish/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "release"):
        return cli_run_file("src/app/release/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "update"):
        return cli_run_file("src/app/update/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "list"):
        return cli_run_file("src/app/list/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "tree"):
        return cli_run_file("src/app/tree/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "cache"):
        return cli_run_file("src/app/cache/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "scv"):
        return cli_run_file("src/app/scv/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "env"):
        return cli_run_file("src/app/env/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "lock"):
        return cli_run_file("src/app/lock/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "run"):
        return cli_handle_run(_cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "os"):
        val os_args = _cli_args_from(filtered_args, 1)
        return handle_os(os_args)
    elif str_eq(first, "sim"):
        return cli_run_file("src/app/sim/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "play"):
        return play_cli_main(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "ui"):
        return run_ui_cli_entry()
    elif str_eq(first, "t32"):
        return t32_cli_main(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "log"):
        return cli_run_file("src/app/log/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "task-daemon"):
        return cli_run_file("src/app/task_daemon/main.spl", _cli_args_from(filtered_args, 1), flags.gc_log, flags.gc_off)
    elif str_eq(first, "leak-check"):
        return run_leak_check()
    elif str_eq(first, "js"):
        return cli_run_file("src/app/js/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif str_eq(first, "jj"):
        val jj_args = _cli_args_from(filtered_args, 1)
        return handle_jj(jj_args)
    elif str_eq(first, "itf"):
        val itf_args = _cli_args_from(filtered_args, 1)
        return handle_itf(itf_args)
    elif str_eq(first, "debug-ui"):
        val debug_ui_args = _cli_args_from(filtered_args, 1)
        return cli_debug_ui(debug_ui_args)
    elif str_eq(first, "browser"):
        return cli_browser(_cli_args_from(filtered_args, 1))
    elif str_eq(first, "theme-sync"):
        val theme_sync_args = _cli_args_from(filtered_args, 1)
        return cli_theme_sync(theme_sync_args)
    elif str_eq(first, "optimize"):
        return cli_run_file("src/app/optimize/main.spl", filtered_args, flags.gc_log, flags.gc_off)
    elif cli_file_exists(first):
        var program_args = [first]
        var j = 1
        while j < filtered_args.len():
            program_args.push(filtered_args[j])
            j = j + 1
        return cli_run_file(first, program_args, flags.gc_log, flags.gc_off)
    else:
        print_error_with_help("file not found: {first}")
        return 1
