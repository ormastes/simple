# Fail-closed option preflight for both `simple check` entry paths.

fn check_option_value_error(option: text, value: text) -> text:
    if value == "" or value.starts_with("-"):
        return "{option} requires a value"
    if option == "--log-mode" and value != "human" and value != "llm" and value != "json":
        return "invalid --log-mode: {value}"
    if option == "--surface" and value != "stdout" and value != "tui":
        return "invalid --surface: {value}"
    if option == "--progress" and value != "summary" and value != "count" and value != "dot" and value != "none":
        return "invalid --progress: {value}"
    ""

pub fn check_option_error(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "check" or arg == "-h" or arg == "--help" or arg == "--human" or arg == "--llm" or arg == "--json" or arg == "--tui" or arg == "--stdout" or arg == "--quiet" or arg == "--verbose" or arg == "--dots" or arg == "--count" or arg == "--no-progress":
            i = i + 1
            continue
        if arg == "--surface":
            return "invalid --surface: use --surface=<stdout|tui>"
        if arg == "--log-mode" or arg == "--progress":
            if i + 1 >= args.len():
                return "{arg} requires a value"
            val value_error = check_option_value_error(arg, args[i + 1])
            if value_error != "":
                return value_error
            i = i + 2
            continue
        if arg.starts_with("--log-mode="):
            val value_error = check_option_value_error("--log-mode", arg.slice(11, arg.len()))
            if value_error != "":
                return value_error
            i = i + 1
            continue
        if arg.starts_with("--surface="):
            val value_error = check_option_value_error("--surface", arg.slice(10, arg.len()))
            if value_error != "":
                return value_error
            i = i + 1
            continue
        if arg.starts_with("--progress="):
            val value_error = check_option_value_error("--progress", arg.slice(11, arg.len()))
            if value_error != "":
                return value_error
            i = i + 1
            continue
        if arg.starts_with("-"):
            return "unknown option: {arg}"
        i = i + 1
    ""

pub fn check_presentation_args(args: [text]) -> [text]:
    var result: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--human" or arg == "--llm" or arg == "--json" or arg == "--tui" or arg == "--stdout" or arg == "--quiet" or arg == "--verbose" or arg == "--dots" or arg == "--count" or arg == "--no-progress":
            result.push(arg)
        elif arg == "--log-mode" or arg == "--progress":
            if i + 1 < args.len() and check_option_value_error(arg, args[i + 1]) == "":
                result.push(arg)
                result.push(args[i + 1])
                i = i + 1
        elif arg.starts_with("--log-mode=") or arg.starts_with("--surface=") or arg.starts_with("--progress="):
            result.push(arg)
        i = i + 1
    result

pub fn check_cli_handoff_args(filtered_args: [text], raw_args: [text]) -> [text]:
    var result: [text] = []
    for arg in filtered_args:
        result.push(arg)
    for arg in check_presentation_args(raw_args):
        result.push(arg)
    result

pub fn check_worker_args(args: [text], file: text) -> [text]:
    var result = [file]
    for arg in check_presentation_args(args):
        result.push(arg)
    result
