# Re-exported from table.spl
export get_command_table, get_all_commands

# Re-exported from types.spl
export CommandEntry

fn find_command(cmd: text) -> CommandEntry?:
    val table = get_command_table()
    for entry in table:
        if entry.name == cmd:
            return Some(entry)
    nil

fn command_count() -> i64:
    get_command_table().len()

fn simple_impl_count() -> i64:
    var count = 0
    for entry in get_command_table():
        if entry.has_simple_impl():
            count = count + 1
    count

fn coverage_percentage() -> f64:
    val total = command_count() as f64
    val simple = simple_impl_count() as f64
    if total > 0.0:
        return (simple / total) * 100.0
    0.0

export find_command
export command_count, simple_impl_count, coverage_percentage
