# Browser CLI — in-process dispatcher for `bin/simple browser ...`.
#
# Mirrors the logic of `src/app/ui.browser/main.spl:main()` but runs as a
# native Simple function inside the deployed CLI binary instead of being
# shelled out via `cli_run_file` / `interpret_file`. The latter path is
# currently broken in the self-hosted binary (the recursive interpreter
# returns a value that falls through to the catch-all case in
# `cli_run_file`, printing `Error running <path>`).
#
# This handler imports `BrowserApp` and friends directly so the
# browser subcommand compiles into the main binary alongside every
# other dispatched command (`theme-sync`, `debug-ui`, ...).

use app.ui.browser.app.{BrowserApp, run_browser_gui, parse_backend_flag}

extern fn rt_mkdir_p(path: text) -> bool

# =========================================================================
# Argument parsing helpers
# =========================================================================

fn _browser_parse_snapshot_flag(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if a == "--snapshot" and i + 1 < args.len():
            return args[i + 1]
        elif a.starts_with("--snapshot="):
            return a[11:]
        i = i + 1
    ""

fn _browser_parse_open_flag(args: [text]) -> bool:
    for a in args:
        if a == "--open":
            return true
    false

fn _browser_first_positional(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if not a.starts_with("--"):
            return a
        i = i + 1
    ""

fn _browser_ensure_parent_dir(path: text):
    # Ensure the directory portion of `path` exists (best-effort).
    var slash = -1
    var i = 0
    while i < path.len():
        if path[i] == "/":
            slash = i
        i = i + 1
    if slash > 0:
        val dir = path[0:slash]
        rt_mkdir_p(dir)

# =========================================================================
# Entry point — called from src/app/cli/main.spl `case "browser":`
# =========================================================================

fn cli_browser(args: [text]) -> i64:
    val file_path = _browser_first_positional(args)
    if file_path == "":
        print "Usage: simple browser <file.ui.sdn> [--snapshot=<out.ppm>] [--open]"
        return 1

    val open_flag = _browser_parse_open_flag(args)
    if open_flag:
        return run_browser_gui(file_path, 0)

    var snapshot_path = _browser_parse_snapshot_flag(args)
    if snapshot_path == "":
        rt_mkdir_p(".build/ui_browser")
        snapshot_path = ".build/ui_browser/snapshot.ppm"
    else:
        _browser_ensure_parent_dir(snapshot_path)

    val gpu_backend = parse_backend_flag()
    val app_result = BrowserApp.new(file_path, 0, gpu_backend)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            return app.run_once(snapshot_path)

export cli_browser
