extern fn sys_get_args() -> [text]
extern fn rt_native_build(args: [text]) -> i64

# Non-lazy AND direct-from-defining-module: `use lazy` deferred the driver to
# a dynload lib that was never implemented (#99), linking as undefined
# compiler_driver_create/run_compile. And native-build closure discovery
# follows plain `use` recursively but does NOT follow `export use`, so the
# compiler.driver __init__ re-export shim was a dead end (4-file closure).
# Importing driver.spl directly lets discovery pull the driver and its
# transitive imports statically. (2026-07-13 redeploy)
use compiler.driver.driver.{compiler_driver_create, compiler_driver_run_compile}
use compiler.driver.bootstrap_api.{aot_native_project_with_backend_fixed}
use compiler.common.driver_core_types (CompileMode, CompileResult, driver_core_compile_options_default, compileoptions_normalize_mir_optimization, driver_output_format_native, driver_output_format_smf, compile_result_is_success, compile_result_errors)
use std.nogc_sync_mut.io_runtime.{env_get, env_set, file_exists, file_size, remove_file_if_exists}

# Keep in sync with ./VERSION file
fn bootstrap_version() -> text:
    "1.0.0-beta"

fn native_build_help() -> i64:
    0

fn bootstrap_output_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "a.out"
    elif args[i].starts_with("-o") and args[i].len() == 2 and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("-o") and args[i].len() > 2:
        args[i].substring(2)
    elif args[i].starts_with("--output") and args[i].len() == 8 and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--output="):
        args[i].substring(9)
    else:
        bootstrap_output_from_args(args, i + 1)

# ponytail: native codegen currently emits an invalid `bitcast i64 to i1`
# when a `bool`-returning function merges more than one branch (each arm
# stores into a shared i64 slot, then the final load is bitcast to i1
# instead of truncated/compared) -- see filed bug. Returning `i64` (1/0)
# instead of `bool` sidesteps that miscompile without touching the shared
# backend; callers compare against `1`.
fn native_build_flag_needs_value(flag: text) -> i64:
    if flag == "-o":
        1
    elif flag == "--output":
        1
    elif flag == "--source":
        1
    elif flag == "--entry":
        1
    elif flag == "--threads":
        1
    elif flag == "--timeout":
        1
    elif flag == "--cache-dir":
        1
    elif flag == "--backend":
        1
    elif flag == "--runtime-bundle":
        1
    elif flag == "--runtime-path":
        1
    elif flag == "--mode":
        1
    elif flag == "--target":
        1
    elif flag == "--linker-script":
        1
    elif flag == "--log":
        1
    else:
        0

fn native_build_entry_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        ""
    elif args[i] == "--entry" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--entry="):
        args[i].substring(8)
    else:
        native_build_entry_from_args(args, i + 1)

fn native_build_has_entry_closure(args: [text]) -> i64:
    for arg in args:
        if arg == "--entry-closure":
            return 1
    0

fn run_rt_native_build(args: [text]) -> i64:
    val has_entry_closure = native_build_has_entry_closure(args)
    val old_entry_closure = env_get("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE")
    if has_entry_closure == 1:
        env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", "1")
    val result = rt_native_build(args)
    if has_entry_closure == 1:
        env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", old_entry_closure)
    result

# rt_native_build's Rust arg parser (src/compiler_rust/native_all/src/lib.rs)
# treats any bare positional that isn't consumed by a value-taking flag as a
# `source_dir` to scan, and silently falls back to compiling
# `src/app/cli/main.spl` as the entry when no `--entry` was given. That means
# `bm native-build some_file.spl` never compiles `some_file.spl` -- it scans
# for it as a directory (a no-op, since it's a file) and then compiles the
# unrelated default entry instead. Detect the "single .spl file positional,
# no explicit --entry" shape here and forward an explicit `--entry <path>`
# (plus `--entry-closure` so the build only walks the entry's reachable
# closure instead of falling through to a full-project scan).
fn native_build_single_spl_positional(args: [text]) -> text:
    var i = 0
    var result = ""
    var count = 0
    var scanning = 0
    var has_source_input = 0
    while i < args.len():
        val arg = args[i]
        if arg == "native-build":
            scanning = 1
            i = i + 1
        elif scanning == 0:
            i = i + 1
        elif arg == "--source":
            has_source_input = 1
            i = i + 2
        elif arg.starts_with("--source="):
            has_source_input = 1
            i = i + 1
        elif native_build_flag_needs_value(arg) == 1:
            i = i + 2
        elif arg.starts_with("-"):
            i = i + 1
        elif arg.ends_with(".spl"):
            result = arg
            count = count + 1
            i = i + 1
        else:
            has_source_input = 1
            i = i + 1
    if count == 1 and has_source_input == 0:
        result
    else:
        ""

fn native_build_backend_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "llvm"
    elif args[i] == "--backend" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--backend="):
        args[i].substring(10)
    else:
        native_build_backend_from_args(args, i + 1)

fn native_build_mode_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        ""
    elif args[i] == "--mode" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--mode="):
        args[i].substring(7)
    else:
        native_build_mode_from_args(args, i + 1)

# S80: `--threads N` was parsed by native_build_flag_needs_value (so the arg
# scanner knows to skip its value token) but never read into a value anywhere
# in this file -- the Stage4 in-process branch below called
# aot_native_project_with_backend_fixed without ever setting
# SIMPLE_NATIVE_BUILD_THREADS, so driver_native_build_threads()
# (driver_aot_output.spl) always saw "" and fell back to auto-detected CPU
# count. The production bootstrap-from-scratch.sh wrapper happens to also
# export SIMPLE_NATIVE_BUILD_THREADS itself, masking this for that one
# caller, but any direct `simple native-build --entry ... --threads N`
# invocation (e.g. this lane's A/B probe, or a developer running the command
# by hand) silently dropped the requested value. Mirrors the existing
# native_threads parse in src/app/io/_CliCompile/compile_targets.spl:667-685.
fn native_build_threads_from_args(args: [text], i: i64) -> i64:
    if i >= args.len():
        0
    elif args[i] == "--threads" and i + 1 < args.len():
        args[i + 1].to_i64() ?? 0
    elif args[i].starts_with("--threads="):
        args[i].substring(10).to_i64() ?? 0
    else:
        native_build_threads_from_args(args, i + 1)

# #138/#19: the authorized Stage4 explicit entry and the single-file positional
# shape (no --source dirs -- i.e. `bm native-build foo.spl -o out`) compile
# THROUGH THE PURE-SIMPLE IN-PROCESS PIPELINE instead of the Rust
# rt_native_build FFI seed. The in-process failure surfaces loudly; it never
# silently retries the seed.
fn run_native_build_bootstrap(args: [text]) -> i64:
    val mode = native_build_mode_from_args(args, 0)
    if mode != "" and mode != "dynload" and mode != "one-binary":
        print "Error: invalid --mode '{mode}' (expected dynload or one-binary)"
        return 1
    val explicit_entry = native_build_entry_from_args(args, 0)
    if explicit_entry != "":
        if env_get("SIMPLE_BOOTSTRAP_STAGE4") != "1":
            return run_rt_native_build(args)
        if explicit_entry != "src/app/cli/main.spl":
            print "Error: Stage4 entry must be src/app/cli/main.spl"
            return 1
        if mode != "one-binary":
            print "Error: Stage4 full CLI requires --mode one-binary"
            return 1
        val stage4_output = bootstrap_output_from_args(args, 0)
        val stage4_backend = native_build_backend_from_args(args, 0)
        env_set("SIMPLE_NATIVE_BUILD_ENTRY", explicit_entry)
        # Seed only the entry. The driver resolves its transitive imports and
        # then enables closure mode; pre-enabling it while passing whole source
        # roots made Stage 4 parse every file before it could prune anything.
        env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", "0")
        val old_native_arena_decls = env_get("SIMPLE_NATIVE_ARENA_DECLS")
        env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")
        # S80: forward the requested --threads value so the AOT codegen
        # phase's ParallelBuildConfig (driver_aot_output.spl:driver_native_build_threads,
        # read from this same env var) sees it instead of silently falling
        # back to auto-detected CPU count. See native_build_threads_from_args
        # above for why this was previously discarded.
        val requested_threads = native_build_threads_from_args(args, 0)
        val old_native_threads = env_get("SIMPLE_NATIVE_BUILD_THREADS")
        if env_get("SIMPLE_COMPILER_TRACE") == "1":
            print "[S80-THREADS] requested_threads={requested_threads} old_env={old_native_threads}"
        if requested_threads > 0:
            env_set("SIMPLE_NATIVE_BUILD_THREADS", "{requested_threads}")
        val stage4_result = aot_native_project_with_backend_fixed(
            "", "", "", "", "", 0,
            explicit_entry, stage4_output, stage4_backend, true, true, 3
        )
        if requested_threads > 0:
            env_set("SIMPLE_NATIVE_BUILD_THREADS", old_native_threads)
        env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena_decls)
        if compile_result_is_success(stage4_result):
            return 0
        for err in compile_result_errors(stage4_result):
            print "error: in-process Stage4 native-build: {err}"
        return 1
    val entry_path = native_build_single_spl_positional(args)
    if entry_path == "":
        return run_rt_native_build(args)
    val output = bootstrap_output_from_args(args, 0)
    val backend = native_build_backend_from_args(args, 0)
    # Seed both scalar and array input channels: compiled struct transport can
    # lose input_files. Leave closure discovery enabled so Driver can load the
    # entry's imports before it flips SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE to 1.
    env_set("SIMPLE_NATIVE_BUILD_ENTRY", entry_path)
    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", "0")
    # Build directly through the pure-Simple CompilerDriver (unique symbol
    # names -- avoids the `aot_native_file_with_backend` duplicate-name
    # collision between driver_public_compile [subprocess facade] and
    # driver_api_native_single [in-process]).
    var options = driver_core_compile_options_default()
    options.input_files = [entry_path]
    options.bootstrap_input_count = 1
    options.bootstrap_input_0 = entry_path
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = driver_output_format_native()
    options.backend = backend
    options.release = true
    options.opt_level = 3
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    val result = compiler_driver_run_compile(driver)
    # Free-function accessors, NOT result.is_success()/.get_errors(): this
    # entry is MIR-lowered without HIR type inference, so method calls on the
    # lazy-import-returned result never resolve (Task #145 erased-receiver
    # class); plain imported calls resolve by symbol name.
    if compile_result_is_success(result):
        0
    else:
        for err in compile_result_errors(result):
            print "error: in-process native-build: {err}"
        1

fn bootstrap_compile_option_takes_value(arg: text) -> bool:
    arg == "-o" or arg == "--output" or arg == "--backend" or arg == "--format" or arg == "--opt-level" or arg == "--target" or arg == "--cpu"

fn bootstrap_compile_source_from_args(args: [text]) -> text:
    var i = 2
    while i < args.len():
        val arg = args[i]
        if bootstrap_compile_option_takes_value(arg):
            i = i + 2
        elif arg.starts_with("-"):
            i = i + 1
        else:
            return arg
    ""

fn bootstrap_compile_output_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        ""
    elif args[i] == "-o" or args[i] == "--output":
        if i + 1 < args.len(): args[i + 1] else: ""
    elif args[i].starts_with("-o") and args[i].len() > 2:
        args[i].substring(2)
    elif args[i].starts_with("--output="):
        args[i].substring(9)
    else:
        bootstrap_compile_output_from_args(args, i + 1)

fn bootstrap_compile_backend_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "auto"
    elif args[i] == "--backend" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--backend="):
        args[i].substring(10)
    else:
        bootstrap_compile_backend_from_args(args, i + 1)

fn bootstrap_compile_requests_smf(args: [text]) -> i64:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--format=smf" or arg == "--emit-smf":
            return 1
        if arg == "--format" and i + 1 < args.len() and args[i + 1] == "smf":
            return 1
        i = i + 1
    val output = bootstrap_compile_output_from_args(args, 0)
    if output.ends_with(".smf"):
        return 1
    0

# Stage 3 is a bootstrap CLI, but its compile command must still be honest and
# useful. Route the supported SMF form through the same in-process driver used
# by single-entry native-build; never report success without running codegen.
fn run_compile_bootstrap(args: [text]) -> i64:
    val source = bootstrap_compile_source_from_args(args)
    if source == "":
        print "error: missing source file"
        return 1
    if bootstrap_compile_requests_smf(args) != 1:
        print "error: bootstrap compile supports --format=smf only"
        return 1
    var output = bootstrap_compile_output_from_args(args, 0)
    if output == "":
        output = source.replace(".spl", ".smf")
    val backend = bootstrap_compile_backend_from_args(args, 0)
    if not remove_file_if_exists(output):
        print "error: cannot replace SMF output '{output}'"
        return 1
    env_set("SIMPLE_NATIVE_BUILD_ENTRY", source)
    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", "0")
    var options = driver_core_compile_options_default()
    options.input_files = [source]
    options.bootstrap_input_count = 1
    options.bootstrap_input_0 = source
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = driver_output_format_smf()
    options.backend = backend
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    val result = compiler_driver_run_compile(driver)
    if compile_result_is_success(result):
        if not file_exists(output):
            print "error: in-process SMF compile reported success without creating '{output}'"
            return 1
        val output_bytes = file_size(output)
        if output_bytes <= 300:
            remove_file_if_exists(output)
            print "error: in-process SMF compile produced a stub artifact ({output_bytes} bytes)"
            return 1
        0
    else:
        for err in compile_result_errors(result):
            print "error: in-process SMF compile: {err}"
        1

fn get_cli_args() -> [text]:
    sys_get_args()

fn main() -> i64:
    val all_args = get_cli_args()
    val argc = all_args.len()
    if argc < 2:
        print "Simple Bootstrap Compiler v1.0.0-beta"
        print "Usage: simple compile <file> [-o <output>] [--native] [--opt-level=<level>] [--list-optimizations]"
        return 0
    val first = all_args[1]
    if first == "native-build":
        return run_native_build_bootstrap(all_args)
    if first.len() == 9 and first.starts_with("--version"):
        print "simple-bootstrap 1.0.0-beta"
        return 0
    if first.len() == 6 and first.starts_with("--help"):
        print "Simple Bootstrap Compiler v1.0.0-beta"
        print "Built from Simple source via the staged bootstrap"
        print ""
        print "Compile-related flags include:"
        print "  --opt-level=<none|basic|standard|aggressive>"
        print "  --list-optimizations"
        return 0
    if first.len() == 7 and first.starts_with("compile"):
        return run_compile_bootstrap(all_args)
    print "error: unknown command '{first}'"
    return 1
