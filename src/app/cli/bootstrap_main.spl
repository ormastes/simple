extern fn rt_get_args() -> [text]
extern fn rt_native_build(args: [text]) -> i64
use compiler.driver.driver_api.{aot_native_file_with_backend}
use compiler.driver.driver_types.{CompileResult, CompileResult__get_errors}

fn run_native_build_bootstrap(args: [text]) -> i64:
    var backend = ""
    var backend_explicit = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--backend="):
            backend = arg.substring(10)
            backend_explicit = true
        elif arg == "--backend" and i + 1 < args.len():
            i = i + 1
            backend = args[i]
            backend_explicit = true
        i = i + 1

    if backend_explicit and (backend == "llvm-lib" or backend == "llvmlib"):
        var entry_point = ""
        var output = "a.out"
        var j = 0
        while j < args.len():
            val a = args[j]
            if a == "native-build":
                pass
            elif a.starts_with("--entry="):
                entry_point = a.substring(8)
            elif a == "--entry" and j + 1 < args.len():
                j = j + 1
                entry_point = args[j]
            elif a == "-o" and j + 1 < args.len():
                j = j + 1
                output = args[j]
            elif a.starts_with("-o"):
                output = a.substring(2)
            j = j + 1

        if entry_point == "":
            print "error: missing --entry for llvm-lib native-build"
            return 1

        print "[bootstrap_main] pure-simple llvm-lib path"
        val result = aot_native_file_with_backend(entry_point, output, "llvm-lib")
        match result:
            case CompileResult.Success(_):
                return 0
            case _:
                val errors = CompileResult__get_errors(result)
                for err in errors:
                    print "error: {err}"
                return 1

    rt_native_build(args)

fn main() -> i64:
    val all_args = rt_get_args()
    val argc = all_args.len()
    if argc < 2:
        print "Simple Bootstrap Compiler v0.8.0"
        print "Usage: simple compile <file> [-o <output>] [--native]"
        print ""
        print "Commands:"
        print "  compile <file>    Compile a .spl file"
        print "  native-build      Compile project to native binary"
        print "  --version         Show version"
        print "  --help            Show this help"
        return 0
    val first = all_args[1]
    if first == "--version":
        print "simple-bootstrap 0.8.0"
        return 0
    if first == "--help":
        print "Simple Bootstrap Compiler v0.8.0"
        print "Built from Simple source via Rust seed compiler"
        return 0
    if first == "native-build":
        return run_native_build_bootstrap(all_args.slice(1, all_args.len()))
    if first == "compile":
        if argc < 3:
            print "error: missing source file"
            print "Usage: simple compile <file> [-o <output>]"
            return 1
        val source_file = all_args[2]
        print "compile: {source_file}"
        print "note: compilation not yet implemented in bootstrap binary"
        return 0
    print "error: unknown command '{first}'"
    return 1
