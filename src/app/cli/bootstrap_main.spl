extern fn rt_get_args() -> [text]
extern fn rt_native_build(args: [text]) -> i64

use lazy compiler.driver.{compiler_driver_create, compiler_driver_run_compile}
use compiler.common.driver_core_types (CompileMode, CompileResult, driver_core_compile_options_default, compileoptions_normalize_mir_optimization, driver_output_format_native)
use app.io._CliCompile.compile_options.{cli_native_default_opt_level}
use std.nogc_sync_mut.io_runtime.{env_set}

# Keep in sync with ./VERSION file
fn bootstrap_version() -> text:
    "1.0.0-beta"

fn native_build_help() -> i64:
    0

fn bootstrap_output_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "a.out"
    elif args[i].starts_with("-o") and args[i].len() == 2 and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("-o") and args[i].len() > 2:
        args[i].substring(2)
    elif args[i].starts_with("--output") and args[i].len() == 8 and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--output="):
        args[i].substring(9)
    else:
        bootstrap_output_from_args(args, i + 1)

# ponytail: native codegen currently emits an invalid `bitcast i64 to i1`
# when a `bool`-returning function merges more than one branch (each arm
# stores into a shared i64 slot, then the final load is bitcast to i1
# instead of truncated/compared) -- see filed bug. Returning `i64` (1/0)
# instead of `bool` sidesteps that miscompile without touching the shared
# backend; callers compare against `1`.
fn native_build_flag_needs_value(flag: text) -> i64:
    if flag == "-o":
        1
    elif flag == "--output":
        1
    elif flag == "--source":
        1
    elif flag == "--entry":
        1
    elif flag == "--threads":
        1
    elif flag == "--timeout":
        1
    elif flag == "--cache-dir":
        1
    elif flag == "--backend":
        1
    elif flag == "--runtime-bundle":
        1
    elif flag == "--runtime-path":
        1
    elif flag == "--mode":
        1
    elif flag == "--target":
        1
    elif flag == "--linker-script":
        1
    elif flag == "--log":
        1
    else:
        0

fn native_build_has_explicit_entry(args: [text]) -> i64:
    var i = 0
    var found = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--entry" or arg.starts_with("--entry="):
            found = 1
        i = i + 1
    found

# rt_native_build's Rust arg parser (src/compiler_rust/native_all/src/lib.rs)
# treats any bare positional that isn't consumed by a value-taking flag as a
# `source_dir` to scan, and silently falls back to compiling
# `src/app/cli/main.spl` as the entry when no `--entry` was given. That means
# `bm native-build some_file.spl` never compiles `some_file.spl` -- it scans
# for it as a directory (a no-op, since it's a file) and then compiles the
# unrelated default entry instead. Detect the "single .spl file positional,
# no explicit --entry" shape here and forward an explicit `--entry <path>`
# (plus `--entry-closure` so the build only walks the entry's reachable
# closure instead of falling through to a full-project scan).
fn native_build_single_spl_positional(args: [text]) -> text:
    var i = 0
    var result = ""
    var count = 0
    while i < args.len():
        val arg = args[i]
        if arg == "native-build":
            i = i + 1
        elif native_build_flag_needs_value(arg) == 1:
            i = i + 2
        elif arg.starts_with("-"):
            i = i + 1
        elif arg.ends_with(".spl"):
            result = arg
            count = count + 1
            i = i + 1
        else:
            i = i + 1
    if count == 1:
        result
    else:
        ""

fn native_build_backend_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "llvm"
    elif args[i] == "--backend" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--backend="):
        args[i].substring(10)
    else:
        native_build_backend_from_args(args, i + 1)

# #138: for the single-file positional shape (no --entry, no --source dirs --
# i.e. `bm native-build foo.spl -o out`), run the compile THROUGH THE
# PURE-SIMPLE IN-PROCESS PIPELINE (compiler_driver_create /
# compiler_driver_run_compile) instead of the Rust rt_native_build FFI seed.
# The in-process failure surfaces loudly; it never silently retries the seed.
fn run_native_build_bootstrap(args: [text]) -> i64:
    if native_build_has_explicit_entry(args) == 1:
        return rt_native_build(args)
    val entry_path = native_build_single_spl_positional(args)
    if entry_path == "":
        return rt_native_build(args)
    val output = bootstrap_output_from_args(args, 0)
    val backend = native_build_backend_from_args(args, 0)
    # The in-process AOT MIR-lowering path only lowers real function bodies for
    # the entry module when SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE=1; otherwise the
    # entry module falls through to an empty MirModule stub and the backend
    # reports "MIR module has no functions" (driver_pipeline.spl:419). Set it
    # here (a fresh compiled bootstrap_main process does not inherit the
    # bootstrap-time env) to match cli_native_build's behaviour.
    env_set("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE", "1")
    # Build directly through the pure-Simple CompilerDriver (unique symbol
    # names -- avoids the `aot_native_file_with_backend` duplicate-name
    # collision between driver_public_compile [subprocess facade] and
    # driver_api_native_single [in-process]).
    var options = driver_core_compile_options_default()
    options.input_files = [entry_path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = driver_output_format_native()
    options.backend = backend
    options.release = true
    options.opt_level = cli_native_default_opt_level()
    options = compileoptions_normalize_mir_optimization(options)
    val driver = compiler_driver_create(options)
    val result = compiler_driver_run_compile(driver)
    if result.is_success():
        0
    else:
        for err in result.get_errors():
            print "error: in-process native-build: {err}"
        1

fn get_cli_args() -> [text]:
    rt_get_args()

fn main() -> i64:
    val all_args = get_cli_args()
    val argc = all_args.len()
    if argc < 2:
        print "Simple Bootstrap Compiler v1.0.0-beta"
        print "Usage: simple compile <file> [-o <output>] [--native] [--opt-level=<level>] [--list-optimizations]"
        return 0
    if argc > 2:
        return run_native_build_bootstrap(all_args)
    val first = all_args[1]
    if first.len() == 9 and first.starts_with("--version"):
        print "simple-bootstrap 1.0.0-beta"
        return 0
    if first.len() == 6 and first.starts_with("--help"):
        print "Simple Bootstrap Compiler v1.0.0-beta"
        print "Built from Simple source via the staged bootstrap"
        print ""
        print "Compile-related flags include:"
        print "  --opt-level=<none|basic|standard|aggressive>"
        print "  --list-optimizations"
        return 0
    if first.len() == 12 and first.starts_with("native-build"):
        return run_native_build_bootstrap(all_args)
    if first.len() == 7 and first.starts_with("compile"):
        if argc < 3:
            print "error: missing source file"
            return 1
        val source_file = all_args[2]
        print "compile: {source_file}"
        return 0
    print "error: unknown command '{first}'"
    return 1
