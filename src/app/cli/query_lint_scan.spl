# Shared line scan context for query lint and diagnostics passes.

use app.cli.query_helpers.{_count_indent}

struct LintScanLine:
    line: text
    trimmed: text
    line_num: i64
    indent: i64

fn lint_scan_line(lines: [text], idx: i64) -> LintScanLine:
    val line = lines[idx]
    LintScanLine(
        line: line,
        trimmed: line.trim(),
        line_num: idx + 1,
        indent: _count_indent(line))
