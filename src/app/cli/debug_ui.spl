# Debug UI — CLI subcommand for GUI theme inspection
#
# Entry point for `bin/simple debug-ui <subcommand> [--theme=<name>]`.
# Delegates to pure functions in glass_debug.spl.

use common.ui.glass_debug.{debug_theme_tokens, debug_css_dump, debug_widget_tree, list_glass_themes}

# =========================================================================
# Argument parsing
# =========================================================================

fn parse_theme_flag(args: List<text>) -> text:
    """Extract --theme=<name> from args, default to glass_dark."""
    var i = 0
    while i < args.len():
        val arg = args.get(i)
        if arg.starts_with("--theme="):
            return arg.slice(8, arg.len())
        i = i + 1
    return "glass_dark"

fn print_debug_ui_usage():
    print "Usage: simple debug-ui <subcommand> [--theme=<name>]"
    print ""
    print "Subcommands:"
    print "  widget-tree    Show widget tree with CSS variable assignments"
    print "  theme-tokens   Dump all design token values for a theme"
    print "  css-dump       Generate full CSS output for a theme"
    print "  list-themes    List available glass themes"
    print ""
    print "Options:"
    print "  --theme=<name>  Theme name (default: glass_dark)"
    print ""
    print "Available themes: glass_dark, glass_light, glass_obsidian_dark"

# =========================================================================
# CLI entry
# =========================================================================

fn cli_debug_ui(args: List<text>) -> i32:
    """Handle `bin/simple debug-ui <subcommand> [--theme=<name>]`."""
    if args.len() < 1:
        print_debug_ui_usage()
        return 1

    val subcmd = args.get(0)
    val theme = parse_theme_flag(args)

    if subcmd == "list-themes":
        val themes = list_glass_themes()
        print "Available glass themes:"
        var i = 0
        while i < themes.len():
            print "  - {themes.get(i)}"
            i = i + 1
        return 0

    if subcmd == "theme-tokens":
        val result = debug_theme_tokens(theme)
        print result
        return 0

    if subcmd == "css-dump":
        val result = debug_css_dump(theme)
        print result
        return 0

    if subcmd == "widget-tree":
        val result = debug_widget_tree(theme)
        print result
        return 0

    print "Error: unknown subcommand '{subcmd}'"
    print ""
    print_debug_ui_usage()
    return 1
