# Package Manager - Dependency Resolver
#
# Reads package.sdn, resolves each dependency.
# For git deps: clones/fetches to ~/.simple/packages/ cache.
# Detects version conflicts (two deps requiring incompatible versions).

use app.pkg.manifest.{PackageManifest, Dependency, parse_manifest_file, parse_manifest}
use app.pkg.version.{SemVer, VersionConstraint}
use app.pkg.lock.{LockEntry, LockFile, parse_lock_file, write_lock_file}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text

# Resolved dependency with exact version/commit info
struct ResolvedDep:
    name: text
    version: text               # Resolved version string
    git_url: text               # Git URL (if git dep)
    git_commit: text            # Exact commit hash (if git dep)
    path: text                  # Local path (if path dep)
    cache_path: text            # Path in global cache
    source_type: text           # "git", "path", or "registry"

impl ResolvedDep:
    fn to_text() -> text:
        if self.source_type == "git":
            "{self.name} ({self.version}, git: {self.git_url}#{self.git_commit})"
        elif self.source_type == "path":
            "{self.name} ({self.version}, path: {self.path})"
        else:
            "{self.name} ({self.version})"


# Resolution result
struct ResolutionResult:
    resolved: [ResolvedDep]
    errors: [text]

impl ResolutionResult:
    fn has_errors() -> bool:
        self.errors.len() > 0


# Get the global cache directory (~/.simple/packages/)
fn get_cache_dir() -> text:
    val home = rt_env_get("HOME")
    if home == "" or home == nil:
        # Fallback for Windows
        val userprofile = rt_env_get("USERPROFILE")
        if userprofile != "" and userprofile != nil:
            return "{userprofile}/.simple/packages"
        return ".simple/packages"
    "{home}/.simple/packages"


# Run a shell command and return (stdout, stderr, exit_code)
fn run_shell(command: text) -> (text, text, i64):
    val os = rt_env_get("OS")
    var is_windows = false
    if os != nil and os != "":
        is_windows = os.lower().contains("windows")

    if is_windows:
        rt_process_run("cmd.exe", ["/c", command])
    else:
        rt_process_run("/bin/sh", ["-c", command])


# Clone or fetch a git repository to the cache
fn git_clone_or_fetch(dep: Dependency, cache_dir: text) -> Result<ResolvedDep, text>:
    val cache_key = dep.cache_key()
    val dest = "{cache_dir}/{cache_key}"

    if rt_file_exists("{dest}/.git"):
        # Already cloned, fetch latest
        print "  Fetching {dep.name}..."
        val (_, fetch_err, fetch_code) = run_shell("cd \"{dest}\" && git fetch --quiet 2>&1")
        if fetch_code != 0:
            return Err("Failed to fetch {dep.name}: {fetch_err}")

        # Checkout specific ref
        val checkout_ref = if dep.git_tag != "":
            dep.git_tag
        elif dep.git_rev != "":
            dep.git_rev
        else:
            "origin/{dep.git_branch}"

        val (_, co_err, co_code) = run_shell("cd \"{dest}\" && git checkout --quiet {checkout_ref} 2>&1")
        if co_code != 0:
            return Err("Failed to checkout {checkout_ref} for {dep.name}: {co_err}")
    else:
        # Clone fresh
        print "  Cloning {dep.name} from {dep.git_url}..."

        var clone_args = "git clone --quiet"
        if dep.git_branch != "" and dep.git_branch != "main" and dep.git_tag == "" and dep.git_rev == "":
            clone_args = "{clone_args} --branch {dep.git_branch}"
        clone_args = "{clone_args} \"{dep.git_url}\" \"{dest}\""

        val (_, clone_err, clone_code) = run_shell(clone_args)
        if clone_code != 0:
            return Err("Failed to clone {dep.name}: {clone_err}")

        # Checkout specific tag or rev if needed
        if dep.git_tag != "":
            val (_, tag_err, tag_code) = run_shell("cd \"{dest}\" && git checkout --quiet {dep.git_tag} 2>&1")
            if tag_code != 0:
                return Err("Failed to checkout tag {dep.git_tag} for {dep.name}: {tag_err}")
        elif dep.git_rev != "":
            val (_, rev_err, rev_code) = run_shell("cd \"{dest}\" && git checkout --quiet {dep.git_rev} 2>&1")
            if rev_code != 0:
                return Err("Failed to checkout rev {dep.git_rev} for {dep.name}: {rev_err}")

    # Get current commit hash
    val (commit_out, _, _) = run_shell("cd \"{dest}\" && git rev-parse HEAD")
    val commit = commit_out.trim()

    # Try to read version from the dep's own package.sdn
    var version = "0.0.0"
    val dep_manifest_path = "{dest}/package.sdn"
    if rt_file_exists(dep_manifest_path):
        val dep_source = rt_file_read_text(dep_manifest_path)
        if dep_source != "" and dep_source != nil:
            val dep_manifest = parse_manifest(dep_source)
            match dep_manifest:
                case Ok(m):
                    if m.version != "":
                        version = m.version
                case Err(_):
                    pass

    Ok(ResolvedDep(
        name: dep.name,
        version: version,
        git_url: dep.git_url,
        git_commit: commit,
        path: "",
        cache_path: dest,
        source_type: "git"
    ))


# Resolve a path dependency
fn resolve_path_dep(dep: Dependency) -> Result<ResolvedDep, text>:
    if not rt_file_exists(dep.path):
        return Err("Path dependency '{dep.name}' not found at: {dep.path}")

    # Try to read version from the dep's own package.sdn
    var version = "0.0.0"
    val dep_manifest_path = "{dep.path}/package.sdn"
    if rt_file_exists(dep_manifest_path):
        val dep_source = rt_file_read_text(dep_manifest_path)
        if dep_source != "" and dep_source != nil:
            val dep_manifest = parse_manifest(dep_source)
            match dep_manifest:
                case Ok(m):
                    if m.version != "":
                        version = m.version
                case Err(_):
                    pass

    Ok(ResolvedDep(
        name: dep.name,
        version: version,
        git_url: "",
        git_commit: "",
        path: dep.path,
        cache_path: dep.path,
        source_type: "path"
    ))


# Resolve a single dependency, using lock file entry if available
fn resolve_dep(dep: Dependency, cache_dir: text, lock_entry: LockEntry?) -> Result<ResolvedDep, text>:
    if dep.is_path():
        return resolve_path_dep(dep)

    if dep.is_git():
        # If we have a lock entry with a commit, use it
        if lock_entry.?:
            val entry = lock_entry.unwrap()
            if entry.git_commit != "":
                # Check if already cached at this commit
                val cache_key = dep.cache_key()
                val dest = "{cache_dir}/{cache_key}"
                if rt_file_exists("{dest}/.git"):
                    # Verify commit matches
                    val (commit_out, _, _) = run_shell("cd \"{dest}\" && git rev-parse HEAD")
                    val current_commit = commit_out.trim()
                    if current_commit == entry.git_commit:
                        return Ok(ResolvedDep(
                            name: dep.name,
                            version: entry.version,
                            git_url: dep.git_url,
                            git_commit: entry.git_commit,
                            path: "",
                            cache_path: dest,
                            source_type: "git"
                        ))
        return git_clone_or_fetch(dep, cache_dir)

    # Registry dependency (Phase 2 -- for now, error)
    Err("Registry dependencies not yet supported (Phase 2). Use --git for '{dep.name}'.")


# Check for version conflicts between resolved dependencies
fn check_conflicts(resolved: [ResolvedDep]) -> [text]:
    var conflicts: [text] = []
    var seen: Dict<text, text> = {}

    for dep in resolved:
        val existing = seen.get(dep.name)
        if existing.?:
            val prev_version = existing.unwrap()
            if prev_version != dep.version:
                conflicts.push("Conflict: {dep.name} required as {prev_version} and {dep.version}")
        else:
            seen[dep.name] = dep.version

    conflicts


# Resolve all dependencies from a manifest
fn resolve_all(manifest: PackageManifest, lock: LockFile?, include_dev: bool) -> ResolutionResult:
    val cache_dir = get_cache_dir()
    var resolved: [ResolvedDep] = []
    var errors: [text] = []

    # Ensure cache directory exists
    val (_, mkdir_err, mkdir_code) = run_shell("mkdir -p \"{cache_dir}\"")
    if mkdir_code != 0:
        errors.push("Failed to create cache directory {cache_dir}: {mkdir_err}")
        return ResolutionResult(resolved: resolved, errors: errors)

    # Resolve regular dependencies
    for dep in manifest.dependencies:
        var lock_entry: LockEntry? = nil
        if lock.?:
            lock_entry = lock.unwrap().find_entry(dep.name)
        val result = resolve_dep(dep, cache_dir, lock_entry)
        match result:
            case Ok(r):
                resolved.push(r)
            case Err(e):
                errors.push(e)

    # Resolve dev dependencies if requested
    if include_dev:
        for dep in manifest.dev_dependencies:
            var lock_entry: LockEntry? = nil
            if lock.?:
                lock_entry = lock.unwrap().find_entry(dep.name)
            val result = resolve_dep(dep, cache_dir, lock_entry)
            match result:
                case Ok(r):
                    resolved.push(r)
                case Err(e):
                    errors.push(e)

    # Check for conflicts
    val conflicts = check_conflicts(resolved)
    for c in conflicts:
        errors.push(c)

    ResolutionResult(resolved: resolved, errors: errors)
