use common.wine_gui_hello.{wine_gui_hello_probe_vm}
use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes, wine_hello_fixture_execution_evidence_struct, wine_hello_fixture_precondition_manifest}
use common.wine_vm_adapter.{wine_vm_process_space_new}

extern fn stdout_write(data: text)

fn main() -> i64:
    val space = wine_vm_process_space_new(2, 1002, "pid fs ipc net capability")
    val result = wine_gui_hello_probe_vm(wine_known_hello_exe_fixture_bytes(), wine_hello_fixture_precondition_manifest(), wine_hello_fixture_execution_evidence_struct(), space, 0x400000, 0x700000, 0x2000, 0x1000)
    if result.status == "executed":
        stdout_write("window={result.window_title}\n")
        stdout_write("text={result.window_text}")
        stdout_write("checksum={result.framebuffer_checksum}\n")
        return 0
    print "wine-gui-hello failed: {result.status}:{result.error}"
    1
