# Build Render Adapter
#
# Bridges build system output (step timeline with timing) to the shared
# ui.render contract.  Produces text (build output with timing) and
# html (build report with step cards, progress bar, and badges).

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_card, html_badge, html_table,
    html_section, html_progress_bar, html_escape,
    css_reset, css_dark_theme, css_light_theme}
use app.ui.render.fmt.{fmt_duration_ms, fmt_number, fmt_bytes}
use app.ui.render.ansi.{RESET, BOLD, DIM, RED, YELLOW, GREEN, CYAN, colorize}
use app.build.types.{BuildResult, BuildConfig, BuildProfile}

# =========================================================================
# Data Types
# =========================================================================

struct BuildStep:
    name: text
    status: text
    duration_ms: i64
    detail: text

struct BuildReport:
    steps: [BuildStep]
    total_duration_ms: i64
    success: bool
    profile: text

# =========================================================================
# Report Construction
# =========================================================================

fn build_report_from_result(result: BuildResult, config: BuildConfig) -> BuildReport:
    """Convert a BuildResult into a structured report."""
    var steps: [BuildStep] = []

    # Main compile step
    val compile_status = if result.success: "complete" else: "failed"
    steps.push(BuildStep(
        name: "Compile",
        status: compile_status,
        duration_ms: result.duration_ms,
        detail: ""
    ))

    # Parse stdout for additional step info
    val lines = result.stdout.split("\n")
    for line in lines:
        if line.contains("Compiling"):
            steps.push(BuildStep(name: "Compiling", status: "complete", duration_ms: 0, detail: line.trim()))
        elif line.contains("Linking"):
            steps.push(BuildStep(name: "Linking", status: "complete", duration_ms: 0, detail: line.trim()))
        elif line.contains("Finished"):
            steps.push(BuildStep(name: "Finished", status: "complete", duration_ms: 0, detail: line.trim()))

    val profile_name = match config.profile:
        BuildProfile.Debug => "debug"
        BuildProfile.Release => "release"
        BuildProfile.Bootstrap => "bootstrap"
        _ => "unknown"

    BuildReport(
        steps: steps,
        total_duration_ms: result.duration_ms,
        success: result.success,
        profile: profile_name
    )

# =========================================================================
# Render Entry Point
# =========================================================================

fn render_build(config: RenderConfig, result: BuildResult, build_config: BuildConfig) -> RenderResult:
    """Render build results via the shared render contract."""
    val report = build_report_from_result(result, build_config)

    match config.format:
        "html":
            return render_build_html(report, config)
        "both":
            val text_out = render_build_text(report, config)
            val html_out = render_build_html(report, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_build_text(report, config)

# =========================================================================
# Text Rendering
# =========================================================================

fn render_build_text(report: BuildReport, config: RenderConfig) -> RenderResult:
    """Render build report as colored terminal text."""
    var lines: [text] = []

    lines.push("{BOLD}Build Report{RESET}")
    lines.push("{DIM}Profile: {report.profile}{RESET}")
    lines.push("")

    for step in report.steps:
        val status_color = match step.status:
            "complete" => GREEN
            "failed" => RED
            "in_progress" => YELLOW
            _ => DIM
        val status_icon = colorize(step.status, status_color)
        val timing = if step.duration_ms > 0: " ({fmt_duration_ms(step.duration_ms)})" else: ""
        var detail_str = ""
        if step.detail != "":
            detail_str = " {DIM}{step.detail}{RESET}"
        lines.push("  {status_icon}  {step.name}{timing}{detail_str}")

    lines.push("")
    val total_str = fmt_duration_ms(report.total_duration_ms)
    val result_color = if report.success: GREEN else: RED
    val result_label = if report.success: "SUCCESS" else: "FAILED"
    lines.push("{BOLD}Result: {colorize(result_label, result_color)}{RESET}  Total: {total_str}")

    var text_out = ""
    var first = true
    for line in lines:
        if not first:
            text_out = "{text_out}\n"
        text_out = "{text_out}{line}"
        first = false

    RenderResult.text(text_out)

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_build_html(report: BuildReport, config: RenderConfig) -> RenderResult:
    """Render build report as HTML with step timeline."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val css = "{css_reset()}\n{theme_css}\n{build_css()}"

    var body = "<h1>Build Report</h1>\n"

    # Status badge + profile badge
    val status_badge = if report.success:
        html_badge("SUCCESS", "#3fb950")
    else:
        html_badge("FAILED", "#f85149")
    val profile_badge = html_badge(report.profile, "#58a6ff")
    val time_badge = html_badge(fmt_duration_ms(report.total_duration_ms), "#8b949e")
    body = "{body}<div style=\"margin-bottom:16px\">{status_badge} {profile_badge} {time_badge}</div>\n"

    # Build steps as cards
    body = "{body}{html_section(\"Build Steps\", \"\")}\n"
    for step in report.steps:
        val step_color = match step.status:
            "complete" => "#3fb950"
            "failed" => "#f85149"
            _ => "#d29922"
        val step_badge = html_badge(step.status, step_color)
        val timing_html = if step.duration_ms > 0:
            "<span style=\"color:var(--text-dim);font-size:12px\"> {fmt_duration_ms(step.duration_ms)}</span>"
        else:
            ""
        var step_body = "{step_badge}{timing_html}"
        if step.detail != "":
            step_body = "{step_body}<div style=\"margin-top:8px;font-size:13px;color:var(--text-dim);font-family:monospace\">{html_escape(step.detail)}</div>"
        body = "{body}{html_card(step.name, step_body)}\n"

    RenderResult.html(html_page("Build Report", css, body))

fn build_css() -> text:
    """Additional CSS for build report."""
    var s = ""
    s = "{s}.card { background:var(--bg-card); border:1px solid var(--border); border-radius:8px; padding:16px; margin-bottom:12px; }\n"
    s = "{s}.card h3 { font-size:14px; margin-bottom:8px; }\n"
    s
