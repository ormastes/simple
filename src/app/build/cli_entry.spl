# Build CLI Entry Point
# Handles the 'build' subcommand from the main CLI dispatcher.
# Dispatches to the native compilation pipeline or quality sub-tools
# based on the first positional argument:
#   (no arg / flags only) → native-build pipeline
#   bootstrap             → native-build pipeline (3-stage self-compilation)
#   lint                  → linter
#   fmt                   → formatter
#   check                 → parser/type-check pass
#   simpleos [arch...]    → build per-arch SimpleOS Simple toolchain (opt-in)

use app.io.cli_ops.{cli_native_build, cli_run_lint, cli_run_fmt}
use app.cli.check.{run_check}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn build_simpleos_targets(arches: [text]) -> i64:
    """`bin/simple build simpleos [arch...]` — build the per-arch SimpleOS Simple
    toolchain (x86_64/aarch64/riscv64-unknown-simpleos) via the CI builder, which
    native-builds each target, verifies it with a fail-closed readelf gate, and
    installs it to bin/release/<arch>-unknown-simpleos/simple. Opt-in on purpose:
    a plain `bin/simple build` stays host-only and fast. Optional args filter the
    arch set (passed through to the builder)."""
    var run_args: [text] = ["scripts/ci/build-simpleos-toolchain.shs"]
    var i = 0
    while i < arches.len():
        run_args.push(arches[i])
        i = i + 1
    var out = ""
    var err = ""
    var rc: i64 = 0
    # ponytail: capture+print (not streamed); a multi-minute build shows output
    # only at the end. Switch to an inherit-stdio exec if progress UX matters.
    (out, err, rc) = rt_process_run("sh", run_args)
    if out.len() > 0:
        print(out)
    if err.len() > 0:
        print(err)
    return rc

fn handle_build(args: [text]) -> i64:
    """Dispatch the 'build' subcommand to the appropriate pipeline."""
    val subcmd = if args.len() > 0: args[0] else: ""

    if subcmd == "lint":
        return cli_run_lint(args[1:])

    if subcmd == "fmt":
        return cli_run_fmt(args[1:])

    if subcmd == "check":
        return run_check(args[1:])

    if subcmd == "simpleos":
        return build_simpleos_targets(args[1:])

    # Both 'bootstrap' and default invoke the native-build pipeline.
    # For 'bootstrap', strip the subcommand so it isn't treated as a source path.
    # Prepend "native-build" so cli_native_build can identify and skip it.
    var native_args: [text] = ["native-build"]
    val pass_args = if subcmd == "bootstrap": args[1:] else: args
    var k = 0
    while k < pass_args.len():
        native_args.push(pass_args[k])
        k = k + 1
    # Propagate the pipeline's exit code explicitly. `bin/simple build bootstrap`
    # must fail (nonzero) when a stage fails; relying on implicit last-expression
    # return here previously let a failed native-build stage surface as exit 0.
    return cli_native_build(native_args)
