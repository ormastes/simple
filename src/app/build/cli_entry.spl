# Build CLI Entry Point
# Handles the 'build' subcommand from the main CLI dispatcher.
# Dispatches to the native compilation pipeline or quality sub-tools
# based on the first positional argument:
#   (no arg / flags only) → native-build pipeline
#   bootstrap             → native-build pipeline (3-stage self-compilation)
#   lint                  → linter
#   fmt                   → formatter
#   check                 → parser/type-check pass

use app.io.cli_ops.{cli_native_build, cli_run_lint, cli_run_fmt}
use app.cli.check.{run_check}

fn handle_build(args: [text]) -> i64:
    """Dispatch the 'build' subcommand to the appropriate pipeline."""
    val subcmd = if args.len() > 0: args[0] else: ""

    if subcmd == "lint":
        return cli_run_lint(args[1:])

    if subcmd == "fmt":
        return cli_run_fmt(args[1:])

    if subcmd == "check":
        return run_check(args[1:])

    # Both 'bootstrap' and default invoke the native-build pipeline.
    # For 'bootstrap', strip the subcommand so it isn't treated as a source path.
    # Prepend "native-build" so cli_native_build can identify and skip it.
    var native_args: [text] = ["native-build"]
    val pass_args = if subcmd == "bootstrap": args[1:] else: args
    var k = 0
    while k < pass_args.len():
        native_args.push(pass_args[k])
        k = k + 1
    cli_native_build(native_args)
