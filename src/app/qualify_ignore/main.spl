# Simple CLI - qualify-ignore command
# Scan test files for unqualified @ignore annotations

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, file_write, cwd, dir_walk)
use std.log.{error}

fn print_help():
    print "Usage: simple qualify-ignore [path] [options]"
    print ""
    print "Scan test files for #[ignore] without qualification reason."
    print ""
    print "Arguments:"
    print "  [path]           Directory to scan (default: test/)"
    print ""
    print "Options:"
    print "  --fix            Add placeholder reason to unqualified ignores"
    print "  --strict         Exit with error if unqualified ignores found"
    print "  --json           Output summary as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help       Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn scan_file(path: text) -> [(i64, text)]:
    val content = file_read(path)
    val lines = content.split("\n")
    var issues = []
    var line_num = 1

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "#[ignore]" or trimmed == "# ignore" or trimmed == "skip":
            issues.push((line_num, trimmed))
        line_num = line_num + 1

    issues

fn fix_file(path: text) -> i64:
    val content = file_read(path)
    val lines = content.split("\n")
    var result = []
    var fixed = 0

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "#[ignore]":
            result.push(line.replace("#[ignore]", "#[ignore = \"TODO: add reason\"]"))
            fixed = fixed + 1
        else:
            result.push(line)

    if fixed > 0:
        file_write(path, result.join("\n"))

    fixed

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("qualify_ignore", log_opts.error)
        return 1

    var scan_path = ""
    var fix_mode = false
    var strict = false
    var as_json = log_opts.log_mode == "json"

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--fix":
            fix_mode = true
        elif arg == "--strict":
            strict = true
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif not arg.starts_with("-"):
            scan_path = arg
        ai = ai + 1

    val cwd = cwd()
    if scan_path == "":
        scan_path = "{cwd}/test"

    if not file_exists(scan_path):
        error("qualify_ignore", "path not found: {scan_path}")
        return 1

    val files = dir_walk(scan_path)
    var total_issues = 0
    var total_fixed = 0
    var scanned = 0

    for file in files:
        if not file.ends_with(".spl") and not file.ends_with(".rs"):
            pass
        else:
            scanned = scanned + 1
            if fix_mode:
                val fixed = fix_file(file)
                if fixed > 0:
                    val display = if file.starts_with(cwd): file[cwd.len() + 1:] else: file
                    if not as_json:
                        print "Fixed {fixed} unqualified ignore(s) in {display}"
                    total_fixed = total_fixed + fixed
            else:
                val issues = scan_file(file)
                if issues.len() > 0:
                    val display = if file.starts_with(cwd): file[cwd.len() + 1:] else: file
                    if not as_json:
                        for (line_num, line_text) in issues:
                            print "{display}:{line_num}: unqualified ignore: {line_text}"
                    total_issues = total_issues + issues.len()

    if log_opts.progress != "summary":
        val progress_line = render_progress(log_opts.progress, scanned, scanned, "qualify-ignore")
        if progress_line != "":
            print progress_line

    if fix_mode:
        if as_json:
            print "{\"command\":\"qualify-ignore\",\"status\":\"ok\",\"mode\":\"fix\",\"files\":{scanned},\"fixed\":{total_fixed}}"
        else:
            print ""
            print "Fixed {total_fixed} unqualified ignore(s)"
    else:
        if total_issues == 0:
            if as_json:
                print "{\"command\":\"qualify-ignore\",\"status\":\"ok\",\"mode\":\"scan\",\"files\":{scanned},\"issues\":0}"
            else:
                print "All ignores are qualified."
        else:
            if as_json:
                print "{\"command\":\"qualify-ignore\",\"status\":\"issues\",\"mode\":\"scan\",\"files\":{scanned},\"issues\":{total_issues}}"
            else:
                print ""
                print "Found {total_issues} unqualified ignore(s)"
            if strict:
                return 1

    0
