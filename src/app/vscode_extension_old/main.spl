# VSCode Extension Build CLI.
# Startup-light surface for the legacy extension builder.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "VSCode Extension Builder"
val TOOL_VERSION = "1.0.0"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("vscode-extension-old", log_opts.error)
        return 1

    val args = vscode_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"vscode-extension-old\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"vscode-extension-old\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "vscode-extension-old")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for extension build planning."
        return 0

    if args[0] == "build":
        print_build_plan(args, log_opts.log_mode, log_opts.progress)
        return 0

    val message = "Unknown command: {args[0]}"
    if log_opts.log_mode == "json":
        print "{\"command\":\"vscode-extension-old\",\"status\":\"error\",\"message\":\"{message}\"}"
    else:
        error("vscode-extension-old", message)
    1

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple vscode-extension-old [command] [options]"
    print ""
    print "Commands:"
    print "  build             Plan a VSCode extension build"
    print ""
    print "Options:"
    print "  -h, --help        Show this help message"
    print "  -v, --version     Show version information"
    print "  --release         Use release build settings"
    print "  --watch           Enable watch mode"
    print "  --lsp-wasm        Include LSP WASM output"
    print "  --no-manifest     Skip manifest generation"
    print "  --source <DIR>    Source directory (default: src)"
    print "  --output <DIR>    Output directory (default: out)"
    print "  --name <NAME>     Extension package name"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn print_build_plan(args: [text], log_mode: text, progress_mode: text):
    val source_dir = vscode_option_value(args, "--source", "src")
    val output_dir = vscode_option_value(args, "--output", "out")
    val extension_name = vscode_option_value(args, "--name", "")
    val release = vscode_has_option(args, "--release")
    val watch = vscode_has_option(args, "--watch")
    val lsp_wasm = vscode_has_option(args, "--lsp-wasm")
    val manifest = not vscode_has_option(args, "--no-manifest")

    if log_mode == "json":
        print "{\"command\":\"vscode-extension-old\",\"status\":\"planned\",\"source\":\"{source_dir}\",\"output\":\"{output_dir}\",\"release\":{vscode_bool_json(release)},\"watch\":{vscode_bool_json(watch)},\"lspWasm\":{vscode_bool_json(lsp_wasm)},\"manifest\":{vscode_bool_json(manifest)}}"
        return

    val progress = render_progress(progress_mode, 1, 1, "build-plan")
    if progress != "":
        print progress
    print "{TOOL_NAME} build plan"
    print "  source: {source_dir}"
    print "  output: {output_dir}"
    if extension_name != "":
        print "  name: {extension_name}"
    if release:
        print "  mode: release"
    if watch:
        print "  watch: enabled"
    if lsp_wasm:
        print "  lsp wasm: enabled"
    if not manifest:
        print "  manifest: disabled"

fn vscode_bool_json(value: bool) -> text:
    if value:
        "true"
    else:
        "false"

fn vscode_option_value(args: [text], name: text, fallback: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with(name + "="):
            return arg.substring(name.len() + 1)
        i = i + 1
    fallback

fn vscode_has_option(args: [text], name: text) -> bool:
    for arg in args:
        if arg == name:
            return true
    false

fn vscode_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn vscode_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if vscode_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
