## Math Rendering Height Test — thick equations, multi-row, fractions, roots

# Nested fraction — tall vertical structure
fn nested_fraction(): f64 =
    m{frac(frac(1, 2) + frac(3, 4), frac(5, 6) * frac(7, 8))}

# Square root of a fraction
fn root_of_fraction(x: f64): f64 =
    m{sqrt(frac(x^2 + 1, x^2 - 1))}

# Double-nested root
fn double_root(): f64 =
    m{sqrt(1 + sqrt(frac(alpha^2, beta^2 + gamma^2)))}

# Summation with fraction body
fn series(n: i32): f64 =
    m{sum(frac(1, k^2), k=1..n)}

# Product notation
fn factorial_like(n: i32): f64 =
    m{product(frac(k + 1, k), k=1..n)}

# Integral with sqrt
fn arc_length(a: f64, b: f64): f64 =
    m{integral(sqrt(1 + frac(dd(y, x), 1)^2), x=a..b)}

# Piecewise / cases — multi-row
fn relu(x: f64): f64 =
    m{cases(x, x geq 0; 0, otherwise)}

# Loss function with complex body
fn cross_entropy(y: Tensor, p: Tensor): f64 =
    loss{-sum(y[i] * log(p[i]), i=1..n)}

# No-gradient softmax with fraction
fn stable_softmax(z: Tensor): Tensor =
    nograd{frac(exp(z[i]), sum(exp(z[j]), j=1..n))}

# Matrix quadratic form
fn quadratic(x: Tensor, A: Tensor): f64 =
    m{x @ A @ x + frac(1, 2) * norm(x)^2}

# Expected value with fraction
fn kl_divergence(p: Dist, q: Dist): f64 =
    m{expect(log(frac(p, q)))}

# Simple inline — short (baseline comparison)
fn area(r: f64): f64 =
    m{pi * r^2}
