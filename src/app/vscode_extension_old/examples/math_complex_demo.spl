# Complex Math Rendering Demo
# Nested fractions, multiple roots, and deep expressions

# 1. Nested fractions
val continued = m{ frac(1, 1 + frac(1, 2 + frac(1, 3))) }

# 2. Multiple square roots
val nested_root = m{ sqrt(sqrt(x^2 + y^2) + sqrt(a^2 + b^2)) }

# 3. Fraction with roots
val mixed = m{ frac(sqrt(x^2 + 1), sqrt(y^2 - 1)) }

# 4. Double fraction
val ratio = m{ frac(frac(a, b), frac(c, d)) }

# 5. Quadratic formula
val quadratic = m{ frac(-b + sqrt(b^2 - 4 * a * c), 2 * a) }

# 6. Chain rule with fractions
val chain = m{ frac(partial f, partial x) * frac(partial x, partial t) + frac(partial f, partial y) * frac(partial y, partial t) }

# 7. Loss with nested operations
val kl_div = loss{ sum(p[i] * log(frac(p[i], q[i]))) }

# 8. Complex neural network
val attention = m{ frac(Q @ K', sqrt(d[k])) }

# 9. Gaussian distribution
val gaussian = m{ frac(1, sigma * sqrt(2 * pi)) * exp(frac(-(x - mu)^2, 2 * sigma^2)) }

# 10. Matrix norm with root
val norm = m{ sqrt(sum(sum(A[i][j]^2))) }
