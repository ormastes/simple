fn _tui_render_palette(state: PaletteState, zones: LayoutZones, width: i64):
    val palette_w = 60
    val palette_h = 12
    val px = (width - palette_w) / 2
    val py = zones.editor_y + 1
    terminal_move_cursor(py, px)
    var border_top = "+"
    var bt = 0
    while bt < palette_w - 2:
        border_top = border_top + "-"
        bt = bt + 1
    border_top = border_top + "+"
    terminal_write("\x1b[1m" + border_top + "\x1b[0m")
    terminal_move_cursor(py + 1, px)
    var query_line = "| > " + state.query
    var qpad = ""
    var qp = 0
    while qp < palette_w - 2 - query_line.len():
        qpad = qpad + " "
        qp = qp + 1
    terminal_write("\x1b[1m" + query_line + qpad + " |\x1b[0m")
    terminal_move_cursor(py + 2, px)
    var sep = "|"
    var sp = 0
    while sp < palette_w - 2:
        sep = sep + "-"
        sp = sp + 1
    sep = sep + "|"
    terminal_write("\x1b[2m" + sep + "\x1b[0m")
    var ri = 0
    while ri < palette_h - 4:
        terminal_move_cursor(py + 3 + ri, px)
        if ri < state.filtered.len():
            val entry = state.filtered[ri]
            var eline = "  " + entry.name
            if eline.len() > palette_w - 4:
                eline = eline.slice(0, palette_w - 4)
            var epad = ""
            var ep = 0
            while ep < palette_w - 4 - eline.len():
                epad = epad + " "
                ep = ep + 1
            if ri == state.selected_index:
                terminal_write("\x1b[7m| " + eline + epad + " |\x1b[0m")
            else:
                terminal_write("| " + eline + epad + " |")
        else:
            var blank = "|"
            var bi = 0
            while bi < palette_w - 2:
                blank = blank + " "
                bi = bi + 1
            blank = blank + "|"
            terminal_write(blank)
        ri = ri + 1
    terminal_move_cursor(py + palette_h - 1, px)
    var border_bot = "+"
    var bb = 0
    while bb < palette_w - 2:
        border_bot = border_bot + "-"
        bb = bb + 1
    border_bot = border_bot + "+"
    terminal_write("\x1b[1m" + border_bot + "\x1b[0m")
