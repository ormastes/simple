# Editor Controller Core Methods
#
# Key dispatch, palette, settings, file tree, and command execution.

use app.editor.editor_controller_types.*
use app.editor.editor_controller.*
use std.editor.buffer.buffer.*
use std.editor.common.types.*
use std.editor.core.session.*
use std.editor.services.file_watcher.*
use std.editor.view.lsp_result_panel.*
use app.editor.commands.*
use app.editor.editor_path_text_helpers.*

fn ctrl_handle_key(ctrl: EditorController, key: text, rects: [SplitRect]) -> EditorAction:
    if key == "":
        return EditorAction(redraw: false, quit: false, status_msg: ctrl.status_msg)

    if ctrl.palette_state != nil and ctrl.palette_state.visible:
        return ctrl_dispatch_palette_key(ctrl, key)

    if ctrl.settings_view != nil:
        return ctrl_dispatch_settings_key(ctrl, key)

    if ctrl.session.mode == editor_mode_command():
        return ctrl_dispatch_command_key(ctrl, key)

    if ctrl.session.mode == editor_mode_normal():
        return ctrl_dispatch_normal_key(ctrl, key, rects)

    if ctrl.session.mode == editor_mode_insert():
        return ctrl_dispatch_insert_key(ctrl, key)

    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_toggle_file_tree(ctrl: EditorController):
    ctrl.file_tree_visible = if ctrl.file_tree_visible then false else: true
    if ctrl.file_tree_visible:
        ctrl.focus_panel = "file_tree"
    else:
        ctrl.focus_panel = "editor"

fn ctrl_toggle_focus(ctrl: EditorController):
    if ctrl.file_tree_visible:
        ctrl.focus_panel = if ctrl.focus_panel == "editor" then "file_tree" else: "editor"

fn ctrl_active_buffer(ctrl: EditorController) -> EditorBuffer:
    ctrl.session.active_buffer()

fn ctrl_mode(ctrl: EditorController) -> EditorMode:
    ctrl.session.mode

fn ctrl_is_running(ctrl: EditorController) -> bool:
    ctrl.running

fn ctrl_settings_open(ctrl: EditorController):
    ctrl.settings_view = SettingsViewState.new(full_settings_schema())

fn ctrl_settings_close(ctrl: EditorController):
    ctrl.settings_view = nil

fn ctrl_dispatch_settings_key(ctrl: EditorController, key: text) -> EditorAction:
    val sv: SettingsViewState = ctrl.settings_view
    if key == "j":
        sv.select_next()
    elif key == "k":
        sv.select_prev()
    elif key == "\t":
        sv.next_category()
    elif key == "h":
        sv.prev_category()
    elif key == "l":
        sv.next_category()
    elif key == "\r" or key == "\n":
        if not sv.is_editing():
            val setting_key = sv.current_setting_key()
            if sv.current_setting_type() == "bool":
                val cur = editor_config_get_by_key(ctrl.config, setting_key)
                val toggled = if cur == "true" then "false" else: "true"
                ctrl.config = editor_config_set_by_key(ctrl.config, setting_key, toggled)
                ctrl.status_msg = setting_key + " = " + toggled
            else:
                val cur2 = editor_config_get_by_key(ctrl.config, setting_key)
                sv.start_edit(cur2)
    elif key == "\x1b":
        if sv.is_editing():
            sv.cancel_edit()
        else:
            ctrl_settings_close(ctrl)
    elif key == "q":
        ctrl_settings_close(ctrl)
    elif key == "/":
        sv.clear_search()
    EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

fn ctrl_dispatch_command_key(ctrl: EditorController, key: text) -> EditorAction:
    val result = ctrl_handle_command_key(key, ctrl.commandline)
    ctrl.commandline = result.commandline
    if result.done:
        val parsed = editor_parse_commandline(ctrl.commandline)
        if parsed.name == "settings":
            ctrl_settings_open(ctrl)
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            ctrl.status_msg = "settings"
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        if parsed.name == "palette":
            ctrl_open_palette(ctrl)
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return EditorAction(redraw: true, quit: false, status_msg: "command palette")
        if parsed.name == "preview":
            ctrl_toggle_md_preview(ctrl)
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        if parsed.name == "outline":
            ctrl_toggle_md_outline(ctrl)
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        if parsed.name == "quickfix":
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return ctrl_request_quickfix(ctrl)
        if parsed.name == "quickfix-apply":
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return ctrl_apply_first_quickfix(ctrl)
        if parsed.name == "problems":
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return ctrl_show_diagnostics_panel(ctrl)
        if parsed.name == "diagnostics-filter":
            ctrl.session.mode = editor_mode_normal()
            ctrl.commandline = ""
            return ctrl_show_diagnostics_filter(ctrl, parsed.payload)
        if parsed.name == "diagnostics-group":
