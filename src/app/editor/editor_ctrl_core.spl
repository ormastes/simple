        val dispatch_result = editor_dispatch_session(ctrl.session, parsed)
        ctrl.status_msg = dispatch_result.message
        if dispatch_result.quit:
            ctrl.running = false
        ctrl.session.mode = editor_mode_normal()
        ctrl.commandline = ""
    elif result.cancelled:
        ctrl.session.mode = editor_mode_normal()
        ctrl.commandline = ""
        ctrl.status_msg = ""
    EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

fn ctrl_dispatch_normal_key(ctrl: EditorController, key: text, rects: [SplitRect]) -> EditorAction:
    if key == "\x02":
        ctrl_toggle_file_tree(ctrl)
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if key == "\t":
        ctrl_toggle_focus(ctrl)
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if key == "\x10":
        ctrl_open_palette(ctrl)
        return EditorAction(redraw: true, quit: false, status_msg: "command palette")
    if key == "\x16":
        ctrl_toggle_md_preview(ctrl)
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if key == "Ctrl+Space":
        return ctrl_request_active_lsp_action(ctrl, "completion")
    if key == "K":
        return ctrl_request_active_lsp_action(ctrl, "hover")
    if key == "F12":
        return ctrl_request_active_lsp_action(ctrl, "definition")
    if key == "Ctrl+.":
        return ctrl_request_quickfix(ctrl)
    if key == "Shift+Alt+Right":
        return ctrl_expand_lsp_selection_range(ctrl)
    if key == "Shift+Alt+Left":
        return ctrl_shrink_lsp_selection_range(ctrl)
    if key == "F5":
        return ctrl_start_debug_process_adapter(ctrl, "simple")
    if key == "\x1b" and ctrl.lsp_hover_popup.visible:
        return ctrl_dismiss_lsp_hover_popup(ctrl)
    if key == "\x1b" and ctrl.lsp_signature_popup.visible:
        return ctrl_dismiss_lsp_signature_popup(ctrl)
    if ctrl.session.dock_layout.active_right_panel() == "lsp-panel":
        val lsp_panel_action = ctrl_dispatch_lsp_result_key(ctrl, key)
        if lsp_panel_action.redraw:
            return lsp_panel_action
    if ctrl.session.dock_layout.active_right_panel() == "wiki-panel":
        val wiki_panel_action = ctrl_dispatch_wiki_panel_key(ctrl, key)
        if wiki_panel_action.redraw:
            return wiki_panel_action
    if ctrl.session.dock_layout.active_right_panel() == "problems":
        val problems_action = ctrl_dispatch_diagnostics_panel_key(ctrl, key)
        if problems_action.redraw:
            return problems_action
    if ctrl.session.dock_layout.active_right_panel() == "md-outline":
        val outline_action = ctrl_dispatch_md_outline_key(ctrl, key)
        if outline_action.redraw:
            return outline_action

    if ctrl.pending_prefix == "ctrl_w":
        ctrl.pending_prefix = ""
        val wresult: WincmdResult = wincmd_dispatch(ctrl.session, key, rects)
        if wincmd_result_handled(wresult):
            ctrl.status_msg = wincmd_result_message(wresult)
            if wincmd_result_quit(wresult):
                ctrl.running = false
        return EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

    if ctrl.pending_prefix == "]" or ctrl.pending_prefix == "[":
        val saved_prefix = ctrl.pending_prefix
        ctrl.pending_prefix = ""
        val doc = ctrl.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            val buffer_m = ctrl.session.active_buffer()
            if buffer_m != nil:
                val content = md_buffer_content(buffer_m)
                val motion_result = md_dispatch_motion(saved_prefix, key, content, buffer_m.cursor_row_value(), buffer_m.cursor_col_value())
                if motion_result.found:
                    buffer_m.move_cursor(motion_result.line, motion_result.col)
                    ctrl.status_msg = "motion"
                return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

    if ctrl.pending_prefix == "g":
        ctrl.pending_prefix = ""
        val doc_g = ctrl.session.active_document()
        if doc_g != nil and doc_g.language_id == "markdown" and key == "x":
            val buffer_gx = ctrl.session.active_buffer()
            if buffer_gx != nil:
                return ctrl_open_markdown_link_under_cursor(ctrl)
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        val buffer_gg = ctrl.session.active_buffer()
        if buffer_gg != nil:
            buffer_gg.move_cursor(0, 0)
            ctrl.status_msg = "top"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

    if ctrl.pending_prefix == "z":
        ctrl.pending_prefix = ""
        if key == "a":
            return ctrl_toggle_active_markdown_fold(ctrl)
        ctrl.status_msg = ""
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

    if key == "\x17":
        ctrl.pending_prefix = "ctrl_w"
        return EditorAction(redraw: true, quit: false, status_msg: "Ctrl+W ...")

    if key == "]" or key == "[":
        ctrl.pending_prefix = key
        return EditorAction(redraw: true, quit: false, status_msg: key + " ...")

    if ctrl.focus_panel == "file_tree":
        return ctrl_dispatch_file_tree_key(ctrl, key)

    val buffer = ctrl.session.active_buffer()
    if buffer == nil:
        if key == ":":
            ctrl.session.mode = editor_mode_command()
            ctrl.commandline = ""
        elif key == "q":
            ctrl.running = false
        return EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

    if key == "g":
        val doc_g2 = ctrl.session.active_document()
        if doc_g2 != nil and doc_g2.language_id == "markdown":
            ctrl.pending_prefix = "g"
            return EditorAction(redraw: true, quit: false, status_msg: "g ...")
    if key == "z":
        val doc_z = ctrl.session.active_document()
        if doc_z != nil and doc_z.language_id == "markdown":
            ctrl.pending_prefix = "z"
            return EditorAction(redraw: true, quit: false, status_msg: "z ...")

    val result = ctrl_handle_normal_key(buffer, key)
    ctrl.status_msg = result.message
    if result.quit:
        ctrl.running = false
    if result.enter_insert:
        ctrl.session.mode = editor_mode_insert()
        ctrl.status_msg = "-- INSERT --"
    if result.enter_command:
        ctrl.session.mode = editor_mode_command()
        ctrl.commandline = ""
    EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

fn ctrl_dispatch_insert_key(ctrl: EditorController, key: text) -> EditorAction:
    val buffer = ctrl.session.active_buffer()
    if buffer == nil:
        ctrl.session.mode = editor_mode_normal()
        return EditorAction(redraw: true, quit: false, status_msg: "")
    val doc = ctrl.session.active_document()
    if doc != nil and doc.language_id == "markdown":
        if key == "\r" or key == "\n":
            val current_line = buffer.line_at(buffer.cursor_row_value())
            val continuation = md_assist_on_enter(current_line, buffer.cursor_col_value())
            if continuation != "":
                buffer.insert_at_cursor("\n" + continuation)
                ctrl_update_markdown_preview(ctrl, doc, buffer)
                ctrl.session.update_active_buffer(buffer)
                ctrl_notify_active_lsp_changed(ctrl)
                return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
        if key == "\t":
            val tab_line = buffer.line_at(buffer.cursor_row_value())
            val same_row_col = md_assist_on_tab(tab_line, buffer.cursor_col_value())
            val nav = md_table_next_cell(buffer.to_text(), buffer.cursor_row_value(), buffer.cursor_col_value())
            if nav.found:
                buffer.move_cursor(nav.line, nav.col)
                ctrl.session.update_active_buffer(buffer)
                return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
            if same_row_col >= 0:
                buffer.move_cursor(buffer.cursor_row_value(), same_row_col)
                ctrl.session.update_active_buffer(buffer)
                return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
    var result = InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    if key == "\x1b":
        result = InsertKeyResult(message: "", exit_insert: true)
    elif key == "\x7f" or key == "\b":
        buffer.delete_before_cursor()
    elif key == "\r" or key == "\n":
        buffer.insert_at_cursor("\n")
    elif key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            buffer.insert_at_cursor(key)
    ctrl.status_msg = result.message
    if result.exit_insert:
        ctrl.session.mode = editor_mode_normal()
        ctrl.status_msg = ""
    else:
        ctrl.session.update_active_buffer(buffer)
        if doc != nil and doc.language_id == "markdown":
            ctrl_update_markdown_preview(ctrl, doc, buffer)
        ctrl_notify_active_lsp_changed(ctrl)
        if ctrl_should_trigger_signature_help(ctrl, key):
            return ctrl_request_active_lsp_action(ctrl, "signature-help")
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_dispatch_file_tree_key(ctrl: EditorController, key: text) -> EditorAction:
    if key == "j":
        ctrl.file_tree.select_next()
    elif key == "k":
        ctrl.file_tree.select_prev()
    elif key == "\r" or key == "\n":
        if ctrl.file_tree.selected_is_dir():
            ctrl.file_tree.toggle_expand()
        else:
            val fpath = ctrl.file_tree.selected_path()
            ctrl.session.open_file(fpath)
            ctrl_activate_active_language(ctrl)
            ctrl.focus_panel = "editor"
            ctrl.status_msg = "opened " + fpath
    elif key == "\x1b":
        ctrl.focus_panel = "editor"
    elif key == ":":
        ctrl.session.mode = editor_mode_command()
        ctrl.commandline = ""
    elif key == "q":
        ctrl.running = false
    EditorAction(redraw: true, quit: not ctrl.running, status_msg: ctrl.status_msg)

fn ctrl_should_trigger_signature_help(ctrl: EditorController, key: text) -> bool:
    key == "(" or key == ","

fn ctrl_dispatch_palette_key(ctrl: EditorController, key: text) -> EditorAction:
    if key == "\x1b":
        ctrl.palette_state = palette_hide(ctrl.palette_state)
        return EditorAction(redraw: true, quit: false, status_msg: "")
    if key == "\r" or key == "\n":
        val selected = palette_selected(ctrl.palette_state)
        ctrl.palette_state = palette_hide(ctrl.palette_state)
        if selected.command_name != "":
            return ctrl_execute_palette_command(ctrl, selected.command_name, selected.command_payload)
        return EditorAction(redraw: true, quit: false, status_msg: "")
    if key == "\x1b[A":
        ctrl.palette_state = palette_select_prev(ctrl.palette_state)
        return EditorAction(redraw: true, quit: false, status_msg: "")
    if key == "\x1b[B":
        ctrl.palette_state = palette_select_next(ctrl.palette_state)
        return EditorAction(redraw: true, quit: false, status_msg: "")
    if key == "\x7f" or key == "\b":
        val q = palette_query(ctrl.palette_state)
        if q.len() > 0:
            ctrl.palette_state = palette_update_query(ctrl.palette_state, q.slice(0, q.len() - 1))
        return EditorAction(redraw: true, quit: false, status_msg: "")
    if key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            ctrl.palette_state = palette_update_query(ctrl.palette_state, palette_query(ctrl.palette_state) + key)
    EditorAction(redraw: true, quit: false, status_msg: "")
