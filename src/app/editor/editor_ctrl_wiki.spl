# Editor Controller Wiki Methods
#
# Wiki panel, markdown editing, note embedding, task, backlinks, and vault helpers.

use app.editor.editor_controller_types.*
use app.editor.editor_controller.*
use std.editor.core.session.*
use std.editor.view.md_editing.*
use std.editor.extensions.builtin.md_edit_assist.*
use std.editor.services.md_wiki_index.*
use std.editor.services.md_search.*
use std.editor.view.diagnostics_panel.*
use std.editor.view.wiki_panel.*
use app.editor.editor_markdown_helpers.*
use app.editor.editor_attachment_template.*
use app.editor.editor_path_text_helpers.*

fn ctrl_show_debug_session_panel(ctrl: EditorController, message: text):
    ctrl.wiki_panel = _editor_debug_session_panel(editor_debug_first_session(ctrl.debug_registry))
    ctrl_show_wiki_panel(ctrl, message)

fn ctrl_wiki_daily_note_create(ctrl: EditorController, payload: text) -> EditorAction:
    val date = _editor_payload_part(payload, 0)
    if date == "":
        ctrl.status_msg = "missing daily note date"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
    val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
    val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
    val config = md_wiki_daily_note_config_with_title(folder, title_format, _editor_payload_part(payload, 4), template_body)
    val path = md_wiki_daily_note_path(config, date)
    val content = md_wiki_daily_note_content(config, date)
    val ok = rt_file_write_text(path, content)
    if not ok:
        ctrl.status_msg = "failed to create daily note"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var session_daily = ctrl.session
    val target_doc_id = session_daily.open_file(path)
    ctrl._replace_session(session_daily)
    ctrl_focus_lsp_target_doc(ctrl, target_doc_id)
    ctrl.status_msg = "created daily note: " + path
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_daily_note_picker(ctrl: EditorController, payload: text) -> EditorAction:
    val date = _editor_payload_part(payload, 0)
    val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
    val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
    val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
    val config = md_wiki_daily_note_config_with_title(folder, title_format, _editor_payload_part(payload, 4), template_body)
    ctrl.wiki_daily_note_payload = date + "|" + folder + "|" + template_body + "|" + title_format + "|" + config.extension
    val preview_date = if date == "" then "YYYY-MM-DD" else: date
    val path = md_wiki_daily_note_path(config, preview_date)
    ctrl.wiki_panel = wiki_panel_with_rows("Daily Notes", [
        WikiPanelRow(icon: "calendar", label: preview_date, detail: ctrl.wiki_daily_note_payload, path: path, line: 0)
    ])
    ctrl_show_wiki_panel(ctrl, "daily notes")
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_template_insert(ctrl: EditorController, payload: text) -> EditorAction:
    val template_path = _editor_payload_part(payload, 0)
    val target_path = _editor_payload_part(payload, 1)
    val title = _editor_payload_part(payload, 2)
    val date = _editor_payload_part(payload, 3)
    if template_path == "" or target_path == "":
        ctrl.status_msg = "missing template or target path"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val rendered = _editor_apply_template_text(rt_file_read_text(template_path) ?? "", title, date)
    val existing = rt_file_read_text(target_path) ?? ""
    val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
    val ok = rt_file_write_text(target_path, existing + sep + rendered)
    if not ok:
        ctrl.status_msg = "failed to insert template"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.status_msg = "inserted template: " + template_path
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_template_picker(ctrl: EditorController, payload: text) -> EditorAction:
    val folder = _editor_payload_part(payload, 0)
    val target_path = _editor_payload_part(payload, 1)
    val title = _editor_payload_part(payload, 2)
    val date = _editor_payload_part(payload, 3)
    val query = _editor_payload_part(payload, 4).trim().to_lower()
    if folder == "":
        ctrl.status_msg = "missing template folder"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.wiki_template_picker_payload = folder + "|" + target_path + "|" + title + "|" + date + "|" + query
    ctrl.wiki_template_query = query
    ctrl.wiki_panel = wiki_panel_with_rows("Templates", _editor_template_picker_rows(folder, target_path, title, date, query))
    ctrl_show_wiki_panel(ctrl, "templates: " + ctrl.wiki_panel.rows.len().to_text())
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_embed_insert(ctrl: EditorController, payload: text) -> EditorAction:
    var target_path = _editor_payload_part(payload, 0)
    val embed_source = _editor_payload_part(payload, 1)
    val alias = _editor_payload_part(payload, 2)
    val active_doc = ctrl.session.active_document()
    if target_path == "" and active_doc != nil:
        target_path = active_doc.path()
    if target_path == "" or embed_source == "":
        ctrl.status_msg = "missing target or embed path"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val embed_target = _editor_note_embed_target(embed_source)
    val embed = _editor_wiki_note_embed(embed_target, alias)
    val buffer = ctrl.session.active_buffer()
    if active_doc != nil and buffer != nil and active_doc.path() == target_path:
        buffer.insert_at_cursor(embed + "\n")
        ctrl.session.update_active_buffer(buffer)
        ctrl.status_msg = "inserted embed: " + embed_target
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val existing = rt_file_read_text(target_path) ?? ""
    val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
    val ok = rt_file_write_text(target_path, existing + sep + embed + "\n")
    if not ok:
        ctrl.status_msg = "failed to insert embed"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.status_msg = "inserted embed: " + embed_target
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_attachment_insert(ctrl: EditorController, payload: text) -> EditorAction:
    val target_path = _editor_payload_part(payload, 0)
    val attachment_path = _editor_payload_part(payload, 1)
    val label = _editor_payload_part(payload, 2)
    val storage_dir = _editor_payload_part(payload, 3)
    if target_path == "" or attachment_path == "":
        ctrl.status_msg = "missing target or attachment path"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var embed_path = attachment_path
    if storage_dir != "":
        val stored = _editor_store_attachment_for_note(target_path, attachment_path, storage_dir)
        if stored == "":
            ctrl.status_msg = "failed to store attachment"
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        embed_path = stored
    val existing = rt_file_read_text(target_path) ?? ""
    val embed = _editor_attachment_embed(embed_path, label)
    val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
    val ok = rt_file_write_text(target_path, existing + sep + embed + "\n")
    if not ok:
        ctrl.status_msg = "failed to insert attachment"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.status_msg = "inserted attachment: " + embed_path
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_wiki_attachment_picker(ctrl: EditorController, payload: text) -> EditorAction:
    val root = _editor_payload_part(payload, 0)
    val query = _editor_payload_part(payload, 1).to_lower()
    val target_path = _editor_payload_part(payload, 2)
    val storage_dir = _editor_payload_part(payload, 3)
    if root == "":
        ctrl.status_msg = "missing attachment root"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.wiki_attachment_picker_payload = root + "|" + query + "|" + target_path + "|" + storage_dir
    ctrl.wiki_attachment_query = query
    ctrl.wiki_panel = wiki_panel_with_rows("Attachment Picker", _editor_attachment_picker_rows(root, query, target_path, storage_dir))
    ctrl_show_wiki_panel(ctrl, "attachments: " + ctrl.wiki_panel.rows.len().to_text())
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_toggle_markdown_task_line(ctrl: EditorController, line: i64) -> EditorAction:
    val doc = ctrl.session.active_document()
    val buffer = ctrl.session.active_buffer()
    if doc == nil or buffer == nil or doc.language_id != "markdown":
        ctrl.status_msg = "no markdown task"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if line < 0 or line >= buffer.line_count():
        ctrl.status_msg = "task line out of range"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val current = buffer.line_at(line)
    val toggled = md_assist_toggle_task(current)
    if toggled == current:
        ctrl.status_msg = "not a task"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    buffer.move_cursor(line, 0)
    var i = 0
    while i < current.len():
        buffer.delete_at_cursor()
        i = i + 1
    buffer.insert_at_cursor(toggled)
    ctrl_update_markdown_preview(ctrl, doc, buffer)
    ctrl.session.update_active_buffer(buffer)
    ctrl_notify_active_lsp_changed(ctrl)
    ctrl.status_msg = "task toggled"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_markdown_table_insert_row(ctrl: EditorController) -> EditorAction:
    val doc = ctrl.session.active_document()
    val buffer = ctrl.session.active_buffer()
    if doc == nil or buffer == nil or doc.language_id != "markdown":
        ctrl.status_msg = "no markdown table"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val edit = md_table_insert_row_after(buffer.to_text(), buffer.cursor_row)
    if not edit.changed:
        ctrl.status_msg = edit.message
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    buffer.push_undo_snapshot()
    buffer.replace_content(edit.content)
    buffer.dirty = true
    buffer.move_cursor(edit.line, edit.col)
    ctrl_update_markdown_preview(ctrl, doc, buffer)
    ctrl.session.update_active_buffer(buffer)
    ctrl_notify_active_lsp_changed(ctrl)
    ctrl.status_msg = edit.message
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

