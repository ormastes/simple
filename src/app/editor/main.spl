# Editor — main entry point
#
# Launch with: bin/simple run src/app/editor/main.spl [file1.spl] [file2.spl] ...

extern fn rt_args() -> [text]

fn main():
    val args = rt_args()
    var session = EditSession.new()
    var i = 1
    while i < args.len():
        session.open_file(args[i])
        i = i + 1
    if session.document_count() == 0:
        session.open_empty()
    editor_tui_run(session)
