# Simple Editor
#
# Entry point for the editor application.
# Usage: bin/simple run src/app/editor/main.spl [file]

extern fn rt_args() -> [text]

fn main():
    val args = rt_args()
    val next_id = 1
    var buffer: EditorBuffer = EditorBuffer.from_text(EditorBufferId(value: next_id), "")

    if args.len() > 1:
        buffer = EditorBuffer.from_file(EditorBufferId(value: next_id), args[1])

    editor_tui_run(buffer)
