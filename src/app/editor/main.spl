# Editor — main entry point
#
# Launch with: bin/simple run src/app/editor/main.spl [--gui] [file1.spl] [file2.spl] ...

use std.editor.core.session.{EditSession}
use app.editor.tui_shell.{editor_tui_run}
use app.editor.gui_shell.{gui_shell_run}
use app.editor.gui_shell.{gui_shell_run_sdl}

extern fn rt_args() -> [text]

fn main():
    val args = rt_args()
    var session = EditSession.new()
    var gui_mode = false
    var sdl_mode = false
    var i = 1
    while i < args.len():
        val arg = args[i]
        if arg == "--gui":
            gui_mode = true
        elif arg == "--gui-sdl":
            gui_mode = true
            sdl_mode = true
        else:
            session.open_file(arg)
        i = i + 1
    if session.document_count() == 0:
        session.open_empty()
    if sdl_mode:
        gui_shell_run_sdl(session)
    elif gui_mode:
        gui_shell_run(session)
    else:
        editor_tui_run(session)
