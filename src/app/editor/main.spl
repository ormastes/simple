# Game Editor — main entry point
#
# Launch with: bin/simple run src/app/editor/main.spl [project-path]

use std.nogc_sync_mut.editor.app.{EditorApp}
use std.nogc_sync_mut.editor.mode.{EditorMode}
use std.common.editor.project.{EditorProject, ProjectManager}
use std.common.editor.scene_format.{SceneFile}

fn main():
    val project = EditorProject.new("Untitled", ".")
    var manager = ProjectManager.new(project)

    var app = EditorApp.new(1280.0, 720.0)
    app.new_scene("Main")

    # Add a default node so the editor is not empty
    val root = app.add_node("Root", -1)
    val root_id = root.node_id
    app.add_node("Player", root_id)
    app.add_node("Camera", root_id)
    app.add_node("Background", root_id)

    # Main loop stub — in a real app this would poll SDL events
    # and render via the engine bridge. For now, tick once to
    # verify the editor initializes correctly.
    app.tick(0.016)

    val scene_sdn = app.scene.to_sdn()
    print("Editor initialized successfully")
    val nc = app.scene.node_count()
    print("Scene nodes: {nc}")
    print(scene_sdn)
