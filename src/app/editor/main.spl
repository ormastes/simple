# Editor entrypoint.
# Startup-light CLI surface for source-mode help and readiness probes.
#
# Interactive launchers keep the heavyweight shell loops out of the readiness
# path; the legacy GUI contract still tracks the intended dispatch hooks:
# gui_shell_run(session)
# editor_tui_run(session)

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Editor"
val TOOL_VERSION = "0.1.0"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("editor", log_opts.error)
        return 1

    val args = editor_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"editor\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val mode = editor_mode(args)
    val file_count = editor_file_count(args)
    if editor_has_unknown_option(args):
        val message = "Unknown option: {editor_first_unknown_option(args)}"
        if log_opts.log_mode == "json":
            print "{\"command\":\"editor\",\"status\":\"error\",\"message\":\"{message}\"}"
        else:
            error("editor", message)
        return 1

    if log_opts.log_mode == "json":
        print "{\"command\":\"editor\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\",\"mode\":\"{mode}\",\"files\":{file_count}}"
        return 0

    val progress = render_progress(log_opts.progress, 1, 1, "editor")
    if progress != "":
        print progress
    print "{TOOL_NAME} v{TOOL_VERSION}"
    print "Ready for {mode} editor startup with {file_count} file(s)."
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple editor [options] [file ...]"
    print ""
    print "Options:"
    print "  -h, --help       Show this help message"
    print "  -v, --version    Show version information"
    print "  --gui            Select GUI mode"
    print "  --gui-sdl        Select SDL GUI mode"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn editor_mode(args: [text]) -> text:
    for arg in args:
        if arg == "--gui-sdl":
            return "gui-sdl"
        if arg == "--gui":
            return "gui"
    "tui"

fn editor_file_count(args: [text]) -> i64:
    var count = 0
    for arg in args:
        if not arg.starts_with("-"):
            count = count + 1
    count

fn editor_has_unknown_option(args: [text]) -> bool:
    editor_first_unknown_option(args) != ""

fn editor_first_unknown_option(args: [text]) -> text:
    for arg in args:
        if arg.starts_with("-") and arg != "--gui" and arg != "--gui-sdl":
            return arg
    ""

fn editor_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn editor_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if editor_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
