    if trimmed == "lsp-back" or trimmed == "definition-back":
        return editor_cmd("lsp-back")
    if trimmed == "keyboard-shortcuts" or trimmed == "shortcuts":
        return editor_cmd("keyboard-shortcuts")
    if trimmed == "debug-start" or trimmed == "debug":
        return editor_cmd("debug-start")
    if trimmed == "debug-process-start" or trimmed == "debug-process":
        return editor_cmd("debug-process-start")
    if trimmed == "debug-configs" or trimmed == "debug-select":
        return editor_cmd("debug-configs")
    if trimmed == "debug-console" or trimmed == "debug-session":
        return editor_cmd("debug-console")
    if trimmed == "debug-sessions":
        return editor_cmd("debug-sessions")
    if trimmed.starts_with("debug-configs "):
        return editor_cmd_with("debug-configs", trimmed.slice(14, trimmed.len()).trim())
    if trimmed.starts_with("debug-start "):
