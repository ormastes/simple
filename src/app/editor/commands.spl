    if trimmed.starts_with("template-insert "):
        return editor_cmd_with("template-insert", trimmed.slice(16, trimmed.len()).trim())
    if trimmed.starts_with("template-picker "):
        return editor_cmd_with("template-picker", trimmed.slice(16, trimmed.len()).trim())
    if trimmed.starts_with("wiki-embed-insert "):
        return editor_cmd_with("wiki-embed-insert", trimmed.slice(18, trimmed.len()).trim())
    if trimmed.starts_with("attachment-insert "):
        return editor_cmd_with("attachment-insert", trimmed.slice(18, trimmed.len()).trim())
    if trimmed.starts_with("attachment-picker "):
        return editor_cmd_with("attachment-picker", trimmed.slice(18, trimmed.len()).trim())
    if trimmed == "wiki-backlinks":
