        return editor_cmd("range-formatting-save")
    if trimmed == "signature-help":
        return editor_cmd("signature-help")
    if trimmed == "signature-next":
        return editor_cmd("signature-next")
    if trimmed == "signature-prev":
        return editor_cmd("signature-prev")
    if trimmed == "signature-dismiss":
        return editor_cmd("signature-dismiss")
    if trimmed == "document-links":
        return editor_cmd("document-links")
    if trimmed == "open-link":
        return editor_cmd("open-link")
    if trimmed == "folding-ranges":
        return editor_cmd("folding-ranges")
    if trimmed == "fold-all":
        return editor_cmd("fold-all")
    if trimmed == "unfold-all":
        return editor_cmd("unfold-all")
    if trimmed == "fold-toggle":
