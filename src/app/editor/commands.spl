# Editor Commands
#
# Table-driven command dispatch for the editor.
# Maps key inputs to buffer mutations via EditCommand/EditResult.

fn editor_dispatch(buffer: EditorBuffer, cmd: EditCommand) -> EditResult:
    match cmd.name:
        "move-left":
            buffer.move_relative(0, 0 - cmd.count)
            edit_ok("left")
        "move-right":
            buffer.move_relative(0, cmd.count)
            edit_ok("right")
        "move-up":
            buffer.move_relative(0 - cmd.count, 0)
            edit_ok("up")
        "move-down":
            buffer.move_relative(cmd.count, 0)
            edit_ok("down")
        "move-line-start":
            buffer.move_to_line_start()
            edit_ok("home")
        "move-line-end":
            buffer.move_to_line_end()
            edit_ok("end")
        "move-file-top":
            buffer.move_cursor(0, 0)
            edit_ok("top")
        "move-file-bottom":
            buffer.move_cursor(buffer.line_count() - 1, 0)
            edit_ok("bottom")
        "insert-text":
            buffer.insert_at_cursor(cmd.payload)
            edit_ok("inserted")
        "newline":
            buffer.insert_at_cursor("\n")
            edit_ok("newline")
        "backspace":
            buffer.delete_before_cursor()
            edit_ok("backspace")
        "delete":
            buffer.delete_at_cursor()
            edit_ok("delete")
        "undo":
            buffer.undo()
            edit_ok("undo")
        "redo":
            buffer.redo()
            edit_ok("redo")
        "save":
            val ok = buffer.save()
            if ok:
                edit_ok("saved {buffer.path}")
            else:
                edit_fail("save failed")
        "save-as":
            val ok = buffer.save_as(cmd.payload)
            if ok:
                edit_ok("saved {cmd.payload}")
            else:
                edit_fail("save failed")
        "quit":
            edit_quit()
        "force-quit":
            edit_quit()
        _:
            edit_fail("unknown command: {cmd.name}")

fn editor_cmd(name: text) -> EditCommand:
    EditCommand(name: name, payload: "", count: 1)

fn editor_cmd_with(name: text, payload: text) -> EditCommand:
    EditCommand(name: name, payload: payload, count: 1)

fn editor_cmd_count(name: text, count: i64) -> EditCommand:
    EditCommand(name: name, payload: "", count: count)

fn editor_parse_commandline(line: text) -> EditCommand:
    val trimmed = line.trim()
    if trimmed == "w":
        return editor_cmd("save")
    if trimmed == "q":
        return editor_cmd("quit")
    if trimmed == "q!":
        return editor_cmd("force-quit")
    if trimmed == "wq":
        return editor_cmd("save")
    if trimmed.starts_with("w "):
        return editor_cmd_with("save-as", trimmed.slice(2, trimmed.len()).trim())
    editor_cmd_with("unknown", trimmed)
