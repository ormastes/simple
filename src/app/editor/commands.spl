fn editor_all_commands() -> [PaletteEntry]:
    var cmds: [PaletteEntry] = []
    cmds.push(PaletteEntry(name: "Open File", description: "Open a file by path", command_name: "open-file", command_payload: ""))
    cmds.push(PaletteEntry(name: "Save", description: "Save current file", command_name: "save", command_payload: ""))
    cmds.push(PaletteEntry(name: "Save As", description: "Save current file to a new path", command_name: "save-as", command_payload: ""))
    cmds.push(PaletteEntry(name: "Quit", description: "Quit the editor", command_name: "quit", command_payload: ""))
    cmds.push(PaletteEntry(name: "Force Quit", description: "Quit without saving", command_name: "force-quit", command_payload: ""))
    cmds.push(PaletteEntry(name: "Tab Next", description: "Switch to next tab", command_name: "tab-next", command_payload: ""))
    cmds.push(PaletteEntry(name: "Tab Prev", description: "Switch to previous tab", command_name: "tab-prev", command_payload: ""))
    cmds.push(PaletteEntry(name: "Tab Close", description: "Close current tab", command_name: "tab-close", command_payload: ""))
    cmds.push(PaletteEntry(name: "Split Vertical", description: "Split editor vertically", command_name: "split-vertical", command_payload: ""))
    cmds.push(PaletteEntry(name: "Split Horizontal", description: "Split editor horizontally", command_name: "split-horizontal", command_payload: ""))
    cmds.push(PaletteEntry(name: "Close Other Groups", description: "Close all groups except active", command_name: "close-other-groups", command_payload: ""))
    cmds.push(PaletteEntry(name: "Resize Grow", description: "Grow active split pane", command_name: "resize-grow", command_payload: ""))
    cmds.push(PaletteEntry(name: "Resize Shrink", description: "Shrink active split pane", command_name: "resize-shrink", command_payload: ""))
