# Editor Commands
#
# Table-driven command dispatch for the editor.
# Session-level commands (tabs, files) and buffer-level commands (movement, editing).

fn editor_dispatch_session(session: EditSession, cmd: EditCommand) -> EditResult:
    match cmd.name:
        "open-file":
            if cmd.payload == "":
                return edit_fail("usage: :e <path>")
            session.open_file(cmd.payload)
            val p = cmd.payload
            edit_ok("opened {p}")
        "tab-next":
            session.switch_tab(1)
            edit_ok("next tab")
        "tab-prev":
            session.switch_tab(0 - 1)
            edit_ok("prev tab")
        "tab-close":
            session.close_tab()
            edit_ok("tab closed")
        "split-vertical":
            session.split_editor()
            edit_ok("split vertical")
        "split-horizontal":
            session.split_editor_horizontal()
            edit_ok("split horizontal")
        "close-other-groups":
            session.close_other_groups()
            edit_ok("only")
        "resize-grow":
            session.layout.tree.resize(session.layout.active_group_id, 5)
            edit_ok("resize grow")
        "resize-shrink":
            session.layout.tree.resize(session.layout.active_group_id, 0 - 5)
            edit_ok("resize shrink")
        "focus-next":
            session.focus_next_group()
            edit_ok("focus next")
        "focus-prev":
            session.focus_prev_group()
            edit_ok("focus prev")
        "save":
            val ok = session.save_active()
            if ok:
                val doc_save = session.active_document()
                if doc_save != nil and doc_save.language_id == "markdown":
                    val buf_save = session.active_buffer()
                    if buf_save != nil:
                        val save_content = md_buffer_content(buf_save)
                        doc_save.cached_md_stats = md_compute_stats(save_content)
                        val diags = md_diagnose(save_content, doc_save.path())
                        val dcount = diags.len()
                        if dcount > 0:
                            return edit_ok("saved ({dcount} diagnostics)")
                edit_ok("saved")
            else:
                edit_fail("save failed")
        "open-dialog":
            val path = editor_open_file_dialog()
            if path != "":
                session.open_file(path)
                edit_ok("opened dialog file")
            else:
                edit_ok("cancelled")
        "save-dialog":
            val buffer_sd = session.active_buffer()
            if buffer_sd == nil:
                return edit_fail("no file open")
            val save_path = editor_save_file_dialog()
            if save_path != "":
                buffer_sd.save_as(save_path)
                edit_ok("saved as dialog file")
            else:
                edit_ok("cancelled")
        "clipboard-copy":
            val buffer_cc = session.active_buffer()
            if buffer_cc == nil:
                return edit_fail("no file open")
            val row_cc = buffer_cc.cursor_row_value()
            val line_cc = buffer_cc.line_at(row_cc)
            editor_clipboard_copy(line_cc)
            edit_ok("copied")
        "clipboard-paste":
            val buffer_cp = session.active_buffer()
            if buffer_cp == nil:
                return edit_fail("no file open")
            val paste_text = editor_clipboard_paste()
            if paste_text != "":
                buffer_cp.insert_at_cursor(paste_text)
            edit_ok("pasted")
        "quit":
            edit_quit()
        "force-quit":
            edit_quit()
        _:
            val buffer = session.active_buffer()
            if buffer == nil:
                return edit_fail("no file open")
            editor_dispatch(buffer, cmd)

fn editor_dispatch(buffer: EditorBuffer, cmd: EditCommand) -> EditResult:
    match cmd.name:
        "move-left":
            buffer.move_relative(0, 0 - cmd.count)
            edit_ok("left")
        "move-right":
            buffer.move_relative(0, cmd.count)
            edit_ok("right")
        "move-up":
            buffer.move_relative(0 - cmd.count, 0)
            edit_ok("up")
        "move-down":
            buffer.move_relative(cmd.count, 0)
            edit_ok("down")
        "move-line-start":
            buffer.move_to_line_start()
            edit_ok("home")
        "move-line-end":
            buffer.move_to_line_end()
            edit_ok("end")
        "move-file-top":
            buffer.move_cursor(0, 0)
            edit_ok("top")
        "move-file-bottom":
            buffer.move_cursor(buffer.line_count() - 1, 0)
            edit_ok("bottom")
        "insert-text":
            buffer.insert_at_cursor(cmd.payload)
            edit_ok("inserted")
        "newline":
            buffer.insert_at_cursor("\n")
            edit_ok("newline")
        "backspace":
            buffer.delete_before_cursor()
            edit_ok("backspace")
        "delete":
            buffer.delete_at_cursor()
            edit_ok("delete")
        "undo":
            buffer.undo()
            edit_ok("undo")
        "redo":
            buffer.redo()
            edit_ok("redo")
        "save":
            val ok = buffer.save()
            if ok:
                val bp = buffer.path
                edit_ok("saved {bp}")
            else:
                edit_fail("save failed")
        "save-as":
            val ok = buffer.save_as(cmd.payload)
            if ok:
                val sp = cmd.payload
                edit_ok("saved {sp}")
            else:
                edit_fail("save failed")
        "quit":
            edit_quit()
        "force-quit":
            edit_quit()
        _:
            val cn = cmd.name
            edit_fail("unknown command: {cn}")

fn editor_cmd(name: text) -> EditCommand:
    EditCommand(name: name, payload: "", count: 1)

fn editor_cmd_with(name: text, payload: text) -> EditCommand:
    EditCommand(name: name, payload: payload, count: 1)

fn editor_cmd_count(name: text, count: i64) -> EditCommand:
    EditCommand(name: name, payload: "", count: count)

fn editor_parse_commandline(line: text) -> EditCommand:
    val trimmed = line.trim()
    if trimmed == "w":
        return editor_cmd("save")
    if trimmed == "q":
        return editor_cmd("quit")
    if trimmed == "q!":
        return editor_cmd("force-quit")
    if trimmed == "wq":
        return editor_cmd("save")
    if trimmed.starts_with("w "):
        return editor_cmd_with("save-as", trimmed.slice(2, trimmed.len()).trim())
    if trimmed.starts_with("e "):
        return editor_cmd_with("open-file", trimmed.slice(2, trimmed.len()).trim())
    if trimmed.starts_with("edit "):
        return editor_cmd_with("open-file", trimmed.slice(5, trimmed.len()).trim())
    if trimmed == "bn" or trimmed == "tabn":
        return editor_cmd("tab-next")
    if trimmed == "bp" or trimmed == "tabp":
        return editor_cmd("tab-prev")
    if trimmed == "bd" or trimmed == "tabc":
        return editor_cmd("tab-close")
    if trimmed == "vs" or trimmed == "vsplit":
        return editor_cmd("split-vertical")
    if trimmed == "sp" or trimmed == "split":
        return editor_cmd("split-horizontal")
    if trimmed == "only":
        return editor_cmd("close-other-groups")
    if trimmed == "open":
        return editor_cmd("open-dialog")
    if trimmed == "saveas":
        return editor_cmd("save-dialog")
    if trimmed == "settings":
        return editor_cmd("settings")
    if trimmed == "palette":
        return editor_cmd("palette")
    if trimmed == "preview":
        return editor_cmd("preview")
    if trimmed == "outline":
        return editor_cmd("outline")
    if trimmed == "quickfix":
        return editor_cmd("quickfix")
    if trimmed == "quickfix-apply":
        return editor_cmd("quickfix-apply")
    if trimmed == "problems":
        return editor_cmd("problems")
    if trimmed.starts_with("diagnostics-filter "):
        return editor_cmd_with("diagnostics-filter", trimmed.slice(19, trimmed.len()).trim())
    if trimmed.starts_with("diagnostics-group "):
        return editor_cmd_with("diagnostics-group", trimmed.slice(18, trimmed.len()).trim())
    if trimmed.starts_with("diagnostics-sort "):
        return editor_cmd_with("diagnostics-sort", trimmed.slice(17, trimmed.len()).trim())
    if trimmed == "completion" or trimmed == "suggest":
        return editor_cmd("completion")
    if trimmed == "hover":
        return editor_cmd("hover")
    if trimmed == "hover-dismiss":
        return editor_cmd("hover-dismiss")
    if trimmed == "definition" or trimmed == "goto-definition":
        return editor_cmd("definition")
    if trimmed == "code-action":
        return editor_cmd("code-action")
    if trimmed == "references":
        return editor_cmd("references")
    if trimmed == "selection-ranges" or trimmed == "selection-range":
        return editor_cmd("selection-ranges")
    if trimmed == "selection-expand" or trimmed == "expand-selection":
        return editor_cmd("selection-expand")
    if trimmed == "selection-shrink" or trimmed == "shrink-selection":
        return editor_cmd("selection-shrink")
    if trimmed == "selection-apply-all":
        return editor_cmd("selection-apply-all")
    if trimmed == "document-symbols":
        return editor_cmd("document-symbols")
    if trimmed == "prepare-rename":
        return editor_cmd("prepare-rename")
    if trimmed.starts_with("rename-preview "):
        return editor_cmd_with("rename-preview", trimmed.slice(15, trimmed.len()).trim())
    if trimmed == "rename-confirm":
        return editor_cmd("rename-confirm")
    if trimmed == "workspace-edit-cancel" or trimmed == "rename-cancel" or trimmed == "formatting-cancel":
        return editor_cmd("workspace-edit-cancel")
    if trimmed.starts_with("rename "):
        return editor_cmd_with("rename", trimmed.slice(7, trimmed.len()).trim())
    if trimmed == "formatting" or trimmed == "format":
        return editor_cmd("formatting")
    if trimmed == "formatting-preview" or trimmed == "format-preview":
        return editor_cmd("formatting-preview")
    if trimmed == "formatting-save" or trimmed == "format-save":
        return editor_cmd("formatting-save")
    if trimmed == "range-formatting" or trimmed == "range-format":
