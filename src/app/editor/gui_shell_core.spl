fn _gui_vault_search_filter_state(state: GuiShellState, filter: text) -> GuiShellState:
    var ctrl = state.ctrl
    if ctrl.wiki_vault_search_root == "" or ctrl.wiki_vault_search_query == "":
        ctrl.status_msg = "missing vault search context"
        state.ctrl = ctrl
        return state
    val query = md_vault_search_query_replace_kind_filter(ctrl.wiki_vault_search_query, filter)
    val action = ctrl._execute_palette_command("wiki-vault-search", ctrl.wiki_vault_search_root + "|" + query)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

