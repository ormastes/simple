fn _gui_task_toggle_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    val doc = ctrl.session.active_document()
    val buffer = ctrl.session.active_buffer()
    if doc == nil or buffer == nil or doc.language_id != "markdown":
        ctrl.status_msg = "no markdown task"
        state.ctrl = ctrl
        return state
    val line = data.to_i64()
    val action = ctrl._toggle_markdown_task_line(line)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_handle_key(state: GuiShellState, key: text):
    val gui_key = _gui_translate_key(key)
    if gui_key == "":
        return
    if gui_key == "Ctrl+P":
        state.ctrl._open_palette()
        state.ctrl.status_msg = "command palette"
        return
    if gui_key == "Ctrl+Shift+V":
        state.ctrl._toggle_md_preview()
        return
    if gui_key == "Ctrl+Shift+O":
        state.ctrl._toggle_md_outline()
        return
    if gui_key == "Ctrl+Space":
        val action_completion = state.ctrl._request_active_lsp_action("completion")
        state.ctrl.status_msg = action_completion.status_msg
        return
    if gui_key == "F12":
        val action_definition = state.ctrl._request_active_lsp_action("definition")
        state.ctrl.status_msg = action_definition.status_msg
        return
    if gui_key == "Ctrl+.":
        val action_quickfix = state.ctrl._request_quickfix()
        state.ctrl.status_msg = action_quickfix.status_msg
        return
    if gui_key == "Shift+Alt+Right":
        val action_expand = state.ctrl._expand_lsp_selection_range()
        state.ctrl.status_msg = action_expand.status_msg
        return
    if gui_key == "Shift+Alt+Left":
        val action_shrink = state.ctrl._shrink_lsp_selection_range()
        state.ctrl.status_msg = action_shrink.status_msg
        return
    if gui_key == "F5":
        val action_debug = state.ctrl._start_debug_adapter("simple")
        state.ctrl.status_msg = action_debug.status_msg
        return
    if gui_key == "Ctrl+S":
        state.ctrl.session.save_active()
        val doc_gs = state.ctrl.session.active_document()
        if doc_gs != nil and doc_gs.language_id == "markdown":
            val buf_gs = state.ctrl.session.active_buffer()
            if buf_gs != nil:
                val gs_content = md_buffer_content(buf_gs)
                doc_gs.cached_md_stats = md_compute_stats(gs_content)
        state.ctrl.status_msg = "saved"
        return
    if gui_key == "Ctrl+O":
        state.ctrl.status_msg = "open dialog"
        return
    if gui_key == "Ctrl+C":
        val copy_result = editor_dispatch_session(state.ctrl.session, EditCommand(name: "clipboard-copy", count: 1, payload: ""))
        state.ctrl.status_msg = copy_result.message
        return
    if gui_key == "Ctrl+V":
        val paste_result = editor_dispatch_session(state.ctrl.session, EditCommand(name: "clipboard-paste", count: 1, payload: ""))
        state.ctrl.status_msg = paste_result.message
        return
    val rects = editor_layout_compute_rects(state.ctrl.session.layout, state.config.initial_width, state.config.initial_height)
    state.ctrl.handle_key(gui_key, rects)

fn _gui_handle_text(state: GuiShellState, text_data: text):
    if text_data == "":
        return
    val rects = editor_layout_compute_rects(state.ctrl.session.layout, state.config.initial_width, state.config.initial_height)
    var idx = 0
    while idx < text_data.len():
        state.ctrl.handle_key(text_data.char_at(idx), rects)
        idx = idx + 1

fn _gui_translate_key(key: text) -> text:
    if key == "Escape":
        return "\x1b"
    if key == "Enter":
        return "\r"
    if key == "Backspace":
        return "\x7f"
    if key == "Ctrl+B":
        return "\x02"
    if key == "Ctrl+W":
        return "\x17"
    if key == "Tab":
        return "\t"
    key

fn _gui_handle_resize(state: GuiShellState, data: text):
    val comma_idx = data.index_of(",")
    if comma_idx < 0:
        return
    val w_str = data.slice(0, comma_idx)
    val h_str = data.slice(comma_idx + 1, data.len())
    state.config.initial_width = w_str.to_i64()
    state.config.initial_height = h_str.to_i64()

fn _gui_handle_file_tree_select(state: GuiShellState, path: text):
    state.ctrl.session.open_file(path)
    _gui_activate_active_language(state)
    state.ctrl.focus_panel = "editor"

fn _gui_handle_tab_select(state: GuiShellState, tab_index_str: text):
    val tab_index = tab_index_str.to_i64()
    val group_idx = state.ctrl.session.layout.active_group_index
    if group_idx < 0 or group_idx >= state.ctrl.session.layout.groups.len():
        return
    var group = state.ctrl.session.layout.groups[group_idx]
    group.select_tab(tab_index)
    state.ctrl.session.layout.groups[group_idx] = group

fn _gui_handle_settings_change(state: GuiShellState, data: text):
    val eq_idx = data.index_of("=")
    if eq_idx < 0:
        return
    val key = data.slice(0, eq_idx)
    val value = data.slice(eq_idx + 1, data.len())
    state.ctrl.config = editor_config_set_by_key(state.ctrl.config, key, value)

fn _gui_editor_ctrl_click_state(state: GuiShellState, data: text) -> GuiShellState:
    var next = state
    val comma_idx = data.index_of(",")
    if comma_idx < 0:
        var ctrl_invalid = next.ctrl
        ctrl_invalid.status_msg = "invalid editor click"
        next.ctrl = ctrl_invalid
        return next
    val line_text = data.slice(0, comma_idx)
    val col_text = data.slice(comma_idx + 1, data.len())
    val line = line_text.to_i64()
    val col = col_text.to_i64()
    var ctrl = next.ctrl
    var buffer = ctrl.session.active_buffer()
    if buffer == nil:
        ctrl.status_msg = "no active buffer"
        next.ctrl = ctrl
        return next
    buffer.move_cursor(line, col)
    ctrl.session.update_active_buffer(buffer)
    val action = ctrl._open_markdown_link_under_cursor()
    ctrl.status_msg = action.status_msg
    next.ctrl = ctrl
    next

fn _gui_wiki_panel_click_state(state: GuiShellState, data: text) -> GuiShellState:
    var next = state
    var ctrl = next.ctrl
    val index = data.to_i64()
    ctrl.wiki_panel = wiki_panel_select(ctrl.wiki_panel, index)
    val action = ctrl._wiki_jump_selected()
    ctrl.status_msg = action.status_msg
    next.ctrl = ctrl
    next

fn _gui_activate_active_language(state: GuiShellState):
    val doc = state.ctrl.session.active_document()
    if doc == nil:
        return
    state.ctrl.extension_host.activate_language(doc.language_id)
    state.ctrl.extension_host.emit_event("onDidOpenTextDocument", doc.path())
    state.ctrl.extension_host.emit_event("onLanguage:" + doc.language_id, doc.path())

# --- Drag/docking for dock panels ---

fn _drag_state_new() -> DragState:
    DragState(active: false, source_panel_id: "", source_zone: -1, mouse_x: 0, mouse_y: 0, drop_target_zone: -1)

fn gui_handle_mouse_down(state: GuiShellState, drag: DragState, x: i64, y: i64) -> DragState:
    val dock = state.ctrl.session.dock_layout
    val zones: [i64] = [DOCK_LEFT, DOCK_RIGHT, DOCK_BOTTOM]
    var zi = 0
    while zi < zones.len():
        val zone = zones[zi]
        val panels = dock.visible_panels_in(zone)
        if panels.len() > 0:
            val hit = _drag_hit_zone_tab(state, zone, x, y)
            if hit != "":
                return DragState(active: true, source_panel_id: hit, source_zone: zone, mouse_x: x, mouse_y: y, drop_target_zone: -1)
        zi = zi + 1
    drag

fn gui_handle_mouse_move(state: GuiShellState, drag: DragState, x: i64, y: i64) -> DragState:
    if not drag.active:
        return drag
    val target = gui_compute_drop_zone(state, x, y)
    DragState(active: true, source_panel_id: drag.source_panel_id, source_zone: drag.source_zone, mouse_x: x, mouse_y: y, drop_target_zone: target)

fn gui_handle_mouse_up(state: GuiShellState, drag: DragState) -> DragState:
    if not drag.active:
        return drag
    if drag.drop_target_zone >= 0 and drag.drop_target_zone != drag.source_zone:
        val dock = state.ctrl.session.dock_layout
        val panels = dock.visible_panels_in(drag.source_zone)
        var found_label = ""
        var found_icon = ""
        var pi = 0
        while pi < panels.len():
            if panels[pi].id == drag.source_panel_id:
                found_label = panels[pi].label
                found_icon = panels[pi].icon
            pi = pi + 1
        dock.remove_panel(drag.source_panel_id)
        dock.add_panel(DockPanel(id: drag.source_panel_id, label: found_label, zone: drag.drop_target_zone, icon: found_icon, visible: true))
        dock.set_active(drag.drop_target_zone, drag.source_panel_id)
    _drag_state_new()

fn gui_compute_drop_zone(state: GuiShellState, x: i64, y: i64) -> i64:
    val w = state.config.initial_width
    val h = state.config.initial_height
    val left_edge = w / 5
    val right_edge = w - w / 5
    val bottom_edge = h - h / 4
    if x < left_edge:
        return DOCK_LEFT
    if x > right_edge:
        return DOCK_RIGHT
    if y > bottom_edge:
        return DOCK_BOTTOM
    -1

fn _drag_hit_zone_tab(state: GuiShellState, zone: i64, x: i64, y: i64) -> text:
    val w = state.config.initial_width
    val h = state.config.initial_height
    val tab_h = 28
    var zone_x = 0
    var zone_y = 0
    var zone_w = 0
    if zone == DOCK_LEFT:
        zone_x = 0
        zone_y = 0
        zone_w = state.ctrl.session.dock_layout.left_width * w / 100
    elif zone == DOCK_RIGHT:
        zone_w = state.ctrl.session.dock_layout.right_width * w / 100
        zone_x = w - zone_w
        zone_y = 0
    elif zone == DOCK_BOTTOM:
        zone_x = 0
        zone_y = h - state.ctrl.session.dock_layout.bottom_height * h / 100
        zone_w = w
    if x >= zone_x and x < zone_x + zone_w and y >= zone_y and y < zone_y + tab_h:
        val panels = state.ctrl.session.dock_layout.visible_panels_in(zone)
        if panels.len() > 0:
            return panels[0].id
    ""

fn gui_shell_poll_event() -> GuiEvent:
    GuiEvent(kind: "", data: "")

fn gui_shell_poll_event_sdl() -> GuiEvent:
    gui_sdl_poll()

fn _parse_mouse_coords(data: text) -> MouseCoords:
    val comma_idx = data.index_of(",")
    if comma_idx < 0:
        return MouseCoords(x: 0, y: 0)
    val x_str = data.slice(0, comma_idx)
    val y_str = data.slice(comma_idx + 1, data.len())
    MouseCoords(x: x_str.to_i64(), y: y_str.to_i64())

fn _gui_shell_basename_without_markdown_ext(path: text) -> text:
    var name = _gui_shell_basename(path)
    if name.ends_with(".markdown"):
        name = name.slice(0, name.len() - 9)
    elif name.ends_with(".md"):
        name = name.slice(0, name.len() - 3)
    name
