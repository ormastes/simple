# Editor GUI Shell — Core
#
# GUI shell core: initialization, event routing, drag/drop.
# Rendering logic lives in gui_shell_render.spl.

use std.editor.view.diagnostics_panel.*
use std.editor.view.lsp_result_panel.*
use std.editor.view.wiki_panel.*
use std.editor.services.diagnostics.*
use std.editor.services.md_search.*

struct DragState:
    active: bool
    source_panel_id: text
    source_zone: i64
    mouse_x: i64
    mouse_y: i64
    drop_target_zone: i64

struct GuiShellState:
    ctrl: EditorController
    config: GuiBackendConfig
    platform_config: PlatformConfig
    extension_host: ExtensionHost

struct GuiShellEventResult:
    state: GuiShellState
    drag: DragState

struct GuiTableCellPayload:
    ok: bool
    line: i64
    col: i64
    value: text

struct GuiEvent:
    kind: text
    data: text

struct MouseCoords:
    x: i64
    y: i64

fn gui_shell_new(session: EditSession) -> GuiShellState:
    val ctrl = EditorController.new(session)
    GuiShellState(
        ctrl: ctrl,
        config: gui_backend_default_config(),
        platform_config: platform_default_config(EditorPlatform.Desktop),
        extension_host: ctrl.extension_host
    )

fn gui_shell_init(state: GuiShellState):
    state.ctrl.extension_host.activate_event("*")
    state.ctrl.extension_host.activate_language("simple")
    state.ctrl.extension_host.activate_language("markdown")

fn gui_shell_run(session: EditSession):
    var state = gui_shell_new(session)
    gui_shell_init(state)
    state.ctrl.file_tree_visible = true
    var drag = _drag_state_new()

    while state.ctrl.is_running():
        state.ctrl._refresh_lsp_results()
        state.ctrl._poll_file_watcher()
        state.ctrl._poll_inlay_hint_refresh_after(100)
        state.ctrl._poll_debug_dap_client()
        val frame = gui_shell_render_frame(state)
        gui_shell_present_frame(frame)

        val event = gui_shell_poll_event()
        val handled = _gui_shell_handle_polled_event(state, drag, event)
        state = handled.state
        drag = handled.drag

fn gui_shell_run_sdl(session: EditSession):
    var state = gui_shell_new(session)
    gui_shell_init(state)
    state.ctrl.file_tree_visible = true
    var drag = _drag_state_new()
    val window = gui_sdl_init(state.config.window_title, state.config.initial_width, state.config.initial_height)
    if window == 0:
        state.ctrl.status_msg = "gui init failed"
        return

    while state.ctrl.is_running():
        state.ctrl._refresh_lsp_results()
        state.ctrl._poll_file_watcher()
        state.ctrl._poll_inlay_hint_refresh_after(100)
        state.ctrl._poll_debug_dap_client()
        val frame = gui_shell_render_frame(state)
        gui_shell_present_frame_sdl(window, frame)

        val event = gui_shell_poll_event_sdl()
        val handled = _gui_shell_handle_polled_event(state, drag, event)
        state = handled.state
        drag = handled.drag

    gui_sdl_shutdown(window)

fn _gui_shell_handle_polled_event(state: GuiShellState, drag: DragState, event: GuiEvent) -> GuiShellEventResult:
    if event.kind == "":
        return GuiShellEventResult(state: state, drag: drag)
    if event.kind == "mouse-down":
        val coords = _parse_mouse_coords(event.data)
        return GuiShellEventResult(state: state, drag: gui_handle_mouse_down(state, drag, coords.x, coords.y))
    if event.kind == "mouse-move":
        val coords = _parse_mouse_coords(event.data)
        return GuiShellEventResult(state: state, drag: gui_handle_mouse_move(state, drag, coords.x, coords.y))
    if event.kind == "mouse-up":
        return GuiShellEventResult(state: state, drag: gui_handle_mouse_up(state, drag))
    val next_state = gui_shell_handle_event(state, event.kind, event.data)
    GuiShellEventResult(state: next_state, drag: drag)

fn gui_shell_handle_event(state: GuiShellState, event_kind: text, event_data: text) -> GuiShellState:
    if event_kind == "key":
        _gui_handle_key(state, event_data)
    elif event_kind == "text":
        _gui_handle_text(state, event_data)
    elif event_kind == "resize":
        _gui_handle_resize(state, event_data)
    elif event_kind == "close":
        state.ctrl.running = false
    elif event_kind == "focus":
        state.ctrl.status_msg = "focused"
    elif event_kind == "blur":
        state.ctrl.status_msg = "unfocused"
    elif event_kind == "file-tree-select":
        _gui_handle_file_tree_select(state, event_data)
    elif event_kind == "tab-select":
        _gui_handle_tab_select(state, event_data)
    elif event_kind == "settings-change":
        _gui_handle_settings_change(state, event_data)
    elif event_kind == "link-click":
        var ctrl_link = state.ctrl
        val action_link = ctrl_link._open_markdown_link_target(event_data)
        ctrl_link.status_msg = action_link.status_msg
        state.ctrl = ctrl_link
    elif event_kind == "editor-ctrl-click":
        val click_state = _gui_editor_ctrl_click_state(state, event_data)
        state = click_state
    elif event_kind == "editor-hover":
        val hover_state = _gui_editor_hover_state(state, event_data)
        state = hover_state
    elif event_kind == "wiki-panel-click":
        val wiki_state = _gui_wiki_panel_click_state(state, event_data)
        state = wiki_state
    elif event_kind == "wiki-property-submit":
        val prop_state = _gui_wiki_property_submit_state(state, event_data)
        state = prop_state
    elif event_kind == "wiki-vault-property-submit":
        val vault_prop_state = _gui_wiki_vault_property_submit_state(state, event_data)
        state = vault_prop_state
    elif event_kind == "wiki-vault-property-review":
        val vault_prop_review_state = _gui_wiki_vault_property_review_state(state, event_data)
        state = vault_prop_review_state
    elif event_kind == "task-toggle":
        val task_state = _gui_task_toggle_state(state, event_data)
        state = task_state
    elif event_kind == "task-filter":
        val task_filter_state = _gui_task_filter_state(state, event_data)
        state = task_filter_state
    elif event_kind == "task-query":
        val task_query_state = _gui_task_query_state(state, event_data)
        state = task_query_state
    elif event_kind == "task-batch":
        val task_batch_state = _gui_task_batch_state(state, event_data)
        state = task_batch_state
    elif event_kind == "vault-search-filter":
        val vault_filter_state = _gui_vault_search_filter_state(state, event_data)
        state = vault_filter_state
    elif event_kind == "vault-search-path-filter":
        val vault_path_filter_state = _gui_vault_search_path_filter_state(state, event_data)
        state = vault_path_filter_state
    elif event_kind == "quick-switch-filter":
        val quick_switch_state = _gui_quick_switch_filter_state(state, event_data)
        state = quick_switch_state
    elif event_kind == "quick-switch-insert":
        val quick_switch_insert_state = _gui_quick_switch_insert_state(state, event_data)
        state = quick_switch_insert_state
    elif event_kind == "daily-note-create":
        val daily_state = _gui_daily_note_create_state(state, event_data)
        state = daily_state
    elif event_kind == "template-picker-filter":
        val template_filter_state = _gui_template_picker_filter_state(state, event_data)
        state = template_filter_state
    elif event_kind == "template-insert":
        val template_insert_state = _gui_template_insert_state(state, event_data)
        state = template_insert_state
    elif event_kind == "attachment-picker-filter":
        val attachment_filter_state = _gui_attachment_picker_filter_state(state, event_data)
        state = attachment_filter_state
    elif event_kind == "attachment-insert":
        val attachment_insert_state = _gui_attachment_insert_state(state, event_data)
        state = attachment_insert_state
    elif event_kind == "diagnostics-filter":
        val diag_filter_state = _gui_diagnostics_filter_state(state, event_data)
        state = diag_filter_state
    elif event_kind == "diagnostics-group":
        val diag_group_state = _gui_diagnostics_group_state(state, event_data)
        state = diag_group_state
    elif event_kind == "diagnostics-sort":
        val diag_sort_state = _gui_diagnostics_sort_state(state, event_data)
        state = diag_sort_state
    elif event_kind == "table-row-insert":
        val table_row_state = _gui_table_edit_state(state, "markdown-table-row-insert")
        state = table_row_state
    elif event_kind == "table-column-insert":
        val table_col_state = _gui_table_edit_state(state, "markdown-table-column-insert")
        state = table_col_state
    elif event_kind == "table-cell-commit":
        val table_cell_state = _gui_table_cell_commit_state(state, event_data)
        state = table_cell_state
    elif event_kind == "callout-fold-toggle":
        val callout_state = _gui_callout_fold_toggle_state(state)
        state = callout_state
    elif event_kind == "fold-toggle":
        val fold_state = _gui_fold_toggle_state(state, event_data)
        state = fold_state
    elif event_kind == "lsp-hover-dismiss":
        var ctrl_hover = state.ctrl
        val action_hover = ctrl_hover._dismiss_lsp_hover_popup()
        ctrl_hover.status_msg = action_hover.status_msg
        state.ctrl = ctrl_hover
    elif event_kind == "lsp-signature-dismiss":
        var ctrl_sig = state.ctrl
        val action_sig = ctrl_sig._dismiss_lsp_signature_popup()
        ctrl_sig.status_msg = action_sig.status_msg
        state.ctrl = ctrl_sig
    elif event_kind == "lsp-signature-next":
        var ctrl_sig_next = state.ctrl
        val action_sig_next = ctrl_sig_next._select_signature_overload(1)
        ctrl_sig_next.status_msg = action_sig_next.status_msg
        state.ctrl = ctrl_sig_next
    elif event_kind == "lsp-signature-prev":
        var ctrl_sig_prev = state.ctrl
        val action_sig_prev = ctrl_sig_prev._select_signature_overload(0 - 1)
        ctrl_sig_prev.status_msg = action_sig_prev.status_msg
        state.ctrl = ctrl_sig_prev
    elif event_kind == "workspace-edit-confirm":
        val workspace_confirm_state = _gui_workspace_edit_action_state(state, "rename-confirm")
        state = workspace_confirm_state
    elif event_kind == "workspace-edit-cancel":
        val workspace_cancel_state = _gui_workspace_edit_action_state(state, "workspace-edit-cancel")
        state = workspace_cancel_state
    elif event_kind == "lsp-result-click":
        val lsp_click_state = _gui_lsp_result_click_state(state, event_data)
        state = lsp_click_state
    elif event_kind == "lsp-back":
        val lsp_back_state = _gui_lsp_back_state(state)
        state = lsp_back_state
    elif event_kind == "code-lens-run":
        val lens_state = _gui_code_lens_run_state(state, event_data)
        state = lens_state
    elif event_kind == "inlay-hint-click":
        val hint_state = _gui_inlay_hint_click_state(state, event_data)
        state = hint_state
    elif event_kind == "code-actions-filter":
        val code_action_filter_state = _gui_code_actions_filter_state(state, event_data)
        state = code_action_filter_state
    elif event_kind == "code-actions-group":
        val code_action_group_state = _gui_code_actions_group_state(state)
        state = code_action_group_state
    state

fn _gui_callout_fold_toggle_state(state: GuiShellState) -> GuiShellState:
    var ctrl = state.ctrl
    val action = ctrl._execute_palette_command("callout-fold-toggle", "")
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_fold_toggle_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    var buffer = ctrl.session.active_buffer()
    if buffer == nil:
        ctrl.status_msg = "no file open"
        state.ctrl = ctrl
        return state
    val line = data.to_i64()
    val end_line = buffer.folded_end_line_for_header(line)
    if end_line < 0:
        buffer.move_cursor(line, 0)
        ctrl.session.update_active_buffer(buffer)
        val action = ctrl._execute_palette_command("fold-toggle", "")
        ctrl.status_msg = action.status_msg
        state.ctrl = ctrl
        return state
    buffer.unfold_range(line, end_line)
    buffer.move_cursor(line, 0)
    ctrl.session.update_active_buffer(buffer)
    ctrl.status_msg = "unfolded section"
    state.ctrl = ctrl
    state

fn _gui_lsp_back_state(state: GuiShellState) -> GuiShellState:
    var ctrl = state.ctrl
    val action = ctrl._execute_palette_command("lsp-back", "")
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_lsp_result_click_state(state: GuiShellState, row: text) -> GuiShellState:
    var ctrl = state.ctrl
    ctrl.lsp_result_panel = lsp_result_panel_select(ctrl.lsp_result_panel, row.to_i64())
    ctrl.status_msg = "lsp result selected"
    state.ctrl = ctrl
    state

fn _gui_code_lens_run_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    val sep = data.index_of("|")
    val command_name = if sep >= 0 then data.slice(0, sep) else: data
    val payload = if sep >= 0 then data.slice(sep + 1, data.len()) else: ""
    if command_name == "":
        ctrl.status_msg = "missing code lens command"
        state.ctrl = ctrl
        return state
    val action = ctrl._execute_palette_command(command_name, payload)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_code_actions_filter_state(state: GuiShellState, filter: text) -> GuiShellState:
    var ctrl = state.ctrl
    val action = ctrl._filter_code_actions(filter)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_code_actions_group_state(state: GuiShellState) -> GuiShellState:
    var ctrl = state.ctrl
    val action = ctrl._group_code_actions_by_kind()
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_inlay_hint_click_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    val comma = data.index_of(",")
    if comma < 0:
        ctrl.status_msg = "invalid inlay hint"
        state.ctrl = ctrl
        return state
    val line_text = data.slice(0, comma)
    val col_text = data.slice(comma + 1, data.len())
    val line = line_text.to_i64()
    val col = col_text.to_i64()
    var buffer = ctrl.session.active_buffer()
    if buffer == nil:
        ctrl.status_msg = "no file open"
        state.ctrl = ctrl
        return state
    buffer.move_cursor(line, col)
    ctrl.session.update_active_buffer(buffer)
    ctrl.status_msg = "inlay hint selected"
    state.ctrl = ctrl
    state

fn _gui_editor_hover_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    val comma = data.index_of(",")
    if comma < 0:
        ctrl.status_msg = "invalid hover target"
        state.ctrl = ctrl
        return state
    val line_text = data.slice(0, comma)
    val rest = data.slice(comma + 1, data.len())
    val second_comma = rest.index_of(",")
    val col_text = if second_comma >= 0 then rest.slice(0, second_comma) else: rest
    val elapsed_text = if second_comma >= 0 then rest.slice(second_comma + 1, rest.len()) else: ""
    val line = line_text.to_i64()
    val col = col_text.to_i64()
    if elapsed_text != "" and elapsed_text.to_i64() < ctrl.config.hover_delay_ms:
        ctrl.status_msg = "hover delayed"
        state.ctrl = ctrl
        return state
    if ctrl.lsp_hover_popup.visible and ctrl.lsp_hover_popup.line == line and ctrl.lsp_hover_popup.col == col:
        ctrl.status_msg = "hover unchanged"
        state.ctrl = ctrl
        return state
    var buffer = ctrl.session.active_buffer()
    if buffer == nil:
        ctrl.status_msg = "no file open"
        state.ctrl = ctrl
        return state
    buffer.move_cursor(line, col)
    ctrl.session.update_active_buffer(buffer)
    val action = ctrl._execute_palette_command("hover", "")
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_table_edit_state(state: GuiShellState, command_name: text) -> GuiShellState:
    var ctrl = state.ctrl
    val action = ctrl._execute_palette_command(command_name, "")
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_table_cell_commit_state(state: GuiShellState, data: text) -> GuiShellState:
    var ctrl = state.ctrl
    val payload = _gui_parse_table_cell_payload(data)
    if not payload.ok:
        ctrl.status_msg = "invalid table cell edit"
        state.ctrl = ctrl
        return state
    val action = ctrl._markdown_table_set_cell(payload.line, payload.col, payload.value)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

fn _gui_parse_table_cell_payload(data: text) -> GuiTableCellPayload:
    var first = -1
    var second = -1
    var i = 0
    while i < data.len():
        if data.char_at(i) == "|":
            if first < 0:
                first = i
            elif second < 0:
                second = i
                i = data.len()
        i = i + 1
    if first < 0 or second < 0:
        return GuiTableCellPayload(ok: false, line: 0, col: 0, value: "")
    val line_text = data.slice(0, first)
    val col_text = data.slice(first + 1, second)
    val line = line_text.to_i64()
    val col = col_text.to_i64()
    val value = data.slice(second + 1, data.len())
    GuiTableCellPayload(ok: true, line: line, col: col, value: value)

fn _gui_task_filter_state(state: GuiShellState, filter: text) -> GuiShellState:
    var ctrl = state.ctrl
    val mode = if filter == "" then ctrl.wiki_task_filter else: filter
    val action = ctrl._execute_palette_command("wiki-tasks", mode + "|" + ctrl.wiki_task_query)
    ctrl.status_msg = action.status_msg
    state.ctrl = ctrl
    state

