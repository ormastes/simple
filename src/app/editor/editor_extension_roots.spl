# Editor Extension Roots
#
# Extension discovery path resolution.

use std.editor.extensions.roots.{editor_extension_roots_from_inputs}
use app.io.mod.{env_get}

fn editor_extension_roots() -> [text]:
    val configured = env_get("SIMPLE_EDITOR_EXTENSION_PATH") ?? ""
    val home = env_get("HOME") ?? ""
    editor_extension_roots_from_inputs(configured, home)
