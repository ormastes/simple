# Editor GUI Shell
#
# GUI shell using Surface system and UISession for graphical rendering.
# Creates surfaces, registers event handlers, manages GUI event loop.

struct GuiShellState:
    session: EditSession
    config: GuiBackendConfig
    platform_config: PlatformConfig
    extension_host: ExtensionHost
    running: bool

fn gui_shell_new(session: EditSession) -> GuiShellState:
    GuiShellState(
        session: session,
        config: gui_backend_default_config(),
        platform_config: platform_default_config(EditorPlatform.Desktop),
        extension_host: ExtensionHost.new(),
        running: true
    )

fn gui_shell_init(state: GuiShellState):
    state.extension_host.activate("simple-language")
    state.extension_host.activate("markdown-language")

fn gui_shell_handle_event(state: GuiShellState, event_kind: text, event_data: text):
    if event_kind == "key":
        _gui_handle_key(state, event_data)
    elif event_kind == "resize":
        _gui_handle_resize(state, event_data)
    elif event_kind == "close":
        state.running = false

fn _gui_handle_key(state: GuiShellState, key: text):
    val buffer = state.session.active_buffer()
    if buffer == nil:
        return
    if state.session.mode == EditorMode.Insert:
        if key == "Escape":
            state.session.mode = EditorMode.Normal
            return
        buffer.insert_at_cursor(key)
    elif state.session.mode == EditorMode.Normal:
        if key == "i":
            state.session.mode = EditorMode.Insert

fn _gui_handle_resize(state: GuiShellState, data: text):
    pass_dn
