# Editor GUI Shell
#
# GUI shell using Surface system and UISession for graphical rendering.
# Creates surfaces for tab bar, file tree, editor area, status bar.
# Routes editing through the same EditSession as TUI mode.
# Phase 3: mouse drag/docking for dock panel reordering.

extern fn rt_gui_present_html(html: text)

struct DragState:
    active: bool
    source_panel_id: text
    source_zone: i64
    mouse_x: i64
    mouse_y: i64
    drop_target_zone: i64

struct GuiShellState:
    ctrl: EditorController
    config: GuiBackendConfig
    platform_config: PlatformConfig
    extension_host: ExtensionHost

fn gui_shell_new(session: EditSession) -> GuiShellState:
    GuiShellState(
        ctrl: EditorController.new(session),
        config: gui_backend_default_config(),
        platform_config: platform_default_config(EditorPlatform.Desktop),
        extension_host: ExtensionHost.new()
    )

fn gui_shell_init(state: GuiShellState):
    state.extension_host.activate("simple-language")
    state.extension_host.activate("markdown-language")

fn gui_shell_run(session: EditSession):
    var state = gui_shell_new(session)
    gui_shell_init(state)
    state.ctrl.file_tree_visible = true
    var drag = _drag_state_new()

    while state.ctrl.is_running():
        val frame = gui_shell_render_frame(state)
        gui_shell_present_frame(frame)

        val event = gui_shell_poll_event()
        if event.kind != "":
            if event.kind == "mouse-down":
                val coords = _parse_mouse_coords(event.data)
                drag = gui_handle_mouse_down(state, drag, coords.x, coords.y)
            elif event.kind == "mouse-move":
                val coords = _parse_mouse_coords(event.data)
                drag = gui_handle_mouse_move(state, drag, coords.x, coords.y)
            elif event.kind == "mouse-up":
                drag = gui_handle_mouse_up(state, drag)
            else:
                gui_shell_handle_event(state, event.kind, event.data)

fn gui_shell_handle_event(state: GuiShellState, event_kind: text, event_data: text):
    if event_kind == "key":
        _gui_handle_key(state, event_data)
    elif event_kind == "resize":
        _gui_handle_resize(state, event_data)
    elif event_kind == "close":
        state.ctrl.running = false
    elif event_kind == "file-tree-select":
        _gui_handle_file_tree_select(state, event_data)
    elif event_kind == "tab-select":
        _gui_handle_tab_select(state, event_data)
    elif event_kind == "settings-change":
        _gui_handle_settings_change(state, event_data)

fn _gui_handle_key(state: GuiShellState, key: text):
    val gui_key = _gui_translate_key(key)
    if gui_key == "":
        return
    if gui_key == "Ctrl+P":
        state.ctrl._open_palette()
        state.ctrl.status_msg = "command palette"
        return
    if gui_key == "Ctrl+Shift+V":
        state.ctrl._toggle_md_preview()
        return
    if gui_key == "Ctrl+Shift+O":
        state.ctrl._toggle_md_outline()
        return
    if gui_key == "Ctrl+S":
        state.ctrl.session.save_active()
        val doc_gs = state.ctrl.session.active_document()
        if doc_gs != nil and doc_gs.language_id == "markdown":
            val buf_gs = state.ctrl.session.active_buffer()
            if buf_gs != nil:
                val gs_content = md_buffer_content(buf_gs)
                doc_gs.cached_md_stats = md_compute_stats(gs_content)
        state.ctrl.status_msg = "saved"
        return
    if gui_key == "Ctrl+O":
        state.ctrl.status_msg = "open dialog"
        return
    val rects = editor_layout_compute_rects(state.ctrl.session.layout, state.config.initial_width, state.config.initial_height)
    state.ctrl.handle_key(gui_key, rects)

fn _gui_translate_key(key: text) -> text:
    if key == "Escape":
        return "\x1b"
    if key == "Enter":
        return "\r"
    if key == "Backspace":
        return "\x7f"
    if key == "Ctrl+B":
        return "\x02"
    if key == "Ctrl+W":
        return "\x17"
    if key == "Tab":
        return "\t"
    key

fn _gui_handle_resize(state: GuiShellState, data: text):
    val comma_idx = data.index_of(",")
    if comma_idx < 0:
        return
    val w_str = data.slice(0, comma_idx)
    val h_str = data.slice(comma_idx + 1, data.len())
    state.config.initial_width = w_str.to_i64()
    state.config.initial_height = h_str.to_i64()

fn _gui_handle_file_tree_select(state: GuiShellState, path: text):
    state.ctrl.session.open_file(path)
    state.ctrl.focus_panel = "editor"

fn _gui_handle_tab_select(state: GuiShellState, tab_index_str: text):
    val tab_index = tab_index_str.to_i64()
    val group_idx = state.ctrl.session.layout.active_group_index
    if group_idx < 0 or group_idx >= state.ctrl.session.layout.groups.len():
        return
    var group = state.ctrl.session.layout.groups[group_idx]
    group.select_tab(tab_index)
    state.ctrl.session.layout.groups[group_idx] = group

fn _gui_handle_settings_change(state: GuiShellState, data: text):
    val eq_idx = data.index_of("=")
    if eq_idx < 0:
        return
    val key = data.slice(0, eq_idx)
    val value = data.slice(eq_idx + 1, data.len())
    state.ctrl.config = editor_config_set_by_key(state.ctrl.config, key, value)

# --- Drag/docking for dock panels ---

fn _drag_state_new() -> DragState:
    DragState(active: false, source_panel_id: "", source_zone: -1, mouse_x: 0, mouse_y: 0, drop_target_zone: -1)

fn gui_handle_mouse_down(state: GuiShellState, drag: DragState, x: i64, y: i64) -> DragState:
    val dock = state.ctrl.session.dock_layout
    val zones: [i64] = [DOCK_LEFT, DOCK_RIGHT, DOCK_BOTTOM]
    var zi = 0
    while zi < zones.len():
        val zone = zones[zi]
        val panels = dock.visible_panels_in(zone)
        if panels.len() > 0:
            val hit = _drag_hit_zone_tab(state, zone, x, y)
            if hit != "":
                return DragState(active: true, source_panel_id: hit, source_zone: zone, mouse_x: x, mouse_y: y, drop_target_zone: -1)
        zi = zi + 1
    drag

fn gui_handle_mouse_move(state: GuiShellState, drag: DragState, x: i64, y: i64) -> DragState:
    if not drag.active:
        return drag
    val target = gui_compute_drop_zone(state, x, y)
    DragState(active: true, source_panel_id: drag.source_panel_id, source_zone: drag.source_zone, mouse_x: x, mouse_y: y, drop_target_zone: target)

fn gui_handle_mouse_up(state: GuiShellState, drag: DragState) -> DragState:
    if not drag.active:
        return drag
    if drag.drop_target_zone >= 0 and drag.drop_target_zone != drag.source_zone:
        val dock = state.ctrl.session.dock_layout
        val panels = dock.visible_panels_in(drag.source_zone)
        var found_label = ""
        var found_icon = ""
        var pi = 0
        while pi < panels.len():
            if panels[pi].id == drag.source_panel_id:
                found_label = panels[pi].label
                found_icon = panels[pi].icon
            pi = pi + 1
        dock.remove_panel(drag.source_panel_id)
        dock.add_panel(DockPanel(id: drag.source_panel_id, label: found_label, zone: drag.drop_target_zone, icon: found_icon, visible: true))
        dock.set_active(drag.drop_target_zone, drag.source_panel_id)
    _drag_state_new()

fn gui_compute_drop_zone(state: GuiShellState, x: i64, y: i64) -> i64:
    val w = state.config.initial_width
    val h = state.config.initial_height
    val left_edge = w / 5
    val right_edge = w - w / 5
    val bottom_edge = h - h / 4
    if x < left_edge:
        return DOCK_LEFT
    if x > right_edge:
        return DOCK_RIGHT
    if y > bottom_edge:
        return DOCK_BOTTOM
    -1

fn gui_render_drop_overlay(drag: DragState, width: i64, height: i64) -> text:
    if not drag.active:
        return ""
    if drag.drop_target_zone < 0:
        return ""
    var zone_style = ""
    if drag.drop_target_zone == DOCK_LEFT:
        zone_style = "left:0;top:0;width:20%;height:100%"
    elif drag.drop_target_zone == DOCK_RIGHT:
        zone_style = "right:0;top:0;width:20%;height:100%"
    elif drag.drop_target_zone == DOCK_BOTTOM:
        zone_style = "left:0;bottom:0;width:100%;height:25%"
    else:
        return ""
    "<div class=\"drop-overlay\" style=\"position:absolute;" + zone_style + ";background:rgba(0,120,215,0.3);pointer-events:none;\"></div>"

fn _drag_hit_zone_tab(state: GuiShellState, zone: i64, x: i64, y: i64) -> text:
    val w = state.config.initial_width
    val h = state.config.initial_height
    val tab_h = 28
    var zone_x = 0
    var zone_y = 0
    var zone_w = 0
    if zone == DOCK_LEFT:
        zone_x = 0
        zone_y = 0
        zone_w = state.ctrl.session.dock_layout.left_width * w / 100
    elif zone == DOCK_RIGHT:
        zone_w = state.ctrl.session.dock_layout.right_width * w / 100
        zone_x = w - zone_w
        zone_y = 0
    elif zone == DOCK_BOTTOM:
        zone_x = 0
        zone_y = h - state.ctrl.session.dock_layout.bottom_height * h / 100
        zone_w = w
    if x >= zone_x and x < zone_x + zone_w and y >= zone_y and y < zone_y + tab_h:
        val panels = state.ctrl.session.dock_layout.visible_panels_in(zone)
        if panels.len() > 0:
            return panels[0].id
    ""


struct GuiFrame:
    tab_bar_html: text
    file_tree_html: text
    editor_html: text
    status_html: text

fn gui_shell_render_frame(state: GuiShellState) -> GuiFrame:
    val buffer = state.ctrl.active_buffer()
    val tab_bar = gui_render_tab_bar_html(state.ctrl.session)
    var file_tree_html = ""
    if state.ctrl.file_tree_visible:
        file_tree_html = gui_render_file_tree_html(state.ctrl.file_tree)
    var editor_html = ""
    if state.ctrl.settings_view != nil:
        editor_html = gui_render_settings_html(state.ctrl.settings_view, state.ctrl.config)
    elif buffer != nil:
        val doc = state.ctrl.session.active_document()
        var lang = "text"
        if doc != nil:
            lang = doc.language_id
        editor_html = gui_render_editor_area(buffer, lang, buffer.viewport)
    else:
        editor_html = "<div class=\"empty\">No file open</div>"
    var right_panel_html = ""
    val doc_frame = state.ctrl.session.active_document()
    if doc_frame != nil and doc_frame.md_state != nil:
        if doc_frame.md_state.preview_visible:
            val preview_lines = preview_pane_render(doc_frame.md_state.preview, 50)
            var preview_content = ""
            var pli = 0
            while pli < preview_lines.len():
                preview_content = preview_content + "<div>" + preview_lines[pli] + "</div>"
                pli = pli + 1
            right_panel_html = "<div class=\"preview-pane\">" + preview_content + "</div>"
        elif doc_frame.md_state.outline_visible:
            val outline_lines = outline_panel_render(doc_frame.md_state.outline, 50)
            var outline_content = ""
            var oli = 0
            while oli < outline_lines.len():
                outline_content = outline_content + "<div>" + outline_lines[oli] + "</div>"
                oli = oli + 1
            right_panel_html = "<div class=\"outline-pane\">" + outline_content + "</div>"
    val mode_str = editor_mode_name(state.ctrl.session.mode)
    var status_extra = ""
    if doc_frame != nil and doc_frame.language_id == "markdown" and doc_frame.cached_md_stats != nil:
        status_extra = " | " + md_stats_to_status_bar(doc_frame.cached_md_stats)
    val status_html = "<div class=\"status\">" + mode_str + " | " + state.ctrl.status_msg + status_extra + "</div>"
    GuiFrame(
        tab_bar_html: tab_bar,
        file_tree_html: file_tree_html,
        editor_html: editor_html + right_panel_html,
        status_html: status_html
    )

fn gui_shell_present_frame(frame: GuiFrame):
    val html = "<html><body>" + frame.tab_bar_html + frame.file_tree_html + frame.editor_html + frame.status_html + "</body></html>"
    rt_gui_present_html(html)

# SDL2-backed presentation path.
# Delegates to gui_sdl2_present_frame from gui_sdl2_bridge.spl.
# The caller is responsible for creating the window via gui_sdl2_init.
fn gui_shell_present_frame_sdl2(window: i64, frame: GuiFrame):
    gui_sdl2_present_frame(window, frame)


struct GuiEvent:
    kind: text
    data: text

fn gui_shell_poll_event() -> GuiEvent:
    GuiEvent(kind: "", data: "")

struct MouseCoords:
    x: i64
    y: i64

fn _parse_mouse_coords(data: text) -> MouseCoords:
    val comma_idx = data.index_of(",")
    if comma_idx < 0:
        return MouseCoords(x: 0, y: 0)
    val x_str = data.slice(0, comma_idx)
    val y_str = data.slice(comma_idx + 1, data.len())
    MouseCoords(x: x_str.to_i64(), y: y_str.to_i64())
