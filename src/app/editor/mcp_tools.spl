fn editor_mcp_dispatch(session: EditSession, tool_name: text, args: [text]) -> McpToolResult:
    if tool_name == "editor.open_file":
        if args.len() > 0:
            session.open_file(args[0])
            return McpToolResult(ok: true, content: "opened {args[0]}")
        return McpToolResult(ok: false, content: "missing path argument")
    if tool_name == "editor.read_buffer":
        val buffer = session.active_buffer()
        if buffer == nil:
            return McpToolResult(ok: false, content: "no active buffer")
        return McpToolResult(ok: true, content: buffer.to_text())
    if tool_name == "editor.list_open_files":
        var listing = ""
        var i = 0
        while i < session.documents.len():
            val doc = session.documents[i]
            listing = listing + doc.path() + "\n"
            i = i + 1
        return McpToolResult(ok: true, content: listing)
    if tool_name == "editor.goto_definition":
        val doc = session.active_document()
        val buffer = session.active_buffer()
        if doc == nil or buffer == nil:
            return McpToolResult(ok: false, content: "no active buffer")
        var ctrl = EditorController.new(session)
        val response = ctrl._request_active_definition()
        if response.ok:
            return McpToolResult(ok: true, content: response.result_json)
        return McpToolResult(ok: false, content: response.error_text)
    if tool_name == "editor.lsp_references":
        return editor_mcp_active_lsp(session, "references", "")
    if tool_name == "editor.lsp_selection_ranges":
        return editor_mcp_active_lsp(session, "selection-ranges", "")
    if tool_name == "editor.lsp_document_symbols":
        return editor_mcp_active_lsp(session, "document-symbols", "")
    if tool_name == "editor.lsp_prepare_rename":
        return editor_mcp_active_lsp(session, "prepare-rename", "")
    if tool_name == "editor.lsp_formatting":
        return editor_mcp_active_lsp(session, "formatting", "")
    if tool_name == "editor.lsp_range_formatting":
        return editor_mcp_active_lsp(session, "range-formatting", "")
    if tool_name == "editor.lsp_signature_help":
        return editor_mcp_active_lsp(session, "signature-help", "")
    if tool_name == "editor.lsp_document_links":
        return editor_mcp_active_lsp(session, "document-links", "")
    if tool_name == "editor.lsp_folding_ranges":
        return editor_mcp_active_lsp(session, "folding-ranges", "")
    if tool_name == "editor.lsp_workspace_symbols":
        val query = if args.len() > 0 then args[0] else: ""
        return editor_mcp_active_lsp(session, "workspace-symbols", query)
    if tool_name == "editor.lsp_semantic_tokens":
        return editor_mcp_active_lsp(session, "semantic-tokens", "")
    if tool_name == "editor.lsp_inlay_hints":
        return editor_mcp_active_lsp(session, "inlay-hints", "")
    if tool_name == "editor.lsp_code_lens":
        return editor_mcp_active_lsp(session, "code-lens", "")
    if tool_name == "editor.lsp_code_lens_resolve":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing item_json argument")
        return editor_mcp_active_lsp(session, "code-lens-resolve", args[0])
    if tool_name == "editor.lsp_call_hierarchy":
        return editor_mcp_active_lsp(session, "call-hierarchy", "")
    if tool_name == "editor.lsp_call_hierarchy_incoming":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing item_json argument")
        return editor_mcp_active_lsp(session, "call-hierarchy-incoming", args[0])
    if tool_name == "editor.lsp_call_hierarchy_outgoing":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing item_json argument")
        return editor_mcp_active_lsp(session, "call-hierarchy-outgoing", args[0])
    if tool_name == "editor.lsp_rename":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing new_name argument")
        return editor_mcp_active_lsp(session, "rename", args[0])
    if tool_name == "editor.run_command":
        if args.len() > 0:
            var ctrl_cmd = EditorController.new(session)
            val action = ctrl_cmd._execute_palette_command(args[0], "")
            return McpToolResult(ok: true, content: action.status_msg)
        return McpToolResult(ok: false, content: "missing command argument")
    if tool_name == "editor.wiki_backlinks":
        val index = editor_mcp_wiki_index(session)
        val target = if args.len() > 0 and args[0] != "" then args[0] else: editor_mcp_active_path(session)
        if target == "":
            return McpToolResult(ok: false, content: "missing path argument")
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_links(md_wiki_backlinks(index, target)))
    if tool_name == "editor.wiki_unresolved":
        val unresolved = md_wiki_unresolved_links(editor_mcp_wiki_index(session))
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_links(unresolved))
    if tool_name == "editor.wiki_tags":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing tag argument")
        val tags = md_wiki_tags(editor_mcp_wiki_index(session), args[0])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_tags(tags))
    if tool_name == "editor.wiki_properties":
        val index = editor_mcp_wiki_index(session)
        val path = if args.len() > 0 and args[0] != "" then args[0] else: editor_mcp_active_path(session)
        if path == "":
            return McpToolResult(ok: false, content: "missing path argument")
        val props = md_wiki_properties_for_path(index, path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_properties(props))
    if tool_name == "editor.wiki_set_property":
        if args.len() < 3:
            return McpToolResult(ok: false, content: "missing path key or value argument")
        if args[1].trim() == "":
            return McpToolResult(ok: false, content: "missing key argument")
        val updated = editor_mcp_set_markdown_property(args[0], args[1], args[2])
        if not updated:
            return McpToolResult(ok: false, content: "failed to set property")
        return McpToolResult(ok: true, content: "set " + args[1] + " in " + args[0])
    if tool_name == "editor.wiki_tasks":
        val checked = args.len() > 0 and (args[0] == "true" or args[0] == "checked" or args[0] == "done")
        val tasks = md_wiki_tasks(editor_mcp_wiki_index(session), checked)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_tasks(tasks))
    if tool_name == "editor.wiki_quick_switch":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing query argument")
        val docs = md_wiki_quick_switch(editor_mcp_wiki_index(session), args[0])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_documents(docs))
    if tool_name == "editor.wiki_vault_quick_switch":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing root or query argument")
        val docs = md_wiki_quick_switch(editor_mcp_wiki_vault_index(args[0]), args[1])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_documents(docs))
    if tool_name == "editor.wiki_vault_search":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing root or query argument")
        val index = editor_mcp_vault_search_index(args[0])
        val matches = md_vault_search_index_search(index, args[1])
        return McpToolResult(ok: true, content: editor_mcp_format_vault_search(matches))
    if tool_name == "editor.wiki_vault_unresolved":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val unresolved = md_wiki_unresolved_links(editor_mcp_wiki_vault_index(args[0]))
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_links(unresolved))
    if tool_name == "editor.wiki_vault_tags":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing root or tag argument")
        val tags = md_wiki_tags(editor_mcp_wiki_vault_index(args[0]), args[1])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_tags(tags))
    if tool_name == "editor.wiki_vault_properties":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing root or path argument")
        val props = md_wiki_properties_for_path(editor_mcp_wiki_vault_index(args[0]), args[1])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_properties(props))
    if tool_name == "editor.wiki_vault_tasks":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val checked = args.len() > 1 and (args[1] == "true" or args[1] == "checked" or args[1] == "done")
        val tasks = md_wiki_tasks(editor_mcp_wiki_vault_index(args[0]), checked)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_tasks(tasks))
    if tool_name == "editor.wiki_vault_backlinks":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing root or path argument")
        val links = md_wiki_backlinks(editor_mcp_wiki_vault_index(args[0]), args[1])
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_links(links))
    if tool_name == "editor.wiki_vault_graph_edges":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val path = if args.len() > 1 then args[1] else: ""
        val edges = md_wiki_graph_edges(editor_mcp_wiki_vault_index(args[0]), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_graph_edges(edges))
    if tool_name == "editor.wiki_vault_embeds":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val path = if args.len() > 1 then args[1] else: ""
        val embeds = md_wiki_embeds(editor_mcp_wiki_vault_index(args[0]), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_embeds(embeds))
    if tool_name == "editor.wiki_vault_callouts":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val path = if args.len() > 1 then args[1] else: ""
        val callouts = md_wiki_callouts(editor_mcp_wiki_vault_index(args[0]), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_callouts(callouts))
    if tool_name == "editor.wiki_vault_attachments":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing root argument")
        val path = if args.len() > 1 then args[1] else: ""
        val attachments = md_wiki_attachments(editor_mcp_wiki_vault_index(args[0]), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_attachments(attachments))
    if tool_name == "editor.wiki_create_note":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing path argument")
        val title = if args.len() > 1 and args[1] != "" then args[1] else: md_wiki_title_from_path(args[0])
        val content = "# " + title + "\n\n"
        val written = rt_file_write_text(args[0], content)
        if not written:
            return McpToolResult(ok: false, content: "failed to create note")
        session.open_file(args[0])
        return McpToolResult(ok: true, content: "created " + args[0])
    if tool_name == "editor.wiki_embeds":
        val path = if args.len() > 0 then args[0] else: ""
        val embeds = md_wiki_embeds(editor_mcp_wiki_index(session), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_embeds(embeds))
    if tool_name == "editor.wiki_callouts":
        val path = if args.len() > 0 then args[0] else: ""
        val callouts = md_wiki_callouts(editor_mcp_wiki_index(session), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_callouts(callouts))
    if tool_name == "editor.wiki_attachments":
        val path = if args.len() > 0 then args[0] else: ""
        val attachments = md_wiki_attachments(editor_mcp_wiki_index(session), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_attachments(attachments))
    if tool_name == "editor.wiki_attachment_insert":
        if args.len() < 2:
            return McpToolResult(ok: false, content: "missing target or attachment argument")
        val label = if args.len() > 2 then args[2] else: ""
        val storage_dir = if args.len() > 3 then args[3] else: ""
        val inserted = editor_mcp_insert_attachment(args[0], args[1], label, storage_dir)
        if not inserted:
            return McpToolResult(ok: false, content: "failed to insert attachment")
        val stored_path = editor_mcp_attachment_storage_path(args[0], args[1], storage_dir)
        return McpToolResult(ok: true, content: "inserted attachment " + stored_path + " into " + args[0])
    if tool_name == "editor.wiki_graph_edges":
        val path = if args.len() > 0 then args[0] else: ""
        val edges = md_wiki_graph_edges(editor_mcp_wiki_index(session), path)
        return McpToolResult(ok: true, content: editor_mcp_format_wiki_graph_edges(edges))
    if tool_name == "editor.wiki_template_preview":
        if args.len() < 3:
            return McpToolResult(ok: false, content: "missing template title or date argument")
        val rendered = md_wiki_apply_template_vars(md_wiki_template("preview", args[0]), args[1], args[2], editor_mcp_template_vars(args, 3))
        return McpToolResult(ok: true, content: rendered)
    if tool_name == "editor.wiki_template_list":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing folder argument")
        return McpToolResult(ok: true, content: editor_mcp_template_list(args[0]))
    if tool_name == "editor.wiki_template_insert":
        if args.len() < 4:
            return McpToolResult(ok: false, content: "missing template target title or date argument")
        val rendered = md_wiki_apply_template_vars(md_wiki_template(md_wiki_title_from_path(args[0]), rt_file_read_text(args[0]) ?? ""), args[2], args[3], editor_mcp_template_vars(args, 4))
        val existing = rt_file_read_text(args[1]) ?? ""
        val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
        val written = rt_file_write_text(args[1], existing + sep + rendered)
        if not written:
            return McpToolResult(ok: false, content: "failed to insert template")
        return McpToolResult(ok: true, content: "inserted " + args[0] + " into " + args[1])
    if tool_name == "editor.wiki_daily_note":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing date argument")
        val folder = if args.len() > 1 then args[1] else: "Daily"
        val template_body = if args.len() > 2 then args[2] else: "# {{title}}\n\n"
        val title_format = if args.len() > 3 then args[3] else: "{{date}}"
        val extension = if args.len() > 4 then args[4] else: ".md"
        val config = md_wiki_daily_note_config_with_title(folder, title_format, extension, template_body)
        val path = md_wiki_daily_note_path(config, args[0])
        val content = md_wiki_daily_note_content(config, args[0])
        return McpToolResult(ok: true, content: path + "\n" + content)
    if tool_name == "editor.wiki_daily_note_create":
        if args.len() == 0:
            return McpToolResult(ok: false, content: "missing date argument")
        val folder = if args.len() > 1 then args[1] else: "Daily"
        val template_body = if args.len() > 2 then args[2] else: "# {{title}}\n\n"
        val title_format = if args.len() > 3 then args[3] else: "{{date}}"
        val extension = if args.len() > 4 then args[4] else: ".md"
        val config = md_wiki_daily_note_config_with_title(folder, title_format, extension, template_body)
        val path = md_wiki_daily_note_path(config, args[0])
        val content = md_wiki_daily_note_content(config, args[0])
        val written = rt_file_write_text(path, content)
        if not written:
            return McpToolResult(ok: false, content: "failed to create daily note")
        session.open_file(path)
        return McpToolResult(ok: true, content: "created " + path)
    McpToolResult(ok: false, content: "unknown tool: {tool_name}")

fn editor_mcp_wiki_index(session: EditSession) -> MdWikiIndex:
    var docs: [MdWikiDocument] = []
    for doc in session.documents:
        if doc.language_id == "markdown":
            docs.push(md_wiki_document(doc.path(), doc.buffer.to_text()))
    md_wiki_index_documents(docs)

fn editor_mcp_wiki_vault_index(root: text) -> MdWikiIndex:
    md_wiki_index_documents(editor_mcp_wiki_vault_documents(root))

fn editor_mcp_wiki_vault_documents(root: text) -> [MdWikiDocument]:
    var docs: [MdWikiDocument] = []
    val files = rt_dir_walk(root)
    for file in files:
        val lower = file.to_lower()
        if lower.ends_with(".md") or lower.ends_with(".markdown"):
            docs.push(md_wiki_document(file, rt_file_read_text(file) ?? ""))
    docs

fn editor_mcp_vault_search_index(root: text) -> MdVaultSearchIndex:
    val cache_path = editor_mcp_vault_search_cache_path(root)
    val docs = editor_mcp_wiki_vault_documents(root)
    val loaded = md_vault_search_index_load(cache_path)
    if loaded.root == root and not loaded.dirty and md_vault_search_index_matches_documents(loaded, docs):
        return loaded
    val index = md_vault_search_index_new(root, docs)
    md_vault_search_index_save(index, cache_path)
    index

fn editor_mcp_vault_search_cache_path(root: text) -> text:
    if root.ends_with("/"):
        return root + ".simple-vault-search.cache"
    root + "/.simple-vault-search.cache"

fn editor_mcp_template_list(folder: text) -> text:
    var out = ""
    val files = rt_dir_walk(folder)
    for file in files:
        val lower = file.to_lower()
        if lower.ends_with(".md") or lower.ends_with(".markdown"):
            out = out + file + "\n"
    out

fn editor_mcp_insert_attachment(target_path: text, attachment_path: text, label: text, storage_dir: text) -> bool:
    val existing = rt_file_read_text(target_path) ?? ""
    val stored_path = editor_mcp_attachment_storage_path(target_path, attachment_path, storage_dir)
    if stored_path == "":
        return false
    val embed = editor_mcp_attachment_embed(stored_path, label)
    val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
    rt_file_write_text(target_path, existing + sep + embed + "\n")

fn editor_mcp_attachment_storage_path(target_path: text, attachment_path: text, storage_dir: text) -> text:
    if storage_dir == "":
        return attachment_path
    val data = rt_file_read_bytes(attachment_path) ?? []
    if data.len() == 0 and not rt_file_exists(attachment_path):
        return ""
    val clean_dir = editor_mcp_clean_relative_dir(storage_dir)
    if clean_dir == "":
        return ""
    val note_dir = editor_mcp_dirname(target_path)
    val dest_dir = if note_dir == "" then clean_dir else: note_dir + "/" + clean_dir
    if not rt_dir_create_all(dest_dir):
        return ""
    val name = editor_mcp_path_basename(attachment_path)
    if name == "":
        return ""
    val unique_name = editor_mcp_unique_attachment_name(dest_dir, name)
    val dest_path = dest_dir + "/" + unique_name
    if not rt_file_write_bytes(dest_path, data):
        return ""
    clean_dir + "/" + unique_name

fn editor_mcp_unique_attachment_name(dest_dir: text, name: text) -> text:
    val dot = editor_mcp_last_dot(name)
    val base = if dot > 0 then name.slice(0, dot) else: name
    val ext = if dot > 0 then name.slice(dot, name.len()) else: ""
    var candidate = name
    var idx = 1
    while rt_file_exists(dest_dir + "/" + candidate):
        candidate = base + "-" + idx.to_text() + ext
        idx = idx + 1
    candidate

fn editor_mcp_last_dot(name: text) -> i64:
    var last = -1
    var i = 0
    while i < name.len():
        if name.char_at(i) == ".":
            last = i
        i = i + 1
    last

fn editor_mcp_attachment_embed(attachment_path: text, label: text) -> text:
    if label != "":
        return "![" + label + "](" + attachment_path + ")"
    "![[{attachment_path}]]"

fn editor_mcp_clean_relative_dir(path: text) -> text:
    var clean = path.trim()
    while clean.starts_with("./"):
        clean = clean.slice(2, clean.len())
    while clean.starts_with("/"):
        clean = clean.slice(1, clean.len())
    while clean.ends_with("/") and clean.len() > 0:
        clean = clean.slice(0, clean.len() - 1)
    if clean == ".":
        return ""
    clean

fn editor_mcp_dirname(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last <= 0:
        return ""
    path.slice(0, last)

fn editor_mcp_path_basename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last >= 0 and last + 1 < path.len():
        return path.slice(last + 1, path.len())
    path

fn editor_mcp_active_lsp(session: EditSession, kind: text, payload: text) -> McpToolResult:
    val doc = session.active_document()
    val buffer = session.active_buffer()
    if doc == nil or buffer == nil:
        return McpToolResult(ok: false, content: "no active buffer")
    var ctrl = EditorController.new(session)
    if kind == "code-lens-resolve" or kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing":
        val doc_for_payload = session.active_document()
        if doc_for_payload == nil:
            return McpToolResult(ok: false, content: "no active buffer")
        ctrl._activate_active_language()
        if doc_for_payload.language_id == "markdown":
            var md_client = ctrl.md_lsp_state.client
            var md_response = LspResponse(id: 0, ok: false, result_json: "", error_text: "unknown lsp request")
            if kind == "code-lens-resolve":
                md_response = md_client.code_lens_resolve(payload)
            elif kind == "call-hierarchy-incoming":
                md_response = md_client.call_hierarchy_incoming(payload)
            elif kind == "call-hierarchy-outgoing":
                md_response = md_client.call_hierarchy_outgoing(payload)
            if md_response.ok:
                return McpToolResult(ok: true, content: md_response.result_json)
            return McpToolResult(ok: false, content: md_response.error_text)
        var simple_client = ctrl.simple_lsp_state.client
        var simple_response = LspResponse(id: 0, ok: false, result_json: "", error_text: "unknown lsp request")
        if kind == "code-lens-resolve":
            simple_response = simple_client.code_lens_resolve(payload)
        elif kind == "call-hierarchy-incoming":
            simple_response = simple_client.call_hierarchy_incoming(payload)
        elif kind == "call-hierarchy-outgoing":
            simple_response = simple_client.call_hierarchy_outgoing(payload)
        if simple_response.ok:
            return McpToolResult(ok: true, content: simple_response.result_json)
        return McpToolResult(ok: false, content: simple_response.error_text)
    if kind == "rename":
        val response = ctrl._request_active_rename(payload)
        if response.ok:
            return McpToolResult(ok: true, content: response.result_json)
        return McpToolResult(ok: false, content: response.error_text)
    val response = ctrl._request_active_lsp_with_payload(kind, payload)
    if response.ok:
        return McpToolResult(ok: true, content: response.result_json)
    McpToolResult(ok: false, content: response.error_text)

fn editor_mcp_active_path(session: EditSession) -> text:
    val doc = session.active_document()
    if doc == nil:
        return ""
    doc.path()

fn editor_mcp_format_wiki_links(links: [MdWikiLink]) -> text:
    var out = ""
    for link in links:
        out = out + link.source_path + ":" + (link.line + 1).to_text() + ":" + (link.col + 1).to_text() + " -> " + link.target + "\n"
    out

fn editor_mcp_template_vars(args: [text], start: i64) -> [MdWikiTemplateVar]:
    var vars: [MdWikiTemplateVar] = []
    var i = start
    while i < args.len():
        val item = args[i].trim()
        val eq = item.index_of("=") ?? -1
        if eq > 0:
            vars.push(md_wiki_template_var(item.slice(0, eq).trim(), item.slice(eq + 1, item.len()).trim()))
            i = i + 1
        elif i + 1 < args.len():
            vars.push(md_wiki_template_var(item, args[i + 1]))
            i = i + 2
        else:
            i = i + 1
    vars

fn editor_mcp_format_wiki_tags(tags: [MdWikiTag]) -> text:
    var out = ""
    for tag in tags:
        out = out + tag.path + ":" + (tag.line + 1).to_text() + " #" + tag.tag + "\n"
    out

fn editor_mcp_format_wiki_properties(props: [MdWikiProperty]) -> text:
    var out = ""
    for prop in props:
        out = out + prop.path + " " + prop.key + ": " + prop.value + "\n"
    out

fn editor_mcp_format_vault_search(matches: [MdVaultSearchMatch]) -> text:
    var out = ""
    for match in matches:
        out = out + match.path + ":" + (match.line + 1).to_text() + ":" + (match.col + 1).to_text() + " score=" + match.score.to_text() + " " + match.block_kind + " " + match.context_text.trim() + "\n"
    out

fn editor_mcp_set_markdown_property(path: text, key: text, value: text) -> bool:
    val content = rt_file_read_text(path) ?? ""
    val next = editor_mcp_markdown_property_content(content, key.trim(), value)
    rt_file_write_text(path, next)

fn editor_mcp_markdown_property_content(content: text, key: text, value: text) -> text:
    if key == "":
        return content
    val line = key + ": " + value
    val lines = content.split("\n")
    if lines.len() == 0 or lines[0].trim() != "---":
        return "---\n" + line + "\n---\n" + content
    var out = "---"
    var i = 1
    var found = false
    var closed = false
    while i < lines.len():
        val trimmed = lines[i].trim()
        if not closed and trimmed == "---":
            if not found:
                out = out + "\n" + line
            out = out + "\n---"
            closed = true
        elif not closed:
            val sep = md_wiki_find_char(trimmed, ":", 0)
            val existing_key = if sep > 0 then trimmed.slice(0, sep).trim() else: ""
            if existing_key == key:
                out = out + "\n" + line
                found = true
            else:
                out = out + "\n" + lines[i]
        else:
            out = out + "\n" + lines[i]
        i = i + 1
    if not closed:
        if not found:
            out = out + "\n" + line
        out = out + "\n---"
    out

fn editor_mcp_format_wiki_tasks(tasks: [MdWikiTask]) -> text:
    var out = ""
    for task in tasks:
        val mark = if task.checked then "[x]" else: "[ ]"
        out = out + task.path + ":" + (task.line + 1).to_text() + " " + mark + " " + task.text_content + "\n"
    out

fn editor_mcp_format_wiki_documents(docs: [MdWikiDocument]) -> text:
    var out = ""
    for doc in docs:
        out = out + doc.path + "\n"
    out

fn editor_mcp_format_wiki_embeds(embeds: [MdWikiEmbed]) -> text:
    var out = ""
    for embed in embeds:
        val state = if embed.resolved then "resolved" else: "unresolved"
        out = out + embed.source_path + ":" + (embed.line + 1).to_text() + ":" + (embed.col + 1).to_text() + " embed " + embed.target + " " + state + "\n"
    out

fn editor_mcp_format_wiki_callouts(callouts: [MdWikiCallout]) -> text:
    var out = ""
    for callout in callouts:
        val fold = if callout.folded then " folded" else: ""
        out = out + callout.path + ":" + (callout.line + 1).to_text() + " " + callout.callout_type + fold + " " + callout.title + "\n"
    out

fn editor_mcp_format_wiki_attachments(attachments: [MdWikiAttachment]) -> text:
    var out = ""
    for attachment in attachments:
        out = out + attachment.source_path + ":" + (attachment.line + 1).to_text() + ":" + (attachment.col + 1).to_text() + " attachment " + attachment.target + "\n"
    out

fn editor_mcp_format_wiki_graph_edges(edges: [MdWikiGraphEdge]) -> text:
    var out = ""
    for edge in edges:
        val state = if edge.resolved then "resolved" else: "unresolved"
        out = out + edge.source_path + " -> " + edge.target + " " + edge.edge_type + " " + state + "\n"
    out
