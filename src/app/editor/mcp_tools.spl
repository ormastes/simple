# Editor MCP Tools
#
# MCP tool entries for AI-assisted editing.
# Provides tools for file operations, buffer reading, editing, and navigation.

use std.editor.services.md_search.*

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_walk(path: text) -> [text]

struct McpToolDef:
    name: text
    description: text
    params: [McpToolParam]

struct McpToolParam:
    name: text
    param_type: text
    required: bool

struct McpToolResult:
    ok: bool
    content: text

fn editor_mcp_tools() -> [McpToolDef]:
    [
        McpToolDef(
            name: "editor.open_file",
            description: "Open a file in the editor",
            params: [McpToolParam(name: "path", param_type: "text", required: true)]
        ),
        McpToolDef(
            name: "editor.read_buffer",
            description: "Read the current buffer content",
            params: []
        ),
        McpToolDef(
