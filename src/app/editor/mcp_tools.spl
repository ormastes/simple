# Editor MCP Tools
#
# MCP tool entries for AI-assisted editing.
# Provides tools for file operations, buffer reading, editing, and navigation.

struct McpToolDef:
    name: text
    description: text
    params: [McpToolParam]

struct McpToolParam:
    name: text
    param_type: text
    required: bool

struct McpToolResult:
    ok: bool
    content: text

fn editor_mcp_tools() -> [McpToolDef]:
    [
        McpToolDef(
            name: "editor.open_file",
            description: "Open a file in the editor",
            params: [McpToolParam(name: "path", param_type: "text", required: true)]
        ),
        McpToolDef(
            name: "editor.read_buffer",
            description: "Read the current buffer content",
            params: []
        ),
        McpToolDef(
            name: "editor.edit",
            description: "Edit text at cursor position",
            params: [McpToolParam(name: "text", param_type: "text", required: true)]
        ),
        McpToolDef(
            name: "editor.search",
            description: "Search for text in current buffer",
            params: [McpToolParam(name: "query", param_type: "text", required: true)]
        ),
        McpToolDef(
            name: "editor.diagnostics",
            description: "Get diagnostics for current file",
            params: []
        ),
        McpToolDef(
            name: "editor.goto_definition",
            description: "Go to definition of symbol at cursor",
            params: []
        ),
        McpToolDef(
            name: "editor.list_open_files",
            description: "List all open files in the editor",
            params: []
        ),
        McpToolDef(
            name: "editor.run_command",
            description: "Execute an editor command by name",
            params: [McpToolParam(name: "command", param_type: "text", required: true)]
        )
    ]

fn editor_mcp_dispatch(session: EditSession, tool_name: text, args: [text]) -> McpToolResult:
    if tool_name == "editor.open_file":
        if args.len() > 0:
            session.open_file(args[0])
            return McpToolResult(ok: true, content: "opened {args[0]}")
        return McpToolResult(ok: false, content: "missing path argument")
    if tool_name == "editor.read_buffer":
        val buffer = session.active_buffer()
        if buffer == nil:
            return McpToolResult(ok: false, content: "no active buffer")
        return McpToolResult(ok: true, content: buffer.to_text())
    if tool_name == "editor.list_open_files":
        var listing = ""
        var i = 0
        while i < session.documents.len():
            val doc = session.documents[i]
            listing = listing + doc.path() + "\n"
            i = i + 1
        return McpToolResult(ok: true, content: listing)
    if tool_name == "editor.run_command":
        if args.len() > 0:
            val buffer = session.active_buffer()
            if buffer != nil:
                val result = editor_dispatch(buffer, editor_cmd(args[0]))
                return McpToolResult(ok: result.ok, content: result.message)
        return McpToolResult(ok: false, content: "missing command argument")
    McpToolResult(ok: false, content: "unknown tool: {tool_name}")
