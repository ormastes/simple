# Editor MCP tool registry metadata.
#
# IDE feature checks need a pure registry surface that does not initialize the
# editor controller, shell out, or touch files. Runtime dispatch remains owned by
# the full editor app; this module exposes the stable tool catalog.

struct McpToolDef:
    name: text
    description: text
    params: [McpToolParam]

struct McpToolParam:
    name: text
    param_type: text
    required: bool

fn mcp_tool(name: text, description: text) -> McpToolDef:
    McpToolDef(
        name: name,
        description: description,
        params: []
    )

fn mcp_tool_with_param(name: text, description: text, param_name: text, param_type: text) -> McpToolDef:
    McpToolDef(
        name: name,
        description: description,
        params: [McpToolParam(name: param_name, param_type: param_type, required: true)]
    )

fn editor_mcp_tools() -> [McpToolDef]:
    [
        mcp_tool_with_param("editor.open_file", "Open a file in the editor", "path", "text"),
        mcp_tool("editor.read_buffer", "Read the current buffer content"),
        mcp_tool_with_param("editor.edit", "Edit text at cursor position", "text", "text"),
        mcp_tool_with_param("editor.search", "Search for text in the current buffer", "query", "text"),
        mcp_tool("editor.diagnostics", "Get diagnostics for the current file"),
        mcp_tool("editor.goto_definition", "Go to definition of the symbol at cursor"),
        mcp_tool("editor.lsp_references", "Find references for the symbol at cursor"),
        mcp_tool("editor.lsp_selection_ranges", "Request selection ranges at cursor"),
        mcp_tool("editor.lsp_document_symbols", "List document symbols for the active file"),
        mcp_tool("editor.lsp_prepare_rename", "Validate rename at the active symbol"),
        mcp_tool("editor.lsp_formatting", "Request formatting edits for the active file"),
        mcp_tool("editor.lsp_range_formatting", "Request range formatting edits"),
        mcp_tool("editor.lsp_signature_help", "Request signature help at cursor"),
        mcp_tool("editor.lsp_document_links", "Request document links for the active file"),
        mcp_tool("editor.lsp_folding_ranges", "Request folding ranges for the active file"),
        mcp_tool("editor.lsp_workspace_symbols", "Request workspace symbols"),
        mcp_tool_with_param("editor.wiki_search", "Search workspace wiki pages", "query", "text"),
        mcp_tool_with_param("editor.wiki_open", "Open a workspace wiki page", "page", "text"),
        mcp_tool("editor.wiki_backlinks", "List backlinks for the current wiki page")
    ]
