# Editor Controller
#
# Shared UI logic for TUI and GUI shells. Handles key dispatch,
# mode switching, file tree interaction, command line, and view state.
# Shells create a controller and call handle_key(); rendering is shell-specific.

use std.editor.services.md_wiki_index.*
use std.editor.services.md_search.*
use std.editor.services.md_diagnostics.*
use std.editor.services.file_watcher.*
use std.editor.services.command_palette.*
use std.editor.common.keybindings.*
use std.editor.extensions.host.*
use std.editor.extensions.builtin.md_edit_assist.*
use std.editor.view.diagnostics_panel.*
use std.editor.view.lsp_result_panel.*
use std.editor.view.lsp_popup.*
use std.editor.view.markdown_state.*
use std.editor.view.md_editing.*
use std.editor.view.outline_panel.*
use std.editor.view.wiki_panel.*
use std.editor.view.file_tree.*
use std.editor.view.settings_view.*
use app.editor.debug_process_runtime.*
use app.editor.editor_ctrl_core.*
use app.editor.editor_ctrl_debug.*
use app.editor.editor_ctrl_diagnostics.*
use app.editor.editor_ctrl_lsp.*
use app.editor.editor_ctrl_wiki.*
use app.editor.editor_json_helpers.*
use app.editor.editor_path_text_helpers.*
use app.editor.editor_lsp_helpers.*
use app.editor.editor_debug_helpers.*
use app.editor.editor_markdown_helpers.*
use app.editor.editor_attachment_template.*
use app.editor.editor_workspace_symbols.*
use app.editor.editor_keymap_dispatch.*
use app.editor.editor_layout.*
use app.editor.editor_extension_roots.*
use app.editor.editor_controller_types.*

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_walk(path: text) -> [text]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

struct EditorAction:
    redraw: bool
    quit: bool
    status_msg: text

struct NormalKeyResult:
    message: text
    quit: bool
    enter_insert: bool
    enter_command: bool

struct InsertKeyResult:
    message: text
    exit_insert: bool

struct CommandKeyResult:
    commandline: text
    done: bool
    cancelled: bool

struct EditorAppliedCodeAction:
    applied: bool
    content: text
    line: i64
    col: i64

struct EditorPropertyPayload:
    key: text
    value: text

struct EditorVaultPropertyPayload:
    root: text
    key: text
    value: text
    selected_paths: [text]

struct EditorLocation:
    path: text
    line: i64
    col: i64

class EditorController:
    session: EditSession
    file_tree: FileTreeState
    file_tree_visible: bool
    focus_panel: text
    status_msg: text
    commandline: text
    pending_prefix: text
    running: bool
    config: EditorConfig
    settings_view: SettingsViewState?
    palette_state: PaletteState?
    extension_host: ExtensionHost
    diagnostic_store: DiagnosticStore
    diagnostics_panel: DiagnosticsPanel
    diagnostics_view_mode: text
    diagnostics_view_payload: text
    file_watcher: FileWatcher
    code_actions: [EditorCodeAction]
    code_action_filter: text
    code_action_group_by_kind: bool
    debug_status: text
    debug_registry: EditorDebugRegistry
    debug_dap_client: EditorDebugDapClient
    debug_dap_clients: [EditorDebugDapClient]
    debug_process_pid: i64
    debug_pending_watch_expressions: [text]
    debug_launch_configs: [EditorDebugLaunchConfig]
    debug_launch_source_path: text
    lsp_result_panel: LspResultPanel
    lsp_call_hierarchy_state: text
    lsp_call_hierarchy_state_title: text
    lsp_call_hierarchy_merge_panel: LspResultPanel
    lsp_call_hierarchy_merge_index: i64
    lsp_hover_popup: LspHoverPopup
    lsp_signature_popup: LspSignaturePopup
    lsp_location_stack: [EditorLocation]
    workspace_symbol_index: [LspResultRow]
    workspace_symbol_index_root: text
    pending_workspace_edit_json: text
    pending_workspace_edit_title: text
    format_save_request_id: i64
    format_save_title: text
    wiki_panel: WikiPanel
    vault_search_index: MdVaultSearchIndex
    wiki_vault_search_root: text
    wiki_vault_search_query: text
    wiki_quick_switch_query: text
    wiki_daily_note_payload: text
    wiki_template_picker_payload: text
    wiki_template_query: text
    wiki_attachment_picker_payload: text
    wiki_attachment_query: text
    wiki_task_filter: text
    wiki_task_query: text
    wiki_property_vault_root: text
    wiki_property_schema_payload: text
    pending_inlay_hint_refresh: bool
    inlay_hint_refresh_elapsed_ms: i64
    inlay_hint_refresh_delay_ms: i64
    md_lsp_state: MdLspState
    simple_lsp_state: SimpleLspState

impl EditorController:

    static fn new(session: EditSession) -> EditorController:
        val host = extension_host_with_builtins()
        host.discover_extensions(editor_extension_roots())
        EditorController(
            session: session,
            file_tree: FileTreeState.new("."),
            file_tree_visible: false,
            focus_panel: "editor",
            status_msg: "ready",
            commandline: "",
            pending_prefix: "",
            running: true,
            config: editor_config_default(),
            settings_view: nil,
            palette_state: nil,
            extension_host: host,
            diagnostic_store: DiagnosticStore.new(),
            diagnostics_panel: diagnostics_panel_new(),
            diagnostics_view_mode: "all",
            diagnostics_view_payload: "",
            file_watcher: FileWatcher.new(),
            code_actions: [],
            code_action_filter: "all",
            code_action_group_by_kind: false,
            debug_status: "stopped",
            debug_registry: editor_debug_registry_new(),
            debug_dap_client: EditorDebugDapClient.new(),
            debug_dap_clients: [],
            debug_process_pid: 0,
            debug_pending_watch_expressions: [],
            debug_launch_configs: [],
            debug_launch_source_path: "",
            lsp_result_panel: lsp_result_panel_new("LSP Results"),
            lsp_call_hierarchy_state: "",
            lsp_call_hierarchy_state_title: "",
            lsp_call_hierarchy_merge_panel: lsp_result_panel_new(""),
            lsp_call_hierarchy_merge_index: -1,
            lsp_hover_popup: lsp_hover_popup_hidden(),
            lsp_signature_popup: lsp_signature_popup_hidden(),
            lsp_location_stack: [],
            workspace_symbol_index: [],
            workspace_symbol_index_root: "",
            pending_workspace_edit_json: "",
            pending_workspace_edit_title: "",
            format_save_request_id: 0,
            format_save_title: "",
            wiki_panel: wiki_panel_new("Wiki"),
            vault_search_index: md_vault_search_index_new("", []),
            wiki_vault_search_root: "",
            wiki_vault_search_query: "",
            wiki_quick_switch_query: "",
            wiki_daily_note_payload: "",
            wiki_template_picker_payload: "",
            wiki_template_query: "",
            wiki_attachment_picker_payload: "",
            wiki_attachment_query: "",
            wiki_task_filter: "open",
            wiki_task_query: "",
            wiki_property_vault_root: "",
            wiki_property_schema_payload: "",
            pending_inlay_hint_refresh: false,
            inlay_hint_refresh_elapsed_ms: 0,
            inlay_hint_refresh_delay_ms: 300,
            md_lsp_state: md_lsp_state_new("."),
            simple_lsp_state: simple_lsp_state_new(".")
        )


    fn is_running() -> bool:
        me.running

    fn active_buffer() -> EditorBuffer:
        me.session.active_buffer()

    fn mode() -> EditorMode:
        me.session.mode

    me _replace_session(session: EditSession):
        me.session.documents = session.documents
        me.session.buffers = session.buffers
        me.session.active_index = session.active_index
        me.session.layout = session.layout
        me.session.split = session.split
        me.session.panes = session.panes
        me.session.next_pane_id = session.next_pane_id
        me.session.mode = session.mode
        me.session.dock_layout = session.dock_layout
        me.session.status_message = session.status_message

    me handle_key(key: text, rects: [SplitRect]) -> EditorAction:
        val key_text = key
        if me.session.mode == editor_mode_insert():
            return me._dispatch_insert_key(key_text)
        if key_text.len() == 10 and key_text.starts_with("Ctrl+Space"):
            return me._request_completion_action()
        if key_text.len() == 1 and key_text.char_at(0) == "K":
            return me._request_hover_action()
        if key_text.len() == 3 and key_text.starts_with("F12"):
            return me._request_definition_action()
        if key_text.len() == 15 and key_text.starts_with("Shift+Alt+Right"):
            return me._expand_lsp_selection_range()
        if key_text.len() == 14 and key_text.starts_with("Shift+Alt+Left"):
            return me._shrink_lsp_selection_range()
        if key_text == "\x1b" and me.lsp_hover_popup.visible:
            return me._dismiss_lsp_hover_popup()
        if key_text == "\x1b" and me.lsp_signature_popup.visible:
            return me._dismiss_lsp_signature_popup()
        if me.session.dock_layout.active_right == "problems":
            val problems_action = me._dispatch_diagnostics_panel_key(key_text)
            if problems_action.redraw:
                return problems_action
        if me.session.dock_layout.active_right == "lsp-panel":
            val lsp_action = me._dispatch_lsp_result_key(key_text)
            if lsp_action.redraw:
                return lsp_action
        if me.session.dock_layout.active_right == "md-outline":
            val outline_action = me._dispatch_md_outline_key(key_text)
            if outline_action.redraw:
                return outline_action
        if me.pending_prefix == "z":
            me.pending_prefix = ""
            if key_text == "a":
                return me._toggle_active_markdown_fold()
            me.status_msg = ""
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.pending_prefix == "g":
            me.pending_prefix = ""
            if key_text == "x":
                return me._open_markdown_link_under_cursor()
            me.status_msg = ""
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key_text == "g":
            val doc_g = me.session.active_document()
            if doc_g != nil and doc_g.language_id == "markdown":
                me.pending_prefix = "g"
                me.status_msg = "g ..."
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key_text == "z":
            val doc_z = me.session.active_document()
            if doc_z != nil and doc_z.language_id == "markdown":
                me.pending_prefix = "z"
                me.status_msg = "z ..."
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        ctrl_handle_key(me, key_text, rects)

    me toggle_file_tree():
        ctrl_toggle_file_tree(me)

    me toggle_focus():
        ctrl_toggle_focus(me)

    me settings_open():
        ctrl_settings_open(me)

    me settings_close():
        ctrl_settings_close(me)

    me _dispatch_settings_key(key: text) -> EditorAction:
        ctrl_dispatch_settings_key(me, key)

    me _dispatch_command_key(key: text) -> EditorAction:
        ctrl_dispatch_command_key(me, key)

    me _dispatch_normal_key(key: text, rects: [SplitRect]) -> EditorAction:
        ctrl_dispatch_normal_key(me, key, rects)

    me _dispatch_insert_key(key: text) -> EditorAction:
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.session.mode = editor_mode_normal()
            return EditorAction(redraw: true, quit: false, status_msg: "")
        val doc = me.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            if key == "\r" or key == "\n":
                val current_line = buffer.line_at(buffer.cursor_row)
                val continuation = md_assist_on_enter(current_line, buffer.cursor_col)
                if continuation != "":
                    buffer.insert_at_cursor("\n" + continuation)
                    ctrl_update_markdown_preview(me, doc, buffer)
                    me.session.update_active_buffer(buffer)
                    me._notify_active_lsp_changed()
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
            if key == "\t":
                val tab_line = buffer.line_at(buffer.cursor_row)
                val same_row_col = md_assist_on_tab(tab_line, buffer.cursor_col)
                val nav = md_table_next_cell(buffer.to_text(), buffer.cursor_row, buffer.cursor_col)
                if nav.found:
                    buffer.move_cursor(nav.line, nav.col)
                    me.session.update_active_buffer(buffer)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
                if same_row_col >= 0:
                    buffer.move_cursor(buffer.cursor_row, same_row_col)
                    me.session.update_active_buffer(buffer)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
        var message = "-- INSERT --"
        var exit_insert = false
        if key == "\x1b":
            message = ""
            exit_insert = true
        elif key == "\x7f" or key == "\b":
            buffer.delete_before_cursor()
        elif key == "\r" or key == "\n":
            buffer.insert_at_cursor("\n")
        elif key.len() == 1:
            val code = key.char_code_at(0)
            if code >= 32:
                buffer.insert_at_cursor(key)
        me.status_msg = message
        if exit_insert:
            me.session.mode = editor_mode_normal()
            me.status_msg = ""
        else:
            me.session.update_active_buffer(buffer)
            if doc != nil and doc.language_id == "markdown":
                ctrl_update_markdown_preview(me, doc, buffer)
            me._notify_active_lsp_changed()
            if me._should_trigger_signature_help(key):
                return me._request_active_lsp_action("signature-help")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _dispatch_file_tree_key(key: text) -> EditorAction:
        ctrl_dispatch_file_tree_key(me, key)

    me _should_trigger_signature_help(key: text) -> bool:
        ctrl_should_trigger_signature_help(me, key)

    me _dispatch_palette_key(key: text) -> EditorAction:
        ctrl_dispatch_palette_key(me, key)

    me _open_palette():
        ctrl_open_palette(me)

    me _execute_palette_command(command_name: text, command_payload: text) -> EditorAction:
        if command_name == "problems":
            return me._show_diagnostics_panel()
        if command_name == "diagnostics-filter":
            return me._show_diagnostics_filter(command_payload)
        if command_name == "diagnostics-group":
            return me._show_diagnostics_group(command_payload)
        if command_name == "diagnostics-sort":
            return me._show_diagnostics_sort(command_payload)
        if command_name == "keyboard-shortcuts":
            return me._show_keyboard_shortcuts()
        if command_name == "outline":
            me._toggle_md_outline()
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if command_name == "completion":
            return me._request_completion_action()
        if command_name == "hover":
            return me._request_hover_action()
        if command_name == "definition":
            return me._request_definition_action()
        if command_name == "hover-dismiss":
            return me._dismiss_lsp_hover_popup()
        if command_name == "code-action":
            return me._request_active_lsp_action("code-action")
        if command_name == "references":
            return me._request_active_lsp_action("references")
        if command_name == "selection-ranges":
            return me._request_active_lsp_action("selection-ranges")
        if command_name == "selection-expand":
            return me._expand_lsp_selection_range()
        if command_name == "selection-shrink":
            return me._shrink_lsp_selection_range()
        if command_name == "selection-apply-all":
            return me._apply_all_lsp_selection_ranges()
        if command_name == "document-symbols":
            return me._request_active_lsp_action("document-symbols")
        if command_name == "prepare-rename":
            return me._request_active_lsp_action("prepare-rename")
        if command_name == "rename":
            return me._rename_active_symbol(command_payload)
        if command_name == "rename-preview":
            return me._rename_active_symbol_preview(command_payload)
        if command_name == "rename-confirm":
            return me._confirm_pending_workspace_edit()
        if command_name == "workspace-edit-cancel":
            return me._cancel_pending_workspace_edit()
        if command_name == "formatting":
            return me._request_active_lsp_action("formatting")
        if command_name == "formatting-preview":
            return me._request_active_formatting_preview("formatting")
        if command_name == "formatting-save":
            return me._request_active_formatting_save("formatting")
        if command_name == "range-formatting":
            return me._request_active_lsp_action("range-formatting")
        if command_name == "range-formatting-preview":
            return me._request_active_formatting_preview("range-formatting")
        if command_name == "range-formatting-save":
            return me._request_active_formatting_save("range-formatting")
        if command_name == "signature-help":
            return me._request_active_lsp_action("signature-help")
        if command_name == "signature-next":
            return me._select_signature_overload(1)
        if command_name == "signature-prev":
            return me._select_signature_overload(0 - 1)
        if command_name == "signature-dismiss":
            return me._dismiss_lsp_signature_popup()
        if command_name == "document-links":
            return me._request_active_lsp_action("document-links")
        if command_name == "folding-ranges":
            return me._request_active_lsp_action("folding-ranges")
        if command_name == "workspace-symbols":
            return me._request_workspace_symbols(command_payload)
        if command_name == "semantic-tokens":
            return me._request_active_lsp_action("semantic-tokens")
        if command_name == "inlay-hints":
            me._cancel_pending_inlay_hint_refresh()
            return me._request_active_lsp_action("inlay-hints")
        if command_name == "code-lens":
            return me._request_active_lsp_action("code-lens")
        if command_name == "code-lens-run":
            return me._run_selected_code_lens()
        if command_name == "code-lens-resolve":
            return me._request_active_code_lens_resolve(command_payload)
        if command_name == "call-hierarchy":
            return me._request_active_lsp_action("call-hierarchy")
        if command_name == "call-hierarchy-incoming":
            return me._request_active_call_hierarchy_direction("incoming", command_payload)
        if command_name == "call-hierarchy-outgoing":
            return me._request_active_call_hierarchy_direction("outgoing", command_payload)
        if command_name == "attachment-picker":
            return me._execute_attachment_picker(command_payload)
        if command_name == "template-picker":
            return me._execute_template_picker(command_payload)
        if command_name == "wiki-quick-switch":
            return me._execute_wiki_quick_switch(command_payload)
        if command_name == "wiki-vault-search":
            return me._execute_wiki_vault_search(command_payload)
        if command_name == "wiki-backlinks":
            return me._wiki_show_backlinks()
        if command_name == "wiki-tasks":
            return me._wiki_show_tasks(command_payload)
        if command_name == "wiki-task-batch":
            return me._wiki_task_batch(command_payload)
        if command_name == "wiki-vault-task-batch":
            return me._wiki_vault_task_batch(command_payload)
        if command_name == "wiki-properties":
            return me._wiki_show_properties()
        if command_name == "wiki-property-set":
            return me._wiki_set_property(command_payload)
        if command_name == "wiki-vault-property-set":
            return me._wiki_vault_set_property(command_payload)
        if command_name == "wiki-vault-property-review":
            return me._wiki_vault_property_review(command_payload)
        if command_name == "wiki-property-diagnostics":
            return me._wiki_property_diagnostics(command_payload)
        if command_name == "wiki-tags":
            return me._wiki_show_tags(command_payload)
        if command_name == "wiki-graph":
            return me._wiki_show_graph()
        if command_name == "daily-note-create":
            return me._execute_daily_note_create(command_payload)
        if command_name == "daily-note-picker":
            return me._execute_daily_note_picker(command_payload)
        if command_name == "template-insert":
            return me._execute_template_insert(command_payload)
        if command_name == "quickfix":
            return me._request_quickfix()
        if command_name == "quickfix-apply":
            val index = if command_payload == "" then 0 else: _editor_parse_i64(command_payload, 0)
            return me._apply_code_action_at(index)
        if command_name == "code-action":
            return ctrl_request_active_lsp_action(me, "code-action")
        if command_name == "markdown-table-row-insert":
            return me._markdown_table_insert_row()
        if command_name == "markdown-table-column-insert":
            return me._markdown_table_insert_column()
        if command_name == "markdown-table-cell-next":
            return me._markdown_table_cell_nav("next")
        if command_name == "markdown-table-cell-prev":
            return me._markdown_table_cell_nav("prev")
        if command_name == "fold-toggle":
            return me._toggle_active_markdown_fold()
        if command_name == "markdown.foldAll" or command_name == "fold-all":
            return me._fold_all_active_document()
        if command_name == "markdown.unfoldAll" or command_name == "unfold-all":
            return me._unfold_all_active_document()
        if command_name == "callout-fold-toggle":
            return me._toggle_active_callout_fold()
        if command_name.len() == 9 and command_name.starts_with("open-link"):
            return me._open_markdown_link_under_cursor()
        if command_name == "debug-start":
            return me._start_debug_adapter(command_payload)
        if command_name == "debug-configs":
            return me._debug_show_launch_configs(command_payload)
        if command_name == "debug-console":
            return me._debug_show_session()
        if command_name == "debug-sessions":
            return me._debug_show_sessions()
        if command_name == "debug-switch":
            val debug_session_id = _editor_parse_i64(command_payload, 0)
            if debug_session_id <= 0:
                me.status_msg = "no debug session"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            me.debug_registry = editor_debug_registry_select(me.debug_registry, debug_session_id)
            val selected_debug_session = editor_debug_first_session(me.debug_registry)
            if editor_debug_session_id(selected_debug_session) != debug_session_id:
                me.status_msg = "debug session not found: " + debug_session_id.to_text()
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val debug_client_index = debug_session_id - 1
            if debug_client_index >= 0 and debug_client_index < me.debug_dap_clients.len():
                me.debug_dap_client = me.debug_dap_clients[debug_client_index]
            me.debug_status = editor_debug_session_status(selected_debug_session)
            me._show_debug_panel_direct("debug session: " + editor_debug_session_id(selected_debug_session).to_text())
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if command_name == "debug-restart":
            return me._debug_restart_first()
        if command_name == "debug-continue":
            return me._debug_continue()
        if command_name == "debug-pause":
            return me._debug_pause()
        if command_name == "debug-step":
            return me._debug_step(if command_payload == "" then "stepOver" else: command_payload)
        if command_name == "debug-stack":
            return me._debug_request_stack_trace()
        if command_name == "debug-scopes":
            return me._debug_request_scopes(_editor_parse_i64(command_payload, 1))
        if command_name == "debug-variables":
            return me._debug_request_variables(_editor_parse_i64(command_payload, 1))
        if command_name == "debug-poll":
            return me._debug_poll_dap_client()
        if command_name == "debug-exceptions":
            return me._debug_set_exception_filters(_editor_payload_csv(command_payload))
        if command_name == "debug-watch":
            return me._debug_add_watch(command_payload)
        if command_name == "debug-evaluate":
            return me._debug_evaluate(command_payload)
        if command_name == "debug-terminate":
            return me._debug_terminate_first()
        ctrl_execute_palette_command(me, command_name, command_payload)

    me _execute_wiki_quick_switch(query: text) -> EditorAction:
        val needle = query.trim()
        me.wiki_quick_switch_query = needle
        val index = ctrl_wiki_index_open_documents(me)
        me.wiki_panel = wiki_panel_from_documents(md_wiki_quick_switch(index, needle))
        var session = me.session
        var layout = session.dock_layout
        layout.show_right("wiki-panel")
        session.dock_layout = layout
        me.session = session
        me.status_msg = "wiki quick switch panel"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_daily_note_create(payload: text) -> EditorAction:
        val date = _editor_payload_part(payload, 0)
        if date == "":
            me.status_msg = "missing daily note date"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
        val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
        val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
        val extension = _editor_daily_note_extension(_editor_payload_part(payload, 4))
        val title = title_format.replace("{{date}}", date)
        val path = _editor_join_path(folder, title + extension)
        val content = _editor_apply_template_text(template_body, title, date)
        if not rt_file_write_text(path, content):
            me.status_msg = "failed to create daily note"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var session_daily = me.session
        val target_doc_id = session_daily.open_file(path)
        me._replace_session(session_daily)
        ctrl_focus_lsp_target_doc(me, target_doc_id)
        me.status_msg = "created daily note: " + path
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_daily_note_picker(payload: text) -> EditorAction:
        val date = _editor_payload_part(payload, 0)
        val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
        val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
        val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
        val extension = _editor_daily_note_extension(_editor_payload_part(payload, 4))
        me.wiki_daily_note_payload = date + "|" + folder + "|" + template_body + "|" + title_format + "|" + extension
        val preview_date = if date == "" then "YYYY-MM-DD" else: date
        val title = title_format.replace("{{date}}", preview_date)
        val path = _editor_join_path(folder, title + extension)
        me.wiki_panel = wiki_panel_with_rows("Daily Notes", [
            WikiPanelRow(icon: "calendar", label: preview_date, detail: me.wiki_daily_note_payload, path: path, line: 0)
        ])
        me._show_right_dock("wiki-panel")
        me.status_msg = "daily notes"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_template_insert(payload: text) -> EditorAction:
        val template_path = _editor_payload_part(payload, 0)
        val target_path = _editor_payload_part(payload, 1)
        val title = _editor_payload_part(payload, 2)
        val date = _editor_payload_part(payload, 3)
        if template_path == "" or target_path == "":
            me.status_msg = "missing template or target path"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val rendered = _editor_apply_template_text(rt_file_read_text(template_path) ?? "", title, date)
        val existing = rt_file_read_text(target_path) ?? ""
        val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
        if not rt_file_write_text(target_path, existing + sep + rendered):
            me.status_msg = "failed to insert template"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.status_msg = "inserted template: " + template_path
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_template_picker(payload: text) -> EditorAction:
        val folder = _editor_payload_part(payload, 0)
        val target_path = _editor_payload_part(payload, 1)
        val title = _editor_payload_part(payload, 2)
        val date = _editor_payload_part(payload, 3)
        val query = _editor_payload_part(payload, 4).trim().to_lower()
        if folder == "":
            me.status_msg = "missing template folder"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.wiki_template_picker_payload = folder + "|" + target_path + "|" + title + "|" + date + "|" + query
        me.wiki_template_query = query
        me.wiki_panel = wiki_panel_with_rows("Templates", _editor_template_picker_rows(folder, target_path, title, date, query))
        var session = me.session
        var layout = session.dock_layout
        layout.show_right("wiki-panel")
        session.dock_layout = layout
        me.session = session
        me.status_msg = "templates: " + me.wiki_panel.rows.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_attachment_picker(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val query = _editor_payload_part(payload, 1).to_lower()
        val target_path = _editor_payload_part(payload, 2)
        val storage_dir = _editor_payload_part(payload, 3)
        if root == "":
            me.status_msg = "missing attachment root"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.wiki_attachment_picker_payload = root + "|" + query + "|" + target_path + "|" + storage_dir
        me.wiki_attachment_query = query
        me.wiki_panel = wiki_panel_with_rows("Attachment Picker", _editor_attachment_picker_rows(root, query, target_path, storage_dir))
        var session = me.session
        var layout = session.dock_layout
        layout.show_right("wiki-panel")
        session.dock_layout = layout
        me.session = session
        me.status_msg = "attachments: " + me.wiki_panel.rows.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_wiki_vault_search(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val query = _editor_payload_part(payload, 1)
        if root == "" or query == "":
            me.status_msg = "missing vault root or query"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.wiki_vault_search_root = root
        me.wiki_vault_search_query = query
        val docs = _editor_markdown_vault_documents(root)
        var index = me.vault_search_index
        if index.root != root:
            val loaded = md_vault_search_index_load(_editor_vault_search_cache_path(root))
            if loaded.root == root and not loaded.dirty and md_vault_search_index_matches_documents(loaded, docs):
                index = loaded
            else:
                index = md_vault_search_index_new(root, docs)
                md_vault_search_index_save(index, _editor_vault_search_cache_path(root))
        elif index.dirty:
            index = md_vault_search_index_refresh(index, docs)
            md_vault_search_index_save(index, _editor_vault_search_cache_path(root))
        me.vault_search_index = index
        val matches = md_vault_search_index_search(index, query)
        me.wiki_panel = wiki_panel_from_vault_search(matches)
        var session = me.session
        var layout = session.dock_layout
        layout.show_right("wiki-panel")
        session.dock_layout = layout
        me.session = session
        me.status_msg = "wiki vault search: " + matches.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _request_quickfix() -> EditorAction:
        if me.session.active_index < 0 or me.session.active_index >= me.session.buffers.len():
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val doc = me.session.documents[me.session.active_index]
        val buffer = me.session.buffers[me.session.active_index]
        if doc.language_id == "markdown":
            val content = md_buffer_content(buffer)
            val row = buffer.cursor_row
            val line = buffer.line_at(row)
            val fixed = _editor_markdown_quickfix_line(line)
            if fixed != line:
                val edit_json = "{\"line\":" + str(row) + ",\"newText\":\"" + _editor_escape_json(fixed) + "\"}"
                me.code_actions = [EditorCodeAction(title: "Apply Markdown quick fix", kind: "quickfix", edit_json: edit_json, command: "")]
                me.status_msg = "1 quick fix"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            me.code_actions = []
            val diags = md_diagnose(content, doc.path())
            me.status_msg = if diags.len() > 0 then "diagnostics available" else: "no quick fixes"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.code_actions = []
        me.status_msg = "no quick fixes"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _show_diagnostics_panel() -> EditorAction:
        me.diagnostics_view_mode = "all"
        me.diagnostics_view_payload = ""
        me._refresh_diagnostics_panel_view()
        me._show_right_dock("problems")
        me.status_msg = "problems: " + me.diagnostic_store.total_count().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _show_diagnostics_filter(payload: text) -> EditorAction:
        me.diagnostics_view_mode = "filter"
        me.diagnostics_view_payload = payload
        me._refresh_diagnostics_panel_view()
        me._show_right_dock("problems")
        me.status_msg = "problems: " + _editor_problem_visible_count(me.diagnostics_panel).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _show_diagnostics_group(payload: text) -> EditorAction:
        me.diagnostics_view_mode = "group"
        me.diagnostics_view_payload = if payload == "source" then "source" else: "severity"
        me._refresh_diagnostics_panel_view()
        me._show_right_dock("problems")
        me.status_msg = "problems: " + _editor_problem_visible_count(me.diagnostics_panel).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _show_diagnostics_sort(payload: text) -> EditorAction:
        me.diagnostics_view_mode = "sort"
        me.diagnostics_view_payload = if payload == "source" or payload == "path" then payload else: "severity"
        me._refresh_diagnostics_panel_view()
        me._show_right_dock("problems")
        me.status_msg = "problems: " + _editor_problem_visible_count(me.diagnostics_panel).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _refresh_diagnostics_panel_view():
        if me.diagnostics_view_mode == "filter":
            val severity = _editor_payload_part(me.diagnostics_view_payload, 0)
            val source = _editor_payload_part(me.diagnostics_view_payload, 1)
            me.diagnostics_panel = diagnostics_panel_from_store_filtered(me.diagnostic_store, severity, source)
            return
        if me.diagnostics_view_mode == "group":
            val group_by = if me.diagnostics_view_payload == "source" then "source" else: "severity"
            me.diagnostics_panel = diagnostics_panel_from_store_grouped(me.diagnostic_store, group_by)
            return
        if me.diagnostics_view_mode == "sort":
            val sort_by = if me.diagnostics_view_payload == "source" or me.diagnostics_view_payload == "path" then me.diagnostics_view_payload else: "severity"
            me.diagnostics_panel = diagnostics_panel_from_store_sorted(me.diagnostic_store, sort_by)
            return
        me.diagnostics_panel = diagnostics_panel_from_store(me.diagnostic_store)

    me _show_right_dock(panel: text):
        var session = me.session
        var layout = session.dock_layout
        layout.show_right(panel)
        session.dock_layout = layout
        me.session = session

    me _apply_first_quickfix() -> EditorAction:
        ctrl_apply_first_quickfix(me)

    me _apply_code_action_at(index: i64) -> EditorAction:
        if me.code_actions.len() == 0:
            me.status_msg = "no quick fix selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var action_index = index
        if action_index < 0:
            action_index = 0
        if action_index >= me.code_actions.len():
            action_index = me.code_actions.len() - 1
        if me.session.active_index < 0 or me.session.active_index >= me.session.buffers.len():
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var buffer = me.session.buffers[me.session.active_index]
        val action = me.code_actions[action_index]
        val doc = me.session.documents[me.session.active_index]
        val applied = _editor_apply_code_action_content(buffer, doc.path(), action.edit_json)
        if not applied.applied:
            if action.command != "":
                val command_requested = me._execute_lsp_code_action_command(action.command)
                me.code_actions = []
                me.status_msg = if command_requested then "command requested: " + _editor_lsp_command_name(action.command) else: "code action command unavailable"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            me.status_msg = "quick fix has no editable change"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val extra_file_edits = if action.edit_json.contains("\"changes\"") then ctrl_apply_workspace_edit_extra_paths(me, doc.path(), action.edit_json) else: 0
        buffer.push_undo_snapshot()
        buffer.replace_content(applied.content)
        buffer.dirty = true
        buffer.move_cursor(applied.line, applied.col)
        me.session.buffers[me.session.active_index] = buffer
        ctrl_replace_open_document_buffer(me, doc.path(), buffer)
        me.code_actions = []
        if doc.language_id == "markdown":
            ctrl_update_markdown_preview(me, doc, buffer)
        me.status_msg = if extra_file_edits > 0 then "applied: " + action.title + " (" + extra_file_edits.to_text() + " file edits)" else: "applied: " + action.title
        if action.command != "":
            val command_requested = me._execute_lsp_code_action_command(action.command)
            if command_requested:
                me.status_msg = me.status_msg + "; command requested: " + _editor_lsp_command_name(action.command)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _execute_lsp_code_action_command(command_json: text) -> bool:
        val params = _editor_lsp_execute_command_params(command_json)
        if params == "":
            return false
        if me.session.active_index < 0 or me.session.active_index >= me.session.documents.len() or me.session.active_index >= me.session.buffers.len():
            return false
        val doc = me.session.documents[me.session.active_index]
        val buffer = me.session.buffers[me.session.active_index]
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            if not me.md_lsp_state.running:
                me.md_lsp_state = md_lsp_ensure_open(me.md_lsp_state, doc.path(), content)
            val result = md_lsp_request(me.md_lsp_state, "execute-command", params, doc.path(), 0, 0)
            me.md_lsp_state = result.0
            val md_resp: LspResponse = result.1
            return md_resp.ok
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not me.simple_lsp_state.running:
                me.simple_lsp_state = simple_lsp_ensure_open(me.simple_lsp_state, doc.path(), content)
            val simple_result = simple_lsp_request(me.simple_lsp_state, "execute-command", params, doc.path(), 0, 0)
            me.simple_lsp_state = simple_result.0
            val simple_resp: LspResponse = simple_result.1
            return simple_resp.ok
        false

    me _apply_debug_ctrl_state(next: EditorController):
        me.status_msg = next.status_msg
        me.debug_status = next.debug_status
        me.debug_registry = next.debug_registry
        me.debug_dap_client = next.debug_dap_client
        me.debug_dap_clients = next.debug_dap_clients
        me.debug_process_pid = next.debug_process_pid
        me.debug_pending_watch_expressions = next.debug_pending_watch_expressions
        me.debug_launch_configs = next.debug_launch_configs
        me.debug_launch_source_path = next.debug_launch_source_path
        me.wiki_panel = next.wiki_panel
        me.session.dock_layout = next.session.dock_layout

    me _show_debug_panel_direct(message: text):
        me.wiki_panel = _editor_debug_session_panel(editor_debug_first_session(me.debug_registry))
        var session = me.session
        var layout = session.dock_layout
        layout.active_right = "wiki-panel"
        layout.right_visible = true
        session.dock_layout = layout
        me.session = session
        me.status_msg = message

    me _start_debug_adapter(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else debug_type
        val adapter = me.extension_host.find_debug_adapter(adapter_id)
        val doc = me.session.active_document()
        val fallback_program = if adapter_id == "simple" then "bin/simple" else: extension_debug_adapter_program(adapter)
        val program = if doc == nil or doc.path() == "" then fallback_program else: doc.path()
        val launch_config = _editor_debug_launch_config_for_doc(program, adapter_id)
        val session_id = me.debug_registry.next_session_id
        me.debug_registry = editor_debug_registry_start(me.debug_registry, launch_config)
        var dap = EditorDebugDapClient.new()
        dap.start()
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, launch_config)
        dap = launched.0
        me.debug_dap_client = dap
        val client_index = session_id - 1
        while me.debug_dap_clients.len() <= client_index:
            me.debug_dap_clients.push(EditorDebugDapClient.new())
        me.debug_dap_clients[client_index] = dap
        me.debug_status = "starting"
        me.status_msg = "debug adapter: " + editor_debug_launch_config_name(launch_config)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _start_debug_process_adapter(debug_type: text) -> EditorAction:
        ctrl_start_debug_process_adapter(me, debug_type)

    me _debug_show_launch_configs(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else: debug_type
        val lookup_adapter_id = _editor_debug_resolve_adapter_id(me, adapter_id)
        val adapter = me.extension_host.find_debug_adapter(lookup_adapter_id)
        if _editor_debug_adapter_missing(adapter, adapter_id):
            me.status_msg = "debug adapter not found: " + adapter_id
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val doc = me.session.active_document()
        val program = if doc == nil or doc.path() == "" then _editor_debug_adapter_program_or_default(adapter, adapter_id) else: doc.path()
        me.debug_launch_source_path = _editor_find_launch_json(program)
        me.debug_launch_configs = _editor_debug_launch_configs_for_doc(program, adapter_id)
        me.wiki_panel = _editor_debug_launch_config_panel(me.debug_launch_configs)
        me._show_right_dock("wiki-panel")
        me.status_msg = "debug launch configs: " + me.debug_launch_configs.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_start_selected_launch_config() -> EditorAction:
        if me.debug_launch_configs.len() == 0:
            me.status_msg = "no debug launch config"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var index = me.wiki_panel.selected
        if index < 0:
            index = 0
        if index >= me.debug_launch_configs.len():
            index = me.debug_launch_configs.len() - 1
        val config = me.debug_launch_configs[index]
        if editor_debug_launch_config_is_compound(config):
            return me._debug_start_compound_launch_config(config)
        val config_debug_type = editor_debug_launch_config_debug_type(config)
        val lookup_adapter_id = _editor_debug_resolve_adapter_id(me, config_debug_type)
        val adapter = me.extension_host.find_debug_adapter(lookup_adapter_id)
        if _editor_debug_adapter_missing(adapter, config_debug_type):
            me.status_msg = "debug adapter not found: " + config_debug_type
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val session_id = me.debug_registry.next_session_id
        me.debug_registry = editor_debug_registry_start(me.debug_registry, config)
        var dap = me.debug_dap_client
        dap.start()
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, config)
        dap = launched.0
        me.debug_dap_client = dap
        val client_index = session_id - 1
        while me.debug_dap_clients.len() <= client_index:
            me.debug_dap_clients.push(EditorDebugDapClient.new())
        me.debug_dap_clients[client_index] = dap
        me.debug_status = "starting"
        me.status_msg = "debug adapter: " + editor_debug_launch_config_name(config)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_start_compound_launch_config(compound_config: EditorDebugLaunchConfig) -> EditorAction:
        val launch_path = me.debug_launch_source_path
        if launch_path == "":
            me.status_msg = "debug compound source not found: " + editor_debug_launch_config_name(compound_config)
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val content = rt_file_read_text(launch_path) ?? ""
        val workspace = _editor_workspace_dir_from_launch_json(launch_path)
        val doc = me.session.active_document()
        val program = if doc == nil then "" else: doc.path()
        val member_names = editor_debug_launch_config_program(compound_config).split("|")
        val all_configs = editor_debug_launch_configs_from_json(content)
        var member_configs: [EditorDebugLaunchConfig] = []
        for member_name in member_names:
            for candidate in all_configs:
                if editor_debug_launch_config_name(candidate) == member_name.trim():
                    var selected = editor_debug_launch_config_with_program(candidate, program)
                    member_configs.push(editor_debug_resolve_launch_config(selected, workspace, program))
        if member_configs.len() == 0:
            me.status_msg = "debug compound empty: " + editor_debug_launch_config_name(compound_config)
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var aggregate = me.debug_dap_client
        aggregate.start()
        for config in member_configs:
            val config_debug_type = editor_debug_launch_config_debug_type(config)
            val lookup_adapter_id = _editor_debug_resolve_adapter_id(me, config_debug_type)
            val adapter = me.extension_host.find_debug_adapter(lookup_adapter_id)
            if _editor_debug_adapter_missing(adapter, config_debug_type):
                me.status_msg = "debug adapter not found: " + config_debug_type
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val session_id = me.debug_registry.next_session_id
            me.debug_registry = editor_debug_registry_start(me.debug_registry, config)
            var dap = EditorDebugDapClient.new()
            dap.start()
            val initialized = editor_debug_dap_client_initialize(dap)
            dap = initialized.0
            val launched = editor_debug_dap_client_launch(dap, config)
            dap = launched.0
            val client_index = session_id - 1
            while me.debug_dap_clients.len() <= client_index:
                me.debug_dap_clients.push(EditorDebugDapClient.new())
            me.debug_dap_clients[client_index] = dap
            for frame in dap.send_buffer:
                aggregate.send_buffer.push(frame)
        me.debug_dap_client = aggregate
        me.debug_status = "starting"
        me.status_msg = "debug compound: " + editor_debug_launch_config_name(compound_config) + " (" + member_configs.len().to_text() + " sessions)"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_show_session() -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me._show_debug_panel_direct("debug session")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_show_sessions() -> EditorAction:
        me.wiki_panel = _editor_debug_sessions_panel(me.debug_registry)
        me._show_right_dock("wiki-panel")
        me.status_msg = "debug sessions: " + editor_debug_session_count(me.debug_registry).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_switch_selected_session() -> EditorAction:
        if me.wiki_panel.rows.len() == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var index = me.wiki_panel.selected
        if index < 0:
            index = 0
        if index >= me.wiki_panel.rows.len():
            index = me.wiki_panel.rows.len() - 1
        me._debug_switch_session(me.wiki_panel.rows[index].line)

    me _debug_switch_session(session_id: i64) -> EditorAction:
        if session_id <= 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_registry_select(me.debug_registry, session_id)
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) != session_id:
            me.status_msg = "debug session not found: " + session_id.to_text()
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me._debug_activate_client_for_session(session_id)
        me.debug_status = editor_debug_session_status(session)
        me._show_debug_panel_direct("debug session: " + editor_debug_session_id(session).to_text())
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_activate_client_for_session(session_id: i64):
        val index = session_id - 1
        if index >= 0 and index < me.debug_dap_clients.len():
            val clients = me.debug_dap_clients
            me.debug_dap_client = clients[index]

    me _show_keyboard_shortcuts() -> EditorAction:
        me.wiki_panel = _editor_keyboard_shortcuts_panel(default_keybindings())
        me._show_right_dock("wiki-panel")
        me.status_msg = "keyboard shortcuts"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_add_breakpoint(path: text, line: i64, condition: text, log_message: text, hit_condition: text) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_add_breakpoint(me.debug_registry, editor_debug_session_id(session), path, line, condition, log_message, hit_condition)
        if me.debug_dap_client.running:
            val synced = editor_debug_dap_client_set_breakpoints(me.debug_dap_client, path, editor_debug_session_breakpoints(editor_debug_first_session(me.debug_registry)))
            me.debug_dap_client = synced.0
        me.status_msg = "breakpoint set: " + path + ":" + line.to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_add_watch(expression: text) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_add_watch(me.debug_registry, editor_debug_session_id(session), expression)
        me._debug_queue_watch_evaluate(expression)
        me._show_debug_panel_direct("watch added: " + expression)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_evaluate(expression: text) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_evaluate(me.debug_registry, editor_debug_session_id(session), expression)
        if me.debug_dap_client.running:
            val requested = editor_debug_dap_client_evaluate(me.debug_dap_client, expression, 1)
            me.debug_dap_client = requested.0
        me._show_debug_panel_direct("debug evaluate: " + expression)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_queue_watch_evaluate(expression: text):
        if not me.debug_dap_client.running:
            return
        val requested = editor_debug_dap_client_evaluate(me.debug_dap_client, expression, _editor_debug_active_frame_id(editor_debug_first_session(me.debug_registry)))
        me.debug_dap_client = requested.0
        me.debug_pending_watch_expressions.push(expression)

    me _debug_refresh_watches() -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        var refreshed = 0
        for watch in session.watches:
            me._debug_queue_watch_evaluate(watch.expression)
            refreshed = refreshed + 1
        me.status_msg = "debug watches refreshed: " + refreshed.to_text()
        EditorAction(redraw: refreshed > 0, quit: false, status_msg: me.status_msg)

    me _debug_update_watch_result(expression: text, value: text, status: text) -> EditorAction:
