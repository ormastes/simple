        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_task_batch(payload: text) -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown task"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val normalized = payload.trim().to_lower()
        val checked = normalized == "done" or normalized == "checked" or normalized == "complete" or normalized == "completed"
        val next = md_tasks_set_checked(buffer.to_text(), checked)
        if next == buffer.to_text():
            me.status_msg = "no tasks changed"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.push_undo_snapshot()
        buffer.replace_content(next)
        buffer.dirty = true
        ctrl_update_markdown_preview(me, doc, buffer)
        me.session.update_active_buffer(buffer)
        ctrl_notify_active_lsp_changed(me)
        me.wiki_property_vault_root = _editor_dirname(doc.path())
        val index = ctrl_wiki_index_open_documents(me)
        me.wiki_panel = wiki_panel_from_tasks(md_wiki_tasks_filtered(index, if checked then "done" else: "open"))
        me._show_right_dock("wiki-panel")
        me.status_msg = if checked then "tasks marked done" else: "tasks marked open"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_vault_task_batch(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val mode = _editor_payload_part(payload, 1).trim().to_lower()
        if root == "":
            me.status_msg = "missing vault root"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val checked = mode == "done" or mode == "checked" or mode == "complete" or mode == "completed"
        var changed_count = 0
        val files = rt_dir_walk(root)
        for file in files:
            if not _editor_is_markdown_path(file):
                continue
            val existing = rt_file_read_text(file) ?? ""
            val next = md_tasks_set_checked(existing, checked)
            if next != existing:
                if rt_file_write_text(file, next):
                    changed_count = changed_count + 1
                    me._refresh_open_document_from_disk_batch(file, next)
        val index = md_wiki_index_documents(_editor_markdown_vault_documents(root))
        me.wiki_panel = wiki_panel_from_tasks(md_wiki_tasks_filtered(index, if checked then "done" else: "open"))
        me._show_right_dock("wiki-panel")
        me.status_msg = "vault tasks changed: " + changed_count.to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_show_properties() -> EditorAction:
        val doc = me.session.active_document()
        if doc == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val index = ctrl_wiki_index_open_documents(me)
        me.wiki_panel = wiki_panel_from_properties(md_wiki_properties_for_path(index, doc.path()))
        me._show_right_dock("wiki-panel")
        me.status_msg = "wiki properties panel"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_set_property(payload: text) -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val parsed = _editor_parse_property_payload(payload)
        if parsed.key == "":
            me.status_msg = "missing property key"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val next = _editor_markdown_property_content(buffer.to_text(), parsed.key, parsed.value)
        buffer.push_undo_snapshot()
        buffer.replace_content(next)
        buffer.dirty = true
        buffer.move_cursor(0, 0)
        ctrl_update_markdown_preview(me, doc, buffer)
        me.session.update_active_buffer(buffer)
        ctrl_notify_active_lsp_changed(me)
        val index = ctrl_wiki_index_open_documents(me)
        me.wiki_panel = wiki_panel_from_properties(md_wiki_properties_for_path(index, doc.path()))
        me._show_right_dock("wiki-panel")
        me.status_msg = "property set: " + parsed.key
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_vault_set_property(payload: text) -> EditorAction:
        val parsed = _editor_parse_vault_property_payload(payload)
        if parsed.root == "" or parsed.key == "":
            me.status_msg = "missing vault root or property key"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.wiki_property_vault_root = parsed.root
        var changed_count = 0
        val files = rt_dir_walk(parsed.root)
        for file in files:
            if not _editor_is_markdown_path(file):
                continue
            if not _editor_vault_property_path_selected(file, parsed.selected_paths):
                continue
            val existing = rt_file_read_text(file) ?? ""
            val next = _editor_markdown_property_content(existing, parsed.key, parsed.value)
            if next != existing:
                if rt_file_write_text(file, next):
                    changed_count = changed_count + 1
                    me._refresh_open_document_from_disk_batch(file, next)
        val index = md_wiki_index_documents(_editor_markdown_vault_documents(parsed.root))
        me.wiki_panel = wiki_panel_from_properties(_editor_wiki_properties_for_key(index, parsed.key))
        me._show_right_dock("wiki-panel")
        me.status_msg = "vault property set: " + changed_count.to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_vault_property_review(payload: text) -> EditorAction:
        val parsed = _editor_parse_vault_property_payload(payload)
        if parsed.root == "" or parsed.key == "":
            me.status_msg = "missing vault root or property key"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.wiki_property_vault_root = parsed.root
        var rows: [WikiPanelRow] = []
        val files = rt_dir_walk(parsed.root)
        for file in files:
            if not _editor_is_markdown_path(file):
                continue
            if not _editor_vault_property_path_selected(file, parsed.selected_paths):
                continue
            val existing = rt_file_read_text(file) ?? ""
            val next = _editor_markdown_property_content(existing, parsed.key, parsed.value)
            if next != existing:
                rows.push(WikiPanelRow(icon: "review", label: _editor_path_basename(file), detail: parsed.key + " -> " + parsed.value, path: file, line: 0))
        me.wiki_panel = wiki_panel_with_rows("Property Review", rows)
        me._show_right_dock("wiki-panel")
        me.status_msg = "vault property review: " + rows.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_property_diagnostics(payload: text) -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val schema_key = _editor_payload_part(payload, 0).trim()
        if schema_key == "":
            me.status_msg = "missing property schema"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val required_text = _editor_payload_part(payload, 1).trim()
        val allowed_text = _editor_payload_part(payload, 2).trim()
        val required = required_text == "required" or required_text == "true" or required_text == "yes"
        val allowed = _editor_payload_csv(allowed_text)
        me.wiki_property_schema_payload = payload
        var lines: [text] = []
        var line_cursor = 0
        while line_cursor < buffer.line_count():
            lines.push(buffer.line_at(line_cursor))
            line_cursor = line_cursor + 1
        var found = false
        var value = ""
        var line_index = 0
        if lines.len() > 0 and lines[0].trim() == "---":
            var i = 1
            while i < lines.len():
                val trimmed = lines[i].trim()
                if trimmed == "---":
                    break
                val sep = _editor_find_text(trimmed, ":")
                if sep > 0 and trimmed.slice(0, sep).trim() == schema_key:
                    found = true
                    value = trimmed.slice(sep + 1, trimmed.len()).trim()
                    line_index = i
                    break
                i = i + 1
        var diags: [EditorDiagnostic] = []
        if required and not found:
            diags.push(EditorDiagnostic(path: doc.path(), line: 0, col: 0, end_line: 0, end_col: 0, severity: "warning", message: "Missing required frontmatter property: " + schema_key, source: "markdown-properties"))
        elif found and required and value == "":
            diags.push(EditorDiagnostic(path: doc.path(), line: line_index, col: 0, end_line: line_index, end_col: lines[line_index].len(), severity: "warning", message: "Frontmatter property requires a value: " + schema_key, source: "markdown-properties"))
        elif found and allowed.len() > 0:
            var allowed_match = false
            for allowed_value in allowed:
                if allowed_value == value:
                    allowed_match = true
            if not allowed_match:
                diags.push(EditorDiagnostic(path: doc.path(), line: line_index, col: 0, end_line: line_index, end_col: lines[line_index].len(), severity: "warning", message: "Invalid frontmatter value for " + schema_key + ": " + value, source: "markdown-properties"))
        me.diagnostic_store.set_diagnostics(doc.path(), diags)
        me.diagnostics_panel = diagnostics_panel_from_store(me.diagnostic_store)
        me._show_right_dock("problems")
        me.status_msg = "property diagnostics: " + diags.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_show_tags(tag: text) -> EditorAction:
        val needle = tag.trim()
        if needle == "":
            me.status_msg = "missing wiki tag"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val index = ctrl_wiki_index_open_documents(me)
        me.wiki_panel = wiki_panel_from_tags(md_wiki_tags(index, needle))
        me._show_right_dock("wiki-panel")
        me.status_msg = "wiki tags panel"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _wiki_show_graph() -> EditorAction:
        val doc = me.session.active_document()
        val path = if doc == nil then "" else: doc.path()
        val index = ctrl_wiki_index_open_documents(me)
        val edges = md_wiki_graph_edges(index, path)
        var ordered_edges: [MdWikiGraphEdge] = []
        val title = md_wiki_title_from_path(path)
        if path != "":
            for edge in edges:
                if edge.source_path != path and edge.target == title:
                    ordered_edges.push(edge)
        for edge in edges:
            if path == "" or edge.source_path == path or edge.target != title:
                ordered_edges.push(edge)
        me.wiki_panel = wiki_panel_from_graph_edges_with_index(ordered_edges, index)
        me._show_right_dock("wiki-panel")
        me.status_msg = "wiki graph panel"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

