    me _show_wiki_panel(message: text):
        ctrl_show_wiki_panel(me, message)

    me _set_lsp_result_panel_from_response(kind: text, response: LspResponse):
        if kind == "code-action" and response.ok and response.result_json != "":
            me.code_actions = _editor_code_actions_from_response(response.result_json)
            me.lsp_result_panel = ctrl_code_action_result_panel(me, response.id)
            return
        if kind == "code-action" and response.ok and response.result_json == "":
            me.lsp_result_panel = lsp_result_panel_pending(kind, response.id)
            return
        if response.ok and response.result_json == "" and _editor_lsp_kind_has_panel(kind):
            me.lsp_result_panel = lsp_result_panel_pending(kind, response.id)
            return
        var panel = lsp_result_panel_from_response(kind, response)
        if kind == "call-hierarchy" or kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing":
            val title = lsp_result_title(kind)
            if panel.pending:
                if me.lsp_result_panel.title == title:
                    me.lsp_call_hierarchy_state = lsp_result_panel_call_state(me.lsp_result_panel)
                    me.lsp_call_hierarchy_state_title = title
            else:
                if me.lsp_result_panel.title == title and me.lsp_call_hierarchy_state_title == title:
                    panel = lsp_result_panel_restore_call_state(panel, me.lsp_call_hierarchy_state)
                if (kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing") and me.lsp_call_hierarchy_merge_index >= 0 and me.lsp_call_hierarchy_merge_panel.title == "Call Hierarchy":
                    val merge_panel = me.lsp_call_hierarchy_merge_panel
                    val merge_index = me.lsp_call_hierarchy_merge_index
                    if merge_index >= 0 and merge_index < merge_panel.rows.len():
                        var merged_rows: [LspResultRow] = []
                        var merge_row_index = 0
                        while merge_row_index < merge_panel.rows.len():
                            val parent = merge_panel.rows[merge_row_index]
                            if merge_row_index == merge_index:
                                merged_rows.push(LspResultRow(
                                    icon: parent.icon,
                                    label: parent.label,
                                    detail: parent.detail,
                                    path: parent.path,
                                    line: parent.line,
                                    col: parent.col,
                                    command_name: parent.command_name,
                                    command_payload: parent.command_payload,
                                    depth: parent.depth,
                                    expanded: true
                                ))
                                var child_index = 0
                                while child_index < panel.rows.len():
                                    val child = panel.rows[child_index]
                                    merged_rows.push(LspResultRow(
                                        icon: child.icon,
                                        label: child.label,
                                        detail: child.detail,
                                        path: child.path,
                                        line: child.line,
                                        col: child.col,
                                        command_name: child.command_name,
                                        command_payload: child.command_payload,
                                        depth: parent.depth + 1,
                                        expanded: if child.icon == "call" then true else: child.expanded
                                    ))
                                    child_index = child_index + 1
                            else:
                                merged_rows.push(parent)
                            merge_row_index = merge_row_index + 1
                        panel = LspResultPanel(
                            title: merge_panel.title,
                            rows: merged_rows,
                            selected: merge_panel.selected,
                            scroll_offset: merge_panel.scroll_offset,
                            visible: merge_panel.visible,
                            pending: false,
                            request_id: response.id
                        )
                    me.lsp_call_hierarchy_merge_index = -1
                    me.lsp_call_hierarchy_merge_panel = lsp_result_panel_new("")
                    me.lsp_call_hierarchy_state = lsp_result_panel_call_state(panel)
                    me.lsp_call_hierarchy_state_title = panel.title
                elif kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing":
                    var expanded_rows: [LspResultRow] = []
                    for row in panel.rows:
                        expanded_rows.push(LspResultRow(
                            icon: row.icon,
                            label: row.label,
                            detail: row.detail,
                            path: row.path,
                            line: row.line,
                            col: row.col,
                            command_name: row.command_name,
                            command_payload: row.command_payload,
                            depth: row.depth,
                            expanded: if row.icon == "call" then true else: row.expanded
                        ))
                    panel = LspResultPanel(
                        title: panel.title,
                        rows: expanded_rows,
                        selected: panel.selected,
                        scroll_offset: panel.scroll_offset,
                        visible: panel.visible,
                        pending: panel.pending,
                        request_id: panel.request_id
                    )
        me.lsp_result_panel = panel

    me _request_active_lsp_action(kind: text) -> EditorAction:
        val response = me._request_active_lsp(kind)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if _editor_lsp_kind_has_panel(kind):
            me._set_lsp_result_panel_from_response(kind, response)
            if kind == "document-symbols" and response.result_json != "":
                me._apply_lsp_document_symbols_outline()
            me._refresh_lsp_hover_popup(kind)
            me._show_lsp_result_panel(kind + " results")
            me.status_msg = kind + " results"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if kind == "formatting":
            me.pending_workspace_edit_title = "formatting"
        if kind == "range-formatting":
            me.pending_workspace_edit_title = "range formatting"
        me.status_msg = kind + " requested"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

