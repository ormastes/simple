    me _execute_markdown_extension_command(command_name: text) -> EditorAction:
        ctrl_execute_markdown_extension_command(me, command_name)

    me _fold_all_active_document() -> EditorAction:
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.clear_folds()
        var folded_count = 0
        var line = 0
        while line < buffer.line_count():
            val level = _editor_markdown_heading_level(buffer.line_at(line))
            if level > 0:
                var end_line = buffer.line_count() - 1
                var scan = line + 1
                while scan < buffer.line_count():
                    val scan_level = _editor_markdown_heading_level(buffer.line_at(scan))
                    if scan_level > 0 and scan_level <= level:
                        end_line = scan - 1
                        scan = buffer.line_count()
                    else:
                        scan = scan + 1
                if end_line > line:
                    buffer.fold_range(line, end_line)
                    folded_count = folded_count + 1
            line = line + 1
        me.session.update_active_buffer(buffer)
        me.status_msg = "folded " + folded_count.to_text() + " ranges"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _unfold_all_active_document() -> EditorAction:
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.clear_folds()
        me.session.update_active_buffer(buffer)
        me.status_msg = "unfolded all"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _toggle_active_markdown_fold() -> EditorAction:
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val content = md_buffer_content(buffer)
        val range = md_vim_toggle_fold_heading(content, buffer.cursor_row)
        val start_line = range.0
        val end_line = range.1
        if end_line <= start_line:
            me.status_msg = "no foldable section"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.toggle_fold_range(start_line, end_line)
        val folded = buffer.has_fold_range(start_line, end_line)
        me.session.update_active_buffer(buffer)
        me.status_msg = if folded then "folded section" else: "unfolded section"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _activate_active_language():
        if me.session.active_index < 0 or me.session.active_index >= me.session.documents.len() or me.session.active_index >= me.session.buffers.len():
            return
        val doc = me.session.documents[me.session.active_index]
        me.extension_host.activate_language(doc.language_id)
        me.extension_host.emit_event("onDidOpenTextDocument", doc.path())
        me.extension_host.emit_event("onLanguage:" + doc.language_id, doc.path())
        val buffer = me.session.buffers[me.session.active_index]
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            me.md_lsp_state = md_lsp_ensure_open(me.md_lsp_state, doc.path(), content)
        elif doc.language_id == "simple" or doc.language_id == "shell":
            me.simple_lsp_state = simple_lsp_ensure_open(me.simple_lsp_state, doc.path(), content)
        me.file_watcher.watch(doc.path())
        me.file_watcher.watch_parent_directory(doc.path())
        ctrl_poll_lsp_diagnostics(me)

    me _configure_file_watcher_policy(poll_interval_ms: i64, ignore_globs: [text]) -> EditorAction:
        ctrl_configure_file_watcher_policy(me, poll_interval_ms, ignore_globs)

    me _poll_file_watcher() -> EditorAction:
        val events = me.file_watcher.check_events()
        me._apply_file_watch_events(events)

    me _poll_file_watcher_after(elapsed_ms: i64) -> EditorAction:
        val events = me.file_watcher.check_events_debounced(elapsed_ms)
        me._apply_file_watch_events(events)

    me _apply_file_watch_events(events: [FileWatchEvent]) -> EditorAction:
        if events.len() == 0:
            return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
        var i = 0
        while i < events.len():
            val event = events[i]
            val path = event.path
            val content = rt_file_read_text(path) ?? ""
            if event.change_type != 3:
                me._refresh_open_document_from_disk_batch(path, content)
            me._notify_lsp_file_changed(path, event.change_type)
            i = i + 1
        me.status_msg = "file changes notified: " + events.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _notify_active_lsp_changed():
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil:
            return
        val should_refresh_inlay_hints = buffer.has_inlay_hints() or me.lsp_result_panel.title == "Inlay Hints"
        val content = md_buffer_content(buffer)
        buffer.clear_inlay_hints()
        buffer.clear_semantic_tokens()
        buffer.clear_code_lenses()
        me.session.update_active_buffer(buffer)
        me.diagnostic_store.clear_diagnostics(doc.path())
        if me.session.dock_layout.active_right_panel() == "problems":
            me._refresh_diagnostics_panel_view()
        if doc.language_id == "markdown" and me.md_lsp_state.running:
            me.md_lsp_state = md_lsp_change_active(me.md_lsp_state, doc.path(), content)
        elif (doc.language_id == "simple" or doc.language_id == "shell") and me.simple_lsp_state.running:
            me.simple_lsp_state = simple_lsp_change_active(me.simple_lsp_state, doc.path(), content)
        if should_refresh_inlay_hints:
            me._schedule_inlay_hint_refresh()
        me._poll_lsp_diagnostics()

    me _schedule_inlay_hint_refresh():
        me.pending_inlay_hint_refresh = true
        me.inlay_hint_refresh_elapsed_ms = 0
        me.lsp_result_panel = lsp_result_panel_pending("inlay-hints", 0)

    me _cancel_pending_inlay_hint_refresh():
        me.pending_inlay_hint_refresh = false
        me.inlay_hint_refresh_elapsed_ms = 0

    me _poll_inlay_hint_refresh_after(elapsed_ms: i64) -> EditorAction:
        if not me.pending_inlay_hint_refresh:
            return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
        me.inlay_hint_refresh_elapsed_ms = me.inlay_hint_refresh_elapsed_ms + elapsed_ms
        if me.inlay_hint_refresh_elapsed_ms < me.inlay_hint_refresh_delay_ms:
            return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
        me._cancel_pending_inlay_hint_refresh()
        me._refresh_active_inlay_hints_after_change()
        me.status_msg = "inlay hints refreshed"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _refresh_active_inlay_hints_after_change():
        val response: LspResponse = me._request_active_lsp("inlay-hints")
        if not response.ok:
            return
        me.lsp_result_panel = lsp_result_panel_from_response("inlay-hints", response)
        if response.result_json != "":
            me._apply_lsp_inlay_hints_result(response.result_json)

    me _start_markdown_lsp_for_active(path: text, content: text):
        ctrl_start_markdown_lsp_for_active(me, path, content)

    me _start_simple_lsp_for_active(path: text, content: text):
        ctrl_start_simple_lsp_for_active(me, path, content)

    me _poll_lsp_diagnostics():
        var changed = false
        if me.md_lsp_state.running:
            val md_result = md_lsp_poll_all_notifications(me.md_lsp_state)
            me.md_lsp_state = md_result.0
            val md_notifications: [LspNotification] = md_result.1
            for n in md_notifications:
                if n.method == "textDocument/publishDiagnostics":
                    me.diagnostic_store = diagnostics_store_with_publish(me.diagnostic_store, n.params_json)
                    changed = true
        if me.simple_lsp_state.running:
            val simple_result = simple_lsp_poll_all_notifications(me.simple_lsp_state)
            me.simple_lsp_state = simple_result.0
            val simple_notifications: [LspNotification] = simple_result.1
            for sn in simple_notifications:
                if sn.method == "textDocument/publishDiagnostics":
                    me.diagnostic_store = diagnostics_store_with_publish(me.diagnostic_store, sn.params_json)
                    changed = true
        if changed:
            me._refresh_diagnostics_panel_view()

    me _poll_lsp_results() -> EditorAction:
        ctrl_poll_lsp_results(me)

    me _refresh_lsp_results() -> bool:
        var updated = false
        if me.md_lsp_state.running:
            var md_client = me.md_lsp_state.client
            val md_poll = ctrl_lsp_drain_completed_responses(md_client)
            md_client = md_poll.0
            val md_responses = md_poll.1
            me.md_lsp_state = MdLspState(client: md_client, running: me.md_lsp_state.running, version: me.md_lsp_state.version)
            for response in md_responses:
                if me._hydrate_lsp_result_response(response):
                    updated = true
        if me.simple_lsp_state.running:
            var simple_client = me.simple_lsp_state.client
            val simple_poll = ctrl_lsp_drain_completed_responses(simple_client)
            simple_client = simple_poll.0
            val simple_responses = simple_poll.1
            me.simple_lsp_state = SimpleLspState(client: simple_client, running: me.simple_lsp_state.running, version: me.simple_lsp_state.version)
            for simple_response in simple_responses:
                if me._hydrate_lsp_result_response(simple_response):
                    updated = true
        updated

    me _hydrate_lsp_result_json(method: text, json: text) -> bool:
        ctrl_hydrate_lsp_result_json(me, method, json)

    me _hydrate_lsp_result_response(completed: LspCompletedResponse) -> bool:
        var method = completed.method
        if method == "":
            method = ctrl_infer_lsp_completed_method(me, completed.id)
        if method == "textDocument/rename":
            var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
            if response.result_json == "" and completed.raw_json != "":
                response = lsp_response_from_json(completed.raw_json)
            if not response.ok:
                me.status_msg = response.error_text
                return true
            if response.result_json == "":
                return false
            if me.lsp_result_panel.pending and me.lsp_result_panel.request_id == completed.id and me.lsp_result_panel.title == "Rename Preview":
                me._show_workspace_edit_preview(response.result_json, "rename")
                return true
            me._apply_workspace_edit_result(response.result_json, "rename")
            me.status_msg = "applied: rename"
            me.pending_workspace_edit_title = ""
            return true
        if method == "textDocument/formatting" or method == "textDocument/rangeFormatting":
            var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
            if response.result_json == "" and completed.raw_json != "":
                response = lsp_response_from_json(completed.raw_json)
            if not response.ok:
                me.status_msg = response.error_text
                return true
            if response.result_json == "":
                return false
            val title = if method == "textDocument/rangeFormatting" then "range formatting" else: "formatting"
            val preview_title = if method == "textDocument/rangeFormatting" then "Range Formatting Preview" else: "Formatting Preview"
            if me.lsp_result_panel.pending and me.lsp_result_panel.request_id == completed.id and me.lsp_result_panel.title == preview_title:
                me._show_workspace_edit_preview(response.result_json, title)
                return true
            if me.format_save_request_id == completed.id:
                me._apply_workspace_edit_result(response.result_json, title)
                me.format_save_request_id = 0
                me.format_save_title = ""
                val saved = me.session.save_active()
                if saved:
                    me.status_msg = "applied and saved: " + title
                else:
                    me.status_msg = "applied: " + title + " (save failed)"
                return true
            me._apply_workspace_edit_result(response.result_json, title)
            me.status_msg = "applied: " + title
            me.pending_workspace_edit_title = ""
            return true
        if me.lsp_result_panel.pending and completed.id == me.lsp_result_panel.request_id and me.lsp_result_panel.title == "Code Actions":
            var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
            if response.result_json == "" and completed.raw_json != "":
                response = lsp_response_from_json(completed.raw_json)
            if response.ok and response.result_json != "":
                me.code_actions = _editor_code_actions_from_response(response.result_json)
                me.lsp_result_panel = ctrl_code_action_result_panel(me, response.id)
                me._refresh_lsp_hover_popup("code-action")
                return true
        if not me.lsp_result_panel.pending:
            return false
        if completed.id != me.lsp_result_panel.request_id:
            return false
        var kind = _editor_lsp_method_to_kind(method)
        if kind == "":
            kind = _editor_lsp_kind_from_panel_title(me.lsp_result_panel.title)
        if not _editor_lsp_kind_has_panel(kind):
            return false
        var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
        if response.result_json == "" and completed.raw_json != "":
            response = lsp_response_from_json(completed.raw_json)
        if kind == "code-action":
            if response.ok and response.result_json != "":
                me.code_actions = _editor_code_actions_from_response(response.result_json)
                me.lsp_result_panel = ctrl_code_action_result_panel(me, response.id)
                me._refresh_lsp_hover_popup(kind)
                return true
            if response.ok:
                me.lsp_result_panel = lsp_result_panel_pending(kind, response.id)
                me._refresh_lsp_hover_popup(kind)
                return false
        me._set_lsp_result_panel_from_response(kind, response)
        if kind == "folding-ranges" and response.ok and response.result_json != "":
            me._apply_lsp_folding_ranges_result(response.result_json)
        if kind == "inlay-hints" and response.ok and response.result_json != "":
            me._apply_lsp_inlay_hints_result(response.result_json)
        if kind == "semantic-tokens" and response.ok and response.result_json != "":
            me._apply_lsp_semantic_tokens_result(response.result_json)
        if (kind == "code-lens" or kind == "code-lens-resolve") and response.ok and response.result_json != "":
            me._apply_lsp_code_lens_panel()
        if kind == "document-symbols" and response.ok and response.result_json != "":
            me._apply_lsp_document_symbols_outline()
        me._refresh_lsp_hover_popup(kind)
        return true

    me _apply_lsp_document_symbols_outline():
        val active_id = me.session.active_doc_id()
        var docs: [EditorDocument] = []
        var changed = false
        var i = 0
        while i < me.session.documents.len():
            var doc = me.session.documents[i]
            if doc.doc_id().int_value() == active_id.int_value():
                var items: [OutlineItem] = []
                for row in me.lsp_result_panel.rows:
                    if row.icon == "symbol":
                        items.push(OutlineItem(kind: "symbol", label: row.label, line: row.line, depth: row.depth))
                if items.len() > 0:
                    var md_state = doc.md_state
                    if md_state == nil:
                        md_state = MarkdownState.new()
                    md_state.outline = outline_panel_from_items(items)
                    md_state.outline_visible = true
                    doc.md_state = md_state
                    changed = true
            docs.push(doc)
            i = i + 1
        if changed:
            me.session.documents = docs
            me._show_right_dock("md-outline")

    me _apply_lsp_folding_ranges_result(result_json: text):
        val buffer = me.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_folds()
        var cursor = 0
        while cursor < result_json.len():
            val slice = result_json.slice(cursor, result_json.len())
            val relative = _editor_find_text(slice, "\"startLine\"")
            if relative < 0:
                me.session.update_active_buffer(buffer)
                return
            val range_json = result_json.slice(cursor + relative, result_json.len())
            val start_line = _editor_json_number_field(range_json, "\"startLine\"")
            val end_line = _editor_json_number_field(range_json, "\"endLine\"")
            buffer.fold_range(start_line, end_line)
            cursor = cursor + relative + 11
        me.session.update_active_buffer(buffer)

    me _apply_lsp_semantic_tokens_result(result_json: text):
        ctrl_apply_lsp_semantic_tokens_result(me, result_json)

    me _apply_lsp_inlay_hints_result(result_json: text):
        val buffer = me.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_inlay_hints()
        var cursor = 0
        while cursor < result_json.len():
            val slice = result_json.slice(cursor, result_json.len())
            val relative = _editor_find_text(slice, "\"position\"")
            if relative < 0:
                me.session.update_active_buffer(buffer)
                return
            val hint_json = result_json.slice(cursor + relative, result_json.len())
            val line = _editor_json_number_field(hint_json, "\"line\"")
            val col = _editor_json_number_field(hint_json, "\"character\"")
            val label = _editor_json_string_field(hint_json, "\"label\"")
            buffer.add_inlay_hint(line, col, label)
            cursor = cursor + relative + 10
        me.session.update_active_buffer(buffer)

    me _apply_lsp_code_lens_panel():
        val buffer = me.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_code_lenses()
        for row in me.lsp_result_panel.rows:
            if row.icon == "lens":
                buffer.add_code_lens(row.line, row.label, row.command_name, row.command_payload)
        me.session.update_active_buffer(buffer)

    me _apply_workspace_edit_result(edit_json: text, title: text) -> EditorAction:
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val doc = me.session.active_document()
        val doc_path = if doc == nil then "" else: doc.path()
        val applied = _editor_apply_code_action_content(buffer, doc_path, edit_json)
        if not applied.applied:
            me.status_msg = title + " has no editable change"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val extra_file_edits = if edit_json.contains("\"changes\"") then me._apply_workspace_edit_extra_paths(doc_path, edit_json) else: 0
        buffer.push_undo_snapshot()
        buffer.replace_content(applied.content)
        buffer.dirty = true
        buffer.move_cursor(applied.line, applied.col)
        me.session.update_active_buffer(buffer)
        me._replace_open_document_buffer(doc_path, buffer)
        if doc != nil and doc.language_id == "markdown":
            me._update_markdown_preview(doc, buffer)
        if extra_file_edits > 0:
            me.status_msg = "applied: " + title + " (" + extra_file_edits.to_text() + " file edits)"
        else:
            me.status_msg = "applied: " + title
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _apply_workspace_edit_extra_paths(active_path: text, edit_json: text) -> i64:
        ctrl_apply_workspace_edit_extra_paths(me, active_path, edit_json)

    me _replace_open_document_buffer(path: text, buffer: EditorBuffer):
        ctrl_replace_open_document_buffer(me, path, buffer)

    me _update_markdown_preview(doc: EditorDocument, buffer: EditorBuffer):
        ctrl_update_markdown_preview(me, doc, buffer)

    me _toggle_md_preview():
        ctrl_toggle_md_preview(me)

    me _toggle_md_outline():
        val doc = me.session.active_document()
        if doc == nil or doc.language_id != "markdown":
            me.status_msg = "not a markdown file"
            return
        val buffer = me.session.active_buffer()
        val content = if buffer == nil then "" else: md_buffer_content(buffer)
        val visible = doc.toggle_markdown_outline(content)
        if visible:
            me._show_right_dock("md-outline")
            me.status_msg = "outline on"
        else:
            if not doc.markdown_preview_visible():
                var layout = me.session.dock_layout
                layout.hide_right()
                me.session.dock_layout = layout
            me.status_msg = "outline off"
        me.session.update_active_document(doc)
