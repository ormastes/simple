    me _debug_sync_active_breakpoints() -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var dap = self.debug_dap_client
        if not dap.running:
            self.status_msg = "debug adapter not running"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var synced_paths: [text] = []
        val breakpoints = editor_debug_session_breakpoints(session)
        for bp in breakpoints:
            val bp_path = editor_debug_breakpoint_path(bp)
            if bp_path != "" and not _editor_text_list_contains(synced_paths, bp_path):
                val synced = editor_debug_dap_client_set_breakpoints(dap, bp_path, breakpoints)
                dap = synced.0
                synced_paths.push(bp_path)
        self.debug_dap_client = dap
        self.status_msg = "debug breakpoints requested"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_continue() -> EditorAction:
