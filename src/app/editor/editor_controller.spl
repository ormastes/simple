    me _notify_lsp_file_changed(path: text, change_type: i64) -> EditorAction:
        me.vault_search_index = md_vault_search_index_apply_file_change(me.vault_search_index, path, rt_file_read_text(path) ?? "", change_type)
        var notified = false
        if me.md_lsp_state.running:
            me.md_lsp_state = md_lsp_notify_watched_file(me.md_lsp_state, path, change_type)
            notified = true
        if me.simple_lsp_state.running:
            me.simple_lsp_state = simple_lsp_notify_watched_file(me.simple_lsp_state, path, change_type)
            notified = true
        if notified:
            me.status_msg = "lsp file change notified"
        else:
            me.status_msg = "no active language server"
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _refresh_open_document_from_disk_batch(path: text, content: text):
        var docs: [EditorDocument] = []
        var i = 0
        while i < me.session.documents.len():
            var doc = me.session.documents[i]
            if doc.path() == path:
                var buffer = doc.buffer
                buffer.replace_content(content)
                buffer.dirty = false
                doc.buffer = buffer
                if doc.language_id == "markdown":
                    md_update_preview(doc, buffer)
            docs.push(doc)
            i = i + 1
        me.session.documents = docs
        var buffers: [EditorBuffer] = []
        var j = 0
        while j < me.session.buffers.len():
            var open_buffer = me.session.buffers[j]
            if open_buffer.path == path:
                open_buffer.replace_content(content)
                open_buffer.dirty = false
            buffers.push(open_buffer)
            j = j + 1
        me.session.buffers = buffers

    me _notify_lsp_workspace_folder(path: text, name: text, added: bool) -> EditorAction:
        var notified = false
        if me.md_lsp_state.running:
            me.md_lsp_state = md_lsp_notify_workspace_folder(me.md_lsp_state, path, name, added)
            notified = true
        if me.simple_lsp_state.running:
            me.simple_lsp_state = simple_lsp_notify_workspace_folder(me.simple_lsp_state, path, name, added)
            notified = true
        if added:
            me._rebuild_workspace_symbol_index(path)
        if notified:
            me.status_msg = "lsp workspace folder notified"
        else:
            me.status_msg = "no active language server"
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _request_active_rename(new_name: text) -> LspResponse:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown" or md_lsp_is_markdown_file(doc.path()):
            if not me.md_lsp_state.running:
                me.md_lsp_state = md_lsp_ensure_open(me.md_lsp_state, doc.path(), content)
            val result = md_lsp_request(me.md_lsp_state, "rename", new_name, doc.path(), buffer.cursor_row, buffer.cursor_col)
            me.md_lsp_state = result.0
            return result.1
        if doc.language_id == "simple" or doc.language_id == "shell" or simple_lsp_is_simple_file(doc.path()):
            if not me.simple_lsp_state.running:
                me.simple_lsp_state = simple_lsp_ensure_open(me.simple_lsp_state, doc.path(), content)
            val simple_result = simple_lsp_request(me.simple_lsp_state, "rename", new_name, doc.path(), buffer.cursor_row, buffer.cursor_col)
            me.simple_lsp_state = simple_result.0
            return simple_result.1
        LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

    me _request_call_hierarchy_direction(direction: text, item_json: text) -> LspResponse:
