    me _dispatch_normal_key(key: text, rects: [SplitRect]) -> EditorAction:
        if key == "\x02":
            self.toggle_file_tree()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\t":
            self.toggle_focus()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\x10":
            self._open_palette()
            return EditorAction(redraw: true, quit: false, status_msg: "command palette")
        if key == "\x16":
            self._toggle_md_preview()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "Ctrl+Space":
            return self._request_active_lsp_action("completion")
        if key == "K":
            return self._request_active_lsp_action("hover")
        if key == "F12":
            return self._request_active_lsp_action("definition")
        if key == "Ctrl+.":
            return self._request_quickfix()
        if key == "Shift+Alt+Right":
            return self._expand_lsp_selection_range()
        if key == "Shift+Alt+Left":
            return self._shrink_lsp_selection_range()
        if key == "F5":
            return self._start_debug_process_adapter("simple")
        if key == "\x1b" and self.lsp_hover_popup.visible:
            return self._dismiss_lsp_hover_popup()
        if key == "\x1b" and self.lsp_signature_popup.visible:
            return self._dismiss_lsp_signature_popup()
        if self.session.dock_layout.active_right_panel() == "lsp-panel":
            val lsp_panel_action = self._dispatch_lsp_result_key(key)
            if lsp_panel_action.redraw:
                return lsp_panel_action
        if self.session.dock_layout.active_right_panel() == "wiki-panel":
            val wiki_panel_action = self._dispatch_wiki_panel_key(key)
            if wiki_panel_action.redraw:
                return wiki_panel_action
        if self.session.dock_layout.active_right_panel() == "problems":
            val problems_action = self._dispatch_diagnostics_panel_key(key)
            if problems_action.redraw:
                return problems_action
        if self.session.dock_layout.active_right_panel() == "md-outline":
            val outline_action = self._dispatch_md_outline_key(key)
            if outline_action.redraw:
                return outline_action

        if self.pending_prefix == "ctrl_w":
            self.pending_prefix = ""
            val wresult: WincmdResult = wincmd_dispatch(self.session, key, rects)
            if wincmd_result_handled(wresult):
                self.status_msg = wincmd_result_message(wresult)
                if wincmd_result_quit(wresult):
                    self.running = false
            return EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

        if self.pending_prefix == "]" or self.pending_prefix == "[":
            val saved_prefix = self.pending_prefix
            self.pending_prefix = ""
            val doc = self.session.active_document()
            if doc != nil and doc.language_id == "markdown":
                val buffer_m = self.session.active_buffer()
                if buffer_m != nil:
                    val content = md_buffer_content(buffer_m)
                    val motion_result = md_dispatch_motion(saved_prefix, key, content, buffer_m.cursor_row_value(), buffer_m.cursor_col_value())
                    if motion_result.found:
                        buffer_m.move_cursor(motion_result.line, motion_result.col)
                        self.status_msg = "motion"
                    return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if self.pending_prefix == "g":
            self.pending_prefix = ""
            val doc_g = self.session.active_document()
            if doc_g != nil and doc_g.language_id == "markdown" and key == "x":
                val buffer_gx = self.session.active_buffer()
                if buffer_gx != nil:
                    return self._open_markdown_link_under_cursor()
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            val buffer_gg = self.session.active_buffer()
            if buffer_gg != nil:
                buffer_gg.move_cursor(0, 0)
                self.status_msg = "top"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if self.pending_prefix == "z":
            self.pending_prefix = ""
            if key == "a":
                return self._toggle_active_markdown_fold()
            self.status_msg = ""
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if key == "\x17":
            self.pending_prefix = "ctrl_w"
            return EditorAction(redraw: true, quit: false, status_msg: "Ctrl+W ...")

        if key == "]" or key == "[":
            self.pending_prefix = key
            return EditorAction(redraw: true, quit: false, status_msg: key + " ...")

        if self.focus_panel == "file_tree":
            return self._dispatch_file_tree_key(key)

        val buffer = self.session.active_buffer()
        if buffer == nil:
            if key == ":":
                self.session.mode = editor_mode_command()
                self.commandline = ""
            elif key == "q":
                self.running = false
            return EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

        if key == "g":
            val doc_g2 = self.session.active_document()
            if doc_g2 != nil and doc_g2.language_id == "markdown":
                self.pending_prefix = "g"
                return EditorAction(redraw: true, quit: false, status_msg: "g ...")
        if key == "z":
            val doc_z = self.session.active_document()
            if doc_z != nil and doc_z.language_id == "markdown":
                self.pending_prefix = "z"
                return EditorAction(redraw: true, quit: false, status_msg: "z ...")

        val result = ctrl_handle_normal_key(buffer, key)
        self.status_msg = result.message
        if result.quit:
            self.running = false
        if result.enter_insert:
            self.session.mode = editor_mode_insert()
            self.status_msg = "-- INSERT --"
        if result.enter_command:
            self.session.mode = editor_mode_command()
            self.commandline = ""
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _dispatch_insert_key(key: text) -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.session.mode = editor_mode_normal()
            return EditorAction(redraw: true, quit: false, status_msg: "")
        val doc = self.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            if key == "\r" or key == "\n":
                val current_line = buffer.line_at(buffer.cursor_row_value())
                val continuation = md_assist_on_enter(current_line, buffer.cursor_col_value())
                if continuation != "":
                    buffer.insert_at_cursor("\n" + continuation)
                    self._update_markdown_preview(doc, buffer)
                    self.session.update_active_buffer(buffer)
                    self._notify_active_lsp_changed()
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
            if key == "\t":
                val tab_line = buffer.line_at(buffer.cursor_row_value())
                val same_row_col = md_assist_on_tab(tab_line, buffer.cursor_col_value())
                val nav = md_table_next_cell(buffer.to_text(), buffer.cursor_row_value(), buffer.cursor_col_value())
                if nav.found:
                    buffer.move_cursor(nav.line, nav.col)
                    self.session.update_active_buffer(buffer)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
                if same_row_col >= 0:
                    buffer.move_cursor(buffer.cursor_row_value(), same_row_col)
                    self.session.update_active_buffer(buffer)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
        var result = InsertKeyResult(message: "-- INSERT --", exit_insert: false)
        if key == "\x1b":
            result = InsertKeyResult(message: "", exit_insert: true)
        elif key == "\x7f" or key == "\b":
            buffer.delete_before_cursor()
        elif key == "\r" or key == "\n":
            buffer.insert_at_cursor("\n")
        elif key.len() == 1:
            val code = key.char_code_at(0)
            if code >= 32:
                buffer.insert_at_cursor(key)
        self.status_msg = result.message
        if result.exit_insert:
            self.session.mode = editor_mode_normal()
            self.status_msg = ""
        else:
            self.session.update_active_buffer(buffer)
            if doc != nil and doc.language_id == "markdown":
                self._update_markdown_preview(doc, buffer)
            self._notify_active_lsp_changed()
            if self._should_trigger_signature_help(key):
                return self._request_active_lsp_action("signature-help")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _dispatch_file_tree_key(key: text) -> EditorAction:
        if key == "j":
            self.file_tree.select_next()
        elif key == "k":
            self.file_tree.select_prev()
        elif key == "\r" or key == "\n":
            if self.file_tree.selected_is_dir():
                self.file_tree.toggle_expand()
            else:
                val fpath = self.file_tree.selected_path()
                self.session.open_file(fpath)
                self._activate_active_language()
                self.focus_panel = "editor"
                self.status_msg = "opened " + fpath
        elif key == "\x1b":
            self.focus_panel = "editor"
        elif key == ":":
            self.session.mode = editor_mode_command()
            self.commandline = ""
        elif key == "q":
            self.running = false
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _should_trigger_signature_help(key: text) -> bool:
        key == "(" or key == ","


    me _dispatch_palette_key(key: text) -> EditorAction:
        if key == "\x1b":
            self.palette_state = palette_hide(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\r" or key == "\n":
            val selected = palette_selected(self.palette_state)
            self.palette_state = palette_hide(self.palette_state)
            if selected.command_name != "":
                return self._execute_palette_command(selected.command_name, selected.command_payload)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x1b[A":
            self.palette_state = palette_select_prev(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x1b[B":
            self.palette_state = palette_select_next(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x7f" or key == "\b":
            val q = palette_query(self.palette_state)
            if q.len() > 0:
                self.palette_state = palette_update_query(self.palette_state, q.slice(0, q.len() - 1))
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key.len() == 1:
            val code = key.char_code_at(0)
            if code >= 32:
                self.palette_state = palette_update_query(self.palette_state, palette_query(self.palette_state) + key)
        EditorAction(redraw: true, quit: false, status_msg: "")

    me _open_palette():
        self._activate_active_language()
        var all_entries = editor_all_commands()
        val doc = self.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            val md_entries = md_commands_palette_entries()
            var mi = 0
            while mi < md_entries.len():
                all_entries.push(md_entries[mi])
                mi = mi + 1
        self.palette_state = palette_show(palette_new(all_entries))

    me _execute_palette_command(command_name: text, command_payload: text) -> EditorAction:
        if command_name == "debug-process-start":
            return self._start_debug_process_adapter(command_payload)
        if command_name == "debug-terminate":
            return self._debug_terminate_first()
        if command_name == "debug-poll":
            return self._debug_poll_dap_client()
        if command_name == "outline":
            self._toggle_md_outline()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.extension_host.activate_command(command_name)
        self.extension_host.emit_event("onWillExecuteCommand", command_name)
        self.extension_host.emit_event("onCommand:" + command_name, command_payload)
        if command_name == "markdown.foldAll" or command_name == "markdown.unfoldAll":
            val action = self._execute_markdown_extension_command(command_name)
            self.extension_host.emit_event("onDidExecuteCommand", command_name)
            return action
        val registered_command = self.extension_host.find_command(command_name)
        val registered_command_id = extension_command_entry_command_id(registered_command)
        if registered_command_id != "" and extension_command_entry_name(registered_command) == "markdown-language":
            val action = self._execute_markdown_extension_command(command_name)
            self.extension_host.emit_event("onDidExecuteCommand", command_name)
            return action
        if registered_command_id != "":
            val invocation = self.extension_host.dispatch_external_command(command_name, command_payload)
            self.status_msg = "extension command queued: " + extension_command_invocation_command_id(invocation)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command_name.starts_with("markdown."):
            self.status_msg = "extension command not registered: " + command_name
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command_name == "quickfix":
            return self._request_quickfix()
        if command_name == "quickfix-apply":
            val index = if command_payload == "" then 0 else: _editor_parse_i64(command_payload, 0)
            return self._apply_code_action_at(index)
        if command_name == "problems":
            return self._show_diagnostics_panel()
        if command_name == "diagnostics-filter":
            return self._show_diagnostics_filter(command_payload)
        if command_name == "diagnostics-group":
            return self._show_diagnostics_group(command_payload)
        if command_name == "diagnostics-sort":
            return self._show_diagnostics_sort(command_payload)
        if command_name == "completion":
            return self._request_active_lsp_action("completion")
        if command_name == "hover":
            return self._request_active_lsp_action("hover")
        if command_name == "hover-dismiss":
            return self._dismiss_lsp_hover_popup()
        if command_name == "definition":
            return self._request_active_lsp_action("definition")
        if command_name == "code-action":
            return self._request_active_lsp_action("code-action")
        if command_name == "references":
            return self._request_active_lsp_action("references")
        if command_name == "selection-ranges":
            return self._request_active_lsp_action("selection-ranges")
        if command_name == "selection-expand":
            return self._expand_lsp_selection_range()
        if command_name == "selection-shrink":
            return self._shrink_lsp_selection_range()
        if command_name == "document-symbols":
            return self._request_active_lsp_action("document-symbols")
        if command_name == "prepare-rename":
            return self._request_active_lsp_action("prepare-rename")
        if command_name == "rename":
            return self._rename_active_symbol(command_payload)
        if command_name == "rename-preview":
            return self._rename_active_symbol_preview(command_payload)
        if command_name == "rename-confirm":
            return self._confirm_pending_workspace_edit()
        if command_name == "workspace-edit-cancel":
            return self._cancel_pending_workspace_edit()
        if command_name == "formatting":
            return self._request_active_lsp_action("formatting")
        if command_name == "formatting-preview":
            return self._request_active_formatting_preview("formatting")
        if command_name == "formatting-save":
            return self._request_active_formatting_save("formatting")
        if command_name == "range-formatting":
            return self._request_active_lsp_action("range-formatting")
        if command_name == "range-formatting-preview":
            return self._request_active_formatting_preview("range-formatting")
        if command_name == "range-formatting-save":
            return self._request_active_formatting_save("range-formatting")
        if command_name == "signature-help":
            return self._request_active_lsp_action("signature-help")
        if command_name == "signature-dismiss":
            return self._dismiss_lsp_signature_popup()
        if command_name == "document-links":
            return self._request_active_lsp_action("document-links")
        if command_name == "open-link":
            return self._open_markdown_link_under_cursor()
        if command_name == "folding-ranges":
            return self._request_active_lsp_action("folding-ranges")
        if command_name == "fold-all":
            return self._fold_all_active_document()
        if command_name == "unfold-all":
            return self._unfold_all_active_document()
        if command_name == "fold-toggle":
            return self._toggle_active_markdown_fold()
        if command_name == "callout-fold-toggle":
            return self._toggle_active_callout_fold()
        if command_name == "workspace-symbols":
            return self._request_workspace_symbols(command_payload)
        if command_name == "semantic-tokens":
            return self._request_active_lsp_action("semantic-tokens")
        if command_name == "inlay-hints":
            return self._request_active_lsp_action("inlay-hints")
        if command_name == "code-lens":
            return self._request_active_lsp_action("code-lens")
        if command_name == "code-lens-run":
            return self._run_selected_code_lens()
        if command_name == "code-lens-resolve":
            return self._request_active_code_lens_resolve(command_payload)
        if command_name == "call-hierarchy":
            return self._request_active_lsp_action("call-hierarchy")
        if command_name == "call-hierarchy-incoming":
            return self._request_active_call_hierarchy_direction("incoming", command_payload)
        if command_name == "call-hierarchy-outgoing":
            return self._request_active_call_hierarchy_direction("outgoing", command_payload)
        if command_name == "lsp-jump":
            return self._lsp_jump_selected()
        if command_name == "lsp-back":
            return self._lsp_back()
        if command_name == "keyboard-shortcuts":
            return self._show_keyboard_shortcuts()
        if command_name == "debug-start":
            return self._start_debug_adapter(command_payload)
        if command_name == "debug-configs":
            return self._debug_show_launch_configs(command_payload)
        if command_name == "debug-console":
            return self._debug_show_session()
        if command_name == "debug-sessions":
            return self._debug_show_sessions()
        if command_name == "debug-switch":
            return self._debug_switch_session(_editor_parse_i64(command_payload, 0))
        if command_name == "debug-restart":
            return self._debug_restart_first()
        if command_name == "debug-continue":
            return self._debug_continue()
        if command_name == "debug-pause":
            return self._debug_pause()
        if command_name == "debug-step":
            return self._debug_step(if command_payload == "" then "stepOver" else: command_payload)
        if command_name == "debug-stack":
            return self._debug_request_stack_trace()
        if command_name == "debug-scopes":
            return self._debug_request_scopes(_editor_parse_i64(command_payload, 1))
        if command_name == "debug-variables":
            return self._debug_request_variables(_editor_parse_i64(command_payload, 1))
        if command_name == "debug-breakpoints-sync":
            return self._debug_sync_active_breakpoints()
        if command_name == "debug-exceptions":
            return self._debug_set_exception_filters(_editor_payload_csv(command_payload))
        if command_name == "debug-watch":
            return self._debug_add_watch(command_payload)
        if command_name == "debug-evaluate":
            return self._debug_evaluate(command_payload)
        if command_name == "daily-note-create":
            return self._wiki_daily_note_create(command_payload)
        if command_name == "daily-note-picker":
            return self._wiki_daily_note_picker(command_payload)
        if command_name == "template-insert":
            return self._wiki_template_insert(command_payload)
        if command_name == "template-picker":
            return self._wiki_template_picker(command_payload)
        if command_name == "attachment-insert":
            return self._wiki_attachment_insert(command_payload)
        if command_name == "attachment-picker":
            return self._wiki_attachment_picker(command_payload)
        if command_name == "wiki-backlinks":
            return self._wiki_show_backlinks()
        if command_name == "wiki-tasks":
            return self._wiki_show_tasks(command_payload)
        if command_name == "wiki-task-batch":
            return self._wiki_task_batch(command_payload)
        if command_name == "wiki-vault-task-batch":
            return self._wiki_vault_task_batch(command_payload)
        if command_name == "wiki-properties":
            return self._wiki_show_properties()
        if command_name == "wiki-property-set":
            return self._wiki_set_property(command_payload)
        if command_name == "wiki-vault-property-set":
            return self._wiki_vault_set_property(command_payload)
        if command_name == "wiki-property-diagnostics":
            return self._wiki_property_diagnostics(command_payload)
        if command_name == "wiki-tags":
            return self._wiki_show_tags(command_payload)
        if command_name == "wiki-graph":
            return self._wiki_show_graph()
        if command_name == "wiki-quick-switch":
            return self._wiki_quick_switch(command_payload)
        if command_name == "wiki-vault-search":
            return self._wiki_vault_search(command_payload)
        if command_name == "markdown-table-row-insert":
            return self._markdown_table_insert_row()
        if command_name == "markdown-table-column-insert":
            return self._markdown_table_insert_column()
        if command_name == "markdown-table-cell-next":
            return self._markdown_table_cell_nav("next")
        if command_name == "markdown-table-cell-prev":
            return self._markdown_table_cell_nav("prev")
        val parsed = editor_cmd_with(command_name, command_payload)
        val dispatch_result = editor_dispatch_session(self.session, parsed)
        self.status_msg = dispatch_result.message
        if command_name == "open-file" and not dispatch_result.quit:
            self._activate_active_language()
        self.extension_host.emit_event("onDidExecuteCommand", command_name)
        if dispatch_result.quit:
            self.running = false
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _request_quickfix() -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if doc.language_id == "markdown":
            val content = md_buffer_content(buffer)
            val line = buffer.line_at(buffer.cursor_row_value())
            val fixed = _editor_markdown_quickfix_line(line)
            if fixed != line:
                val edit_json = "{\"line\":" + str(buffer.cursor_row_value()) + ",\"newText\":\"" + _editor_escape_json(fixed) + "\"}"
                self.code_actions = [EditorCodeAction(title: "Apply Markdown quick fix", kind: "quickfix", edit_json: edit_json, command: "")]
                self.status_msg = "1 quick fix"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            self.code_actions = []
            val diags = md_diagnose(content, doc.path())
            if diags.len() > 0:
                self.status_msg = "diagnostics available"
            else:
                self.status_msg = "no quick fixes"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.code_actions = []
        self.status_msg = "no quick fixes"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_diagnostics_panel() -> EditorAction:
        self.diagnostics_view_mode = "all"
        self.diagnostics_view_payload = ""
        self._refresh_diagnostics_panel_view()
        var layout = self.session.dock_layout
        layout.show_right("problems")
        self.session.dock_layout = layout
        self.status_msg = "problems: " + self.diagnostic_store.total_count().to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_diagnostics_filter(payload: text) -> EditorAction:
        self.diagnostics_view_mode = "filter"
        self.diagnostics_view_payload = payload
        self._refresh_diagnostics_panel_view()
        var layout = self.session.dock_layout
        layout.show_right("problems")
        self.session.dock_layout = layout
        val visible = _editor_problem_visible_count(self.diagnostics_panel)
        self.status_msg = "problems: " + visible.to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_diagnostics_group(payload: text) -> EditorAction:
        self.diagnostics_view_mode = "group"
        self.diagnostics_view_payload = if payload == "source" then "source" else: "severity"
        self._refresh_diagnostics_panel_view()
        var layout = self.session.dock_layout
        layout.show_right("problems")
        self.session.dock_layout = layout
        val visible = _editor_problem_visible_count(self.diagnostics_panel)
        self.status_msg = "problems: " + visible.to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_diagnostics_sort(payload: text) -> EditorAction:
        self.diagnostics_view_mode = "sort"
        self.diagnostics_view_payload = if payload == "source" or payload == "path" then payload else: "severity"
        self._refresh_diagnostics_panel_view()
        var layout = self.session.dock_layout
        layout.show_right("problems")
        self.session.dock_layout = layout
        val visible = _editor_problem_visible_count(self.diagnostics_panel)
        self.status_msg = "problems: " + visible.to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _refresh_diagnostics_panel_view():
        if self.diagnostics_view_mode == "filter":
            val severity = _editor_payload_part(self.diagnostics_view_payload, 0)
            val source = _editor_payload_part(self.diagnostics_view_payload, 1)
            self.diagnostics_panel = diagnostics_panel_from_store_filtered(self.diagnostic_store, severity, source)
            return
        if self.diagnostics_view_mode == "group":
            val group_by = if self.diagnostics_view_payload == "source" then "source" else: "severity"
            self.diagnostics_panel = diagnostics_panel_from_store_grouped(self.diagnostic_store, group_by)
            return
        if self.diagnostics_view_mode == "sort":
            val sort_by = if self.diagnostics_view_payload == "source" or self.diagnostics_view_payload == "path" then self.diagnostics_view_payload else: "severity"
            self.diagnostics_panel = diagnostics_panel_from_store_sorted(self.diagnostic_store, sort_by)
            return
        self.diagnostics_panel = diagnostics_panel_from_store(self.diagnostic_store)

    me _apply_first_quickfix() -> EditorAction:
        self._apply_code_action_at(0)

    me _apply_code_action_at(index: i64) -> EditorAction:
        if self.code_actions.len() == 0:
            self.status_msg = "no quick fix selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var action_index = index
        if action_index < 0:
            action_index = 0
        if action_index >= self.code_actions.len():
            action_index = self.code_actions.len() - 1
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val action = self.code_actions[action_index]
        val doc = self.session.active_document()
        val doc_path = if doc == nil then "" else: doc.path()
        val applied = _editor_apply_code_action_content(buffer, doc_path, action.edit_json)
        if not applied.applied:
            if action.command != "":
                val command_requested = self._execute_lsp_code_action_command(action.command)
                self.code_actions = []
                if command_requested:
                    val command_name = _editor_lsp_command_name(action.command)
                    self.status_msg = "command requested: " + command_name
                else:
                    self.status_msg = "code action command unavailable"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            self.status_msg = "quick fix has no editable change"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val extra_file_edits = if action.edit_json.contains("\"changes\"") then self._apply_workspace_edit_extra_paths(doc_path, action.edit_json) else: 0
        buffer.push_undo_snapshot()
        buffer.replace_content(applied.content)
        buffer.dirty = true
        buffer.move_cursor(applied.line, applied.col)
        self.session.update_active_buffer(buffer)
        self._replace_open_document_buffer(doc_path, buffer)
        self.code_actions = []
        val doc = self.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            self._update_markdown_preview(doc, buffer)
        if extra_file_edits > 0:
            self.status_msg = "applied: " + action.title + " (" + extra_file_edits.to_text() + " file edits)"
        else:
            self.status_msg = "applied: " + action.title
        if action.command != "":
            val command_requested = self._execute_lsp_code_action_command(action.command)
            if command_requested:
                self.status_msg = self.status_msg + "; command requested: " + _editor_lsp_command_name(action.command)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _start_debug_adapter(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else debug_type
        self.extension_host.activate_language(adapter_id)
        val adapter = self.extension_host.find_debug_adapter(adapter_id)
        if extension_debug_adapter_id(adapter) == "":
            self.status_msg = "debug adapter not found: " + adapter_id
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val doc = self.session.active_document()
        val program = if doc == nil or doc.path() == "" then extension_debug_adapter_program(adapter) else: doc.path()
        val launch_config = _editor_debug_launch_config_for_doc(program, adapter_id)
        self.debug_registry = editor_debug_registry_start(
            self.debug_registry,
            launch_config
        )
        var dap = EditorDebugDapClient.new()
        dap.start()
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, launch_config)
        dap = launched.0
        self.debug_dap_client = dap
        self.debug_status = "starting"
        self.status_msg = "debug adapter: " + editor_debug_launch_config_name(launch_config)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _start_debug_process_adapter(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else debug_type
        val adapter_program = if adapter_id == "simple" then "src/app/dap/simple_dap_main.spl" else: ""
        if adapter_program == "":
            val adapter = self.extension_host.find_debug_adapter(adapter_id)
            if extension_debug_adapter_id(adapter) == "":
                self.status_msg = "debug adapter not found: " + adapter_id
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            adapter_program = extension_debug_adapter_program(adapter)
        val program = adapter_program
        val launch_config = _editor_debug_launch_config_for_doc(program, adapter_id)
        val process_pid = if adapter_id == "simple" then editor_debug_process_spawn_simple_adapter() else: editor_debug_process_spawn_adapter(adapter_program)
        var dap = EditorDebugDapClient.new()
        if process_pid <= 0:
            self.status_msg = "debug process adapter failed: " + adapter_program
            self.debug_dap_client = dap
            self.debug_process_pid = 0
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_registry_start_fresh(launch_config)
        if adapter_id == "simple":
            editor_debug_process_start_simple_adapter(process_pid)
        else:
            val init_json = "{\"seq\":1,\"type\":\"request\",\"command\":\"initialize\",\"arguments\":{\"adapterID\":\"simple\"}}"
            val launch_json = "{\"seq\":2,\"type\":\"request\",\"command\":\"launch\",\"arguments\":{\"program\":\"" + program + "\",\"cwd\":\".\"}}"
            editor_debug_process_write_frame(process_pid, init_json)
            editor_debug_process_write_frame(process_pid, launch_json)
        self.debug_dap_client = dap
        self.debug_process_pid = process_pid
        self.debug_status = "starting"
        self.status_msg = "debug process adapter: " + editor_debug_launch_config_name(launch_config)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_show_launch_configs(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else: debug_type
        self.extension_host.activate_language(adapter_id)
        val adapter = self.extension_host.find_debug_adapter(adapter_id)
        if extension_debug_adapter_id(adapter) == "":
            self.status_msg = "debug adapter not found: " + adapter_id
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val doc = self.session.active_document()
        val program = if doc == nil or doc.path() == "" then extension_debug_adapter_program(adapter) else: doc.path()
        self.debug_launch_configs = _editor_debug_launch_configs_for_doc(program, adapter_id)
        self.wiki_panel = _editor_debug_launch_config_panel(self.debug_launch_configs)
        self._show_wiki_panel("debug launch configs: " + self.debug_launch_configs.len().to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_start_selected_launch_config() -> EditorAction:
        if self.debug_launch_configs.len() == 0:
            self.status_msg = "no debug launch config"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var index = self.wiki_panel.selected
        if index < 0:
            index = 0
        if index >= self.debug_launch_configs.len():
            index = self.debug_launch_configs.len() - 1
        val config = self.debug_launch_configs[index]
        val config_debug_type = editor_debug_launch_config_debug_type(config)
        self.extension_host.activate_language(config_debug_type)
        val adapter = self.extension_host.find_debug_adapter(config_debug_type)
        if extension_debug_adapter_id(adapter) == "":
            self.status_msg = "debug adapter not found: " + config_debug_type
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_registry_start(self.debug_registry, config)
        var dap = self.debug_dap_client
        dap.start()
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, config)
        dap = launched.0
        self.debug_dap_client = dap
        self.debug_status = "starting"
        self.status_msg = "debug adapter: " + editor_debug_launch_config_name(config)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_show_session() -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self._show_debug_session_panel("debug session")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_show_sessions() -> EditorAction:
        self.wiki_panel = _editor_debug_sessions_panel(self.debug_registry)
        self._show_wiki_panel("debug sessions: " + editor_debug_session_count(self.debug_registry).to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_switch_selected_session() -> EditorAction:
        if self.wiki_panel.rows.len() == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var index = self.wiki_panel.selected
        if index < 0:
            index = 0
        if index >= self.wiki_panel.rows.len():
            index = self.wiki_panel.rows.len() - 1
        return self._debug_switch_session(self.wiki_panel.rows[index].line)

    me _debug_switch_session(session_id: i64) -> EditorAction:
        if session_id <= 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_registry_select(self.debug_registry, session_id)
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) != session_id:
            self.status_msg = "debug session not found: " + session_id.to_text()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_status = editor_debug_session_status(session)
        self._show_debug_session_panel("debug session: " + editor_debug_session_id(session).to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_keyboard_shortcuts() -> EditorAction:
        self.wiki_panel = _editor_keyboard_shortcuts_panel(default_keybindings())
        self._show_wiki_panel("keyboard shortcuts")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_add_breakpoint(path: text, line: i64, condition: text, log_message: text, hit_condition: text) -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_add_breakpoint(
            self.debug_registry,
            editor_debug_session_id(session),
            path,
            line,
            condition,
            log_message,
            hit_condition
        )
        var dap = self.debug_dap_client
        if dap.running:
            val synced = editor_debug_dap_client_set_breakpoints(dap, path, editor_debug_session_breakpoints(editor_debug_first_session(self.debug_registry)))
            dap = synced.0
            self.debug_dap_client = dap
        self.status_msg = "breakpoint set: " + path + ":" + line.to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

