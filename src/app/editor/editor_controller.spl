    me _markdown_table_insert_row() -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown table"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val edit = md_table_insert_row_after(buffer.to_text(), buffer.cursor_row)
        if not edit.changed:
            me.status_msg = edit.message
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.push_undo_snapshot()
        buffer.replace_content(edit.content)
        buffer.dirty = true
        buffer.move_cursor(edit.line, edit.col)
        ctrl_update_markdown_preview(me, doc, buffer)
        me.session.update_active_buffer(buffer)
        ctrl_notify_active_lsp_changed(me)
        me.status_msg = edit.message
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _markdown_table_insert_column() -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown table"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val edit = md_table_insert_column_after(buffer.to_text(), buffer.cursor_row, buffer.cursor_col)
        if not edit.changed:
            me.status_msg = edit.message
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.push_undo_snapshot()
        buffer.replace_content(edit.content)
        buffer.dirty = true
        buffer.move_cursor(edit.line, edit.col)
        ctrl_update_markdown_preview(me, doc, buffer)
        me.session.update_active_buffer(buffer)
        ctrl_notify_active_lsp_changed(me)
        me.status_msg = edit.message
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _markdown_table_set_cell(line: i64, col: i64, value: text) -> EditorAction:
        ctrl_markdown_table_set_cell(me, line, col, value)

    me _markdown_table_cell_nav(direction: text) -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "no markdown table"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val nav = if direction == "prev" then md_table_prev_cell(buffer.to_text(), buffer.cursor_row, buffer.cursor_col) else: md_table_next_cell(buffer.to_text(), buffer.cursor_row, buffer.cursor_col)
        if not nav.found:
            me.status_msg = nav.message
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.move_cursor(nav.line, nav.col)
        me.session.update_active_buffer(buffer)
        me.status_msg = nav.message
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _markdown_table_cell_nav(direction: text) -> EditorAction:
