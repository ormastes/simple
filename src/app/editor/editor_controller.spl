    me _request_workspace_symbols(query: text) -> EditorAction:
        val response = me._request_active_lsp_with_payload("workspace-symbols", query)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.lsp_result_panel = lsp_result_panel_from_response("workspace-symbols", response)
        val indexed_rows = me._workspace_symbol_index_rows(query)
        if indexed_rows.len() > 0:
            me.lsp_result_panel = LspResultPanel(
                title: "Workspace Symbols",
                rows: indexed_rows,
                selected: 0,
                scroll_offset: 0,
                visible: true,
                pending: false,
                request_id: response.id
            )
        me._refresh_lsp_hover_popup("workspace-symbols")
        me._show_lsp_result_panel("workspace-symbols results")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _rebuild_workspace_symbol_index(root: text) -> EditorAction:
        me.workspace_symbol_index_root = root
        me.workspace_symbol_index = _editor_workspace_symbol_index(root)
        me.status_msg = "workspace symbols indexed: " + me.workspace_symbol_index.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _workspace_symbol_index_rows(query: text) -> [LspResultRow]:
        var rows: [LspResultRow] = []
        val clean_query = query.trim().lower()
        if clean_query == "":
            return rows
        for row in me.workspace_symbol_index:
            if row.label.lower().contains(clean_query):
                rows.push(row)
                if rows.len() >= 100:
                    return rows
        rows

    me _dismiss_lsp_hover_popup() -> EditorAction:
        me.lsp_hover_popup = lsp_hover_popup_hidden()
        me.status_msg = "hover dismissed"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _dismiss_lsp_signature_popup() -> EditorAction:
        me.lsp_signature_popup = lsp_signature_popup_hidden()
        me.status_msg = "signature dismissed"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _select_signature_overload(delta: i64) -> EditorAction:
        ctrl_select_signature_overload(me, delta)

    me _request_active_formatting_preview(kind: text) -> EditorAction:
        val response = me._request_active_lsp(kind)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val title = if kind == "range-formatting" then "range formatting" else: "formatting"
        me.pending_workspace_edit_json = ""
        me.pending_workspace_edit_title = title
        if response.result_json != "":
            me._show_workspace_edit_preview(response.result_json, title)
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val pending_kind = if kind == "range-formatting" then "range-formatting-preview" else: "formatting-preview"
        me.lsp_result_panel = lsp_result_panel_pending(pending_kind, response.id)
        me._show_lsp_result_panel(title + " preview requested")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _request_active_formatting_save(kind: text) -> EditorAction:
        val response = me._request_active_lsp(kind)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val title = if kind == "range-formatting" then "range formatting" else: "formatting"
        me.format_save_request_id = response.id
        me.format_save_title = title
        if response.result_json != "":
            me._apply_workspace_edit_result(response.result_json, title)
            me.format_save_request_id = 0
            me.format_save_title = ""
            return me._save_active_after_format(title)
        me.status_msg = title + " save requested"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _save_active_after_format(title: text) -> EditorAction:
        val saved = me.session.save_active()
        if saved:
            me.status_msg = "applied and saved: " + title
        else:
            me.status_msg = "applied: " + title + " (save failed)"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _rename_active_symbol(new_name: text) -> EditorAction:
        val name = new_name.trim()
        if name == "":
            me.status_msg = "missing rename target"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val response = me._request_active_rename(name)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if response.result_json != "":
            return me._apply_workspace_edit_result(response.result_json, "rename")
        me.pending_workspace_edit_title = "rename"
        me.status_msg = "rename requested: " + name
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _rename_active_symbol_preview(new_name: text) -> EditorAction:
        val name = new_name.trim()
        if name == "":
            me.status_msg = "missing rename target"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val response = me._request_active_rename(name)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.pending_workspace_edit_json = ""
        me.pending_workspace_edit_title = "rename"
        if response.result_json != "":
            me._show_workspace_edit_preview(response.result_json, "rename")
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.lsp_result_panel = lsp_result_panel_pending("rename-preview", response.id)
        me._show_lsp_result_panel("rename preview requested: " + name)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _show_workspace_edit_preview(edit_json: text, title: text):
        me.pending_workspace_edit_json = edit_json
        me.pending_workspace_edit_title = title
        me.lsp_result_panel = lsp_result_panel_workspace_edit_preview(title, edit_json, 0)
        var rows: [LspResultRow] = []
        for row in me.lsp_result_panel.rows:
            if row.path != "" and not rt_file_exists(row.path):
                rows.push(LspResultRow(
                    icon: "conflict",
                    label: row.label,
                    detail: row.detail + " [conflict: missing file]",
                    path: row.path,
                    line: row.line,
                    col: row.col,
                    command_name: row.command_name,
                    command_payload: row.command_payload,
                    depth: row.depth,
                    expanded: row.expanded
                ))
            else:
                rows.push(row)
        me.lsp_result_panel = LspResultPanel(
            title: me.lsp_result_panel.title,
            rows: rows,
            selected: me.lsp_result_panel.selected,
            scroll_offset: me.lsp_result_panel.scroll_offset,
            visible: me.lsp_result_panel.visible,
            pending: me.lsp_result_panel.pending,
            request_id: me.lsp_result_panel.request_id
        )
        me.lsp_hover_popup = lsp_hover_popup_hidden()
        me.lsp_signature_popup = lsp_signature_popup_hidden()
        me._show_right_dock("lsp-panel")
        me.status_msg = title + " preview: " + me.lsp_result_panel.rows.len().to_text() + " edits"

    me _mark_workspace_edit_preview_conflicts():
        var rows: [LspResultRow] = []
        for row in me.lsp_result_panel.rows:
            if row.path != "" and not rt_file_exists(row.path):
                rows.push(LspResultRow(
                    icon: "conflict",
                    label: row.label,
                    detail: row.detail + " [conflict: missing file]",
                    path: row.path,
                    line: row.line,
                    col: row.col,
                    command_name: row.command_name,
                    command_payload: row.command_payload,
                    depth: row.depth,
                    expanded: row.expanded
                ))
            else:
                rows.push(row)
        me.lsp_result_panel = LspResultPanel(
            title: me.lsp_result_panel.title,
            rows: rows,
            selected: me.lsp_result_panel.selected,
            scroll_offset: me.lsp_result_panel.scroll_offset,
            visible: me.lsp_result_panel.visible,
            pending: me.lsp_result_panel.pending,
            request_id: me.lsp_result_panel.request_id
        )

    me _confirm_pending_workspace_edit() -> EditorAction:
        if me.pending_workspace_edit_json == "":
            me.status_msg = "no pending workspace edit"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val edit_json = me.pending_workspace_edit_json
        val title = me.pending_workspace_edit_title
        me.pending_workspace_edit_json = ""
        me.pending_workspace_edit_title = ""
        me._apply_workspace_edit_result(edit_json, title)

    me _cancel_pending_workspace_edit() -> EditorAction:
        ctrl_cancel_pending_workspace_edit(me)

    me _request_active_call_hierarchy_direction(direction: text, item_json: text) -> EditorAction:
        val payload = item_json.trim()
        if payload == "":
            me.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val response = me._request_call_hierarchy_direction(direction, payload)
        if not response.ok:
            me.lsp_call_hierarchy_merge_index = -1
            me.lsp_call_hierarchy_merge_panel = lsp_result_panel_new("")
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val kind = if direction == "outgoing" then "call-hierarchy-outgoing" else: "call-hierarchy-incoming"
        me._set_lsp_result_panel_from_response(kind, response)
        me._refresh_lsp_hover_popup(kind)
        me._show_lsp_result_panel(kind + " results")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _request_selected_call_hierarchy_direction(direction: text) -> EditorAction:
        if me.lsp_result_panel.rows.len() == 0:
            me.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val row = me.lsp_result_panel.rows[me.lsp_result_panel.selected]
        if row.icon != "call":
            me.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.lsp_result_panel.title == "Call Hierarchy":
            me.lsp_call_hierarchy_merge_panel = me.lsp_result_panel
            me.lsp_call_hierarchy_merge_index = me.lsp_result_panel.selected
        var payload = row.command_payload.trim()
        if payload == "":
            payload = "{\"name\":\"" + row.label + "\",\"kind\":12,\"uri\":\"file://" + row.path + "\",\"range\":{\"start\":{\"line\":" + row.line.to_text() + ",\"character\":" + row.col.to_text() + "},\"end\":{\"line\":" + row.line.to_text() + ",\"character\":" + row.col.to_text() + "}},\"selectionRange\":{\"start\":{\"line\":" + row.line.to_text() + ",\"character\":" + row.col.to_text() + "},\"end\":{\"line\":" + row.line.to_text() + ",\"character\":" + row.col.to_text() + "}}}"
        return me._request_active_call_hierarchy_direction(direction, payload)

    me _request_active_code_lens_resolve(item_json: text) -> EditorAction:
        val payload = item_json.trim()
        if payload == "":
            me.status_msg = "missing code lens item"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val response = me._request_code_lens_resolve(payload)
        if not response.ok:
            me.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if response.result_json == "":
            me.lsp_result_panel = lsp_result_panel_pending("code-lens-resolve", response.id)
        else:
            me.lsp_result_panel = lsp_result_panel_from_response("code-lens-resolve", response)
        me._refresh_lsp_hover_popup("code-lens-resolve")
        me._show_lsp_result_panel("code-lens-resolve results")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _run_selected_code_lens() -> EditorAction:
        ctrl_run_selected_code_lens(me)

    me _show_lsp_result_panel(message: text):
        var layout = me.session.dock_layout
        layout.show_right("lsp-panel")
        me.session.dock_layout = layout
        me.status_msg = message

    me _code_action_result_panel(request_id: i64) -> LspResultPanel:
        ctrl_code_action_result_panel(me, request_id)

    me _filter_code_actions(filter: text) -> EditorAction:
        me.code_action_filter = if filter == "" then "all" else: filter
        me.lsp_result_panel = ctrl_code_action_result_panel(me, me.lsp_result_panel.request_id)
        me.status_msg = "code actions filtered: " + me.code_action_filter
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _group_code_actions_by_kind() -> EditorAction:
        me.code_action_group_by_kind = true
        me.lsp_result_panel = ctrl_code_action_result_panel(me, me.lsp_result_panel.request_id)
        me.status_msg = "code actions grouped: kind"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _refresh_lsp_hover_popup(kind: text):
        val buffer = me.session.active_buffer()
        val line = if buffer == nil then 0 else: buffer.cursor_row
        val col = if buffer == nil then 0 else: buffer.cursor_col
        if kind == "hover":
            me.lsp_hover_popup = lsp_hover_popup_from_panel(me.lsp_result_panel, line, col)
        else:
            me.lsp_hover_popup = lsp_hover_popup_hidden()
        if kind == "signature-help":
            me.lsp_signature_popup = lsp_signature_popup_from_panel(me.lsp_result_panel, line, col)
        else:
            me.lsp_signature_popup = lsp_signature_popup_hidden()

    me _lsp_jump_selected() -> EditorAction:
        ctrl_lsp_jump_selected(me)

    me _apply_selected_lsp_selection_range() -> EditorAction:
        if me.lsp_result_panel.rows.len() == 0:
            me.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.lsp_result_panel.selected < 0 or me.lsp_result_panel.selected >= me.lsp_result_panel.rows.len():
            me.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val row = me.lsp_result_panel.rows[me.lsp_result_panel.selected]
        if row.icon != "selection":
            me.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val end_line = _editor_parse_i64(_editor_payload_part(row.command_payload, 0), row.line)
        val end_col = _editor_parse_i64(_editor_payload_part(row.command_payload, 1), row.col)
        var preserved_ranges: [SelectionRangeDeco] = []
        for existing in buffer.selection_ranges:
            val same_range = existing.start_row == row.line and existing.start_col == row.col and existing.end_row == end_line and existing.end_col == end_col
            if not same_range:
                preserved_ranges.push(existing)
        buffer.set_primary_selection_range(row.line, row.col, end_line, end_col)
        for preserved in preserved_ranges:
            buffer.add_selection_range(preserved.start_row, preserved.start_col, preserved.end_row, preserved.end_col)
        buffer.move_cursor(row.line, row.col)
        me.session.update_active_buffer(buffer)
        me.status_msg = "selection range: " + (row.line + 1).to_text() + ":" + (row.col + 1).to_text() + "-" + (end_line + 1).to_text() + ":" + (end_col + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _apply_all_lsp_selection_ranges() -> EditorAction:
        if me.lsp_result_panel.title != "Selection Ranges" or me.lsp_result_panel.rows.len() == 0:
            me.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val buffer = me.session.active_buffer()
        if buffer == nil:
            me.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        buffer.clear_selection_range()
        var applied = 0
        var i = 0
        while i < me.lsp_result_panel.rows.len():
            val row = me.lsp_result_panel.rows[i]
            if row.icon == "selection":
                val end_line = _editor_parse_i64(_editor_payload_part(row.command_payload, 0), row.line)
                val end_col = _editor_parse_i64(_editor_payload_part(row.command_payload, 1), row.col)
                buffer.add_selection_range(row.line, row.col, end_line, end_col)
                applied = applied + 1
            i = i + 1
        me.session.update_active_buffer(buffer)
        me.status_msg = "selection ranges applied: " + applied.to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _expand_lsp_selection_range() -> EditorAction:
        if me.lsp_result_panel.title == "Selection Ranges" and me.lsp_result_panel.rows.len() > 0:
            val buffer = me.session.active_buffer()
            if buffer != nil and buffer.has_active_selection_range() and me.lsp_result_panel.selected < me.lsp_result_panel.rows.len() - 1:
                me.lsp_result_panel = lsp_result_panel_select(me.lsp_result_panel, me.lsp_result_panel.selected + 1)
            return me._apply_selected_lsp_selection_range()
        return me._request_active_lsp_action("selection-ranges")

    me _shrink_lsp_selection_range() -> EditorAction:
        if me.lsp_result_panel.title != "Selection Ranges" or me.lsp_result_panel.rows.len() == 0:
            me.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.lsp_result_panel.selected > 0:
            me.lsp_result_panel = lsp_result_panel_select(me.lsp_result_panel, me.lsp_result_panel.selected - 1)
        me._apply_selected_lsp_selection_range()

    me _lsp_push_current_location():
        ctrl_lsp_push_current_location(me)

    me _lsp_back() -> EditorAction:
        ctrl_lsp_back(me)

    me _open_markdown_link_under_cursor() -> EditorAction:
        val doc = me.session.active_document()
        val buffer = me.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            me.status_msg = "not a markdown file"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val content = md_buffer_content(buffer)
        val raw_target = md_vim_open_link_under_cursor(content, buffer.cursor_row, buffer.cursor_col)
        if raw_target == "":
            me.status_msg = "no link under cursor"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me._open_markdown_link_target(raw_target)

    me _open_markdown_link_target(raw_target: text) -> EditorAction:
        val doc = me.session.active_document()
        if doc == nil or doc.language_id != "markdown":
            me.status_msg = "not a markdown file"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if raw_target.starts_with("http://") or raw_target.starts_with("https://"):
            me.status_msg = _editor_open_external_url_status(raw_target)
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val path = _editor_resolve_markdown_link_path(raw_target, doc.path(), me.session)
        if path == "":
            me.status_msg = "unresolved link: " + raw_target
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val parsed_target = md_wiki_parse_link_target(raw_target.trim())
        val title = parsed_target.0.trim()
        val should_create = _editor_markdown_link_should_create_note(raw_target, path)
        if should_create:
            val heading = if title == "" then md_wiki_title_from_path(path) else: title
            val note_content = "# " + heading + "\n\n"
            val written = rt_file_write_text(path, note_content)
            if not written:
                me.status_msg = "failed to create note: " + path
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            me.vault_search_index = md_vault_search_index_apply_file_change(me.vault_search_index, path, note_content, 1)
        var session_link = me.session
        session_link.open_file(path)
        me._replace_session(session_link)
        ctrl_focus_lsp_target_path(me, path)
        me.status_msg = if should_create then "created note: " + path else: "opened link: " + path
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _focus_lsp_target_doc(doc_id: EditorDocumentId):
        ctrl_focus_lsp_target_doc(me, doc_id)

    me _focus_lsp_target_path(path: text):
        ctrl_focus_lsp_target_path(me, path)

    me _dispatch_lsp_result_key(key: text) -> EditorAction:
        if key == "j":
            me.lsp_result_panel = lsp_result_panel_select(me.lsp_result_panel, me.lsp_result_panel.selected + 1)
            if me.lsp_result_panel.title == "Signature Help":
                me._refresh_lsp_hover_popup("signature-help")
            me.status_msg = "lsp result selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "k":
            me.lsp_result_panel = lsp_result_panel_select(me.lsp_result_panel, me.lsp_result_panel.selected - 1)
            if me.lsp_result_panel.title == "Signature Help":
                me._refresh_lsp_hover_popup("signature-help")
            me.status_msg = "lsp result selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "i":
            return me._request_selected_call_hierarchy_direction("incoming")
        if key == "o":
            return me._request_selected_call_hierarchy_direction("outgoing")
        if key == " " or key == "h" or key == "l":
            if me.lsp_result_panel.rows.len() == 0:
                return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
            val before = me.lsp_result_panel.rows[me.lsp_result_panel.selected]
            if key == " " and me.lsp_result_panel.title == "Call Hierarchy" and before.icon == "call" and not before.expanded:
                return me._request_selected_call_hierarchy_direction("incoming")
            me.lsp_result_panel = lsp_result_panel_toggle_expanded(me.lsp_result_panel)
            me.lsp_call_hierarchy_state = lsp_result_panel_call_state(me.lsp_result_panel)
            me.lsp_call_hierarchy_state_title = me.lsp_result_panel.title
            val row = me.lsp_result_panel.rows[me.lsp_result_panel.selected]
            me.status_msg = if row.expanded then "lsp result expanded" else: "lsp result collapsed"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "\r" or key == "\n":
            if me.lsp_result_panel.title == "Selection Ranges":
                return ctrl_apply_selected_lsp_selection_range(me)
            if me.lsp_result_panel.title == "Code Actions":
                val row = me.lsp_result_panel.rows[me.lsp_result_panel.selected]
                if row.command_name == "quickfix-apply":
                    return me._apply_code_action_at(row.command_payload.to_i64())
                me.status_msg = "no quick fix selected"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            return ctrl_lsp_jump_selected(me)
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _dispatch_wiki_panel_key(key: text) -> EditorAction:
        if key == "j":
            me.wiki_panel = wiki_panel_select(me.wiki_panel, me.wiki_panel.selected + 1)
            me.status_msg = "wiki result selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "k":
            me.wiki_panel = wiki_panel_select(me.wiki_panel, me.wiki_panel.selected - 1)
            me.status_msg = "wiki result selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "\r" or key == "\n":
            return me._wiki_jump_selected()
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _wiki_jump_selected() -> EditorAction:
        if me.wiki_panel.title == "Debug Launch Configs":
            return me._debug_start_selected_launch_config()
        if me.wiki_panel.title == "Debug Sessions":
            if me.wiki_panel.rows.len() == 0:
                me.status_msg = "no debug session"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            var debug_index = me.wiki_panel.selected
            if debug_index < 0:
                debug_index = 0
            if debug_index >= me.wiki_panel.rows.len():
                debug_index = me.wiki_panel.rows.len() - 1
            val debug_session_id = me.wiki_panel.rows[debug_index].line
            me.debug_registry = editor_debug_registry_select(me.debug_registry, debug_session_id)
            val selected_debug_session = editor_debug_first_session(me.debug_registry)
            if editor_debug_session_id(selected_debug_session) != debug_session_id:
                me.status_msg = "debug session not found: " + debug_session_id.to_text()
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val debug_client_index = debug_session_id - 1
            if debug_client_index >= 0 and debug_client_index < me.debug_dap_clients.len():
                me.debug_dap_client = me.debug_dap_clients[debug_client_index]
            me.debug_status = editor_debug_session_status(selected_debug_session)
            me._show_debug_panel_direct("debug session: " + editor_debug_session_id(selected_debug_session).to_text())
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.wiki_panel.title == "Templates":
            if me.wiki_panel.rows.len() == 0:
                me.status_msg = "no template target"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val template_detail = me.wiki_panel.rows[me.wiki_panel.selected].detail
            return me._execute_template_insert(template_detail)
        if me.wiki_panel.title == "Daily Notes":
            if me.wiki_panel.rows.len() == 0:
                me.status_msg = "no daily note target"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val daily_detail = me.wiki_panel.rows[me.wiki_panel.selected].detail
            return me._execute_daily_note_create(daily_detail)
        if me.wiki_panel.title == "Attachment Picker":
            if me.wiki_panel.rows.len() == 0:
                me.status_msg = "no attachment target"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            val picked_payload = me.wiki_panel.rows[me.wiki_panel.selected].detail
            if _editor_payload_part(picked_payload, 1) != "":
                return me._wiki_attachment_insert(picked_payload)
        val path = wiki_panel_target_path(me.wiki_panel)
        if path == "":
            me.status_msg = "no wiki result target"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val line = wiki_panel_target_line(me.wiki_panel)
        var session_jump = me.session
        session_jump.open_file(path)
        me._replace_session(session_jump)
        ctrl_focus_lsp_target_path(me, path)
        val buffer = me.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(line, 0)
            me.session.update_active_buffer(buffer)
        me.status_msg = "wiki jump: " + path + ":" + (line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _dispatch_diagnostics_panel_key(key: text) -> EditorAction:
        if key == "j":
            me.diagnostics_panel = diagnostics_panel_select(me.diagnostics_panel, me.diagnostics_panel.selected + 1)
            me.status_msg = "problem selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "k":
            me.diagnostics_panel = diagnostics_panel_select(me.diagnostics_panel, me.diagnostics_panel.selected - 1)
            me.status_msg = "problem selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "\r" or key == "\n":
            return me._diagnostics_jump_selected()
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _dispatch_md_outline_key(key: text) -> EditorAction:
        val doc = me.session.active_document()
        if doc == nil or not doc.has_markdown_state():
            return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
        var outline = doc.md_state.outline
        if key == "j":
            outline = outline_panel_navigate(outline, 1)
            var md_state = doc.md_state
            md_state.outline = outline
            doc.md_state = md_state
            me.session.update_active_document(doc)
            me.status_msg = "outline selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "k":
            outline = outline_panel_navigate(outline, -1)
            var md_state = doc.md_state
            md_state.outline = outline
            doc.md_state = md_state
            me.session.update_active_document(doc)
            me.status_msg = "outline selected"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if key == "\r" or key == "\n":
            val line = outline_panel_target_line(outline)
            doc.buffer.move_cursor(line, 0)
            doc.buffer.cursor_row = line
            doc.buffer.cursor_col = 0
            me.session.update_active_document(doc)
            me.status_msg = "outline jump: " + (line + 1).to_text()
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _diagnostics_jump_selected() -> EditorAction:
        val path = diagnostics_panel_target_path(me.diagnostics_panel)
        if path == "":
            me.status_msg = "no diagnostic target"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val line = diagnostics_panel_target_line(me.diagnostics_panel)
        val col = diagnostics_panel_target_col(me.diagnostics_panel)
        var session_jump = me.session
        session_jump.open_file(path)
        me._replace_session(session_jump)
        val buffer = me.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(line, col)
            me.session.update_active_buffer(buffer)
        me.status_msg = "problem jump: " + path + ":" + (line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _request_active_completion() -> LspResponse:
        if me.session.active_index < 0 or me.session.active_index >= me.session.documents.len() or me.session.active_index >= me.session.buffers.len():
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val doc = me.session.documents[me.session.active_index]
        val buffer = me.session.buffers[me.session.active_index]
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown" or md_lsp_is_markdown_file(doc.path()):
            if not me.md_lsp_state.running:
                me.md_lsp_state = md_lsp_ensure_open(me.md_lsp_state, doc.path(), content)
            val result = md_lsp_request(me.md_lsp_state, "completion", "", doc.path(), buffer.cursor_row, buffer.cursor_col)
            me.md_lsp_state = result.0
            return result.1
        elif doc.language_id == "simple" or doc.language_id == "shell":
            if not me.simple_lsp_state.running:
                me.simple_lsp_state = simple_lsp_ensure_open(me.simple_lsp_state, doc.path(), content)
            val simple_result = simple_lsp_request(me.simple_lsp_state, "completion", "", doc.path(), buffer.cursor_row, buffer.cursor_col)
            me.simple_lsp_state = simple_result.0
            return simple_result.1
        else:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

