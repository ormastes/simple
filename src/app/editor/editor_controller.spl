    me _debug_hydrate_dap_response(response_json: text) -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if not editor_debug_dap_response_success(response_json):
            self.status_msg = "debug response failed: " + editor_debug_dap_response_command(response_json)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val command = editor_debug_dap_response_command(response_json)
        if command == "stackTrace":
            self.debug_registry = editor_debug_update_stack_frames(self.debug_registry, editor_debug_session_id(session), editor_debug_stack_frames_from_dap_response(response_json))
            self._show_debug_session_panel("debug stack")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command == "scopes":
            self.debug_registry = editor_debug_update_scopes(self.debug_registry, editor_debug_session_id(session), editor_debug_scopes_from_dap_response(response_json))
            self._show_debug_session_panel("debug scopes")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command == "variables":
            self.debug_registry = editor_debug_update_scope_variables(self.debug_registry, editor_debug_session_id(session), "Locals", editor_debug_variables_from_dap_response(response_json))
            self._show_debug_session_panel("debug variables: Locals")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command == "evaluate":
            self.debug_registry = editor_debug_console_append(self.debug_registry, editor_debug_session_id(session), "evaluate-result", editor_debug_evaluate_result_from_dap_response(response_json))
            self._show_debug_session_panel("debug evaluate result")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "debug response ignored: " + command
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_hydrate_dap_event(event_json: text) -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if editor_debug_dap_message_type(event_json) != "event":
            self.status_msg = "debug event ignored"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val event = editor_debug_dap_event_name(event_json)
        val status = editor_debug_dap_event_status(event_json)
        if status == "":
            self.status_msg = "debug event ignored: " + event
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_set_status(self.debug_registry, editor_debug_session_id(session), status)
        self.debug_status = status
        self._show_debug_session_panel(editor_debug_dap_event_summary(event_json))
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_set_exception_filters(filters: [text]) -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_set_exception_filters(self.debug_registry, editor_debug_session_id(session), filters)
        var dap = self.debug_dap_client
        if dap.running:
            val requested = editor_debug_dap_client_set_exception_breakpoints(dap, filters)
            dap = requested.0
            self.debug_dap_client = dap
        self._show_debug_session_panel("exception breakpoints set")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_poll_dap_client() -> EditorAction:
        val action = self._poll_debug_dap_client()
        if action.redraw:
            return action
        self.status_msg = "no debug messages"
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _poll_debug_dap_client() -> EditorAction:
        var messages: [EditorDebugDapInboundMessage] = []
        if self.debug_process_pid > 0:
            if editor_debug_process_wait_simple_stopped(self.debug_process_pid):
                self.debug_status = "paused"
                self.status_msg = "debug stopped: entry"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)
        else:
            var dap = self.debug_dap_client
            val polled = editor_debug_dap_client_poll_messages(dap)
            dap = polled.0
            messages = polled.1
            self.debug_dap_client = dap
        var updated = false
        for message in messages:
            val message_type = editor_debug_dap_inbound_message_type(message)
            val raw_json = editor_debug_dap_inbound_raw_json(message)
            if message_type == "response":
                val action = self._debug_hydrate_dap_response(raw_json)
                if action.redraw:
                    updated = true
            elif message_type == "event":
                val event_action = self._debug_hydrate_dap_event(raw_json)
                if event_action.redraw:
                    updated = true
        if updated:
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _debug_request_stack_trace() -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var dap = self.debug_dap_client
        if not dap.running:
            self.status_msg = "debug adapter not running"
