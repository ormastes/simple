# Editor Controller
#
# Shared UI logic for TUI and GUI shells. Handles key dispatch,
# mode switching, file tree interaction, command line, and view state.
# Shells create a controller and call handle_key(); rendering is shell-specific.

extern fn rt_env_get(key: text) -> text

struct EditorAction:
    redraw: bool
    quit: bool
    status_msg: text

struct NormalKeyResult:
    message: text
    quit: bool
    enter_insert: bool
    enter_command: bool

struct InsertKeyResult:
    message: text
    exit_insert: bool

struct CommandKeyResult:
    commandline: text
    done: bool
    cancelled: bool

class EditorController:
    session: EditSession
    file_tree: FileTreeState
    file_tree_visible: bool
    focus_panel: text
    status_msg: text
    commandline: text
    pending_prefix: text
    running: bool
    config: EditorConfig
    settings_view: SettingsViewState
    palette_state: PaletteState
    extension_host: ExtensionHost
    diagnostic_store: DiagnosticStore
    code_actions: [EditorCodeAction]
    debug_status: text

impl EditorController:

    static fn new(session: EditSession) -> EditorController:
        val host = extension_host_with_builtins()
        host.discover_extensions(editor_extension_roots())
        EditorController(
            session: session,
            file_tree: FileTreeState.new("."),
            file_tree_visible: false,
            focus_panel: "editor",
            status_msg: "ready",
            commandline: "",
            pending_prefix: "",
            running: true,
            config: editor_config_default(),
            settings_view: nil,
            palette_state: nil,
            extension_host: host,
            diagnostic_store: DiagnosticStore.new(),
            code_actions: [],
            debug_status: "stopped"
        )

    me handle_key(key: text, rects: [SplitRect]) -> EditorAction:
        if key == "":
            return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

        if self.palette_state != nil and self.palette_state.visible:
            return self._dispatch_palette_key(key)

        if self.settings_view != nil:
            return self._dispatch_settings_key(key)

        if self.session.mode == EditorMode.Command:
            return self._dispatch_command_key(key)

        if self.session.mode == EditorMode.Normal:
            return self._dispatch_normal_key(key, rects)

        if self.session.mode == EditorMode.Insert:
            return self._dispatch_insert_key(key)

        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me toggle_file_tree():
        self.file_tree_visible = if self.file_tree_visible then false else: true
        if self.file_tree_visible:
            self.focus_panel = "file_tree"
        else:
            self.focus_panel = "editor"

    me toggle_focus():
        if self.file_tree_visible:
            self.focus_panel = if self.focus_panel == "editor" then "file_tree" else: "editor"

    fn active_buffer() -> EditorBuffer:
        self.session.active_buffer()

    fn mode() -> EditorMode:
        self.session.mode

    fn is_running() -> bool:
        self.running

    me settings_open():
        self.settings_view = SettingsViewState.new(full_settings_schema())

    me settings_close():
        self.settings_view = nil

    me _dispatch_settings_key(key: text) -> EditorAction:
        val sv = self.settings_view
        if key == "j":
            sv.select_next()
        elif key == "k":
            sv.select_prev()
        elif key == "\t":
            sv.next_category()
        elif key == "h":
            sv.prev_category()
        elif key == "l":
            sv.next_category()
        elif key == "\r" or key == "\n":
            if not sv.editing:
                val sd = sv.current_setting()
                if sd.setting_type == "bool":
                    val cur = editor_config_get_by_key(self.config, sd.key)
                    val toggled = if cur == "true" then "false" else: "true"
                    self.config = editor_config_set_by_key(self.config, sd.key, toggled)
                    self.status_msg = sd.key + " = " + toggled
                else:
                    val cur2 = editor_config_get_by_key(self.config, sd.key)
                    sv.start_edit(cur2)
        elif key == "\x1b":
            if sv.editing:
                sv.cancel_edit()
            else:
                self.settings_close()
        elif key == "q":
            self.settings_close()
        elif key == "/":
            sv.search_query = ""
            sv.editing = false
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _dispatch_command_key(key: text) -> EditorAction:
        val result = ctrl_handle_command_key(key, self.commandline)
        self.commandline = result.commandline
        if result.done:
            val parsed = editor_parse_commandline(self.commandline)
            if parsed.name == "settings":
                self.settings_open()
                self.session.mode = EditorMode.Normal
                self.commandline = ""
                self.status_msg = "settings"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            if parsed.name == "palette":
                self._open_palette()
                self.session.mode = EditorMode.Normal
                self.commandline = ""
                return EditorAction(redraw: true, quit: false, status_msg: "command palette")
            if parsed.name == "preview":
                self._toggle_md_preview()
                self.session.mode = EditorMode.Normal
                self.commandline = ""
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            if parsed.name == "outline":
                self._toggle_md_outline()
                self.session.mode = EditorMode.Normal
                self.commandline = ""
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            val dispatch_result = editor_dispatch_session(self.session, parsed)
            self.status_msg = dispatch_result.message
            if dispatch_result.quit:
                self.running = false
            self.session.mode = EditorMode.Normal
            self.commandline = ""
        elif result.cancelled:
            self.session.mode = EditorMode.Normal
            self.commandline = ""
            self.status_msg = ""
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _dispatch_normal_key(key: text, rects: [SplitRect]) -> EditorAction:
        if key == "\x02":
            self.toggle_file_tree()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\t":
            self.toggle_focus()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\x10":
            self._open_palette()
            return EditorAction(redraw: true, quit: false, status_msg: "command palette")
        if key == "\x16":
            self._toggle_md_preview()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if self.pending_prefix == "ctrl_w":
            self.pending_prefix = ""
            val wresult = wincmd_dispatch(self.session, key, rects)
            if wresult.handled:
                self.status_msg = wresult.message
                if wresult.quit:
                    self.running = false
            return EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

        if self.pending_prefix == "]" or self.pending_prefix == "[":
            val saved_prefix = self.pending_prefix
            self.pending_prefix = ""
            val doc = self.session.active_document()
            if doc != nil and doc.language_id == "markdown":
                val buffer_m = self.session.active_buffer()
                if buffer_m != nil:
                    val content = md_buffer_content(buffer_m)
                    val motion_result = md_dispatch_motion(saved_prefix, key, content, buffer_m.cursor_row, buffer_m.cursor_col)
                    if motion_result.found:
                        buffer_m.move_cursor(motion_result.line, motion_result.col)
                        self.status_msg = "motion"
                    return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if self.pending_prefix == "g":
            self.pending_prefix = ""
            val doc_g = self.session.active_document()
            if doc_g != nil and doc_g.language_id == "markdown" and key == "x":
                val buffer_gx = self.session.active_buffer()
                if buffer_gx != nil:
                    val content_gx = md_buffer_content(buffer_gx)
                    val link_url = md_vim_open_link_under_cursor(content_gx, buffer_gx.cursor_row, buffer_gx.cursor_col)
                    if link_url != "":
                        self.status_msg = "open: " + link_url
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            val buffer_gg = self.session.active_buffer()
            if buffer_gg != nil:
                buffer_gg.move_cursor(0, 0)
                self.status_msg = "top"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

        if key == "\x17":
            self.pending_prefix = "ctrl_w"
            return EditorAction(redraw: true, quit: false, status_msg: "Ctrl+W ...")

        if key == "]" or key == "[":
            self.pending_prefix = key
            return EditorAction(redraw: true, quit: false, status_msg: key + " ...")

        if self.focus_panel == "file_tree":
            return self._dispatch_file_tree_key(key)

        val buffer = self.session.active_buffer()
        if buffer == nil:
            if key == ":":
                self.session.mode = EditorMode.Command
                self.commandline = ""
            elif key == "q":
                self.running = false
            return EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

        if key == "g":
            val doc_g2 = self.session.active_document()
            if doc_g2 != nil and doc_g2.language_id == "markdown":
                self.pending_prefix = "g"
                return EditorAction(redraw: true, quit: false, status_msg: "g ...")

        val result = ctrl_handle_normal_key(buffer, key)
        self.status_msg = result.message
        if result.quit:
            self.running = false
        if result.enter_insert:
            self.session.mode = EditorMode.Insert
            self.status_msg = "-- INSERT --"
        if result.enter_command:
            self.session.mode = EditorMode.Command
            self.commandline = ""
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _dispatch_insert_key(key: text) -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.session.mode = EditorMode.Normal
            return EditorAction(redraw: true, quit: false, status_msg: "")
        val doc = self.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            if key == "\r" or key == "\n":
                val current_line = buffer.line_at(buffer.cursor_row)
                val continuation = md_assist_on_enter(current_line, buffer.cursor_col)
                if continuation != "":
                    buffer.insert_at_cursor("\n" + continuation)
                    md_update_preview(doc, buffer)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
            if key == "\t":
                val tab_line = buffer.line_at(buffer.cursor_row)
                val next_col = md_assist_on_tab(tab_line, buffer.cursor_col)
                if next_col >= 0:
                    buffer.move_cursor(buffer.cursor_row, next_col)
                    return EditorAction(redraw: true, quit: false, status_msg: "-- INSERT --")
        val result = ctrl_handle_insert_key(buffer, key)
        self.status_msg = result.message
        if result.exit_insert:
            self.session.mode = EditorMode.Normal
            self.status_msg = ""
        else:
            if doc != nil and doc.language_id == "markdown":
                md_update_preview(doc, buffer)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _dispatch_file_tree_key(key: text) -> EditorAction:
        if key == "j":
            self.file_tree.select_next()
        elif key == "k":
            self.file_tree.select_prev()
        elif key == "\r" or key == "\n":
            if self.file_tree.selected_is_dir():
                self.file_tree.toggle_expand()
            else:
                val fpath = self.file_tree.selected_path()
                self.session.open_file(fpath)
                self._activate_active_language()
                self.focus_panel = "editor"
                self.status_msg = "opened " + fpath
        elif key == "\x1b":
            self.focus_panel = "editor"
        elif key == ":":
            self.session.mode = EditorMode.Command
            self.commandline = ""
        elif key == "q":
            self.running = false
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)


    me _dispatch_palette_key(key: text) -> EditorAction:
        if key == "\x1b":
            self.palette_state = palette_hide(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\r" or key == "\n":
            val selected = palette_selected(self.palette_state)
            self.palette_state = palette_hide(self.palette_state)
            if selected.command_name != "":
                return self._execute_palette_command(selected.command_name, selected.command_payload)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x1b[A":
            self.palette_state = palette_select_prev(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x1b[B":
            self.palette_state = palette_select_next(self.palette_state)
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key == "\x7f" or key == "\b":
            val q = self.palette_state.query
            if q.len() > 0:
                self.palette_state = palette_update_query(self.palette_state, q.slice(0, q.len() - 1))
            return EditorAction(redraw: true, quit: false, status_msg: "")
        if key.len() == 1:
            val code = key.char_code_at(0)
            if code >= 32:
                self.palette_state = palette_update_query(self.palette_state, self.palette_state.query + key)
        EditorAction(redraw: true, quit: false, status_msg: "")

    me _open_palette():
        self._activate_active_language()
        var all_entries = editor_all_commands()
        val doc = self.session.active_document()
        if doc != nil and doc.language_id == "markdown":
            val md_entries = md_commands_palette_entries()
            var mi = 0
            while mi < md_entries.len():
                all_entries.push(md_entries[mi])
                mi = mi + 1
        self.palette_state = palette_show(palette_new(all_entries))

    me _execute_palette_command(command_name: text, command_payload: text) -> EditorAction:
        self.extension_host.activate_command(command_name)
        self.extension_host.emit_event("onWillExecuteCommand", command_name)
        self.extension_host.emit_event("onCommand:" + command_name, command_payload)
        val registered_command = self.extension_host.find_command(command_name)
        if registered_command.command.id != "" and registered_command.extension_name == "markdown-language":
            val action = self._execute_markdown_extension_command(command_name)
            self.extension_host.emit_event("onDidExecuteCommand", command_name)
            return action
        if registered_command.command.id != "":
            val invocation = self.extension_host.dispatch_external_command(command_name, command_payload)
            self.status_msg = "extension command queued: " + invocation.command_id
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command_name.starts_with("markdown."):
            self.status_msg = "extension command not registered: " + command_name
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if command_name == "quickfix":
            return self._request_quickfix()
        if command_name == "quickfix-apply":
            return self._apply_first_quickfix()
        if command_name == "debug-start":
            return self._start_debug_adapter(command_payload)
        val parsed = editor_cmd_with(command_name, command_payload)
        val dispatch_result = editor_dispatch_session(self.session, parsed)
        self.status_msg = dispatch_result.message
        if command_name == "open-file" and not dispatch_result.quit:
            self._activate_active_language()
        self.extension_host.emit_event("onDidExecuteCommand", command_name)
        if dispatch_result.quit:
            self.running = false
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _request_quickfix() -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if doc.language_id == "markdown":
            val content = md_buffer_content(buffer)
            val line = buffer.line_at(buffer.cursor_row)
            val fixed = _editor_markdown_quickfix_line(line)
            if fixed != line:
                val edit_json = "{\"line\":" + str(buffer.cursor_row) + ",\"newText\":\"" + _editor_escape_json(fixed) + "\"}"
                self.code_actions = [EditorCodeAction(title: "Apply Markdown quick fix", kind: "quickfix", edit_json: edit_json, command: "")]
                self.status_msg = "1 quick fix"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            val diags = md_diagnose(content, doc.path())
            if diags.len() > 0:
                self.status_msg = "diagnostics available"
            else:
                self.status_msg = "no quick fixes"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "no quick fixes"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _apply_first_quickfix() -> EditorAction:
        if self.code_actions.len() == 0:
            self.status_msg = "no quick fix selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "quick fix ready"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _start_debug_adapter(debug_type: text) -> EditorAction:
        val adapter_id = if debug_type == "" then "simple" else debug_type
        val adapter = self.extension_host.find_debug_adapter(adapter_id)
        if adapter.adapter.id == "":
            self.status_msg = "debug adapter not found: " + adapter_id
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_status = "starting"
        self.status_msg = "debug adapter: " + adapter.adapter.program
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _execute_markdown_extension_command(command_name: text) -> EditorAction:
        if command_name.starts_with("markdown."):
            val doc = self.session.active_document()
            val buffer = self.session.active_buffer()
            if doc != nil and doc.md_state != nil and buffer != nil:
                val content = md_buffer_content(buffer)
                val cmd_result = md_commands_dispatch(command_name, doc.md_state, content, buffer.cursor_row, buffer.cursor_col)
                doc.md_state = cmd_result.state
                md_apply_result(buffer, cmd_result)
                if cmd_result.state.preview_visible:
                    self.session.dock_layout.right_visible = true
                    self.session.dock_layout.active_right = "md-preview"
                elif cmd_result.state.outline_visible:
                    self.session.dock_layout.right_visible = true
                    self.session.dock_layout.active_right = "md-outline"
                else:
                    if not cmd_result.state.preview_visible and not cmd_result.state.outline_visible:
                        self.session.dock_layout.right_visible = false
                self.status_msg = cmd_result.status_message
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "markdown command unavailable"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _activate_active_language():
        val doc = self.session.active_document()
        if doc == nil:
            return
        self.extension_host.activate_language(doc.language_id)
        self.extension_host.emit_event("onDidOpenTextDocument", doc.path())
        self.extension_host.emit_event("onLanguage:" + doc.language_id, doc.path())

    me _toggle_md_preview():
        val doc = self.session.active_document()
        if doc == nil or doc.md_state == nil:
            self.status_msg = "not a markdown file"
            return
        doc.md_state.preview_visible = not doc.md_state.preview_visible
        if doc.md_state.preview_visible:
            val buffer = self.session.active_buffer()
            if buffer != nil:
                md_update_preview(doc, buffer)
            self.session.dock_layout.right_visible = true
            self.session.dock_layout.active_right = "md-preview"
            self.status_msg = "preview on"
        else:
            if not doc.md_state.outline_visible:
                self.session.dock_layout.right_visible = false
            self.status_msg = "preview off"

    me _toggle_md_outline():
        val doc = self.session.active_document()
        if doc == nil or doc.md_state == nil:
            self.status_msg = "not a markdown file"
            return
        doc.md_state.outline_visible = not doc.md_state.outline_visible
        if doc.md_state.outline_visible:
            val buffer = self.session.active_buffer()
            if buffer != nil:
                val content = md_buffer_content(buffer)
                doc.md_state.outline = outline_panel_update(doc.md_state.outline, content)
            self.session.dock_layout.right_visible = true
            self.session.dock_layout.active_right = "md-outline"
            self.status_msg = "outline on"
        else:
            if not doc.md_state.preview_visible:
                self.session.dock_layout.right_visible = false
            self.status_msg = "outline off"


fn ctrl_handle_normal_key(buffer: EditorBuffer, key: text) -> NormalKeyResult:
    if key == "q":
        return NormalKeyResult(message: "quit", quit: true, enter_insert: false, enter_command: false)
    if key == "i":
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == "a":
        buffer.move_relative(0, 1)
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == "o":
        buffer.move_to_line_end()
        buffer.insert_at_cursor("\n")
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == ":":
        return NormalKeyResult(message: "", quit: false, enter_insert: false, enter_command: true)
    if key == "h":
        val result = editor_dispatch(buffer, editor_cmd("move-left"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "j":
        val result = editor_dispatch(buffer, editor_cmd("move-down"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "k":
        val result = editor_dispatch(buffer, editor_cmd("move-up"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "l":
        val result = editor_dispatch(buffer, editor_cmd("move-right"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "0":
        buffer.move_to_line_start()
        return NormalKeyResult(message: "home", quit: false, enter_insert: false, enter_command: false)
    if key == "$":
        buffer.move_to_line_end()
        return NormalKeyResult(message: "end", quit: false, enter_insert: false, enter_command: false)
    if key == "G":
        buffer.move_cursor(buffer.line_count() - 1, 0)
        return NormalKeyResult(message: "bottom", quit: false, enter_insert: false, enter_command: false)
    if key == "g":
        buffer.move_cursor(0, 0)
        return NormalKeyResult(message: "top", quit: false, enter_insert: false, enter_command: false)
    if key == "x":
        val result = editor_dispatch(buffer, editor_cmd("delete"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "u":
        val result = editor_dispatch(buffer, editor_cmd("undo"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "\x12":
        val result = editor_dispatch(buffer, editor_cmd("redo"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    NormalKeyResult(message: "", quit: false, enter_insert: false, enter_command: false)

fn editor_extension_roots() -> [text]:
    var roots: [text] = []
    roots.push(".simple/editor/extensions")
    roots.push(".vscode/simple-editor/extensions")
    val configured = rt_env_get("SIMPLE_EDITOR_EXTENSION_PATH") ?? ""
    val configured_roots = _editor_split_path_list(configured)
    for root in configured_roots:
        roots.push(root)
    val home = rt_env_get("HOME") ?? ""
    if home != "":
        roots.push(home + "/.simple/editor/extensions")
        roots.push(home + "/.simple/extensions")
    roots.push("/usr/local/share/simple/editor/extensions")
    roots.push("/usr/share/simple/editor/extensions")
    roots

fn _editor_split_path_list(value: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    while i < value.len():
        if value.char_at(i) == ":":
            val part = value.slice(start, i).trim()
            if part != "":
                parts.push(part)
            start = i + 1
        i = i + 1
    val last = value.slice(start, value.len()).trim()
    if last != "":
        parts.push(last)
    parts

fn _editor_markdown_quickfix_line(line: text) -> text:
    val trimmed = line.trim()
    if trimmed.starts_with("#"):
        var level = 0
        while level < trimmed.len() and trimmed.char_at(level) == "#":
            level = level + 1
        if level < trimmed.len() and trimmed.char_at(level) != " ":
            return trimmed.slice(0, level) + " " + trimmed.slice(level, trimmed.len())
    if line.contains("[]()"):
        return line.replace("[]()", "[text](url)")
    if line.ends_with(" ") or line.ends_with("\t"):
        return line.trim()
    line

fn _editor_escape_json(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        else:
            result = result + ch
        i = i + 1
    result

fn ctrl_handle_insert_key(buffer: EditorBuffer, key: text) -> InsertKeyResult:
    if key == "\x1b":
        return InsertKeyResult(message: "", exit_insert: true)
    if key == "\x7f" or key == "\b":
        editor_dispatch(buffer, editor_cmd("backspace"))
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    if key == "\r" or key == "\n":
        editor_dispatch(buffer, editor_cmd("newline"))
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    if key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            editor_dispatch(buffer, editor_cmd_with("insert-text", key))
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    InsertKeyResult(message: "-- INSERT --", exit_insert: false)

fn ctrl_handle_command_key(key: text, commandline: text) -> CommandKeyResult:
    if key == "\x1b":
        return CommandKeyResult(commandline: "", done: false, cancelled: true)
    if key == "\r" or key == "\n":
        return CommandKeyResult(commandline: commandline, done: true, cancelled: false)
    if key == "\x7f" or key == "\b":
        if commandline.len() > 0:
            return CommandKeyResult(commandline: commandline.slice(0, commandline.len() - 1), done: false, cancelled: false)
        return CommandKeyResult(commandline: "", done: false, cancelled: true)
    if key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            return CommandKeyResult(commandline: commandline + key, done: false, cancelled: false)
    CommandKeyResult(commandline: commandline, done: false, cancelled: false)

struct LayoutZones:
    tab_bar_y: i64
    tab_bar_h: i64
    sidebar_x: i64
    sidebar_y: i64
    sidebar_w: i64
    sidebar_h: i64
    editor_x: i64
    editor_y: i64
    editor_w: i64
    editor_h: i64
    status_y: i64
    command_y: i64

struct LayoutZonesRight:
    x: i64
    w: i64

fn ctrl_compute_zones(ctrl: EditorController, total_w: i64, total_h: i64) -> LayoutZones:
    val sidebar_w = if ctrl.file_tree_visible then ctrl.session.dock_layout.left_width else: 0
    val right_w = if ctrl.session.dock_layout.right_visible then ctrl.session.dock_layout.right_width else: 0
    val editor_area_h = total_h - 3
    val ew = total_w - sidebar_w - right_w
    LayoutZones(
        tab_bar_y: 0,
        tab_bar_h: 1,
        sidebar_x: 0,
        sidebar_y: 1,
        sidebar_w: sidebar_w,
        sidebar_h: editor_area_h,
        editor_x: sidebar_w,
        editor_y: 1,
        editor_w: ew,
        editor_h: editor_area_h,
        status_y: total_h - 2,
        command_y: total_h - 1
    )

fn ctrl_right_zone(ctrl: EditorController, zones: LayoutZones) -> LayoutZonesRight:
    val right_w = if ctrl.session.dock_layout.right_visible then ctrl.session.dock_layout.right_width else: 0
    LayoutZonesRight(
        x: zones.editor_x + zones.editor_w,
        w: right_w
    )
