        val nav = if direction == "prev" then md_table_prev_cell(buffer.to_text(), buffer.cursor_row_value(), buffer.cursor_col_value()) else: md_table_next_cell(buffer.to_text(), buffer.cursor_row_value(), buffer.cursor_col_value())
        if not nav.found:
            self.status_msg = nav.message
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
