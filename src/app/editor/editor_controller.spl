# Editor Controller
#
# Shared UI logic for TUI and GUI shells. Handles key dispatch,
# mode switching, file tree interaction, command line, and view state.
# Shells create a controller and call handle_key(); rendering is shell-specific.

use std.editor.services.md_wiki_index.*
use std.editor.services.md_search.*
use std.editor.services.file_watcher.*
use std.editor.common.keybindings.*
use std.editor.extensions.builtin.md_edit_assist.*
use std.editor.view.diagnostics_panel.*
use std.editor.view.lsp_result_panel.*
use std.editor.view.wiki_panel.*
use app.editor.debug_process_runtime.*

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_walk(path: text) -> [text]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

struct EditorAction:
    redraw: bool
    quit: bool
    status_msg: text

struct NormalKeyResult:
    message: text
    quit: bool
    enter_insert: bool
    enter_command: bool

struct InsertKeyResult:
    message: text
    exit_insert: bool

struct CommandKeyResult:
    commandline: text
    done: bool
    cancelled: bool

struct EditorAppliedCodeAction:
    applied: bool
    content: text
    line: i64
    col: i64

struct EditorPropertyPayload:
    key: text
    value: text

struct EditorLocation:
    path: text
    line: i64
    col: i64

class EditorController:
    session: EditSession
    file_tree: FileTreeState
    file_tree_visible: bool
    focus_panel: text
    status_msg: text
    commandline: text
    pending_prefix: text
    running: bool
    config: EditorConfig
    settings_view: SettingsViewState?
    palette_state: PaletteState
    extension_host: ExtensionHost
    diagnostic_store: DiagnosticStore
    diagnostics_panel: DiagnosticsPanel
    diagnostics_view_mode: text
    diagnostics_view_payload: text
    file_watcher: FileWatcher
    code_actions: [EditorCodeAction]
    debug_status: text
    debug_registry: EditorDebugRegistry
    debug_dap_client: EditorDebugDapClient
    debug_process_pid: i64
    debug_launch_configs: [EditorDebugLaunchConfig]
    lsp_result_panel: LspResultPanel
    lsp_call_hierarchy_state: text
    lsp_call_hierarchy_state_title: text
    lsp_call_hierarchy_merge_panel: LspResultPanel
    lsp_call_hierarchy_merge_index: i64
    lsp_hover_popup: LspHoverPopup
    lsp_signature_popup: LspSignaturePopup
    lsp_location_stack: [EditorLocation]
    pending_workspace_edit_json: text
    pending_workspace_edit_title: text
    format_save_request_id: i64
    format_save_title: text
    wiki_panel: WikiPanel
    vault_search_index: MdVaultSearchIndex
    wiki_vault_search_root: text
    wiki_vault_search_query: text
    wiki_quick_switch_query: text
    wiki_daily_note_payload: text
    wiki_template_picker_payload: text
    wiki_template_query: text
    wiki_attachment_picker_payload: text
    wiki_attachment_query: text
    wiki_task_filter: text
    wiki_task_query: text
    wiki_property_vault_root: text
    md_lsp_state: MdLspState
    simple_lsp_state: SimpleLspState

impl EditorController:

    static fn new(session: EditSession) -> EditorController:
        val host = extension_host_with_builtins()
        host.discover_extensions(editor_extension_roots())
        EditorController(
            session: session,
            file_tree: FileTreeState.new("."),
            file_tree_visible: false,
            focus_panel: "editor",
            status_msg: "ready",
            commandline: "",
            pending_prefix: "",
            running: true,
            config: editor_config_default(),
            settings_view: nil,
            palette_state: nil,
            extension_host: host,
            diagnostic_store: DiagnosticStore.new(),
            diagnostics_panel: diagnostics_panel_new(),
            diagnostics_view_mode: "all",
            diagnostics_view_payload: "",
            file_watcher: FileWatcher.new(),
            code_actions: [],
            debug_status: "stopped",
            debug_registry: editor_debug_registry_new(),
            debug_dap_client: EditorDebugDapClient.new(),
            debug_process_pid: 0,
            debug_launch_configs: [],
            lsp_result_panel: lsp_result_panel_new("LSP Results"),
            lsp_call_hierarchy_state: "",
            lsp_call_hierarchy_state_title: "",
            lsp_call_hierarchy_merge_panel: lsp_result_panel_new(""),
            lsp_call_hierarchy_merge_index: -1,
            lsp_hover_popup: lsp_hover_popup_hidden(),
            lsp_signature_popup: lsp_signature_popup_hidden(),
            lsp_location_stack: [],
            pending_workspace_edit_json: "",
            pending_workspace_edit_title: "",
            format_save_request_id: 0,
            format_save_title: "",
            wiki_panel: wiki_panel_new("Wiki"),
            vault_search_index: md_vault_search_index_new("", []),
            wiki_vault_search_root: "",
            wiki_vault_search_query: "",
            wiki_quick_switch_query: "",
            wiki_daily_note_payload: "",
            wiki_template_picker_payload: "",
            wiki_template_query: "",
            wiki_attachment_picker_payload: "",
            wiki_attachment_query: "",
            wiki_task_filter: "open",
            wiki_task_query: "",
            wiki_property_vault_root: "",
            md_lsp_state: md_lsp_state_new("."),
            simple_lsp_state: simple_lsp_state_new(".")
        )

    me handle_key(key: text, rects: [SplitRect]) -> EditorAction:
        if key == "":
            return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

        if self.palette_state != nil and self.palette_state.visible:
            return self._dispatch_palette_key(key)

        if self.settings_view != nil:
            return self._dispatch_settings_key(key)

        if self.session.mode == editor_mode_command():
            return self._dispatch_command_key(key)

        if self.session.mode == editor_mode_normal():
            return self._dispatch_normal_key(key, rects)

        if self.session.mode == editor_mode_insert():
            return self._dispatch_insert_key(key)

        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me toggle_file_tree():
        self.file_tree_visible = if self.file_tree_visible then false else: true
        if self.file_tree_visible:
            self.focus_panel = "file_tree"
        else:
            self.focus_panel = "editor"

    me toggle_focus():
        if self.file_tree_visible:
            self.focus_panel = if self.focus_panel == "editor" then "file_tree" else: "editor"

    fn active_buffer() -> EditorBuffer:
        self.session.active_buffer()

    fn mode() -> EditorMode:
        self.session.mode

    fn is_running() -> bool:
        self.running

    me settings_open():
        self.settings_view = SettingsViewState.new(full_settings_schema())

    me settings_close():
        self.settings_view = nil

    me _dispatch_settings_key(key: text) -> EditorAction:
        val sv: SettingsViewState = self.settings_view
        if key == "j":
            sv.select_next()
        elif key == "k":
            sv.select_prev()
        elif key == "\t":
            sv.next_category()
        elif key == "h":
            sv.prev_category()
        elif key == "l":
            sv.next_category()
        elif key == "\r" or key == "\n":
            if not sv.is_editing():
                val setting_key = sv.current_setting_key()
                if sv.current_setting_type() == "bool":
                    val cur = editor_config_get_by_key(self.config, setting_key)
                    val toggled = if cur == "true" then "false" else: "true"
                    self.config = editor_config_set_by_key(self.config, setting_key, toggled)
                    self.status_msg = setting_key + " = " + toggled
                else:
                    val cur2 = editor_config_get_by_key(self.config, setting_key)
                    sv.start_edit(cur2)
        elif key == "\x1b":
            if sv.is_editing():
                sv.cancel_edit()
            else:
                self.settings_close()
        elif key == "q":
            self.settings_close()
        elif key == "/":
            sv.clear_search()
        EditorAction(redraw: true, quit: not self.running, status_msg: self.status_msg)

    me _dispatch_command_key(key: text) -> EditorAction:
        val result = ctrl_handle_command_key(key, self.commandline)
        self.commandline = result.commandline
        if result.done:
            val parsed = editor_parse_commandline(self.commandline)
            if parsed.name == "settings":
                self.settings_open()
                self.session.mode = editor_mode_normal()
                self.commandline = ""
                self.status_msg = "settings"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            if parsed.name == "palette":
                self._open_palette()
                self.session.mode = editor_mode_normal()
                self.commandline = ""
                return EditorAction(redraw: true, quit: false, status_msg: "command palette")
            if parsed.name == "preview":
                self._toggle_md_preview()
                self.session.mode = editor_mode_normal()
                self.commandline = ""
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            if parsed.name == "outline":
                self._toggle_md_outline()
