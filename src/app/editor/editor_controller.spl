        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_registry_terminate(self.debug_registry, editor_debug_session_id(session))
        self.debug_dap_client = editor_debug_dap_stop_process_pid(self.debug_process_pid)
        self.debug_process_pid = 0
        self.debug_status = "terminated"
        self.status_msg = "debug terminated"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _debug_restart_first() -> EditorAction:
        val session = editor_debug_first_session(self.debug_registry)
        if editor_debug_session_id(session) == 0:
            self.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.debug_registry = editor_debug_registry_restart(self.debug_registry, editor_debug_session_id(session))
        var dap = self.debug_dap_client
        dap.start()
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, editor_debug_session_config(session))
        dap = launched.0
        self.debug_dap_client = dap
        self.debug_status = "restarting"
        self.status_msg = "debug restart"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_debug_session_panel(message: text):
        self.wiki_panel = _editor_debug_session_panel(editor_debug_first_session(self.debug_registry))
        self._show_wiki_panel(message)

    me _wiki_daily_note_create(payload: text) -> EditorAction:
        val date = _editor_payload_part(payload, 0)
        if date == "":
            self.status_msg = "missing daily note date"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
        val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
        val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
        val extension = _editor_daily_note_extension(_editor_payload_part(payload, 4))
        val title = title_format.replace("{{date}}", date)
        val path = _editor_join_path(folder, title + extension)
        val content = _editor_apply_template_text(template_body, title, date)
        val ok = rt_file_write_text(path, content)
        if not ok:
            self.status_msg = "failed to create daily note"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val target_doc_id = self.session.open_file(path)
        self._focus_lsp_target_doc(target_doc_id)
        self.status_msg = "created daily note: " + path
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_daily_note_picker(payload: text) -> EditorAction:
        val date = _editor_payload_part(payload, 0)
        val folder = if _editor_payload_part(payload, 1) == "" then "Daily" else: _editor_payload_part(payload, 1)
        val template_body = if _editor_payload_part(payload, 2) == "" then "# {{title}}\n\n" else: _editor_payload_part(payload, 2)
        val title_format = if _editor_payload_part(payload, 3) == "" then "{{date}}" else: _editor_payload_part(payload, 3)
        val extension = _editor_daily_note_extension(_editor_payload_part(payload, 4))
        self.wiki_daily_note_payload = date + "|" + folder + "|" + template_body + "|" + title_format + "|" + extension
        val preview_date = if date == "" then "YYYY-MM-DD" else: date
        val title = title_format.replace("{{date}}", preview_date)
        val path = _editor_join_path(folder, title + extension)
        self.wiki_panel = wiki_panel_with_rows("Daily Notes", [
            WikiPanelRow(icon: "calendar", label: preview_date, detail: self.wiki_daily_note_payload, path: path, line: 0)
        ])
        self._show_wiki_panel("daily notes")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_template_insert(payload: text) -> EditorAction:
        val template_path = _editor_payload_part(payload, 0)
        val target_path = _editor_payload_part(payload, 1)
        val title = _editor_payload_part(payload, 2)
        val date = _editor_payload_part(payload, 3)
        if template_path == "" or target_path == "":
            self.status_msg = "missing template or target path"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val rendered = _editor_apply_template_text(rt_file_read_text(template_path) ?? "", title, date)
        val existing = rt_file_read_text(target_path) ?? ""
        val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
        val ok = rt_file_write_text(target_path, existing + sep + rendered)
        if not ok:
            self.status_msg = "failed to insert template"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "inserted template: " + template_path
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_template_picker(payload: text) -> EditorAction:
        val folder = _editor_payload_part(payload, 0)
        val target_path = _editor_payload_part(payload, 1)
        val title = _editor_payload_part(payload, 2)
        val date = _editor_payload_part(payload, 3)
        val query = _editor_payload_part(payload, 4).trim().to_lower()
        if folder == "":
            self.status_msg = "missing template folder"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.wiki_template_picker_payload = folder + "|" + target_path + "|" + title + "|" + date + "|" + query
        self.wiki_template_query = query
        self.wiki_panel = wiki_panel_with_rows("Templates", _editor_template_picker_rows(folder, target_path, title, date, query))
        self._show_wiki_panel("templates: " + self.wiki_panel.rows.len().to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_attachment_insert(payload: text) -> EditorAction:
        val target_path = _editor_payload_part(payload, 0)
        val attachment_path = _editor_payload_part(payload, 1)
        val label = _editor_payload_part(payload, 2)
        val storage_dir = _editor_payload_part(payload, 3)
        if target_path == "" or attachment_path == "":
            self.status_msg = "missing target or attachment path"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        var embed_path = attachment_path
        if storage_dir != "":
            val stored = _editor_store_attachment_for_note(target_path, attachment_path, storage_dir)
            if stored == "":
                self.status_msg = "failed to store attachment"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            embed_path = stored
        val existing = rt_file_read_text(target_path) ?? ""
        val embed = _editor_attachment_embed(embed_path, label)
        val sep = if existing == "" or existing.ends_with("\n") then "" else: "\n"
        val ok = rt_file_write_text(target_path, existing + sep + embed + "\n")
        if not ok:
            self.status_msg = "failed to insert attachment"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "inserted attachment: " + embed_path
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_attachment_picker(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val query = _editor_payload_part(payload, 1).to_lower()
        val target_path = _editor_payload_part(payload, 2)
        val storage_dir = _editor_payload_part(payload, 3)
        if root == "":
            self.status_msg = "missing attachment root"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.wiki_attachment_picker_payload = root + "|" + query + "|" + target_path + "|" + storage_dir
        self.wiki_attachment_query = query
        self.wiki_panel = wiki_panel_with_rows("Attachment Picker", _editor_attachment_picker_rows(root, query, target_path, storage_dir))
        self._show_wiki_panel("attachments: " + self.wiki_panel.rows.len().to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _toggle_markdown_task_line(line: i64) -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown task"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if line < 0 or line >= buffer.line_count():
            self.status_msg = "task line out of range"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val current = buffer.line_at(line)
        val toggled = md_assist_toggle_task(current)
        if toggled == current:
            self.status_msg = "not a task"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.move_cursor(line, 0)
        var i = 0
        while i < current.len():
            buffer.delete_at_cursor()
            i = i + 1
        buffer.insert_at_cursor(toggled)
        self._update_markdown_preview(doc, buffer)
        self.session.update_active_buffer(buffer)
        self._notify_active_lsp_changed()
        self.status_msg = "task toggled"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _markdown_table_insert_row() -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown table"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val edit = md_table_insert_row_after(buffer.to_text(), buffer.cursor_row_value())
        if not edit.changed:
            self.status_msg = edit.message
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.push_undo_snapshot()
        buffer.replace_content(edit.content)
        buffer.dirty = true
        buffer.move_cursor(edit.line, edit.col)
        self._update_markdown_preview(doc, buffer)
        self.session.update_active_buffer(buffer)
        self._notify_active_lsp_changed()
        self.status_msg = edit.message
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

