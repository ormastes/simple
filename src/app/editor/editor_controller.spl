        me._show_debug_panel_direct("debug variables: " + scope_name)
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_hydrate_dap_response(response_json: text) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if not editor_debug_dap_response_success(response_json):
            me.status_msg = "debug response failed: " + editor_debug_dap_response_command(response_json)
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val command = editor_debug_dap_response_command(response_json)
        if command == "stackTrace":
            me.debug_registry = editor_debug_update_stack_frames(me.debug_registry, editor_debug_session_id(session), editor_debug_stack_frames_from_dap_response(response_json))
            me._show_debug_panel_direct("debug stack")
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if command == "scopes":
            me.debug_registry = editor_debug_update_scopes(me.debug_registry, editor_debug_session_id(session), editor_debug_scopes_from_dap_response(response_json))
            me._show_debug_panel_direct("debug scopes")
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if command == "variables":
            me.debug_registry = editor_debug_update_scope_variables(me.debug_registry, editor_debug_session_id(session), "Locals", editor_debug_variables_from_dap_response(response_json))
            me._show_debug_panel_direct("debug variables: Locals")
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if command == "evaluate":
            val value = editor_debug_evaluate_result_from_dap_response(response_json)
            if me.debug_pending_watch_expressions.len() > 0:
                val expression = me.debug_pending_watch_expressions[0]
                me.debug_pending_watch_expressions = _editor_text_list_without_first(me.debug_pending_watch_expressions)
                me.debug_registry = editor_debug_update_watch(me.debug_registry, editor_debug_session_id(session), expression, value, "ok")
                me._show_debug_panel_direct("watch refreshed: " + expression)
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            me.debug_registry = editor_debug_console_append(me.debug_registry, editor_debug_session_id(session), "evaluate-result", value)
            me._show_debug_panel_direct("debug evaluate result")
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.status_msg = "debug response ignored: " + command
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_hydrate_dap_event(event_json: text) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if editor_debug_dap_message_type(event_json) != "event":
            me.status_msg = "debug event ignored"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val event = editor_debug_dap_event_name(event_json)
        val status = editor_debug_dap_event_status(event_json)
        if status == "":
            me.status_msg = "debug event ignored: " + event
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_set_status(me.debug_registry, editor_debug_session_id(session), status)
        me.debug_status = status
        me._show_debug_panel_direct(editor_debug_dap_event_summary(event_json))
        if status == "paused":
            val event_status = me.status_msg
            me._debug_refresh_watches()
            me.status_msg = event_status
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_set_exception_filters(filters: [text]) -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_set_exception_filters(me.debug_registry, editor_debug_session_id(session), filters)
        if me.debug_dap_client.running:
            val requested = editor_debug_dap_client_set_exception_breakpoints(me.debug_dap_client, filters)
            me.debug_dap_client = requested.0
        me._show_debug_panel_direct("exception breakpoints set")
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_poll_dap_client() -> EditorAction:
        val action = me._poll_debug_dap_client()
        if action.redraw:
            return action
        me.status_msg = "no debug messages"
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _poll_debug_dap_client() -> EditorAction:
        var messages: [EditorDebugDapInboundMessage] = []
        if me.debug_process_pid > 0:
            if editor_debug_process_wait_simple_stopped(me.debug_process_pid):
                me.debug_status = "paused"
                me.status_msg = "debug stopped: entry"
                return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
            return EditorAction(redraw: false, quit: false, status_msg: me.status_msg)
        else:
            var dap = me.debug_dap_client
            val polled = editor_debug_dap_client_poll_messages(dap)
            dap = polled.0
            messages = polled.1
            me.debug_dap_client = dap
        var updated = false
        for message in messages:
            val message_type = editor_debug_dap_inbound_message_type(message)
            val raw_json = editor_debug_dap_inbound_raw_json(message)
            if message_type == "response":
                val action = me._debug_hydrate_dap_response(raw_json)
                if action.redraw:
                    updated = true
            elif message_type == "event":
                val event_action = me._debug_hydrate_dap_event(raw_json)
                if event_action.redraw:
                    updated = true
        if updated:
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        EditorAction(redraw: false, quit: false, status_msg: me.status_msg)

    me _debug_request_stack_trace() -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if not me.debug_dap_client.running:
            me.status_msg = "debug adapter not running"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        val requested = editor_debug_dap_client_stack_trace(me.debug_dap_client, 1)
        me.debug_dap_client = requested.0
        me.status_msg = "debug stack requested"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

