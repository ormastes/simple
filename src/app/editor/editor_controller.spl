        val requested = editor_debug_dap_client_stack_trace(dap, 1)
        dap = requested.0
        self.debug_dap_client = dap
        self.status_msg = "debug stack requested"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

