    fn _wiki_index_open_documents() -> MdWikiIndex:
        var docs: [MdWikiDocument] = []
        for doc in self.session.documents:
            if doc.language_id == "markdown":
                if not _editor_wiki_docs_has_path(docs, doc.path()):
                    docs.push(md_wiki_document(doc.path(), doc.buffer.to_text()))
        if self.vault_search_index.root != "" and not self.vault_search_index.dirty:
            for vault_doc in self.vault_search_index.documents:
                if not _editor_wiki_docs_has_path(docs, vault_doc.path):
                    docs.push(vault_doc)
        md_wiki_index_documents(docs)

    me _wiki_vault_search(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val query = _editor_payload_part(payload, 1)
        if root == "" or query == "":
            self.status_msg = "missing vault root or query"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.wiki_vault_search_root = root
        self.wiki_vault_search_query = query
        var index = self.vault_search_index
        val cache_path = _editor_vault_search_cache_path(root)
        if index.root != root:
            val docs = _editor_markdown_vault_documents(root)
            val loaded = md_vault_search_index_load(cache_path)
            if loaded.root == root and not loaded.dirty and md_vault_search_index_matches_documents(loaded, docs):
                index = loaded
            else:
                index = md_vault_search_index_new(root, docs)
                md_vault_search_index_save(index, cache_path)
        elif index.dirty:
            index = md_vault_search_index_refresh(index, _editor_markdown_vault_documents(root))
            md_vault_search_index_save(index, cache_path)
        self.vault_search_index = index
        val matches = md_vault_search_index_search(index, query)
        self.wiki_panel = wiki_panel_from_vault_search(matches)
        self._show_wiki_panel("wiki vault search: " + matches.len().to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_wiki_panel(message: text):
        var layout = self.session.dock_layout
        layout.show_right("wiki-panel")
        self.session.dock_layout = layout
        self.status_msg = message

    me _set_lsp_result_panel_from_response(kind: text, response: LspResponse):
        if kind == "code-action" and response.ok and response.result_json != "":
            self.code_actions = _editor_code_actions_from_response(response.result_json)
            self.lsp_result_panel = self._code_action_result_panel(response.id)
            return
        var panel = lsp_result_panel_from_response(kind, response)
        if kind == "call-hierarchy" or kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing":
            val title = lsp_result_title(kind)
            if panel.pending:
                if self.lsp_result_panel.title == title:
                    self.lsp_call_hierarchy_state = lsp_result_panel_call_state(self.lsp_result_panel)
                    self.lsp_call_hierarchy_state_title = title
            else:
                if self.lsp_result_panel.title == title and self.lsp_call_hierarchy_state_title == title:
                    panel = lsp_result_panel_restore_call_state(panel, self.lsp_call_hierarchy_state)
                if (kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing") and self.lsp_call_hierarchy_merge_index >= 0 and self.lsp_call_hierarchy_merge_panel.title == "Call Hierarchy":
                    panel = lsp_result_panel_with_call_children(self.lsp_call_hierarchy_merge_panel, self.lsp_call_hierarchy_merge_index, panel)
                    self.lsp_call_hierarchy_merge_index = -1
                    self.lsp_call_hierarchy_merge_panel = lsp_result_panel_new("")
                self.lsp_call_hierarchy_state = lsp_result_panel_call_state(panel)
                self.lsp_call_hierarchy_state_title = panel.title
        self.lsp_result_panel = panel

    me _request_active_lsp_action(kind: text) -> EditorAction:
        val response = self._request_active_lsp(kind)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if _editor_lsp_kind_has_panel(kind):
            self._set_lsp_result_panel_from_response(kind, response)
            if kind == "document-symbols" and response.ok and response.result_json != "":
                self._apply_lsp_document_symbols_outline()
            self._refresh_lsp_hover_popup(kind)
            self._show_lsp_result_panel(kind + " results")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = kind + " requested"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_workspace_symbols(query: text) -> EditorAction:
        val response = self._request_active_lsp_with_payload("workspace-symbols", query)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.lsp_result_panel = lsp_result_panel_from_response("workspace-symbols", response)
        self._refresh_lsp_hover_popup("workspace-symbols")
        self._show_lsp_result_panel("workspace-symbols results")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _dismiss_lsp_hover_popup() -> EditorAction:
        self.lsp_hover_popup = lsp_hover_popup_hidden()
        self.status_msg = "hover dismissed"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _dismiss_lsp_signature_popup() -> EditorAction:
        self.lsp_signature_popup = lsp_signature_popup_hidden()
        self.status_msg = "signature dismissed"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_active_formatting_preview(kind: text) -> EditorAction:
        val response = self._request_active_lsp(kind)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val title = if kind == "range-formatting" then "range formatting" else: "formatting"
        self.pending_workspace_edit_json = ""
        self.pending_workspace_edit_title = title
        if response.result_json != "":
            self._show_workspace_edit_preview(response.result_json, title)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val pending_kind = if kind == "range-formatting" then "range-formatting-preview" else: "formatting-preview"
        self.lsp_result_panel = lsp_result_panel_pending(pending_kind, response.id)
        self._show_lsp_result_panel(title + " preview requested")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_active_formatting_save(kind: text) -> EditorAction:
        val response = self._request_active_lsp(kind)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val title = if kind == "range-formatting" then "range formatting" else: "formatting"
        self.format_save_request_id = response.id
        self.format_save_title = title
        if response.result_json != "":
            self._apply_workspace_edit_result(response.result_json, title)
            self.format_save_request_id = 0
            self.format_save_title = ""
            return self._save_active_after_format(title)
        self.status_msg = title + " save requested"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _save_active_after_format(title: text) -> EditorAction:
        val saved = self.session.save_active()
        if saved:
            self.status_msg = "applied and saved: " + title
        else:
            self.status_msg = "applied: " + title + " (save failed)"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _rename_active_symbol(new_name: text) -> EditorAction:
        val name = new_name.trim()
        if name == "":
            self.status_msg = "missing rename target"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val response = self._request_active_rename(name)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if response.result_json != "":
            return self._apply_workspace_edit_result(response.result_json, "rename")
        self.status_msg = "rename requested: " + name
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _rename_active_symbol_preview(new_name: text) -> EditorAction:
        val name = new_name.trim()
        if name == "":
            self.status_msg = "missing rename target"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val response = self._request_active_rename(name)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.pending_workspace_edit_json = ""
        self.pending_workspace_edit_title = "rename"
        if response.result_json != "":
            self._show_workspace_edit_preview(response.result_json, "rename")
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.lsp_result_panel = lsp_result_panel_pending("rename-preview", response.id)
        self._show_lsp_result_panel("rename preview requested: " + name)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _show_workspace_edit_preview(edit_json: text, title: text):
        self.pending_workspace_edit_json = edit_json
        self.pending_workspace_edit_title = title
        self.lsp_result_panel = lsp_result_panel_workspace_edit_preview(title, edit_json, 0)
        self._refresh_lsp_hover_popup("workspace-edit-preview")
        self._show_lsp_result_panel(title + " preview: " + self.lsp_result_panel.rows.len().to_text() + " edits")

    me _confirm_pending_workspace_edit() -> EditorAction:
        if self.pending_workspace_edit_json == "":
            self.status_msg = "no pending workspace edit"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val edit_json = self.pending_workspace_edit_json
        val title = self.pending_workspace_edit_title
        self.pending_workspace_edit_json = ""
        self.pending_workspace_edit_title = ""
        self._apply_workspace_edit_result(edit_json, title)

    me _cancel_pending_workspace_edit() -> EditorAction:
        if self.pending_workspace_edit_json == "":
            self.status_msg = "no pending workspace edit"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.pending_workspace_edit_json = ""
        self.pending_workspace_edit_title = ""
        self.lsp_result_panel = lsp_result_panel_new("LSP Results")
        self._refresh_lsp_hover_popup("workspace-edit-cancel")
        self._show_lsp_result_panel("workspace edit cancelled")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_active_call_hierarchy_direction(direction: text, item_json: text) -> EditorAction:
        val payload = item_json.trim()
        if payload == "":
            self.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val response = self._request_call_hierarchy_direction(direction, payload)
        if not response.ok:
            self.lsp_call_hierarchy_merge_index = -1
            self.lsp_call_hierarchy_merge_panel = lsp_result_panel_new("")
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val kind = if direction == "outgoing" then "call-hierarchy-outgoing" else: "call-hierarchy-incoming"
        self._set_lsp_result_panel_from_response(kind, response)
        self._refresh_lsp_hover_popup(kind)
        self._show_lsp_result_panel(kind + " results")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_selected_call_hierarchy_direction(direction: text) -> EditorAction:
        if self.lsp_result_panel.rows.len() == 0:
            self.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val row = self.lsp_result_panel.rows[self.lsp_result_panel.selected]
        if row.icon != "call":
            self.status_msg = "missing call hierarchy item"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if self.lsp_result_panel.title == "Call Hierarchy":
            self.lsp_call_hierarchy_merge_panel = self.lsp_result_panel
            self.lsp_call_hierarchy_merge_index = self.lsp_result_panel.selected
        return self._request_active_call_hierarchy_direction(direction, row.command_payload)

    me _request_active_code_lens_resolve(item_json: text) -> EditorAction:
        val payload = item_json.trim()
        if payload == "":
            self.status_msg = "missing code lens item"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val response = self._request_code_lens_resolve(payload)
        if not response.ok:
            self.status_msg = response.error_text
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.lsp_result_panel = lsp_result_panel_from_response("code-lens-resolve", response)
        self._refresh_lsp_hover_popup("code-lens-resolve")
        self._show_lsp_result_panel("code-lens-resolve results")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _run_selected_code_lens() -> EditorAction:
        val command_name = lsp_result_panel_target_command(self.lsp_result_panel)
        if command_name == "":
            self.status_msg = "no code lens command"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val payload = lsp_result_panel_target_command_payload(self.lsp_result_panel)
        val action = self._execute_palette_command(command_name, payload)
        if action.status_msg == "":
            self.status_msg = "ran code lens: " + command_name
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        action

    me _show_lsp_result_panel(message: text):
        var layout = self.session.dock_layout
        layout.show_right("lsp-panel")
        self.session.dock_layout = layout
        self.status_msg = message

    me _code_action_result_panel(request_id: i64) -> LspResultPanel:
        var rows: [LspResultRow] = []
        var i = 0
        while i < self.code_actions.len():
            val action = self.code_actions[i]
            var detail = action.kind
            if action.edit_json != "":
                detail = if detail == "" then "edit" else: detail + " edit"
            if action.command != "":
                detail = if detail == "" then "command" else: detail + " command"
            rows.push(LspResultRow(icon: "action", label: action.title, detail: detail, path: "", line: 0, col: 0, command_name: "quickfix-apply", command_payload: i.to_text(), depth: 0, expanded: false))
            i = i + 1
        if rows.len() == 0:
            rows.push(LspResultRow(icon: "empty", label: "No code actions", detail: "", path: "", line: 0, col: 0, command_name: "", command_payload: "", depth: 0, expanded: false))
        LspResultPanel(title: "Code Actions", rows: rows, selected: 0, scroll_offset: 0, pending: false, request_id: request_id)

    me _refresh_lsp_hover_popup(kind: text):
        val buffer = self.session.active_buffer()
        val line = if buffer == nil then 0 else: buffer.cursor_row_value()
        val col = if buffer == nil then 0 else: buffer.cursor_col_value()
        if kind == "hover":
            self.lsp_hover_popup = lsp_hover_popup_from_panel(self.lsp_result_panel, line, col)
        else:
            self.lsp_hover_popup = lsp_hover_popup_hidden()
        if kind == "signature-help":
            self.lsp_signature_popup = lsp_signature_popup_from_panel(self.lsp_result_panel, line, col)
        else:
            self.lsp_signature_popup = lsp_signature_popup_hidden()

    me _lsp_jump_selected() -> EditorAction:
        val path = lsp_result_panel_target_path(self.lsp_result_panel)
        if path == "":
            self.status_msg = "no lsp result target"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val line = lsp_result_panel_target_line(self.lsp_result_panel)
        val col = lsp_result_panel_target_col(self.lsp_result_panel)
        self._lsp_push_current_location()
        self.session.open_file(path)
        self._focus_lsp_target_path(path)
        val buffer = self.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(line, col)
            self.session.update_active_buffer(buffer)
        self.status_msg = "lsp jump: " + path + ":" + (line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _apply_selected_lsp_selection_range() -> EditorAction:
        if self.lsp_result_panel.rows.len() == 0:
            self.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if self.lsp_result_panel.selected < 0 or self.lsp_result_panel.selected >= self.lsp_result_panel.rows.len():
            self.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val row = self.lsp_result_panel.rows[self.lsp_result_panel.selected]
        if row.icon != "selection":
            self.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val end_line = _editor_parse_i64(_editor_payload_part(row.command_payload, 0), row.line)
        val end_col = _editor_parse_i64(_editor_payload_part(row.command_payload, 1), row.col)
        buffer.set_selection_range(row.line, row.col, end_line, end_col)
        buffer.move_cursor(row.line, row.col)
        self.session.update_active_buffer(buffer)
        self.status_msg = "selection range: " + (row.line + 1).to_text() + ":" + (row.col + 1).to_text() + "-" + (end_line + 1).to_text() + ":" + (end_col + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _expand_lsp_selection_range() -> EditorAction:
        if self.lsp_result_panel.title == "Selection Ranges" and self.lsp_result_panel.rows.len() > 0:
            val buffer = self.session.active_buffer()
            if buffer != nil and buffer.has_active_selection_range() and self.lsp_result_panel.selected < self.lsp_result_panel.rows.len() - 1:
                self.lsp_result_panel = lsp_result_panel_select(self.lsp_result_panel, self.lsp_result_panel.selected + 1)
            return self._apply_selected_lsp_selection_range()
        return self._request_active_lsp_action("selection-ranges")

    me _shrink_lsp_selection_range() -> EditorAction:
        if self.lsp_result_panel.title != "Selection Ranges" or self.lsp_result_panel.rows.len() == 0:
            self.status_msg = "no selection range"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if self.lsp_result_panel.selected > 0:
            self.lsp_result_panel = lsp_result_panel_select(self.lsp_result_panel, self.lsp_result_panel.selected - 1)
        return self._apply_selected_lsp_selection_range()

    me _lsp_push_current_location():
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return
        self.lsp_location_stack.push(EditorLocation(path: doc.path(), line: buffer.cursor_row_value(), col: buffer.cursor_col_value()))

    me _lsp_back() -> EditorAction:
        if self.lsp_location_stack.len() == 0:
            self.status_msg = "lsp location stack empty"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val location = self.lsp_location_stack[self.lsp_location_stack.len() - 1]
        var next_stack: [EditorLocation] = []
        var i = 0
        while i < self.lsp_location_stack.len() - 1:
            next_stack.push(self.lsp_location_stack[i])
            i = i + 1
        self.lsp_location_stack = next_stack
        self.session.open_file(location.path)
        self._focus_lsp_target_path(location.path)
        val buffer = self.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(location.line, location.col)
            self.session.update_active_buffer(buffer)
        self.status_msg = "lsp back: " + location.path + ":" + (location.line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _open_markdown_link_under_cursor() -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "not a markdown file"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val content = md_buffer_content(buffer)
        val raw_target = md_vim_open_link_under_cursor(content, buffer.cursor_row_value(), buffer.cursor_col_value())
        if raw_target == "":
            self.status_msg = "no link under cursor"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self._open_markdown_link_target(raw_target)

    me _open_markdown_link_target(raw_target: text) -> EditorAction:
        val doc = self.session.active_document()
        if doc == nil or doc.language_id != "markdown":
            self.status_msg = "not a markdown file"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if raw_target.starts_with("http://") or raw_target.starts_with("https://"):
            self.status_msg = _editor_open_external_url_status(raw_target)
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val path = _editor_resolve_markdown_link_path(raw_target, doc.path(), self.session)
        if path == "":
            self.status_msg = "unresolved link: " + raw_target
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val parsed_target = md_wiki_parse_link_target(raw_target.trim())
        val title = parsed_target.0.trim()
        val should_create = _editor_markdown_link_should_create_note(raw_target, path)
        if should_create:
            val heading = if title == "" then md_wiki_title_from_path(path) else: title
            val note_content = "# " + heading + "\n\n"
            val written = rt_file_write_text(path, note_content)
            if not written:
                self.status_msg = "failed to create note: " + path
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            self.vault_search_index = md_vault_search_index_apply_file_change(self.vault_search_index, path, note_content, 1)
        self.session.open_file(path)
        self._focus_lsp_target_path(path)
        self.status_msg = if should_create then "created note: " + path else: "opened link: " + path
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _focus_lsp_target_doc(doc_id: EditorDocumentId):
        var layout = self.session.layout
        val group_idx = editor_layout_active_group_index(layout)
        if group_idx < 0 or group_idx >= editor_layout_group_count_raw(layout):
            return
        var group = editor_layout_group_at(layout, group_idx)
        if group.select_matching_doc(doc_id):
            layout = editor_layout_with_group(layout, group_idx, group)
            self.session.layout = layout
            return

    me _focus_lsp_target_path(path: text):
        var i = 0
        while i < self.session.documents.len():
            if self.session.documents[i].path() == path:
                self._focus_lsp_target_doc(self.session.documents[i].id)
                return
            i = i + 1

    me _dispatch_lsp_result_key(key: text) -> EditorAction:
        if key == "j":
            self.lsp_result_panel = lsp_result_panel_select(self.lsp_result_panel, self.lsp_result_panel.selected + 1)
            self.status_msg = "lsp result selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "k":
            self.lsp_result_panel = lsp_result_panel_select(self.lsp_result_panel, self.lsp_result_panel.selected - 1)
            self.status_msg = "lsp result selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "i":
            return self._request_selected_call_hierarchy_direction("incoming")
        if key == "o":
            return self._request_selected_call_hierarchy_direction("outgoing")
        if key == " " or key == "h" or key == "l":
            if self.lsp_result_panel.rows.len() == 0:
                return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)
            val before = self.lsp_result_panel.rows[self.lsp_result_panel.selected]
            if key == " " and self.lsp_result_panel.title == "Call Hierarchy" and before.icon == "call" and not before.expanded:
                return self._request_selected_call_hierarchy_direction("incoming")
            self.lsp_result_panel = lsp_result_panel_toggle_expanded(self.lsp_result_panel)
            self.lsp_call_hierarchy_state = lsp_result_panel_call_state(self.lsp_result_panel)
            self.lsp_call_hierarchy_state_title = self.lsp_result_panel.title
            val row = self.lsp_result_panel.rows[self.lsp_result_panel.selected]
            self.status_msg = if row.expanded then "lsp result expanded" else: "lsp result collapsed"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\r" or key == "\n":
            if self.lsp_result_panel.title == "Selection Ranges":
                return self._apply_selected_lsp_selection_range()
            if self.lsp_result_panel.title == "Code Actions":
                return self._apply_code_action_at(self.lsp_result_panel.selected)
            return self._lsp_jump_selected()
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _dispatch_wiki_panel_key(key: text) -> EditorAction:
        if key == "j":
            self.wiki_panel = wiki_panel_select(self.wiki_panel, self.wiki_panel.selected + 1)
            self.status_msg = "wiki result selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "k":
            self.wiki_panel = wiki_panel_select(self.wiki_panel, self.wiki_panel.selected - 1)
            self.status_msg = "wiki result selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\r" or key == "\n":
            return self._wiki_jump_selected()
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _wiki_jump_selected() -> EditorAction:
        if self.wiki_panel.title == "Debug Launch Configs":
            return self._debug_start_selected_launch_config()
        if self.wiki_panel.title == "Debug Sessions":
            return self._debug_switch_selected_session()
        if self.wiki_panel.title == "Templates":
            if self.wiki_panel.rows.len() == 0:
                self.status_msg = "no template target"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            return self._wiki_template_insert(self.wiki_panel.rows[self.wiki_panel.selected].detail)
        if self.wiki_panel.title == "Daily Notes":
            if self.wiki_panel.rows.len() == 0:
                self.status_msg = "no daily note target"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            return self._wiki_daily_note_create(self.wiki_panel.rows[self.wiki_panel.selected].detail)
        if self.wiki_panel.title == "Attachment Picker":
            if self.wiki_panel.rows.len() == 0:
                self.status_msg = "no attachment target"
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
            val picked_payload = self.wiki_panel.rows[self.wiki_panel.selected].detail
            if _editor_payload_part(picked_payload, 1) != "":
                return self._wiki_attachment_insert(picked_payload)
        val path = wiki_panel_target_path(self.wiki_panel)
        if path == "":
            self.status_msg = "no wiki result target"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val line = wiki_panel_target_line(self.wiki_panel)
        self.session.open_file(path)
        self._focus_lsp_target_path(path)
        val buffer = self.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(line, 0)
            self.session.update_active_buffer(buffer)
        self.status_msg = "wiki jump: " + path + ":" + (line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _dispatch_diagnostics_panel_key(key: text) -> EditorAction:
        if key == "j":
            self.diagnostics_panel = diagnostics_panel_select(self.diagnostics_panel, self.diagnostics_panel.selected + 1)
            self.status_msg = "problem selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "k":
            self.diagnostics_panel = diagnostics_panel_select(self.diagnostics_panel, self.diagnostics_panel.selected - 1)
            self.status_msg = "problem selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\r" or key == "\n":
            return self._diagnostics_jump_selected()
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _dispatch_md_outline_key(key: text) -> EditorAction:
        val doc = self.session.active_document()
        if doc == nil or not doc.has_markdown_state():
            return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)
        var outline = doc.md_state.outline
        if key == "j":
            outline = outline_panel_navigate(outline, 1)
            var md_state = doc.md_state
            md_state.outline = outline
            doc.md_state = md_state
            self.session.update_active_document(doc)
            self.status_msg = "outline selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "k":
            outline = outline_panel_navigate(outline, -1)
            var md_state = doc.md_state
            md_state.outline = outline
            doc.md_state = md_state
            self.session.update_active_document(doc)
            self.status_msg = "outline selected"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        if key == "\r" or key == "\n":
            val line = outline_panel_target_line(outline)
            doc.buffer.move_cursor(line, 0)
            doc.buffer.cursor_row = line
            doc.buffer.cursor_col = 0
            self.session.update_active_document(doc)
            self.status_msg = "outline jump: " + (line + 1).to_text()
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _diagnostics_jump_selected() -> EditorAction:
        val path = diagnostics_panel_target_path(self.diagnostics_panel)
        if path == "":
            self.status_msg = "no problem target"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val line = diagnostics_panel_target_line(self.diagnostics_panel)
        val col = diagnostics_panel_target_col(self.diagnostics_panel)
        self.session.open_file(path)
        self._focus_lsp_target_path(path)
        val buffer = self.session.active_buffer()
        if buffer != nil:
            buffer.move_cursor(line, col)
            self.session.update_active_buffer(buffer)
        self.status_msg = "problem jump: " + path + ":" + (line + 1).to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _request_active_completion() -> LspResponse:
        self._request_active_lsp("completion")

    me _request_active_hover() -> LspResponse:
        self._request_active_lsp("hover")

    me _request_active_definition() -> LspResponse:
        self._request_active_lsp("definition")

    me _request_active_code_action() -> LspResponse:
        self._request_active_lsp("code-action")

    me _notify_lsp_file_changed(path: text, change_type: i64) -> EditorAction:
        self.vault_search_index = md_vault_search_index_apply_file_change(self.vault_search_index, path, rt_file_read_text(path) ?? "", change_type)
        var notified = false
        if self.md_lsp_state.running:
            self.md_lsp_state = md_lsp_notify_watched_file(self.md_lsp_state, path, change_type)
            notified = true
        if self.simple_lsp_state.running:
            self.simple_lsp_state = simple_lsp_notify_watched_file(self.simple_lsp_state, path, change_type)
            notified = true
        if notified:
            self.status_msg = "lsp file change notified"
        else:
            self.status_msg = "no active language server"
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _refresh_open_document_from_disk_batch(path: text, content: text):
        var docs: [EditorDocument] = []
        var i = 0
        while i < self.session.documents.len():
            var doc = self.session.documents[i]
            if doc.path() == path:
                var buffer = doc.buffer
                buffer.replace_content(content)
                buffer.dirty = false
                doc.buffer = buffer
                if doc.language_id == "markdown":
                    md_update_preview(doc, buffer)
            docs.push(doc)
            i = i + 1
        self.session.documents = docs

    me _notify_lsp_workspace_folder(path: text, name: text, added: bool) -> EditorAction:
        var notified = false
        if self.md_lsp_state.running:
            self.md_lsp_state = md_lsp_notify_workspace_folder(self.md_lsp_state, path, name, added)
            notified = true
        if self.simple_lsp_state.running:
            self.simple_lsp_state = simple_lsp_notify_workspace_folder(self.simple_lsp_state, path, name, added)
            notified = true
        if notified:
            self.status_msg = "lsp workspace folder notified"
        else:
            self.status_msg = "no active language server"
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _request_active_rename(new_name: text) -> LspResponse:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            if not self.md_lsp_state.running:
                self._start_markdown_lsp_for_active(doc.path(), content)
            val result = md_lsp_request(self.md_lsp_state, "rename", new_name, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.md_lsp_state = result.0
            return result.1
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not self.simple_lsp_state.running:
                self._start_simple_lsp_for_active(doc.path(), content)
            val simple_result = simple_lsp_request(self.simple_lsp_state, "rename", new_name, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.simple_lsp_state = simple_result.0
            return simple_result.1
        LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

    me _request_call_hierarchy_direction(direction: text, item_json: text) -> LspResponse:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val content = md_buffer_content(buffer)
        val request_kind = if direction == "outgoing" then "call-hierarchy-outgoing" else: "call-hierarchy-incoming"
        if doc.language_id == "markdown":
            if not self.md_lsp_state.running:
                self._start_markdown_lsp_for_active(doc.path(), content)
            val result = md_lsp_request(self.md_lsp_state, request_kind, item_json, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.md_lsp_state = result.0
            return result.1
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not self.simple_lsp_state.running:
                self._start_simple_lsp_for_active(doc.path(), content)
            val simple_result = simple_lsp_request(self.simple_lsp_state, request_kind, item_json, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.simple_lsp_state = simple_result.0
            return simple_result.1
        LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

    me _request_code_lens_resolve(item_json: text) -> LspResponse:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            if not self.md_lsp_state.running:
                self._start_markdown_lsp_for_active(doc.path(), content)
            val result = md_lsp_request(self.md_lsp_state, "code-lens-resolve", item_json, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.md_lsp_state = result.0
            return result.1
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not self.simple_lsp_state.running:
                self._start_simple_lsp_for_active(doc.path(), content)
            val simple_result = simple_lsp_request(self.simple_lsp_state, "code-lens-resolve", item_json, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.simple_lsp_state = simple_result.0
            return simple_result.1
        LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

    me _request_active_lsp(kind: text) -> LspResponse:
        self._request_active_lsp_with_payload(kind, "")

    me _request_active_lsp_with_payload(kind: text, payload: text) -> LspResponse:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return LspResponse(id: 0, ok: false, result_json: "", error_text: "no file open")
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            if not self.md_lsp_state.running:
                self._start_markdown_lsp_for_active(doc.path(), content)
            val result = md_lsp_request(self.md_lsp_state, kind, payload, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.md_lsp_state = result.0
            return result.1
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not self.simple_lsp_state.running:
                self._start_simple_lsp_for_active(doc.path(), content)
            val simple_result = simple_lsp_request(self.simple_lsp_state, kind, payload, doc.path(), buffer.cursor_row_value(), buffer.cursor_col_value())
            self.simple_lsp_state = simple_result.0
            return simple_result.1
        LspResponse(id: 0, ok: false, result_json: "", error_text: "no active language server")

    me _execute_markdown_extension_command(command_name: text) -> EditorAction:
        if command_name == "markdown.foldAll":
            return self._fold_all_active_document()
        if command_name == "markdown.unfoldAll":
            return self._unfold_all_active_document()
        if command_name.starts_with("markdown."):
            val doc = self.session.active_document()
            val buffer = self.session.active_buffer()
            if doc != nil and doc.has_markdown_state() and buffer != nil:
                val content = md_buffer_content(buffer)
                val cmd_result: MdCommandResult = md_commands_dispatch(command_name, doc.markdown_state(), content, buffer.cursor_row_value(), buffer.cursor_col_value())
                val command_state: MdEditorState = md_command_result_state(cmd_result)
                doc.set_markdown_state(command_state)
                md_apply_result(buffer, cmd_result)
                val preview_visible = md_editor_state_preview_visible(command_state)
                val outline_visible = md_editor_state_outline_visible(command_state)
                if preview_visible:
                    self.session.dock_layout.show_right("md-preview")
                elif outline_visible:
                    self.session.dock_layout.show_right("md-outline")
                else:
                    if not preview_visible and not outline_visible:
                        self.session.dock_layout.hide_right()
                self.status_msg = cmd_result.status_message
                self.session.update_active_document(doc)
                return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "markdown command unavailable"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _fold_all_active_document() -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.clear_folds()
        var folded_count = 0
        var line = 0
        while line < buffer.line_count():
            val level = _editor_markdown_heading_level(buffer.line_at(line))
            if level > 0:
                var end_line = buffer.line_count() - 1
                var scan = line + 1
                while scan < buffer.line_count():
                    val scan_level = _editor_markdown_heading_level(buffer.line_at(scan))
                    if scan_level > 0 and scan_level <= level:
                        end_line = scan - 1
                        scan = buffer.line_count()
                    else:
                        scan = scan + 1
                if end_line > line:
                    buffer.fold_range(line, end_line)
                    folded_count = folded_count + 1
            line = line + 1
        self.session.update_active_buffer(buffer)
        self.status_msg = "folded " + folded_count.to_text() + " ranges"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _unfold_all_active_document() -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.clear_folds()
        self.session.update_active_buffer(buffer)
        self.status_msg = "unfolded all"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _toggle_active_markdown_fold() -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val content = md_buffer_content(buffer)
        val range = md_vim_toggle_fold_heading(content, buffer.cursor_row_value())
        val start_line = range.0
        val end_line = range.1
        if end_line <= start_line:
            self.status_msg = "no foldable section"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.toggle_fold_range(start_line, end_line)
        val folded = buffer.has_fold_range(start_line, end_line)
        self.session.update_active_buffer(buffer)
        self.status_msg = if folded then "folded section" else: "unfolded section"
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _activate_active_language():
        val doc = self.session.active_document()
        if doc == nil:
            return
        self.extension_host.activate_language(doc.language_id)
        self.extension_host.emit_event("onDidOpenTextDocument", doc.path())
        self.extension_host.emit_event("onLanguage:" + doc.language_id, doc.path())
        val buffer = self.session.active_buffer()
        if buffer == nil:
            return
        val content = md_buffer_content(buffer)
        if doc.language_id == "markdown":
            self._start_markdown_lsp_for_active(doc.path(), content)
        elif doc.language_id == "simple" or doc.language_id == "shell":
            self._start_simple_lsp_for_active(doc.path(), content)
        self.file_watcher.watch(doc.path())
        self.file_watcher.watch_parent_directory(doc.path())
        self._poll_lsp_diagnostics()

    me _poll_file_watcher() -> EditorAction:
        val events = self.file_watcher.check_events()
        if events.len() == 0:
            return EditorAction(redraw: false, quit: false, status_msg: self.status_msg)
        var i = 0
        while i < events.len():
            val event = events[i]
            val path = event.path
            val content = rt_file_read_text(path) ?? ""
            if event.change_type != 3:
                self._refresh_open_document_from_disk_batch(path, content)
            self._notify_lsp_file_changed(path, event.change_type)
            i = i + 1
        self.status_msg = "file changes notified: " + events.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _notify_active_lsp_changed():
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil:
            return
        val should_refresh_inlay_hints = buffer.has_inlay_hints() or self.lsp_result_panel.title == "Inlay Hints"
        val content = md_buffer_content(buffer)
        buffer.clear_inlay_hints()
        buffer.clear_semantic_tokens()
        buffer.clear_code_lenses()
        self.session.update_active_buffer(buffer)
        self.diagnostic_store.clear_diagnostics(doc.path())
        if self.session.dock_layout.active_right_panel() == "problems":
            self._refresh_diagnostics_panel_view()
        if doc.language_id == "markdown" and self.md_lsp_state.running:
            self.md_lsp_state = md_lsp_change_active(self.md_lsp_state, doc.path(), content)
        elif (doc.language_id == "simple" or doc.language_id == "shell") and self.simple_lsp_state.running:
            self.simple_lsp_state = simple_lsp_change_active(self.simple_lsp_state, doc.path(), content)
        if should_refresh_inlay_hints:
            self._refresh_active_inlay_hints_after_change()
        self._poll_lsp_diagnostics()

    me _refresh_active_inlay_hints_after_change():
        val response = self._request_active_lsp("inlay-hints")
        if not response.ok:
            return
        self.lsp_result_panel = lsp_result_panel_from_response("inlay-hints", response)
        if response.result_json != "":
            self._apply_lsp_inlay_hints_result(response.result_json)

    me _start_markdown_lsp_for_active(path: text, content: text):
        if not md_lsp_is_markdown_file(path):
            return
        self.md_lsp_state = md_lsp_ensure_open(self.md_lsp_state, path, content)

    me _start_simple_lsp_for_active(path: text, content: text):
        if not simple_lsp_is_simple_file(path):
            return
        self.simple_lsp_state = simple_lsp_ensure_open(self.simple_lsp_state, path, content)

    me _poll_lsp_diagnostics():
        var changed = false
        if self.md_lsp_state.running:
            val md_result = md_lsp_poll_all_notifications(self.md_lsp_state)
            self.md_lsp_state = md_result.0
            val md_notifications = md_result.1
            for n in md_notifications:
                if n.method == "textDocument/publishDiagnostics":
                    self.diagnostic_store = diagnostics_store_with_publish(self.diagnostic_store, n.params_json)
                    changed = true
        if self.simple_lsp_state.running:
            val simple_result = simple_lsp_poll_all_notifications(self.simple_lsp_state)
            self.simple_lsp_state = simple_result.0
            val simple_notifications = simple_result.1
            for sn in simple_notifications:
                if sn.method == "textDocument/publishDiagnostics":
                    self.diagnostic_store = diagnostics_store_with_publish(self.diagnostic_store, sn.params_json)
                    changed = true
        if changed:
            self._refresh_diagnostics_panel_view()

    me _poll_lsp_results() -> EditorAction:
        val updated = self._refresh_lsp_results()
        if updated:
            self.status_msg = "lsp results updated"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.status_msg = "no lsp results"
        EditorAction(redraw: false, quit: false, status_msg: self.status_msg)

    me _refresh_lsp_results() -> bool:
        var updated = false
        val md_result = md_lsp_poll_all_responses(self.md_lsp_state)
        self.md_lsp_state = md_result.0
        val md_responses = md_result.1
        for response in md_responses:
            if self._hydrate_lsp_result_response(response):
                updated = true
        val simple_result = simple_lsp_poll_all_responses(self.simple_lsp_state)
        self.simple_lsp_state = simple_result.0
        val simple_responses = simple_result.1
        for simple_response in simple_responses:
            if self._hydrate_lsp_result_response(simple_response):
                updated = true
        updated

    me _hydrate_lsp_result_json(method: text, json: text) -> bool:
        val response = lsp_response_from_json(json)
        if not self.lsp_result_panel.pending:
            return false
        if response.id != self.lsp_result_panel.request_id:
            return false
        val kind = _editor_lsp_method_to_kind(method)
        if not _editor_lsp_kind_has_panel(kind):
            return false
        self._set_lsp_result_panel_from_response(kind, response)
        if kind == "folding-ranges" and response.ok and response.result_json != "":
            self._apply_lsp_folding_ranges_result(response.result_json)
        if kind == "inlay-hints" and response.ok and response.result_json != "":
            self._apply_lsp_inlay_hints_result(response.result_json)
        if kind == "semantic-tokens" and response.ok and response.result_json != "":
            self._apply_lsp_semantic_tokens_result(response.result_json)
        if (kind == "code-lens" or kind == "code-lens-resolve") and response.ok and response.result_json != "":
            self._apply_lsp_code_lens_panel()
        if kind == "document-symbols" and response.ok and response.result_json != "":
            self._apply_lsp_document_symbols_outline()
        self._refresh_lsp_hover_popup(kind)
        not self.lsp_result_panel.pending

    me _hydrate_lsp_result_response(completed: LspCompletedResponse) -> bool:
        if completed.method == "textDocument/rename":
            var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
            if response.result_json == "" and completed.raw_json != "":
                response = lsp_response_from_json(completed.raw_json)
            if not response.ok:
                self.status_msg = response.error_text
                return true
            if response.result_json == "":
                return false
            if self.lsp_result_panel.pending and self.lsp_result_panel.request_id == completed.id and self.lsp_result_panel.title == "Rename Preview":
                self._show_workspace_edit_preview(response.result_json, "rename")
                return true
            self._apply_workspace_edit_result(response.result_json, "rename")
            return true
        if completed.method == "textDocument/formatting" or completed.method == "textDocument/rangeFormatting":
            var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
            if response.result_json == "" and completed.raw_json != "":
                response = lsp_response_from_json(completed.raw_json)
            if not response.ok:
                self.status_msg = response.error_text
                return true
            if response.result_json == "":
                return false
            val title = if completed.method == "textDocument/rangeFormatting" then "range formatting" else: "formatting"
            val preview_title = if completed.method == "textDocument/rangeFormatting" then "Range Formatting Preview" else: "Formatting Preview"
            if self.lsp_result_panel.pending and self.lsp_result_panel.request_id == completed.id and self.lsp_result_panel.title == preview_title:
                self._show_workspace_edit_preview(response.result_json, title)
                return true
            if self.format_save_request_id == completed.id:
                self._apply_workspace_edit_result(response.result_json, title)
                self.format_save_request_id = 0
                self.format_save_title = ""
                self._save_active_after_format(title)
                return true
            self._apply_workspace_edit_result(response.result_json, title)
            return true
        if not self.lsp_result_panel.pending:
            return false
        if completed.id != self.lsp_result_panel.request_id:
            return false
        val kind = _editor_lsp_method_to_kind(completed.method)
        if not _editor_lsp_kind_has_panel(kind):
            return false
        var response = LspResponse(id: completed.id, ok: completed.ok, result_json: completed.result_json, error_text: completed.error_text)
        if response.result_json == "" and completed.raw_json != "":
            response = lsp_response_from_json(completed.raw_json)
        self._set_lsp_result_panel_from_response(kind, response)
        if kind == "folding-ranges" and response.ok and response.result_json != "":
            self._apply_lsp_folding_ranges_result(response.result_json)
        if kind == "inlay-hints" and response.ok and response.result_json != "":
            self._apply_lsp_inlay_hints_result(response.result_json)
        if kind == "semantic-tokens" and response.ok and response.result_json != "":
            self._apply_lsp_semantic_tokens_result(response.result_json)
        if (kind == "code-lens" or kind == "code-lens-resolve") and response.ok and response.result_json != "":
            self._apply_lsp_code_lens_panel()
        if kind == "document-symbols" and response.ok and response.result_json != "":
            self._apply_lsp_document_symbols_outline()
        self._refresh_lsp_hover_popup(kind)
        true

    me _apply_lsp_document_symbols_outline():
        val active_id = self.session.active_doc_id()
        var docs: [EditorDocument] = []
        var changed = false
        var i = 0
        while i < self.session.documents.len():
            var doc = self.session.documents[i]
            if doc.doc_id().int_value() == active_id.int_value() and doc.has_markdown_state():
                var entries: [OutlineEntry] = []
                for row in self.lsp_result_panel.rows:
                    if row.icon == "symbol":
                        val level = if row.depth > 0 then row.depth + 1 else: 1
                        entries.push(OutlineEntry(level: level, title: row.label, line: row.line))
                if entries.len() > 0:
                    doc.set_markdown_outline_entries(entries)
                    changed = true
            docs.push(doc)
            i = i + 1
        if changed:
            self.session.documents = docs
            return

    me _apply_lsp_folding_ranges_result(result_json: text):
        val buffer = self.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_folds()
        var cursor = 0
        while cursor < result_json.len():
            val slice = result_json.slice(cursor, result_json.len())
            val relative = _editor_find_text(slice, "\"startLine\"")
            if relative < 0:
                self.session.update_active_buffer(buffer)
                return
            val range_json = result_json.slice(cursor + relative, result_json.len())
            val start_line = _editor_json_number_field(range_json, "\"startLine\"")
            val end_line = _editor_json_number_field(range_json, "\"endLine\"")
            buffer.fold_range(start_line, end_line)
            cursor = cursor + relative + 11
        self.session.update_active_buffer(buffer)

    me _apply_lsp_semantic_tokens_result(result_json: text):
        val buffer = self.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_semantic_tokens()
        val data = _editor_json_numbers_in_array_field(result_json, "\"data\"")
        var i = 0
        var line = 0
        var col = 0
        while i + 4 < data.len():
            val delta_line = data[i]
            val delta_start = data[i + 1]
            val length = data[i + 2]
            val token_type = data[i + 3]
            line = line + delta_line
            if delta_line == 0:
                col = col + delta_start
            else:
                col = delta_start
            buffer.add_semantic_token(line, col, length, token_type)
            i = i + 5
        self.session.update_active_buffer(buffer)

    me _apply_lsp_inlay_hints_result(result_json: text):
        val buffer = self.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_inlay_hints()
        var cursor = 0
        while cursor < result_json.len():
            val slice = result_json.slice(cursor, result_json.len())
            val relative = _editor_find_text(slice, "\"position\"")
            if relative < 0:
                self.session.update_active_buffer(buffer)
                return
            val hint_json = result_json.slice(cursor + relative, result_json.len())
            val line = _editor_json_number_field(hint_json, "\"line\"")
            val col = _editor_json_number_field(hint_json, "\"character\"")
            val label = _editor_json_string_field(hint_json, "\"label\"")
            buffer.add_inlay_hint(line, col, label)
            cursor = cursor + relative + 10
        self.session.update_active_buffer(buffer)

    me _apply_lsp_code_lens_panel():
        val buffer = self.session.active_buffer()
        if buffer == nil:
            return
        buffer.clear_code_lenses()
        for row in self.lsp_result_panel.rows:
            if row.icon == "lens":
                buffer.add_code_lens(row.line, row.label, row.command_name, row.command_payload)
        self.session.update_active_buffer(buffer)

    me _apply_workspace_edit_result(edit_json: text, title: text) -> EditorAction:
        val buffer = self.session.active_buffer()
        if buffer == nil:
            self.status_msg = "no file open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val doc = self.session.active_document()
        val doc_path = if doc == nil then "" else: doc.path()
        val applied = _editor_apply_code_action_content(buffer, doc_path, edit_json)
        if not applied.applied:
            self.status_msg = title + " has no editable change"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val extra_file_edits = if edit_json.contains("\"changes\"") then self._apply_workspace_edit_extra_paths(doc_path, edit_json) else: 0
        buffer.push_undo_snapshot()
        buffer.replace_content(applied.content)
        buffer.dirty = true
        buffer.move_cursor(applied.line, applied.col)
        self.session.update_active_buffer(buffer)
        self._replace_open_document_buffer(doc_path, buffer)
        if doc != nil and doc.language_id == "markdown":
            self._update_markdown_preview(doc, buffer)
        if extra_file_edits > 0:
            self.status_msg = "applied: " + title + " (" + extra_file_edits.to_text() + " file edits)"
        else:
            self.status_msg = "applied: " + title
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _apply_workspace_edit_extra_paths(active_path: text, edit_json: text) -> i64:
        var applied_count = 0
        val paths = _editor_workspace_edit_paths(edit_json)
        var docs: [EditorDocument] = []
        for path in paths:
            if path != "" and path != active_path:
                var applied_open = false
                docs = []
                var i = 0
                while i < self.session.documents.len():
                    var doc = self.session.documents[i]
                    if doc.path() == path:
                        var open_buffer = doc.buffer
                        val open_applied = _editor_apply_workspace_edit_content(open_buffer, path, edit_json)
                        if open_applied.applied:
                            open_buffer.push_undo_snapshot()
                            open_buffer.replace_content(open_applied.content)
                            open_buffer.dirty = true
                            open_buffer.move_cursor(open_applied.line, open_applied.col)
                            doc.buffer = open_buffer
                            if doc.language_id == "markdown":
                                md_update_preview(doc, open_buffer)
                            applied_open = true
                    docs.push(doc)
                    i = i + 1
                if applied_open:
                    self.session.documents = docs
                    applied_count = applied_count + 1
                else:
                    val existing = rt_file_read_text(path) ?? ""
                    var disk_buffer = EditorBuffer.from_text(EditorBufferId(value: 0), existing)
                    disk_buffer.path = path
                    val disk_applied = _editor_apply_workspace_edit_content(disk_buffer, path, edit_json)
                    if disk_applied.applied and rt_file_write_text(path, disk_applied.content):
                        applied_count = applied_count + 1
        applied_count

    me _replace_open_document_buffer(path: text, buffer: EditorBuffer):
        if path == "":
            return
        var docs: [EditorDocument] = []
        var i = 0
        while i < self.session.documents.len():
            var doc = self.session.documents[i]
            if doc.path() == path:
                doc.buffer = buffer
            docs.push(doc)
            i = i + 1
        self.session.documents = docs

    me _execute_lsp_code_action_command(command_json: text) -> bool:
        val params = _editor_lsp_execute_command_params(command_json)
        if params == "":
            return false
        val doc = self.session.active_document()
        if doc == nil:
            return false
        if doc.language_id == "markdown":
            if not self.md_lsp_state.running:
                val buffer = self.session.active_buffer()
                val content = if buffer == nil then "" else: md_buffer_content(buffer)
                self._start_markdown_lsp_for_active(doc.path(), content)
            val result = md_lsp_request(self.md_lsp_state, "execute-command", params, doc.path(), 0, 0)
            self.md_lsp_state = result.0
            return result.1.ok
        if doc.language_id == "simple" or doc.language_id == "shell":
            if not self.simple_lsp_state.running:
                val buffer = self.session.active_buffer()
                val content = if buffer == nil then "" else: md_buffer_content(buffer)
                self._start_simple_lsp_for_active(doc.path(), content)
            val simple_result = simple_lsp_request(self.simple_lsp_state, "execute-command", params, doc.path(), 0, 0)
            self.simple_lsp_state = simple_result.0
            return simple_result.1.ok
        false

    me _update_markdown_preview(doc: EditorDocument, buffer: EditorBuffer):
        val index = self._wiki_index_open_documents()
        md_update_preview_with_wiki(doc, buffer, index)

    me _toggle_md_preview():
        val doc = self.session.active_document()
        if doc == nil or not doc.has_markdown_state():
            self.status_msg = "not a markdown file"
            return
        val visible = doc.toggle_markdown_preview()
        if visible:
            val buffer = self.session.active_buffer()
            if buffer != nil:
                self._update_markdown_preview(doc, buffer)
            self.session.dock_layout.show_right("md-preview")
            self.status_msg = "preview on"
        else:
            if not doc.markdown_outline_visible():
                self.session.dock_layout.hide_right()
            self.status_msg = "preview off"
        self.session.update_active_document(doc)

    me _toggle_md_outline():
        val doc = self.session.active_document()
        if doc == nil or not doc.has_markdown_state():
            self.status_msg = "not a markdown file"
            return
        val buffer = self.session.active_buffer()
        val content = if buffer == nil then "" else: md_buffer_content(buffer)
        val visible = doc.toggle_markdown_outline(content)
        if visible:
            var layout = self.session.dock_layout
            layout.show_right("md-outline")
            self.session.dock_layout = layout
            self.status_msg = "outline on"
        else:
            if not doc.markdown_preview_visible():
                var layout = self.session.dock_layout
                layout.hide_right()
                self.session.dock_layout = layout
            self.status_msg = "outline off"
        self.session.update_active_document(doc)


fn ctrl_handle_normal_key(buffer: EditorBuffer, key: text) -> NormalKeyResult:
    if key == "q":
        return NormalKeyResult(message: "quit", quit: true, enter_insert: false, enter_command: false)
    if key == "i":
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == "a":
        buffer.move_relative(0, 1)
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == "o":
        buffer.move_to_line_end()
        buffer.insert_at_cursor("\n")
        return NormalKeyResult(message: "-- INSERT --", quit: false, enter_insert: true, enter_command: false)
    if key == ":":
        return NormalKeyResult(message: "", quit: false, enter_insert: false, enter_command: true)
    if key == "h":
        val result = editor_dispatch(buffer, editor_cmd("move-left"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "j":
        val result = editor_dispatch(buffer, editor_cmd("move-down"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "k":
        val result = editor_dispatch(buffer, editor_cmd("move-up"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "l":
        val result = editor_dispatch(buffer, editor_cmd("move-right"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "0":
        buffer.move_to_line_start()
        return NormalKeyResult(message: "home", quit: false, enter_insert: false, enter_command: false)
    if key == "$":
        buffer.move_to_line_end()
        return NormalKeyResult(message: "end", quit: false, enter_insert: false, enter_command: false)
    if key == "G":
        buffer.move_cursor(buffer.line_count() - 1, 0)
        return NormalKeyResult(message: "bottom", quit: false, enter_insert: false, enter_command: false)
    if key == "g":
        buffer.move_cursor(0, 0)
        return NormalKeyResult(message: "top", quit: false, enter_insert: false, enter_command: false)
    if key == "x":
        val result = editor_dispatch(buffer, editor_cmd("delete"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "u":
        val result = editor_dispatch(buffer, editor_cmd("undo"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    if key == "\x12":
        val result = editor_dispatch(buffer, editor_cmd("redo"))
        return NormalKeyResult(message: result.message, quit: false, enter_insert: false, enter_command: false)
    NormalKeyResult(message: "", quit: false, enter_insert: false, enter_command: false)

fn editor_extension_roots() -> [text]:
    var roots: [text] = []
    roots.push(".simple/editor/extensions")
    roots.push(".vscode/simple-editor/extensions")
    val configured = rt_env_get("SIMPLE_EDITOR_EXTENSION_PATH") ?? ""
    val configured_roots = _editor_split_path_list(configured)
    for root in configured_roots:
        roots.push(root)
    val home = rt_env_get("HOME") ?? ""
    if home != "":
        roots.push(home + "/.simple/editor/extensions")
        roots.push(home + "/.simple/extensions")
    roots.push("/usr/local/share/simple/editor/extensions")
    roots.push("/usr/share/simple/editor/extensions")
    roots

fn _editor_split_path_list(value: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    while i < value.len():
        if value.char_at(i) == ":":
            val part = value.slice(start, i).trim()
            if part != "":
                parts.push(part)
            start = i + 1
        i = i + 1
    val last = value.slice(start, value.len()).trim()
    if last != "":
        parts.push(last)
    parts

fn _editor_markdown_quickfix_line(line: text) -> text:
    val trimmed = line.trim()
    if trimmed.starts_with("#"):
        var level = 0
        while level < trimmed.len() and trimmed.char_at(level) == "#":
            level = level + 1
        if level < trimmed.len() and trimmed.char_at(level) != " ":
            return trimmed.slice(0, level) + " " + trimmed.slice(level, trimmed.len())
    if line.contains("[]()"):
        return line.replace("[]()", "[text](url)")
    if line.ends_with(" ") or line.ends_with("\t"):
        return line.trim()
    line

fn _editor_markdown_heading_level(line: text) -> i64:
    val trimmed = line.trim()
    var level = 0
    while level < trimmed.len() and trimmed.char_at(level) == "#":
        level = level + 1
    if level == 0 or level > 6:
        return 0
    if level < trimmed.len() and trimmed.char_at(level) == " ":
        return level
    0

fn _editor_escape_json(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        else:
            result = result + ch
        i = i + 1
    result

fn _editor_apply_code_action_content(buffer: EditorBuffer, path: text, edit_json: text) -> EditorAppliedCodeAction:
    if edit_json == "":
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    if edit_json.contains("\"changes\""):
        return _editor_apply_workspace_edit_content(buffer, path, edit_json)
    val line = _editor_json_number_field(edit_json, "\"line\"")
    val new_text = _editor_json_string_field(edit_json, "\"newText\"")
    if line < 0 or new_text == "":
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    if line >= buffer.line_count():
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    var content = ""
    var i = 0
    while i < buffer.line_count():
        if i > 0:
            content = content + "\n"
        if i == line:
            content = content + new_text
        else:
            content = content + buffer.line_at(i)
        i = i + 1
    EditorAppliedCodeAction(applied: true, content: content, line: line, col: new_text.len())

fn _editor_apply_workspace_edit_content(buffer: EditorBuffer, path: text, edit_json: text) -> EditorAppliedCodeAction:
    val edit_slice = _editor_workspace_edit_slice(edit_json, path)
    if edit_slice == "":
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    val start_line = _editor_json_number_after(edit_slice, "\"start\"", "\"line\"")
    val start_col = _editor_json_number_after(edit_slice, "\"start\"", "\"character\"")
    val end_line = _editor_json_number_after(edit_slice, "\"end\"", "\"line\"")
    val end_col = _editor_json_number_after(edit_slice, "\"end\"", "\"character\"")
    val new_text = _editor_json_string_field(edit_slice, "\"newText\"")
    if start_line < 0 or start_col < 0 or end_line < 0 or end_col < 0:
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    if start_line >= buffer.line_count() or end_line >= buffer.line_count() or start_line > end_line:
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    val first = buffer.line_at(start_line)
    val last = buffer.line_at(end_line)
    if start_col > first.len() or end_col > last.len():
        return EditorAppliedCodeAction(applied: false, content: "", line: 0, col: 0)
    var content = ""
    var i = 0
    while i < buffer.line_count():
        if i > 0:
            content = content + "\n"
        if i == start_line:
            content = content + first.slice(0, start_col) + new_text + last.slice(end_col, last.len())
        elif i > start_line and i <= end_line:
            content = content
        else:
            content = content + buffer.line_at(i)
        i = i + 1
    EditorAppliedCodeAction(applied: true, content: content, line: start_line, col: start_col + new_text.len())

fn _editor_apply_workspace_edit_disk_files(active_path: text, edit_json: text) -> i64:
    var applied_count = 0
    val paths = _editor_workspace_edit_paths(edit_json)
    for path in paths:
        if path != "" and path != active_path:
            val existing = rt_file_read_text(path) ?? ""
            var buffer = EditorBuffer.from_text(EditorBufferId(value: 0), existing)
            buffer.path = path
            val applied = _editor_apply_workspace_edit_content(buffer, path, edit_json)
            if applied.applied and rt_file_write_text(path, applied.content):
                applied_count = applied_count + 1
    applied_count

fn _editor_workspace_edit_slice(edit_json: text, path: text) -> text:
    if path == "":
        return edit_json
    val uri = "file://" + path
    var i = 0
    while i < edit_json.len():
        if edit_json.slice(i, edit_json.len()).starts_with(uri):
            var end = edit_json.len()
            var j = i + uri.len()
            while j < edit_json.len():
                if edit_json.slice(j, edit_json.len()).starts_with("\"file://"):
                    end = j
                    break
                j = j + 1
            return edit_json.slice(i, end)
        i = i + 1
    ""

fn _editor_workspace_edit_paths(edit_json: text) -> [text]:
    var paths: [text] = []
    var i = 0
    while i < edit_json.len():
        if edit_json.slice(i, edit_json.len()).starts_with("\"file://"):
            var j = i + 8
            var path = ""
            while j < edit_json.len() and edit_json.char_at(j) != "\"":
                path = path + edit_json.char_at(j)
                j = j + 1
            if path != "" and not _editor_text_list_contains(paths, path):
                paths.push(path)
            i = j
        else:
            i = i + 1
    paths

fn _editor_lsp_execute_command_params(command_json: text) -> text:
    val trimmed = command_json.trim()
    if trimmed == "":
        return ""
    if trimmed.starts_with("{"):
        val command_name = _editor_json_string_field(trimmed, "\"command\"")
        if command_name == "":
            return ""
        val args = _editor_json_value_field(trimmed, "\"arguments\"")
        val arg_json = if args == "" then "[]" else: args
        return "{\"command\":\"" + _editor_escape_json(command_name) + "\",\"arguments\":" + arg_json + "}"
    if trimmed.starts_with("\""):
        val command_name = _editor_unescape_json_string(trimmed, 0)
        if command_name == "":
            return ""
        return "{\"command\":\"" + _editor_escape_json(command_name) + "\",\"arguments\":[]}"
    "{\"command\":\"" + _editor_escape_json(trimmed) + "\",\"arguments\":[]}"

fn _editor_lsp_command_name(command_json: text) -> text:
    val trimmed = command_json.trim()
    if trimmed == "":
        return ""
    if trimmed.starts_with("{"):
        val command_name = _editor_json_string_field(trimmed, "\"command\"")
        if command_name != "":
            return command_name
    if trimmed.starts_with("\""):
        return _editor_unescape_json_string(trimmed, 0)
    trimmed

fn _editor_code_actions_from_response(result_json: text) -> [EditorCodeAction]:
    var actions: [EditorCodeAction] = []
    var i = 0
    while i < result_json.len():
        if result_json.char_at(i) == "{":
            val action_json = _editor_json_balanced(result_json, i, "{")
            if action_json != "":
                actions.push(EditorCodeAction(
                    title: _editor_json_string_field(action_json, "\"title\""),
                    kind: _editor_json_string_field(action_json, "\"kind\""),
                    edit_json: _editor_json_value_field(action_json, "\"edit\""),
                    command: _editor_json_value_field(action_json, "\"command\"")
                ))
                i = i + action_json.len()
            else:
                i = i + 1
        else:
            i = i + 1
    actions

fn _editor_text_list_contains(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn _editor_debug_launch_config_for_doc(program: text, debug_type: text) -> EditorDebugLaunchConfig:
    val configs = _editor_debug_launch_configs_for_doc(program, debug_type)
    if configs.len() > 0:
        return configs[0]
    editor_debug_launch_config_default(program)

fn _editor_debug_launch_configs_for_doc(program: text, debug_type: text) -> [EditorDebugLaunchConfig]:
    val launch_path = _editor_find_launch_json(program)
    if launch_path == "":
        return [editor_debug_launch_config_default(program)]
    val content = rt_file_read_text(launch_path) ?? ""
    if content == "":
        return [editor_debug_launch_config_default(program)]
    val workspace = _editor_workspace_dir_from_launch_json(launch_path)
    var resolved: [EditorDebugLaunchConfig] = []
    val configs = editor_debug_launch_configs_from_json(content)
    for config in configs:
        if editor_debug_launch_config_matches_type(config, debug_type):
            var selected = editor_debug_launch_config_with_program(config, program)
            resolved.push(editor_debug_resolve_launch_config(selected, workspace, program))
    if resolved.len() == 0:
        val selected = editor_debug_select_launch_config(content, debug_type, program)
        resolved.push(editor_debug_resolve_launch_config(selected, workspace, program))
    resolved

fn _editor_debug_launch_config_panel(configs: [EditorDebugLaunchConfig]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for config in configs:
        val config_program = editor_debug_launch_config_program(config)
        rows.push(WikiPanelRow(icon: "debug", label: editor_debug_launch_config_name(config), detail: editor_debug_launch_config_detail(config), path: config_program, line: 0))
    wiki_panel_with_rows("Debug Launch Configs", rows)

fn _editor_debug_sessions_panel(registry: EditorDebugRegistry) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    var first = true
    var i = 0
    while i < editor_debug_session_count(registry):
        val session = editor_debug_session_at(registry, i)
        val config = editor_debug_session_config(session)
        val active = if first then "active " else: ""
        val session_id = editor_debug_session_id(session)
        val config_program = editor_debug_launch_config_program(config)
        val detail = active + editor_debug_session_status(session) + " " + editor_debug_launch_config_debug_type(config) + " " + config_program
        rows.push(WikiPanelRow(icon: "debug", label: "#" + session_id.to_text() + " " + editor_debug_launch_config_name(config), detail: detail, path: config_program, line: session_id))
        first = false
        i = i + 1
    if rows.len() == 0:
        rows.push(WikiPanelRow(icon: "debug", label: "No debug sessions", detail: "", path: "", line: 0))
    wiki_panel_with_rows("Debug Sessions", rows)

fn _editor_debug_session_panel(session: EditorDebugSession) -> WikiPanel:
    editor_debug_session_wiki_panel(session)

fn _editor_keyboard_shortcuts_panel(config: KeybindingConfig) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for binding in config.bindings:
        var detail = binding.mode + " -> " + binding.command
        if binding.args != "":
            detail = detail + " " + binding.args
        rows.push(WikiPanelRow(icon: "key", label: binding.key, detail: detail, path: "", line: 0))
    wiki_panel_with_rows("Keyboard Shortcuts", rows)

fn _editor_workspace_dir_from_launch_json(launch_path: text) -> text:
    val vscode_dir = _editor_dirname(launch_path)
    _editor_dirname(vscode_dir)

fn _editor_find_launch_json(path: text) -> text:
    var dir = _editor_dirname(path)
    var depth = 0
    while dir != "" and depth < 12:
        val candidate = dir + "/.vscode/launch.json"
        val content = rt_file_read_text(candidate) ?? ""
        if content != "":
            return candidate
        val parent = _editor_dirname(dir)
        if parent == dir:
            return ""
        dir = parent
        depth = depth + 1
    ""

fn _editor_resolve_markdown_link_path(raw_target: text, active_path: text, session: EditSession) -> text:
    var target = raw_target.trim()
    if target.starts_with("file://"):
        target = target.slice(7, target.len())
    val parsed = md_wiki_parse_link_target(target)
    target = parsed.0
    val heading = _editor_find_text(target, "#")
    if heading >= 0:
        target = target.slice(0, heading).trim()
    if target == "":
        return ""
    if target.starts_with("/"):
        return target
    if target.ends_with(".md") or target.ends_with(".markdown"):
        val base_dir = _editor_dirname(active_path)
        if base_dir == "":
            return target
        return _editor_join_path(base_dir, target)
    val slug = md_wiki_slug(target)
    for doc in session.documents:
        if md_wiki_slug(md_wiki_title_from_path(doc.path())) == slug:
            return doc.path()
    val dir = _editor_dirname(active_path)
    if dir == "":
        return target + ".md"
    _editor_join_path(dir, target + ".md")

fn _editor_markdown_link_should_create_note(raw_target: text, path: text) -> bool:
    if path == "":
        return false
    if rt_file_exists(path):
        return false
    var target = raw_target.trim()
    if target.starts_with("file://"):
        return false
    val parsed = md_wiki_parse_link_target(target)
    target = parsed.0.trim()
    if target == "":
        return false
    if target.starts_with("/") or target.ends_with(".md") or target.ends_with(".markdown"):
        return false
    true

fn _editor_dirname(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last <= 0:
        return ""
    path.slice(0, last)

fn _editor_payload_part(payload: text, index: i64) -> text:
    var current = ""
    var current_index = 0
    var i = 0
    while i < payload.len():
        val ch = payload.char_at(i)
        if ch == "|":
            if current_index == index:
                return current
            current = ""
            current_index = current_index + 1
        else:
            current = current + ch
        i = i + 1
    if current_index == index:
        return current
    ""

fn _editor_payload_csv(payload: text) -> [text]:
    var values: [text] = []
    var current = ""
    var i = 0
    while i < payload.len():
        val ch = payload.char_at(i)
        if ch == ",":
            val item = current.trim()
            if item != "":
                values.push(item)
            current = ""
        else:
            current = current + ch
        i = i + 1
    val last = current.trim()
    if last != "":
        values.push(last)
    values

fn _editor_parse_i64(value: text, fallback: i64) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return fallback
    var sign = 1
    var i = 0
    if trimmed.starts_with("-"):
        sign = 0 - 1
        i = 1
    var result = 0
    var any = false
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if ch < "0" or ch > "9":
            if any:
                return result * sign
            return fallback
        result = result * 10 + _editor_digit_value(ch)
        any = true
        i = i + 1
    if any:
        return result * sign
    fallback

fn _editor_digit_value(ch: text) -> i64:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn _editor_parse_property_payload(payload: text) -> EditorPropertyPayload:
    val pipe = _editor_find_text(payload, "|")
    if pipe >= 0:
        return EditorPropertyPayload(
            key: payload.slice(0, pipe).trim(),
            value: payload.slice(pipe + 1, payload.len()).trim()
        )
    val eq = _editor_find_text(payload, "=")
    if eq >= 0:
        return EditorPropertyPayload(
            key: payload.slice(0, eq).trim(),
            value: payload.slice(eq + 1, payload.len()).trim()
        )
    EditorPropertyPayload(key: payload.trim(), value: "")

fn _editor_property_schema_rule_from_payload(payload: text) -> MdPropertySchemaRule:
    val key = _editor_payload_part(payload, 0).trim()
    val required_text = _editor_payload_part(payload, 1).trim()
    val allowed_text = _editor_payload_part(payload, 2).trim()
    val required = required_text == "required" or required_text == "true" or required_text == "yes"
    val allowed = _editor_payload_csv(allowed_text)
    md_property_schema_rule(key, required, allowed)

fn _editor_markdown_property_content(content: text, key: text, value: text) -> text:
    if key == "":
        return content
    val line = key + ": " + value
    val lines = content.split("\n")
    if lines.len() == 0:
        return "---\n" + line + "\n---\n" + content
    val first_line = lines[0]
    if first_line.trim() != "---":
        return "---\n" + line + "\n---\n" + content
    var out = "---"
    var i = 1
    var found = false
    var closed = false
    while i < lines.len():
        val raw = lines[i]
        val trimmed = raw.trim()
        if not closed and trimmed == "---":
            if not found:
                out = out + "\n" + line
            out = out + "\n---"
            closed = true
        elif not closed:
            val sep = _editor_find_text(trimmed, ":")
            val existing_key = if sep > 0 then trimmed.slice(0, sep).trim() else: ""
            if existing_key == key:
                out = out + "\n" + line
                found = true
            else:
                out = out + "\n" + raw
        else:
            out = out + "\n" + raw
        i = i + 1
    if not closed:
        if not found:
            out = out + "\n" + line
        out = out + "\n---"
    out

fn _editor_open_external_url(url: text) -> bool:
    _editor_open_external_url_status(url).starts_with("opened external link:")

fn _editor_open_external_url_status(url: text) -> text:
    val configured = rt_env_get("SIMPLE_EDITOR_BROWSER_COMMAND") ?? ""
    val browser = if configured.trim() != "" then configured.trim() else: rt_env_get("BROWSER") ?? ""
    val command = if browser.trim() != "" then browser.trim() else: "xdg-open"
    val (_out, _err, code) = rt_process_run(command, [url])
    if code == 0:
        return "opened external link: " + url
    "failed external link: " + url + " via " + command + " (exit " + code.to_text() + ")"

fn _editor_apply_template_text(template_body: text, title: text, date: text) -> text:
    val with_title = template_body.replace("{{title}}", title)
    with_title.replace("{{date}}", date)

fn _editor_daily_note_extension(extension: text) -> text:
    val clean = extension.trim()
    if clean == "":
        return ".md"
    if clean.starts_with("."):
        return clean
    "." + clean

fn _editor_attachment_embed(attachment_path: text, label: text) -> text:
    if label != "":
        return "![" + label + "](" + attachment_path + ")"
    "![[{attachment_path}]]"

fn _editor_store_attachment_for_note(target_path: text, source_path: text, storage_dir: text) -> text:
    val data = rt_file_read_bytes(source_path) ?? []
    if data.len() == 0 and not rt_file_exists(source_path):
        return ""
    val note_dir = _editor_dirname(target_path)
    val clean_dir = _editor_clean_relative_dir(storage_dir)
    if clean_dir == "":
        return ""
    val dest_dir = if note_dir == "" then clean_dir else: note_dir + "/" + clean_dir
    if not rt_dir_create_all(dest_dir):
        return ""
    val name = _editor_path_basename(source_path)
    if name == "":
        return ""
    val unique_name = _editor_unique_attachment_name(dest_dir, name)
    val dest_path = dest_dir + "/" + unique_name
    if not rt_file_write_bytes(dest_path, data):
        return ""
    clean_dir + "/" + unique_name

fn _editor_unique_attachment_name(dest_dir: text, name: text) -> text:
    val dot = _editor_last_dot(name)
    val base = if dot > 0 then name.slice(0, dot) else: name
    val ext = if dot > 0 then name.slice(dot, name.len()) else: ""
    var candidate = name
    var idx = 1
    while rt_file_exists(dest_dir + "/" + candidate):
        candidate = base + "-" + idx.to_text() + ext
        idx = idx + 1
    candidate

fn _editor_last_dot(name: text) -> i64:
    var last = -1
    var i = 0
    while i < name.len():
        if name.char_at(i) == ".":
            last = i
        i = i + 1
    last

fn _editor_clean_relative_dir(path: text) -> text:
    var clean = path.trim()
    while clean.starts_with("./"):
        clean = clean.slice(2, clean.len())
    while clean.starts_with("/"):
        clean = clean.slice(1, clean.len())
    while clean.ends_with("/") and clean.len() > 0:
        clean = clean.slice(0, clean.len() - 1)
    if clean == ".":
        return ""
    clean

fn _editor_attachment_picker_rows(root: text, query: text, target_path: text, storage_dir: text) -> [WikiPanelRow]:
    var rows: [WikiPanelRow] = []
    val files = rt_dir_walk(root)
    for file in files:
        if not md_wiki_is_attachment_target(file):
            continue
        if query != "" and _editor_find_text(file.to_lower(), query) < 0:
            continue
        val label = _editor_path_basename(file)
        val detail = if target_path == "" then file else: target_path + "|" + file + "|" + label + "|" + storage_dir
        rows.push(WikiPanelRow(icon: "attachment", label: label, detail: detail, path: file, line: 0))
    rows

fn _editor_template_picker_rows(folder: text, target_path: text, title: text, date: text, query: text) -> [WikiPanelRow]:
    var rows: [WikiPanelRow] = []
    val files = rt_dir_walk(folder)
    for file in files:
        if not _editor_is_markdown_path(file):
            continue
        if query != "" and _editor_find_text(file.to_lower(), query) < 0:
            continue
        val insert_payload = file + "|" + target_path + "|" + title + "|" + date
        rows.push(WikiPanelRow(icon: "template", label: _editor_path_basename(file), detail: insert_payload, path: file, line: 0))
    rows

fn _editor_tasks_matching(tasks: [MdWikiTask], query: text) -> [MdWikiTask]:
    if query == "":
        return tasks
    var result: [MdWikiTask] = []
    for task in tasks:
        if _editor_find_text(task.text_content.to_lower(), query) >= 0 or _editor_find_text(task.path.to_lower(), query) >= 0:
            result.push(task)
    result

fn _editor_problem_visible_count(panel: DiagnosticsPanel) -> i64:
    var count = 0
    for row in panel.rows:
        if row.path != "":
            count = count + 1
    count

fn _editor_is_markdown_path(path: text) -> bool:
    val lower = path.to_lower()
    lower.ends_with(".md") or lower.ends_with(".markdown")

fn _editor_wiki_properties_for_key(index: MdWikiIndex, key: text) -> [MdWikiProperty]:
    var props: [MdWikiProperty] = []
    for prop in index.properties:
        if prop.key == key:
            props.push(prop)
    props

fn _editor_path_basename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last >= 0 and last + 1 < path.len():
        return path.slice(last + 1, path.len())
    path

fn _editor_join_path(folder: text, name: text) -> text:
    if folder == "":
        return name
    if folder.ends_with("/"):
        return folder + name
    folder + "/" + name

fn _editor_find_text(haystack: text, needle: text) -> i64:
    var i = 0
    while i < haystack.len():
        if haystack.slice(i, haystack.len()).starts_with(needle):
            return i
        i = i + 1
    -1

fn _editor_json_number_field(json: text, field: text) -> i64:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            var num = ""
            while j < json.len():
                val ch = json.char_at(j)
                if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
                    num = num + ch
                else:
                    break
                j = j + 1
            if num != "":
                return num.to_i64() ?? -1
        i = i + 1
    -1

fn _editor_json_number_after(json: text, marker: text, field: text) -> i64:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(marker):
            return _editor_json_number_field(json.slice(i, json.len()), field)
        i = i + 1
    -1

fn _editor_json_string_field(json: text, field: text) -> text:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            if j < json.len() and json.char_at(j) == "\"":
                return _editor_unescape_json_string(json, j)
        i = i + 1
    ""

fn _editor_json_value_field(json: text, field: text) -> text:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            if j >= json.len():
                return ""
            val ch = json.char_at(j)
            if ch == "{" or ch == "[":
                return _editor_json_balanced(json, j, ch)
            if ch == "\"":
                return "\"" + _editor_escape_json(_editor_unescape_json_string(json, j)) + "\""
            var result = ""
            while j < json.len():
                val c = json.char_at(j)
                if c == "," or c == "}":
                    return result.trim()
                result = result + c
                j = j + 1
            return result.trim()
        i = i + 1
    ""

fn _editor_json_balanced(json: text, start: i64, open_ch: text) -> text:
    val close_ch = if open_ch == "{" then "}" else: "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return json.slice(start, i + 1)
        i = i + 1
    ""

fn _editor_json_numbers_in_array_field(json: text, field: text) -> [i64]:
    var nums: [i64] = []
    val idx = _editor_find_text(json, field)
    if idx < 0:
        return nums
    var i = idx
    while i < json.len() and json.char_at(i) != "[":
        i = i + 1
    if i >= json.len():
        return nums
    i = i + 1
    while i < json.len() and json.char_at(i) != "]":
        while i < json.len() and (json.char_at(i) == " " or json.char_at(i) == "\n" or json.char_at(i) == ","):
            i = i + 1
        var digits = ""
        while i < json.len() and json.char_at(i) >= "0" and json.char_at(i) <= "9":
            digits = digits + json.char_at(i)
            i = i + 1
        if digits != "":
            nums.push(digits.to_i64() ?? 0)
        else:
            i = i + 1
    nums

fn _editor_unescape_json_string(json: text, start: i64) -> text:
    var result = ""
    var i = start + 1
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "\"":
            return result
        if ch == "\\":
            i = i + 1
            if i < json.len():
                val esc = json.char_at(i)
                if esc == "n":
                    result = result + "\n"
                elif esc == "t":
                    result = result + "\t"
                else:
                    result = result + esc
        else:
            result = result + ch
        i = i + 1
    result

fn _editor_wiki_index_open_documents(session: EditSession) -> MdWikiIndex:
    var docs: [MdWikiDocument] = []
    for doc in session.documents:
        if doc.language_id == "markdown":
            docs.push(md_wiki_document(doc.path(), doc.buffer.to_text()))
    md_wiki_index_documents(docs)

fn _editor_wiki_docs_has_path(docs: [MdWikiDocument], path: text) -> bool:
    for doc in docs:
        if doc.path == path:
            return true
    false

fn _editor_markdown_vault_documents(root: text) -> [MdWikiDocument]:
    var docs: [MdWikiDocument] = []
    val files = rt_dir_walk(root)
    for file in files:
        val lower = file.to_lower()
        if lower.ends_with(".md") or lower.ends_with(".markdown"):
            docs.push(md_wiki_document(file, rt_file_read_text(file) ?? ""))
    docs

fn _editor_vault_search_cache_path(root: text) -> text:
    if root.ends_with("/"):
        return root + ".simple-vault-search.cache"
    root + "/.simple-vault-search.cache"

fn _editor_lsp_kind_has_panel(kind: text) -> bool:
    kind == "definition" or kind == "references" or kind == "selection-ranges" or kind == "document-symbols" or kind == "workspace-symbols" or kind == "signature-help" or kind == "folding-ranges" or kind == "document-links" or kind == "call-hierarchy" or kind == "call-hierarchy-incoming" or kind == "call-hierarchy-outgoing" or kind == "semantic-tokens" or kind == "inlay-hints" or kind == "code-lens" or kind == "code-lens-resolve" or kind == "hover" or kind == "code-action"

fn _editor_lsp_method_to_kind(method: text) -> text:
    if method == "textDocument/definition":
        return "definition"
    if method == "textDocument/references":
        return "references"
    if method == "textDocument/selectionRange":
        return "selection-ranges"
    if method == "textDocument/documentSymbol":
        return "document-symbols"
    if method == "workspace/symbol":
        return "workspace-symbols"
    if method == "textDocument/signatureHelp":
        return "signature-help"
    if method == "textDocument/foldingRange":
        return "folding-ranges"
    if method == "textDocument/documentLink":
        return "document-links"
    if method == "textDocument/prepareCallHierarchy":
        return "call-hierarchy"
    if method == "callHierarchy/incomingCalls":
        return "call-hierarchy-incoming"
    if method == "callHierarchy/outgoingCalls":
        return "call-hierarchy-outgoing"
    if method == "textDocument/semanticTokens/full":
        return "semantic-tokens"
    if method == "textDocument/inlayHint":
        return "inlay-hints"
    if method == "textDocument/codeLens":
        return "code-lens"
    if method == "codeLens/resolve":
        return "code-lens-resolve"
    if method == "textDocument/hover":
        return "hover"
    if method == "textDocument/codeAction":
        return "code-action"
    ""

fn ctrl_handle_insert_key(buffer: EditorBuffer, key: text) -> InsertKeyResult:
    if key == "\x1b":
        return InsertKeyResult(message: "", exit_insert: true)
    if key == "\x7f" or key == "\b":
        buffer.delete_before_cursor()
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    if key == "\r" or key == "\n":
        buffer.insert_at_cursor("\n")
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    if key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            buffer.insert_at_cursor(key)
        return InsertKeyResult(message: "-- INSERT --", exit_insert: false)
    InsertKeyResult(message: "-- INSERT --", exit_insert: false)

fn ctrl_handle_command_key(key: text, commandline: text) -> CommandKeyResult:
    if key == "\x1b":
        return CommandKeyResult(commandline: "", done: false, cancelled: true)
    if key == "\r" or key == "\n":
        return CommandKeyResult(commandline: commandline, done: true, cancelled: false)
    if key == "\x7f" or key == "\b":
        if commandline.len() > 0:
            return CommandKeyResult(commandline: commandline.slice(0, commandline.len() - 1), done: false, cancelled: false)
        return CommandKeyResult(commandline: "", done: false, cancelled: true)
    if key.len() == 1:
        val code = key.char_code_at(0)
        if code >= 32:
            return CommandKeyResult(commandline: commandline + key, done: false, cancelled: false)
    CommandKeyResult(commandline: commandline, done: false, cancelled: false)

struct LayoutZones:
    tab_bar_y: i64
    tab_bar_h: i64
    sidebar_x: i64
    sidebar_y: i64
    sidebar_w: i64
    sidebar_h: i64
    editor_x: i64
    editor_y: i64
    editor_w: i64
    editor_h: i64
    status_y: i64
    command_y: i64

struct LayoutZonesRight:
    x: i64
    w: i64

fn ctrl_compute_zones(ctrl: EditorController, total_w: i64, total_h: i64) -> LayoutZones:
    val sidebar_w = if ctrl.file_tree_visible then ctrl.session.dock_layout.left_width_value() else: 0
    val right_w = if ctrl.session.dock_layout.is_right_visible() then ctrl.session.dock_layout.right_width_value() else: 0
    val editor_area_h = total_h - 3
    val ew = total_w - sidebar_w - right_w
    LayoutZones(
        tab_bar_y: 0,
        tab_bar_h: 1,
        sidebar_x: 0,
        sidebar_y: 1,
        sidebar_w: sidebar_w,
        sidebar_h: editor_area_h,
        editor_x: sidebar_w,
        editor_y: 1,
        editor_w: ew,
        editor_h: editor_area_h,
        status_y: total_h - 2,
        command_y: total_h - 1
    )

fn ctrl_right_zone(ctrl: EditorController, zones: LayoutZones) -> LayoutZonesRight:
    val right_w = if ctrl.session.dock_layout.is_right_visible() then ctrl.session.dock_layout.right_width_value() else: 0
    LayoutZonesRight(
        x: zones.editor_x + zones.editor_w,
        w: right_w
    )
