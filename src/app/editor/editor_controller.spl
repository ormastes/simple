    me _wiki_show_tasks(filter: text) -> EditorAction:
        val index = self._wiki_index_open_documents()
        val normalized = if _editor_payload_part(filter, 0).trim() == "" then "open" else: _editor_payload_part(filter, 0).trim().to_lower()
        val query = _editor_payload_part(filter, 1).trim().to_lower()
        self.wiki_task_filter = normalized
        self.wiki_task_query = query
        self.wiki_panel = wiki_panel_from_tasks(_editor_tasks_matching(md_wiki_tasks_filtered(index, normalized), query))
        self._show_wiki_panel("wiki tasks: " + normalized)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_task_batch(payload: text) -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown task"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val normalized = payload.trim().to_lower()
        val checked = normalized == "done" or normalized == "checked" or normalized == "complete" or normalized == "completed"
        val next = md_tasks_set_checked(buffer.to_text(), checked)
        if next == buffer.to_text():
            self.status_msg = "no tasks changed"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        buffer.push_undo_snapshot()
        buffer.replace_content(next)
        buffer.dirty = true
        self._update_markdown_preview(doc, buffer)
        self.session.update_active_buffer(buffer)
        self._notify_active_lsp_changed()
        self.wiki_property_vault_root = _editor_dirname(doc.path())
        val index = self._wiki_index_open_documents()
        self.wiki_panel = wiki_panel_from_tasks(md_wiki_tasks_filtered(index, if checked then "done" else: "open"))
        self._show_wiki_panel(if checked then "tasks marked done" else: "tasks marked open")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_vault_task_batch(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val mode = _editor_payload_part(payload, 1).trim().to_lower()
        if root == "":
            self.status_msg = "missing vault root"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val checked = mode == "done" or mode == "checked" or mode == "complete" or mode == "completed"
        var changed_count = 0
        val files = rt_dir_walk(root)
        for file in files:
            if not _editor_is_markdown_path(file):
                continue
            val existing = rt_file_read_text(file) ?? ""
            val next = md_tasks_set_checked(existing, checked)
            if next != existing:
                if rt_file_write_text(file, next):
                    changed_count = changed_count + 1
                    self._refresh_open_document_from_disk_batch(file, next)
        val index = md_wiki_index_documents(_editor_markdown_vault_documents(root))
        self.wiki_panel = wiki_panel_from_tasks(md_wiki_tasks_filtered(index, if checked then "done" else: "open"))
        self._show_wiki_panel("vault tasks changed: " + changed_count.to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_show_properties() -> EditorAction:
        val doc = self.session.active_document()
        if doc == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val index = self._wiki_index_open_documents()
        self.wiki_panel = wiki_panel_from_properties(md_wiki_properties_for_path(index, doc.path()))
        self._show_wiki_panel("wiki properties panel")
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_set_property(payload: text) -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val parsed = _editor_parse_property_payload(payload)
        if parsed.key == "":
            self.status_msg = "missing property key"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val next = _editor_markdown_property_content(buffer.to_text(), parsed.key, parsed.value)
        buffer.push_undo_snapshot()
        buffer.replace_content(next)
        buffer.dirty = true
        buffer.move_cursor(0, 0)
        self._update_markdown_preview(doc, buffer)
        self.session.update_active_buffer(buffer)
        self._notify_active_lsp_changed()
        val index = self._wiki_index_open_documents()
        self.wiki_panel = wiki_panel_from_properties(md_wiki_properties_for_path(index, doc.path()))
        self._show_wiki_panel("property set: " + parsed.key)
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_vault_set_property(payload: text) -> EditorAction:
        val root = _editor_payload_part(payload, 0)
        val key = _editor_payload_part(payload, 1).trim()
        val value = _editor_payload_part(payload, 2).trim()
        if root == "" or key == "":
            self.status_msg = "missing vault root or property key"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        self.wiki_property_vault_root = root
        var changed_count = 0
        val files = rt_dir_walk(root)
        for file in files:
            if not _editor_is_markdown_path(file):
                continue
            val existing = rt_file_read_text(file) ?? ""
            val next = _editor_markdown_property_content(existing, key, value)
            if next != existing:
                if rt_file_write_text(file, next):
                    changed_count = changed_count + 1
                    self._refresh_open_document_from_disk_batch(file, next)
        val index = md_wiki_index_documents(_editor_markdown_vault_documents(root))
        self.wiki_panel = wiki_panel_from_properties(_editor_wiki_properties_for_key(index, key))
        self._show_wiki_panel("vault property set: " + changed_count.to_text())
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

    me _wiki_property_diagnostics(payload: text) -> EditorAction:
        val doc = self.session.active_document()
        val buffer = self.session.active_buffer()
        if doc == nil or buffer == nil or doc.language_id != "markdown":
            self.status_msg = "no markdown note open"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val rule = _editor_property_schema_rule_from_payload(payload)
        if rule.key == "":
            self.status_msg = "missing property schema"
            return EditorAction(redraw: true, quit: false, status_msg: self.status_msg)
        val diags = md_check_frontmatter_property_schema(buffer.to_text(), doc.path(), [rule])
        self.diagnostic_store.set_diagnostics(doc.path(), diags)
        self.diagnostics_panel = diagnostics_panel_from_store(self.diagnostic_store)
        self._show_diagnostics_panel()
        self.status_msg = "property diagnostics: " + diags.len().to_text()
        EditorAction(redraw: true, quit: false, status_msg: self.status_msg)

