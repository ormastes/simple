    me _wiki_show_tasks(filter: text) -> EditorAction:
        val index = ctrl_wiki_index_open_documents(me)
        val normalized = if _editor_payload_part(filter, 0).trim() == "" then "open" else: _editor_payload_part(filter, 0).trim().to_lower()
        val query = _editor_payload_part(filter, 1).trim().to_lower()
        me.wiki_task_filter = normalized
        me.wiki_task_query = query
        me.wiki_panel = wiki_panel_from_tasks(_editor_tasks_matching(md_wiki_tasks_filtered(index, normalized), query))
        me._show_right_dock("wiki-panel")
