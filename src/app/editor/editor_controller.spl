    me _debug_terminate_first() -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        if me.debug_dap_client.running:
            val requested = editor_debug_dap_client_disconnect(me.debug_dap_client)
            me.debug_dap_client = requested.0
        me.debug_registry = editor_debug_registry_terminate(me.debug_registry, editor_debug_session_id(session))
        var stopped_dap = me.debug_dap_client
        stopped_dap.running = false
        me.debug_dap_client = stopped_dap
        val client_index = editor_debug_session_id(session) - 1
        while me.debug_dap_clients.len() <= client_index:
            me.debug_dap_clients.push(EditorDebugDapClient.new())
        me.debug_dap_clients[client_index] = stopped_dap
        me.debug_process_pid = 0
        me.debug_status = "terminated"
        me.status_msg = "debug terminated"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_restart_first() -> EditorAction:
        val session = editor_debug_first_session(me.debug_registry)
        if editor_debug_session_id(session) == 0:
            me.status_msg = "no debug session"
            return EditorAction(redraw: true, quit: false, status_msg: me.status_msg)
        me.debug_registry = editor_debug_registry_restart(me.debug_registry, editor_debug_session_id(session))
        var dap = me.debug_dap_client
        dap.start()
        val restarted = editor_debug_dap_client_restart(dap)
        dap = restarted.0
        val initialized = editor_debug_dap_client_initialize(dap)
        dap = initialized.0
        val launched = editor_debug_dap_client_launch(dap, editor_debug_session_config(session))
        dap = launched.0
        me.debug_dap_client = dap
        val client_index = editor_debug_session_id(session) - 1
        while me.debug_dap_clients.len() <= client_index:
            me.debug_dap_clients.push(EditorDebugDapClient.new())
        me.debug_dap_clients[client_index] = dap
        me.debug_status = "restarting"
        me.status_msg = "debug restart"
        EditorAction(redraw: true, quit: false, status_msg: me.status_msg)

    me _debug_store_client_for_session(session_id: i64, dap: EditorDebugDapClient):
        val index = session_id - 1
        if index < 0:
            return
        while me.debug_dap_clients.len() <= index:
            me.debug_dap_clients.push(EditorDebugDapClient.new())
        me.debug_dap_clients[index] = dap

