# Persistent .sprof loader helpers.
# This slice models validation, merge, hot-path policy, and diagnostic bounds
# without opening profile files from hot request handlers.

use std.io (file_read)

val SPROF_COUNTER_MAX: i64 = 9223372036854775807

struct SprofMergeSummary:
    merged_count: i64
    diagnostic_count: i64
    saturated: bool

struct SprofLoadedProfile:
    status: text
    module_identity: text
    workload_label: text
    function_count: i64
    merged_count: i64
    diagnostic_count: i64
    saturated: bool

fn sprof_profile_record_status(record_kind: text, module_matches: bool, workload_matches: bool) -> text:
    if record_kind == "corrupt":
        return "invalid"
    if record_kind == "schema_mismatch":
        return "incompatible"
    if record_kind == "stale":
        return "ignored"
    if not module_matches:
        return "incompatible"
    if not workload_matches:
        return "ignored"
    "loaded"

fn sprof_hot_path_policy() -> [text]:
    ["no_file_open", "no_shell_out", "no_repo_scan", "use_loaded_summary"]

fn sprof_hot_path_allows_operation(operation: text) -> bool:
    if operation == "file_open":
        return false
    if operation == "shell_out":
        return false
    if operation == "repo_scan":
        return false
    operation == "use_loaded_summary"

fn sprof_merge_count(left: i64, right: i64) -> i64:
    if left < 0 or right < 0:
        return 0
    if left > SPROF_COUNTER_MAX - right:
        return SPROF_COUNTER_MAX
    left + right

fn sprof_merge_summary(left: i64, right: i64) -> SprofMergeSummary:
    if left < 0 or right < 0:
        return SprofMergeSummary(
            merged_count: 0,
            diagnostic_count: 1,
            saturated: false
        )

    val merged = sprof_merge_count(left, right)
    SprofMergeSummary(
        merged_count: merged,
        diagnostic_count: 0,
        saturated: merged == SPROF_COUNTER_MAX and (left != SPROF_COUNTER_MAX or right != 0)
    )

fn sprof_bounded_diagnostics(diagnostics: [text], limit: i64) -> [text]:
    if limit <= 0:
        return []

    var bounded: [text] = []
    var i: i64 = 0
    while i < diagnostics.len() and i < limit:
        bounded.push(diagnostics[i])
        i = i + 1

    if diagnostics.len() > limit:
        bounded.push("diagnostics_truncated:{diagnostics.len() - limit}")

    bounded

fn _sprof_line_value(line: text, key: text) -> text:
    val prefix = "{key}="
    val parts = line.split(";")
    var i = 0
    while i < parts.len():
        val part = parts[i].trim()
        if part.starts_with(prefix):
            return part[prefix.len():]
        i = i + 1
    ""

fn _sprof_parse_count(value: text) -> i64:
    value.trim().to_i64() ?? -1

fn sprof_load_profile_text(profile_text: text, expected_module: text, expected_workload: text) -> SprofLoadedProfile:
    if profile_text.trim() == "":
        return SprofLoadedProfile(
            status: "invalid",
            module_identity: "",
            workload_label: "",
            function_count: 0,
            merged_count: 0,
            diagnostic_count: 1,
            saturated: false
        )

    var module_identity = ""
    var workload_label = ""
    var function_count: i64 = 0
    var merged_count: i64 = 0
    var diagnostic_count: i64 = 0
    var saturated = false

    val lines = profile_text.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("header;"):
            module_identity = _sprof_line_value(line, "module")
            workload_label = _sprof_line_value(line, "workload")
        elif line.starts_with("function;"):
            val count = _sprof_parse_count(_sprof_line_value(line, "count"))
            val summary = sprof_merge_summary(merged_count, count)
            merged_count = summary.merged_count
            diagnostic_count = diagnostic_count + summary.diagnostic_count
            saturated = saturated or summary.saturated
            if count >= 0:
                function_count = function_count + 1
        i = i + 1

    val status = sprof_profile_record_status("exact", module_identity == expected_module, workload_label == expected_workload)
    SprofLoadedProfile(
        status: status,
        module_identity: module_identity,
        workload_label: workload_label,
        function_count: function_count,
        merged_count: merged_count,
        diagnostic_count: diagnostic_count,
        saturated: saturated
    )

fn sprof_load_profile_file(path: text, expected_module: text, expected_workload: text) -> SprofLoadedProfile:
    val body = file_read(path)
    sprof_load_profile_text(body, expected_module, expected_workload)
