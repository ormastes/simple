# Persistent .sprof loader helpers.
# This slice models validation, merge, hot-path policy, and diagnostic bounds
# without opening profile files from hot request handlers.

use std.io (file_read)

extern fn rt_file_write_text(path: text, content: text) -> bool

val SPROF_COUNTER_MAX: i64 = 9223372036854775807
val SPROF_SCHEMA_VERSION: text = "sprof-v1"

struct SprofMergeSummary:
    merged_count: i64
    function_count: i64
    block_count: i64
    edge_count: i64
    function_merged_count: i64
    block_merged_count: i64
    edge_merged_count: i64
    diagnostic_count: i64
    saturated: bool

struct SprofLoadedProfile:
    status: text
    schema_version: text
    module_identity: text
    workload_label: text
    function_count: i64
    block_count: i64
    edge_count: i64
    merged_count: i64
    function_merged_count: i64
    block_merged_count: i64
    edge_merged_count: i64
    diagnostic_count: i64
    diagnostics: [text]
    saturated: bool

struct SprofCounterRecord:
    record_kind: text
    key: text
    secondary_key: text
    count: i64

struct SprofWriteResult:
    wrote: bool
    byte_count: i64
    record_count: i64
    diagnostic_count: i64
    diagnostics: [text]

fn sprof_profile_record_status(record_kind: text, module_matches: bool, workload_matches: bool) -> text:
    if record_kind == "corrupt":
        return "invalid"
    if record_kind == "schema_mismatch":
        return "incompatible"
    if record_kind == "stale":
        return "ignored"
    if not module_matches:
        return "incompatible"
    if not workload_matches:
        return "ignored"
    "loaded"

fn sprof_hot_path_policy() -> [text]:
    ["no_file_open", "no_shell_out", "no_repo_scan", "use_loaded_summary"]

fn sprof_hot_path_allows_operation(operation: text) -> bool:
    if operation == "file_open":
        return false
    if operation == "shell_out":
        return false
    if operation == "repo_scan":
        return false
    operation == "use_loaded_summary"

fn sprof_merge_count(left: i64, right: i64) -> i64:
    if left < 0 or right < 0:
        return 0
    if left > SPROF_COUNTER_MAX - right:
        return SPROF_COUNTER_MAX
    left + right

fn sprof_merge_summary(left: i64, right: i64) -> SprofMergeSummary:
    if left < 0 or right < 0:
        return SprofMergeSummary(
            merged_count: 0,
            function_count: 0,
            block_count: 0,
            edge_count: 0,
            function_merged_count: 0,
            block_merged_count: 0,
            edge_merged_count: 0,
            diagnostic_count: 1,
            saturated: false
        )

    val merged = sprof_merge_count(left, right)
    SprofMergeSummary(
        merged_count: merged,
        function_count: 0,
        block_count: 0,
        edge_count: 0,
        function_merged_count: 0,
        block_merged_count: 0,
        edge_merged_count: 0,
        diagnostic_count: 0,
        saturated: merged == SPROF_COUNTER_MAX and (left != SPROF_COUNTER_MAX or right != 0)
    )

fn sprof_bounded_diagnostics(diagnostics: [text], limit: i64) -> [text]:
    if limit <= 0:
        return []

    var bounded: [text] = []
    var i: i64 = 0
    while i < diagnostics.len() and i < limit:
        bounded.push(diagnostics[i])
        i = i + 1

    if diagnostics.len() > limit:
        bounded.push("diagnostics_truncated:{diagnostics.len() - limit}")

    bounded

fn _sprof_line_value(line: text, key: text) -> text:
    val prefix = "{key}="
    val parts = line.split(";")
    var i = 0
    while i < parts.len():
        val part = parts[i].trim()
        if part.starts_with(prefix):
            return part[prefix.len():]
        i = i + 1
    ""

fn _sprof_parse_count(value: text) -> i64:
    value.trim().to_i64() ?? -1

fn _sprof_token_safe(value: text) -> bool:
    value != "" and not value.contains(";") and not value.contains("\n")

fn _sprof_schema_is_compatible(schema_version: text) -> bool:
    schema_version == "" or schema_version == "1" or schema_version == SPROF_SCHEMA_VERSION

fn sprof_counter_record(record_kind: text, key: text, secondary_key: text, count: i64) -> SprofCounterRecord:
    SprofCounterRecord(
        record_kind: record_kind,
        key: key,
        secondary_key: secondary_key,
        count: count
    )

fn sprof_counter_record_valid(record: SprofCounterRecord) -> bool:
    if record.count < 0:
        return false
    if record.record_kind == "function":
        return _sprof_token_safe(record.key) and record.secondary_key == ""
    if record.record_kind == "block":
        return _sprof_token_safe(record.key) and _sprof_token_safe(record.secondary_key)
    if record.record_kind == "edge":
        return _sprof_token_safe(record.key) and _sprof_token_safe(record.secondary_key)
    false

fn sprof_serialize_record(record: SprofCounterRecord) -> text:
    if record.record_kind == "function":
        return "function;key={record.key};count={record.count}"
    if record.record_kind == "block":
        return "block;function={record.secondary_key};key={record.key};count={record.count}"
    if record.record_kind == "edge":
        return "edge;from={record.key};to={record.secondary_key};count={record.count}"
    "invalid;kind={record.record_kind};count={record.count}"

fn sprof_serialize_profile(module_identity: text, workload_label: text, records: [SprofCounterRecord]) -> text:
    var lines: [text] = ["header;schema={SPROF_SCHEMA_VERSION};module={module_identity};workload={workload_label}"]
    var i = 0
    while i < records.len():
        if sprof_counter_record_valid(records[i]):
            lines.push(sprof_serialize_record(records[i]))
        i = i + 1
    lines.join("\n")

fn sprof_profile_write_diagnostics(module_identity: text, workload_label: text, records: [SprofCounterRecord]) -> [text]:
    var diagnostics: [text] = []
    if not _sprof_token_safe(module_identity):
        diagnostics.push("invalid_module_identity")
    if not _sprof_token_safe(workload_label):
        diagnostics.push("invalid_workload_label")
    var i = 0
    while i < records.len():
        if not sprof_counter_record_valid(records[i]):
            diagnostics.push("invalid_record:{i}")
        i = i + 1
    sprof_bounded_diagnostics(diagnostics, 8)

fn sprof_write_profile_file(path: text, module_identity: text, workload_label: text, records: [SprofCounterRecord]) -> SprofWriteResult:
    val diagnostics = sprof_profile_write_diagnostics(module_identity, workload_label, records)
    if path == "":
        return SprofWriteResult(
            wrote: false,
            byte_count: 0,
            record_count: 0,
            diagnostic_count: diagnostics.len() + 1,
            diagnostics: sprof_bounded_diagnostics(diagnostics + ["invalid_path"], 8)
        )
    if diagnostics.len() > 0:
        return SprofWriteResult(
            wrote: false,
            byte_count: 0,
            record_count: 0,
            diagnostic_count: diagnostics.len(),
            diagnostics: diagnostics
        )

    val body = sprof_serialize_profile(module_identity, workload_label, records)
    val wrote = rt_file_write_text(path, body)
    SprofWriteResult(
        wrote: wrote,
        byte_count: if wrote: body.len() else: 0,
        record_count: if wrote: records.len() else: 0,
        diagnostic_count: if wrote: 0 else: 1,
        diagnostics: if wrote: [] else: ["write_failed"]
    )

fn _sprof_merge_record_summary(record_kind: text, left: i64, right: i64) -> SprofMergeSummary:
    val summary = sprof_merge_summary(left, right)
    if summary.diagnostic_count > 0:
        return summary

    if record_kind == "function":
        return SprofMergeSummary(
            merged_count: summary.merged_count,
            function_count: 1,
            block_count: 0,
            edge_count: 0,
            function_merged_count: summary.merged_count,
            block_merged_count: 0,
            edge_merged_count: 0,
            diagnostic_count: 0,
            saturated: summary.saturated
        )
    if record_kind == "block":
        return SprofMergeSummary(
            merged_count: summary.merged_count,
            function_count: 0,
            block_count: 1,
            edge_count: 0,
            function_merged_count: 0,
            block_merged_count: summary.merged_count,
            edge_merged_count: 0,
            diagnostic_count: 0,
            saturated: summary.saturated
        )
    if record_kind == "edge":
        return SprofMergeSummary(
            merged_count: summary.merged_count,
            function_count: 0,
            block_count: 0,
            edge_count: 1,
            function_merged_count: 0,
            block_merged_count: 0,
            edge_merged_count: summary.merged_count,
            diagnostic_count: 0,
            saturated: summary.saturated
        )

    SprofMergeSummary(
        merged_count: 0,
        function_count: 0,
        block_count: 0,
        edge_count: 0,
        function_merged_count: 0,
        block_merged_count: 0,
        edge_merged_count: 0,
        diagnostic_count: 1,
        saturated: false
    )

fn sprof_load_profile_text(profile_text: text, expected_module: text, expected_workload: text) -> SprofLoadedProfile:
    if profile_text.trim() == "":
        return SprofLoadedProfile(
            status: "invalid",
            schema_version: "",
            module_identity: "",
            workload_label: "",
            function_count: 0,
            block_count: 0,
            edge_count: 0,
            merged_count: 0,
            function_merged_count: 0,
            block_merged_count: 0,
            edge_merged_count: 0,
            diagnostic_count: 1,
            diagnostics: ["empty_profile"],
            saturated: false
        )

    var schema_version = ""
    var module_identity = ""
    var workload_label = ""
    var function_count: i64 = 0
    var block_count: i64 = 0
    var edge_count: i64 = 0
    var merged_count: i64 = 0
    var function_merged_count: i64 = 0
    var block_merged_count: i64 = 0
    var edge_merged_count: i64 = 0
    var diagnostic_count: i64 = 0
    var diagnostics: [text] = []
    var saturated = false

    val lines = profile_text.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("header;"):
            schema_version = _sprof_line_value(line, "schema")
            module_identity = _sprof_line_value(line, "module")
            workload_label = _sprof_line_value(line, "workload")
        elif line.starts_with("function;") or line.starts_with("block;") or line.starts_with("edge;"):
            var record_kind = "function"
            if line.starts_with("block;"):
                record_kind = "block"
            elif line.starts_with("edge;"):
                record_kind = "edge"
            val count = _sprof_parse_count(_sprof_line_value(line, "count"))
            val summary = _sprof_merge_record_summary(record_kind, merged_count, count)
            if summary.diagnostic_count == 0:
                merged_count = sprof_merge_count(merged_count, count)
            elif count < 0:
                diagnostics.push("invalid_{record_kind}_count")
            diagnostic_count = diagnostic_count + summary.diagnostic_count
            saturated = saturated or summary.saturated
            if count >= 0:
                if record_kind == "function":
                    function_count = function_count + summary.function_count
                    function_merged_count = sprof_merge_count(function_merged_count, count)
                elif record_kind == "block":
                    block_count = block_count + summary.block_count
                    block_merged_count = sprof_merge_count(block_merged_count, count)
                elif record_kind == "edge":
                    edge_count = edge_count + summary.edge_count
                    edge_merged_count = sprof_merge_count(edge_merged_count, count)
        i = i + 1

    if not _sprof_schema_is_compatible(schema_version):
        diagnostic_count = diagnostic_count + 1
        diagnostics.push("schema_mismatch:{schema_version}")
    if module_identity != expected_module:
        diagnostic_count = diagnostic_count + 1
        diagnostics.push("module_mismatch:{module_identity}")
    if workload_label != expected_workload:
        diagnostic_count = diagnostic_count + 1
        diagnostics.push("workload_mismatch:{workload_label}")

    var record_kind = "exact"
    if not _sprof_schema_is_compatible(schema_version):
        record_kind = "schema_mismatch"
    val status = sprof_profile_record_status(record_kind, module_identity == expected_module, workload_label == expected_workload)
    SprofLoadedProfile(
        status: status,
        schema_version: schema_version,
        module_identity: module_identity,
        workload_label: workload_label,
        function_count: function_count,
        block_count: block_count,
        edge_count: edge_count,
        merged_count: merged_count,
        function_merged_count: function_merged_count,
        block_merged_count: block_merged_count,
        edge_merged_count: edge_merged_count,
        diagnostic_count: diagnostic_count,
        diagnostics: sprof_bounded_diagnostics(diagnostics, 8),
        saturated: saturated
    )

fn sprof_load_profile_file(path: text, expected_module: text, expected_workload: text) -> SprofLoadedProfile:
    val body = file_read(path)
    sprof_load_profile_text(body, expected_module, expected_workload)
