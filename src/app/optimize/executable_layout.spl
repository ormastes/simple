# Pure-Simple executable layout optimizer contract helpers.
#
# This module owns the production-side contract slice for BOLT-like executable
# layout planning. It only models deterministic eligibility and manifest rules;
# it does not invoke external binary rewriters.

struct ExecutableLayoutManifestEntry:
    symbol_name: text
    section_name: text
    original_offset: i64
    optimized_offset: i64
    size_bytes: i64

struct ExecutableLayoutFunctionProfile:
    symbol_name: text
    sample_count: i64
    call_count: i64
    size_bytes: i64
    original_index: i64

struct ExecutableLayoutColdCandidate:
    symbol_name: text
    is_cold: bool
    reason: text

struct ExecutableLayoutManifestSummary:
    entry_count: i64
    total_size_bytes: i64
    first_optimized_offset: i64
    last_optimized_end: i64

struct ExecutableLayoutPlanEntry:
    symbol_name: text
    section_name: text
    original_offset: i64
    new_offset: i64
    size_bytes: i64
    placement: text
    validation_status: text
    skip_reason: text

struct ExecutableLayoutPlan:
    hot_order: [text]
    cold_section_entries: [ExecutableLayoutPlanEntry]
    entries: [ExecutableLayoutPlanEntry]
    validation_status: text
    skip_reason: text

pub fn layout_plan_steps() -> [text]:
    [
        "hot_function_cluster",
        "hot_block_fallthrough",
        "cold_region_marking",
        "offset_manifest"
    ]

pub fn layout_transform_allowed(
    relocations_safe: bool,
    entry_preserved: bool,
    symbols_preserved: bool,
    workload_matches: bool
) -> bool:
    relocations_safe and entry_preserved and symbols_preserved and workload_matches

pub fn layout_transform_skip_reason(
    relocations_safe: bool,
    entry_preserved: bool,
    symbols_preserved: bool,
    workload_matches: bool
) -> text:
    if not relocations_safe:
        return "unsafe_relocations"
    if not entry_preserved:
        return "entry_not_preserved"
    if not symbols_preserved:
        return "symbols_not_preserved"
    if not workload_matches:
        return "workload_mismatch"
    "ok"

fn _is_command_separator(ch: text) -> bool:
    ch == " " or ch == "\t" or ch == "\n" or ch == "/" or ch == "\\" or
        ch == "'" or ch == "\"" or ch == "`" or ch == ";" or ch == "&" or
        ch == "|" or ch == "(" or ch == ")"

fn _command_tokens(command: text) -> [text]:
    val input = command.lower()
    var tokens: [text] = []
    var current = ""
    var i = 0
    while i < input.len():
        val ch = input[i:i + 1]
        if _is_command_separator(ch):
            if current != "":
                tokens.push(current)
                current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        tokens.push(current)
    tokens

fn _is_external_bolt_token(token: text) -> bool:
    token == "bolt" or token.starts_with("bolt.") or
        token == "llvm-bolt" or token.starts_with("llvm-bolt-") or token.starts_with("llvm-bolt.") or
        token == "perf2bolt" or token.starts_with("perf2bolt.") or
        token == "merge-fdata" or token.starts_with("merge-fdata.")

pub fn layout_uses_external_bolt(command: text) -> bool:
    val tokens = _command_tokens(command)
    var i = 0
    while i < tokens.len():
        if _is_external_bolt_token(tokens[i]):
            return true
        i = i + 1
    false

pub fn layout_external_bolt_allowed(command: text) -> bool:
    not layout_uses_external_bolt(command)

pub fn layout_hot_weight(profile: ExecutableLayoutFunctionProfile) -> i64:
    if profile.symbol_name.trim() == "":
        return 0
    if profile.sample_count < 0 or profile.call_count < 0 or profile.size_bytes <= 0:
        return 0
    (profile.sample_count * 100) + (profile.call_count * 10)

fn _profile_precedes(left: ExecutableLayoutFunctionProfile, right: ExecutableLayoutFunctionProfile) -> bool:
    val left_weight = layout_hot_weight(left)
    val right_weight = layout_hot_weight(right)
    if left_weight > right_weight:
        return true
    if left_weight < right_weight:
        return false
    left.original_index < right.original_index

pub fn layout_weighted_hot_function_order(profiles: [ExecutableLayoutFunctionProfile]) -> [text]:
    var sorted = profiles
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and _profile_precedes(sorted[j], sorted[j - 1]):
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1

    var names: [text] = []
    var ni = 0
    while ni < sorted.len():
        if layout_hot_weight(sorted[ni]) > 0:
            names.push(sorted[ni].symbol_name)
        ni = ni + 1
    names

pub fn layout_mark_cold_candidate(
    profile: ExecutableLayoutFunctionProfile,
    min_hot_weight: i64,
    max_cold_samples: i64
) -> ExecutableLayoutColdCandidate:
    if profile.symbol_name.trim() == "":
        return ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: false, reason: "missing_symbol")
    if profile.size_bytes <= 0:
        return ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: false, reason: "invalid_size")
    if profile.sample_count < 0 or profile.call_count < 0:
        return ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: false, reason: "invalid_profile")

    val weight = layout_hot_weight(profile)
    if profile.sample_count == 0 and profile.call_count == 0:
        return ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: true, reason: "no_profile_hits")
    if profile.sample_count <= max_cold_samples and weight < min_hot_weight:
        return ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: true, reason: "below_hot_threshold")
    ExecutableLayoutColdCandidate(symbol_name: profile.symbol_name, is_cold: false, reason: "hot_enough")

pub fn layout_manifest_entry_valid(entry: ExecutableLayoutManifestEntry) -> bool:
    if entry.symbol_name.trim() == "":
        return false
    if entry.section_name.trim() == "":
        return false
    if not entry.section_name.starts_with("."):
        return false
    if entry.original_offset < 0:
        return false
    if entry.optimized_offset < 0:
        return false
    entry.size_bytes > 0

pub fn layout_manifest_summary(entries: [ExecutableLayoutManifestEntry]) -> ExecutableLayoutManifestSummary:
    var total_size: i64 = 0
    var first_offset: i64 = 0
    var last_end: i64 = 0
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        val end_offset = entry.optimized_offset + entry.size_bytes
        total_size = total_size + entry.size_bytes
        if i == 0 or entry.optimized_offset < first_offset:
            first_offset = entry.optimized_offset
        if end_offset > last_end:
            last_end = end_offset
        i = i + 1
    ExecutableLayoutManifestSummary(
        entry_count: entries.len() as i64,
        total_size_bytes: total_size,
        first_optimized_offset: first_offset,
        last_optimized_end: last_end
    )

pub fn layout_manifest_summary_valid(
    entries: [ExecutableLayoutManifestEntry],
    summary: ExecutableLayoutManifestSummary
) -> bool:
    if summary.entry_count != entries.len() as i64:
        return false
    var i = 0
    while i < entries.len():
        if not layout_manifest_entry_valid(entries[i]):
            return false
        i = i + 1
    val expected = layout_manifest_summary(entries)
    summary.total_size_bytes == expected.total_size_bytes and
        summary.first_optimized_offset == expected.first_optimized_offset and
        summary.last_optimized_end == expected.last_optimized_end

fn _manifest_entry_precedes(left: ExecutableLayoutManifestEntry, right: ExecutableLayoutManifestEntry) -> bool:
    if left.original_offset < right.original_offset:
        return true
    if left.original_offset > right.original_offset:
        return false
    left.symbol_name < right.symbol_name

fn _manifest_entries_by_original_offset(entries: [ExecutableLayoutManifestEntry]) -> [ExecutableLayoutManifestEntry]:
    var sorted = entries
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and _manifest_entry_precedes(sorted[j], sorted[j - 1]):
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    sorted

fn _profile_index_for_symbol(profiles: [ExecutableLayoutFunctionProfile], symbol_name: text) -> i64:
    var i = 0
    while i < profiles.len():
        if profiles[i].symbol_name == symbol_name:
            return i as i64
        i = i + 1
    -1

fn _entry_index_for_symbol(entries: [ExecutableLayoutManifestEntry], symbol_name: text) -> i64:
    var i = 0
    while i < entries.len():
        if entries[i].symbol_name == symbol_name:
            return i as i64
        i = i + 1
    -1

fn _plan_entry_index_for_symbol(entries: [ExecutableLayoutPlanEntry], symbol_name: text) -> i64:
    var i = 0
    while i < entries.len():
        if entries[i].symbol_name == symbol_name:
            return i as i64
        i = i + 1
    -1

fn _profile_valid(profile: ExecutableLayoutFunctionProfile) -> bool:
    profile.symbol_name.trim() != "" and
        profile.sample_count >= 0 and
        profile.call_count >= 0 and
        profile.size_bytes > 0

fn _profile_skip_reason(profile: ExecutableLayoutFunctionProfile) -> text:
    if profile.symbol_name.trim() == "":
        return "missing_symbol"
    if profile.size_bytes <= 0:
        return "invalid_size"
    if profile.sample_count < 0 or profile.call_count < 0:
        return "invalid_profile"
    "ok"

fn _make_plan_entry(
    entry: ExecutableLayoutManifestEntry,
    new_offset: i64,
    placement: text,
    validation_status: text,
    skip_reason: text
) -> ExecutableLayoutPlanEntry:
    ExecutableLayoutPlanEntry(
        symbol_name: entry.symbol_name,
        section_name: entry.section_name,
        original_offset: entry.original_offset,
        new_offset: new_offset,
        size_bytes: entry.size_bytes,
        placement: placement,
        validation_status: validation_status,
        skip_reason: skip_reason
    )

pub fn layout_profile_guided_plan(
    manifest_entries: [ExecutableLayoutManifestEntry],
    profiles: [ExecutableLayoutFunctionProfile],
    relocations_safe: bool,
    entry_preserved: bool,
    symbols_preserved: bool,
    workload_matches: bool,
    hot_section_start: i64,
    cold_section_start: i64,
    min_hot_weight: i64,
    max_cold_samples: i64
) -> ExecutableLayoutPlan:
    val global_skip = layout_transform_skip_reason(
        relocations_safe: relocations_safe,
        entry_preserved: entry_preserved,
        symbols_preserved: symbols_preserved,
        workload_matches: workload_matches
    )
    val ordered_entries = _manifest_entries_by_original_offset(manifest_entries)
    var plan_entries: [ExecutableLayoutPlanEntry] = []
    var cold_entries: [ExecutableLayoutPlanEntry] = []
    var hot_order: [text] = []

    if global_skip != "ok":
        var unsafe_i = 0
        while unsafe_i < ordered_entries.len():
            val entry = ordered_entries[unsafe_i]
            plan_entries.push(_make_plan_entry(entry, entry.original_offset, "skipped", "skipped", global_skip))
            unsafe_i = unsafe_i + 1
        return ExecutableLayoutPlan(
            hot_order: hot_order,
            cold_section_entries: cold_entries,
            entries: plan_entries,
            validation_status: "skipped",
            skip_reason: global_skip
        )

    val ordered_hot_symbols = layout_weighted_hot_function_order(profiles)
    var hot_offset = hot_section_start
    var hot_i = 0
    while hot_i < ordered_hot_symbols.len():
        val symbol_name = ordered_hot_symbols[hot_i]
        val entry_index = _entry_index_for_symbol(ordered_entries, symbol_name)
        val profile_index = _profile_index_for_symbol(profiles, symbol_name)
        if entry_index >= 0 and profile_index >= 0:
            val entry = ordered_entries[entry_index]
            val profile = profiles[profile_index]
            val cold = layout_mark_cold_candidate(
                profile,
                min_hot_weight: min_hot_weight,
                max_cold_samples: max_cold_samples
            )
            if layout_manifest_entry_valid(entry) and _profile_valid(profile) and not cold.is_cold:
                plan_entries.push(_make_plan_entry(entry, hot_offset, "hot", "valid", "ok"))
                hot_order.push(entry.symbol_name)
                hot_offset = hot_offset + entry.size_bytes
        hot_i = hot_i + 1

    var cold_offset = cold_section_start
    var entry_i = 0
    while entry_i < ordered_entries.len():
        val entry = ordered_entries[entry_i]
        if _plan_entry_index_for_symbol(plan_entries, entry.symbol_name) < 0:
            val profile_index = _profile_index_for_symbol(profiles, entry.symbol_name)
            if not layout_manifest_entry_valid(entry):
                plan_entries.push(_make_plan_entry(entry, entry.original_offset, "skipped", "skipped", "invalid_manifest_entry"))
            elif profile_index < 0:
                plan_entries.push(_make_plan_entry(entry, entry.original_offset, "skipped", "skipped", "missing_profile"))
            else:
                val profile = profiles[profile_index]
                if not _profile_valid(profile):
                    plan_entries.push(_make_plan_entry(entry, entry.original_offset, "skipped", "skipped", _profile_skip_reason(profile)))
                else:
                    val cold = layout_mark_cold_candidate(
                        profile,
                        min_hot_weight: min_hot_weight,
                        max_cold_samples: max_cold_samples
                    )
                    if cold.is_cold:
                        val cold_entry = _make_plan_entry(entry, cold_offset, "cold", "valid", "ok")
                        plan_entries.push(cold_entry)
                        cold_entries.push(cold_entry)
                        cold_offset = cold_offset + entry.size_bytes
                    else:
                        plan_entries.push(_make_plan_entry(entry, hot_offset, "hot", "valid", "ok"))
                        hot_order.push(entry.symbol_name)
                        hot_offset = hot_offset + entry.size_bytes
        entry_i = entry_i + 1

    var status = "valid"
    var reason = "ok"
    var status_i = 0
    while status_i < plan_entries.len():
        if plan_entries[status_i].validation_status != "valid":
            status = "partial"
            reason = "entry_skipped"
        status_i = status_i + 1

    ExecutableLayoutPlan(
        hot_order: hot_order,
        cold_section_entries: cold_entries,
        entries: plan_entries,
        validation_status: status,
        skip_reason: reason
    )
