# Simple optimizer - auto-apply safe passes
# AC-9: Applies specified (or default safe) MIR passes and writes optimized output.

use app.io.file_shell.{shell_output, file_write}
use std.log.{error}

# ── Safe-pass list ────────────────────────────────────────────────────────────

fn safe_passes_for_level(level: text) -> [text]:
    if level == "O0":
        return []
    if level == "O1":
        return ["dead_code_elimination", "constant_folding"]
    if level == "O3":
        return [
            "dead_code_elimination", "constant_folding",
            "copy_propagation", "common_subexpr_elim",
            "inline_small_functions", "loop_invariant_motion",
            "bounds_check_elimination", "strength_reduction"
        ]
    # O2 default — safe subset only
    ["dead_code_elimination", "constant_folding", "copy_propagation", "common_subexpr_elim"]

fn _passes_to_flag(passes: [text]) -> text:
    if passes.is_empty():
        return ""
    var result = "--passes="
    var i = 0
    while i < passes.len():
        if i > 0:
            result = result + ","
        result = result + passes[i]
        i = i + 1
    result

fn _output_path(file_path: text) -> text:
    if file_path.ends_with(".spl"):
        val base = file_path[0:file_path.len() - 4]
        return "{base}.opt.spl"
    "{file_path}.opt"

# ── Public API ────────────────────────────────────────────────────────────────

fn optimize_apply(file_path: text, passes: [text], level: text) -> i64:
    print "=== Optimizer Apply: {file_path} (level={level}) ==="
    print ""

    val effective_passes = if passes.is_empty():
        safe_passes_for_level(level)
    else:
        passes

    if effective_passes.is_empty():
        print "Level O0: no passes to apply."
        return 0

    print "Applying {effective_passes.len()} pass(es):"
    var pi = 0
    while pi < effective_passes.len():
        print "  - {effective_passes[pi]}"
        pi = pi + 1
    print ""

    # Invoke the Simple compiler with MIR pass flags and emit=spl for source output
    val passes_flag = _passes_to_flag(effective_passes)
    val out_path    = _output_path(file_path)
    val cmd = "bin/simple compile '{file_path}' --emit=mir-opt {passes_flag} --level={level} -o '{out_path}' 2>&1"
    val cmd_out = shell_output(cmd)

    if cmd_out.contains("Error") or cmd_out.contains("error:"):
        print "Error: optimizer pass failed:"
        print cmd_out
        return 1

    print "Applied passes successfully."
    print ""
    print "Output written to: {out_path}"
    print ""
    print "Summary: Applied {effective_passes.len()} optimization(s)"

    # Print any informational output from the pass pipeline
    if cmd_out.trim() != "":
        print ""
        print "Pass output:"
        print cmd_out

    0
