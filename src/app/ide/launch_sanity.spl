# IDE launch sanity checks.
#
# Thin product-level probes over the shared editor launch parser. Runtime and
# renderer startup remain in the existing editor/IDE entrypoints.

use std.editor.core.launch.{editor_launch_parse}
use app.office.launcher.{launcher_action_allowlist, launcher_app_cards}

struct IdeLaunchSanity:
    tui_mode: text
    gui_mode: text
    sdl_mode: text
    file_count: i64
    office_action_count: i64
    office_card_count: i64
    unknown_option: text

fn ide_launch_sanity() -> IdeLaunchSanity:
    val tui = editor_launch_parse(["--tui", "notes.md", "deck.spres"])
    val gui = editor_launch_parse(["--gui", "sheet.scsv"])
    val sdl = editor_launch_parse(["--gui-sdl"])
    val bad = editor_launch_parse(["--bad-mode"])
    IdeLaunchSanity(
        tui_mode: tui.mode,
        gui_mode: gui.mode,
        sdl_mode: sdl.mode,
        file_count: tui.files.len() + gui.files.len(),
        office_action_count: launcher_action_allowlist().len(),
        office_card_count: launcher_app_cards().len(),
        unknown_option: bad.unknown_option
    )

fn ide_launch_sanity_summary() -> text:
    val sanity = ide_launch_sanity()
    "launch: tui={sanity.tui_mode} gui={sanity.gui_mode} sdl={sanity.sdl_mode} files={sanity.file_count} office_actions={sanity.office_action_count} office_cards={sanity.office_card_count} unknown={sanity.unknown_option}"

# Returns true when parsing empty argv produces a valid (non-crashing) result.
fn ide_launch_empty_argv_safe() -> bool:
    val result = editor_launch_parse([])
    result.mode != "" or result.unknown_option != "" or result.files.len() >= 0

# Returns true when a single unknown option populates unknown_option only.
fn ide_launch_unknown_only() -> bool:
    val result = editor_launch_parse(["--totally-unknown-flag"])
    result.unknown_option != "" and result.mode != "--totally-unknown-flag"
