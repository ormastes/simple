# IDE GUI sanity surface.
#
# Uses the existing editor GUI backend and editor-area renderer. This adapter is
# intentionally probe-only so feature checks do not start a GUI event loop.

use std.editor.backend.gui_backend.{gui_backend_default_config, gui_render_markdown_document}
use std.editor.services.md_document_decor.{md_document_render_office_html}

struct IdeGuiSanity:
    theme: text
    width: i64
    height: i64
    renders_markdown: bool
    renders_presentation: bool
    renders_sheet: bool
    has_backend_config: bool

fn ide_gui_sanity() -> IdeGuiSanity:
    val config = gui_backend_default_config()
    val markdown_source = "# GUI\n\nBody"
    val presentation_source = "---\nlayout: presentation\n---\n\n## Slide One\n\nBody"
    val sheet_source = "---\nlayout: spreadsheet\n---\n\n| A | B |\n|---|---|\n| 1 | 2 |"
    val markdown_html = gui_render_markdown_document(markdown_source)
    val presentation_html = gui_render_markdown_document(presentation_source)
    val sheet_html = gui_render_markdown_document(sheet_source)
    val presentation_office_html = md_document_render_office_html(presentation_source)
    val sheet_office_html = md_document_render_office_html(sheet_source)
    IdeGuiSanity(
        theme: config.theme,
        width: config.initial_width,
        height: config.initial_height,
        renders_markdown: markdown_html.contains("md-document") and markdown_html.contains("<h1>GUI</h1>"),
        renders_presentation: presentation_html.contains("md-ppt-deck") or presentation_office_html.contains("md-ppt-deck"),
        renders_sheet: sheet_html.contains("md-sheet-layout") or sheet_office_html.contains("md-sheet-layout"),
        has_backend_config: config.window_title == "Simple Editor" and config.initial_width > 0 and config.initial_height > 0
    )

fn ide_gui_sanity_summary() -> text:
    val sanity = ide_gui_sanity()
    "gui-backend: theme={sanity.theme} size={sanity.width}x{sanity.height} md={sanity.renders_markdown} ppt={sanity.renders_presentation} sheet={sanity.renders_sheet} config={sanity.has_backend_config}"
