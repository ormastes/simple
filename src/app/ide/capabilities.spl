# IDE capability registry.
#
# This is product-level metadata only: each capability points at the existing
# implementation owner so the IDE can expose app/plugin support without forking
# renderers, document models, spreadsheets, slide decks, dashboards, or DB code.

use app.ide.sheets_compat.{ide_sheet_compat_summary}
use app.ide.slides_compat.{ide_slide_compat_summary}
use app.ide.db_admin.{ide_db_admin_summary}
use app.ide.agent_dashboard.{ide_agent_dashboard_summary}
use app.ide.markdown_render.{ide_markdown_render_summary}
use app.ide.launch_sanity.{ide_launch_sanity_summary}
use app.ide.plugin_manifest.{ide_plugin_manifest_summary}
use app.ide.gui_sanity.{ide_gui_sanity_summary}
use app.ide.tui_sanity.{ide_tui_sanity_summary}

struct IdeCapability:
    id: text
    label: text
    plugin_kind: text
    owner_module: text
    compatible_with: [text]
    feature_check: text

fn ide_capability_new(id: text, label: text, plugin_kind: text, owner_module: text, compatible_with: [text], feature_check: text) -> IdeCapability:
    IdeCapability(
        id: id,
        label: label,
        plugin_kind: plugin_kind,
        owner_module: owner_module,
        compatible_with: compatible_with,
        feature_check: feature_check
    )

fn ide_capabilities() -> [IdeCapability]:
    [
        ide_capability_new(
            "markdown",
            "Markdown Preview",
            "document-renderer",
            "std.editor.render.md_renderer",
            ["md", "markdown"],
            ide_markdown_render_summary()
        ),
        ide_capability_new(
            "slides",
            "Presentation Slides",
            "office-app",
            "app.office.slides",
            ["ppt", "presentation", "slides"],
            ide_slide_compat_summary()
        ),
        ide_capability_new(
            "sheets",
            "Spreadsheet",
            "office-app",
            "app.office.sheets",
            ["excel", "xlsx", "tabular", "csv"],
            ide_sheet_compat_summary()
        ),
        ide_capability_new(
            "agent-dashboard",
            "Agent Dashboard",
            "dashboard",
            "app.editor.mcp_tools",
            ["agent", "dashboard", "mcp"],
            ide_agent_dashboard_summary()
        ),
        ide_capability_new(
            "db-admin",
            "Database Admin",
            "database",
            "std.editor.core.session_db",
            ["embedded-db", "simple-db", "portal-db"],
            ide_db_admin_summary()
        )
    ]

fn ide_capability_count() -> i64:
    ide_capabilities().len()

fn ide_capability_ids() -> [text]:
    var ids: [text] = []
    for cap in ide_capabilities():
        ids = ids.push(cap.id)
    ids

fn ide_capability_report() -> [text]:
    var lines: [text] = []
    for cap in ide_capabilities():
        lines = lines.push("{cap.id}: {cap.label} [{cap.plugin_kind}] -> {cap.owner_module} ({cap.compatible_with.join(\", \")})")
        lines = lines.push("  check: {cap.feature_check}")
    lines
    return lines

fn ide_feature_check_report(mode: text) -> [text]:
    var lines: [text] = [
        "Simple IDE feature check",
        "mode: {mode}",
        "capabilities: {ide_capability_count()}"
    ]
    for line in ide_capability_report():
        lines = lines.push(line)
    lines = lines.push("  tui: " + ide_tui_sanity_summary())
    lines = lines.push("  launch: " + ide_launch_sanity_summary())
    lines = lines.push("  gui: " + ide_gui_sanity_summary())
    lines = lines.push("  plugin-manifest: " + ide_plugin_manifest_summary())
    lines
