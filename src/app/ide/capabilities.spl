# IDE capability registry.
#
# This is product-level metadata only: each capability points at the existing
# implementation owner so the IDE can expose app/plugin support without forking
# renderers, document models, spreadsheets, slide decks, dashboards, or DB code.

struct IdeCapability:
    id: text
    label: text
    plugin_kind: text
    owner_module: text
    compatible_with: [text]
    feature_check: text

fn ide_capability_new(id: text, label: text, plugin_kind: text, owner_module: text, compatible_with: [text], feature_check: text) -> IdeCapability:
    IdeCapability(
        id: id,
        label: label,
        plugin_kind: plugin_kind,
        owner_module: owner_module,
        compatible_with: compatible_with,
        feature_check: feature_check
    )

fn ide_capabilities() -> [IdeCapability]:
    [
        ide_capability_new(
            "sheets",
            "Spreadsheet",
            "office-app",
            "app.office.sheets",
            ["excel", "xlsx", "tabular", "csv"],
            "sheets: app.office.sheets formats=excel,xlsx,csv,tabular formula=true edit=true"
        ),
        ide_capability_new(
            "markdown",
            "Markdown Preview",
            "document-renderer",
            "std.editor.render.md_renderer",
            ["md", "markdown"],
            "markdown: std.editor.render.md_renderer preview=true css_doc=true escaped=true metadata=true"
        ),
        ide_capability_new(
            "writer",
            "Markdown Writer",
            "office-app",
            "app.office.word.html_render",
            ["writer", "md", "markdown", "html"],
            "writer: app.office.word.html_render markdown=true html=true paper=true escaped=true"
        ),
        ide_capability_new(
            "slides",
            "Presentation Slides",
            "office-app",
            "app.office.slides",
            ["ppt", "presentation", "slides"],
            "slides: app.office.slides ppt_html=true safe_css=true positioned=true edit=true"
        ),
        ide_capability_new(
            "draw",
            "SDD Diagram Draw",
            "office-app",
            "std.editor.services.sdn_graph",
            ["draw", "diagram", "sdd", "sdn"],
            "draw: sdn_graph format=sdd name=\"SDD: Simple Diagram Document\" html=true path_meta=true handle_meta=true edit=true layout=true canvas=true"
        ),
        ide_capability_new(
            "designer",
            "UI Designer",
            "office-app",
            "app.office.ui_editor",
            ["figma", "html", "sdd", "ui"],
            "designer: app.office.ui_editor html=true sdd=true selection=true resize_handle_metadata=true"
        ),
        ide_capability_new(
            "math",
            "Formula Math",
            "office-app",
            "app.office.math_editor",
            ["math", "formula", "mathml", "equation"],
            "math: app.office.math_editor mathml=true checked=true fraction=true escaped=true"
        ),
        ide_capability_new(
            "agent-dashboard",
            "Agent Dashboard",
            "dashboard",
            "app.editor.mcp_tools",
            ["agent", "dashboard", "mcp"],
            "agent-dashboard: app.editor.mcp_tools tools=true status=true"
        ),
        ide_capability_new(
            "db-admin",
            "Database Admin",
            "database",
            "std.editor.core.session_db",
            ["embedded-db", "simple-db", "portal-db"],
            "db-admin: std.editor.core.session_db owners=true targets=true contracts=true"
        )
    ]

fn ide_capability_count() -> i64:
    ide_capabilities().len()

fn ide_capability_ids() -> [text]:
    var ids: [text] = []
    for cap in ide_capabilities():
        ids.push(cap.id)
    ids

fn ide_capability_report() -> [text]:
    var lines: [text] = []
    for cap in ide_capabilities():
        val compat = cap.compatible_with.join(", ")
        lines.push(cap.id + ": " + cap.label + " [" + cap.plugin_kind + "] -> " + cap.owner_module + " (" + compat + ")")
        lines.push("  check: " + cap.feature_check)
    lines

# Returns true when a capability entry has non-empty required fields.
fn ide_capability_valid(cap: IdeCapability) -> bool:
    cap.id != "" and cap.label != "" and cap.owner_module != "" and cap.plugin_kind != "" and cap.feature_check != ""

# Returns true when both preview pane dimensions are positive (sane defaults).
fn ide_preview_bounds_valid(width: i64, height: i64) -> bool:
    width > 0 and height > 0

# Returns the count of capabilities that pass ide_capability_valid.
fn ide_capability_valid_count() -> i64:
    var count: i64 = 0
    for cap in ide_capabilities():
        if ide_capability_valid(cap):
            count = count + 1
    count
