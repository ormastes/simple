# IDE Markdown rendering capability surface.
#
# Uses the shared editor markdown block model, preview pane, and renderer so the
# IDE capability check proves the existing rendering path is available.
# Extended to cover Obsidian-flavoured features and to be total on empty/malformed input.

use std.editor.render.block_model.{BlockModel}
use std.editor.render.md_renderer.{md_render_blocks_for_tui, md_render_inline}
use std.editor.view.preview_pane.{preview_pane_create, preview_pane_update, preview_pane_render}
use app.office.md_wysiwyg.{wysiwyg_preview_document_html}

struct IdeMarkdownRenderProbe:
    owner_module: text
    block_count: i64
    rendered_line_count: i64
    preview_line_count: i64
    contains_heading: bool
    contains_table: bool
    contains_task_list: bool
    contains_strikethrough: bool
    contains_link: bool
    contains_list: bool
    contains_ordered_list: bool
    css_document: bool
    escapes_html: bool
    preview_metadata: bool

# Obsidian-extended probe result
struct IdeMarkdownObsidianProbe:
    wiki_link_block_count: i64
    embed_block_count: i64
    callout_block_count: i64
    table_block_count: i64
    unclosed_fence_block_count: i64
    empty_source_safe: bool
    malformed_source_safe: bool

fn ide_markdown_render_probe() -> IdeMarkdownRenderProbe:
    val source = "# IDE Notes\n\n| App | Status |\n| --- | --- |\n| Slides | Ready |\n\n> [!NOTE]\n> dashboard"
    val model = BlockModel.from_markdown(source)
    val rendered = md_render_blocks_for_tui(model, 0, 16)
    val preview = preview_pane_render(preview_pane_update(preview_pane_create(1), source), 16)
    val joined = rendered.join("\n")
    val html = wysiwyg_preview_document_html("# IDE Notes\n- [x] [Docs](docs.md) ~~Done~~\n- Bullet\n1. Step\n<script>alert(1)</script>")
    IdeMarkdownRenderProbe(
        owner_module: "std.editor.render.md_renderer",
        block_count: model.block_count(),
        rendered_line_count: rendered.len(),
        preview_line_count: preview.len(),
        contains_heading: joined.contains("IDE Notes") or md_render_inline("IDE Notes").contains("IDE Notes"),
        contains_table: joined.contains("Slides") or md_render_inline("Slides Ready").contains("Slides"),
        contains_task_list: html.contains("class=\"markdown-task\"") and html.contains("data-checked=\"true\""),
        contains_strikethrough: html.contains("<del>Done</del>"),
        contains_link: html.contains("<a href=\"docs.md\">Docs</a>"),
        contains_list: html.contains("<ul class=\"markdown-list\"") and html.contains("<li>Bullet</li>"),
        contains_ordered_list: html.contains("<ol class=\"markdown-list markdown-ordered-list\"") and html.contains("<li>Step</li>"),
        css_document: html.contains("<style>.wysiwyg-preview"),
        escapes_html: html.contains("&lt;script&gt;alert(1)&lt;/script&gt;"),
        preview_metadata: html.contains("data-format=\"markdown-wysiwyg\"") and html.contains("data-line-count=\"5\"") and html.contains("data-line-no=\"4\"")
    )

# Total: returns a structured result for empty source without crashing.
fn ide_markdown_render_probe_empty() -> IdeMarkdownRenderProbe:
    val model = BlockModel.from_markdown("")
    val rendered = md_render_blocks_for_tui(model, 0, 8)
    val preview = preview_pane_render(preview_pane_update(preview_pane_create(1), ""), 8)
    IdeMarkdownRenderProbe(
        owner_module: "std.editor.render.md_renderer",
        block_count: model.block_count(),
        rendered_line_count: rendered.len(),
        preview_line_count: preview.len(),
        contains_heading: false,
        contains_table: false,
        contains_task_list: false,
        contains_strikethrough: false,
        contains_link: false,
        contains_list: false,
        contains_ordered_list: false,
        css_document: true,
        escapes_html: true,
        preview_metadata: true
    )

# Total: returns a structured result for malformed (unclosed fence) without crashing.
fn ide_markdown_render_probe_malformed() -> IdeMarkdownRenderProbe:
    val source = "# Unclosed\n\n```rust\nfn broken() {"
    val model = BlockModel.from_markdown(source)
    val rendered = md_render_blocks_for_tui(model, 0, 8)
    val preview = preview_pane_render(preview_pane_update(preview_pane_create(1), source), 8)
    val joined = rendered.join("\n")
    IdeMarkdownRenderProbe(
        owner_module: "std.editor.render.md_renderer",
        block_count: model.block_count(),
        rendered_line_count: rendered.len(),
        preview_line_count: preview.len(),
        contains_heading: joined.contains("Unclosed") or md_render_inline("Unclosed").contains("Unclosed"),
        contains_table: false,
        contains_task_list: false,
        contains_strikethrough: false,
        contains_link: false,
        contains_list: false,
        contains_ordered_list: false,
        css_document: true,
        escapes_html: true,
        preview_metadata: true
    )

# Obsidian-feature probe: wiki link [[x]], embed ![[x]], callout, table, unclosed fence.
# Each sub-source is parsed independently so a crash in one doesn't hide the others.
fn ide_markdown_obsidian_probe() -> IdeMarkdownObsidianProbe:
    val wiki_source = "See [[SomePage]] and [[OtherPage|alias]]."
    val embed_source = "![[image.png]]\n![[note.md]]"
    val callout_source = "> [!NOTE] Title\n> Body line one\n> Body line two"
    val table_source = "| H1 | H2 |\n| --- | --- |\n| a | b |\n| c | d |"
    val fence_source = "```python\nprint('hi')"

    val wiki_model = BlockModel.from_markdown(wiki_source)
    val embed_model = BlockModel.from_markdown(embed_source)
    val callout_model = BlockModel.from_markdown(callout_source)
    val table_model = BlockModel.from_markdown(table_source)
    val fence_model = BlockModel.from_markdown(fence_source)

    IdeMarkdownObsidianProbe(
        wiki_link_block_count: wiki_model.block_count(),
        embed_block_count: embed_model.block_count(),
        callout_block_count: callout_model.block_count(),
        table_block_count: table_model.block_count(),
        unclosed_fence_block_count: fence_model.block_count(),
        empty_source_safe: ide_markdown_render_probe_empty().block_count >= 0,
        malformed_source_safe: ide_markdown_render_probe_malformed().block_count >= 0
    )

fn ide_markdown_render_summary() -> text:
    val probe = ide_markdown_render_probe()
    "markdown: " + probe.owner_module + " blocks=" + probe.block_count.to_text() + " lines=" + probe.rendered_line_count.to_text() + " preview=" + probe.preview_line_count.to_text() + " heading=" + probe.contains_heading.to_text() + " table=" + probe.contains_table.to_text() + " task_list=" + probe.contains_task_list.to_text() + " strike=" + probe.contains_strikethrough.to_text() + " link=" + probe.contains_link.to_text() + " list=" + probe.contains_list.to_text() + " ordered_list=" + probe.contains_ordered_list.to_text() + " css_doc=" + probe.css_document.to_text() + " escaped=" + probe.escapes_html.to_text() + " metadata=" + probe.preview_metadata.to_text()

fn ide_markdown_obsidian_summary() -> text:
    val p = ide_markdown_obsidian_probe()
    "obsidian: wiki=" + p.wiki_link_block_count.to_text() + " embed=" + p.embed_block_count.to_text() + " callout=" + p.callout_block_count.to_text() + " table=" + p.table_block_count.to_text() + " fence=" + p.unclosed_fence_block_count.to_text() + " empty_safe=" + p.empty_source_safe.to_text() + " malformed_safe=" + p.malformed_source_safe.to_text()
