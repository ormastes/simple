# IDE Draw/SDD capability probe.
#
# Keeps the IDE feature-check surface pure while proving that the SDD-backed
# Draw app path can render, select, inspect, edit, reroute, align/distribute,
# and preserve canvas metadata without starting GUI/browser/host APIs.

use std.editor.services.sdn_graph.{sdn_graph_add_edge, sdn_graph_add_node_checked, sdn_graph_align_checked, sdn_graph_delete_edge_at, sdn_graph_delete_node_at, sdn_graph_delete_style_rule_checked, sdn_graph_distribute_checked, sdn_graph_duplicate_edge_checked, sdn_graph_file_extension, sdn_graph_geometry_signature, sdn_graph_inspect_edge, sdn_graph_inspect_node, sdn_graph_inspect_style_rule, sdn_graph_parse, sdn_graph_render_html, sdn_graph_render_html_with_selection, sdn_graph_reorder_node_checked, sdn_graph_set_style_rule_checked, sdn_graph_update_canvas, sdn_graph_update_edge_at, sdn_graph_update_edge_endpoints_at, sdn_graph_update_edge_kind_at, sdn_graph_update_edge_label_point_at, sdn_graph_update_edge_style_at, sdn_graph_update_node_at, sdn_graph_update_node_layer_at, sdn_graph_update_node_parent_at, sdn_graph_update_node_role_at, sdn_graph_update_node_shape_at, sdn_graph_update_node_style_at}

struct IdeDrawSanityProbe:
    owner_module: text
    node_count: i64
    edge_count: i64
    html_render: bool
    selected_render: bool
    node_create: bool
    style_rule_edit: bool
    style_rule_delete: bool
    style_rule_inspect: bool
    edge_create: bool
    edge_duplicate: bool
    edge_label_point_edit: bool
    reroute_edit: bool
    node_edit: bool
    node_geometry_edit: bool
    node_layer_edit: bool
    node_order_edit: bool
    node_role_edit: bool
    edge_style_edit: bool
    edge_kind_edit: bool
    reconnect_edit: bool
    delete_edit: bool
    node_delete_edit: bool
    inspector: bool
    group_child_metadata: bool
    connector_path_metadata: bool
    connector_handle_metadata: bool
    layout_edit: bool
    canvas_metadata: bool

fn ide_draw_sanity_probe() -> IdeDrawSanityProbe:
    val graph = sdn_graph_parse("graph: DrawCheck\ncanvas: width: 800 height: 600 grid: 10 snap: false zoom: 100 background: white\nA: Start @plain role: source shape: rect x: 0 y: 0 width: 80 height: 20\nB: End @target role: sink shape: rounded x: 160 y: 0 width: 80 height: 20\nA -> B: flow @primary route: simple start: right end: left")
    val style_rule = sdn_graph_set_style_rule_checked(graph, "accent", "node", "none", "fill", "#ffffff")
    val style_inspector = sdn_graph_inspect_style_rule(style_rule.graph, "accent", "fill")
    val style_deleted = sdn_graph_delete_style_rule_checked(style_rule.graph, "accent", "fill")
    val deleted_style_inspector = sdn_graph_inspect_style_rule(style_deleted.graph, "accent", "fill")
    val node_created = sdn_graph_add_node_checked(graph, "C", "Decision", "accent", "decision", "diamond", "80", "80", "64", "48", "front", "")
    val created = sdn_graph_add_edge(node_created.graph, "B", "A", "return", "secondary", "reply", "simple", "", "left", "right")
    val edge_duplicated = sdn_graph_duplicate_edge_checked(created, 1)
    val rerouted = sdn_graph_update_edge_at(created, 0, "orthogonal", "120x10;120x40", "right", "left")
    val edge_labeled_point = sdn_graph_update_edge_label_point_at(rerouted, 0, "140", "32")
    val edge_styled = sdn_graph_update_edge_style_at(edge_labeled_point, 0, "warning dashed")
    val edge_kind = sdn_graph_update_edge_kind_at(edge_styled, 0, "async")
    val reconnected = sdn_graph_update_edge_endpoints_at(edge_kind, 0, "B", "A")
    val edge_deleted = sdn_graph_delete_edge_at(reconnected, 0)
    val node_deleted = sdn_graph_delete_node_at(edge_styled, 1)
    val moved = sdn_graph_update_node_at(edge_styled, 1, "target", "sink", "rounded", "184", "24", "96", "28", "")
    val shaped = sdn_graph_update_node_shape_at(edge_styled, 1, "cylinder")
    val styled = sdn_graph_update_node_style_at(shaped, 1, "storage selected")
    val layered = sdn_graph_update_node_layer_at(styled, 1, "front")
    val ordered = sdn_graph_reorder_node_checked(layered, "A", "front")
    val roled = sdn_graph_update_node_role_at(layered, 1, "database")
    val grouped = sdn_graph_update_node_parent_at(roled, 1, "A")
    val canvas = sdn_graph_update_canvas(grouped, "1024", "768", "16", "true", "125", "#ffffff")
    val html = sdn_graph_render_html(canvas)
    val selected = sdn_graph_render_html_with_selection(canvas, "B", 0)
    val node = sdn_graph_inspect_node(canvas, "B")
    val edge = sdn_graph_inspect_edge(canvas, 0)
    val layout_graph = sdn_graph_parse("graph: Layout\nB: B x: 120 y: 120 width: 20 height: 20\nA: A x: 0 y: 0 width: 20 height: 20\nC: C x: 20 y: 20 width: 20 height: 20")
    val layout_ids = ["A", "B", "C"]
    val layout_signature = sdn_graph_geometry_signature(layout_graph, layout_ids)
    val aligned = sdn_graph_align_checked(layout_graph, layout_ids, layout_signature, "left")
    val distributed = sdn_graph_distribute_checked(layout_graph, layout_ids, layout_signature, "horizontal")
    IdeDrawSanityProbe(
        owner_module: "std.editor.services.sdn_graph",
        node_count: canvas.nodes.len(),
        edge_count: canvas.edges.len(),
        html_render: html.contains("class=\"sdn-graph sdd-diagram\"") and html.contains("data-canvas-grid=\"16\""),
        selected_render: selected.contains("data-selected=\"true\" aria-selected=\"true\"") and selected.contains("data-resize-handle=\"se\" data-node=\"B\" data-node-index=\"1\"") and selected.contains("data-connector-handle=\"end\" data-edit-action=\"reconnect-end\" data-handle-index=\"1\"") and selected.contains("data-node=\"B\" data-opposite-node=\"A\"") and selected.contains("data-connector-handle=\"waypoint\" data-edit-action=\"move-waypoint\" data-handle-index=\"3\"") and selected.contains("data-connector-handle=\"label\" data-edit-action=\"move-label\" data-handle-index=\"2\""),
        node_create: node_created.accepted and node_created.graph.nodes.len() == 3 and node_created.graph.nodes[2].id == "C",
        style_rule_edit: style_rule.accepted and style_rule.graph.css_defs.len() == 1 and style_rule.graph.styles.len() == 1 and style_rule.graph.styles[0].key == "fill",
        style_rule_delete: style_deleted.accepted and style_deleted.graph.css_defs.len() == 1 and style_deleted.graph.styles.len() == 0 and deleted_style_inspector.reason == "missing-style-rule",
        style_rule_inspect: style_inspector.found and style_inspector.value == "#ffffff",
        edge_create: created.edges.len() == 2 and created.edges[1].label == "return",
        edge_duplicate: edge_duplicated.accepted and edge_duplicated.graph.edges.len() == 3 and edge_duplicated.graph.edges[2].label == "return",
        edge_label_point_edit: edge.label_x == "140" and edge.label_y == "32" and html.contains("data-label-x=\"140\" data-label-y=\"32\""),
        reroute_edit: edge.path == "M 80,10 L 120,10 L 120,40 L 160,40 L 160,10",
        node_edit: node.shape == "cylinder" and node.css == "storage selected" and node.parent == "A" and html.contains("box-shadow:inset 0 8px 0 rgba(15,23,42,0.08)"),
        node_geometry_edit: moved.nodes[1].x == "184" and moved.nodes[1].width == "96",
        node_layer_edit: layered.nodes[1].layer == "front",
        node_order_edit: ordered.accepted and ordered.graph.nodes[ordered.graph.nodes.len() - 1].id == "A",
        node_role_edit: roled.nodes[1].role == "database",
        edge_style_edit: edge.css == "warning dashed" and html.contains("sdn-css-warning sdn-css-dashed"),
        edge_kind_edit: edge_kind.edges[0].kind == "async",
        reconnect_edit: sdn_graph_render_html(reconnected).contains("data-from=\"B\" data-to=\"A\""),
        delete_edit: edge_deleted.edges.len() == 1 and edge_deleted.edges[0].label == "return",
        node_delete_edit: node_deleted.nodes.len() == 2 and node_deleted.nodes[1].id == "C" and node_deleted.edges.len() == 0,
        inspector: node.found and edge.found,
        group_child_metadata: node.child_count == "0" and node.child_bounds == "" and sdn_graph_inspect_node(canvas, "A").child_count == "1" and sdn_graph_inspect_node(canvas, "A").child_bounds == "160,0,240,20",
        connector_path_metadata: edge.path_bounds == "80,10,160,40" and edge.segment_count == "4" and edge.segments == "80,10-120,10;120,10-120,40;120,40-160,40;160,40-160,10" and edge.segment_midpoints == "100,10;120,25;140,40;160,25" and edge.segment_orientations == "h;v;h;v",
        connector_handle_metadata: selected.contains("data-connector-handle=\"start\" data-edit-action=\"reconnect-start\" data-handle-index=\"0\"") and selected.contains("data-connector-handle=\"end\" data-edit-action=\"reconnect-end\" data-handle-index=\"1\"") and selected.contains("data-connector-handle=\"label\" data-edit-action=\"move-label\" data-handle-index=\"2\"") and selected.contains("data-connector-handle=\"waypoint\" data-edit-action=\"move-waypoint\" data-handle-index=\"3\""),
        layout_edit: aligned.accepted and aligned.graph.nodes[0].x == "0" and distributed.accepted and distributed.graph.nodes[0].x == "120" and distributed.graph.nodes[2].x == "60",
        canvas_metadata: canvas.canvas_width == "1024" and canvas.canvas_snap == "true" and html.contains("background-color:#ffffff") and html.contains("background-size:16px 16px")
    )

fn ide_draw_sanity_summary() -> text:
    val probe = ide_draw_sanity_probe()
    "draw: sdn_graph format=sdd name=\"SDD: Simple Diagram Document\" extension={sdn_graph_file_extension()} nodes={probe.node_count} edges={probe.edge_count} html={probe.html_render} route={probe.reroute_edit} select={probe.selected_render} inspect={probe.inspector} child_meta={probe.group_child_metadata} path_meta={probe.connector_path_metadata} handle_meta={probe.connector_handle_metadata} edit={probe.node_edit} geometry={probe.node_geometry_edit} layer={probe.node_layer_edit} order={probe.node_order_edit} role={probe.node_role_edit} node_create={probe.node_create} style_rule={probe.style_rule_edit} style_delete={probe.style_rule_delete} style_inspect={probe.style_rule_inspect} edge_create={probe.edge_create} edge_duplicate={probe.edge_duplicate} edge_label_point={probe.edge_label_point_edit} edge_style={probe.edge_style_edit} edge_kind={probe.edge_kind_edit} reconnect={probe.reconnect_edit} delete={probe.delete_edit} node_delete={probe.node_delete_edit} layout={probe.layout_edit} canvas={probe.canvas_metadata}"
