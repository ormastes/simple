# IDE feature-check report.
#
# Keeps executable sanity checks separate from capability metadata so each probe
# runs directly against its owning subsystem instead of being precomputed inside
# the registry.

use app.ide.sheets_compat.{ide_sheet_compat_summary}
use app.ide.slides_compat.{ide_slide_compat_summary}
use app.ide.db_admin.{ide_db_admin_summary}
use app.ide.agent_dashboard.{ide_agent_dashboard_summary}
use app.ide.draw_sanity.{ide_draw_sanity_summary}
use app.ide.markdown_render.{ide_markdown_render_summary}
use app.ide.launch_sanity.{ide_launch_sanity_summary}
use app.ide.plugin_manifest.{ide_plugin_manifest_summary}
use app.ide.gui_sanity.{ide_gui_sanity_summary}
use app.ide.tui_sanity.{ide_tui_sanity_summary}
use app.ide.capabilities.{ide_capability_count}
use app.office.llm_catalog.{office_llm_catalog_app_names, office_llm_catalog_summary}
use app.office.md_wysiwyg.{build_wysiwyg_view, wysiwyg_update_line_checked}
use app.office.ui_editor.{office_ui_design_parse, office_ui_design_render_html_with_selection, office_ui_design_to_sdd}
use app.office.word.html_render.{render_writer_markdown_html}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.slides.slide.{blank_slide, add_text_box, slide_update_text_checked}

fn ide_office_edit_command_summary() -> text:
    val view = build_wysiwyg_view("first\nactual")
    val rejected = wysiwyg_update_line_checked(view, 1, "expected", "changed")
    val accepted = wysiwyg_update_line_checked(view, 1, "actual", "changed")
    "md-edit={accepted.accepted} stale-reject={not rejected.accepted} reason={rejected.reason}"

fn ide_writer_markdown_summary() -> text:
    val html = render_writer_markdown_html("# Writer\n\nBody <tag>")
    val markdown = html.contains("Writer") and html.contains("Body")
    val paper = html.contains("markdown-paper") or html.contains("office-paper")
    val escaped = html.contains("&lt;tag&gt;")
    "writer: app.office.word.html_render markdown={markdown} html={html.contains(\"<\")} paper={paper} escaped={escaped}"

fn ide_sheet_edit_command_summary() -> text:
    val sheet = Sheet.new("FeatureCheck")
    sheet.set_value("A1", "actual")
    val rejected = sheet.update_cell_checked("A1", "expected", "changed")
    val accepted = sheet.update_cell_checked("A1", "actual", "changed")
    "sheet-edit={accepted.accepted} stale-reject={not rejected.accepted} reason={rejected.reason}"

fn ide_slide_edit_command_summary() -> text:
    val slide = add_text_box(blank_slide("feature_check"), "title", "actual", 40, 40, 840, 60)
    val rejected = slide_update_text_checked(slide, "title", "expected", "changed")
    val accepted = slide_update_text_checked(slide, "title", "actual", "changed")
    "slide-edit={accepted.accepted} stale-reject={not rejected.accepted} reason={rejected.reason}"

fn ide_designer_metadata_summary() -> text:
    val source = "design: Feature Check\nnode button|Run|button|16|16|80|32|primary|controls|action"
    val design = office_ui_design_parse(source)
    val html = office_ui_design_render_html_with_selection(design, "button")
    val sdd = office_ui_design_to_sdd(design)
    val html_ok = html.contains("data-format=\"html-ui\"") and html.contains("data-selected-node-id=\"button\"")
    val sdd_ok = sdd.contains("theme: office-ui") and sdd.contains("nodes |id")
    val selection = html.contains("office-ui-selected")
    val metadata = html.contains("data-resize-handle=\"se\"") and html.contains("data-handle-label=\"Resize southeast\"") and html.contains("data-delta-x=\"1\" data-delta-y=\"1\"")
    "designer: app.office.ui_editor html={html_ok} sdd={sdd_ok} selection={selection} resize_handle_metadata={metadata}"

fn ide_feature_check_report(mode: text) -> [text]:
    var lines: [text] = []
    lines.push("Simple IDE feature check")
    lines.push("mode: {mode}")
    lines.push("capabilities: {ide_capability_count()}")
    lines.push("markdown: Markdown Preview [document-renderer] -> std.editor.render.md_renderer (md, markdown)")
    lines.push("  check: " + ide_markdown_render_summary())
    lines.push("  edit-command: " + ide_office_edit_command_summary())
    lines.push("writer: Markdown Writer [office-app] -> app.office.word.html_render (writer, md, markdown, html)")
    lines.push("  check: " + ide_writer_markdown_summary())
    lines.push("slides: Presentation Slides [office-app] -> app.office.slides (ppt, presentation, slides)")
    lines.push("  check: " + ide_slide_compat_summary())
    lines.push("  edit-command: " + ide_slide_edit_command_summary())
    lines.push("draw: SDD Diagram Draw [office-app] -> std.editor.services.sdn_graph (draw, diagram, sdd, sdn)")
    lines.push("  check: " + ide_draw_sanity_summary())
    lines.push("designer: UI Designer [office-app] -> app.office.ui_editor (figma, html, sdd, ui)")
    lines.push("  check: " + ide_designer_metadata_summary())
    lines.push("sheets: Spreadsheet [office-app] -> app.office.sheets (excel, xlsx, tabular, csv)")
    lines.push("  check: " + ide_sheet_compat_summary())
    lines.push("  edit-command: " + ide_sheet_edit_command_summary())
    lines.push("  gui: " + ide_gui_sanity_summary())
    lines.push("agent-dashboard: Agent Dashboard [dashboard] -> app.editor.mcp_tools (agent, dashboard, mcp)")
    lines.push("  check: " + ide_agent_dashboard_summary())
    lines.push("db-admin: Database Admin [database] -> std.editor.core.session_db (embedded-db, simple-db, portal-db)")
    lines.push("  check: " + ide_db_admin_summary())
    lines.push("  tui: " + ide_tui_sanity_summary())
    lines.push("  launch: " + ide_launch_sanity_summary())
    lines.push("  plugin-manifest: " + ide_plugin_manifest_summary())
    lines.push("  " + office_llm_catalog_summary())
    lines.push("  llm-apps: " + office_llm_catalog_app_names().join(","))
    return lines
