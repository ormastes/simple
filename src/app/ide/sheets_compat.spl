# IDE spreadsheet compatibility surface.
#
# Thin checks over the existing office sheets model. This module gives the IDE
# a tabular/Excel-like capability contract without introducing a second sheet
# or formula implementation.

use app.office.sheets.spreadsheet.{Workbook}
use app.office.sheets.cell.{Cell, cell_display_text, default_style}
use app.office.sheets.formula.{evaluate_formula}

struct IdeSheetCompat:
    app_id: text
    owner_module: text
    compatible_formats: [text]
    sample_range: text
    formula_probe: text

fn ide_sheet_compat_probe() -> IdeSheetCompat:
    var workbook = Workbook.new("IDE Spreadsheet")
    var sheet = workbook.active()
    sheet.set_value("A1", "2")
    sheet.set_value("B1", "3")
    sheet.set_value("C1", "=A1+B1")
    val result = evaluate_formula("A1+B1", sheet)
    IdeSheetCompat(
        app_id: "sheets",
        owner_module: "app.office.sheets",
        compatible_formats: ["excel", "xlsx", "csv", "tabular"],
        sample_range: sheet.used_range(),
        formula_probe: cell_display_text(Cell(value: result, style: default_style()))
    )

fn ide_sheet_compat_summary() -> text:
    val compat = ide_sheet_compat_probe()
    "sheets: {compat.owner_module} formats={compat.compatible_formats.join(\",\")} range={compat.sample_range} formula={compat.formula_probe}"
