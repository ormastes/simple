# Feature Documentation Generator - Usage (Cucumber-like) Doc Generator
#
# Generates Cucumber-style documentation from test/feature/usage/ spec files.
# Maps: context -> Scenario, it -> Example, expect -> Then step

use app.io.mod (file_write, dir_create)
use app.feature_doc.types.*

fn render_doc_block(block: text, skip_top_title: bool) -> text:
    """Strip duplicated headings and metadata from a parsed doc block."""
    val lines = block.split("\n")
    var out: [text] = []
    var skip_title = skip_top_title

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            if out.len() > 0 and out[-1] != "":
                out.push("")
            continue
        if skip_title and trimmed.starts_with("# ") and not trimmed.starts_with("## "):
            skip_title = false
            continue
        if trimmed.starts_with("## ") or trimmed.starts_with("### "):
            continue
        if trimmed.starts_with("**Feature") or trimmed.starts_with("**Category") or trimmed.starts_with("**Status") or trimmed.starts_with("**Keywords") or trimmed.starts_with("**Difficulty") or trimmed.starts_with("*Source:*"):
            continue
        out.push(trimmed)
    out.join("\n").trim()

# ============================================================================
# Usage Doc Generation
# ============================================================================

fn generate_usage_doc(info: FeatureFileInfo, output_dir: text) -> text:
    """Generate a Cucumber-like markdown doc from a feature file.

    Returns the output path on success, empty string on failure.
    """
    var md_parts: [text] = []

    # Title
    md_parts.push("# {info.title}\n")
    md_parts.push("*Source:* `{info.file_path}`\n")

    # Metadata line
    var meta_parts = []
    if info.metadata.feature_ids != "":
        meta_parts.push("**Feature IDs:** {info.metadata.feature_ids}")
    if info.metadata.category != "":
        meta_parts.push("**Category:** {info.metadata.category}")
    if info.metadata.status != "":
        meta_parts.push("**Status:** {info.metadata.status}")
    if meta_parts.len() > 0:
        md_parts.push(meta_parts.join("  |  ") + "\n")
    md_parts.push("\n")

    # Overview from first doc block
    if info.doc_blocks.len() > 0:
        val overview = render_doc_block(info.doc_blocks[0], true)
        if overview != "":
            md_parts.push("## Overview\n\n")
            md_parts.push(overview + "\n\n")

    # Describe blocks -> Feature sections
    for desc in info.describes:
        md_parts.push("## Feature: {desc.name}\n\n")

        if desc.doc != "":
            val desc_doc = render_doc_block(desc.doc, false)
            if desc_doc != "":
                md_parts.push(desc_doc + "\n\n")

        # Context blocks -> Scenario sections
        for ctx in desc.contexts:
            if ctx.name != "":
                md_parts.push("### Scenario: {ctx.name}\n\n")
            else:
                md_parts.push("### Scenario: General\n\n")

            if ctx.doc != "":
                val ctx_doc = render_doc_block(ctx.doc, false)
                if ctx_doc != "":
                    md_parts.push(ctx_doc + "\n\n")

            # Examples table
            if ctx.its.len() > 0:
                md_parts.push("| # | Example | Status |\n")
                md_parts.push("|---|---------|--------|\n")
                var idx = 1
                for it_block in ctx.its:
                    var status = "pass"
                    # Check if any expect line contains pass_todo
                    for exp in it_block.expects:
                        if exp.contains("pass_todo"):
                            status = "pending"
                    md_parts.push("| {idx} | {it_block.name} | {status} |\n")
                    idx = idx + 1
                md_parts.push("\n")

            # Expanded examples with Given/Then
            for it_block in ctx.its:
                if it_block.expects.len() > 0:
                    md_parts.push("**Example:** {it_block.name}\n")
                    for exp in it_block.expects:
                        val et = exp.trim()
                        if et.starts_with("val ") or et.starts_with("var "):
                            md_parts.push("    Given {et}\n")
                        elif et.starts_with("expect"):
                            md_parts.push("    Then  {et}\n")
                    md_parts.push("\n")

    # Write output
    val filename = extract_doc_filename(info.file_path)
    val output_path = "{output_dir}/{filename}.md"
    dir_create(output_dir, true)
    file_write(output_path, md_parts.join(""))
    output_path

fn extract_doc_filename(file_path: text) -> text:
    """Get doc filename from spec path (strip _spec.spl)."""
    val parts = file_path.split("/")
    val filename = parts[-1]
    if filename.ends_with("_spec.spl"):
        return filename[:-9]
    if filename.ends_with("_test.spl"):
        return filename[:-9]
    if filename.ends_with(".spl"):
        return filename[:-4]
    filename
