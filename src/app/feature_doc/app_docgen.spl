# Feature Documentation Generator - App (Manual-like) Doc Generator
#
# Generates user-manual style documentation from test/feature/app/ spec files.
# Maps: describe -> Command/Feature section, context -> When subsection, it -> bullet

use app.io.mod (file_write, dir_create)
use app.feature_doc.types.*
use app.feature_doc.usage_docgen (extract_doc_filename)

fn render_doc_block(block: text, skip_top_title: bool) -> text:
    """Strip duplicated headings and metadata from a parsed doc block."""
    val lines = block.split("\n")
    var out: [text] = []
    var skip_title = skip_top_title

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            if out.len() > 0 and out[-1] != "":
                out.push("")
            continue
        if skip_title and trimmed.starts_with("# ") and not trimmed.starts_with("## "):
            skip_title = false
            continue
        if trimmed.starts_with("## ") or trimmed.starts_with("### "):
            continue
        if trimmed.starts_with("**Feature") or trimmed.starts_with("**Category") or trimmed.starts_with("**Status") or trimmed.starts_with("**Keywords") or trimmed.starts_with("*Source:*"):
            continue
        out.push(trimmed)
    out.join("\n").trim()

# ============================================================================
# App Doc Generation
# ============================================================================

fn generate_app_doc(info: FeatureFileInfo, output_dir: text) -> text:
    """Generate a manual-like markdown doc from an app feature file.

    Returns the output path on success, empty string on failure.
    """
    var md = ""

    # Title
    md = md + "# {info.title}\n"
    md = md + "*Source:* `{info.file_path}`\n\n"

    # Overview from first doc block
    if info.doc_blocks.len() > 0:
        val overview = render_doc_block(info.doc_blocks[0], true)
        if overview != "":
            md = md + "## Overview\n\n"
            md = md + overview + "\n\n"

    # Behavior section from describe/context/it structure
    if info.describes.len() > 0:
        md = md + "## Behavior\n\n"

        for desc in info.describes:
            # Only add describe heading if more than one
            if info.describes.len() > 1:
                md = md + "### {desc.name}\n\n"

            if desc.doc != "":
                val desc_doc = render_doc_block(desc.doc, false)
                if desc_doc != "":
                    md = md + desc_doc + "\n\n"

            for ctx in desc.contexts:
                if ctx.name != "":
                    md = md + "### When {ctx.name}\n\n"

                if ctx.doc != "":
                    val ctx_doc = render_doc_block(ctx.doc, false)
                    if ctx_doc != "":
                        md = md + ctx_doc + "\n\n"

                # Its as bullet points
                for it_block in ctx.its:
                    md = md + "- {it_block.name}\n"

                md = md + "\n"

    # Write output
    val filename = extract_doc_filename(info.file_path)
    val output_path = "{output_dir}/{filename}.md"
    dir_create(output_dir, true)
    file_write(output_path, md)
    output_path
