# Electron Application Main Loop
#
# Runs the Electron mode: loads .ui.sdn, renders HTML via IPC,
# polls stdin for JSON events from the Electron shell.
#
# NOTE: Uses module-level functions instead of class methods to avoid
# interpreter method-dispatch bug on imported classes.

use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state, update_state, update_tree, is_quit_event}
use app.ui.electron.backend.{ElectronBackend}
use app.ui.electron.ipc.{parse_ipc_message, build_ipc_render}
use app.ui.render.widgets.{render_html_tree}
use app.ui.web.html.{generate_css}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_stdin_read_line() -> text?

# =========================================================================
# Standalone helpers (avoid interpreter method-dispatch issues)
# =========================================================================

fn _do_render(state: UIState):
    """Render the current state and send via IPC to stdout."""
    var tree = state.tree
    val theme = tree.theme_name()
    val css = generate_css(theme)
    val root = tree.root_node()
    val body_html = render_html_tree(root, state)
    val html = "<html><head><style>{css}</style></head><body><div id=\"app\">{body_html}</div></body></html>"
    val ipc_msg = build_ipc_render(html)
    print ipc_msg

fn _poll_ipc() -> UIEvent?:
    """Read a line from stdin and parse as IPC message."""
    val line = rt_stdin_read_line()
    if line == nil:
        return nil
    if line == "":
        return nil
    return parse_ipc_message(line)

fn _check_file_changes(file_path: text, last_content: text, state: UIState) -> (text, UIState):
    """Check if the .ui.sdn file has changed and reload if so.
    Returns (new_content, new_state)."""
    if not rt_file_exists(file_path):
        return (last_content, state)

    val current_content = rt_file_read_text(file_path)
    if current_content != last_content:
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Ok(new_tree):
                return (current_content, update_tree(state, new_tree))
            Err(e):
                return (current_content, state)
    return (last_content, state)

# =========================================================================
# Entry Point
# =========================================================================

fn run_electron(file_path: text, port: i32) -> i64:
    """Start Electron mode for a .ui.sdn file."""
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    var tree_result = parse_ui_to_tree(file_path)
    if tree_result.is_err():
        print "Error: {tree_result.unwrap_err()}"
        return 1
    var tree = tree_result.unwrap()
    var state = init_state(tree)
    var last_content = rt_file_read_text(file_path)
    var running = true

    # Initial render
    _do_render(state)

    # Main IPC loop
    while running:
        val event = _poll_ipc()
        if event != nil:
            match event:
                UIEvent.Quit:
                    running = false
                _:
                    state = update_state(state, event)
                    val result = _check_file_changes(file_path, last_content, state)
                    last_content = result.0
                    state = result.1
                    _do_render(state)
        else:
            val result = _check_file_changes(file_path, last_content, state)
            last_content = result.0
            state = result.1

    return 0
