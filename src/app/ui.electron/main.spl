# Electron Main-Process Entry Point (V4, Row 6)
#
# Describes the Simple-side contract for the external Electron shell.
# The real BrowserWindow lifecycle is owned by `tools/electron-shell/`,
# while this module emits the stdout JSON commands that shell already
# consumes and keeps the compositor/IPC wiring state on the Simple side.
#
# Dev-preview only — per
# `doc/01_research/domain/v4_electron_packaging_2026-04-14.md` Electron is
# not shipped as a first-class target and must not be added to CI.
#
# The real Electron process is launched out-of-band via
# `tools/electron-shell/` and listens for line-delimited JSON messages on
# the Simple process stdout. This module stays compile-safe and dev-preview
# only, but it now follows the live shell contract instead of a future
# direct-node-binding design.
#
# Depends on:
#   - os.compositor.electron_capture       (scene capture entry points)
#   - os.compositor.wm_scene                (WmSceneSpec)
#   - app.ui.electron.backend               (ElectronBackend)
#   - app.ui.ipc.protocol                   (IPC bridges: FS + notification)

use os.compositor.electron_capture.{
    CaptureResult,
    capture_electron_scene,
    display_in_electron,
    capture_error}
use os.compositor.wm_scene.{WmSceneSpec}
use app.ui.electron.backend.{ElectronBackend}
use app.ui.ipc.protocol.{
    build_ipc_window_control,
    build_ipc_file_dialog,
    build_ipc_notification}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry}

# =========================================================================
# ElectronMain — owns BrowserWindow + compositor backend wiring
# =========================================================================

class ElectronMain:
    backend: ElectronBackend
    window_id: text
    window_url: text
    width: i32
    height: i32
    title: text
    running: bool
    compositor_wired: bool

    static fn new(width: i32, height: i32, title: text, port: i32)
            -> Result<ElectronMain, text>:
        val be = ElectronBackend.new(port)
        match be:
            Ok(backend):
                return Ok(ElectronMain(
                    backend: backend,
                    window_id: "electron-main",
                    window_url: "about:blank",
                    width: width,
                    height: height,
                    title: title,
                    running: false,
                    compositor_wired: false))
            Err(e):
                return Err("ElectronMain: backend init failed: {e}")

    # ---- Lifecycle ----

    me start() -> Result<bool, text>:
        val init_res = self.backend.init()
        match init_res:
            Err(e):
                return Err("ElectronMain: backend init failed: {e}")
            _:
                pass_dn
        self.backend.new_browser_window(
            self.window_id,
            self.window_url,
            self.width,
            self.height,
            self.title
        )
        self.running = true
        # Wire the renderer to the electron_capture compositor path so
        # the BrowserWindow displays pixels produced by the shared
        # BrowserCompositorBackend — the exact same path wm_compare uses
        # for its A/B parity screenshots.
        self.compositor_wired = self._wire_compositor_backend()
        return Ok(self.compositor_wired)

    me stop():
        if self.running:
            self.backend.close_browser_window(self.window_id)
            self.backend.shutdown()
            self.running = false
            self.compositor_wired = false

    # ---- Compositor wire-up (renderer <-> electron_capture) ----

    me _wire_compositor_backend() -> bool:
        """Hand the renderer process over to electron_capture.

        The renderer does NOT draw its own DOM when running in V4 parity
        mode — instead it receives a pixel buffer produced by
        BrowserCompositorBackend and blits it into a <canvas>. This keeps
        V4 bit-identical with V2/V3 in wm_compare.
        """
        # TODO(v4-dev-preview): post a 'bind_compositor' control message
        # telling the renderer to switch into canvas-blit mode.
        val ctrl = build_ipc_window_control("bind_compositor")
        print ctrl
        true

    me present_scene(scene: WmSceneSpec) -> CaptureResult:
        """Render `scene` through BrowserCompositorBackend and display it
        in the Electron BrowserWindow.

        This is the V4 hot path the wm_compare source-A pipeline exercises
        when --source=A is requested.
        """
        if not self.compositor_wired:
            return capture_error(
                "electron_main", self.width, self.height,
                "compositor backend not wired — call start() first")
        val capture = capture_electron_scene(scene)
        if capture.success:
            display_in_electron(capture.pixels, capture.width, capture.height)
        return capture

    # ---- ui.ipc bridges (filesystem + notifications) ----

    me notify(title: text, body: text) -> bool:
        """Forward a native notification request through ui.ipc."""
        # TODO(v4-dev-preview): the renderer relays this to the OS
        # notification center via Electron's Notification API.
        val msg = build_ipc_notification(title, body)
        print msg
        return true

    me open_file_dialog(kind: text, filters: text) -> bool:
        """Forward an open/save dialog request through ui.ipc."""
        # TODO(v4-dev-preview): bridge to Electron dialog.showOpenDialog /
        # dialog.showSaveDialog in the main process.
        val msg = build_ipc_file_dialog(kind, filters)
        print msg
        return true

    # ---- Introspection (used by the smoke spec) ----

    me is_compositor_wired() -> bool:
        return self.compositor_wired

    me is_running() -> bool:
        return self.running

    me backend_name() -> text:
        return self.backend.backend_name()

    me shell_transport_name() -> text:
        return "electron-shell-stdout-json"

    me shell_window_id() -> text:
        return self.window_id

# =========================================================================
# Entry Point
# =========================================================================

# =========================================================================
# Wave 5: Registry integration — Electron windows register with
# surface_kind "Electron" so wm_bridge can address them uniformly with
# SimpleWeb windows. Callers invoke this after new_browser_window so
# the authoritative surface registry reflects a live Electron surface.
# =========================================================================

fn register_electron_window(reg: UiWindowSurfaceRegistry, surface_id: text, window_id: text, process_id: u64, app_id: text, title: text):
    """Bind a freshly-spawned Electron BrowserWindow into the registry."""
    reg.bind_with_kind(window_id, surface_id, process_id, app_id, title, "Electron")

fn run_electron_main(width: i32, height: i32, title: text, port: i32) -> i64:
    """Dev-preview entry point — creates an ElectronMain, wires the
    compositor backend, and returns a status code. Not used in CI."""
    val res = ElectronMain.new(width, height, title, port)
    match res:
        Err(e):
            print "[ui.electron.main] {e}"
            return 1
        Ok(app):
            val start_res = app.start()
            match start_res:
                Err(e):
                    print "[ui.electron.main] start failed: {e}"
                    return 1
                Ok(wired):
                    if not wired:
                        print "[ui.electron.main] compositor not wired"
                        return 1
                    return 0
