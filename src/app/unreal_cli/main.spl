# Unreal CLI Tool - project scaffolding.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.io_runtime.{dir_create_all, file_write, file_exists}
use std.log.{error}

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("unreal-cli", log_opts.error)
        return 1

    val args = unreal_clean_log_args(raw_args)
    if args.len() == 0 or args[0] == "--help" or args[0] == "-h":
        if log_opts.log_mode == "json" and args.len() == 0:
            print "{\"command\":\"unreal-cli\",\"status\":\"ready\"}"
            return 0
        print_help_with_progress(log_opts.progress)
        return 0

    val command = args[0]
    if command == "new":
        return cmd_new(args, log_opts.log_mode, log_opts.progress)
    if command == "add-module":
        return cmd_add_module(args, log_opts.log_mode, log_opts.progress)
    if command == "generate-bindings":
        return cmd_generate_bindings(args, log_opts.log_mode, log_opts.progress)

    if log_opts.log_mode == "json":
        print "{\"command\":\"unreal-cli\",\"status\":\"error\",\"error\":\"unknown command\"}"
        return 1
    print "Unknown command: {command}"
    print_help()
    1

fn print_help():
    print "Usage: simple unreal-cli <command> [options]"
    print ""
    print "Commands:"
    print "  new <project_name> [--path <path>] [--version <ue_version>]"
    print "  add-module <module_name> [--type <Runtime|Editor>]"
    print "  generate-bindings <class_name>"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn cmd_new(args: [text], log_mode: text, progress_mode: text) -> i64:
    if args.len() < 2:
        return print_error("unreal-cli", "project name required", log_mode)

    val project_name = args[1]
    var base_path = "."
    var ue_version = "5.4"
    var i = 2
    while i < args.len():
        if args[i] == "--path" and i + 1 < args.len():
            base_path = args[i + 1]
            i = i + 2
        elif args[i] == "--version" and i + 1 < args.len():
            ue_version = args[i + 1]
            i = i + 2
        else:
            i = i + 1

    val project_path = "{base_path}/{project_name}"
    create_project_structure(project_path, project_name, ue_version)

    if log_mode == "json":
        print "{\"command\":\"unreal-cli\",\"status\":\"ok\",\"action\":\"new\",\"project\":\"{project_name}\",\"path\":\"{project_path}\"}"
        return 0

    val progress = render_progress(progress_mode, 1, 1, "unreal project")
    if progress != "":
        print progress
    print "Created Unreal project: {project_name}"
    print "Path: {project_path}"
    0

fn cmd_add_module(args: [text], log_mode: text, progress_mode: text) -> i64:
    if args.len() < 2:
        return print_error("unreal-cli", "module name required", log_mode)

    val module_name = args[1]
    var module_type = "Runtime"
    var i = 2
    while i < args.len():
        if args[i] == "--type" and i + 1 < args.len():
            module_type = args[i + 1]
            i = i + 2
        else:
            i = i + 1

    val module_path = "Source/{module_name}"
    dir_create_all(module_path)
    file_write("{module_path}/{module_name}.Build.cs", generate_module_build_cs(module_name, module_type))

    if log_mode == "json":
        print "{\"command\":\"unreal-cli\",\"status\":\"ok\",\"action\":\"add-module\",\"module\":\"{module_name}\",\"type\":\"{module_type}\"}"
        return 0

    val progress = render_progress(progress_mode, 1, 1, "unreal module")
    if progress != "":
        print progress
    print "Created Unreal module: {module_name}"
    0

fn cmd_generate_bindings(args: [text], log_mode: text, progress_mode: text) -> i64:
    if args.len() < 2:
        return print_error("unreal-cli", "class name required", log_mode)

    val class_name = args[1]
    dir_create_all("Simple/Bindings")
    file_write("Simple/Bindings/{class_name}.spl", generate_binding_scaffold(class_name))

    if log_mode == "json":
        print "{\"command\":\"unreal-cli\",\"status\":\"ok\",\"action\":\"generate-bindings\",\"class\":\"{class_name}\"}"
        return 0

    val progress = render_progress(progress_mode, 1, 1, "unreal bindings")
    if progress != "":
        print progress
    print "Generated bindings for: {class_name}"
    0

fn create_project_structure(project_path: text, project_name: text, ue_version: text):
    dir_create_all(project_path)
    dir_create_all("{project_path}/Source/{project_name}")
    dir_create_all("{project_path}/Content")
    dir_create_all("{project_path}/Config")
    dir_create_all("{project_path}/Plugins/SimpleIntegration/Source/SimpleIntegration")
    dir_create_all("{project_path}/Simple/Core")

    file_write("{project_path}/{project_name}.uproject", generate_uproject(project_name, ue_version))
    file_write("{project_path}/Source/{project_name}/{project_name}.Build.cs", generate_module_build_cs(project_name, "Runtime"))
    file_write("{project_path}/Source/{project_name}/{project_name}.h", generate_module_header(project_name))
    file_write("{project_path}/Source/{project_name}/{project_name}.cpp", generate_module_cpp(project_name))
    file_write("{project_path}/Plugins/SimpleIntegration/SimpleIntegration.uplugin", generate_plugin_descriptor())
    file_write("{project_path}/Simple/Core/Example.spl", "# Example Simple script for {project_name}\n")
    file_write("{project_path}/Simple/simple.toml", "[package]\nname = \"{project_name}\"\nversion = \"0.1.0\"\n")

fn generate_uproject(project_name: text, ue_version: text) -> text:
    "{\n  \"FileVersion\": 3,\n  \"EngineAssociation\": \"{ue_version}\",\n  \"Modules\": [\n    {\"Name\": \"{project_name}\", \"Type\": \"Runtime\", \"LoadingPhase\": \"Default\"}\n  ],\n  \"Plugins\": [{\"Name\": \"SimpleIntegration\", \"Enabled\": true}]\n}\n"

fn generate_module_build_cs(module_name: text, module_type: text) -> text:
    "using UnrealBuildTool;\n\npublic class {module_name} : ModuleRules\n{\n    public {module_name}(ReadOnlyTargetRules Target) : base(Target)\n    {\n        PCHUsage = PCHUsageMode.UseExplicitOrSharedPCHs;\n        Type = ModuleRules.ModuleType.{module_type};\n        PublicDependencyModuleNames.AddRange(new string[] { \"Core\", \"CoreUObject\", \"Engine\" });\n    }\n}\n"

fn generate_module_header(module_name: text) -> text:
    "#pragma once\n\n#include \"CoreMinimal.h\"\n#include \"Modules/ModuleManager.h\"\n\nclass F{module_name}Module : public IModuleInterface\n{\npublic:\n    virtual void StartupModule() override;\n    virtual void ShutdownModule() override;\n};\n"

fn generate_module_cpp(module_name: text) -> text:
    "#include \"{module_name}.h\"\n\nvoid F{module_name}Module::StartupModule() {}\nvoid F{module_name}Module::ShutdownModule() {}\n"

fn generate_plugin_descriptor() -> text:
    "{\n  \"FileVersion\": 3,\n  \"Version\": 1,\n  \"VersionName\": \"1.0\",\n  \"FriendlyName\": \"Simple Language Integration\",\n  \"Category\": \"Scripting\",\n  \"CanContainContent\": true\n}\n"

fn generate_binding_scaffold(class_name: text) -> text:
    "# Generated Unreal binding scaffold for {class_name}\n\nclass {class_name}Binding:\n    unreal_class: text\n\n    static fn create() -> {class_name}Binding:\n        {class_name}Binding(unreal_class: \"{class_name}\")\n"

fn print_error(command: text, message: text, log_mode: text) -> i64:
    if log_mode == "json":
        print "{\"command\":\"{command}\",\"status\":\"error\",\"error\":\"{message}\"}"
    else:
        print "error: {message}"
    1

fn unreal_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn unreal_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if unreal_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
