# App root placeholder entrypoint.
#
# Real CLI commands live under src/app/<command>/main.spl. This root module
# stays startup-light so direct source-run probes have deterministic behavior.

use std.cli.cli_util.{get_cli_args}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("app-root", log_opts.error)
        return 1

    val args = app_root_clean_log_args(raw_args)
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"app-root\",\"status\":\"ready\"}"
        return 0

    if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_app_root_help()
        return 0

    if log_opts.log_mode == "json":
        print "{\"command\":\"app-root\",\"status\":\"error\",\"error\":\"unknown option\"}"
        return 1
    print "error: unknown option: {args[0]}"
    print_app_root_help()
    1

fn print_app_root_help():
    print "Simple app root entrypoint"
    print ""
    print "USAGE:"
    print "  simple run src/app/main.spl [options]"
    print ""
    print "Real CLI commands live under src/app/<command>/main.spl."
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn app_root_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn app_root_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if app_root_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
