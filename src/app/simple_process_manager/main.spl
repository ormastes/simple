"""Simple Process Manager (SPM) — daemon entry point.

At startup the binary reads `SIMPLE_SPM_TRANSPORT` from the environment
(values: `simpleos` or `host`) and — if unset — auto-detects by probing
for SimpleOS kernel-specific markers. Once a transport is chosen, it is
bound to a freshly constructed `SpmService` and the `listen()` loop takes
over.

Feature: spm-winfs-llm-suite AC-3.
"""

use lib.nogc_sync_mut.io.env_ops.{env_get}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.simple_process_manager.spm_service.{SpmService}
use app.simple_process_manager.transport.spm_transport.{SpmTransport, TransportStatus, SpmRequest, SpmResponse}
use app.simple_process_manager.transport.spm_transport_host.{SpmTransportHost}
use app.simple_process_manager.transport.spm_transport_simpleos.{SpmTransportSimpleos}
use os.userlib.syscall_raw.{sys_spm_claim}

extern fn rt_cli_get_args() -> [text]

fn main() -> i32:
    val raw_args = _spm_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("simple-process-manager", log_opts.error)
        return 1 as i32

    val args = _spm_clean_args(raw_args)
    if args.len() > 0:
        if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
            _print_spm_help_with_progress(log_opts.progress)
            return 0 as i32
        if log_opts.log_mode == "json":
            print "{\"command\":\"simple-process-manager\",\"status\":\"error\",\"error\":\"unknown command\"}"
            return 1 as i32
        print "Unknown simple-process-manager command: {args[0]}"
        print "Run 'simple simple-process-manager --help' for usage."
        return 1 as i32

    if log_opts.log_mode == "json":
        print "{\"command\":\"simple-process-manager\",\"status\":\"ready\"}"
        return 0 as i32

    val service = SpmService.new_for_test()
    val transport_kind = _select_transport_kind()
    if transport_kind == "simpleos":
        if sys_spm_claim() != 0 as i64:
            return 1 as i32
        val t = SpmTransportSimpleos.new()
        val status = t.listen("spm")
        return _status_to_exit(status)
    val t = SpmTransportHost.new()
    val status = t.listen(t.sock_path)
    _status_to_exit(status)

fn _print_spm_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    _print_spm_help()

fn _print_spm_help():
    print "Simple Process Manager"
    print ""
    print "Usage: simple simple-process-manager [options]"
    print ""
    print "Environment:"
    print "  SIMPLE_SPM_TRANSPORT=simpleos|host"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn _spm_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _spm_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _spm_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn _spm_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found = false
    var i = 0
    while i < all_args.len():
        if found:
            args.push(all_args[i])
        elif all_args[i] == "simple-process-manager":
            found = true
        i = i + 1
    if found:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/simple_process_manager/main.spl") or all_args[i] == "src/app/simple_process_manager/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn _select_transport_kind() -> text:
    val explicit = env_get("SIMPLE_SPM_TRANSPORT")
    if explicit == "simpleos":
        return "simpleos"
    if explicit == "host":
        return "host"
    # Auto-detect: SimpleOS sets `SIMPLE_OS=1` during boot.
    if env_get("SIMPLE_OS") == "1":
        return "simpleos"
    "host"

fn _status_to_exit(status: TransportStatus) -> i32:
    if status.ok:
        return 0 as i32
    1 as i32
