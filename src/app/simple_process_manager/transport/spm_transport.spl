#![allow(unnamed_duplicate_typed_args)]
"""SpmTransport — abstract trait + spec-facing request/response re-export.

Transports ship a `send()` (client) and a `listen()` (server) method. The
trait is concrete enough for specs to stub in-process (see `SpmTransportMock`
in `spm_transport_simpleos.spl`) and for production binaries to swap in the
real syscall or UNIX socket implementation.

Feature: spm-winfs-llm-suite AC-3.
"""

pub use lib.common.spm.spm_rpc.{SpmRequest, SpmResponse, spm_encode_request, spm_encode_response, spm_decode_request, spm_decode_response}

use lib.common.privilege.authority_token.{AuthorityToken}

# ---------------------------------------------------------------------------
# Trait
# ---------------------------------------------------------------------------

trait SpmTransport:
    """Both transports (SimpleOS syscall + host socket) implement this."""
    fn send(req: SpmRequest) -> SpmResponse
    fn listen(bind: text) -> TransportStatus

class TransportStatus:
    """Sized result for `listen`."""
    ok: bool
    error: text

    static fn success() -> TransportStatus:
        TransportStatus(ok: true, error: "")

    static fn failure(reason: text) -> TransportStatus:
        TransportStatus(ok: false, error: reason)

# ---------------------------------------------------------------------------
# Spec helper: `AuthorityToken.public_none()` alias
# ---------------------------------------------------------------------------
#
# `spm_service_spec.spl` calls `AuthorityToken.public_none()`. Wave 5a exposes
# the same value as `AuthorityToken.public()`; we re-export it under the name
# the spec expects without touching wave 5a files.

fn public_none() -> AuthorityToken:
    AuthorityToken.public()
