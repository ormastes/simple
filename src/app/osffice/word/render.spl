# Word Document Rendering
#
# Render document blocks as UI widgets for display.

use common.ui.builder.{text_widget, panel, row}
use common.ui.widget.{WidgetNode}
use common.rich_text.attributed_text.{DocBlock, TextSpan, spans_to_plain_text, block_to_plain_text}

# =========================================================================
# Block Rendering
# =========================================================================

fn render_block(block: DocBlock, index: i32) -> WidgetNode:
    """Convert a DocBlock into a WidgetNode for display.

    Each block type gets an appropriate text representation:
      Paragraph     -> plain text
      Heading       -> "# title" / "## title" / "### title"
      BulletList    -> "- item" per line
      NumberedList  -> "1. item" per line
      CodeBlock     -> language prefix + code
      Quote         -> "> " prefix per line
      HorizontalRule-> "---"
      Image         -> "[Image: alt]"
    """
    val widget_id = "block_{index}"

    match block:
        case DocBlock.Paragraph(spans):
            val content = spans_to_plain_text(spans)
            return _styled_text(widget_id, content, "paragraph")

        case DocBlock.Heading(level, spans):
            val heading_text = spans_to_plain_text(spans)
            val prefix = _heading_prefix(level)
            val content = "{prefix} {heading_text}"
            return _styled_text(widget_id, content, "heading_{level}")

        case DocBlock.BulletList(items):
            var lines: [text] = []
            for item in items:
                val item_text = spans_to_plain_text(item)
                lines = lines.push("- {item_text}")
            val content = lines.join("\n")
            return _styled_text(widget_id, content, "bullet_list")

        case DocBlock.NumberedList(items, start):
            var lines: [text] = []
            var num = start
            for item in items:
                val item_text = spans_to_plain_text(item)
                lines = lines.push("{num}. {item_text}")
                num = num + 1
            val content = lines.join("\n")
            return _styled_text(widget_id, content, "numbered_list")

        case DocBlock.CodeBlock(language, code):
            val lang_label = if language != "": "[{language}] " else: ""
            val content = "{lang_label}{code}"
            return _styled_text(widget_id, content, "code_block")

        case DocBlock.Quote(blocks):
            var lines: [text] = []
            for inner_block in blocks:
                val inner_text = block_to_plain_text(inner_block)
                lines = lines.push("> {inner_text}")
            val content = lines.join("\n")
            return _styled_text(widget_id, content, "quote")

        case DocBlock.HorizontalRule:
            return _styled_text(widget_id, "---", "horizontal_rule")

        case DocBlock.Image(src, alt):
            val content = "[Image: {alt}]"
            return _styled_text(widget_id, content, "image")

    # Fallback for any unmatched variant
    return text_widget(widget_id, "")

# =========================================================================
# Document Rendering
# =========================================================================

fn render_document(blocks: [DocBlock]) -> [WidgetNode]:
    """Render all blocks in a document as a list of WidgetNodes."""
    var widgets: [WidgetNode] = []
    var idx = 0
    for block in blocks:
        val widget = render_block(block, idx)
        widgets = widgets.push(widget)
        idx = idx + 1
    return widgets

# =========================================================================
# Internal Helpers
# =========================================================================

fn _heading_prefix(level: i32) -> text:
    """Return the markdown-style heading prefix for a given level."""
    if level == 1:
        return "#"
    if level == 2:
        return "##"
    if level == 3:
        return "###"
    if level == 4:
        return "####"
    return "#"

fn _styled_text(id: text, content: text, block_type: text) -> WidgetNode:
    """Create a text widget annotated with its block type for styling."""
    var node = text_widget(id, content)
    node = node.set_prop("block_type", block_type)
    return node
