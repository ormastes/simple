# SPipe MCP entrypoint.

use std.cli.cli_util.{get_cli_args}
use app.io.context_ops.{context_sql_get_pack, context_sql_put_pack, context_sql_query_packs_by_source}
use app.io.mod.{process_run_timeout}
use std.io.{file_read, file_exists}
use std.nogc_sync_mut.spipe.codebase_ingest.{spipe_codebase_get, spipe_codebase_ingest, spipe_codebase_pack_args, spipe_codebase_profile, spipe_codebase_save_text, spipe_codebase_search, spipe_codebase_simple_ignore_profile, spipe_codebase_simple_include_profile, spipe_codebase_validate_patterns}
use std.nogc_sync_mut.spipe.hook_event.{spipe_hook_event, spipe_hook_rules}
use std.nogc_sync_mut.spipe.minimality.{spipe_minimality_check, spipe_minimality_debt, spipe_minimality_review}
use std.nogc_sync_mut.spipe.tree_context.{ContextStore, spipe_context_get, spipe_context_put, spipe_context_raw, spipe_context_search, spipe_context_store_new, spipe_parse_source, spipe_parse_text, spipe_render_tree, spipe_match_parser, spipe_parser_names, spipe_raw_context, spipe_source_blob}
use std.mcp_sdk.core.json.{LB, RB, jp, js, jo1, jo2, jo3, escape_json, extract_json_value}
use std.mcp_sdk.server.app.{app_extract_id, app_extract_obj, app_extract_str}
use std.mcp_sdk.server.method_detect.{has_method}

extern fn stdin_read_char() -> text
extern fn print_raw(s: text)

var _SPIPE_TRANSPORT_MODE = "framed"
var _SPIPE_STORE = spipe_context_store_new()

fn print_help():
    print "Usage: spipe_mcp <command> [options]"
    print ""
    print "Commands:"
    print "  serve                   Run MCP stdio server (default with no args)"
    print "  parsers|tree-parser-list"
    print "  match|tree-match-parser --command=CMD [--source-kind=K] -f FILE"
    print "  parse|tree-parse --command=CMD [--source-kind=K] -f FILE"
    print "  render|tree-render --command=CMD [--source-kind=K] -f FILE"
    print "  raw|context-raw|context-get-raw -f FILE --start=N --end=N [--source-kind=K] [--before=N] [--after=N]"
    print "  sql-put|context-sql-put --db=PATH --source-id=ID [--sourceId=ID] [--command=CMD] [--source-kind=K] -f FILE"
    print "  sql-get|context-sql-get --db=PATH --source-id=ID [--sourceId=ID]"
    print "  sql-search|context-sql-search --db=PATH --query=TEXT [--source-filter=ID]"
    print "  exec-capture --db=PATH --source-id=ID [--sourceId=ID] [--command=CMD] [--source-kind=K] -f FILE"
    print "  exec-parse [--command=CMD] [--source-kind=K] -f FILE"
    print "  exec-search --db=PATH --query=TEXT [--source-filter=ID]"
    print "  minimality-check --task=TEXT [-f FILE]"
    print "  minimality-review [-f FILE]"
    print "  minimality-debt [-f FILE]"
    print "  hook-event --provider=codex --event=tool_start [--tool=NAME]"
    print "  hook-render --provider=codex --event=tool_start [--tool=NAME]"
    print "  hook-rules --provider=codex"
    print "  codebase-profile"
    print "  codebase-pack|getCodebase [--root=PATH] [--source-id=ID] [--sourceId=ID]"
    print "  codebase-pack-local [--root=PATH] [--source-id=ID] [--sourceId=ID]"
    print "  codebase-pack-remote|getRemoteCodebase --root=URL [--source-id=ID] [--sourceId=ID]"
    print "  codebase-save|saveCodebase --source-id=ID [--sourceId=ID] [-f FILE]"

fn _value(args: [text], name: text, default_value: text) -> text:
    val prefix = name + "="
    var i = 0
    while i < args.len():
        if args[i].starts_with(prefix):
            return args[i][prefix.len():]
        if args[i] == name and i + 1 < args.len():
            return args[i + 1]
        i = i + 1
    default_value

fn _read_file_arg(args: [text]) -> text:
    val path = _value(args, "-f", "")
    if path == "" or not file_exists(path):
        return ""
    file_read(path)

fn _to_i64(value: text, default_value: i64) -> i64:
    if value == "":
        return default_value
    for ch in value:
        if ch < "0" or ch > "9":
            return default_value
    int(value)

fn _safe_cli_value(value: text) -> bool:
    not value.contains(";") and not value.contains("|") and not value.contains("&&") and not value.contains("`") and not value.contains("$(") and not value.contains(">") and not value.contains("<")

fn _short_text(value: text, limit: i64) -> text:
    if value.len() <= limit:
        return value
    value.substring(0, limit) + "...(truncated)"

fn _json_unescape(value: text) -> text:
    var out = value
    out = out.replace("\\n", "\n")
    out = out.replace("\\r", "\r")
    out = out.replace("\\t", "\t")
    out = out.replace("\\\"", "\"")
    out = out.replace("\\\\", "\\")
    out

fn _arg_str(args_raw: text, key: text, default_value: text) -> text:
    val value = app_extract_str(args_raw, key)
    if value == "":
        return default_value
    _json_unescape(value)

fn _arg_i64(args_raw: text, key: text, default_value: i64) -> i64:
    val raw = _arg_str(args_raw, key, "")
    if raw != "":
        return _to_i64(raw, default_value)
    val value = extract_json_value(args_raw, key)
    if value == "null" or value == "":
        return default_value
    _to_i64(value, default_value)

fn _arg_source_kind(args_raw: text) -> text:
    _arg_str(args_raw, "source_kind", _arg_str(args_raw, "sourceKind", "command_output"))

fn _arg_source_id(args_raw: text, default_value: text) -> text:
    _arg_str(args_raw, "source_id", _arg_str(args_raw, "sourceId", default_value))

fn _arg_text(args_raw: text) -> text:
    _arg_str(args_raw, "text", _arg_str(args_raw, "raw_text", _arg_str(args_raw, "rawText", "")))

fn _arg_packed_text(args_raw: text) -> text:
    _arg_str(args_raw, "text", _arg_str(args_raw, "packed_text", _arg_str(args_raw, "packedText", _arg_str(args_raw, "codebase", ""))))

fn _json_result(id: text, result: text) -> text:
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn _json_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", str(code)), jp("message", js(message)))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

fn _tool_text_result(id: text, content: text) -> text:
    val text_obj = jo2(jp("type", js("text")), jp("text", js(escape_json(content))))
    _json_result(id, jo1(jp("content", "[" + text_obj + "]")))

fn _tool_schema(props: text, required: text) -> text:
    "{\"type\":\"object\",\"properties\":" + props + ",\"required\":" + required + "}"

fn _tool_def(name: text, desc: text, props: text, required: text) -> text:
    var obj = LB()
    obj = obj + jp("name", js(name))
    obj = obj + "," + jp("description", js(desc))
    obj = obj + "," + jp("inputSchema", _tool_schema(props, required))
    obj = obj + RB()
    obj

fn _spipe_tools_list_payload() -> text:
    val text_prop = "{\"type\":\"string\"}"
    val int_prop = "{\"type\":\"integer\"}"
    val source_id_props = "\"source_id\":" + text_prop + ",\"sourceId\":" + text_prop
    val source_kind_props = "\"source_kind\":" + text_prop + ",\"sourceKind\":" + text_prop
    val raw_text_props = "\"text\":" + text_prop + ",\"raw_text\":" + text_prop + ",\"rawText\":" + text_prop
    val packed_text_props = "\"text\":" + text_prop + ",\"packed_text\":" + text_prop + ",\"packedText\":" + text_prop
    val common_props = "{" + source_kind_props + ",\"command\":" + text_prop + "," + raw_text_props + "}"
    val raw_props = "{" + source_id_props + "," + source_kind_props + "," + raw_text_props + ",\"start_line\":" + int_prop + ",\"startLine\":" + int_prop + ",\"end_line\":" + int_prop + ",\"endLine\":" + int_prop + ",\"before\":" + int_prop + ",\"contextBefore\":" + int_prop + ",\"after\":" + int_prop + ",\"contextAfter\":" + int_prop + "}"
    val sql_context_props = "{" + source_id_props + "," + source_kind_props + ",\"command\":" + text_prop + "," + raw_text_props + ",\"db_path\":" + text_prop + ",\"db\":" + text_prop + ",\"dbPath\":" + text_prop + "}"
    val sql_context_get_props = "{" + source_id_props + ",\"db_path\":" + text_prop + ",\"db\":" + text_prop + ",\"dbPath\":" + text_prop + "}"
    val sql_context_search_props = "{\"query\":" + text_prop + ",\"source_filter\":" + text_prop + ",\"sourceFilter\":" + text_prop + ",\"db_path\":" + text_prop + ",\"db\":" + text_prop + ",\"dbPath\":" + text_prop + "}"
    val minimality_props = "{\"task\":" + text_prop + ",\"text\":" + text_prop + ",\"mode\":" + text_prop + "}"
    val hook_props = "{\"provider\":" + text_prop + ",\"event\":" + text_prop + ",\"raw_payload\":" + text_prop + ",\"tool_name\":" + text_prop + ",\"cwd\":" + text_prop + ",\"repo\":" + text_prop + ",\"files\":" + text_prop + ",\"diff\":" + text_prop + ",\"prompt_excerpt\":" + text_prop + "}"
    val codebase_ingest_props = "{" + source_id_props + "," + packed_text_props + ",\"include_patterns\":" + text_prop + ",\"includePatterns\":" + text_prop + ",\"ignore_patterns\":" + text_prop + ",\"ignorePatterns\":" + text_prop + "}"
    val codebase_pack_props = "{" + source_id_props + ",\"root\":" + text_prop + ",\"cwd\":" + text_prop + ",\"repo\":" + text_prop + ",\"include_patterns\":" + text_prop + ",\"includePatterns\":" + text_prop + ",\"ignore_patterns\":" + text_prop + ",\"ignorePatterns\":" + text_prop + ",\"timeout_ms\":" + int_prop + ",\"timeoutMs\":" + int_prop + "}"
    val codebase_save_props = "{" + source_id_props + "," + packed_text_props + ",\"codebase\":" + text_prop + "}"
    var tools: [text] = []
    tools.push(_tool_def("spipe_tree_parser_list", "List SPipe parser names.", "{}", "[]"))
    tools.push(_tool_def("spipe_tree_match_parser", "Return the best parser for source kind, command, and text.", common_props, "[]"))
    tools.push(_tool_def("spipe_tree_parse", "Parse text into compact parent-chain tree output.", common_props, "[]"))
    tools.push(_tool_def("spipe_tree_render", "Render parsed text into compact parent-chain tree output. Alias of spipe_tree_parse.", common_props, "[]"))
    tools.push(_tool_def("spipe_context_put", "Store raw text and parsed tree in this MCP session.", "{" + source_id_props + "," + source_kind_props + ",\"command\":" + text_prop + "," + raw_text_props + "}", "[]"))
    tools.push(_tool_def("spipe_context_put_raw", "Store raw text and parsed tree in this MCP session. Alias of spipe_context_put.", "{" + source_id_props + "," + source_kind_props + ",\"command\":" + text_prop + "," + raw_text_props + "}", "[]"))
    tools.push(_tool_def("spipe_context_get", "Render a stored tree by source id.", "{" + source_id_props + "}", "[]"))
    tools.push(_tool_def("spipe_context_get_tree", "Render a stored tree by source id. Alias of spipe_context_get.", "{" + source_id_props + "}", "[]"))
    tools.push(_tool_def("spipe_context_search", "Search stored raw text and return matching rendered trees.", "{\"query\":" + text_prop + "}", "[\"query\"]"))
    tools.push(_tool_def("spipe_context_raw", "Return exact raw lines with optional before/after context.", raw_props, "[]"))
    tools.push(_tool_def("spipe_context_get_raw", "Return exact raw lines with optional before/after context. Alias of spipe_context_raw.", raw_props, "[]"))
    tools.push(_tool_def("spipe_context_sql_put", "Persist parsed parent-chain context in a SQLite context database.", sql_context_props, "[]"))
    tools.push(_tool_def("spipe_context_sql_get", "Read persisted parsed context by source id from a SQLite context database.", sql_context_get_props, "[]"))
    tools.push(_tool_def("spipe_context_sql_search", "Search persisted parsed context in a SQLite context database.", sql_context_search_props, "[]"))
    tools.push(_tool_def("spipe_exec_capture", "Capture supplied command output into the SPipe context store.", "{" + source_id_props + "," + source_kind_props + ",\"command\":" + text_prop + "," + raw_text_props + "}", "[]"))
    tools.push(_tool_def("spipe_exec_parse", "Parse supplied command output into compact parent-chain tree output.", common_props, "[]"))
    tools.push(_tool_def("spipe_exec_search", "Search captured execution output and return matching rendered trees.", "{\"query\":" + text_prop + "}", "[\"query\"]"))
    tools.push(_tool_def("spipe_minimality_check", "Run deterministic Ponytail minimality gate.", minimality_props, "[\"task\"]"))
    tools.push(_tool_def("spipe_minimality_review", "Review text or diff for obvious Ponytail findings.", minimality_props, "[\"text\"]"))
    tools.push(_tool_def("spipe_minimality_debt", "List ponytail: debt markers from text.", "{\"text\":" + text_prop + "}", "[\"text\"]"))
    tools.push(_tool_def("spipe_hook_event", "Normalize a provider hook event into the SPipe hook model.", hook_props, "[\"provider\",\"event\"]"))
    tools.push(_tool_def("spipe_hook_rules", "List provider hook event-to-phase mappings.", "{\"provider\":" + text_prop + "}", "[\"provider\"]"))
    tools.push(_tool_def("spipe_hook_render", "Render a normalized hook event. Alias of spipe_hook_event.", hook_props, "[\"provider\",\"event\"]"))
    tools.push(_tool_def("spipe_codebase_profile", "Return focused Simple MCP RepoMix include/ignore profile.", "{}", "[]"))
    tools.push(_tool_def("spipe_codebase_pack", "Run RepoMix through argv-safe process execution and ingest stdout into the SPipe context tree.", codebase_pack_props, "[]"))
    tools.push(_tool_def("spipe_codebase_pack_local", "Alias of spipe_codebase_pack for local RepoMix/codebase-mcp parity.", codebase_pack_props, "[]"))
    tools.push(_tool_def("spipe_codebase_pack_remote", "Alias of spipe_codebase_pack for remote RepoMix/codebase-mcp parity; pass a supported URL as root.", codebase_pack_props, "[]"))
    tools.push(_tool_def("getCodebase", "codebase-mcp compatibility alias of spipe_codebase_pack_local.", codebase_pack_props, "[]"))
    tools.push(_tool_def("getRemoteCodebase", "codebase-mcp compatibility alias of spipe_codebase_pack_remote.", codebase_pack_props, "[]"))
    tools.push(_tool_def("spipe_codebase_ingest", "Ingest existing RepoMix/codebase-mcp output into the SPipe context tree.", codebase_ingest_props, "[]"))
    tools.push(_tool_def("spipe_codebase_search", "Search ingested codebase trees.", "{\"query\":" + text_prop + "}", "[\"query\"]"))
    tools.push(_tool_def("spipe_codebase_get", "Render an ingested codebase tree by source id.", "{" + source_id_props + "}", "[]"))
    tools.push(_tool_def("spipe_codebase_save", "Return save metadata for existing packed text; filesystem writes stay app-owned.", codebase_save_props, "[]"))
    tools.push(_tool_def("saveCodebase", "codebase-mcp compatibility alias of spipe_codebase_save.", codebase_save_props, "[]"))
    jo1(jp("tools", "[" + tools.join(",") + "]"))

fn _spipe_initialize_payload() -> text:
    val caps = jo1(jp("tools", LB() + RB()))
    val info = jo2(jp("name", js("spipe-mcp")), jp("version", js("0.1.0")))
    jo3(jp("protocolVersion", js("2025-06-18")), jp("capabilities", caps), jp("serverInfo", info))

fn _dispatch_tool(id: text, tool_name: text, args_raw: text) -> text:
    if tool_name == "spipe_tree_parser_list":
        return _tool_text_result(id, spipe_parser_names().join("\n"))
    if tool_name == "spipe_tree_match_parser":
        val kind = _arg_source_kind(args_raw)
        val command = _arg_str(args_raw, "command", "")
        val raw = _arg_text(args_raw)
        return _tool_text_result(id, spipe_match_parser(kind, command, raw))
    if tool_name == "spipe_tree_parse" or tool_name == "spipe_tree_render" or tool_name == "spipe_exec_parse":
        val kind = _arg_source_kind(args_raw)
        val command = _arg_str(args_raw, "command", "")
        val raw = _arg_text(args_raw)
        return _tool_text_result(id, spipe_render_tree(spipe_parse_text(kind, command, raw)))
    if tool_name == "spipe_context_put" or tool_name == "spipe_context_put_raw" or tool_name == "spipe_exec_capture":
        val source_id = _arg_source_id(args_raw, "src:1")
        val kind = _arg_source_kind(args_raw)
        val command = _arg_str(args_raw, "command", "")
        val raw = _arg_text(args_raw)
        _SPIPE_STORE = spipe_context_put(_SPIPE_STORE, spipe_source_blob(source_id, kind, command, raw))
        return _tool_text_result(id, "stored " + source_id)
    if tool_name == "spipe_context_get" or tool_name == "spipe_context_get_tree":
        val source_id = _arg_source_id(args_raw, "")
        return _tool_text_result(id, spipe_context_get(_SPIPE_STORE, source_id))
    if tool_name == "spipe_context_search" or tool_name == "spipe_exec_search":
        val query = _arg_str(args_raw, "query", "")
        return _tool_text_result(id, spipe_context_search(_SPIPE_STORE, query))
    if tool_name == "spipe_context_raw" or tool_name == "spipe_context_get_raw":
        val source_id = _arg_source_id(args_raw, "")
        val kind = _arg_source_kind(args_raw)
        val raw = _arg_text(args_raw)
        val start_line = _arg_i64(args_raw, "start_line", _arg_i64(args_raw, "startLine", 1))
        val end_line = _arg_i64(args_raw, "end_line", _arg_i64(args_raw, "endLine", start_line))
        val before = _arg_i64(args_raw, "before", _arg_i64(args_raw, "contextBefore", 0))
        val after = _arg_i64(args_raw, "after", _arg_i64(args_raw, "contextAfter", 0))
        if raw != "":
            return _tool_text_result(id, spipe_raw_context(source_id, kind, _arg_str(args_raw, "command", ""), raw, start_line, end_line, before, after))
        return _tool_text_result(id, spipe_context_raw(_SPIPE_STORE, source_id, start_line, end_line, before, after))
    if tool_name == "spipe_context_sql_put":
        val source_id = _arg_source_id(args_raw, "")
        val kind = _arg_source_kind(args_raw)
        val command = _arg_str(args_raw, "command", "")
        val raw = _arg_text(args_raw)
        val db_path = _arg_str(args_raw, "db_path", _arg_str(args_raw, "db", _arg_str(args_raw, "dbPath", "")))
        val rendered = spipe_render_tree(spipe_parse_source(spipe_source_blob(source_id, kind, command, raw)))
        return _tool_text_result(id, context_sql_put_pack(source_id, "spipe-tree", rendered, db_path, "text"))
    if tool_name == "spipe_context_sql_get":
        return _tool_text_result(id, context_sql_get_pack(_arg_source_id(args_raw, ""), _arg_str(args_raw, "db_path", _arg_str(args_raw, "db", _arg_str(args_raw, "dbPath", ""))), "text"))
    if tool_name == "spipe_context_sql_search":
        return _tool_text_result(id, context_sql_query_packs_by_source([], "", _arg_str(args_raw, "query", ""), _arg_str(args_raw, "source_filter", _arg_str(args_raw, "sourceFilter", "")), _arg_str(args_raw, "db_path", _arg_str(args_raw, "db", _arg_str(args_raw, "dbPath", ""))), "text"))
    if tool_name == "spipe_minimality_check":
        val task = _arg_str(args_raw, "task", "")
        val raw = _arg_str(args_raw, "text", "")
        val mode = _arg_str(args_raw, "mode", "full")
        return _tool_text_result(id, spipe_minimality_check(task, raw, mode))
    if tool_name == "spipe_minimality_review":
        val raw = _arg_str(args_raw, "text", _arg_str(args_raw, "diff", ""))
        val mode = _arg_str(args_raw, "mode", "full")
        return _tool_text_result(id, spipe_minimality_review(raw, mode))
    if tool_name == "spipe_minimality_debt":
        val raw = _arg_str(args_raw, "text", "")
        return _tool_text_result(id, spipe_minimality_debt(raw))
    if tool_name == "spipe_hook_rules":
        return _tool_text_result(id, spipe_hook_rules(_arg_str(args_raw, "provider", "generic")))
    if tool_name == "spipe_hook_event" or tool_name == "spipe_hook_render":
        val provider = _arg_str(args_raw, "provider", "generic")
        val event = _arg_str(args_raw, "event", "")
        val raw_payload = _arg_str(args_raw, "raw_payload", _arg_str(args_raw, "raw", ""))
        val hook_tool_name = _arg_str(args_raw, "tool_name", _arg_str(args_raw, "tool", ""))
        val cwd = _arg_str(args_raw, "cwd", "")
        val repo = _arg_str(args_raw, "repo", "")
        val files = _arg_str(args_raw, "files", "")
        val diff = _arg_str(args_raw, "diff", "")
        val prompt_excerpt = _arg_str(args_raw, "prompt_excerpt", _arg_str(args_raw, "prompt", ""))
        return _tool_text_result(id, spipe_hook_event(provider, event, raw_payload, hook_tool_name, cwd, repo, files, diff, prompt_excerpt))
    if tool_name == "spipe_codebase_profile":
        return _tool_text_result(id, spipe_codebase_profile())
    if tool_name == "spipe_codebase_pack" or tool_name == "spipe_codebase_pack_local" or tool_name == "spipe_codebase_pack_remote" or tool_name == "getCodebase" or tool_name == "getRemoteCodebase":
        val source_id = _arg_source_id(args_raw, "codebase:repomix")
        val root = _arg_str(args_raw, "root", _arg_str(args_raw, "cwd", _arg_str(args_raw, "repo", ".")))
        val include_patterns = _arg_str(args_raw, "include_patterns", _arg_str(args_raw, "includePatterns", spipe_codebase_simple_include_profile()))
        val ignore_patterns = _arg_str(args_raw, "ignore_patterns", _arg_str(args_raw, "ignorePatterns", spipe_codebase_simple_ignore_profile()))
        val timeout_ms = _arg_i64(args_raw, "timeout_ms", _arg_i64(args_raw, "timeoutMs", 120000))
        if not _safe_cli_value(root) or root.starts_with("-"):
            return _tool_text_result(id, "invalid: root")
        val include_status = spipe_codebase_validate_patterns(include_patterns)
        val ignore_status = spipe_codebase_validate_patterns(ignore_patterns)
        if include_status != "ok":
            return _tool_text_result(id, include_status)
        if ignore_status != "ok":
            return _tool_text_result(id, ignore_status)
        val args = spipe_codebase_pack_args(root, include_patterns, ignore_patterns, tool_name == "spipe_codebase_pack_remote" or tool_name == "getRemoteCodebase")
        val (stdout, stderr, exit_code) = process_run_timeout("npx", args, timeout_ms)
        if exit_code != 0:
            return _tool_text_result(id, "status: failed\ncommand: npx -y repomix\nexit_code: " + str(exit_code) + "\nstderr: " + _short_text(stderr, 1000))
        _SPIPE_STORE = spipe_codebase_ingest(_SPIPE_STORE, source_id, stdout)
        return _tool_text_result(id, "status: ready\nsource_id: " + source_id + "\nbytes: " + str(stdout.len()))
    if tool_name == "spipe_codebase_ingest":
        val source_id = _arg_source_id(args_raw, "codebase:1")
        val packed = _arg_packed_text(args_raw)
        val include_status = spipe_codebase_validate_patterns(_arg_str(args_raw, "include_patterns", _arg_str(args_raw, "includePatterns", "")))
        val ignore_status = spipe_codebase_validate_patterns(_arg_str(args_raw, "ignore_patterns", _arg_str(args_raw, "ignorePatterns", "")))
        if include_status != "ok":
            return _tool_text_result(id, include_status)
        if ignore_status != "ok":
            return _tool_text_result(id, ignore_status)
        _SPIPE_STORE = spipe_codebase_ingest(_SPIPE_STORE, source_id, packed)
        return _tool_text_result(id, "ingested " + source_id)
    if tool_name == "spipe_codebase_search":
        return _tool_text_result(id, spipe_codebase_search(_SPIPE_STORE, _arg_str(args_raw, "query", "")))
    if tool_name == "spipe_codebase_get":
        return _tool_text_result(id, spipe_codebase_get(_SPIPE_STORE, _arg_source_id(args_raw, "")))
    if tool_name == "spipe_codebase_save" or tool_name == "saveCodebase":
        return _tool_text_result(id, spipe_codebase_save_text(_arg_source_id(args_raw, "codebase:1"), _arg_packed_text(args_raw)))
    _tool_text_result(id, "unknown tool: " + tool_name)

fn _read_line() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            return result
        result = result + ch
        if ch == "\n":
            return result

fn _read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn _strip_line_end(line: text) -> text:
    val n = line.len()
    if n >= 2 and line.substring(n - 2, n) == "\r\n":
        return line.substring(0, n - 2)
    if n >= 1 and line.substring(n - 1, n) == "\n":
        return line.substring(0, n - 1)
    if n >= 1 and line.substring(n - 1, n) == "\r":
        return line.substring(0, n - 1)
    line

fn _parse_decimal(s: text) -> i64:
    var result: i64 = 0
    for ch in s:
        if ch < "0" or ch > "9":
            return result
        result = result * 10 + int(ch)
    result

fn _read_message() -> text:
    var content_length = 0
    while true:
        var line = _read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        line = _strip_line_end(line)
        if line.starts_with(LB()):
            _SPIPE_TRANSPORT_MODE = "jsonl"
            return line
        if line.starts_with("Content-Length:"):
            content_length = _parse_decimal(line.replace("Content-Length:", "").trim())
    if content_length <= 0:
        return ""
    _read_chars(content_length)

fn _write_message(body: text):
    if _SPIPE_TRANSPORT_MODE == "jsonl":
        print_raw(body + "\n")
        return
    val nl = "\n"
    print_raw("Content-Length: " + str(body.len()) + "\r" + nl + "\r" + nl)
    print_raw(body)

fn _serve() -> i64:
    while true:
        val msg = _read_message()
        if msg == "":
            return 0
        val response = spipe_mcp_handle_message(msg)
        if response != "":
            _write_message(response)
    0

fn spipe_mcp_handle_message(msg: text) -> text:
    if has_method(msg, "initialize"):
        return _json_result(app_extract_id(msg), _spipe_initialize_payload())
    if has_method(msg, "notifications/initialized") or has_method(msg, "initialized"):
        return ""
    if has_method(msg, "tools/list"):
        return _json_result(app_extract_id(msg), _spipe_tools_list_payload())
    if has_method(msg, "tools/call"):
        val id = app_extract_id(msg)
        val params = app_extract_obj(msg, "params")
        val tool_name = app_extract_str(params, "name")
        var args_raw = app_extract_obj(params, "arguments")
        if args_raw == "":
            args_raw = "{}"
        return _dispatch_tool(id, tool_name, args_raw)
    if has_method(msg, "shutdown"):
        return _json_result(app_extract_id(msg), "null")
    _json_error(app_extract_id(msg), -32601, "Method not found")

fn spipe_mcp_run(args: [text]) -> i64:
    if args.len() == 0 or args[0] == "serve":
        return _serve()
    if args[0] == "-h" or args[0] == "--help":
        print_help()
        return 0
    val cmd = args[0]
    if cmd == "parsers" or cmd == "tree-parser-list":
        for name in spipe_parser_names():
            print name
        return 0
    if cmd == "codebase-profile":
        print spipe_codebase_profile()
        return 0
    if cmd == "codebase-pack" or cmd == "codebase-pack-local" or cmd == "codebase-pack-remote" or cmd == "getCodebase" or cmd == "getRemoteCodebase":
        val source_id = _value(args, "--source-id", _value(args, "--sourceId", "codebase:repomix"))
        val root = _value(args, "--root", _value(args, "--cwd", _value(args, "--repo", ".")))
        val include_patterns = _value(args, "--include", _value(args, "--includePatterns", _value(args, "--include-patterns", spipe_codebase_simple_include_profile())))
        val ignore_patterns = _value(args, "--ignore", _value(args, "--ignorePatterns", _value(args, "--ignore-patterns", spipe_codebase_simple_ignore_profile())))
        val timeout_ms = _to_i64(_value(args, "--timeout-ms", _value(args, "--timeoutMs", "120000")), 120000)
        if not _safe_cli_value(root) or root.starts_with("-"):
            print "invalid: root"
            return 2
        val include_status = spipe_codebase_validate_patterns(include_patterns)
        val ignore_status = spipe_codebase_validate_patterns(ignore_patterns)
        if include_status != "ok":
            print include_status
            return 2
        if ignore_status != "ok":
            print ignore_status
            return 2
        val pack_args = spipe_codebase_pack_args(root, include_patterns, ignore_patterns, cmd == "codebase-pack-remote" or cmd == "getRemoteCodebase")
        val (stdout, stderr, exit_code) = process_run_timeout("npx", pack_args, timeout_ms)
        if exit_code != 0:
            print "status: failed\ncommand: npx -y repomix\nexit_code: " + str(exit_code) + "\nstderr: " + _short_text(stderr, 1000)
            return 1
        print spipe_codebase_save_text(source_id, stdout)
        return 0
    if cmd == "codebase-save" or cmd == "saveCodebase":
        print spipe_codebase_save_text(_value(args, "--source-id", _value(args, "--sourceId", "codebase:1")), _read_file_arg(args))
        return 0
    if cmd == "sql-get" or cmd == "context-sql-get":
        print context_sql_get_pack(_value(args, "--source-id", _value(args, "--sourceId", "")), _value(args, "--db", _value(args, "--db-path", _value(args, "--dbPath", ""))), "text")
        return 0
    if cmd == "sql-search" or cmd == "context-sql-search" or cmd == "exec-search":
        print context_sql_query_packs_by_source([], "", _value(args, "--query", ""), _value(args, "--source-filter", _value(args, "--sourceFilter", "")), _value(args, "--db", _value(args, "--db-path", _value(args, "--dbPath", ""))), "text")
        return 0
    if cmd == "hook-rules":
        print spipe_hook_rules(_value(args, "--provider", "generic"))
        return 0
    if cmd == "minimality-check" or cmd == "minimality-review" or cmd == "minimality-debt":
        val raw = _read_file_arg(args)
        val mode = _value(args, "--mode", "full")
        if cmd == "minimality-check":
            print spipe_minimality_check(_value(args, "--task", ""), raw, mode)
            return 0
        if cmd == "minimality-review":
            print spipe_minimality_review(raw, mode)
            return 0
        print spipe_minimality_debt(raw)
        return 0
    val command = _value(args, "--command", "")
    val source_kind = _value(args, "--source-kind", _value(args, "--sourceKind", _value(args, "--kind", "command_output")))
    val raw = _read_file_arg(args)
    if raw == "":
        print "spipe_mcp: missing readable -f FILE"
        return 1
    if cmd == "sql-put" or cmd == "context-sql-put" or cmd == "exec-capture":
        val source_id = _value(args, "--source-id", _value(args, "--sourceId", "src:1"))
        val rendered = spipe_render_tree(spipe_parse_source(spipe_source_blob(source_id, source_kind, command, raw)))
        print context_sql_put_pack(source_id, "spipe-tree", rendered, _value(args, "--db", _value(args, "--db-path", _value(args, "--dbPath", ""))), "text")
        return 0
    if cmd == "match" or cmd == "tree-match-parser":
        print spipe_match_parser(source_kind, command, raw)
        return 0
    if cmd == "parse" or cmd == "render" or cmd == "tree-parse" or cmd == "tree-render" or cmd == "exec-parse":
        val doc = spipe_parse_text(source_kind, command, raw)
        print spipe_render_tree(doc)
        return 0
    if cmd == "raw" or cmd == "context-raw" or cmd == "context-get-raw":
        val start_line = _to_i64(_value(args, "--start", _value(args, "--startLine", "1")), 1)
        val end_line = _to_i64(_value(args, "--end", _value(args, "--endLine", start_line.to_string())), start_line)
        val before = _to_i64(_value(args, "--before", _value(args, "--contextBefore", "0")), 0)
        val after = _to_i64(_value(args, "--after", _value(args, "--contextAfter", "0")), 0)
        print spipe_raw_context("file:1", source_kind, command, raw, start_line, end_line, before, after)
        return 0
    if cmd == "hook-event" or cmd == "hook-render":
        print spipe_hook_event(
            _value(args, "--provider", "generic"),
            _value(args, "--event", ""),
            raw,
            _value(args, "--tool", ""),
            _value(args, "--cwd", ""),
            _value(args, "--repo", ""),
            _value(args, "--files", ""),
            _value(args, "--diff", ""),
            _value(args, "--prompt", "")
        )
        return 0
    print_help()
    1

fn main() -> i64:
    spipe_mcp_run(get_cli_args())

export spipe_mcp_handle_message
