use app.simple_portal.server.{SimplePortalServer}
use app.simple_portal.content_db.{simple_portal_default_app_root, simple_portal_default_data_root}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_env_get(key: text) -> text
extern fn rt_cli_get_args() -> [text]

fn _port() -> i32:
    val env = rt_env_get("SIMPLE_PORTAL_PORT") ?? ""
    if env == "":
        return 4040
    env.to_i32() ?? 4040

fn _token() -> text:
    val env = rt_env_get("SIMPLE_PORTAL_RUN_TOKEN") ?? ""
    if env != "":
        return env
    "simple-portal-dev-token"

fn main() -> i64:
    val raw_args = _simple_portal_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("simple-portal", log_opts.error)
        return 1

    val args = _simple_portal_clean_args(raw_args)
    if args.len() > 0:
        if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
            _print_simple_portal_help_with_progress(log_opts.progress)
            return 0
        if log_opts.log_mode == "json":
            print "{\"command\":\"simple-portal\",\"status\":\"error\",\"error\":\"unknown command\"}"
            return 1
        print "Unknown simple-portal command: {args[0]}"
        print "Run 'simple simple-portal --help' for usage."
        return 1

    if log_opts.log_mode == "json":
        print "{\"command\":\"simple-portal\",\"status\":\"ready\",\"port\":" + _port().to_string() + "}"
        return 0

    val server_result = SimplePortalServer.new(
        _port(),
        simple_portal_default_app_root(),
        simple_portal_default_data_root(),
        _token()
    )
    match server_result:
        Err(e):
            print "simple_portal bootstrap failed: {e}"
            return 1
        Ok(server):
            server.start()
            return 0

fn _print_simple_portal_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    _print_simple_portal_help()

fn _print_simple_portal_help():
    print "Simple Portal"
    print ""
    print "Usage: simple simple-portal [options]"
    print ""
    print "Environment:"
    print "  SIMPLE_PORTAL_PORT"
    print "  SIMPLE_PORTAL_RUN_TOKEN"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn _simple_portal_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _simple_portal_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _simple_portal_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn _simple_portal_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found = false
    var i = 0
    while i < all_args.len():
        if found:
            args.push(all_args[i])
        elif all_args[i] == "simple-portal" or all_args[i] == "simple_portal":
            found = true
        i = i + 1
    if found:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/simple_portal/main.spl") or all_args[i] == "src/app/simple_portal/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
