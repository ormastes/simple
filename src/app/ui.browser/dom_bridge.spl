# DOM Bridge — UI Widgets to Browser DOM
#
# Converts the UI widget tree's HTML output into browser engine DOM nodes.
# Maps UI events back to widget events and syncs state changes to the DOM.

use examples.browser.entity.dom.node_types.{DomNode, NodeKind, Element, TextNode}
use examples.browser.entity.dom.attribute_types.{Attr}
use examples.browser.entity.dom.css_types.{CSSRule, CSSDeclaration, CSSValue, Selector, SelectorPart}
use examples.browser.entity.dom.event_types.{DomEvent, EventPhase}
use common.ui.widget.{UIEvent, WidgetNode, WidgetKind}

# =========================================================================
# DOM Tree — lightweight wrapper for the bridge output
# =========================================================================

class DomTree:
    root: DomNode
    elements: [Element]
    text_nodes: [TextNode]
    css_rules: [CSSRule]
    next_id: i64

    static fn empty() -> DomTree:
        val root = DomNode.create(0, NodeKind.Document, -1, "")
        DomTree(
            root: root,
            elements: [],
            text_nodes: [],
            css_rules: [],
            next_id: 1
        )

# =========================================================================
# DOM Bridge
# =========================================================================

class DomBridge:
    next_id: i64

    static fn new() -> DomBridge:
        DomBridge(next_id: 1)

    me html_to_dom(html: text, css_text: text) -> DomTree:
        """Parse HTML string and CSS into a DomTree for the browser renderer.

        Uses a lightweight tag-walk: splits on '<' / '>' to produce
        DomNode + Element entries.  Full HTML parsing lives in the browser
        example's parser; this bridge only needs enough fidelity to turn
        the render_html_tree() output into paintable nodes.
        """
        var tree = DomTree.empty()
        tree.css_rules = self.parse_css_rules(css_text)

        # Build DOM from HTML — walk tag boundaries
        var nodes: [DomNode] = []
        var elems: [Element] = []
        var texts: [TextNode] = []
        var stack: [i64] = [0]  # parent-id stack, root = 0

        var pos = 0
        val html_len = html.len()

        while pos < html_len:
            val lt = html.index_of("<", pos)
            if lt < 0:
                # Remaining text node
                val remaining = html[pos:]
                val trimmed = remaining.trim()
                if trimmed.len() > 0:
                    val parent_id = stack[stack.len() - 1]
                    val tid = self.next_id
                    self.next_id = self.next_id + 1
                    val tnode = DomNode.create(tid, NodeKind.Text, parent_id, trimmed)
                    nodes = nodes.push(tnode)
                    texts = texts.push(TextNode.create(tid, trimmed))
                break

            # Text before '<'
            if lt > pos:
                val text_chunk = html[pos:lt]
                val trimmed_chunk = text_chunk.trim()
                if trimmed_chunk.len() > 0:
                    val parent_id = stack[stack.len() - 1]
                    val tid = self.next_id
                    self.next_id = self.next_id + 1
                    val tnode = DomNode.create(tid, NodeKind.Text, parent_id, trimmed_chunk)
                    nodes = nodes.push(tnode)
                    texts = texts.push(TextNode.create(tid, trimmed_chunk))

            val gt = html.index_of(">", lt)
            if gt < 0:
                break

            val tag_content = html[lt + 1:gt]
            pos = gt + 1

            if tag_content.starts_with("/"):
                # Closing tag — pop stack
                if stack.len() > 1:
                    stack = stack[0:stack.len() - 1]
            else:
                # Opening tag (or self-closing)
                val is_self_closing = tag_content.ends_with("/")
                val clean_tag = if is_self_closing:
                    tag_content[0:tag_content.len() - 1].trim()
                else:
                    tag_content.trim()

                val tag_name = extract_tag_name(clean_tag)
                val parent_id = stack[stack.len() - 1]

                val nid = self.next_id
                self.next_id = self.next_id + 1

                val node = DomNode.create(nid, NodeKind.Element, parent_id, tag_name)
                nodes = nodes.push(node)

                val attrs = extract_attributes(clean_tag)
                val elem = Element(node_id: nid, tag_name: tag_name, attributes: attrs, namespace: "")
                elems = elems.push(elem)

                if not is_self_closing and not is_void_element(tag_name):
                    stack = stack.push(nid)

        tree.elements = elems
        tree.text_nodes = texts
        tree.next_id = self.next_id
        return tree

    fn parse_css_rules(css_text: text) -> [CSSRule]:
        """Lightweight CSS rule extraction.

        Splits on '{' / '}' pairs to produce CSSRule entries with
        property/value declarations.  Enough for the browser engine's
        style resolver to compute styles.
        """
        var rules: [CSSRule] = []
        var remaining = css_text

        while remaining.len() > 0:
            val brace_open = remaining.index_of("{", 0)
            if brace_open < 0:
                break

            val brace_close = remaining.index_of("}", brace_open)
            if brace_close < 0:
                break

            val selector_text = remaining[0:brace_open].trim()
            val decls_text = remaining[brace_open + 1:brace_close].trim()
            remaining = remaining[brace_close + 1:]

            if selector_text.len() == 0:
                continue

            val selector = parse_selector(selector_text)
            val declarations = parse_declarations(decls_text)
            val rule = CSSRule.create(selector, declarations)
            rules = rules.push(rule)

        return rules

    # --- Event mapping ---

    fn dom_event_to_ui_event(event: DomEvent) -> UIEvent?:
        """Convert a browser DOM event to a UI widget event."""
        match event.type_name:
            "click":
                return UIEvent.Click(id: event.target_id)
            "keydown":
                return UIEvent.KeyPress(key: event.type_name)
            "mousedown":
                return UIEvent.Click(id: event.target_id)
            _:
                return nil

# =========================================================================
# Helpers
# =========================================================================

fn extract_tag_name(tag_content: text) -> text:
    """Extract the tag name from tag content like 'div class=\"foo\"'."""
    val space_idx = tag_content.index_of(" ", 0)
    if space_idx < 0:
        return tag_content.to_lower()
    return tag_content[0:space_idx].to_lower()

fn extract_attributes(tag_content: text) -> List<Attr>:
    """Extract attributes from tag content."""
    var attrs = List<Attr>()
    val space_idx = tag_content.index_of(" ", 0)
    if space_idx < 0:
        return attrs

    val attr_text = tag_content[space_idx + 1:]
    # Split on spaces to find name="value" pairs
    val parts = attr_text.split(" ")
    for part in parts:
        val eq_idx = part.index_of("=", 0)
        if eq_idx > 0:
            val name = part[0:eq_idx]
            var value = part[eq_idx + 1:]
            # Strip quotes
            if value.starts_with("\"") and value.ends_with("\""):
                value = value[1:value.len() - 1]
            attrs = attrs.push(Attr.create(name, value))
    return attrs

fn is_void_element(tag_name: text) -> bool:
    """Check if an HTML element is void (self-closing by spec)."""
    match tag_name:
        "br" | "hr" | "img" | "input" | "meta" | "link" | "area" | "base" | "col" | "embed" | "source" | "track" | "wbr":
            return true
        _:
            return false

fn parse_selector(selector_text: text) -> Selector:
    """Parse a simple CSS selector string into a Selector."""
    var parts = List<SelectorPart>()
    val trimmed = selector_text.trim()

    if trimmed.starts_with("#"):
        parts = parts.push(SelectorPart.Id(name: trimmed[1:]))
    elif trimmed.starts_with("."):
        parts = parts.push(SelectorPart.Class(name: trimmed[1:]))
    elif trimmed == "*":
        parts = parts.push(SelectorPart.Universal)
    else:
        parts = parts.push(SelectorPart.Type(name: trimmed))

    return Selector.create(parts)

fn parse_declarations(decls_text: text) -> List<CSSDeclaration>:
    """Parse CSS declarations like 'color: red; font-size: 14px'."""
    var decls = List<CSSDeclaration>()
    val parts = decls_text.split(";")
    for part in parts:
        val trimmed = part.trim()
        if trimmed.len() == 0:
            continue
        val colon_idx = trimmed.index_of(":", 0)
        if colon_idx < 0:
            continue
        val prop = trimmed[0:colon_idx].trim()
        val val_text = trimmed[colon_idx + 1:].trim()

        val css_val = parse_css_value(val_text)
        decls = decls.push(CSSDeclaration.create(prop, css_val))
    return decls

fn parse_css_value(val_text: text) -> CSSValue:
    """Parse a CSS value string into a CSSValue."""
    # Check for length units
    if val_text.ends_with("px"):
        val num_str = val_text[0:val_text.len() - 2]
        return CSSValue.Length(v: num_str.to_f64(), unit: "px")
    if val_text.ends_with("em"):
        val num_str = val_text[0:val_text.len() - 2]
        return CSSValue.Length(v: num_str.to_f64(), unit: "em")
    if val_text.ends_with("rem"):
        val num_str = val_text[0:val_text.len() - 3]
        return CSSValue.Length(v: num_str.to_f64(), unit: "rem")
    if val_text.ends_with("%"):
        val num_str = val_text[0:val_text.len() - 1]
        return CSSValue.Percentage(v: num_str.to_f64())

    # Check for inherit/initial/unset
    if val_text == "inherit":
        return CSSValue.Inherit
    if val_text == "initial":
        return CSSValue.Initial
    if val_text == "unset":
        return CSSValue.Unset

    # Check for hex color
    if val_text.starts_with("#"):
        return CSSValue.Keyword(v: val_text)

    # Default: treat as keyword
    return CSSValue.Keyword(v: val_text)
