# bin/simple browser <file.ui.sdn> [--snapshot=<out.ppm>] [--open]
#
# Headless one-shot renderer for the in-process browser engine.
#
# Flags:
#   --snapshot=PATH  Write the framebuffer to PATH (P3 PPM). Defaults to
#                    .build/ui_browser/snapshot.ppm in headless mode.
#   --open           Run the interactive event loop (delegated to
#                    run_browser_gui). Phase B will attach a real window.
#   --backend=NAME   Forwarded to BrowserBackend via parse_backend_flag.

use app.ui.browser.app.{BrowserApp, run_browser_gui, parse_backend_flag}
use std.cli.cli_util.{get_cli_args}

extern fn rt_mkdir_p(path: text) -> bool

fn parse_snapshot_flag(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if a == "--snapshot" and i + 1 < args.len():
            return args[i + 1]
        elif a.starts_with("--snapshot="):
            return a[11:]
        i = i + 1
    ""

fn parse_open_flag(args: [text]) -> bool:
    for a in args:
        if a == "--open":
            return true
    false

fn first_positional(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if not a.starts_with("--"):
            return a
        i = i + 1
    ""

fn ensure_parent_dir(path: text):
    # Ensure the directory portion of `path` exists (best-effort).
    var slash = -1
    var i = 0
    while i < path.len():
        if path[i] == "/":
            slash = i
        i = i + 1
    if slash > 0:
        val dir = path[0:slash]
        rt_mkdir_p(dir)

fn main() -> i64:
    val args = get_cli_args()
    val file_path = first_positional(args)
    if file_path == "":
        print "Usage: simple browser <file.ui.sdn> [--snapshot=<out.ppm>] [--open]"
        return 1

    val open_flag = parse_open_flag(args)
    if open_flag:
        return run_browser_gui(file_path, 0)

    var snapshot_path = parse_snapshot_flag(args)
    if snapshot_path == "":
        rt_mkdir_p(".build/ui_browser")
        snapshot_path = ".build/ui_browser/snapshot.ppm"
    else:
        ensure_parent_dir(snapshot_path)

    val gpu_backend = parse_backend_flag()
    val app_result = BrowserApp.new(file_path, 0, gpu_backend)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            return app.run_once(snapshot_path)
