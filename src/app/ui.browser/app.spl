# Browser Engine Application Main Loop
#
# Runs the browser-engine mode: loads .ui.sdn, converts widgets to DOM,
# layouts and paints via the 2D engine, polls for input events.
# This backend renders entirely in-process using the browser engine
# and a GPU-accelerated (or software) 2D engine.

use common.ui.widget.{UIEvent}
use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use nogc_sync_mut.ui.session.{UISession}
use nogc_sync_mut.ui.access_store.{ui_access_store_runtime_open_with_override}
use nogc_sync_mut.ui.gui_renderer.{GuiRenderer, GuiEvent, GUI_EVT_NONE}
use app.ui.browser.backend.{BrowserBackend}
use app.ui.browser.event_bridge.{translate_key_event, translate_mouse_event}
use std.io_runtime.{file_exists, get_args, read_file, time_now_unix_micros}
use std.diag.{dbg_stage}
use lazy common.window_protocol.geometry.{Size}
use lazy os.compositor.host_compositor_entry.{HostBackendKind, HostWmConfig, HostWmHandle, init_host_wm}

# Host window state — backed by the GuiRenderer facade (backend-isolation
# Gap A: no raw winit extern declarations in the app layer; the facade dlopens the
# spl_winit sibling cdylib instead). The browser_winit_* wrappers keep their
# original handle-style signatures so the main loop below is unchanged.
var _host_gui: GuiRenderer = GuiRenderer.empty()
var _host_gui_event: GuiEvent = GuiEvent.none()

fn browser_winit_event_loop_new() -> i64:
    # The facade creates the native event loop together with the window in
    # browser_winit_window_new; report readiness with a placeholder token.
    1

fn browser_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64:
    val created = GuiRenderer.create("auto", w.to_i32(), h.to_i32(), title)
    match created:
        case Some(g):
            _host_gui = g
            1
        case None:
            0

fn browser_winit_event_loop_poll_events(el: i64, max: i64) -> i64:
    val e = _host_gui.poll_event()
    _host_gui_event = e
    if e.kind == GUI_EVT_NONE:
        return 0
    1

fn browser_winit_event_get_type(ev: i64) -> i64:
    _host_gui_event.kind

fn browser_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool):
    (_host_gui_event.scancode, _host_gui_event.keycode, _host_gui_event.pressed)

fn browser_winit_event_mouse_moved(ev: i64) -> (f64, f64):
    (_host_gui_event.x, _host_gui_event.y)

fn browser_winit_event_mouse_button(ev: i64) -> (i64, bool):
    (_host_gui_event.btn, _host_gui_event.pressed)

fn browser_winit_event_free(ev: i64):
    _host_gui_event = GuiEvent.none()

fn browser_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64]) -> bool:
    _host_gui.present_rgba(w, h, pixels)

fn browser_winit_window_free(win: i64):
    _host_gui.close()

fn browser_winit_event_loop_free(el: i64):
    _host_gui.close()
    _host_gui = GuiRenderer.empty()

fn browser_time_now_unix_micros() -> i64:
    time_now_unix_micros()

val EVT_CLOSE: i64 = 3
val EVT_KEYBOARD: i64 = 10
val EVT_MOUSE_BUTTON: i64 = 20
val EVT_MOUSE_MOVED: i64 = 21
val HOST_WINDOW_TITLE: text = "Simple Browser"
val BROWSER_WINDOW_SCALE: i32 = 1
val FILE_CHANGE_POLL_INTERVAL_TICKS: i32 = 15

fn browser_file_change_poll_next(had_event: bool, ticks: i32, interval: i32) -> (bool, i32):
    if had_event:
        return (true, 0)
    val next_ticks = ticks + 1
    if next_ticks >= interval:
        return (true, 0)
    (false, next_ticks)

# =========================================================================
# BrowserApp
# =========================================================================

class BrowserApp:
    file_path: text
    session: UISession
    backend: BrowserBackend
    running: bool
    last_file_content: text
    last_mouse_x: i32
    last_mouse_y: i32
    file_change_poll_ticks: i32
    file_change_poll_interval_ticks: i32

    static fn new(file_path: text, port: i32, gpu_backend: text, web_engine: text = "pure_simple") -> Result<BrowserApp, text>:
        return BrowserApp.new_with_access_store_path(file_path, port, gpu_backend, "", web_engine)

    static fn file_poll_interval_ticks() -> i32:
        FILE_CHANGE_POLL_INTERVAL_TICKS

    static fn new_with_access_store_path(file_path: text, port: i32, gpu_backend: text, access_db_path: text, web_engine: text = "pure_simple") -> Result<BrowserApp, text>:
        dbg_stage("browser", "parse_start")
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                dbg_stage("browser", "parse_done")
                var session = UISession.new(tree)
                session.set_active_backend("browser")
                if access_db_path != "":
                    val store = ui_access_store_runtime_open_with_override(access_db_path, file_path, "browser")
                    if store != nil:
                        session.attach_access_store(store)
                val width: i32 = 672
                val height: i32 = 448
                dbg_stage("browser", "backend_create_start")
                val backend_result = BrowserBackend.create(width, height, gpu_backend, web_engine)
                match backend_result:
                    Err(e):
                        return Err(e)
                    Ok(backend):
                        dbg_stage("browser", "backend_create_done")
                        val content = if file_exists(file_path):
                            read_file(file_path) ?? ""
                        else:
                            ""

                        return Ok(BrowserApp(
                            file_path: file_path,
                            session: session,
                            backend: backend,
                            running: true,
                            last_file_content: content,
                            last_mouse_x: 0,
                            last_mouse_y: 0,
                            file_change_poll_ticks: 0,
                            file_change_poll_interval_ticks: FILE_CHANGE_POLL_INTERVAL_TICKS
                        ))

    me run_once(snapshot_path: text) -> i64:
        """Headless one-shot: render a single frame and snapshot to PPM.

        Returns 0 on success, 1 on failure.
        """
        val state = self.session.current_state()
        self.backend.render_frame(state.tree, state)
        val ok = self.backend.snapshot_ppm(snapshot_path)
        self.backend.shutdown()
        if ok:
            return 0
        return 1

    me run() -> bool:
        """Main browser engine loop with a real hosted window."""
        var presentation_ok = true
        val width = (self.backend.viewport_width() * BROWSER_WINDOW_SCALE).to_i64()
        val height = (self.backend.viewport_height() * BROWSER_WINDOW_SCALE).to_i64()
        val event_loop = browser_winit_event_loop_new()
        if event_loop == 0:
            print "Error: failed to create host event loop"
            self.backend.shutdown()
            return false

        val window = browser_winit_window_new(event_loop, width, height, HOST_WINDOW_TITLE)
        if window == 0:
            print "Error: failed to create host browser window"
            browser_winit_event_loop_free(event_loop)
            self.backend.shutdown()
            return false
        dbg_stage("browser", "window_created")

        val initial_state = self.session.current_state()
        dbg_stage("browser", "first_frame_start")
        self.backend.render_frame(initial_state.tree, initial_state)
        dbg_stage("browser", "first_frame_done")
        if not self.present_host_window(window):
            print "Error: failed to present initial browser frame"
            browser_winit_window_free(window)
            browser_winit_event_loop_free(event_loop)
            self.backend.shutdown()
            return false

        var next_present_at = browser_time_now_unix_micros() + 16000
        while self.running:
            var had_event = false
            var ev = browser_winit_event_loop_poll_events(event_loop, 1)
            while ev != 0:
                had_event = true
                self.handle_host_event(ev)
                browser_winit_event_free(ev)
                ev = browser_winit_event_loop_poll_events(event_loop, 1)

            val should_poll_file = self.consume_file_change_poll(had_event)
            if should_poll_file:
                if self.check_file_changes():
                    had_event = true

            val now = browser_time_now_unix_micros()
            if had_event or now >= next_present_at:
                val state = self.session.current_state()
                self.backend.render_frame(state.tree, state)
                if not self.present_host_window(window):
                    print "Error: failed to present browser frame"
                    presentation_ok = false
                    self.running = false
                next_present_at = now + 16000

        browser_winit_window_free(window)
        browser_winit_event_loop_free(event_loop)
        self.backend.shutdown()
        presentation_ok

    me consume_file_change_poll(had_event: bool) -> bool:
        """Throttle idle file reload checks while preserving event-time checks."""
        val (should_poll, next_ticks) = browser_file_change_poll_next(had_event, self.file_change_poll_ticks, self.file_change_poll_interval_ticks)
        self.file_change_poll_ticks = next_ticks
        should_poll

    me check_file_changes() -> bool:
        """Check if the .ui.sdn file has changed and reload if so."""
        if not file_exists(self.file_path):
            return false

        val current_content = read_file(self.file_path) ?? ""
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_to_tree(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.session.update_tree(new_tree)
                    return true
                Err(e):
                    # Keep old state on parse error
                    return false
        return false

    me handle_ui_event(event: UIEvent):
        match event:
            UIEvent.Quit:
                self.running = false
            _:
                self.session.dispatch(event)

    me handle_host_event(ev: i64):
        val event_type = browser_winit_event_get_type(ev)
        if event_type == EVT_CLOSE:
            self.running = false
            return

        if event_type == EVT_KEYBOARD:
            val (_scancode, keycode, pressed) = browser_winit_event_keyboard_input(ev)
            if pressed:
                val translated = translate_key_event(keycode.to_i32(), 0)
                if translated != nil:
                    self.handle_ui_event(translated)
            return

        if event_type == EVT_MOUSE_MOVED:
            val (mouse_x, mouse_y) = browser_winit_event_mouse_moved(ev)
            self.last_mouse_x = mouse_x.to_i32() / BROWSER_WINDOW_SCALE
            self.last_mouse_y = mouse_y.to_i32() / BROWSER_WINDOW_SCALE
            val translated = translate_mouse_event(
                self.last_mouse_x,
                self.last_mouse_y,
                0,
                "move"
            )
            if translated != nil:
                self.handle_ui_event(translated)
            return

        if event_type == EVT_MOUSE_BUTTON:
            val (button_code, pressed) = browser_winit_event_mouse_button(ev)
            val action = if pressed:
                "press"
            else:
                "release"
            val translated = translate_mouse_event(
                self.last_mouse_x,
                self.last_mouse_y,
                button_code.to_i32(),
                action
            )
            if translated != nil:
                self.handle_ui_event(translated)

    me present_host_window(window: i64) -> bool:
        val pixels = self.backend.pixels_rgba_i64()
        browser_winit_window_present_rgba(
            window,
            self.backend.viewport_width().to_i64(),
            self.backend.viewport_height().to_i64(),
            pixels
        )

# =========================================================================
# Entry Point
# =========================================================================

fn run_browser_gui(file_path: text, port: i32) -> i64:
    return run_browser_gui_with_access_store(file_path, port, "")

# Pure config builder split out from run_shared_wm_browser so the shared-WM
# handoff shape is unit-testable without entering HostWmHandle.tick_forever's
# blocking loop (mirrors why shared_wm_entrypoints_spec.spl avoids calling
# run_shared_wm_* directly).
fn browser_shared_wm_config(title: text) -> HostWmConfig:
    HostWmConfig(
        backend: HostBackendKind.Browser,
        initial_size: Size.wh(1280, 800),
        title: title
    )

# Joins the shared host WM (os.compositor.host_compositor_entry) as a
# Browser-backend hosted window instead of spawning a standalone winit
# window. Mirrors run_shared_wm_electron/_tauri/_tui in the sibling
# ui.electron/ui.tauri/ui.tui async_app.spl entrypoints.
fn run_shared_wm_browser(title: text) -> i64:
    dbg_stage("browser", "shared_wm_init_start")
    val config = browser_shared_wm_config(title)
    val handle = init_host_wm(config)
    if handle == nil:
        print "Error: failed to initialise shared WM (Browser backend)"
        return 1
    dbg_stage("browser", "shared_wm_init_done")
    handle.tick_forever()
    return 0

fn run_browser_gui_with_access_store(file_path: text, port: i32, access_db_path: text, shared_wm: bool = false) -> i64:
    """Start browser-engine mode for a .ui.sdn file."""
    dbg_stage("browser", "launch_start")
    if shared_wm:
        return run_shared_wm_browser("Simple Browser")

    if not file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1
    dbg_stage("browser", "file_checked")

    val gpu_backend = parse_backend_flag()
    val web_engine = parse_web_engine_flag()

    val app_result = BrowserApp.new_with_access_store_path(file_path, port, gpu_backend, access_db_path, web_engine)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            dbg_stage("browser", "app_created")
            if app.run():
                return 0
            return 1

fn parse_backend_flag() -> text:
    """Parse --backend flag from CLI args. Defaults to auto-detect."""
    val raw_args = get_args()
    var i = 0
    while i < raw_args.len():
        val arg = raw_args[i]
        if arg == "--backend" and i + 1 < raw_args.len():
            return raw_args[i + 1]
        elif arg.starts_with("--backend="):
            return arg[10:]
        i = i + 1
    return "auto"

fn parse_web_engine_flag() -> text:
    """Parse --web-engine flag from CLI args (Gap B: WebRenderer facade engine
    selector, distinct from --backend which selects the Engine2D backend).
    Defaults to "pure_simple" — no flag/env means unchanged default behavior.
    An unrecognized value is passed through unvalidated here; BrowserBackend.create
    loud-fails (Result::Err) rather than silently normalizing it, so callers see
    an honest error instead of a silent fallback to the default engine."""
    val raw_args = get_args()
    var i = 0
    while i < raw_args.len():
        val arg = raw_args[i]
        if arg == "--web-engine" and i + 1 < raw_args.len():
            return raw_args[i + 1]
        elif arg.starts_with("--web-engine="):
            return arg[13:]
        i = i + 1
    return "pure_simple"
