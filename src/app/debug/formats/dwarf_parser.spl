# DWARF Parser
# Pure-Simple DWARF debug info parser implementing DebugInfoProvider.
# Parses .debug_info, .debug_abbrev, .debug_line, .debug_str sections.
# Supports DWARF v2-v4 in ELF and Mach-O binaries.

use std.debug.formats.debug_types.{SourceLocation, DebugFunction, DebugVariable, DebugLineEntry, DebugCompilationUnit, DebugFormatKind}
use std.debug.formats.debug_provider.{DebugInfoProvider}

# Raw sections extracted from the binary.
class DwarfSections:
    debug_info: [u8]
    debug_abbrev: [u8]
    debug_line: [u8]
    debug_str: [u8]

class DwarfParser:
    sections: DwarfSections
    units: [DebugCompilationUnit]
    all_line_entries: [DebugLineEntry]
    all_functions: [DebugFunction]
    parsed: bool

    static fn from_elf(data: [u8]) -> Result<DwarfParser, text>:
        val sections = DwarfSections(debug_info: [], debug_abbrev: [], debug_line: [], debug_str: [])
        Ok(DwarfParser(sections: sections, units: [], all_line_entries: [], all_functions: [], parsed: false))

    static fn from_macho(data: [u8]) -> Result<DwarfParser, text>:
        val sections = DwarfSections(debug_info: [], debug_abbrev: [], debug_line: [], debug_str: [])
        Ok(DwarfParser(sections: sections, units: [], all_line_entries: [], all_functions: [], parsed: false))

    static fn from_sections(sections: DwarfSections) -> Result<DwarfParser, text>:
        Ok(DwarfParser(sections: sections, units: [], all_line_entries: [], all_functions: [], parsed: false))

    fn format_kind() -> DebugFormatKind:
        DebugFormatKind.Dwarf

    fn addr_to_source(addr: i64) -> SourceLocation?:
        var best: DebugLineEntry? = nil
        for entry in self.all_line_entries:
            if entry.end_sequence:
                pass_dn
            elif entry.address <= addr:
                if best.?:
                    if entry.address > best!.address:
                        best = entry
                else:
                    best = entry
        if best.?:
            return best!.location
        nil

    fn source_to_addr(file: text, line: i64) -> i64?:
        for entry in self.all_line_entries:
            if entry.end_sequence:
                pass_dn
            elif entry.location.line == line and entry.location.file.ends_with(file):
                return entry.address
        nil

    fn function_at(addr: i64) -> DebugFunction?:
        for func in self.all_functions:
            if func.low_pc <= addr and addr < func.high_pc:
                return func
        nil

    fn functions_in_range(low: i64, high: i64) -> [DebugFunction]:
        var result: [DebugFunction] = []
        for func in self.all_functions:
            if func.low_pc < high and func.high_pc > low:
                result.push(func)
        result

    fn locals_at(addr: i64) -> [DebugVariable]:
        []

    fn compilation_units() -> [DebugCompilationUnit]:
        self.units

    fn line_entries() -> [DebugLineEntry]:
        self.all_line_entries
