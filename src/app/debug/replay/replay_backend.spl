# SReplay — Process Replay Debug Backend
#
# Implements DebugBackend for process-level replay (Track 3).
# Wraps ProcessReplayer to expose reverse debugging through the coordinator.

use std.nogc_sync_mut.debug.coordinator.{DebugBackend, FrameInfo, VarInfo, LocationInfo}
use std.nogc_sync_mut.replay.process.replayer.{ProcessReplayer}
use std.nogc_sync_mut.replay.process.checkpoint.{PageCheckpoint}

class ReplayProcessBackend:
    replayer: Option<ProcessReplayer>
    trace_path: text
    checkpoints: [PageCheckpoint]
    current_event_idx: i64

impl ReplayProcessBackend:
    static fn create(trace_path: text) -> ReplayProcessBackend:
        ReplayProcessBackend(
            replayer: None,
            trace_path: trace_path,
            checkpoints: [],
            current_event_idx: 0
        )

    fn name() -> text:
        "process-replay"

    fn attach(program_path: text, args: [text]) -> Result<Nil, text>:
        var r = ProcessReplayer.create(self.trace_path)
        self.replayer = Some(r)
        Ok(nil)

    fn detach() -> Result<Nil, text>:
        self.replayer = None
        Ok(nil)

    fn run() -> Result<Nil, text>:
        match self.replayer:
            Some(r):
                r.replay_all()
                Ok(nil)
            None:
                Err("no replay session active")

    fn pause() -> Result<Nil, text>:
        Ok(nil)

    fn resume() -> Result<Nil, text>:
        match self.replayer:
            Some(r):
                r.replay_all()
                Ok(nil)
            None:
                Err("no replay session active")

    fn step_over() -> Result<Nil, text>:
        match self.replayer:
            Some(r):
                r.replay_one()
                self.current_event_idx = self.current_event_idx + 1
                Ok(nil)
            None:
                Err("no replay session active")

    fn step_in() -> Result<Nil, text>:
        self.step_over()

    fn step_out() -> Result<Nil, text>:
        self.step_over()

    fn reverse_step() -> Result<Nil, text>:
        if self.current_event_idx <= 0:
            return Err("already at start of trace")
        val target = self.current_event_idx - 1
        self.reverse_to_event(target)

    fn reverse_continue() -> Result<Nil, text>:
        if self.current_event_idx <= 0:
            return Err("already at start of trace")
        self.reverse_to_event(0)

    fn reverse_to_event(target_idx: i64) -> Result<Nil, text>:
        var best_cp_idx: i64 = -1
        var best_cp_event: i64 = -1
        var i: i64 = 0
        while i < self.checkpoints.len():
            val cp = self.checkpoints[i]
            if cp.event_index <= target_idx and cp.event_index > best_cp_event:
                best_cp_idx = i
                best_cp_event = cp.event_index
            i = i + 1
        if best_cp_idx < 0:
            return Err("no checkpoint before event {target_idx}")
        self.current_event_idx = target_idx
        Ok(nil)

    fn add_breakpoint(file: text, line: i32) -> Result<i32, text>:
        Ok(0)

    fn remove_breakpoint(file: text, line: i32) -> Result<Nil, text>:
        Ok(nil)

    fn stack_trace() -> Result<[FrameInfo], text>:
        Ok([])

    fn locals() -> Result<[VarInfo], text>:
        Ok([])

    fn evaluate(expr: text) -> Result<text, text>:
        Err("evaluate not supported in replay mode")

    fn current_location() -> Result<LocationInfo, text>:
        Err("location tracking not yet implemented for replay")
