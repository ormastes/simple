"""Trust Store — manage trusted package signers

Stores trusted signer fingerprints, trust levels, and revocation lists
in SDN format at ~/.simple/trusted_signers.sdn.

Usage:
    var store = TrustStore.default()
    store.add_trusted("abc123...", "Alice", TrustLevel.UserTrusted, 365)?
    store.save()?

    if store.is_trusted("abc123..."):
        install_package(...)

SDN file format (trusted_signers.sdn):
    # Simple Trusted Signers
    signers:
      fingerprint: abc123...
      name: Alice
      trust_level: user
      added_at: 2026-01-01T00:00:00Z
      expires_at: 2027-01-01T00:00:00Z
      added_by: user

    revoked:
      abc123...
"""

use std.fs.{read_file, write_file, is_file, file_exists}

# --- Data Types ---

enum TrustLevel:
    """Trust level for a package signer."""
    RegistryTrusted
    UserTrusted
    Untrusted
    Revoked

class TrustedSigner:
    """A trusted signing identity."""
    fingerprint: text
    name: text
    trust_level: TrustLevel
    added_at: text
    expires_at: text
    added_by: text

class TrustStore:
    """Database of trusted package signers and revocations.

    Loaded from and saved to ~/.simple/trusted_signers.sdn.
    """
    trusted_signers: [TrustedSigner]
    revocation_list: [text]
    store_path: text

    static fn load(path: text) -> Result<TrustStore, text>:
        """Load a trust store from an SDN file.

        Args:
            path: Path to the trusted_signers.sdn file

        Returns: Parsed trust store, or error if file is corrupt.
        """
        if not is_file(path):
            # No trust store file — return empty store
            return Ok(TrustStore(
                trusted_signers: [],
                revocation_list: [],
                store_path: path
            ))

        val content = read_file(path)
        if content == "":
            return Ok(TrustStore(
                trusted_signers: [],
                revocation_list: [],
                store_path: path
            ))

        parse_trust_store(content, path)

    static fn default() -> TrustStore:
        """Load from the default path ~/.simple/trusted_signers.sdn.

        Returns an empty store if the file does not exist.
        """
        val home = home_dir()
        val path = "{home}/.simple/trusted_signers.sdn"
        val result = TrustStore.load(path)
        match result:
            Ok(store): store
            Err(_): TrustStore(
                trusted_signers: [],
                revocation_list: [],
                store_path: path
            )

    me save() -> Result<(), text>:
        """Persist the trust store to disk in SDN format."""
        val content = serialize_trust_store(self)
        write_file(self.store_path, content)
        Ok(())

    me add_trusted(fingerprint: text, name: text, trust_level: TrustLevel, expiry_days: i64) -> Result<(), text>:
        """Add a signer to the trusted list.

        Args:
            fingerprint: SHA-256 fingerprint of the signer's public key
            name: Human-readable name for the signer
            trust_level: RegistryTrusted or UserTrusted
            expiry_days: Number of days until this trust entry expires (0 = no expiry)

        Returns: Ok if added, Err if fingerprint is revoked.
        """
        # Cannot trust a revoked signer
        if self.is_revoked(fingerprint):
            return Err("cannot trust revoked signer: {fingerprint}")

        # Check for existing entry — update if present
        for i in 0..self.trusted_signers.len():
            if self.trusted_signers[i].fingerprint == fingerprint:
                self.trusted_signers[i] = TrustedSigner(
                    fingerprint: fingerprint,
                    name: name,
                    trust_level: trust_level,
                    added_at: current_timestamp(),
                    expires_at: compute_expiry(expiry_days),
                    added_by: "user"
                )
                return Ok(())

        self.trusted_signers.push(TrustedSigner(
            fingerprint: fingerprint,
            name: name,
            trust_level: trust_level,
            added_at: current_timestamp(),
            expires_at: compute_expiry(expiry_days),
            added_by: "user"
        ))
        Ok(())

    me remove_trusted(fingerprint: text) -> bool:
        """Remove a signer from the trusted list.

        Returns: true if the signer was found and removed.
        """
        var new_list: [TrustedSigner] = []
        var found = false
        for signer in self.trusted_signers:
            if signer.fingerprint == fingerprint:
                found = true
            else:
                new_list.push(signer)
        self.trusted_signers = new_list
        found

    me revoke(fingerprint: text) -> bool:
        """Revoke a signer. Removes from trusted list and adds to revocation list.

        Returns: true if the fingerprint was not already revoked.
        """
        # Remove from trusted
        self.remove_trusted(fingerprint)

        # Add to revocation list if not already there
        for existing in self.revocation_list:
            if existing == fingerprint:
                return false
        self.revocation_list.push(fingerprint)
        true

    fn get_trust_level(fingerprint: text) -> TrustLevel:
        """Get the trust level for a given fingerprint.

        Returns Revoked if in revocation list, Untrusted if not in store.
        """
        if self.is_revoked(fingerprint):
            return TrustLevel.Revoked

        for signer in self.trusted_signers:
            if signer.fingerprint == fingerprint:
                return signer.trust_level

        TrustLevel.Untrusted

    fn is_trusted(fingerprint: text) -> bool:
        """Check if a fingerprint is trusted (not revoked, not expired)."""
        if self.is_revoked(fingerprint):
            return false

        for signer in self.trusted_signers:
            if signer.fingerprint == fingerprint:
                # Check expiry
                if signer.expires_at != "" and signer.expires_at != "never":
                    # Simple string comparison for ISO 8601 dates
                    val now = current_timestamp()
                    if now > signer.expires_at:
                        return false
                return true

        false

    fn is_revoked(fingerprint: text) -> bool:
        """Check if a fingerprint is in the revocation list."""
        for revoked in self.revocation_list:
            if revoked == fingerprint:
                return true
        false

    fn list_trusted() -> [TrustedSigner]:
        """Return all trusted signers (including expired — use is_trusted() to filter)."""
        self.trusted_signers

    me gc():
        """Remove expired signers from the trusted list."""
        val now = current_timestamp()
        var kept: [TrustedSigner] = []
        for signer in self.trusted_signers:
            if signer.expires_at == "" or signer.expires_at == "never":
                kept.push(signer)
            elif signer.expires_at > now:
                kept.push(signer)
            # else: expired — drop it
        self.trusted_signers = kept

# --- Serialization ---

fn serialize_trust_store(store: TrustStore) -> text:
    """Serialize a trust store to SDN format."""
    var out = "# Simple Trusted Signers\n"
    out = out + "# Managed by 'simple trust' commands\n\n"

    if store.trusted_signers.len() > 0:
        out = out + "signers:\n"
        for signer in store.trusted_signers:
            val level_str = trust_level_to_text(signer.trust_level)
            out = out + "  -\n"
            out = out + "    fingerprint: {signer.fingerprint}\n"
            out = out + "    name: {signer.name}\n"
            out = out + "    trust_level: {level_str}\n"
            out = out + "    added_at: {signer.added_at}\n"
            out = out + "    expires_at: {signer.expires_at}\n"
            out = out + "    added_by: {signer.added_by}\n"
        out = out + "\n"

    if store.revocation_list.len() > 0:
        out = out + "revoked:\n"
        for fp in store.revocation_list:
            out = out + "  - {fp}\n"
        out = out + "\n"

    out

fn parse_trust_store(content: text, path: text) -> Result<TrustStore, text>:
    """Parse an SDN trust store file."""
    var signers: [TrustedSigner] = []
    var revoked: [text] = []
    var section = ""
    var current_fp = ""
    var current_name = ""
    var current_level = TrustLevel.Untrusted
    var current_added_at = ""
    var current_expires_at = ""
    var current_added_by = ""
    var in_signer = false

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()

        if trimmed == "" or trimmed.starts_with("#"):
            pass_dn
        elif trimmed == "signers:":
            section = "signers"
        elif trimmed == "revoked:":
            # Flush any pending signer
            if in_signer and current_fp != "":
                signers.push(TrustedSigner(
                    fingerprint: current_fp,
                    name: current_name,
                    trust_level: current_level,
                    added_at: current_added_at,
                    expires_at: current_expires_at,
                    added_by: current_added_by
                ))
                in_signer = false
            section = "revoked"
        elif section == "signers":
            if trimmed == "-":
                # Flush previous signer
                if in_signer and current_fp != "":
                    signers.push(TrustedSigner(
                        fingerprint: current_fp,
                        name: current_name,
                        trust_level: current_level,
                        added_at: current_added_at,
                        expires_at: current_expires_at,
                        added_by: current_added_by
                    ))
                # Reset for new signer
                current_fp = ""
                current_name = ""
                current_level = TrustLevel.Untrusted
                current_added_at = ""
                current_expires_at = ""
                current_added_by = ""
                in_signer = true
            elif trimmed.starts_with("fingerprint:"):
                current_fp = trimmed[12:].trim()
            elif trimmed.starts_with("name:"):
                current_name = trimmed[5:].trim()
            elif trimmed.starts_with("trust_level:"):
                current_level = text_to_trust_level(trimmed[12:].trim())
            elif trimmed.starts_with("added_at:"):
                current_added_at = trimmed[9:].trim()
            elif trimmed.starts_with("expires_at:"):
                current_expires_at = trimmed[11:].trim()
            elif trimmed.starts_with("added_by:"):
                current_added_by = trimmed[9:].trim()
        elif section == "revoked":
            if trimmed.starts_with("-"):
                val fp = trimmed[1:].trim()
                if fp != "":
                    revoked.push(fp)

    # Flush last signer
    if in_signer and current_fp != "":
        signers.push(TrustedSigner(
            fingerprint: current_fp,
            name: current_name,
            trust_level: current_level,
            added_at: current_added_at,
            expires_at: current_expires_at,
            added_by: current_added_by
        ))

    Ok(TrustStore(
        trusted_signers: signers,
        revocation_list: revoked,
        store_path: path
    ))

# --- Display ---

fn format_trust_store(store: TrustStore) -> text:
    """Format the trust store for CLI display."""
    var out = "Trusted Signers ({store.trusted_signers.len()}):\n"

    if store.trusted_signers.len() == 0:
        out = out + "  (none)\n"
    else:
        for signer in store.trusted_signers:
            val level_str = trust_level_to_text(signer.trust_level)
            val short_fp = if signer.fingerprint.len() > 16: signer.fingerprint[0:16] + "..." else: signer.fingerprint
            out = out + "  {short_fp}  {signer.name}  [{level_str}]  expires: {signer.expires_at}\n"

    if store.revocation_list.len() > 0:
        out = out + "\nRevoked ({store.revocation_list.len()}):\n"
        for fp in store.revocation_list:
            val short = if fp.len() > 16: fp[0:16] + "..." else: fp
            out = out + "  {short}\n"

    out

# --- Helpers ---

fn trust_level_to_text(level: TrustLevel) -> text:
    """Convert a TrustLevel enum to its SDN string representation."""
    match level:
        TrustLevel.RegistryTrusted: "registry"
        TrustLevel.UserTrusted: "user"
        TrustLevel.Untrusted: "untrusted"
        TrustLevel.Revoked: "revoked"

fn text_to_trust_level(s: text) -> TrustLevel:
    """Parse a trust level string from SDN."""
    match s:
        "registry": TrustLevel.RegistryTrusted
        "user": TrustLevel.UserTrusted
        "revoked": TrustLevel.Revoked
        _: TrustLevel.Untrusted

fn current_timestamp() -> text:
    """Return current ISO 8601 timestamp.

    Placeholder — uses datetime FFI when available.
    """
    # TODO: [runtime][P2] Use real datetime FFI
    "2026-01-01T00:00:00Z"

fn compute_expiry(days: i64) -> text:
    """Compute expiry date from now + days.

    Args:
        days: Number of days until expiry. 0 means no expiry.

    Returns: ISO 8601 timestamp or "never" if days == 0.
    """
    if days == 0:
        return "never"
    # TODO: [runtime][P2] Use real datetime arithmetic
    # For now return a placeholder
    "2027-01-01T00:00:00Z"

fn home_dir() -> text:
    """Get the user's home directory path."""
    # This delegates to the runtime's home() function
    # Imported via app.io.mod in the full build
    "/home/user"
