"""Package Verification — signature and checksum verification for packages

Fail-closed verification: packages without valid signatures are rejected
unless the user explicitly opts in to untrusted packages.

Usage:
    val trust = TrustStore.default()
    val result = full_verify("pkg-1.0.0.spk", signature, checksum, trust)?
    if result.valid and result.trust_level == TrustLevel.RegistryTrusted:
        install_package(...)
"""

use std.crypto.{hash_sha256, hmac_sha256}
use std.fs.{read_file, is_file}

use app.package.registry.signing.{PackageSignature, hex_to_bytes, bytes_to_hex, hex_digit_value}
use app.package.registry.trust.{TrustStore, TrustLevel, TrustedSigner}

# --- Ed25519 FFI (optional) ---

extern fn rt_ed25519_verify(public_key: text, data: text, signature: text) -> i64

# --- Data Types ---

class VerificationResult:
    """Result of package signature verification."""
    valid: bool
    signer_fingerprint: text
    trust_level: TrustLevel
    message: text

# --- Public API ---

fn verify_package(package_path: text, signature: PackageSignature, trust_store: TrustStore) -> VerificationResult:
    """Verify a package's signature against the trust store.

    Args:
        package_path: Path to the .spk file
        signature: The signature metadata from the registry
        trust_store: Trusted signer database

    Returns: VerificationResult with validity, trust level, and message.
    """
    # Check if signer is revoked first (fail-closed)
    if trust_store.is_revoked(signature.signer_fingerprint):
        return VerificationResult(
            valid: false,
            signer_fingerprint: signature.signer_fingerprint,
            trust_level: TrustLevel.Revoked,
            message: "signer has been revoked: {signature.signer_fingerprint}"
        )

    # Read package content
    if not is_file(package_path):
        return VerificationResult(
            valid: false,
            signer_fingerprint: signature.signer_fingerprint,
            trust_level: TrustLevel.Untrusted,
            message: "package file not found: {package_path}"
        )

    val content = read_file(package_path)
    if content == "":
        return VerificationResult(
            valid: false,
            signer_fingerprint: signature.signer_fingerprint,
            trust_level: TrustLevel.Untrusted,
            message: "package file is empty"
        )

    # Hash the package
    val content_hash = hash_sha256(content)

    # Get signer's public key from trust store
    val trust_level = trust_store.get_trust_level(signature.signer_fingerprint)

    # Verify signature
    val sig_valid = verify_signature(
        hex_to_bytes(content_hash),
        signature.signature,
        get_public_key_for(signature.signer_fingerprint, trust_store)
    )

    if not sig_valid:
        return VerificationResult(
            valid: false,
            signer_fingerprint: signature.signer_fingerprint,
            trust_level: trust_level,
            message: "signature verification failed"
        )

    VerificationResult(
        valid: true,
        signer_fingerprint: signature.signer_fingerprint,
        trust_level: trust_level,
        message: "signature valid"
    )

fn verify_signature(data: [u8], signature: text, public_key: [u8]) -> bool:
    """Verify a raw Ed25519/HMAC signature against data.

    Args:
        data: The data that was signed (typically a hash)
        signature: Hex-encoded signature
        public_key: Raw public key bytes

    Returns: true if the signature is valid, false otherwise.
    """
    if public_key.len() == 0:
        return false

    val data_hex = bytes_to_hex(data)
    val pub_hex = bytes_to_hex(public_key)

    # Try native Ed25519 verification
    val native_result = try_ed25519_verify(pub_hex, data_hex, signature)
    if native_result >= 0:
        return native_result == 1

    # Fallback: HMAC-SHA256 verification
    # In HMAC-SHA256 mode, the "public key" is hash(private_key).
    # We cannot verify directly without the private key.
    # Instead, we check if the signature matches hmac(public_key_as_proxy, data).
    # This is a weaker guarantee — true Ed25519 FFI should be added.
    val expected = hmac_sha256(pub_hex, data_hex)
    expected == signature

fn verify_checksum(package_path: text, expected_checksum: text) -> Result<bool, text>:
    """Verify a package file's SHA-256 checksum.

    Args:
        package_path: Path to the .spk file
        expected_checksum: Expected hex-encoded SHA-256 hash

    Returns: true if checksum matches, false otherwise.
    """
    if not is_file(package_path):
        return Err("package file not found: {package_path}")

    val content = read_file(package_path)
    if content == "":
        return Err("package file is empty")

    val actual = hash_sha256(content)
    Ok(actual == expected_checksum)

fn full_verify(package_path: text, signature: PackageSignature, checksum: text, trust_store: TrustStore) -> Result<VerificationResult, text>:
    """Combined verification: signature + checksum + trust.

    Performs all three verification steps:
    1. Checksum verification (integrity)
    2. Signature verification (authenticity)
    3. Trust level check (authorization)

    This is the recommended entry point for package install verification.

    Args:
        package_path: Path to the .spk file
        signature: Signature metadata from the registry index
        checksum: Expected SHA-256 checksum from the registry index
        trust_store: Trusted signer database

    Returns: VerificationResult with combined status.
    """
    # Step 1: Checksum
    val checksum_ok = verify_checksum(package_path, checksum)?
    if not checksum_ok:
        return Ok(VerificationResult(
            valid: false,
            signer_fingerprint: signature.signer_fingerprint,
            trust_level: TrustLevel.Untrusted,
            message: "checksum mismatch — package may have been tampered with"
        ))

    # Step 2: Signature + trust
    val sig_result = verify_package(package_path, signature, trust_store)
    if not sig_result.valid:
        return Ok(sig_result)

    # Step 3: Trust level assessment
    match sig_result.trust_level:
        TrustLevel.Revoked:
            return Ok(VerificationResult(
                valid: false,
                signer_fingerprint: signature.signer_fingerprint,
                trust_level: TrustLevel.Revoked,
                message: "signer has been revoked — do not install"
            ))
        TrustLevel.RegistryTrusted:
            return Ok(VerificationResult(
                valid: true,
                signer_fingerprint: signature.signer_fingerprint,
                trust_level: TrustLevel.RegistryTrusted,
                message: "verified — signed by registry-trusted signer"
            ))
        TrustLevel.UserTrusted:
            return Ok(VerificationResult(
                valid: true,
                signer_fingerprint: signature.signer_fingerprint,
                trust_level: TrustLevel.UserTrusted,
                message: "verified — signed by user-trusted signer"
            ))
        TrustLevel.Untrusted:
            return Ok(VerificationResult(
                valid: true,
                signer_fingerprint: signature.signer_fingerprint,
                trust_level: TrustLevel.Untrusted,
                message: "signature valid but signer is not trusted — use 'simple trust add' to trust"
            ))

    Ok(sig_result)

# --- Internal Helpers ---

fn try_ed25519_verify(pub_hex: text, data_hex: text, signature: text) -> i64:
    """Try native Ed25519 verification.

    Returns:
        1  — signature valid
        0  — signature invalid
       -1  — Ed25519 FFI not available
    """
    # The extern fn may be auto-stubbed. Return -1 to trigger fallback.
    -1

fn get_public_key_for(fingerprint: text, trust_store: TrustStore) -> [u8]:
    """Look up a signer's public key from the trust store.

    Currently returns empty bytes if the signer is not in the store.
    The trust store would need to store public keys alongside fingerprints
    for full verification. For now, the fingerprint itself is used as a
    proxy in the HMAC-SHA256 fallback mode.
    """
    val trusted = trust_store.list_trusted()
    for signer in trusted:
        if signer.fingerprint == fingerprint:
            # Return fingerprint as pseudo-key for HMAC fallback
            return hex_to_bytes(fingerprint)
    []

fn format_verification_result(result: VerificationResult) -> text:
    """Format a verification result for CLI display."""
    val status = if result.valid: "PASS" else: "FAIL"
    val trust_label = match result.trust_level:
        TrustLevel.RegistryTrusted: "registry-trusted"
        TrustLevel.UserTrusted: "user-trusted"
        TrustLevel.Untrusted: "untrusted"
        TrustLevel.Revoked: "REVOKED"

    "[{status}] {trust_label} | signer: {result.signer_fingerprint[0:16]}... | {result.message}"
