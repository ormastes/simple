# Blink DOM interaction state — blink.dom.interaction_state
#
# Tracks per-node interaction state (hover, focus, active, etc.) for CSS
# pseudo-class matching in the selector engine.
# Consumer: blink/css_parser/selector.spl

struct InteractionState:
    """Per-node interaction flags used by CSS pseudo-class selectors."""
    hovered: bool
    focused: bool
    active: bool
    visited: bool
    checked: bool
    disabled: bool
    read_only: bool

fn interaction_state_empty() -> InteractionState:
    """Return an InteractionState with all flags false (default/idle state)."""
    InteractionState(
        hovered: false,
        focused: false,
        active: false,
        visited: false,
        checked: false,
        disabled: false,
        read_only: false
    )
