#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Baremetal Math Utilities
#
# Allocation-free integer math functions for bare-metal and embedded targets.
# All functions operate on i64 values with no heap allocation.
#
# Functions:
#   bm_abs    - Absolute value
#   bm_min    - Minimum of two values
#   bm_max    - Maximum of two values
#   bm_clamp  - Clamp value to [lo, hi] range
#   bm_pow    - Integer exponentiation (iterative)
#   bm_isqrt  - Integer square root (Newton's method)
#   bm_gcd    - Greatest common divisor (Euclidean algorithm)
#   bm_lcm    - Least common multiple
#
# Usage:
#   use std.math.{bm_abs, bm_min, bm_max, bm_clamp}
#   use std.math.{bm_pow, bm_isqrt, bm_gcd, bm_lcm}


# ============================================================================
# Basic Arithmetic Utilities
# ============================================================================

fn bm_abs(x: i64) -> i64:
    """Return the absolute value of x.

    Returns x unchanged if non-negative, -x otherwise.
    Note: bm_abs(i64::MIN) is undefined behaviour (overflow).

    Example:
        bm_abs(-5)   # => 5
        bm_abs(3)    # => 3
        bm_abs(0)    # => 0
    """
    if x < 0:
        return -x
    x

fn bm_min(a: i64, b: i64) -> i64:
    """Return the smaller of a and b.

    Example:
        bm_min(3, 7)   # => 3
        bm_min(-1, 0)  # => -1
    """
    if a < b:
        return a
    b

fn bm_max(a: i64, b: i64) -> i64:
    """Return the larger of a and b.

    Example:
        bm_max(3, 7)   # => 7
        bm_max(-1, 0)  # => 0
    """
    if a > b:
        return a
    b

fn bm_clamp(x: i64, lo: i64, hi: i64) -> i64:
    """Clamp x to the inclusive range [lo, hi].

    Returns lo if x < lo, hi if x > hi, otherwise x.
    Requires lo <= hi.

    Example:
        bm_clamp(5, 0, 10)   # => 5
        bm_clamp(-3, 0, 10)  # => 0
        bm_clamp(15, 0, 10)  # => 10
    """
    if x < lo:
        return lo
    if x > hi:
        return hi
    x

# ============================================================================
# Power and Root
# ============================================================================

fn bm_pow(base: i64, exp: i64) -> i64:
    """Raise base to the power exp (iterative, no allocation).

    Returns 1 for exp == 0 (including 0^0 = 1 by convention).
    Negative exponents return 0 (integer truncation).

    Example:
        bm_pow(2, 10)  # => 1024
        bm_pow(3, 0)   # => 1
        bm_pow(5, 1)   # => 5
    """
    if exp <= 0:
        return 1
    var result: i64 = 1
    var b = base
    var e = exp
    while e > 0:
        if (e & 1) == 1:
            result = result * b
        b = b * b
        e = e >> 1
    result

fn bm_isqrt(n: i64) -> i64:
    """Compute the integer square root of n (floor of sqrt(n)).

    Uses Newton's method, converges in O(log n) iterations.
    Returns 0 for n <= 0.

    Example:
        bm_isqrt(9)   # => 3
        bm_isqrt(10)  # => 3
        bm_isqrt(16)  # => 4
        bm_isqrt(0)   # => 0
    """
    if n <= 0:
        return 0
    if n < 4:
        return 1
    # Initial estimate: n / 2
    var x = n / 2
    var x1 = (x + n / x) / 2
    while x1 < x:
        x = x1
        x1 = (x + n / x) / 2
    x

# ============================================================================
# Number Theory
# ============================================================================

fn bm_gcd(a: i64, b: i64) -> i64:
    """Compute the greatest common divisor using the Euclidean algorithm.

    Returns 0 if both inputs are 0. Works on non-negative values;
    absolute values are taken first.

    Example:
        bm_gcd(12, 8)   # => 4
        bm_gcd(7, 5)    # => 1
        bm_gcd(0, 5)    # => 5
    """
    var x = bm_abs(a)
    var y = bm_abs(b)
    while y != 0:
        val t = y
        y = x % y
        x = t
    x

fn bm_lcm(a: i64, b: i64) -> i64:
    """Compute the least common multiple of a and b.

    Returns 0 if either input is 0.
    Uses: lcm(a, b) = abs(a * b) / gcd(a, b)

    Example:
        bm_lcm(4, 6)   # => 12
        bm_lcm(3, 5)   # => 15
        bm_lcm(0, 5)   # => 0
    """
    val g = bm_gcd(a, b)
    if g == 0:
        return 0
    bm_abs(a / g * b)
