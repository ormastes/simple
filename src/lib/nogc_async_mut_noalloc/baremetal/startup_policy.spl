# Bare-Metal Startup Policy
#
# Pure Simple startup defaults shared by examples before importing architecture
# startup capsules. Register setup and trap instructions stay platform-local.

fn baremetal_startup_stack_top(ram_base: u32, ram_size: u32) -> u32:
    ram_base + ram_size

fn baremetal_startup_hart_count(harts: i32) -> i32:
    if harts < 1:
        return 1
    harts

fn baremetal_startup_is_primary_hart(hart_id: i32) -> bool:
    hart_id == 0
