# Bare-Metal Semihost Stdout Policy
#
# Pure Simple metadata for stdout operation safety. Keep semihost_policy.spl
# opcode-only for tiny native probes.

use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_WRITE,
    BAREMETAL_SEMIHOST_OP_WRITE0,
    baremetal_semihost_stdout_op
}

class BaremetalSemihostStdoutPolicy:
    op: i32
    null_safe: bool
    needs_fd: bool

fn baremetal_semihost_stdout_policy(has_write: bool, has_write0: bool) -> BaremetalSemihostStdoutPolicy:
    val op = baremetal_semihost_stdout_op(has_write, has_write0)
    BaremetalSemihostStdoutPolicy(
        op: op,
        null_safe: op != BAREMETAL_SEMIHOST_OP_WRITE0,
        needs_fd: op == BAREMETAL_SEMIHOST_OP_WRITE
    )
