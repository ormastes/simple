# codex-impl
# Fixed-field guest receipt records. No text, arrays, allocation, IO, or runtime
# calls: architecture entries can write these numeric fields to serial/MMIO.

val BACKEND_RENDER_RECEIPT_VERSION: u32 = 1

struct BackendRenderReceiptHeader:
    version: u32
    arch_code: u32
    runtime_code: u32
    backend_code: u32
    firmware_hash_hi: u64
    firmware_hash_lo: u64
    boot_id: u64
    frame_id: u64
    surface_handle: u64
    width: u32
    height: u32
    stride: u32
    format_code: u32

struct BackendRenderReceiptEvent:
    sequence: u32
    operation_code: u32
    resource_id: u64
    state_before: u32
    state_after: u32
    value_hash: u64

struct BackendRenderReceiptTrailer:
    event_count: u32
    frame_complete: bool
    pixel_hash_hi: u64
    pixel_hash_lo: u64
    nonblank_pixel_count: u64
    reason_code: u32

fn backend_render_receipt_header_valid(header: BackendRenderReceiptHeader) -> bool:
    header.version == BACKEND_RENDER_RECEIPT_VERSION and
        header.arch_code > 0 and header.runtime_code > 0 and
        header.backend_code > 0 and header.boot_id > 0 and
        header.frame_id > 0 and header.surface_handle > 0 and
        header.width > 0 and header.height > 0 and
        header.stride >= header.width * 4 and header.format_code > 0

fn backend_render_receipt_event_valid(event: BackendRenderReceiptEvent, expected_sequence: u32) -> bool:
    event.sequence == expected_sequence and event.operation_code > 0 and event.resource_id > 0

fn backend_render_receipt_trailer_valid(trailer: BackendRenderReceiptTrailer, observed_events: u32) -> bool:
    trailer.event_count == observed_events and observed_events > 0 and
        trailer.frame_complete and trailer.nonblank_pixel_count > 0 and
        trailer.reason_code == 0
