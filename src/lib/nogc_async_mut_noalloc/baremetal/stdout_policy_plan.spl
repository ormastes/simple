# Bare-Metal Stdout Policy Plan
#
# Pure Simple composition layer that carries semihost stdout safety metadata.
# Keep stdout_plan.spl opcode-only for tiny native policy probes.

use std.nogc_async_mut_noalloc.baremetal.console_policy.{
    BAREMETAL_CONSOLE_NONE,
    BAREMETAL_CONSOLE_SEMIHOST,
    BAREMETAL_CONSOLE_UART,
    BAREMETAL_UART_QEMU_VIRT,
    BaremetalConsoleConfig,
    baremetal_console_choose
}
use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_WRITEC
}
use std.nogc_async_mut_noalloc.baremetal.semihost_stdout_policy.{
    BaremetalSemihostStdoutPolicy,
    baremetal_semihost_stdout_policy
}

class BaremetalStdoutPolicyPlan:
    console: BaremetalConsoleConfig
    semihost: BaremetalSemihostStdoutPolicy

impl BaremetalStdoutPolicyPlan:
    static fn none() -> BaremetalStdoutPolicyPlan:
        BaremetalStdoutPolicyPlan(
            console: BaremetalConsoleConfig.none(),
            semihost: BaremetalSemihostStdoutPolicy(op: BAREMETAL_SEMIHOST_OP_WRITEC, null_safe: true, needs_fd: false)
        )

fn baremetal_stdout_policy_plan(
    prefer_semihost: bool,
    semihost_available: bool,
    has_write: bool,
    has_write0: bool,
    uart_base: u32
) -> BaremetalStdoutPolicyPlan:
    BaremetalStdoutPolicyPlan(
        console: baremetal_console_choose(prefer_semihost, semihost_available, uart_base),
        semihost: baremetal_semihost_stdout_policy(has_write, has_write0)
    )

fn baremetal_stdout_policy_plan_qemu(prefer_semihost: bool, semihost_available: bool, has_write: bool, has_write0: bool) -> BaremetalStdoutPolicyPlan:
    baremetal_stdout_policy_plan(prefer_semihost, semihost_available, has_write, has_write0, BAREMETAL_UART_QEMU_VIRT)

fn baremetal_stdout_policy_plan_is_enabled(plan: BaremetalStdoutPolicyPlan) -> bool:
    plan.console.mode != BAREMETAL_CONSOLE_NONE

fn baremetal_stdout_policy_plan_uses_semihost(plan: BaremetalStdoutPolicyPlan) -> bool:
    plan.console.mode == BAREMETAL_CONSOLE_SEMIHOST

fn baremetal_stdout_policy_plan_uses_uart(plan: BaremetalStdoutPolicyPlan) -> bool:
    plan.console.mode == BAREMETAL_CONSOLE_UART
