# ============================================================================
# Spec: RISC-V Common — CSR Definitions
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.csr_defs.{CSR_MSTATUS, CSR_MIE, CSR_MTVEC, CSR_MSCRATCH, CSR_MEPC, CSR_MCAUSE, CSR_MTVAL, CSR_MIP, CSR_MHARTID, CSR_MCYCLE, CSR_SSTATUS, CSR_SATP, MSTATUS_MIE, MSTATUS_MPIE, MSTATUS_MPP_MASK, MIE_MSIE, MIE_MTIE, MIE_MEIE, PRIV_USER, PRIV_SUPERVISOR, PRIV_MACHINE, EXC_ILLEGAL_INSN, EXC_ECALL_M, INT_MTI, INT_MEI, MTVEC_DIRECT, MTVEC_VECTORED, csr_name}

describe "CSR addresses":
    it "has correct machine trap setup addresses":
        expect CSR_MSTATUS == 0x300
        expect CSR_MIE == 0x304
        expect CSR_MTVEC == 0x305

    it "has correct machine trap handling addresses":
        expect CSR_MSCRATCH == 0x340
        expect CSR_MEPC == 0x341
        expect CSR_MCAUSE == 0x342
        expect CSR_MTVAL == 0x343
        expect CSR_MIP == 0x344

    it "has correct machine info addresses":
        expect CSR_MHARTID == 0xF14

    it "has correct counter addresses":
        expect CSR_MCYCLE == 0xB00

    it "has correct supervisor addresses":
        expect CSR_SSTATUS == 0x100
        expect CSR_SATP == 0x180

describe "MSTATUS bits":
    it "MIE is bit 3":
        expect MSTATUS_MIE == 8
    it "MPIE is bit 7":
        expect MSTATUS_MPIE == 128
    it "MPP mask covers bits 11-12":
        expect MSTATUS_MPP_MASK == 0x1800

describe "MIE bits":
    it "MSIE is bit 3":
        expect MIE_MSIE == 8
    it "MTIE is bit 7":
        expect MIE_MTIE == 128
    it "MEIE is bit 11":
        expect MIE_MEIE == 2048

describe "privilege levels":
    it "has correct encoding":
        expect PRIV_USER == 0
        expect PRIV_SUPERVISOR == 1
        expect PRIV_MACHINE == 3

describe "exception codes":
    it "has correct values":
        expect EXC_ILLEGAL_INSN == 2
        expect EXC_ECALL_M == 11

describe "interrupt codes":
    it "has correct values":
        expect INT_MTI == 7
        expect INT_MEI == 11

describe "MTVEC modes":
    it "has correct values":
        expect MTVEC_DIRECT == 0
        expect MTVEC_VECTORED == 1

describe "csr_name":
    it "returns known CSR names":
        expect csr_name(CSR_MSTATUS) == "mstatus"
        expect csr_name(CSR_MEPC) == "mepc"
        expect csr_name(CSR_MCAUSE) == "mcause"
        expect csr_name(CSR_MHARTID) == "mhartid"
        expect csr_name(CSR_SATP) == "satp"

    it "returns fallback for unknown CSR":
        val name = csr_name(0x999)
        expect name.len() > 0
