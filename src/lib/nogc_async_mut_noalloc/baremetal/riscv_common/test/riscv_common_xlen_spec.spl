# ============================================================================
# Spec: RISC-V Common — XLEN Configuration
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.xlen.{XlenConfig, XLEN_32, XLEN_64}

describe "XlenConfig":
    it "creates RV32 config with correct width":
        val cfg = XlenConfig.rv32()
        expect cfg.xlen == 32
        expect cfg.bytes_per_reg == 4
        expect cfg.sign_bit == 31
        expect cfg.is_rv32() == true
        expect cfg.is_rv64() == false

    it "creates RV64 config with correct width":
        val cfg = XlenConfig.rv64()
        expect cfg.xlen == 64
        expect cfg.bytes_per_reg == 8
        expect cfg.sign_bit == 63
        expect cfg.is_rv32() == false
        expect cfg.is_rv64() == true

    it "truncates values to RV32 width":
        val cfg = XlenConfig.rv32()
        expect cfg.truncate(0x1FFFFFFFF) == 0xFFFFFFFF
        expect cfg.truncate(0x12345678) == 0x12345678
        expect cfg.truncate(0) == 0

    it "truncate is identity for RV64":
        val cfg = XlenConfig.rv64()
        val big = 0x123456789ABCDEF0
        expect cfg.truncate(big) == big

    it "sign-extends 32-bit values for RV64":
        val cfg = XlenConfig.rv64()
        # Positive value — no extension
        expect cfg.sign_extend_32(0x7FFFFFFF) == 0x7FFFFFFF
        # Negative value — extend with 1s
        val neg = cfg.sign_extend_32(0x80000000)
        expect neg & 0xFFFFFFFF == 0x80000000

    it "sign-extends immediates correctly":
        val cfg = XlenConfig.rv32()
        # 12-bit immediate -1 (0xFFF)
        val minus_one = cfg.sign_extend_imm(0xFFF, 12)
        expect minus_one & 0xFFFFFFFF == 0xFFFFFFFF
        # 12-bit immediate +1
        expect cfg.sign_extend_imm(1, 12) == 1

    it "has correct cause interrupt bit":
        val rv32 = XlenConfig.rv32()
        expect rv32.cause_interrupt_bit == 0x80000000
        val rv64 = XlenConfig.rv64()
        expect rv64.cause_interrupt_bit == 0x8000000000000000
