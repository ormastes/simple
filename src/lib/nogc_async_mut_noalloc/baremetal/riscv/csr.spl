# RISC-V Control and Status Registers (CSR)
#
# Central CSR registry for M-mode, S-mode, and U-mode registers.
# Provides typed CSR addresses, read/write wrappers via inline asm,
# and bitfield helpers using int.bits[lo..hi] sugar.
#
# This module is the canonical source of CSR addresses — other modules
# (plic, startup, etc.) should import from here rather than re-defining.
#
# Reference: RISC-V Privileged ISA Specification v1.12
#
# ============================================================================
# Machine-mode CSRs (0x300..0x3FF, 0xF00..0xFFF)
# ============================================================================

# Machine Information Registers (read-only)
val CSR_MVENDORID: u64 = 0xF11
val CSR_MARCHID: u64 = 0xF12
val CSR_MIMPID: u64 = 0xF13
val CSR_MHARTID: u64 = 0xF14

# Machine Trap Setup
val CSR_MSTATUS: u64 = 0x300
val CSR_MISA: u64 = 0x301
val CSR_MEDELEG: u64 = 0x302
val CSR_MIDELEG: u64 = 0x303
val CSR_MIE: u64 = 0x304
val CSR_MTVEC: u64 = 0x305
val CSR_MCOUNTEREN: u64 = 0x306

# Machine Trap Handling
val CSR_MSCRATCH: u64 = 0x340
val CSR_MEPC: u64 = 0x341
val CSR_MCAUSE: u64 = 0x342
val CSR_MTVAL: u64 = 0x343
val CSR_MIP: u64 = 0x344

# Machine Memory Protection
val CSR_PMPCFG0: u64 = 0x3A0
val CSR_PMPCFG1: u64 = 0x3A1
val CSR_PMPCFG2: u64 = 0x3A2
val CSR_PMPCFG3: u64 = 0x3A3
val CSR_PMPADDR0: u64 = 0x3B0
val CSR_PMPADDR1: u64 = 0x3B1
val CSR_PMPADDR2: u64 = 0x3B2
val CSR_PMPADDR3: u64 = 0x3B3

# Machine Counter/Timers (read-only)
val CSR_MCYCLE: u64 = 0xB00
val CSR_MINSTRET: u64 = 0xB02

# ============================================================================
# Supervisor-mode CSRs (0x100..0x1FF)
# ============================================================================

# Supervisor Trap Setup
val CSR_SSTATUS: u64 = 0x100
val CSR_SIE: u64 = 0x104
val CSR_STVEC: u64 = 0x105
val CSR_SCOUNTEREN: u64 = 0x106

# Supervisor Trap Handling
val CSR_SSCRATCH: u64 = 0x140
val CSR_SEPC: u64 = 0x141
val CSR_SCAUSE: u64 = 0x142
val CSR_STVAL: u64 = 0x143
val CSR_SIP: u64 = 0x144

# Supervisor Address Translation and Protection
val CSR_SATP: u64 = 0x180

# ============================================================================
# User-mode CSRs (0x000..0x0FF)
# ============================================================================

val CSR_CYCLE: u64 = 0xC00
val CSR_TIME: u64 = 0xC01
val CSR_INSTRET: u64 = 0xC02

# ============================================================================
# MSTATUS Bit Fields (RV64)
# ============================================================================

val MSTATUS_SIE: u64 = 1 << 1      # Supervisor Interrupt Enable
val MSTATUS_MIE: u64 = 1 << 3      # Machine Interrupt Enable
val MSTATUS_SPIE: u64 = 1 << 5     # Supervisor Previous IE
val MSTATUS_MPIE: u64 = 1 << 7     # Machine Previous IE
val MSTATUS_SPP: u64 = 1 << 8      # Supervisor Previous Privilege
val MSTATUS_MPP_MASK: u64 = 3 << 11  # Machine Previous Privilege mask
val MSTATUS_MPP_U: u64 = 0 << 11   # MPP = User mode
val MSTATUS_MPP_S: u64 = 1 << 11   # MPP = Supervisor mode
val MSTATUS_MPP_M: u64 = 3 << 11   # MPP = Machine mode
val MSTATUS_FS_MASK: u64 = 3 << 13 # Floating-point Status mask
val MSTATUS_XS_MASK: u64 = 3 << 15 # Extension Status mask
val MSTATUS_MPRV: u64 = 1 << 17    # Modify PRiVilege
val MSTATUS_SUM: u64 = 1 << 18     # Supervisor User Memory access
val MSTATUS_MXR: u64 = 1 << 19     # Make eXecutable Readable
val MSTATUS_TVM: u64 = 1 << 20     # Trap Virtual Memory
val MSTATUS_TW: u64 = 1 << 21      # Timeout Wait
val MSTATUS_TSR: u64 = 1 << 22     # Trap SRET

# ============================================================================
# MIE / MIP Bit Fields
# ============================================================================

val MIE_SSIE: u64 = 1 << 1   # Supervisor Software Interrupt Enable
val MIE_MSIE: u64 = 1 << 3   # Machine Software Interrupt Enable
val MIE_STIE: u64 = 1 << 5   # Supervisor Timer Interrupt Enable
val MIE_MTIE: u64 = 1 << 7   # Machine Timer Interrupt Enable
val MIE_SEIE: u64 = 1 << 9   # Supervisor External Interrupt Enable
val MIE_MEIE: u64 = 1 << 11  # Machine External Interrupt Enable

# ============================================================================
# MTVEC Mode Fields
# ============================================================================

val MTVEC_MODE_DIRECT: u64 = 0    # All traps to base address
val MTVEC_MODE_VECTORED: u64 = 1  # Interrupts to base + 4*cause

# ============================================================================
# Exception/Interrupt Cause Codes
# ============================================================================

val CAUSE_INTERRUPT_BIT: u64 = 0x8000000000000000

# Interrupt causes (bit 63 set)
val CAUSE_S_SOFTWARE_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 1
val CAUSE_M_SOFTWARE_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 3
val CAUSE_S_TIMER_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 5
val CAUSE_M_TIMER_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 7
val CAUSE_S_EXTERNAL_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 9
val CAUSE_M_EXTERNAL_INTERRUPT: u64 = CAUSE_INTERRUPT_BIT | 11

# Synchronous exception causes (bit 63 clear)
val CAUSE_INSN_MISALIGNED: u64 = 0
val CAUSE_INSN_ACCESS_FAULT: u64 = 1
val CAUSE_ILLEGAL_INSN: u64 = 2
val CAUSE_BREAKPOINT: u64 = 3
val CAUSE_LOAD_MISALIGNED: u64 = 4
val CAUSE_LOAD_ACCESS_FAULT: u64 = 5
val CAUSE_STORE_MISALIGNED: u64 = 6
val CAUSE_STORE_ACCESS_FAULT: u64 = 7
val CAUSE_ECALL_U: u64 = 8
val CAUSE_ECALL_S: u64 = 9
val CAUSE_ECALL_M: u64 = 11
val CAUSE_INSN_PAGE_FAULT: u64 = 12
val CAUSE_LOAD_PAGE_FAULT: u64 = 13
val CAUSE_STORE_PAGE_FAULT: u64 = 15

# ============================================================================
# CSR Read / Write Wrappers
# ============================================================================
#
# On real hardware these use inline asm (csrr/csrw).  In interpreter /
# spec mode the asm blocks are not executed, so the functions return
# sentinel values (0 for reads, no-op for writes).  This keeps the
# module usable in both contexts.

fn csr_read(addr: u64) -> u64:
    """Read a CSR by address.

    In compiled/baremetal mode this emits a csrr instruction.
    In interpreter mode returns 0 (tests should mock as needed).
    """
    # TODO: when targeting baremetal, lower to real csrr via asm switch
    # unsafe:
    #     var value: u64
    #     asm volatile:
    #         "csrr {0}, {1}"
    #         out(reg) value
    #         in(reg) addr
    #     return value
    0

fn csr_write(addr: u64, value: u64):
    """Write a value to a CSR by address.

    In compiled/baremetal mode this emits a csrw instruction.
    In interpreter mode this is a no-op.
    """
    # TODO: when targeting baremetal, lower to real csrw via asm switch
    # unsafe:
    #     asm volatile:
    #         "csrw {0}, {1}"
    #         in(reg) addr
    #         in(reg) value
    pass

fn csr_set_bits(addr: u64, mask: u64):
    """Set bits in a CSR (csrs instruction).

    Sets bits specified by mask without affecting other bits.
    """
    # TODO: lower to csrs in compiled mode
    # unsafe:
    #     asm volatile:
    #         "csrs {0}, {1}"
    #         in(reg) addr
    #         in(reg) mask
    pass

fn csr_clear_bits(addr: u64, mask: u64):
    """Clear bits in a CSR (csrc instruction).

    Clears bits specified by mask without affecting other bits.
    """
    # TODO: lower to csrc in compiled mode
    # unsafe:
    #     asm volatile:
    #         "csrc {0}, {1}"
    #         in(reg) addr
    #         in(reg) mask
    pass

fn csr_read_write(addr: u64, value: u64) -> u64:
    """Atomically swap CSR value, returning old value (csrrw)."""
    # TODO: lower to csrrw in compiled mode
    # unsafe:
    #     var old: u64
    #     asm volatile:
    #         "csrrw {0}, {1}, {2}"
    #         out(reg) old
    #         in(reg) addr
    #         in(reg) value
    #     return old
    0

# ============================================================================
# MSTATUS Bitfield Helpers (using int.bits[lo..hi] sugar)
# ============================================================================

fn mstatus_get_mpp(status: u64) -> u64:
    """Extract Machine Previous Privilege from mstatus (bits 12:11)."""
    status.bits[11..13]

fn mstatus_set_mpp(status: u64, mode: u64) -> u64:
    """Set Machine Previous Privilege in mstatus."""
    var s = status
    s.bits[11..13] = mode & 0x03
    s

fn mstatus_get_spp(status: u64) -> u64:
    """Extract Supervisor Previous Privilege from mstatus (bit 8)."""
    status.bits[8..9]

fn mstatus_set_spp(status: u64, mode: u64) -> u64:
    """Set Supervisor Previous Privilege in mstatus."""
    var s = status
    s.bits[8..9] = mode & 0x01
    s

fn mstatus_get_fs(status: u64) -> u64:
    """Extract floating-point status (bits 14:13)."""
    status.bits[13..15]

fn mstatus_set_fs(status: u64, fs: u64) -> u64:
    """Set floating-point status field."""
    var s = status
    s.bits[13..15] = fs & 0x03
    s

# ============================================================================
# MTVEC Helpers
# ============================================================================

fn mtvec_encode(base: u64, mode: u64) -> u64:
    """Encode a mtvec value from base address and mode.

    base must be 4-byte aligned (bits 1:0 used for mode).
    mode: 0 = Direct, 1 = Vectored
    """
    (base & ~3) | (mode & 0x03)

fn mtvec_base(mtvec: u64) -> u64:
    """Extract base address from mtvec (clear mode bits)."""
    mtvec & ~3

fn mtvec_mode(mtvec: u64) -> u64:
    """Extract mode from mtvec (bits 1:0)."""
    mtvec & 0x03

# ============================================================================
# MCAUSE Helpers
# ============================================================================

fn mcause_is_interrupt(mcause: u64) -> bool:
    """Check if mcause indicates an interrupt (MSB set)."""
    (mcause & CAUSE_INTERRUPT_BIT) != 0

fn mcause_code(mcause: u64) -> u64:
    """Extract exception/interrupt code from mcause (clear MSB)."""
    mcause & 0x7FFFFFFFFFFFFFFF

# ============================================================================
# CSR Address Classification
# ============================================================================

fn csr_is_readonly(addr: u64) -> bool:
    """Check if a CSR address is read-only (bits 11:10 == 0b11)."""
    ((addr >> 10) & 0x03) == 3

fn csr_privilege_level(addr: u64) -> u64:
    """Extract the minimum privilege level from a CSR address (bits 9:8).

    0 = User, 1 = Supervisor, 3 = Machine
    """
    (addr >> 8) & 0x03
