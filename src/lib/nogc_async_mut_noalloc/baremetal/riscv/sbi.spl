# RISC-V SBI (Supervisor Binary Interface) IPI Extensions
#
# SBI ecall convention:
#   a7 = extension ID (EID)
#   a6 = function ID (FID)
#   a0-a5 = arguments
#   Return: a0 = error code, a1 = value
#
# IPI Extension IDs:
#   0x735049 ("IPI"): SBI v0.3+ IPI extension, FID 0 = sbi_send_ipi
#   0x04: Legacy IPI extension (deprecated, single hart_mask_ptr arg)
#   CLINT MSIP fallback: MMIO write to 0x02000000 + 4*hartid

# ============================================================================
# SBI Error Codes
# ============================================================================

val SBI_IPI_SUCCESS: i64 = 0
val SBI_IPI_ERR_FAILED: i64 = -1
val SBI_IPI_ERR_NOT_SUPPORTED: i64 = -2

# ============================================================================
# SBI Extension IDs
# ============================================================================

val SBI_EXT_BASE: u64 = 0x10
val SBI_EXT_IPI: u64 = 0x735049
val SBI_EXT_LEGACY_IPI: u64 = 0x04

# ============================================================================
# CLINT MSIP base address
# ============================================================================

val CLINT_MSIP_BASE: u64 = 0x02000000

# ============================================================================
# IPI path selection (cached at boot via init_ipi_path)
# ============================================================================

enum IpiPath:
    Unavailable
    Sbi_v3
    Sbi_legacy
    ClintMmio

var IPI_PATH: IpiPath = IpiPath.Unavailable

# ============================================================================
# Generic SBI Ecall (self-contained; lib cannot depend on os/kernel/sbi.spl)
# ============================================================================

@repr("C")
struct SbiResult:
    """SBI ecall return value pair."""
    error: i64
    value: i64

fn sbi_ecall(ext: u64, fid: u64, arg0: u64, arg1: u64, arg2: u64,
             arg3: u64, arg4: u64, arg5: u64) -> SbiResult:
    var ret_error: i64 = 0
    var ret_value: i64 = 0

    unsafe:
        asm volatile:
            "mv a0, {arg0}"
            "mv a1, {arg1}"
            "mv a2, {arg2}"
            "mv a3, {arg3}"
            "mv a4, {arg4}"
            "mv a5, {arg5}"
            "mv a6, {fid}"
            "mv a7, {ext}"
            "ecall"
            "mv {out_err}, a0"
            "mv {out_val}, a1"
            in(reg) arg0
            in(reg) arg1
            in(reg) arg2
            in(reg) arg3
            in(reg) arg4
            in(reg) arg5
            in(reg) fid
            in(reg) ext
            out(reg) ret_error
            out(reg) ret_value
            clobber("a0", "a1", "a2", "a3", "a4", "a5", "a6", "a7")

    SbiResult(error: ret_error, value: ret_value)

fn sbi_probe_extension(ext_id: u64) -> bool:
    val ret = sbi_ecall(SBI_EXT_BASE, 3, ext_id, 0, 0, 0, 0, 0)
    ret.value != 0

# ============================================================================
# IPI path initialisation (call once at boot)
# ============================================================================

fn init_ipi_path():
    """Probe SBI IPI extension availability once and cache the result."""
    if sbi_probe_extension(SBI_EXT_IPI):
        IPI_PATH = IpiPath.Sbi_v3
    else if sbi_probe_extension(SBI_EXT_LEGACY_IPI):
        IPI_PATH = IpiPath.Sbi_legacy
    else:
        IPI_PATH = IpiPath.ClintMmio

# ============================================================================
# SBI IPI v0.3+ (EID 0x735049, FID 0)
# ============================================================================

fn sbi_send_ipi_v3(hart_mask: u64, hart_mask_base: u64) -> SbiResult:
    """Send IPI to harts specified in hart_mask (SBI IPI ext v0.3+)."""
    sbi_ecall(SBI_EXT_IPI, 0, hart_mask, hart_mask_base, 0, 0, 0, 0)

# ============================================================================
# Legacy SBI IPI (EID 0x04)
# ============================================================================

fn sbi_send_ipi_legacy(hart_mask_ptr: u64) -> SbiResult:
    """Send IPI using deprecated legacy SBI extension (EID 0x04)."""
    sbi_ecall(SBI_EXT_LEGACY_IPI, 0, hart_mask_ptr, 0, 0, 0, 0, 0)

# ============================================================================
# CLINT MSIP MMIO fallback
# ============================================================================

fn clint_send_ipi_to_hart(hartid: u32):
    """Write MSIP bit for hartid via CLINT MMIO (0x02000000 + 4*hartid)."""
    val addr = CLINT_MSIP_BASE + 4u64 * hartid as u64
    val value: u32 = 1u32
    var scratch: u32 = 0u32
    unsafe:
        asm volatile:
            "sw {value}, 0({addr})"
            in(reg) addr
            in(reg) value
            out(reg) scratch

# ============================================================================
# Unified IPI send — chooses path by cached IPI_PATH
# ============================================================================

fn sbi_probe_then_send_ipi(hart_mask: u64, hart_mask_base: u64):
    """Send IPI using the best available path (probes once, then dispatches)."""
    if IPI_PATH == IpiPath.Unavailable:
        init_ipi_path()
    if IPI_PATH == IpiPath.Sbi_v3:
        sbi_send_ipi_v3(hart_mask, hart_mask_base)
    else if IPI_PATH == IpiPath.Sbi_legacy:
        # Legacy takes a pointer to the hart_mask; pass mask on stack via register
        sbi_send_ipi_legacy(hart_mask)
    else:
        # ClintMmio: iterate set bits in hart_mask
        var bit: u32 = 0
        var mask = hart_mask
        while bit < 64u32:
            if mask & 1u64 != 0u64:
                clint_send_ipi_to_hart(bit)
            mask = mask >> 1u64
            bit = bit + 1u32
