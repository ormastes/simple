# Bare-Metal Semihost Policy
#
# Pure Simple semihost operation choices shared by examples before importing
# architecture trap capsules or the full semihost transport implementation.

val BAREMETAL_SEMIHOST_OP_WRITEC: i32 = 3
val BAREMETAL_SEMIHOST_OP_WRITE0: i32 = 4
val BAREMETAL_SEMIHOST_OP_WRITE: i32 = 5
val BAREMETAL_SEMIHOST_OP_EXIT: i32 = 0x18

fn baremetal_semihost_stdout_op(has_write: bool, has_write0: bool) -> i32:
    if has_write:
        return BAREMETAL_SEMIHOST_OP_WRITE
    if has_write0:
        return BAREMETAL_SEMIHOST_OP_WRITE0
    BAREMETAL_SEMIHOST_OP_WRITEC

fn baremetal_semihost_exit_op() -> i32:
    BAREMETAL_SEMIHOST_OP_EXIT

export BAREMETAL_SEMIHOST_OP_EXIT, BAREMETAL_SEMIHOST_OP_WRITE, BAREMETAL_SEMIHOST_OP_WRITE0, BAREMETAL_SEMIHOST_OP_WRITEC
