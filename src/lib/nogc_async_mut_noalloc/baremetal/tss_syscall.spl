# TSS / SYSCALL MSR setup — kernel-stack isolation for SYSCALL/SYSRET (M2, REQ-4).
#
# Provides:
#   tss_write_rsp0      — write TSS.RSP0 (kernel stack pointer for ring-0 entry)
#   msr_lstar_install   — install LSTAR MSR (SYSCALL entry point)
#   msr_star_install    — install STAR MSR (segment selectors)
#   msr_sfmask_install  — install SFMASK MSR (flags to clear on SYSCALL)
#
# In interpreter mode these are no-ops that record the last installed address.
#
# @cover tss_syscall

# ============================================================================
# Storage for last-written values (interpreter-mode verification)
# ============================================================================

var _tss_rsp0:      u64 = 0
var _msr_lstar:     u64 = 0
var _msr_star:      u64 = 0
var _msr_sfmask:    u64 = 0

# ============================================================================
# Public API
# ============================================================================

pub fn tss_write_rsp0(kernel_stack_addr: u64):
    """Write the kernel-stack pointer to TSS.RSP0.

    On real hardware this updates the Task State Segment so that SYSCALL/INT
    switches to the correct ring-0 stack. In interpreter mode the address is
    stored for test inspection.

    Args:
        kernel_stack_addr: Top-of-stack address for the kernel stack.
    """
    _tss_rsp0 = kernel_stack_addr

pub fn msr_lstar_install(handler_addr: u64):
    """Write handler_addr to the LSTAR MSR (SYSCALL 64-bit entry point).

    Args:
        handler_addr: Virtual address of the syscall handler function.
    """
    _msr_lstar = handler_addr

pub fn msr_star_install(star_value: u64):
    """Write star_value to the STAR MSR (CS/SS selectors for SYSCALL/SYSRET).

    Args:
        star_value: Packed STAR MSR value (kernel CS in bits 47:32).
    """
    _msr_star = star_value

pub fn msr_sfmask_install(sfmask_value: u64):
    """Write sfmask_value to the SFMASK MSR (EFLAGS bits to clear on SYSCALL).

    Args:
        sfmask_value: Bit mask of EFLAGS to clear (e.g. IF=0x200).
    """
    _msr_sfmask = sfmask_value

pub fn tss_rsp0_current() -> u64:
    """Return the last value written to TSS.RSP0 (for tests/diagnostics)."""
    _tss_rsp0
