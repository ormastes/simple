# Bare-Metal Startup Plan
#
# Pure Simple composition layer for startup defaults plus interrupt-controller
# selection. Keep scalar startup_policy.spl importable without interrupt policy
# retention for the smallest native probe lane.

use std.nogc_async_mut_noalloc.baremetal.interrupt_policy.{
    BaremetalInterruptConfig,
    baremetal_interrupt_choose
}
use std.nogc_async_mut_noalloc.baremetal.startup_policy.{
    baremetal_startup_hart_count,
    baremetal_startup_is_primary_hart,
    baremetal_startup_stack_top
}

class BaremetalStartupPlan:
    stack_top: u32
    hart_count: i32
    primary_hart: bool
    interrupt: BaremetalInterruptConfig

fn baremetal_startup_plan(arch_name: text, ram_base: u32, ram_size: u32, harts: i32, hart_id: i32, interrupt_base: u32) -> BaremetalStartupPlan:
    BaremetalStartupPlan(
        stack_top: baremetal_startup_stack_top(ram_base, ram_size),
        hart_count: baremetal_startup_hart_count(harts),
        primary_hart: baremetal_startup_is_primary_hart(hart_id),
        interrupt: baremetal_interrupt_choose(arch_name, interrupt_base)
    )
