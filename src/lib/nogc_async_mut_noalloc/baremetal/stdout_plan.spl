# Bare-Metal Stdout Plan
#
# Pure Simple stdout routing plan shared by examples before importing
# semihost trap, UART, syscall, or semihost transport implementations.

use std.nogc_async_mut_noalloc.baremetal.console_policy.{
    BAREMETAL_CONSOLE_NONE,
    BAREMETAL_CONSOLE_SEMIHOST,
    BAREMETAL_CONSOLE_UART,
    BAREMETAL_UART_QEMU_VIRT,
    BaremetalConsoleConfig,
    baremetal_console_choose
}
use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_WRITEC,
    baremetal_semihost_stdout_op
}

class BaremetalStdoutPlan:
    console: BaremetalConsoleConfig
    semihost_op: i32

impl BaremetalStdoutPlan:
    static fn none() -> BaremetalStdoutPlan:
        BaremetalStdoutPlan(
            console: BaremetalConsoleConfig.none(),
            semihost_op: BAREMETAL_SEMIHOST_OP_WRITEC
        )

fn baremetal_stdout_plan(
    prefer_semihost: bool,
    semihost_available: bool,
    has_write: bool,
    has_write0: bool,
    uart_base: u32
) -> BaremetalStdoutPlan:
    val console = baremetal_console_choose(prefer_semihost, semihost_available, uart_base)
    val op = baremetal_semihost_stdout_op(has_write, has_write0)
    BaremetalStdoutPlan(console: console, semihost_op: op)

fn baremetal_stdout_plan_qemu(
    prefer_semihost: bool,
    semihost_available: bool,
    has_write: bool,
    has_write0: bool
) -> BaremetalStdoutPlan:
    baremetal_stdout_plan(
        prefer_semihost,
        semihost_available,
        has_write,
        has_write0,
        BAREMETAL_UART_QEMU_VIRT
    )

fn baremetal_stdout_plan_is_enabled(plan: BaremetalStdoutPlan) -> bool:
    plan.console.mode != BAREMETAL_CONSOLE_NONE

fn baremetal_stdout_plan_uses_semihost(plan: BaremetalStdoutPlan) -> bool:
    plan.console.mode == BAREMETAL_CONSOLE_SEMIHOST

fn baremetal_stdout_plan_uses_uart(plan: BaremetalStdoutPlan) -> bool:
    plan.console.mode == BAREMETAL_CONSOLE_UART

fn baremetal_stdout_plan_semihost_op(plan: BaremetalStdoutPlan) -> i32:
    plan.semihost_op
