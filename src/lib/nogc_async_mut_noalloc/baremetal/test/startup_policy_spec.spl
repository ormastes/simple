use std.nogc_async_mut_noalloc.baremetal.startup_policy.{
    baremetal_startup_hart_count,
    baremetal_startup_is_primary_hart,
    baremetal_startup_stack_top
}

use std.spec.{describe, it, expect}

describe "baremetal startup policy":
    it "derives stack tops and clamps RISC-V hart count":
        expect(baremetal_startup_stack_top(0x80000000u32, 0x10000u32)).to_equal(0x80010000u32)
        expect(baremetal_startup_hart_count(0)).to_equal(1)
        expect(baremetal_startup_hart_count(4)).to_equal(4)

    it "keeps startup defaults scalar for the small policy lane":
        expect(baremetal_startup_stack_top(0x20000000u32, 0x20000u32)).to_equal(0x20020000u32)
        expect(baremetal_startup_hart_count(-1)).to_equal(1)

    it "selects only hart zero for single-init startup work":
        expect(baremetal_startup_is_primary_hart(0)).to_equal(true)
        expect(baremetal_startup_is_primary_hart(1)).to_equal(false)
