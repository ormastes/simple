# ============================================================================
# Spec: RISC-V CLINT Module — Timer, Software Interrupt, Register Layout
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv.clint.{
    CLINT_BASE, CLINT_MSIP_OFFSET, CLINT_MTIMECMP_OFFSET, CLINT_MTIME_OFFSET,
    CLINT_TIMER_FREQ,
    ClintRegisters,
    clint_regs_default, clint_regs_with_base,
    clint_msip_addr, clint_mtimecmp_addr, clint_mtime_addr,
    clint_get_mtime, clint_get_mtimecmp, clint_get_ipi_pending
}

describe "CLINT Constants":
    it "has correct base address":
        expect CLINT_BASE == 0x02000000

    it "has correct register offsets":
        expect CLINT_MSIP_OFFSET == 0x0000
        expect CLINT_MTIMECMP_OFFSET == 0x4000
        expect CLINT_MTIME_OFFSET == 0xBFF8

    it "has correct timer frequency":
        expect CLINT_TIMER_FREQ == 10000000

describe "ClintRegisters Address Calculations":
    it "computes MSIP address for hart 0":
        val regs = clint_regs_default()
        expect clint_msip_addr(regs, 0) == 0x02000000

    it "computes MSIP address for hart 1":
        val regs = clint_regs_default()
        expect clint_msip_addr(regs, 1) == 0x02000004

    it "computes MSIP address for hart 3":
        val regs = clint_regs_default()
        expect clint_msip_addr(regs, 3) == 0x0200000C

    it "computes MTIMECMP address for hart 0":
        val regs = clint_regs_default()
        expect clint_mtimecmp_addr(regs, 0) == 0x02004000

    it "computes MTIMECMP address for hart 1":
        val regs = clint_regs_default()
        expect clint_mtimecmp_addr(regs, 1) == 0x02004008

    it "computes MTIME address":
        val regs = clint_regs_default()
        expect clint_mtime_addr(regs) == 0x0200BFF8

    it "supports custom base address":
        val regs = clint_regs_with_base(0x10000000)
        expect clint_msip_addr(regs, 0) == 0x10000000
        expect clint_mtimecmp_addr(regs, 0) == 0x10004000
        expect clint_mtime_addr(regs) == 0x1000BFF8

describe "CLINT Stubs":
    it "mtime returns zero in interpreter mode":
        expect clint_get_mtime() == 0

    it "mtimecmp returns zero in interpreter mode":
        expect clint_get_mtimecmp(0) == 0

    it "ipi pending returns false in interpreter mode":
        expect clint_get_ipi_pending(0) == false
