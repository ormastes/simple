use std.nogc_async_mut_noalloc.baremetal.console_policy.{
    BAREMETAL_CONSOLE_NONE,
    BAREMETAL_CONSOLE_SEMIHOST,
    BAREMETAL_CONSOLE_UART,
    BAREMETAL_UART_QEMU_VIRT
}
use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_WRITE,
    BAREMETAL_SEMIHOST_OP_WRITE0,
    BAREMETAL_SEMIHOST_OP_WRITEC
}
use std.nogc_async_mut_noalloc.baremetal.stdout_plan.{
    BaremetalStdoutPlan,
    baremetal_stdout_plan,
    baremetal_stdout_plan_qemu,
    baremetal_stdout_plan_is_enabled,
    baremetal_stdout_plan_semihost_op,
    baremetal_stdout_plan_uses_semihost,
    baremetal_stdout_plan_uses_uart
}
use std.nogc_async_mut_noalloc.baremetal.stdout_policy_plan.{
    baremetal_stdout_policy_plan_qemu,
    baremetal_stdout_policy_plan_uses_semihost,
    baremetal_stdout_policy_plan_uses_uart
}

use std.spec.{describe, it, expect}

describe "baremetal stdout plan":
    it "selects semihost and the widest operation when available":
        val plan = baremetal_stdout_plan_qemu(true, true, true, true)
        expect(plan.console.mode).to_equal(BAREMETAL_CONSOLE_SEMIHOST)
        expect(baremetal_stdout_plan_semihost_op(plan)).to_equal(BAREMETAL_SEMIHOST_OP_WRITE)
        expect(baremetal_stdout_plan_is_enabled(plan)).to_equal(true)
        expect(baremetal_stdout_plan_uses_semihost(plan)).to_equal(true)
        expect(baremetal_stdout_plan_uses_uart(plan)).to_equal(false)

    it "falls back to UART without importing runtime transports":
        val plan = baremetal_stdout_plan(
            true,
            false,
            false,
            true,
            BAREMETAL_UART_QEMU_VIRT
        )
        expect(plan.console.mode).to_equal(BAREMETAL_CONSOLE_UART)
        expect(plan.console.uart_base).to_equal(BAREMETAL_UART_QEMU_VIRT)
        expect(baremetal_stdout_plan_semihost_op(plan)).to_equal(BAREMETAL_SEMIHOST_OP_WRITE0)
        expect(baremetal_stdout_plan_uses_semihost(plan)).to_equal(false)
        expect(baremetal_stdout_plan_uses_uart(plan)).to_equal(true)

    it "keeps the disabled plan explicit":
        val plan = BaremetalStdoutPlan.none()
        expect(plan.console.mode).to_equal(BAREMETAL_CONSOLE_NONE)
        expect(baremetal_stdout_plan_semihost_op(plan)).to_equal(BAREMETAL_SEMIHOST_OP_WRITEC)
        expect(baremetal_stdout_plan_is_enabled(plan)).to_equal(false)
        expect(baremetal_stdout_plan_uses_semihost(plan)).to_equal(false)
        expect(baremetal_stdout_plan_uses_uart(plan)).to_equal(false)

    it "offers a richer policy plan without changing the tiny opcode plan":
        val rich = baremetal_stdout_policy_plan_qemu(true, true, true, true)
        expect(rich.semihost.op).to_equal(BAREMETAL_SEMIHOST_OP_WRITE)
        expect(rich.semihost.null_safe).to_equal(true)
        expect(rich.semihost.needs_fd).to_equal(true)
        expect(baremetal_stdout_policy_plan_uses_semihost(rich)).to_equal(true)
        expect(baremetal_stdout_policy_plan_uses_uart(rich)).to_equal(false)
