use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_EXIT,
    BAREMETAL_SEMIHOST_OP_WRITE,
    BAREMETAL_SEMIHOST_OP_WRITE0,
    BAREMETAL_SEMIHOST_OP_WRITEC,
    baremetal_semihost_exit_op,
    baremetal_semihost_stdout_op
}

use std.spec.{describe, it, expect}

describe "baremetal semihost policy":
    it "selects the widest available stdout operation":
        expect(baremetal_semihost_stdout_op(true, true)).to_equal(BAREMETAL_SEMIHOST_OP_WRITE)
        expect(baremetal_semihost_stdout_op(false, true)).to_equal(BAREMETAL_SEMIHOST_OP_WRITE0)
        expect(baremetal_semihost_stdout_op(false, false)).to_equal(BAREMETAL_SEMIHOST_OP_WRITEC)

    it "exposes the shared semihost exit operation":
        expect(baremetal_semihost_exit_op()).to_equal(BAREMETAL_SEMIHOST_OP_EXIT)
