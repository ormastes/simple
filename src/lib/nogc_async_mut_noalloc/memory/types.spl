# Memory module newtype wrappers — no-alloc baremetal

pub struct BinaryId:
    value: i64

pub struct Offset:
    value: i64

pub struct Length:
    value: i64

pub struct RefCount:
    value: i64

pub struct ByteSize:
    value: i64

pub struct Capacity:
    value: i64

pub struct Count:
    value: i64
