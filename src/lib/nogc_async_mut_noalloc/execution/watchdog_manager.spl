# WatchdogManager — facade over the native wall-clock watchdog timer.
#
# Owns the `rt_watchdog_start`/`rt_watchdog_stop` externs so app-layer code
# (e.g. `src/app/interpreter/core/watchdog.spl`) never declares or calls them
# directly. Backend-isolation Gap D
# (doc/03_plan/ui/rendering/backend_isolation_plan.md § P3 Gap D — "WatchdogManager
# facade does not exist").
#
# `start(timeout_secs)` arms a background-thread deadline; if execution runs
# past it, the native side sets a shared timeout flag that pollers read via
# `std.common.fault_detection.is_timeout_exceeded`. `stop()` disarms it. Any
# existing timer is implicitly replaced by a fresh `start()` call (the native
# side owns that semantics — this facade adds no extra bookkeeping).

extern fn rt_watchdog_start(timeout_secs: i64)
extern fn rt_watchdog_stop()

pub class WatchdogManager:
    pass_dn

impl WatchdogManager:
    pub static fn start(timeout_secs: i64):
        """Arm the native watchdog timer for `timeout_secs` seconds."""
        rt_watchdog_start(timeout_secs)

    pub static fn stop():
        """Disarm the native watchdog timer if one is running."""
        rt_watchdog_stop()
