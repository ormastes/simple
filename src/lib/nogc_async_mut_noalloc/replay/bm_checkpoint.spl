module std.noalloc.replay.bm_checkpoint

struct BmCheckpoint {
    id: i32,
    cycle: i64,
    pc: i64,
    sp: i64,
    ring_head: i64,
    ring_count: i64,
}

var checkpoints: [BmCheckpoint] = []

fn bm_save_checkpoint(id: i32, cycle: i64, pc: i64, sp: i64) {
    use std.noalloc.replay.bm_replay_core.ring_head
    use std.noalloc.replay.bm_replay_core.ring_count
    let cp = BmCheckpoint {
        id: id,
        cycle: cycle,
        pc: pc,
        sp: sp,
        ring_head: ring_head as i64,
        ring_count: ring_count as i64,
    }
    // update existing or append
    let mut i = 0
    while i < checkpoints.len() {
        if checkpoints[i].id == id {
            checkpoints[i] = cp
            return
        }
        i = i + 1
    }
    checkpoints.push(cp)
}

fn bm_restore_checkpoint(id: i32) -> Result<BmCheckpoint, text> {
    let mut i = 0
    while i < checkpoints.len() {
        if checkpoints[i].id == id {
            return Ok(checkpoints[i])
        }
        i = i + 1
    }
    Err("checkpoint not found: " + id.to_text())
}

fn bm_find_checkpoint_before(cycle: i64) -> Option<BmCheckpoint> {
    let mut best: Option<BmCheckpoint> = None
    let mut i = 0
    while i < checkpoints.len() {
        let cp = checkpoints[i]
        if cp.cycle <= cycle {
            match best {
                None => { best = Some(cp) },
                Some(b) => {
                    if cp.cycle > b.cycle {
                        best = Some(cp)
                    }
                },
            }
        }
        i = i + 1
    }
    best
}
