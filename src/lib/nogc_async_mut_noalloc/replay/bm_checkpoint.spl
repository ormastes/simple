
struct BmCheckpoint:
    id: i32
    cycle: i64
    pc: i64
    sp: i64
    ring_head: i64
    ring_count: i64

var checkpoints: [BmCheckpoint] = []

fn bm_save_checkpoint(id: i32, cycle: i64, pc: i64, sp: i64):
    use std.noalloc.replay.bm_replay_core.ring_head
    use std.noalloc.replay.bm_replay_core.ring_count
    val cp = BmCheckpoint(
        id: id,
        cycle: cycle,
        pc: pc,
        sp: sp,
        ring_head: ring_head as i64,
        ring_count: ring_count as i64
    )
    var i = 0
    while i < checkpoints.len():
        if checkpoints[i].id == id:
            checkpoints[i] = cp
            return
        i = i + 1
    checkpoints.push(cp)

fn bm_restore_checkpoint(id: i32) -> Result<BmCheckpoint, text>:
    var i = 0
    while i < checkpoints.len():
        if checkpoints[i].id == id:
            return Ok(checkpoints[i])
        i = i + 1
    Err("checkpoint not found")

fn bm_find_checkpoint_before(cycle: i64) -> Option<BmCheckpoint>:
    var best: Option<BmCheckpoint> = None
    var i = 0
    while i < checkpoints.len():
        val cp = checkpoints[i]
        if cp.cycle <= cycle:
            var dominated = false
            if val Some(b) = best:
                if cp.cycle <= b.cycle:
                    dominated = true
            if dominated == false:
                best = Some(cp)
        i = i + 1
    best
