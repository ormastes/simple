module std.noalloc.replay.bm_replay_core

// mode: 0=off, 1=record, 2=replay
var g_bm_mode: i32 = 0

fn bm_replay_is_off() -> bool {
    g_bm_mode == 0
}

fn bm_replay_set_mode(mode: i32) {
    g_bm_mode = mode
}

// Ring buffer capacity
let RING_CAP: i32 = 4096

var ring_kinds: [i64] = []
var ring_timestamps: [i64] = []
var ring_values_a: [i64] = []
var ring_values_b: [i64] = []
var ring_head: i32 = 0
var ring_count: i32 = 0

fn bm_ring_init() {
    ring_kinds = []
    ring_timestamps = []
    ring_values_a = []
    ring_values_b = []
    ring_head = 0
    ring_count = 0
    let mut i = 0
    while i < RING_CAP {
        ring_kinds.push(0)
        ring_timestamps.push(0)
        ring_values_a.push(0)
        ring_values_b.push(0)
        i = i + 1
    }
}

fn bm_ring_push(kind: i64, timestamp: i64, val_a: i64, val_b: i64) {
    if ring_kinds.len() == 0 {
        bm_ring_init()
    }
    let tail = (ring_head + ring_count) % RING_CAP
    ring_kinds[tail] = kind
    ring_timestamps[tail] = timestamp
    ring_values_a[tail] = val_a
    ring_values_b[tail] = val_b
    if ring_count < RING_CAP {
        ring_count = ring_count + 1
    } else {
        // overwrite oldest
        ring_head = (ring_head + 1) % RING_CAP
    }
}

fn bm_ring_pop_kind() -> i64 {
    if ring_count == 0 {
        return 0
    }
    let v = ring_kinds[ring_head]
    ring_head = (ring_head + 1) % RING_CAP
    ring_count = ring_count - 1
    v
}

fn bm_ring_pop_timestamp() -> i64 {
    if ring_count == 0 {
        return 0
    }
    let v = ring_timestamps[ring_head]
    v
}

fn bm_ring_pop_val_a() -> i64 {
    if ring_count == 0 {
        return 0
    }
    let v = ring_values_a[ring_head]
    v
}

fn bm_ring_pop_val_b() -> i64 {
    if ring_count == 0 {
        return 0
    }
    let v = ring_values_b[ring_head]
    v
}

fn bm_ring_count() -> i64 {
    ring_count as i64
}
