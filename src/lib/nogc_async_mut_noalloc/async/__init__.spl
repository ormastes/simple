# Async Module - Noalloc Cooperative Coroutines
#
# Stack-only cooperative scheduling for bare-metal systems.
# No heap allocation — fixed task slots with bitmask tracking.
# Adapted from nogc_async_mut/async_embedded.spl.
#
# Public API:
#   - use std.async.{PollResult, POLL_PENDING, POLL_READY}
#   - use std.async.{NoallocScheduler, TaskSlot, MAX_TASKS}
#   - use std.async.{timer_now, timer_elapsed, TimerFuture, timer_after}

# All submodules are automatically available.

# Re-exported from poll.spl
export POLL_PENDING, POLL_READY, PollResult

# Re-exported from scheduler.spl
export MAX_TASKS, TaskSlot, NoallocScheduler

# Re-exported from timer.spl
export timer_now, timer_elapsed, timer_delay_ticks
export TimerFuture, timer_after
