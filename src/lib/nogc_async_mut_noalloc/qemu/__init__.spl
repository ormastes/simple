# QEMU Module
#
# QEMU integration for testing and emulation.
# Supports running Simple programs in QEMU for cross-platform testing.
#
# Public API:
#   - use std.qemu.{QemuInstance, QemuConfig}
#   - use std.qemu.{start_qemu, run_in_qemu}

# All submodules are automatically available.

# Re-exported from boot_runner.spl
export BootTestConfig, BootTestResult, BootTestRunner
export run_boot_test, is_qemu_available, is_gdb_available

# Re-exported from debug_boot_runner.spl
export DebugBootConfig, DebugBootRunner, DebugInfo, StackFrame, StopInfo
export run_debug_boot_test, format_debug_info, analyze_crash, parse_hex_value_u64
