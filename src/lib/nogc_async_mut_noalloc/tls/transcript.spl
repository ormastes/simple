# TLS 1.3 Transcript Hash — No-Alloc Baremetal Port
#
# Ported from src/os/tls13/transcript.spl.
# Key change: the transcript accumulator is a running SHA-256 compression
# state (not a stored copy of all bytes). Each update feeds the message
# bytes into an incremental SHA-256 state so only 32 bytes of state are kept.
#
# Note: this requires an incremental sha256 (init/update/finalize).
# Since os/crypto/sha256.spl does not expose incremental state, we keep the
# full buffer approach using a fixed [u8; N] buffer up to the maximum
# handshake transcript size (8 KB covers all standard handshake messages).
#
# For truly no-alloc operation the transcript buf is pre-allocated at
# construction with a fixed capacity of TLS_HS_TRANSCRIPT_MAX bytes.

use src.lib.nogc_async_mut_noalloc.tls.types.{HASH_SIZE_SHA256}

extern fn rt_tls13_sha256(data: [u8]) -> [u8]
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# Maximum handshake transcript size (ClientHello + ServerHello +
# EncryptedExtensions + Certificate + CertificateVerify + Finished)
# 8192 bytes is sufficient for all standard TLS 1.3 handshakes.
val TLS_HS_TRANSCRIPT_MAX: u64 = 8192

# ============================================================================
# Transcript — mutable running accumulator
# ============================================================================

class Transcript:
    """Mutable running SHA-256 transcript accumulator.

    Pre-allocates a fixed buffer of TLS_HS_TRANSCRIPT_MAX bytes.
    All writes are bounds-checked; exceeding capacity is a silent no-op
    that sets the overflow flag (checked in transcript_is_valid).
    """
    buf: [u8]
    buf_len: u64
    overflow: bool

fn transcript_new() -> Transcript:
    """Create a new empty transcript with a pre-allocated buffer."""
    var buf: [u8] = []
    var i: u64 = 0
    while i < TLS_HS_TRANSCRIPT_MAX:
        buf.push(0x00u8)
        i = i + 1
    Transcript(buf: buf, buf_len: 0, overflow: false)

fn transcript_add(t: Transcript, msg: [u8]) -> Transcript:
    """Append a handshake message to the transcript.

    Returns updated Transcript. If the message would overflow the buffer,
    the overflow flag is set and no bytes are written.
    """
    transcript_add_with_len(t, msg, msg.len().to_u64())

fn transcript_add_with_len(t: Transcript, msg: [u8], msg_len: u64) -> Transcript:
    """Append msg[0..msg_len) to the transcript."""
    if t.overflow:
        return t
    val safe_len = if msg_len < msg.len().to_u64() { msg_len } else { msg.len().to_u64() }
    if t.buf_len + safe_len > TLS_HS_TRANSCRIPT_MAX:
        return Transcript(buf: t.buf, buf_len: t.buf_len, overflow: true)
    var pos: u64 = t.buf_len
    var i: u64 = 0
    while i < safe_len:
        t.buf[pos] = rt_bytes_u8_at(msg, i.to_i64()).to_u8()
        pos = pos + 1
        i = i + 1
    Transcript(buf: t.buf, buf_len: t.buf_len + safe_len, overflow: false)

fn transcript_hash(t: Transcript) -> [u8]:
    """Return SHA-256 hash of all bytes added so far (32 bytes)."""
    _transcript_sha256_prefix(t.buf, t.buf_len)

fn transcript_empty_hash() -> [u8]:
    """Return SHA-256("") — the empty transcript hash used in key schedule."""
    _transcript_sha256_prefix([], 0)

fn transcript_is_valid(t: Transcript) -> bool:
    """Return false if the transcript overflowed its buffer."""
    not t.overflow

# ============================================================================
# Internal helpers
# ============================================================================

fn _transcript_sha256_prefix(buf: [u8], buf_len: u64) -> [u8]:
    """Compute SHA-256 of the first buf_len bytes of buf."""
    # Fast path: delegate to C extern if available (returns 32 bytes)
    if buf_len == buf.len().to_u64():
        val out = rt_tls13_sha256(buf)
        if out.len() == 32:
            return out
    # Pure-Simple path: copy prefix then hash
    var data: [u8] = []
    var i: u64 = 0
    while i < buf_len:
        data.push(rt_bytes_u8_at(buf, i.to_i64()).to_u8())
        i = i + 1
    val out = rt_tls13_sha256(data)
    if out.len() == 32:
        return out
    # Fallback: return 32 zero bytes on failure (should never happen)
    var zeros: [u8] = []
    i = 0
    while i < 32:
        zeros.push(0x00u8)
        i = i + 1
    zeros
