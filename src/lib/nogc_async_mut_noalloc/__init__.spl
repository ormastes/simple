#![allow(unknown_attribute)]
# nogc_async_mut_noalloc — Baremetal Runtime (No Heap, No GC)
#
# Stack-only, allocation-free runtime for bare-metal embedded targets.
# All data structures use fixed-size, stack-allocated storage.
# No heap allocation, no garbage collector, no OS dependencies.
#
# Architecture modules:
#   baremetal/arm/     — ARM Cortex-M (armv7m-none-eabi)
#   baremetal/arm64/   — AArch64 bare-metal
#   baremetal/riscv/   — RISC-V 64-bit (riscv64gc-unknown-none-elf)
#   baremetal/riscv32/ — RISC-V 32-bit
#   baremetal/x86/     — x86 bare-metal
#   baremetal/x86_64/  — x86_64 bare-metal (x86_64-unknown-none)
#
# Core modules:
#   async/       — Cooperative coroutines (no heap, fixed task slots)
#   collections/ — Fixed-size arrays, maps, sets, stacks, ring buffers
#   execution/   — Runtime execution context
#   hash/        — FNV-1a and CRC32 (stack-based)
#   io/          — Semihost and UART I/O
#   log/         — Structured logging (multi-target, interned strings)
#   math/        — Integer math (no float, no alloc)
#   memory/      — Reference-counted binary, shared heap
#   path/        — Minimal semihost path handling
#   qemu/        — QEMU boot test runner and debug runner
#   sort/        — In-place insertion sort, heapsort, binary search
#   string/      — Allocation-free string inspection and conversion
#
# Design constraints:
#   - @no_gc: GC is forbidden in this family
#   - alloc_allowed: false (enforced by BaremetalConfig)
#   - No heap allocation — all storage is stack or static
#   - No OS — cooperative scheduling only
#   - SFFI limited to MMIO, interrupts, semihosting syscalls

@no_gc

fn nogc_async_mut_noalloc_version() -> text:
    "0.1.0"

export nogc_async_mut_noalloc_version

# ============================================================================
# Sub-module declarations
# ============================================================================

pub mod async        # Cooperative coroutines, task slots, timers
pub mod baremetal    # Architecture-specific HAL (ARM, RISC-V, x86, etc.)
pub mod collections  # Fixed-size data structures (arrays, maps, stacks, rings)
pub mod execution    # Runtime execution context
pub mod hash         # FNV-1a, CRC32 hashing
pub mod io           # Semihost/UART readers and writers
pub mod log          # Structured logging (device, semihost, host file)
pub mod math         # Integer math utilities
pub mod memory       # Reference-counted binary, shared heap
pub mod path         # Baremetal path handling (semihost)
pub mod qemu         # QEMU boot test and debug runners
pub mod sort         # In-place sorting and binary search
pub mod string       # Allocation-free string utilities

