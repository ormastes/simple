# Log Module - Structured Logging for Bare-Metal Systems
#
# Multi-target logging with configurable levels.
# Supports device serial, semihost terminal, and host file output.
# Compressed format via string interning for minimal bandwidth.
#
# Public API:
#   - use std.log.{log_init, log_info, log_warn, log_error, log_debug, ...}
#   - use std.log.{LOG_TRACE, LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_ERROR, LOG_FATAL}
#   - use std.log.{TARGET_DEVICE, TARGET_SEMIHOST, TARGET_HOST_FILE}

# All submodules are automatically available.

# Re-exported from format.spl
export log_format, log_format_h, log_format_init
export log_buffer_push, log_buffer_flush, log_buffer_count
export H_TRACE, H_DEBUG, H_INFO, H_WARN, H_ERROR, H_FATAL

# Re-exported from logger.spl
export LOG_TRACE, LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_ERROR, LOG_FATAL, LOG_OFF
export log_init, log_set_level, log_set_targets
export log_trace, log_debug, log_info, log_warn, log_error, log_fatal
export log_trace_h, log_debug_h, log_info_h, log_warn_h, log_error_h, log_fatal_h
export log_info_h1, log_warn_h1, log_error_h1
export log_info_h2, log_warn_h2, log_error_h2
export log_level_name

# Re-exported from targets.spl
export TARGET_DEVICE, TARGET_SEMIHOST, TARGET_HOST_FILE
export target_device_write, target_semihost_write
export target_semihost_write_h, target_semihost_write_h1, target_semihost_write_h2
export target_file_open, target_file_write, target_file_close
