# Noalloc log output targets.

extern fn rt_string_data(value: text) -> i64
extern fn rt_string_len(value: text) -> i64
extern fn rt_log_target_device_write_bytes(ptr: i64, len: i64) -> bool
extern fn rt_log_target_semihost_write_bytes(ptr: i64, len: i64) -> bool

pub val TARGET_DEVICE: i32 = 1
pub val TARGET_SEMIHOST: i32 = 2
pub val TARGET_HOST_FILE: i32 = 4

fn target_device_write(msg: text):
    if rt_log_target_device_write_bytes(rt_string_data(msg), rt_string_len(msg)):
        return
    print msg

fn target_semihost_write(msg: text):
    if rt_log_target_semihost_write_bytes(rt_string_data(msg), rt_string_len(msg)):
        return
    print msg

fn target_semihost_write_h(handle: i32):
    print "[interned:" + handle.to_text() + "]"

fn target_semihost_write_h1(handle: i32, p0: i32):
    print "[interned:" + handle.to_text() + " p0=" + p0.to_text() + "]"

fn target_semihost_write_h2(handle: i32, p0: i32, p1: i32):
    print "[interned:" + handle.to_text() + " p0=" + p0.to_text() + " p1=" + p1.to_text() + "]"

var g_log_file_handle: i32 = -1

fn target_file_open(path: text) -> bool:
    g_log_file_handle = 1
    true

fn target_file_write(msg: text):
    if g_log_file_handle == -1:
        return
    print msg

fn target_file_close():
    g_log_file_handle = -1


export TARGET_DEVICE, TARGET_HOST_FILE, TARGET_SEMIHOST
