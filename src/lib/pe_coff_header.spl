# PE/COFF Header Parsing
# Utilities for reading Windows PE (Portable Executable) headers.

class PeHeaderSummary:
    ok: bool
    error: text
    pe_offset: i64
    machine: i64
    is_64bit: bool

fn parse_pe_header_summary(data: [u8]) -> PeHeaderSummary:
    if data.len() < 64:
        return PeHeaderSummary(ok: false, error: "data too short", pe_offset: 0, machine: 0, is_64bit: false)
    # DOS header: magic MZ at offset 0
    if data[0] != 77 or data[1] != 90:
        return PeHeaderSummary(ok: false, error: "not a valid PE file (missing MZ header)", pe_offset: 0, machine: 0, is_64bit: false)
    # PE offset at 0x3C (little-endian i32)
    val pe_off = data[0x3C].to_i64() or (data[0x3D].to_i64() << 8) or (data[0x3E].to_i64() << 16) or (data[0x3F].to_i64() << 24)
    if pe_off + 6 > data.len().to_i64():
        return PeHeaderSummary(ok: false, error: "PE offset out of bounds", pe_offset: 0, machine: 0, is_64bit: false)
    # Check PE signature "PE\0\0"
    val sig0 = data[pe_off.to_i64()].to_i64()
    val sig1 = data[(pe_off + 1).to_i64()].to_i64()
    if sig0 != 80 or sig1 != 69:
        return PeHeaderSummary(ok: false, error: "missing PE signature", pe_offset: 0, machine: 0, is_64bit: false)
    val machine = data[(pe_off + 4).to_i64()].to_i64() or (data[(pe_off + 5).to_i64()].to_i64() << 8)
    PeHeaderSummary(ok: true, error: "", pe_offset: pe_off, machine: machine, is_64bit: machine == 0x8664)

fn pe_rva_to_file_offset(data: [u8], rva: i64) -> i64:
    # Without section table parsing, approximate: for simple cases RVA == file offset
    # A full implementation would scan section headers to find the section containing rva
    rva
