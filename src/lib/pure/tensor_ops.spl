use std.pure.tensor.{PureTensor}

fn tensor_sum(t: PureTensor<f64>) -> f64:
    var total = 0.0
    for v in t.data:
        total = total + v
    total

fn tensor_mul_scalar(t: PureTensor<f64>, scalar: f64) -> PureTensor<f64>:
    var out: [f64] = []
    for v in t.data:
        out.push(v * scalar)
    PureTensor(data: out, shape: t.shape)

export tensor_sum
export tensor_mul_scalar
