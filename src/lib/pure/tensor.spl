# Stubs for pure tensor primitives
# These are placeholder implementations; real tensor ops use torch backends.

struct PureTensor<T>:
    data: [T]
    shape: [i64]

fn tensor_from_data(data: [f64], shape: [i64]) -> PureTensor<f64>:
    PureTensor(data: data, shape: shape)

export PureTensor, tensor_from_data
