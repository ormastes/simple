# Stubs for pure dataset primitives

struct LabeledSample:
    features: [f64]
    label: f64

class ArrayDataset:
    samples: [[f64]]

    fn len() -> i64:
        self.samples.len()

    fn get(idx: i64) -> [f64]:
        self.samples[idx]

class LabeledDataset:
    samples: [LabeledSample]

    fn len() -> i64:
        self.samples.len()

    fn get(idx: i64) -> LabeledSample:
        self.samples[idx]

export ArrayDataset, LabeledDataset, LabeledSample
