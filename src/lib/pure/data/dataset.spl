# Dataset primitives for supervised and unsupervised learning.

struct LabeledSample:
    feature: [f64]
    label: f64

class ArrayDataset:
    data: [[f64]]

    fn len() -> i64:
        self.data.len()

    fn get_item(idx: i64) -> [f64]:
        val n = self.data.len()
        if idx < 0 or idx >= n:
            return []
        self.data[idx]

class LabeledDataset:
    features: [[f64]]
    labels: [f64]

    fn len() -> i64:
        self.features.len()

    fn get_item(idx: i64) -> LabeledSample:
        val n = self.features.len()
        if idx < 0 or idx >= n:
            return LabeledSample(feature: [], label: 0.0)
        LabeledSample(feature: self.features[idx], label: self.labels[idx])

export ArrayDataset, LabeledDataset, LabeledSample
