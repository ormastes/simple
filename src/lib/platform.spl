    get_host_os, get_host_arch,
    dir_sep, path_sep, exe_ext, lib_ext,
    normalize_path, is_absolute_path, join_path, resolve_command
}

export is_windows, is_unix, is_macos, is_linux
export get_host_os, get_host_arch, dir_sep, path_sep, exe_ext, lib_ext
export normalize_path, is_absolute_path, join_path, resolve_command
