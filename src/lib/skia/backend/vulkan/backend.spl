# Skia Vulkan Backend
#
# GPU-accelerated rendering via Vulkan.
# All methods are stubs — actual Vulkan FFI is in a separate layer.

use std.skia.entity.canvas.{SkCanvas, sk_canvas_make}
use std.skia.entity.image.{SkImage, SkImageInfo, sk_image_info_n32_premul}
use std.skia.entity.geometry.{SkIRect}
use std.skia.capability.{SkCapability, sk_capability_vulkan}

# ============================================================================
# SkVulkanContext — opaque Vulkan device/queue context
# ============================================================================

class SkVulkanContext:
    device_index: i64
    is_initialized: bool

fn sk_vulkan_context_default() -> SkVulkanContext:
    SkVulkanContext(device_index: 0, is_initialized: false)

fn sk_vulkan_context_init(device_index: i64) -> SkVulkanContext:
    pass_todo

impl SkVulkanContext:
    fn is_valid() -> bool:
        self.is_initialized

    fn flush() -> SkVulkanContext:
        pass_todo

    fn wait() -> SkVulkanContext:
        pass_todo

# ============================================================================
# SkVulkanSurface — Vulkan-backed rendering surface
# ============================================================================

class SkVulkanSurface:
    info: SkImageInfo
    context: SkVulkanContext
    canvas: SkCanvas

fn sk_vulkan_surface_make(ctx: SkVulkanContext, width: i64, height: i64) -> SkVulkanSurface:
    pass_todo

impl SkVulkanSurface:
    fn canvas() -> SkCanvas:
        self.canvas

    fn capability() -> SkCapability:
        sk_capability_vulkan()

    fn width() -> i64:
        self.info.width

    fn height() -> i64:
        self.info.height

    fn snapshot() -> SkImage:
        pass_todo

    fn read_pixels(dst_rect: SkIRect) -> [i64]:
        pass_todo

    fn flush() -> SkVulkanSurface:
        pass_todo
