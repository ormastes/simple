# Skia Vulkan Backend
#
# GPU-accelerated rendering via Vulkan.
# PaintOp→vkCmd translator: pipeline cache, triangulation, command buffer recording.
# Actual vkQueueSubmit / ioctl edge is pass_todo in submit().

use std.skia.entity.canvas.{SkCanvas, sk_canvas_make}
use std.skia.entity.image.{SkImage, SkImageInfo, sk_image_info_n32_premul}
use std.skia.entity.geometry.{SkIRect, SkRect, SkPoint}
use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind}
use std.skia.entity.paint.{SkPaint, sk_paint_new}
use std.skia.entity.path.{SkPath, SkPathVerb, SkPathSegment}
use std.skia.entity.enums.{SkBlendMode, SkPaintStyle}
use std.skia.capability.{SkCapability, sk_capability_vulkan}

