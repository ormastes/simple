# CPU shader evaluators: gradients, image sampling, blend dispatch

use std.skia.entity.shader.{SkShader, SkShaderKind}
use std.skia.entity.color.{SkColor4f, SkColor, sk_color_alpha, sk_color_red, sk_color_green, sk_color_blue}
use std.skia.entity.image.{SkImage}
use std.skia.entity.geometry.{SkPoint}
use std.skia.entity.enums.{SkBlendMode, SkTileMode}
use std.skia.feature.blend.blend_compose.{compose}
use std.common.math.{math_clamp, math_abs, MATH_PI}

# ============================================================================
# Internal math helpers (no atan2/sqrt in stdlib)
# ============================================================================

fn _sqrt(x: f64) -> f64:
    if x <= 0.0:
        0.0
    else:
        # Newton-Raphson: 8 iterations sufficient for f64
        var g = x / 2.0
        var i = 0
        while i < 8:
            g = (g + x / g) / 2.0
            i = i + 1
        g

fn _atan_taylor(x: f64) -> f64:
    # Taylor series atan(x) for |x| <= 1, 12 terms
    val x2 = x * x
    val x3 = x2 * x
    val x5 = x3 * x2
    val x7 = x5 * x2
    val x9 = x7 * x2
    val x11 = x9 * x2
    val x13 = x11 * x2
    val x15 = x13 * x2
    val x17 = x15 * x2
    val x19 = x17 * x2
    val x21 = x19 * x2
    val x23 = x21 * x2
    x - x3 / 3.0 + x5 / 5.0 - x7 / 7.0 + x9 / 9.0 - x11 / 11.0 + x13 / 13.0 - x15 / 15.0 + x17 / 17.0 - x19 / 19.0 + x21 / 21.0 - x23 / 23.0

fn _atan2(y: f64, x: f64) -> f64:
    # Quadrant-aware atan2 using Taylor reduction to |t| <= 1
    val pi = MATH_PI
    val pi2 = MATH_PI / 2.0
    if x == 0.0:
        if y > 0.0: pi2
        else if y < 0.0: -pi2
        else: 0.0
    else if math_abs(x) >= math_abs(y):
        val t = y / x
        val a = _atan_taylor(t)
        if x > 0.0: a
        else if y >= 0.0: a + pi
        else: a - pi
    else:
        val t = x / y
        val a = _atan_taylor(t)
        if y > 0.0: pi2 - a
        else: -pi2 - a

fn _clamp01(x: f64) -> f64:
    math_clamp(x, 0.0, 1.0)

fn _color4f_from_sk_color(c: SkColor) -> SkColor4f:
    val a = sk_color_alpha(c).to_f64() / 255.0
    val r = sk_color_red(c).to_f64() / 255.0
    val g = sk_color_green(c).to_f64() / 255.0
    val b = sk_color_blue(c).to_f64() / 255.0
    SkColor4f(r: r, g: g, b: b, a: a)

# ============================================================================
# interpolate_stops
# ============================================================================

fn interpolate_stops(colors: [SkColor], positions: [f64], t: f64) -> SkColor4f:
    val n = colors.length()
    if n == 0:
        SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
    else if n == 1:
        _color4f_from_sk_color(colors[0])
    else:
        # clamp t
        val tc = _clamp01(t)
        # find bracketing pair
        var lo = 0
        var hi = n - 1
        var idx = 0
        while idx < n - 1:
            val p_next = positions[idx + 1]
            if tc <= p_next:
                lo = idx
                hi = idx + 1
                idx = n  # break
            else:
                idx = idx + 1
        # if we exhausted the loop without breaking, use last pair
        if idx == n - 1:
            lo = n - 2
            hi = n - 1
        val p0 = positions[lo]
        val p1 = positions[hi]
        val span = p1 - p0
        val local_t = if span <= 0.0: 0.0 else: _clamp01((tc - p0) / span)
        val ca = _color4f_from_sk_color(colors[lo])
        val cb = _color4f_from_sk_color(colors[hi])
        SkColor4f(
            r: ca.r + (cb.r - ca.r) * local_t,
            g: ca.g + (cb.g - ca.g) * local_t,
            b: ca.b + (cb.b - ca.b) * local_t,
            a: ca.a + (cb.a - ca.a) * local_t
        )

# ============================================================================
# tile_coord
# ============================================================================

fn tile_coord(t: f64, mode: SkTileMode) -> f64:
    match mode:
        SkTileMode.Clamp:
            _clamp01(t)
        SkTileMode.Repeat:
            val floored = t.to_i64().to_f64()
            val frac = t - floored
            if frac < 0.0: frac + 1.0 else: frac
        SkTileMode.Mirror:
            # tri-wave: fold into [0,2] then mirror second half
            val floored = t.to_i64().to_f64()
            val frac = t - floored
            val pos_frac = if frac < 0.0: frac + 1.0 else: frac
            # determine which half of the mirror cycle we're in
            val t_abs = if t < 0.0: -t else: t
            val cycle = t_abs.to_i64()
            val even = (cycle % 2) == 0
            if even: pos_frac else: 1.0 - pos_frac
        SkTileMode.Decal:
            if t < 0.0 or t > 1.0: -1.0 else: t

# ============================================================================
# eval_linear_gradient
# ============================================================================

fn eval_linear_gradient(shader: SkShader, x: f64, y: f64) -> SkColor4f:
    val start = shader.pt0
    val end = shader.pt1
    val dx = end.x - start.x
    val dy = end.y - start.y
    val len2 = dx * dx + dy * dy
    val px = x - start.x
    val py = y - start.y
    val t_raw = if len2 == 0.0: 0.0 else: (px * dx + py * dy) / len2
    val t = tile_coord(t_raw, shader.tile_mode)
    interpolate_stops(shader.colors, shader.positions, t)

# ============================================================================
# eval_radial_gradient
# ============================================================================

fn eval_radial_gradient(shader: SkShader, x: f64, y: f64) -> SkColor4f:
    val cx = shader.center.x
    val cy = shader.center.y
    val dx = x - cx
    val dy = y - cy
    val dist = _sqrt(dx * dx + dy * dy)
    val t_raw = if shader.radius == 0.0: 0.0 else: dist / shader.radius
    val t = tile_coord(t_raw, shader.tile_mode)
    interpolate_stops(shader.colors, shader.positions, t)

# ============================================================================
# eval_conic_gradient  (sweep from start_angle over 2*pi)
# ============================================================================

fn eval_conic_gradient(shader: SkShader, x: f64, y: f64) -> SkColor4f:
    val cx = shader.center.x
    val cy = shader.center.y
    val angle = _atan2(y - cy, x - cx)
    # start_angle stored in pt0.x (radians), range mapped via pt0.y as end_angle
    # For conic: start_angle = pt0.x, full 2*pi span
    val start_angle = shader.pt0.x
    val two_pi = 2.0 * MATH_PI
    val relative = angle - start_angle
    val frac = relative / two_pi
    val floored = frac.to_i64().to_f64()
    val t_raw = frac - floored
    val t = if t_raw < 0.0: t_raw + 1.0 else: t_raw
    interpolate_stops(shader.colors, shader.positions, t)

# ============================================================================
# eval_sweep_gradient  (same as conic, full 360 span)
# ============================================================================

fn eval_sweep_gradient(shader: SkShader, x: f64, y: f64) -> SkColor4f:
    eval_conic_gradient(shader, x, y)

# ============================================================================
# Image sampling helpers
# ============================================================================

fn _transparent_black() -> SkColor4f:
    SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)

fn _fetch_pixel(image: SkImage, px: i64, py: i64) -> SkColor4f:
    # Bounds check
    val w = image.info.width
    val h = image.info.height
    if px < 0 or px >= w or py < 0 or py >= h:
        _transparent_black()
    else if image.pixels.length() == 0:
        _transparent_black()
    else:
        # pixels stored as packed ARGB i64 per pixel (4 bytes per pixel, width*height entries)
        val idx = py * w + px
        val pixel_count = image.pixels.length()
        if idx < 0 or idx >= pixel_count:
            _transparent_black()
        else:
            val packed = image.pixels[idx]
            val a = ((packed >> 24) & 0xFF).to_f64() / 255.0
            val r = ((packed >> 16) & 0xFF).to_f64() / 255.0
            val g = ((packed >> 8) & 0xFF).to_f64() / 255.0
            val b = (packed & 0xFF).to_f64() / 255.0
            SkColor4f(r: r, g: g, b: b, a: a)

fn sample_image_nearest(image: SkImage, u: f64, v: f64) -> SkColor4f:
    if image.pixels.length() == 0:
        _transparent_black()
    else:
        val px = u.to_i64()
        val py = v.to_i64()
        _fetch_pixel(image, px, py)

fn sample_image_bilinear(image: SkImage, u: f64, v: f64) -> SkColor4f:
    # TODO(skia-cpu-sampler): real pixel fetch once SkImage backing-store is defined.
    if image.pixels.length() == 0:
        _transparent_black()
    else:
        val x0 = u.to_i64()
        val y0 = v.to_i64()
        val x1 = x0 + 1
        val y1 = y0 + 1
        val tx = u - x0.to_f64()
        val ty = v - y0.to_f64()
        val c00 = _fetch_pixel(image, x0, y0)
        val c10 = _fetch_pixel(image, x1, y0)
        val c01 = _fetch_pixel(image, x0, y1)
        val c11 = _fetch_pixel(image, x1, y1)
        # bilinear interpolation: mix along x first, then y
        val r0 = c00.r + (c10.r - c00.r) * tx
        val g0 = c00.g + (c10.g - c00.g) * tx
        val b0 = c00.b + (c10.b - c00.b) * tx
        val a0 = c00.a + (c10.a - c00.a) * tx
        val r1 = c01.r + (c11.r - c01.r) * tx
        val g1 = c01.g + (c11.g - c01.g) * tx
        val b1 = c01.b + (c11.b - c01.b) * tx
        val a1 = c01.a + (c11.a - c01.a) * tx
        SkColor4f(
            r: r0 + (r1 - r0) * ty,
            g: g0 + (g1 - g0) * ty,
            b: b0 + (b1 - b0) * ty,
            a: a0 + (a1 - a0) * ty
        )

# ============================================================================
# eval_shader — main dispatch
# ============================================================================

fn eval_shader(shader: SkShader, x: f64, y: f64) -> SkColor4f:
    match shader.kind:
        SkShaderKind.Color:
            _color4f_from_sk_color(shader.color)
        SkShaderKind.LinearGradient:
            eval_linear_gradient(shader, x, y)
        SkShaderKind.RadialGradient:
            eval_radial_gradient(shader, x, y)
        SkShaderKind.SweepGradient:
            eval_sweep_gradient(shader, x, y)
        SkShaderKind.TwoPointConicalGradient:
            eval_conic_gradient(shader, x, y)
        SkShaderKind.Image:
            _transparent_black()
        SkShaderKind.Blend:
            _transparent_black()
        SkShaderKind.Empty:
            _transparent_black()

# ============================================================================
# apply_blend
# ============================================================================

fn apply_blend(src: SkColor4f, dst: SkColor4f, mode: SkBlendMode) -> SkColor4f:
    compose(src, dst, mode)
