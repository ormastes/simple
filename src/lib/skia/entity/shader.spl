# Skia Shader
#
# SkShader — color source for SkPaint (gradients, images, etc.)

use std.skia.entity.enums.{SkTileMode}
use std.skia.entity.color.{SkColor}
use std.skia.entity.geometry.{SkPoint, SkRect}
use std.skia.entity.matrix.{Matrix3x3}

# ============================================================================
# SkShaderKind — discriminates the shader variant
# ============================================================================

enum SkShaderKind:
    Color
    LinearGradient
    RadialGradient
    SweepGradient
    TwoPointConicalGradient
    Image
    Blend
    Empty

# ============================================================================
# SkShader — sum-type approximation via kind + data fields
# ============================================================================

class SkShader:
    kind: SkShaderKind
    # color shader
    color: SkColor
    # gradient shared fields
    colors: [SkColor]
    positions: [f64]
    tile_mode: SkTileMode
    # linear gradient
    pt0: SkPoint
    pt1: SkPoint
    # radial gradient
    center: SkPoint
    radius: f64
    # local matrix
    local_matrix: Matrix3x3?

fn sk_shader_make_color(c: SkColor) -> SkShader:
    SkShader(
        kind: SkShaderKind.Color,
        color: c,
        colors: [],
        positions: [],
        tile_mode: SkTileMode.Clamp,
        pt0: SkPoint(x: 0.0, y: 0.0),
        pt1: SkPoint(x: 0.0, y: 0.0),
        center: SkPoint(x: 0.0, y: 0.0),
        radius: 0.0,
        local_matrix: nil
    )

fn sk_shader_make_linear_gradient(pt0: SkPoint, pt1: SkPoint, colors: [SkColor], positions: [f64], tile_mode: SkTileMode) -> SkShader:
    SkShader(
        kind: SkShaderKind.LinearGradient,
        color: 0,
        colors: colors,
        positions: positions,
        tile_mode: tile_mode,
        pt0: pt0,
        pt1: pt1,
        center: SkPoint(x: 0.0, y: 0.0),
        radius: 0.0,
        local_matrix: nil
    )

fn sk_shader_make_radial_gradient(center: SkPoint, radius: f64, colors: [SkColor], positions: [f64], tile_mode: SkTileMode) -> SkShader:
    SkShader(
        kind: SkShaderKind.RadialGradient,
        color: 0,
        colors: colors,
        positions: positions,
        tile_mode: tile_mode,
        pt0: SkPoint(x: 0.0, y: 0.0),
        pt1: SkPoint(x: 0.0, y: 0.0),
        center: center,
        radius: radius,
        local_matrix: nil
    )

impl SkShader:
    fn with_local_matrix(m: Matrix3x3) -> SkShader:
        SkShader(
            kind: self.kind,
            color: self.color,
            colors: self.colors,
            positions: self.positions,
            tile_mode: self.tile_mode,
            pt0: self.pt0,
            pt1: self.pt1,
            center: self.center,
            radius: self.radius,
            local_matrix: Some(m)
        )

    fn is_opaque() -> bool:
        pass_todo
