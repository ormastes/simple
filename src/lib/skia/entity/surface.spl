# SkSurface — immutable pixel container + canvas factory.
#
# Mirrors Skia's SkSurface. Owns a Bitmap (or GPU texture in a future backend)
# and provides:
#   - get_canvas(): returns an SkCanvas that draws into this surface
#   - snapshot(): returns an immutable SkImage (bitmap copy)
#   - make_surface(w, h): factory for a new surface
#
# Raster-only in this module. GPU-backed surfaces live in backend/vulkan.

use std.skia.entity.canvas.{SkCanvas, sk_canvas_make}
use std.skia.backend.cpu.raster_prims.{Bitmap}

# ============================================================================
# SurfaceBackend — enum of supported surface backends
# ============================================================================

enum SurfaceBackend:
    Cpu
    GpuStub

# ============================================================================
# SkSurface — pixel container + canvas factory
# ============================================================================

class SkSurface:
    width: i64
    height: i64
    backend: SurfaceBackend
    bitmap: Bitmap

# ============================================================================
# Constructors
# ============================================================================

fn sk_surface_make_raster(w: i64, h: i64) -> SkSurface:
    # Allocates a new SkSurface with a fresh zeroed Bitmap.
    val bmp = Bitmap.zeros(w, h)
    SkSurface(width: w, height: h, backend: SurfaceBackend.Cpu, bitmap: bmp)

fn sk_surface_make_from_bitmap(bmp: Bitmap) -> SkSurface:
    # Wraps an existing bitmap; width/height are taken from the bitmap.
    SkSurface(width: bmp.width, height: bmp.height, backend: SurfaceBackend.Cpu, bitmap: bmp)

fn sk_surface_make_gpu_stub(w: i64, h: i64) -> SkSurface:
    # Stub for future GPU-backed surface. Bitmap is an empty placeholder.
    val empty = Bitmap.zeros(0, 0)
    SkSurface(width: w, height: h, backend: SurfaceBackend.GpuStub, bitmap: empty)

# ============================================================================
# Methods
# ============================================================================

impl SkSurface:
    me get_canvas() -> SkCanvas:
        # Returns a new SkCanvas bound to this surface's dimensions.
        sk_canvas_make(me.width, me.height)

    me width() -> i64:
        me.width

    me height() -> i64:
        me.height

    me snapshot_bitmap() -> Bitmap:
        # Returns a clone of the current bitmap, decoupled from the surface.
        val total = me.bitmap.width * me.bitmap.height * 4
        var buf = [u8]()
        var i = 0
        while i < total:
            buf.push(me.bitmap.pixels[i])
            i = i + 1
        Bitmap(width: me.bitmap.width, height: me.bitmap.height, pixels: buf)

    me clear():
        # Resets all pixels to transparent/black (0,0,0,0).
        val total = me.bitmap.width * me.bitmap.height * 4
        var i = 0
        while i < total:
            me.bitmap.pixels[i] = 0 as u8
            i = i + 1
