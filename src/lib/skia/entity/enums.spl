# Skia Enumerations
#
# Core enums matching Skia/Chromium API surface.

# ============================================================================
# SkPaint enums
# ============================================================================

enum SkPaintStyle:
    Fill
    Stroke
    StrokeAndFill

enum SkPaintCap:
    Butt
    Round
    Square

enum SkPaintJoin:
    Miter
    Round
    Bevel

# ============================================================================
# SkBlendMode
# ============================================================================

enum SkBlendMode:
    Clear
    Src
    Dst
    SrcOver
    DstOver
    SrcIn
    DstIn
    SrcOut
    DstOut
    SrcATop
    DstATop
    Xor
    Plus
    Modulate
    Screen
    Overlay
    Darken
    Lighten
    ColorDodge
    ColorBurn
    HardLight
    SoftLight
    Difference
    Exclusion
    Multiply
    Hue
    Saturation
    Color
    Luminosity

# ============================================================================
# SkFilterQuality / SkSamplingOptions
# ============================================================================

enum SkFilterMode:
    Nearest
    Linear

enum SkMipmapMode:
    None
    Nearest
    Linear

# ============================================================================
# SkPath enums
# ============================================================================

enum SkPathFillType:
    Winding
    EvenOdd
    InverseWinding
    InverseEvenOdd

enum SkPathDirection:
    Cw
    Ccw

# ============================================================================
# SkClipOp
# ============================================================================

enum SkClipOp:
    Difference
    Intersect

# ============================================================================
# SkTileMode
# ============================================================================

enum SkTileMode:
    Clamp
    Repeat
    Mirror
    Decal

# ============================================================================
# SkAlphaType / SkColorType
# ============================================================================

enum SkAlphaType:
    Unknown
    Opaque
    Premul
    Unpremul

enum SkColorType:
    Unknown
    Alpha8
    Rgb565
    Argb4444
    Rgba8888
    Rgb888x
    Bgra8888
    Rgba1010102
    Bgra1010102
    Rgb101010x
    Bgr101010x
    Gray8
    RgbaF16Norm
    RgbaF16
    RgbaF32

# ============================================================================
# SkTextEncoding
# ============================================================================

enum SkTextEncoding:
    Utf8
    Utf16
    Utf32
    GlyphId
