# Skia Picture
#
# SkPicture — recorded drawing commands for later playback.

use std.skia.entity.geometry.{SkRect}

# ============================================================================
# SkPictureOp — a recorded drawing operation
# ============================================================================

enum SkPictureOpKind:
    Save
    SaveLayer
    Restore
    DrawRect
    DrawOval
    DrawPath
    DrawText
    DrawImage
    ClipRect
    SetMatrix
    DrawPaint
    DrawPoints
    DrawRRect
    DrawTextBlob

class SkPictureOp:
    kind: SkPictureOpKind

# ============================================================================
# SkPicture — immutable recorded display list
# ============================================================================

class SkPicture:
    cull_rect: SkRect
    op_count: i64

fn sk_picture_empty() -> SkPicture:
    SkPicture(cull_rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0), op_count: 0)

impl SkPicture:
    fn cull_rect() -> SkRect:
        self.cull_rect

    fn approximate_op_count() -> i64:
        self.op_count

    fn serialize() -> [i64]:
        pass_todo

# ============================================================================
# SkPictureRecorder — records drawing commands into a picture
# ============================================================================

class SkPictureRecorder:
    recording: bool
    cull_rect: SkRect
    ops: i64

fn sk_picture_recorder_new() -> SkPictureRecorder:
    SkPictureRecorder(recording: false, cull_rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0), ops: 0)

impl SkPictureRecorder:
    fn begin_recording(bounds: SkRect) -> SkPictureRecorder:
        SkPictureRecorder(recording: true, cull_rect: bounds, ops: 0)

    fn finish_recording() -> SkPicture:
        SkPicture(cull_rect: self.cull_rect, op_count: self.ops)

    fn is_recording() -> bool:
        self.recording
