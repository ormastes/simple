# Skia TextBlob
#
# SkTextBlob — immutable container of shaped glyphs + positions.

use std.skia.entity.font.{SkFont}
use std.skia.entity.geometry.{SkPoint, SkRect}

# ============================================================================
# SkGlyphRun — one run of glyphs with a single font
# ============================================================================

class SkGlyphRun:
    font: SkFont
    glyphs: [i64]      # glyph IDs
    positions: [SkPoint]

# ============================================================================
# SkTextBlob
# ============================================================================

class SkTextBlob:
    runs: [SkGlyphRun]

fn sk_text_blob_make_from_text(text: text, font: SkFont) -> SkTextBlob:
    # Simple stub: create a single run with one glyph per character
    val n = text.len()
    var glyphs: [i64] = []
    var positions: [SkPoint] = []
    var i = 0
    while i < n:
        glyphs.push(i)
        positions.push(SkPoint(x: font.size * i.to_f64() * 0.6, y: 0.0))
        i = i + 1
    val run = SkGlyphRun(font: font, glyphs: glyphs, positions: positions)
    SkTextBlob(runs: [run])

fn sk_text_blob_make_from_pos_text(text: text, positions: [SkPoint], font: SkFont) -> SkTextBlob:
    val n = text.len()
    var glyphs: [i64] = []
    var i = 0
    while i < n:
        glyphs.push(i)
        i = i + 1
    val actual_positions = if positions.len() >= n: positions[:n] else: positions
    val run = SkGlyphRun(font: font, glyphs: glyphs, positions: actual_positions)
    SkTextBlob(runs: [run])

impl SkTextBlob:
    fn is_empty() -> bool:
        self.runs.len() == 0

    fn bounds() -> SkRect:
        if self.runs.len() == 0:
            return SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
        var min_x = 0.0
        var min_y = 0.0
        var max_x = 0.0
        var max_y = 0.0
        var first = true
        for run in self.runs:
            val glyph_w = run.font.size * 0.6
            val glyph_h = run.font.size
            for pos in run.positions:
                if first:
                    min_x = pos.x
                    min_y = pos.y - glyph_h
                    max_x = pos.x + glyph_w
                    max_y = pos.y
                    first = false
                else:
                    if pos.x < min_x:
                        min_x = pos.x
                    if pos.y - glyph_h < min_y:
                        min_y = pos.y - glyph_h
                    if pos.x + glyph_w > max_x:
                        max_x = pos.x + glyph_w
                    if pos.y > max_y:
                        max_y = pos.y
        SkRect(left: min_x, top: min_y, right: max_x, bottom: max_y)

    fn glyph_count() -> i64:
        var total = 0
        for run in self.runs:
            total = total + run.glyphs.len()
        total
