# Skia Image
#
# SkImage — immutable image handle.

use std.skia.entity.enums.{SkAlphaType, SkColorType}
use std.skia.entity.geometry.{SkIRect, SkISize}

# ============================================================================
# SkImageInfo — describes pixel buffer layout
# ============================================================================

class SkImageInfo:
    width: i64
    height: i64
    color_type: SkColorType
    alpha_type: SkAlphaType

fn sk_image_info_make(width: i64, height: i64, ct: SkColorType, at: SkAlphaType) -> SkImageInfo:
    SkImageInfo(width: width, height: height, color_type: ct, alpha_type: at)

fn sk_image_info_n32_premul(width: i64, height: i64) -> SkImageInfo:
    SkImageInfo(width: width, height: height, color_type: SkColorType.Rgba8888, alpha_type: SkAlphaType.Premul)

impl SkImageInfo:
    fn size() -> SkISize:
        SkISize(width: self.width, height: self.height)

    fn is_empty() -> bool:
        self.width <= 0 or self.height <= 0

    fn bytes_per_pixel() -> i64:
        match self.color_type:
            case SkColorType.Alpha8: 1
            case SkColorType.Rgb565: 2
            case SkColorType.Argb4444: 2
            case SkColorType.Rgba8888: 4
            case SkColorType.Rgb888x: 4
            case SkColorType.Bgra8888: 4
            case SkColorType.Gray8: 1
            case _: 4

    fn min_row_bytes() -> i64:
        self.width * self.bytes_per_pixel()

# ============================================================================
# SkImage — immutable raster image
# ============================================================================

class SkImage:
    info: SkImageInfo
    pixels: [i64]   # raw pixel data (packed ARGB as i64 per channel byte)

fn sk_image_make(info: SkImageInfo, pixels: [i64]) -> SkImage:
    SkImage(info: info, pixels: pixels)

fn sk_image_empty(width: i64, height: i64) -> SkImage:
    val info = sk_image_info_n32_premul(width, height)
    val size = width * height * 4
    val pixels: [i64] = [0 for _ in 0..size]
    SkImage(info: info, pixels: pixels)

impl SkImage:
    fn width() -> i64:
        self.info.width

    fn height() -> i64:
        self.info.height

    fn bounds() -> SkIRect:
        SkIRect(left: 0, top: 0, right: self.info.width, bottom: self.info.height)

    fn is_empty() -> bool:
        self.info.is_empty()

    fn encode_to_png() -> [i64]:
        pass_todo

    fn subset(rect: SkIRect) -> SkImage?:
        pass_todo
