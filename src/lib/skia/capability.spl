# Skia Capability
#
# Describes what a Skia backend can do.

# ============================================================================
# SkBackendType
# ============================================================================

enum SkBackendType:
    Cpu
    Vulkan
    Metal
    OpenGl
    Direct3d

# ============================================================================
# SkCapability — feature flags for a backend
# ============================================================================

class SkCapability:
    backend: SkBackendType
    supports_msaa: bool
    supports_mip_maps: bool
    supports_compute_shaders: bool
    max_texture_size: i64
    max_render_targets: i64

fn sk_capability_cpu() -> SkCapability:
    SkCapability(
        backend: SkBackendType.Cpu,
        supports_msaa: false,
        supports_mip_maps: true,
        supports_compute_shaders: false,
        max_texture_size: 32767,
        max_render_targets: 1
    )

fn sk_capability_vulkan() -> SkCapability:
    SkCapability(
        backend: SkBackendType.Vulkan,
        supports_msaa: true,
        supports_mip_maps: true,
        supports_compute_shaders: true,
        max_texture_size: 16384,
        max_render_targets: 8
    )

impl SkCapability:
    fn to_string() -> text:
        "SkCapability(backend:{self.backend} msaa:{self.supports_msaa})"
