# UAX#9 bidi algorithm — simplified subset for mixed-direction text.
#
# Mirrors ICU's ubidi_ API. Given a UTF-8 codepoint sequence, classifies
# each codepoint, assigns embedding levels (even=LTR, odd=RTL), and
# computes the visual order (array of indices into original sequence).
#
# Character classes supported:
#   - L: strong left-to-right (Latin letters, digits when in LTR context)
#   - R: strong right-to-left (Hebrew U+0590-05FF)
#   - AL: arabic letter (RTL)  (U+0600-06FF, U+0750-077F)
#   - EN: european number (neutral in RTL contexts — simplified to L)
#   - ON: other neutral (punctuation, whitespace — take surrounding direction)
#
# Not supported:
#   - Explicit embedding controls (LRE/RLE/PDF/LRI/RLI/PDI)
#   - AN (Arabic number) separate handling
#   - BN (boundary neutral), CS/ES/ET (separators)

# ===== BidiClass enum =====

enum BidiClass:
    L
    R
    AL
    EN
    ON

# ===== classify_bidi: classify a single Unicode codepoint =====

fn classify_bidi(codepoint: i64) -> BidiClass:
    # Hebrew: U+0590..U+05FF = 1424..1535
    if codepoint >= 1424 and codepoint <= 1535:
        BidiClass.R
    # Arabic basic block: U+0600..U+06FF = 1536..1791
    else if codepoint >= 1536 and codepoint <= 1791:
        BidiClass.AL
    # Arabic supplement: U+0750..U+077F = 1872..1919
    else if codepoint >= 1872 and codepoint <= 1919:
        BidiClass.AL
    # Arabic extended-A: U+08A0..U+08FF = 2208..2303
    else if codepoint >= 2208 and codepoint <= 2303:
        BidiClass.AL
    # ASCII uppercase letters: U+0041..U+005A = 65..90
    else if codepoint >= 65 and codepoint <= 90:
        BidiClass.L
    # ASCII lowercase letters: U+0061..U+007A = 97..122
    else if codepoint >= 97 and codepoint <= 122:
        BidiClass.L
    # ASCII digits: U+0030..U+0039 = 48..57
    else if codepoint >= 48 and codepoint <= 57:
        BidiClass.EN
    # Other ASCII (spaces, punctuation): U+0000..U+007F excluding letters and digits
    else if codepoint >= 0 and codepoint <= 127:
        BidiClass.ON
    # CJK Unified Ideographs: U+4E00..U+9FFF = 19968..40959
    else if codepoint >= 19968 and codepoint <= 40959:
        BidiClass.L
    # Default: treat as LTR (simplified)
    else:
        BidiClass.L

# ===== Helper: is a BidiClass a strong character? =====

fn _is_strong(cls: BidiClass) -> bool:
    if cls == BidiClass.L:
        true
    else if cls == BidiClass.R:
        true
    else if cls == BidiClass.AL:
        true
    else:
        false

# ===== Helper: is a BidiClass RTL strong? =====

fn _is_rtl_strong(cls: BidiClass) -> bool:
    if cls == BidiClass.R:
        true
    else if cls == BidiClass.AL:
        true
    else:
        false

# ===== compute_embedding_levels =====
# Returns one embedding level per codepoint.
# even = LTR, odd = RTL.

fn compute_embedding_levels(codepoints: [i64], base_direction_rtl: bool) -> [i64]:
    val n = codepoints.len()
    var levels: [i64] = []
    var base_level: i64 = 0
    if base_direction_rtl:
        base_level = 1

    # First pass: assign levels to L, R/AL. Leave EN and ON as -1 (pending).
    var i: i64 = 0
    while i < n:
        val cp = codepoints[i]
        val cls = classify_bidi(cp)
        if cls == BidiClass.L:
            # Strong LTR: use even level
            if base_level == 0:
                levels.push(0)
            else:
                levels.push(base_level + 1)
        else if cls == BidiClass.R or cls == BidiClass.AL:
            # Strong RTL: use odd level
            if base_level == 0:
                levels.push(1)
            else:
                levels.push(base_level)
        else:
            # EN or ON: placeholder -1 for second pass
            levels.push(-1)
        i = i + 1

    # Second pass: resolve EN — inherit from preceding strong, or base_level
    var last_strong_level: i64 = base_level
    var j: i64 = 0
    while j < n:
        val cp = codepoints[j]
        val cls = classify_bidi(cp)
        if cls == BidiClass.L:
            last_strong_level = levels[j]
        else if cls == BidiClass.R or cls == BidiClass.AL:
            last_strong_level = levels[j]
        else if cls == BidiClass.EN:
            levels[j] = last_strong_level
        j = j + 1

    # Third pass: resolve ON — look left and right for nearest strong
    var k: i64 = 0
    while k < n:
        val cp = codepoints[k]
        val cls = classify_bidi(cp)
        if cls == BidiClass.ON:
            # Find nearest strong to the left
            var left_level: i64 = base_level
            var li: i64 = k - 1
            while li >= 0:
                val lcls = classify_bidi(codepoints[li])
                if _is_strong(lcls):
                    left_level = levels[li]
                    li = -1
                else:
                    li = li - 1
            # Find nearest strong to the right
            var right_level: i64 = base_level
            var ri: i64 = k + 1
            while ri < n:
                val rcls = classify_bidi(codepoints[ri])
                if _is_strong(rcls):
                    right_level = levels[ri]
                    ri = n
                else:
                    ri = ri + 1
            # Resolve: if both neighbors agree, use that level; else use base_level
            if left_level == right_level:
                levels[k] = left_level
            else:
                levels[k] = base_level
        k = k + 1

    levels

# ===== reorder_visual =====
# UAX#9 L2: from highest level down to 1, reverse each run at that level or higher.
# Returns reordered codepoints.

fn reorder_visual(codepoints: [i64], levels: [i64]) -> [i64]:
    val n = codepoints.len()
    # Work on a mutable copy
    var result: [i64] = []
    var lvls: [i64] = []
    var ci: i64 = 0
    while ci < n:
        result.push(codepoints[ci])
        lvls.push(levels[ci])
        ci = ci + 1

    # Find max level
    var max_level: i64 = 0
    var mi: i64 = 0
    while mi < n:
        if lvls[mi] > max_level:
            max_level = lvls[mi]
        mi = mi + 1

    # For each level from max down to 1, reverse runs where level >= current
    var level: i64 = max_level
    while level >= 1:
        # Find contiguous runs where lvls[i] >= level and reverse them
        var start: i64 = 0
        while start < n:
            if lvls[start] >= level:
                # Find end of run
                var end_idx: i64 = start + 1
                while end_idx < n and lvls[end_idx] >= level:
                    end_idx = end_idx + 1
                # Reverse result[start..end_idx-1]
                var lo: i64 = start
                var hi: i64 = end_idx - 1
                while lo < hi:
                    val tmp_cp = result[lo]
                    val tmp_lv = lvls[lo]
                    result[lo] = result[hi]
                    lvls[lo] = lvls[hi]
                    result[hi] = tmp_cp
                    lvls[hi] = tmp_lv
                    lo = lo + 1
                    hi = hi - 1
                start = end_idx
            else:
                start = start + 1
        level = level - 1

    result

# ===== is_rtl =====
# Returns true if the first strong character (L, R, or AL) in the sequence
# is R or AL; false otherwise. Defaults to false (LTR) if no strong chars.

fn is_rtl(codepoints: [i64]) -> bool:
    val n = codepoints.len()
    var i: i64 = 0
    while i < n:
        val cls = classify_bidi(codepoints[i])
        if _is_strong(cls):
            return _is_rtl_strong(cls)
        i = i + 1
    false
