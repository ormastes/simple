# 4x5 color matrix filter applied per-pixel to an ImageBuffer

use std.skia.entity.color.{SkColor4f}
use std.skia.feature.filter.gaussian_blur.{ImageBuffer}
use std.common.math.{math_clamp}

fn apply_color_matrix(buf: ImageBuffer, matrix: [f64]) -> ImageBuffer:
    # matrix: 20 elements, 4 rows x 5 cols (r,g,b,a,offset)
    var out: [SkColor4f] = []
    var i = 0
    while i < buf.pixels.len().to_i32():
        val p = buf.pixels[i.to_i64()]
        val nr = matrix[0] * p.r + matrix[1] * p.g + matrix[2] * p.b + matrix[3] * p.a + matrix[4]
        val ng = matrix[5] * p.r + matrix[6] * p.g + matrix[7] * p.b + matrix[8] * p.a + matrix[9]
        val nb = matrix[10] * p.r + matrix[11] * p.g + matrix[12] * p.b + matrix[13] * p.a + matrix[14]
        val na = matrix[15] * p.r + matrix[16] * p.g + matrix[17] * p.b + matrix[18] * p.a + matrix[19]
        out = out + [SkColor4f(r: math_clamp(nr, 0.0, 1.0),
                               g: math_clamp(ng, 0.0, 1.0),
                               b: math_clamp(nb, 0.0, 1.0),
                               a: math_clamp(na, 0.0, 1.0))]
        i = i + 1
    ImageBuffer(width: buf.width, height: buf.height, pixels: out)
