# Glyph outline rasterizer: SkPath bounding-box fill to alpha bitmap

use std.skia.feature.glyph.outline.{GlyphOutline}

class GlyphBitmap:
    width: i64
    height: i64
    left: i64
    top: i64
    pixels: [u8]

fn rasterize_outline(outline: GlyphOutline, size_px: f64) -> GlyphBitmap:
    # TODO(skia-glyph): real analytic AA scanline rasterizer in Phase 3 final.
    # For now: uniform black fill for all pixels inside path bounds.
    val bounds = outline.metrics.bounds
    val scale = size_px / 12.0
    val raw_w = (bounds.right - bounds.left) * scale
    val raw_h = (bounds.bottom - bounds.top) * scale
    val w = if raw_w < 1.0: 1 else: raw_w as i64
    val h = if raw_h < 1.0: 1 else: raw_h as i64
    val total = w * h
    var pixels: [u8] = []
    var i: i64 = 0
    while i < total:
        pixels.push(255)
        i = i + 1
    GlyphBitmap(
        width: w,
        height: h,
        left: 0,
        top: 0,
        pixels: pixels
    )
