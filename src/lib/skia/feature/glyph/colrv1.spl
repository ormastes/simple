# COLRv1 color emoji layer-list decoder and paint-graph compositor.
# Decodes COLR table header (v1), layer-list structure, and composes
# paint graphs into Bitmap output.

use std.skia.feature.glyph.ot_parser.{read_u16_be, read_u32_be}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.backend.cpu.shaders.{eval_linear_gradient, eval_radial_gradient, eval_sweep_gradient, apply_blend}
use std.skia.entity.color.{SkColor4f, SkColor, sk_color_alpha, sk_color_red, sk_color_green, sk_color_blue}
use std.skia.entity.enums.{SkBlendMode}
use std.skia.entity.geometry.{SkRect}

# ===== COLR v1 header =====

class ColrV1Header:
    version: u16
    num_base_glyph_records: u16
    layer_list_offset: u32
    clip_list_offset: u32
    var_index_map_offset: u32

# parse_colr_header reads the COLR table header from a raw blob.
# Returns None if blob is too short or version != 1.
fn parse_colr_header(blob: [u8]) -> Option<ColrV1Header>:
    # Minimum COLR v1 header is 20 bytes:
    # 2  version
    # 2  numBaseGlyphRecords
    # 4  baseGlyphRecordsOffset
    # 4  layersOffset  (layer_list_offset)
    # 4  numLayers (or clip_list_offset in v1 extended form)
    # 4  varIndexMapOffset
    # We require at least 20 bytes for a v1 header.
    if blob.len() < 20:
        return None
    val version_raw = read_u16_be(blob, 0) as u16
    if version_raw != 1:
        return None
    val num_base = read_u16_be(blob, 2) as u16
    # offset 4: baseGlyphRecordsOffset (4 bytes) — skip, not stored
    val layer_off = read_u32_be(blob, 8)
    val clip_off = read_u32_be(blob, 12)
    val var_off = read_u32_be(blob, 16)
    Some(ColrV1Header(
        version: version_raw,
        num_base_glyph_records: num_base,
        layer_list_offset: layer_off,
        clip_list_offset: clip_off,
        var_index_map_offset: var_off
    ))

# ===== Layer list =====

class ColrLayer:
    glyph_id: u32
    paint_offset: u32

# parse_layer_list reads the layer list from the COLR blob using the header.
# Returns [] if layer_list_offset is 0 or the region is too short.
fn parse_layer_list(blob: [u8], header: ColrV1Header) -> [ColrLayer]:
    val off = header.layer_list_offset as i64
    if off == 0:
        return []
    # layer list starts with numLayers u32, then each record: glyphId u16, paintOffset u32
    # record size = 6 bytes
    if off + 4 > blob.len() as i64:
        return []
    val num_layers = read_u32_be(blob, off) as i64
    val data_start = off + 4
    if data_start + num_layers * 6 > blob.len() as i64:
        return []
    var layers: [ColrLayer] = []
    var i: i64 = 0
    while i < num_layers:
        val rec = data_start + i * 6
        val gid = read_u16_be(blob, rec) as u32
        val paint_off = read_u32_be(blob, rec + 2)
        val layer = ColrLayer(glyph_id: gid, paint_offset: paint_off)
        layers = [...layers, layer]
        i = i + 1
    layers

# ===== Paint kind enum =====

enum PaintKind:
    Solid
    LinearGradient
    RadialGradient
    SweepGradient
    Glyph
    ColrLayers
    Transform
    Translate
    Rotate
    Scale
    Skew
    Composite

# ===== Paint node =====

class PaintNode:
    kind: PaintKind
    palette_index: u16
    # alpha in 2.14 fixed-point (0x4000 == 1.0)
    alpha_fixed: i32

# decode_paint_subtable reads one paint record from blob at the given offset.
# Dispatches on the format byte; unknown formats return a safe Solid fallback.
# Returns None if offset is out of bounds.
fn decode_paint_subtable(blob: [u8], offset: u32) -> Option<PaintNode>:
    val off = offset as i64
    if off >= blob.len() as i64:
        return None
    val fmt = blob[off] as u32
    # COLRv1 paint format values (OpenType spec §COLRv1)
    # 2/3  = PaintSolid / PaintVarSolid
    # 4/5  = PaintLinearGradient / PaintVarLinearGradient
    # 6/7  = PaintRadialGradient / PaintVarRadialGradient
    # 8/9  = PaintSweepGradient / PaintVarSweepGradient
    # 10   = PaintGlyph
    # 11   = PaintColrLayers
    # 12/13= PaintTransform / PaintVarTransform
    # 14/15= PaintTranslate / PaintVarTranslate
    # 16/17= PaintRotate / PaintVarRotate
    # 18/19= PaintScale / PaintVarScale
    # 20/21= PaintSkew / PaintVarSkew
    # 32   = PaintComposite
    if fmt == 2 or fmt == 3:
        # pass_todo: read palette_index and alpha from record fields
        val pal_idx = read_u16_be(blob, off + 1) as u16
        Some(PaintNode(kind: PaintKind.Solid, palette_index: pal_idx, alpha_fixed: 16384))
    else if fmt == 4 or fmt == 5:
        # pass_todo: read gradient color line and geometry
        Some(PaintNode(kind: PaintKind.LinearGradient, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 6 or fmt == 7:
        # pass_todo: read radial gradient parameters
        Some(PaintNode(kind: PaintKind.RadialGradient, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 8 or fmt == 9:
        # pass_todo: read sweep gradient parameters
        Some(PaintNode(kind: PaintKind.SweepGradient, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 10:
        # pass_todo: read glyph_id and child paint offset
        Some(PaintNode(kind: PaintKind.Glyph, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 11:
        # pass_todo: read num_layers and first_layer_index into layer list
        Some(PaintNode(kind: PaintKind.ColrLayers, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 12 or fmt == 13:
        # pass_todo: read 2x3 affine transform matrix
        Some(PaintNode(kind: PaintKind.Transform, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 14 or fmt == 15:
        # pass_todo: read dx/dy translation
        Some(PaintNode(kind: PaintKind.Translate, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 16 or fmt == 17:
        # pass_todo: read rotation angle
        Some(PaintNode(kind: PaintKind.Rotate, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 18 or fmt == 19:
        # pass_todo: read scale factors
        Some(PaintNode(kind: PaintKind.Scale, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 20 or fmt == 21:
        # pass_todo: read skew x/y angles
        Some(PaintNode(kind: PaintKind.Skew, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 32:
        # pass_todo: read source/backdrop paint offsets and composite mode
        Some(PaintNode(kind: PaintKind.Composite, palette_index: 0, alpha_fixed: 16384))
    else:
        # Unknown format — safe Solid fallback, alpha=1.0 (0x4000)
        Some(PaintNode(kind: PaintKind.Solid, palette_index: 0, alpha_fixed: 16384))

# ===== BaseGlyph v1 record search =====

# find_base_glyph_v1 scans the BaseGlyph v1 records for glyph_id.
# BaseGlyph v1 record: glyphId (u16) + paintOffset (u32) = 6 bytes each.
# The records start at baseGlyphRecordsOffset (bytes 4-7 in the COLR table).
# Returns Some(paint_offset) or None if not found.
fn find_base_glyph_v1(blob: [u8], header: ColrV1Header, glyph_id: u32) -> Option<u32>:
    # BaseGlyphRecordsOffset is at blob offset 4 (not stored in header; re-read it)
    if blob.len() < 8:
        return None
    val base_off = read_u32_be(blob, 4) as i64
    if base_off == 0:
        return None
    val count = header.num_base_glyph_records as i64
    if base_off + count * 6 > blob.len() as i64:
        return None
    # Linear scan (BaseGlyph records are sorted by glyph_id; binary search possible but linear is simpler)
    var i: i64 = 0
    while i < count:
        val rec = base_off + i * 6
        val gid = read_u16_be(blob, rec) as u32
        if gid == glyph_id:
            val paint_off = read_u32_be(blob, rec + 2)
            return Some(paint_off)
        i = i + 1
    None

# ===== Shaper entry point =====

# route_color_glyph is called by the shaper to produce a layer breakdown
# for a color glyph from the raw COLR table blob.
# Returns None if the blob is empty, has no v1 header, or the glyph isn't found.
fn route_color_glyph(shaper_glyph_id: u32, colr_blob: [u8]) -> Option<[ColrLayer]>:
    if colr_blob.len() == 0:
        return None
    val maybe_header = parse_colr_header(colr_blob)
    if maybe_header == None:
        return None
    val header = maybe_header.unwrap()
    val maybe_paint_off = find_base_glyph_v1(colr_blob, header, shaper_glyph_id)
    if maybe_paint_off == None:
        return None
    # pass_todo: recursively walk paint graph and flatten into layer list
    # For now return the flat layer list from the layer-list table as a skeleton.
    val layers = parse_layer_list(colr_blob, header)
    Some(layers)

# ===== Paint-graph compositor =====

# PaintGraphContext carries per-glyph rendering context through the paint graph.
class PaintGraphContext:
    bounds: SkRect
    palette: [SkColor]
    em_units: i32

    fn new(bounds: SkRect, palette: [SkColor], em_units: i32) -> PaintGraphContext:
        PaintGraphContext(bounds: bounds, palette: palette, em_units: em_units)

# _sk_color_to_color4f converts a packed SkColor (i64 ARGB) to SkColor4f.
fn _sk_color_to_color4f(c: SkColor) -> SkColor4f:
    val a = sk_color_alpha(c).to_f64() / 255.0
    val r = sk_color_red(c).to_f64() / 255.0
    val g = sk_color_green(c).to_f64() / 255.0
    val b = sk_color_blue(c).to_f64() / 255.0
    SkColor4f(r: r, g: g, b: b, a: a)

# _bitmap_blend_over composites src bitmap onto dst bitmap with SrcOver per pixel.
fn _bitmap_blend_over(dst: Bitmap, src: Bitmap):
    val w = dst.width
    val h = dst.height
    var y = 0 as i64
    while y < h:
        var x = 0 as i64
        while x < w:
            val idx = (y * w + x) * 4
            if idx + 3 < src.pixels.len() as i64:
                val sr = (src.pixels[idx] as f64) / 255.0
                val sg = (src.pixels[idx + 1] as f64) / 255.0
                val sb = (src.pixels[idx + 2] as f64) / 255.0
                val sa = (src.pixels[idx + 3] as f64) / 255.0
                val src_color = SkColor4f(r: sr, g: sg, b: sb, a: sa)
                val dr = (dst.pixels[idx] as f64) / 255.0
                val dg = (dst.pixels[idx + 1] as f64) / 255.0
                val db = (dst.pixels[idx + 2] as f64) / 255.0
                val da = (dst.pixels[idx + 3] as f64) / 255.0
                val dst_color = SkColor4f(r: dr, g: dg, b: db, a: da)
                val result = apply_blend(src_color, dst_color, SkBlendMode.SrcOver)
                val ri = (result.r * 255.0) as u8
                val gi = (result.g * 255.0) as u8
                val bi = (result.b * 255.0) as u8
                val ai = (result.a * 255.0) as u8
                dst.pixels[idx]     = ri
                dst.pixels[idx + 1] = gi
                dst.pixels[idx + 2] = bi
                dst.pixels[idx + 3] = ai
            x = x + 1
        y = y + 1

# compose_paint_graph recursively decodes the paint-graph subtree starting at
# paint_offset and rasterizes it into a Bitmap sized by context.bounds.
fn compose_paint_graph(blob: [u8], paint_offset: u32, context: PaintGraphContext) -> Bitmap:
    val w = (context.bounds.right - context.bounds.left) as i64
    val h = (context.bounds.bottom - context.bounds.top) as i64
    val bw = if w > 0: w else: 1 as i64
    val bh = if h > 0: h else: 1 as i64

    # Out-of-bounds offset: return transparent bitmap without crashing
    if paint_offset as i64 >= blob.len() as i64:
        return Bitmap.zeros(bw, bh)

    val maybe_node = decode_paint_subtable(blob, paint_offset)
    if maybe_node == None:
        return Bitmap.zeros(bw, bh)

    val node = maybe_node.unwrap()
    val out = Bitmap.zeros(bw, bh)

    if node.kind == PaintKind.Solid:
        # Fill entire bounds with the palette color, alpha-scaled by alpha_fixed/0x4000
        val alpha_scale = node.alpha_fixed.to_f64() / 16384.0
        val pal_count = context.palette.len() as i64
        val pal_idx = node.palette_index as i64
        val base_color = if pal_count > 0 and pal_idx < pal_count:
            _sk_color_to_color4f(context.palette[pal_idx])
        else:
            SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
        val fill_color = SkColor4f(
            r: base_color.r,
            g: base_color.g,
            b: base_color.b,
            a: base_color.a * alpha_scale
        )
        var py = 0 as i64
        while py < bh:
            var px = 0 as i64
            while px < bw:
                val idx = (py * bw + px) * 4
                out.pixels[idx]     = (fill_color.r * 255.0) as u8
                out.pixels[idx + 1] = (fill_color.g * 255.0) as u8
                out.pixels[idx + 2] = (fill_color.b * 255.0) as u8
                out.pixels[idx + 3] = (fill_color.a * 255.0) as u8
                px = px + 1
            py = py + 1
        out

    else if node.kind == PaintKind.ColrLayers:
        # Read num_layers (u8) and first_layer_index (u32) from the record.
        # Format 11: [format_byte(1)] [num_layers(1)] [first_layer_index(4)]
        val off = paint_offset as i64
        if off + 6 > blob.len() as i64:
            return out
        val num_layers = blob[off + 1] as i64
        val first_layer_idx = read_u32_be(blob, off + 2) as i64
        # Layer offsets are stored in a separate layer offsets table.
        # For our purposes: each layer entry in blob is a 4-byte paint offset
        # stored sequentially starting at a LayerList table.
        # Since decode_paint_subtable already decoded the layer record,
        # we read sequential child paint offsets from the blob at first_layer_idx.
        # In a real COLR table the layer list index is into the LayerList array.
        # We treat the blob entries at (first_layer_idx * 4) as sequential u32 offsets.
        # This is a reasonable structural interpretation for the stub-advance pass.
        var layer_i = 0 as i64
        while layer_i < num_layers:
            val entry_off = (first_layer_idx + layer_i) * 4
            if entry_off + 4 <= blob.len() as i64:
                val child_offset = read_u32_be(blob, entry_off)
                val child_bmp = compose_paint_graph(blob, child_offset, context)
                _bitmap_blend_over(out, child_bmp)
            layer_i = layer_i + 1
        out

    else if node.kind == PaintKind.Composite:
        # Format 32: [format(1)] [source_paint_offset(4)] [composite_mode(1)] [backdrop_paint_offset(4)]
        val off = paint_offset as i64
        if off + 10 > blob.len() as i64:
            return out
        val src_offset = read_u32_be(blob, off + 1)
        val mode_byte = blob[off + 5] as i64
        val backdrop_offset = read_u32_be(blob, off + 6)
        val backdrop_bmp = compose_paint_graph(blob, backdrop_offset, context)
        val src_bmp = compose_paint_graph(blob, src_offset, context)
        # Map COLRv1 CompositeMode byte to SkBlendMode (spec §COLRv1 CompositeMode)
        val mode = if mode_byte == 3: SkBlendMode.SrcOver
            else if mode_byte == 4: SkBlendMode.DstOver
            else if mode_byte == 5: SkBlendMode.SrcIn
            else if mode_byte == 6: SkBlendMode.DstIn
            else if mode_byte == 7: SkBlendMode.SrcOut
            else if mode_byte == 8: SkBlendMode.DstOut
            else if mode_byte == 9: SkBlendMode.SrcATop
            else if mode_byte == 10: SkBlendMode.DstATop
            else if mode_byte == 11: SkBlendMode.Xor
            else if mode_byte == 14: SkBlendMode.Multiply
            else if mode_byte == 15: SkBlendMode.Screen
            else if mode_byte == 16: SkBlendMode.Overlay
            else if mode_byte == 17: SkBlendMode.Darken
            else if mode_byte == 18: SkBlendMode.Lighten
            else if mode_byte == 21: SkBlendMode.ColorDodge
            else if mode_byte == 22: SkBlendMode.ColorBurn
            else if mode_byte == 23: SkBlendMode.HardLight
            else if mode_byte == 24: SkBlendMode.SoftLight
            else if mode_byte == 25: SkBlendMode.Difference
            else if mode_byte == 26: SkBlendMode.Exclusion
            else: SkBlendMode.SrcOver
        # Merge src over backdrop using the specified blend mode
        var cy = 0 as i64
        while cy < bh:
            var cx = 0 as i64
            while cx < bw:
                val idx = (cy * bw + cx) * 4
                val valid_src = idx + 3 < src_bmp.pixels.len() as i64
                val valid_bd = idx + 3 < backdrop_bmp.pixels.len() as i64
                val src_c = if valid_src:
                    SkColor4f(
                        r: (src_bmp.pixels[idx] as f64) / 255.0,
                        g: (src_bmp.pixels[idx + 1] as f64) / 255.0,
                        b: (src_bmp.pixels[idx + 2] as f64) / 255.0,
                        a: (src_bmp.pixels[idx + 3] as f64) / 255.0
                    )
                else:
                    SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
                val bd_c = if valid_bd:
                    SkColor4f(
                        r: (backdrop_bmp.pixels[idx] as f64) / 255.0,
                        g: (backdrop_bmp.pixels[idx + 1] as f64) / 255.0,
                        b: (backdrop_bmp.pixels[idx + 2] as f64) / 255.0,
                        a: (backdrop_bmp.pixels[idx + 3] as f64) / 255.0
                    )
                else:
                    SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
                val result = apply_blend(src_c, bd_c, mode)
                out.pixels[idx]     = (result.r * 255.0) as u8
                out.pixels[idx + 1] = (result.g * 255.0) as u8
                out.pixels[idx + 2] = (result.b * 255.0) as u8
                out.pixels[idx + 3] = (result.a * 255.0) as u8
                cx = cx + 1
            cy = cy + 1
        out

    else if node.kind == PaintKind.LinearGradient:
        # pass_todo: build SkShader from COLRv1 color-line and geometry fields,
        # then call eval_linear_gradient per pixel. Currently returns transparent.
        out

    else if node.kind == PaintKind.RadialGradient:
        # pass_todo: build SkShader from COLRv1 radial parameters,
        # then call eval_radial_gradient per pixel. Currently returns transparent.
        out

    else if node.kind == PaintKind.SweepGradient:
        # pass_todo: build SkShader from COLRv1 sweep parameters,
        # then call eval_sweep_gradient per pixel. Currently returns transparent.
        out

    else if node.kind == PaintKind.Glyph:
        # pass_todo: rasterize glyph outline via rasterize_outline and use as
        # alpha mask over recursive child paint. Currently returns transparent.
        out

    else if node.kind == PaintKind.Transform or node.kind == PaintKind.Translate or node.kind == PaintKind.Rotate or node.kind == PaintKind.Scale or node.kind == PaintKind.Skew:
        # pass_todo: apply Matrix3x3 to child bitmap sampling coords and recurse.
        # Currently returns transparent.
        out

    else:
        # Unknown/unreachable kind — return transparent bitmap
        # pass_todo: handle any future PaintKind variants
        out
