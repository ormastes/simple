# Glyph outline type and stub box outline builder

use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.geometry.{SkRect}

class GlyphMetrics:
    advance_x: f64
    advance_y: f64
    bounds: SkRect

class GlyphOutline:
    glyph_id: u32
    path: SkPath
    metrics: GlyphMetrics

fn stub_box_outline(glyph_id: u32, width: f64, height: f64) -> GlyphOutline:
    # TODO(skia-glyph): replace with TTF/OTF parser in Phase 3 final.
    val bounds = SkRect(left: 0.0, top: 0.0, right: width, bottom: height)
    val p0 = sk_path_new()
    val p1 = p0.move_to(0.0, 0.0)
    val p2 = p1.line_to(width, 0.0)
    val p3 = p2.line_to(width, height)
    val p4 = p3.line_to(0.0, height)
    val path = p4.close()
    val metrics = GlyphMetrics(advance_x: width, advance_y: 0.0, bounds: bounds)
    GlyphOutline(glyph_id: glyph_id, path: path, metrics: metrics)
