# Compatibility surface for callers that have not migrated to common sfnt cmap.

export use std.common.encoding.sfnt_cmap.{CmapFormat4, CmapFormat12, parse_cmap_format4, parse_cmap_format12, cmap_lookup, cmap12_lookup}
use std.common.encoding.sfnt.{OtFont}
use std.common.encoding.sfnt_cmap.{sfnt_cmap_glyph_id}

fn cmap_glyph_id(font: OtFont, codepoint: u32) -> u32:
    sfnt_cmap_glyph_id(font, codepoint)
