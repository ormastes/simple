# Skia compatibility adapter over the neutral sfnt glyf owner.

use std.common.encoding.sfnt.{OtFont}
use std.common.encoding.sfnt_glyf.{SFNT_GLYF_MOVE, SFNT_GLYF_LINE, SFNT_GLYF_QUAD, SFNT_GLYF_CLOSE, SfntGlyfCommand, parse_sfnt_glyf_outline, parse_sfnt_glyf_simple_at, rasterize_sfnt_glyf}
use std.skia.entity.path.{SkPath, sk_path_new}

class GlyfRasterBitmap:
    width: i64
    height: i64
    advance: i64
    bearing_x: i64
    bearing_y: i64
    pixels: [u8]

fn _commands_path(commands: [SfntGlyfCommand]) -> Option<SkPath>:
    var path = sk_path_new()
    for command in commands:
        if command.verb == SFNT_GLYF_MOVE:
            path = path.move_to(command.x1, command.y1)
        elif command.verb == SFNT_GLYF_LINE:
            path = path.line_to(command.x1, command.y1)
        elif command.verb == SFNT_GLYF_QUAD:
            path = path.quad_to(command.x1, command.y1, command.x2, command.y2)
        elif command.verb == SFNT_GLYF_CLOSE:
            path = path.close()
        else:
            return None
    Some(path)

fn parse_glyf_outline(font: OtFont, glyph_id: u32) -> Option<SkPath>:
    val outline = parse_sfnt_glyf_outline(font, glyph_id)
    if outline == None: return None
    _commands_path(outline.unwrap().commands)

fn rasterize_glyf_bitmap(font: OtFont, glyph_id: u32, size_px: i64) -> Option<GlyfRasterBitmap>:
    val bitmap = rasterize_sfnt_glyf(font, glyph_id, size_px)
    if bitmap == None: return None
    val value = bitmap.unwrap()
    Some(GlyfRasterBitmap(width: value.width, height: value.height,
        advance: value.advance, bearing_x: value.bearing_x,
        bearing_y: value.bearing_y, pixels: value.pixels))

# Deprecated offset entry point retained for source compatibility.
fn parse_glyf_simple(font: OtFont, glyph_offset: u32) -> Option<SkPath>:
    val outline = parse_sfnt_glyf_simple_at(font, glyph_offset)
    if outline == None: return None
    _commands_path(outline.unwrap().commands)

fn parse_glyf_compound(font: OtFont, glyph_offset: u32) -> Option<SkPath>:
    nil
