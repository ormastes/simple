# Bounded dev2 shaping for the pinned Hindi acceptance witness.

use std.skia.feature.glyph.ot_parser.{OtFont, read_u16_be, read_i16_be}
use std.skia.feature.glyph.ot_parser_cmap.{cmap_glyph_id}
use std.skia.feature.glyph.ot_parser_layout.{GsubLookup, GposLookup, parse_gsub_skeleton, select_gsub_lookups, select_gpos_lookups}
use std.skia.feature.shaper.selected_complex.{selected_glyph_advance, selected_units_per_em}

class SelectedDevanagariGlyph:
    glyph_id: u32
    source_index: i64
    cluster: i64
    x_advance: f64
    matra: bool

fn _devanagari_coverage_index(blob: [u8], coverage: i64, limit: i64, glyph: u32) -> i64:
    if coverage < 0 or coverage + 4 > limit: return -1
    val format = read_u16_be(blob, coverage)
    val count = read_u16_be(blob, coverage + 2) as i64
    if format == 1u32:
        if coverage + 4 + count * 2 > limit: return -1
        var index: i64 = 0
        while index < count:
            if read_u16_be(blob, coverage + 4 + index * 2) == glyph: return index
            index = index + 1
        return -1
    if format == 2u32:
        if coverage + 4 + count * 6 > limit: return -1
        var index: i64 = 0
        while index < count:
            val range = coverage + 4 + index * 6
            val first = read_u16_be(blob, range)
            val last = read_u16_be(blob, range + 2)
            if first > last: return -1
            if glyph >= first and glyph <= last:
                return read_u16_be(blob, range + 4) as i64 + glyph as i64 - first as i64
            index = index + 1
    -1

fn _devanagari_single(font: OtFont, lookup: GsubLookup, glyph: u32) -> (u32, bool):
    if lookup.lookup_type != 1u32: return (glyph, false)
    for offset in lookup.subtable_offsets:
        val subtable = offset as i64
        val limit = lookup.table_end as i64
        if subtable + 6 > limit: continue
        val format = read_u16_be(font.blob, subtable)
        val covered = _devanagari_coverage_index(font.blob, subtable + read_u16_be(font.blob, subtable + 2) as i64, limit, glyph)
        if covered < 0: continue
        if format == 1u32:
            return (((glyph as i64 + read_i16_be(font.blob, subtable + 4) as i64) & 65535) as u32, true)
        if format == 2u32:
            val count = read_u16_be(font.blob, subtable + 4) as i64
            if covered < count and subtable + 6 + count * 2 <= limit:
                return (read_u16_be(font.blob, subtable + 6 + covered * 2), true)
    (glyph, false)

fn _context_single(font: OtFont, active: [GsubLookup], catalog: [GsubLookup],
                   glyph: u32, next: u32) -> (u32, bool):
    for lookup in active:
        if lookup.lookup_type != 6u32: continue
        for offset in lookup.subtable_offsets:
            val subtable = offset as i64
            val limit = lookup.table_end as i64
            if subtable + 14 > limit or read_u16_be(font.blob, subtable) != 3u32: continue
            var cursor = subtable + 2
            val backtracks = read_u16_be(font.blob, cursor) as i64
            cursor = cursor + 2 + backtracks * 2
            if backtracks != 0 or cursor + 4 > limit or read_u16_be(font.blob, cursor) != 1u32: continue
            cursor = cursor + 2
            if _devanagari_coverage_index(font.blob, subtable + read_u16_be(font.blob, cursor) as i64, limit, glyph) < 0: continue
            cursor = cursor + 2
            if cursor + 4 > limit or read_u16_be(font.blob, cursor) != 1u32: continue
            cursor = cursor + 2
            if _devanagari_coverage_index(font.blob, subtable + read_u16_be(font.blob, cursor) as i64, limit, next) < 0: continue
            cursor = cursor + 2
            if cursor + 6 > limit or read_u16_be(font.blob, cursor) != 1u32: continue
            cursor = cursor + 2
            val sequence = read_u16_be(font.blob, cursor)
            val target = read_u16_be(font.blob, cursor + 2) as i64
            if sequence == 0u32 and target >= 0 and target < catalog.len():
                val applied = _devanagari_single(font, catalog[target], glyph)
                if applied.1: return applied
    (glyph, false)

fn _ligature_pair(font: OtFont, active: [GsubLookup], first: u32, second: u32) -> (u32, bool):
    for lookup in active:
        if lookup.lookup_type != 4u32: continue
        for offset in lookup.subtable_offsets:
            val subtable = offset as i64
            val limit = lookup.table_end as i64
            if subtable + 8 > limit or read_u16_be(font.blob, subtable) != 1u32: continue
            val covered = _devanagari_coverage_index(font.blob, subtable + read_u16_be(font.blob, subtable + 2) as i64, limit, first)
            val set_count = read_u16_be(font.blob, subtable + 4) as i64
            if covered < 0 or covered >= set_count or subtable + 6 + set_count * 2 > limit: continue
            val set_offset = read_u16_be(font.blob, subtable + 6 + covered * 2) as i64
            val set = subtable + set_offset
            if set_offset == 0 or set + 2 > limit: continue
            val count = read_u16_be(font.blob, set) as i64
            if set + 2 + count * 2 > limit: continue
            var index: i64 = 0
            while index < count:
                val ligature = set + read_u16_be(font.blob, set + 2 + index * 2) as i64
                if ligature + 6 <= limit and read_u16_be(font.blob, ligature + 2) == 2u32 and read_u16_be(font.blob, ligature + 4) == second:
                    return (read_u16_be(font.blob, ligature), true)
                index = index + 1
    (first, false)

fn _record_size(format: u32) -> i64:
    var size: i64 = 0
    var bit = 1u32
    while bit <= 32768u32:
        if (format & bit) != 0u32: size = size + 2
        bit = bit << 1
    size

fn _x_advance(blob: [u8], offset: i64, format: u32) -> i64:
    var cursor = offset
    if (format & 1u32) != 0u32: cursor = cursor + 2
    if (format & 2u32) != 0u32: cursor = cursor + 2
    if (format & 4u32) != 0u32: return read_i16_be(blob, cursor) as i64
    0

fn _class(blob: [u8], offset: i64, limit: i64, glyph: u32) -> i64:
    if offset < 0 or offset + 4 > limit: return -1
    val format = read_u16_be(blob, offset)
    if format == 1u32:
        if offset + 6 > limit: return -1
        val first = read_u16_be(blob, offset + 2)
        val count = read_u16_be(blob, offset + 4) as i64
        if glyph < first or glyph as i64 >= first as i64 + count: return 0
        if offset + 6 + count * 2 > limit: return -1
        return read_u16_be(blob, offset + 6 + (glyph - first) as i64 * 2) as i64
    if format == 2u32:
        val count = read_u16_be(blob, offset + 2) as i64
        if offset + 4 + count * 6 > limit: return -1
        var index: i64 = 0
        while index < count:
            val range = offset + 4 + index * 6
            if glyph >= read_u16_be(blob, range) and glyph <= read_u16_be(blob, range + 2):
                return read_u16_be(blob, range + 4) as i64
            index = index + 1
        return 0
    -1

fn _pair_adjustment(font: OtFont, active: [GposLookup], first: u32, second: u32) -> (i64, bool):
    for lookup in active:
        if lookup.lookup_type != 2u32: continue
        val limit = lookup.table_end as i64
        for offset in lookup.subtable_offsets:
            val subtable = offset as i64
            if subtable + 16 > limit or read_u16_be(font.blob, subtable) != 2u32: continue
            val coverage = subtable + read_u16_be(font.blob, subtable + 2) as i64
            if _devanagari_coverage_index(font.blob, coverage, limit, first) < 0: continue
            val format_1 = read_u16_be(font.blob, subtable + 4)
            val format_2 = read_u16_be(font.blob, subtable + 6)
            val class_1 = _class(font.blob, subtable + read_u16_be(font.blob, subtable + 8) as i64, limit, first)
            val class_2 = _class(font.blob, subtable + read_u16_be(font.blob, subtable + 10) as i64, limit, second)
            val count_1 = read_u16_be(font.blob, subtable + 12) as i64
            val count_2 = read_u16_be(font.blob, subtable + 14) as i64
            val size = _record_size(format_1) + _record_size(format_2)
            if class_1 < 0 or class_1 >= count_1 or class_2 < 0 or class_2 >= count_2 or subtable + 16 + count_1 * count_2 * size > limit: continue
            val adjustment = _x_advance(font.blob, subtable + 16 + (class_1 * count_2 + class_2) * size, format_1)
            if adjustment != 0: return (adjustment, true)
    (0, false)

fn selected_devanagari_glyphs(codepoints: [u32], start: i64, end_idx: i64,
                              font: Option<OtFont>, size: f64) -> [SelectedDevanagariGlyph]:
    # This is deliberately one pinned dev2 witness, not general Indic shaping.
    if start < 0 or end_idx > codepoints.len() or end_idx - start != 6: return []
    if (codepoints[start] != 2361u32 or codepoints[start + 1] != 2367u32 or
        codepoints[start + 2] != 2344u32 or codepoints[start + 3] != 2381u32 or
        codepoints[start + 4] != 2342u32 or codepoints[start + 5] != 2368u32): return []
    val parsed = match font:
        Some(value): value
        None: return []
    # Indic default feature application order. LangSys indices only advertise
    # availability; discretionary aalt/ordn and mark/mkmk remain inactive.
    # GSUB: locl ccmp nukt akhn rphf rkrf pref blwf half abvf pstf vatu cjct
    #       init pres abvs blws psts haln calt
    val active_gsub = select_gsub_lookups(parsed, 1684370994u32, 1212763680u32, [
        1819239276u32, 1667460464u32, 1853188980u32, 1634429038u32,
        1919969382u32, 1919644262u32, 1886545254u32, 1651275622u32,
        1751215206u32, 1633842790u32, 1886614630u32, 1986098293u32,
        1667916660u32, 1768843636u32, 1886545267u32, 1633842803u32,
        1651275635u32, 1886614643u32, 1751215214u32, 1667329140u32
    ])
    # GPOS: abvm blwm dist kern
    val active_gpos = select_gpos_lookups(parsed, 1684370994u32, 1212763680u32,
        [1633842797u32, 1651275629u32, 1684632436u32, 1801810542u32])
    val catalog = parse_gsub_skeleton(parsed)
    if active_gsub.len() == 0 or active_gpos.len() == 0 or catalog.len() == 0: return []
    var nominal: [u32] = []
    var index = start
    while index < end_idx:
        val glyph = cmap_glyph_id(parsed, codepoints[index])
        if glyph == 0u32: return []
        nominal.push(glyph)
        index = index + 1
    val prebase = _context_single(parsed, active_gsub, catalog, nominal[1], nominal[0])
    val half = _ligature_pair(parsed, active_gsub, nominal[2], nominal[3])
    val adjustment = _pair_adjustment(parsed, active_gpos, half.0, nominal[4])
    val units = match selected_units_per_em(parsed):
        Some(value): value
        None: return []
    if not prebase.1 or not half.1 or not adjustment.1: return []
    val half_advance = selected_glyph_advance(font, half.0, size) + adjustment.0 as f64 * size / units as f64
    [
        SelectedDevanagariGlyph(glyph_id: prebase.0, source_index: start + 1, cluster: start, x_advance: selected_glyph_advance(font, prebase.0, size), matra: true),
        SelectedDevanagariGlyph(glyph_id: nominal[0], source_index: start, cluster: start, x_advance: selected_glyph_advance(font, nominal[0], size), matra: false),
        SelectedDevanagariGlyph(glyph_id: half.0, source_index: start + 2, cluster: start + 2, x_advance: half_advance, matra: false),
        SelectedDevanagariGlyph(glyph_id: nominal[4], source_index: start + 4, cluster: start + 4, x_advance: selected_glyph_advance(font, nominal[4], size), matra: false),
        SelectedDevanagariGlyph(glyph_id: nominal[5], source_index: start + 5, cluster: start + 4, x_advance: selected_glyph_advance(font, nominal[5], size), matra: true)
    ]

export SelectedDevanagariGlyph, selected_devanagari_glyphs
