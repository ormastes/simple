# Unicode script detection for text shaping

enum Script:
    Common
    Inherited
    Latin
    Cyrillic
    Arabic
    Hebrew
    Devanagari
    Bengali
    Thai
    CJK
    Emoji
    Unknown

fn script_of(codepoint: u32) -> Script:
    # ASCII letters are Latin; digits, whitespace, controls, and punctuation
    # are Common and inherit the surrounding strong script.
    if ((codepoint >= 65 and codepoint <= 90) or
        (codepoint >= 97 and codepoint <= 122)):
        Script.Latin
    else if codepoint <= 127:
        Script.Common
    # Combining Diacritical Marks inherit the surrounding strong script.
    else if ((codepoint >= 768 and codepoint <= 879) or
            (codepoint >= 6832 and codepoint <= 6911) or
            (codepoint >= 7616 and codepoint <= 7679) or
            (codepoint >= 8400 and codepoint <= 8447) or
            (codepoint >= 65024 and codepoint <= 65039) or
            (codepoint >= 65056 and codepoint <= 65071) or
            (codepoint >= 917760 and codepoint <= 917999)):
        Script.Inherited
    # Join controls are Common and resolve with their surrounding run.
    else if codepoint == 8204 or codepoint == 8205:
        Script.Common
    # Latin-1 letters, Latin Extended-A/B, and Latin Extended Additional.
    else if ((codepoint >= 192 and codepoint <= 214) or
            (codepoint >= 216 and codepoint <= 246) or
            (codepoint >= 248 and codepoint <= 591) or
            (codepoint >= 7680 and codepoint <= 7935)):
        Script.Latin
    # U+0400-052F Cyrillic and Cyrillic Supplement
    else if codepoint >= 1024 and codepoint <= 1327:
        Script.Cyrillic
    # U+0590-05FF Hebrew
    else if codepoint >= 1424 and codepoint <= 1535:
        Script.Hebrew
    # Arabic, Arabic Supplement, Extended-A/B, and presentation forms
    else if ((codepoint >= 1536 and codepoint <= 1791) or
            (codepoint >= 1872 and codepoint <= 1919) or
            (codepoint >= 2160 and codepoint <= 2303) or
            (codepoint >= 64336 and codepoint <= 65023) or
            (codepoint >= 65136 and codepoint <= 65279)):
        Script.Arabic
    # U+0900-097F Devanagari
    else if codepoint >= 2304 and codepoint <= 2431:
        Script.Devanagari
    # U+0980-09FF Bengali
    else if codepoint >= 2432 and codepoint <= 2559:
        Script.Bengali
    # U+0E00-0E7F Thai
    else if codepoint >= 3584 and codepoint <= 3711:
        Script.Thai
    # U+4E00-9FFF CJK Unified Ideographs
    else if codepoint >= 19968 and codepoint <= 40959:
        Script.CJK
    # U+1F300-1F9FF Emoji
    else if codepoint >= 127744 and codepoint <= 129535:
        Script.Emoji
    else:
        Script.Unknown

fn script_is_rtl(s: Script) -> bool:
    if s == Script.Arabic:
        true
    else if s == Script.Hebrew:
        true
    else:
        false
