# Bounded Arabic/Urdu letter shaping helpers for pinned acceptance witnesses.

use std.skia.feature.glyph.ot_parser.{OtFont, find_table, read_u16_be}
use std.skia.feature.glyph.ot_parser_metrics.{HorizontalMetrics, parse_hmtx}

fn selected_arabic_presentation_codepoint(cp: u32, form: i32) -> u32:
    if cp == 1575u32:
        if form == 3: return 65166u32
        if form == 0: return 65165u32
        return 0u32
    if cp == 1576u32:
        if form == 0: return 65167u32
        if form == 3: return 65168u32
        if form == 1: return 65169u32
        return 65170u32
    if cp == 1577u32:
        if form == 3: return 65172u32
        if form == 0: return 65171u32
        return 0u32
    if cp == 1583u32:
        if form == 3: return 65194u32
        if form == 0: return 65193u32
        return 0u32
    if cp == 1585u32:
        if form == 3: return 65198u32
        if form == 0: return 65197u32
        return 0u32
    if cp == 1593u32:
        if form == 0: return 65225u32
        if form == 3: return 65226u32
        if form == 1: return 65227u32
        return 65228u32
    if cp == 1604u32:
        if form == 0: return 65245u32
        if form == 3: return 65246u32
        if form == 1: return 65247u32
        return 65248u32
    if cp == 1608u32:
        if form == 3: return 65262u32
        if form == 0: return 65261u32
        return 0u32
    if cp == 1610u32:
        if form == 0: return 65265u32
        if form == 3: return 65266u32
        if form == 1: return 65267u32
        return 65268u32
    0u32

fn selected_bounded_hmtx(font: OtFont, glyph_id: u32) -> Option<HorizontalMetrics>:
    val hhea = match find_table(font, 1751672161u32):
        Some(table): table
        None: return None
    if hhea.length < 36u32: return None
    val count = read_u16_be(font.blob, hhea.offset as i64 + 34)
    if count == 0u32: return None
    val hmtx = match find_table(font, 1752003704u32):
        Some(table): table
        None: return None
    val required = if glyph_id < count: glyph_id as i64 * 4 + 4 else: count as i64 * 4 + (glyph_id - count) as i64 * 2 + 2
    if required > hmtx.length as i64: return None
    parse_hmtx(font, count, glyph_id)

fn selected_units_per_em(font: OtFont) -> Option<u32>:
    val head = match find_table(font, 1751474532u32):
        Some(table): table
        None: return None
    if head.length < 20u32: return None
    val units = read_u16_be(font.blob, head.offset as i64 + 18)
    if units == 0u32: None else: Some(units)

fn selected_hmtx_advance(font: OtFont, glyph_id: u32, font_size: f64) -> Option<f64>:
    val metrics = match selected_bounded_hmtx(font, glyph_id):
        Some(value): value
        None: return None
    val units = match selected_units_per_em(font):
        Some(value): value
        None: return None
    val advance = metrics.advance_width as f64 * font_size / units as f64
    if advance != advance or advance - advance != 0.0 or advance < 0.0: None else: Some(advance)

fn selected_glyph_advance(font: Option<OtFont>, glyph_id: u32, font_size: f64) -> f64:
    match font:
        case Some(value):
            match selected_hmtx_advance(value, glyph_id, font_size):
                case Some(advance): advance
                case None: font_size * 0.6
        case None: font_size * 0.6

export selected_arabic_presentation_codepoint, selected_bounded_hmtx
export selected_units_per_em, selected_hmtx_advance, selected_glyph_advance
