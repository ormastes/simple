# Path effect feature module.
#
# Re-exports SkCornerPathEffect- and SkDiscretePathEffect-like helpers that
# operate directly on SkPath values, producing a new transformed SkPath.
#
# ============================================================================
# Overview
# ============================================================================
#
# SkCornerPathEffect rounds each sharp corner of an input path into a short
# circular-ish arc. This module exposes it as:
#
#   apply_corner_path_effect(input: SkPath, params: CornerPathEffectParams)
#     -> SkPath
#
# where CornerPathEffectParams carries a single `radius` field. A radius of
# zero short-circuits to the flattened input polyline.
#
# SkDiscretePathEffect breaks the path into short fixed-length line segments
# and displaces each segment endpoint perpendicular to the local direction
# using a deterministic LCG seeded by `seed`. Exposed as:
#
#   apply_discrete_path_effect(input: SkPath, params: DiscretePathEffectParams)
#     -> SkPath
#
# where DiscretePathEffectParams carries `length`, `deviation`, `seed`.
#
# Both functions flatten curves internally (quad/cubic/conic -> 16 line
# chords) before applying the effect. Output is a plain line-segment SkPath.

use std.skia.feature.path_effect.corner_discrete.{
    CornerPathEffectParams,
    DiscretePathEffectParams,
    corner_path_effect_params_new,
    discrete_path_effect_params_new,
    apply_corner_path_effect,
    apply_discrete_path_effect
}
