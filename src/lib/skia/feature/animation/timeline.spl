# timeline.spl — Tick-driven animation timeline.
#
# A minimal, deterministic timeline for progress bars and transitions: it maps
# injected elapsed time to an eased value between two endpoints. Time is always
# supplied by the caller (no wall clock) so playback is reproducible in specs.
#
# Reuses the existing easing/interpolation primitives in interpolate.spl
# (linear + cubic-bezier ease-in/out + lerp) rather than reimplementing them.

use std.skia.feature.animation.interpolate.{
    EasingKind,
    ease_linear,
    apply_easing,
    lerp_f64,
    clamp_unit
}

struct Timeline:
    from_value: f64
    to_value: f64
    duration_ms: f64
    easing: EasingKind

fn timeline_new(from_value: f64, to_value: f64, duration_ms: f64, easing: EasingKind) -> Timeline:
    Timeline(from_value: from_value, to_value: to_value, duration_ms: duration_ms, easing: easing)

# Normalized progress t in [0, 1] at `elapsed_ms`.
fn timeline_progress(tl: Timeline, elapsed_ms: f64) -> f64:
    if tl.duration_ms <= 0.0:
        return 1.0
    clamp_unit(elapsed_ms / tl.duration_ms)

# Eased value at `elapsed_ms`. Monotonic in elapsed_ms for the supported
# easings (linear + ease-in/out), so successive ticks never regress.
fn timeline_value_at(tl: Timeline, elapsed_ms: f64) -> f64:
    val t = timeline_progress(tl, elapsed_ms)
    val eased = apply_easing(tl.easing, t, ease_linear())
    lerp_f64(tl.from_value, tl.to_value, eased)

fn timeline_done(tl: Timeline, elapsed_ms: f64) -> bool:
    elapsed_ms >= tl.duration_ms

export Timeline, timeline_new, timeline_progress, timeline_value_at, timeline_done
