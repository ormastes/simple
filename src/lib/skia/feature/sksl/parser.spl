# SkSL parser — token stream → simple AST.
#
# Mirrors Skia's SkSL::Parser, minimal subset:
#   - Top-level: uniform declarations, function definitions
#   - Function body: variable declarations, assignments, return, expression statements
#   - Expressions: literals, identifiers, binary ops (+ - * / < > ==), function calls
#
# Full SkSL (control flow, structs, intrinsics, matrix types) is out of scope.

use std.skia.feature.sksl.tokenizer.{TokenKind, Token}

# ============================================================================
# AstNodeKind — variant tag for each AST node type.
# ============================================================================

enum AstNodeKind:
    Uniform
    Function
    ReturnStmt
    ExpressionStmt
    VarDecl
    Assign
    BinaryOp
    UnaryOp
    Call
    IntLit
    FloatLit
    Identifier
    Invalid

# ============================================================================
# AstNode — one node in the SkSL AST.
#
# WHY a single class with a `kind` tag rather than a sum type: the SkSL
# subset we parse is small, and a uniform shape keeps downstream walks
# (codegen, lint) simple. A sealed hierarchy can replace this later if the
# AST fans out.
# ============================================================================

class AstNode:
    kind: AstNodeKind
    text: String
    type_name: String
    children: [AstNode]
    int_value: i64
    float_value: f64

# ============================================================================
# ParseResult — output of parse_sksl.
#
# `ast` holds the top-level declaration nodes. `errors` collects one
# human-readable string per syntax error; an empty list means a clean
# parse.
# ============================================================================

class ParseResult:
    ast: [AstNode]
    errors: [String]

# ============================================================================
# _ast_node_leaf — construct a childless AST node with just a text label.
# ============================================================================

fn _ast_node_leaf(kind: AstNodeKind, text: String) -> AstNode:
    val kids: [AstNode] = []
    AstNode(
        kind: kind,
        text: text,
        type_name: "",
        children: kids,
        int_value: 0,
        float_value: 0.0
    )

# ============================================================================
# _ast_node_int — build an IntLit node from a parsed i64.
# ============================================================================

fn _ast_node_int(value: i64) -> AstNode:
    val kids: [AstNode] = []
    AstNode(
        kind: AstNodeKind.IntLit,
        text: "",
        type_name: "",
        children: kids,
        int_value: value,
        float_value: 0.0
    )

# ============================================================================
# _ast_node_float — build a FloatLit node from a parsed f64.
# ============================================================================

fn _ast_node_float(value: f64) -> AstNode:
    val kids: [AstNode] = []
    AstNode(
        kind: AstNodeKind.FloatLit,
        text: "",
        type_name: "",
        children: kids,
        int_value: 0,
        float_value: value
    )

# ============================================================================
# _eof_token — construct a synthetic EOF token used when _peek runs OOB.
#
# WHY synthesize: returning an Option at every peek would bury the parser
# logic in match ladders. An EOF sentinel cannot collide with any real
# lexeme (the tokenizer only emits one, as the last token), so any
# predicate that compares against Keyword/Identifier naturally rejects it.
# ============================================================================

fn _eof_token() -> Token:
    Token(kind: TokenKind.Eof, text: "", line: 0, column: 0)

# ============================================================================
# _peek — returns tokens[pos], or an EOF sentinel on out-of-range access.
# ============================================================================

fn _peek(tokens: [Token], pos: i64) -> Token:
    if pos < 0 or pos >= tokens.len():
        return _eof_token()
    tokens[pos]

# ============================================================================
# _accept — true iff tokens[pos] matches both kind and text.
# ============================================================================

fn _accept(tokens: [Token], pos: i64, kind: TokenKind, text: String) -> bool:
    val t = _peek(tokens, pos)
    t.kind == kind and t.text == text

# ============================================================================
# _is_type_keyword — SkSL type keywords we accept at decl position.
# ============================================================================

fn _is_type_keyword(text: String) -> bool:
    text == "void" or text == "float" or text == "int" or text == "bool" or text == "vec2" or text == "vec3" or text == "vec4"

# ============================================================================
# _parse_int — decimal string → i64. Returns 0 on empty input.
#
# WHY a bespoke parser: the standard library's i64 parse isn't available
# from this module in bootstrap mode; SkSL int literals are plain decimals
# so a digit-by-digit loop suffices.
# ============================================================================

fn _parse_int(text: String) -> i64:
    val bytes = text.bytes()
    val n = bytes.length()
    var i = 0
    var v: i64 = 0
    while i < n:
        val opt = bytes.at(i)
        match opt:
            Some(b):
                val c = b as i64
                if c >= 48 and c <= 57:
                    v = v * 10 + (c - 48)
            None:
                pass_do_nothing
        i = i + 1
    v

# ============================================================================
# _parse_float — simple decimal float parser for `<int>.<frac>` form.
#
# WHY: see _parse_int. Exponent forms are not emitted by tokenize_sksl in
# the current minimal grammar.
# ============================================================================

fn _parse_float(text: String) -> f64:
    val bytes = text.bytes()
    val n = bytes.length()
    var i = 0
    var int_part: f64 = 0.0
    var frac_part: f64 = 0.0
    var frac_scale: f64 = 1.0
    var seen_dot = false
    while i < n:
        val opt = bytes.at(i)
        match opt:
            Some(b):
                val c = b as i64
                if c == 46:
                    seen_dot = true
                else:
                    if c >= 48 and c <= 57:
                        val d = (c - 48) as f64
                        if seen_dot:
                            frac_scale = frac_scale * 10.0
                            frac_part = frac_part + d / frac_scale
                        else:
                            int_part = int_part * 10.0 + d
            None:
                pass_do_nothing
        i = i + 1
    int_part + frac_part

# ============================================================================
# _skip_to_semi_or_brace — recovery: advance until `;` or `}` or Eof.
#
# WHY: on a syntax error we want to resume at the next statement
# boundary so a single malformed line doesn't torpedo the rest of the
# parse.
# ============================================================================

fn _skip_to_semi_or_brace(tokens: [Token], pos: i64) -> i64:
    var p = pos
    val n = tokens.len()
    while p < n:
        val t = tokens[p]
        if t.kind == TokenKind.Eof:
            return p
        if t.kind == TokenKind.Punctuation and (t.text == ";" or t.text == "}"):
            return p + 1
        p = p + 1
    p

# ============================================================================
# _parse_primary — identifier, int/float literal, or call.
#
# Returns (AstNode, new_pos). Emits an Invalid node if nothing matches.
# ============================================================================

fn _parse_primary(tokens: [Token], pos: i64) -> AstNode:
    val t = _peek(tokens, pos)
    if t.kind == TokenKind.IntLiteral:
        return _ast_node_int(_parse_int(t.text))
    if t.kind == TokenKind.FloatLiteral:
        return _ast_node_float(_parse_float(t.text))
    if t.kind == TokenKind.Identifier:
        return _ast_node_leaf(AstNodeKind.Identifier, t.text)
    _ast_node_leaf(AstNodeKind.Invalid, t.text)

# ============================================================================
# _advance_primary — consume the token(s) a primary expression used.
#
# Returns new position. Mirrors _parse_primary but only reports the
# cursor movement; keeping them split avoids tuple-return awkwardness in
# Simple's current typesystem.
# ============================================================================

fn _advance_primary(tokens: [Token], pos: i64) -> i64:
    val t = _peek(tokens, pos)
    if t.kind == TokenKind.Eof:
        return pos
    pos + 1

# ============================================================================
# _parse_expr — parse one expression with left-chained binary ops.
#
# WHY left-chain rather than precedence-aware: this is a known lossy
# simplification — `a + b * c` becomes `((a + b) * c)` instead of the
# mathematically correct `(a + (b * c))`. Acceptable for the first-cut
# SkRuntimeEffect prototype; replace with a pratt parser once operator
# precedence matters for codegen. Tracked in doc/TODO.md (sksl-parser).
# ============================================================================

fn _parse_expr(tokens: [Token], pos: i64, errors: [String]) -> AstNode:
    var p = pos
    var left = _parse_primary(tokens, p)
    p = _advance_primary(tokens, p)

    # --- optional call suffix: `<ident> ( args )` ---
    if left.kind == AstNodeKind.Identifier:
        val next = _peek(tokens, p)
        if next.kind == TokenKind.Punctuation and next.text == "(":
            p = p + 1
            var args: [AstNode] = []
            # consume args until `)`
            while true:
                val probe = _peek(tokens, p)
                if probe.kind == TokenKind.Eof:
                    errors.push("parse_sksl: unterminated call argument list")
                    break
                if probe.kind == TokenKind.Punctuation and probe.text == ")":
                    p = p + 1
                    break
                val arg = _parse_primary(tokens, p)
                p = _advance_primary(tokens, p)
                args.push(arg)
                val sep = _peek(tokens, p)
                if sep.kind == TokenKind.Punctuation and sep.text == ",":
                    p = p + 1
            val call = AstNode(
                kind: AstNodeKind.Call,
                text: left.text,
                type_name: "",
                children: args,
                int_value: 0,
                float_value: 0.0
            )
            left = call

    # --- left-chained binary ops ---
    while true:
        val op = _peek(tokens, p)
        if op.kind != TokenKind.Operator:
            break
        val ot = op.text
        val is_bin = ot == "+" or ot == "-" or ot == "*" or ot == "/" or ot == "<" or ot == ">" or ot == "=="
        if not is_bin:
            break
        p = p + 1
        val right = _parse_primary(tokens, p)
        p = _advance_primary(tokens, p)
        var kids: [AstNode] = []
        kids.push(left)
        kids.push(right)
        left = AstNode(
            kind: AstNodeKind.BinaryOp,
            text: ot,
            type_name: "",
            children: kids,
            int_value: 0,
            float_value: 0.0
        )

    left

# ============================================================================
# _expr_span — count tokens consumed by _parse_expr at `pos`.
#
# WHY a second pass: _parse_expr takes its position by value and the
# current Simple bootstrap cannot return tuples cleanly from this
# module. We mirror the cursor logic here; both functions must stay in
# lockstep — any new expression form needs an update in both.
# ============================================================================

fn _expr_span(tokens: [Token], pos: i64) -> i64:
    var p = pos
    val first = _peek(tokens, p)
    if first.kind == TokenKind.Eof:
        return p
    p = p + 1

    # call suffix
    if first.kind == TokenKind.Identifier:
        val next = _peek(tokens, p)
        if next.kind == TokenKind.Punctuation and next.text == "(":
            p = p + 1
            while true:
                val probe = _peek(tokens, p)
                if probe.kind == TokenKind.Eof:
                    return p
                if probe.kind == TokenKind.Punctuation and probe.text == ")":
                    p = p + 1
                    break
                # arg is a single primary
                val arg = _peek(tokens, p)
                if arg.kind == TokenKind.Eof:
                    return p
                p = p + 1
                val sep = _peek(tokens, p)
                if sep.kind == TokenKind.Punctuation and sep.text == ",":
                    p = p + 1

    # trailing binary ops
    while true:
        val op = _peek(tokens, p)
        if op.kind != TokenKind.Operator:
            break
        val ot = op.text
        val is_bin = ot == "+" or ot == "-" or ot == "*" or ot == "/" or ot == "<" or ot == ">" or ot == "=="
        if not is_bin:
            break
        p = p + 1
        val right = _peek(tokens, p)
        if right.kind == TokenKind.Eof:
            return p
        p = p + 1
    p

# ============================================================================
# _parse_stmt — one function-body statement. Returns the AST node; caller
# uses _stmt_span to advance.
# ============================================================================

fn _parse_stmt(tokens: [Token], pos: i64, errors: [String]) -> AstNode:
    val t = _peek(tokens, pos)

    # return <expr> ;
    if t.kind == TokenKind.Keyword and t.text == "return":
        val expr = _parse_expr(tokens, pos + 1, errors)
        var kids: [AstNode] = []
        kids.push(expr)
        return AstNode(
            kind: AstNodeKind.ReturnStmt,
            text: "",
            type_name: "",
            children: kids,
            int_value: 0,
            float_value: 0.0
        )

    # <type> <name> = <expr> ;
    if t.kind == TokenKind.Keyword and _is_type_keyword(t.text):
        val name = _peek(tokens, pos + 1)
        val eq = _peek(tokens, pos + 2)
        if name.kind == TokenKind.Identifier and eq.kind == TokenKind.Operator and eq.text == "=":
            val expr = _parse_expr(tokens, pos + 3, errors)
            var kids: [AstNode] = []
            kids.push(expr)
            return AstNode(
                kind: AstNodeKind.VarDecl,
                text: name.text,
                type_name: t.text,
                children: kids,
                int_value: 0,
                float_value: 0.0
            )

    # <name> = <expr> ;
    if t.kind == TokenKind.Identifier:
        val eq = _peek(tokens, pos + 1)
        if eq.kind == TokenKind.Operator and eq.text == "=":
            val expr = _parse_expr(tokens, pos + 2, errors)
            var kids: [AstNode] = []
            kids.push(expr)
            return AstNode(
                kind: AstNodeKind.Assign,
                text: t.text,
                type_name: "",
                children: kids,
                int_value: 0,
                float_value: 0.0
            )

    # expression statement
    val expr = _parse_expr(tokens, pos, errors)
    var kids: [AstNode] = []
    kids.push(expr)
    AstNode(
        kind: AstNodeKind.ExpressionStmt,
        text: "",
        type_name: "",
        children: kids,
        int_value: 0,
        float_value: 0.0
    )

# ============================================================================
# _stmt_span — count tokens a statement at `pos` consumes, including the
# trailing `;`.
# ============================================================================

fn _stmt_span(tokens: [Token], pos: i64) -> i64:
    val t = _peek(tokens, pos)
    var p = pos

    if t.kind == TokenKind.Keyword and t.text == "return":
        p = _expr_span(tokens, pos + 1)
    elif t.kind == TokenKind.Keyword and _is_type_keyword(t.text):
        val name = _peek(tokens, pos + 1)
        val eq = _peek(tokens, pos + 2)
        if name.kind == TokenKind.Identifier and eq.kind == TokenKind.Operator and eq.text == "=":
            p = _expr_span(tokens, pos + 3)
        else:
            p = _expr_span(tokens, pos)
    elif t.kind == TokenKind.Identifier:
        val eq = _peek(tokens, pos + 1)
        if eq.kind == TokenKind.Operator and eq.text == "=":
            p = _expr_span(tokens, pos + 2)
        else:
            p = _expr_span(tokens, pos)
    else:
        p = _expr_span(tokens, pos)

    # swallow trailing `;`
    val semi = _peek(tokens, p)
    if semi.kind == TokenKind.Punctuation and semi.text == ";":
        p = p + 1
    p

# ============================================================================
# _parse_function_body — consume `{ ... }`, collect stmt nodes.
#
# Expects `pos` to point at the `{`. Returns the last position after the
# matching `}`; the body nodes are appended to `body`.
# ============================================================================

fn _parse_function_body(tokens: [Token], pos: i64, body: [AstNode], errors: [String]) -> i64:
    var p = pos
    val open = _peek(tokens, p)
    if open.kind != TokenKind.Punctuation or open.text != "{":
        errors.push("parse_sksl: expected `{` for function body")
        return p
    p = p + 1

    while true:
        val t = _peek(tokens, p)
        if t.kind == TokenKind.Eof:
            errors.push("parse_sksl: unterminated function body")
            return p
        if t.kind == TokenKind.Punctuation and t.text == "}":
            return p + 1
        val stmt = _parse_stmt(tokens, p, errors)
        body.push(stmt)
        val next_p = _stmt_span(tokens, p)
        if next_p <= p:
            # safety: never regress, always advance
            errors.push("parse_sksl: failed to advance inside function body")
            p = p + 1
        else:
            p = next_p

# ============================================================================
# parse_sksl — top-level entry point.
#
# Walks the token stream and produces a ParseResult. Each top-level
# construct is one of:
#   - `uniform <type> <name> ;`
#   - `<type> <name> ( <params> ) { <body> }`
# Anything else records an error and advances to the next statement
# boundary so parsing can continue.
# ============================================================================

fn parse_sksl(tokens: [Token]) -> ParseResult:
    var ast: [AstNode] = []
    var errors: [String] = []
    val n = tokens.len()
    var pos = 0

    while pos < n:
        val t = tokens[pos]
        if t.kind == TokenKind.Eof:
            break

        # --- uniform decl: uniform <type> <name> ; ---
        if t.kind == TokenKind.Keyword and t.text == "uniform":
            val type_tok = _peek(tokens, pos + 1)
            val name_tok = _peek(tokens, pos + 2)
            val semi_tok = _peek(tokens, pos + 3)
            val ok_type = type_tok.kind == TokenKind.Keyword and _is_type_keyword(type_tok.text)
            val ok_name = name_tok.kind == TokenKind.Identifier
            val ok_semi = semi_tok.kind == TokenKind.Punctuation and semi_tok.text == ";"
            if ok_type and ok_name and ok_semi:
                val kids: [AstNode] = []
                val node = AstNode(
                    kind: AstNodeKind.Uniform,
                    text: name_tok.text,
                    type_name: type_tok.text,
                    children: kids,
                    int_value: 0,
                    float_value: 0.0
                )
                ast.push(node)
                pos = pos + 4
                continue
            errors.push("parse_sksl: malformed uniform declaration")
            pos = _skip_to_semi_or_brace(tokens, pos + 1)
            continue

        # --- function: <type> <name> ( ... ) { ... } ---
        if t.kind == TokenKind.Keyword and _is_type_keyword(t.text):
            val name_tok = _peek(tokens, pos + 1)
            val lp = _peek(tokens, pos + 2)
            val is_fn_head = name_tok.kind == TokenKind.Identifier and lp.kind == TokenKind.Punctuation and lp.text == "("
            if is_fn_head:
                # skip to matching `)`
                var p2 = pos + 3
                var found_rp = false
                while p2 < n:
                    val tt = tokens[p2]
                    if tt.kind == TokenKind.Eof:
                        break
                    if tt.kind == TokenKind.Punctuation and tt.text == ")":
                        found_rp = true
                        p2 = p2 + 1
                        break
                    p2 = p2 + 1
                if not found_rp:
                    errors.push("parse_sksl: unterminated function parameter list")
                    pos = _skip_to_semi_or_brace(tokens, pos + 1)
                    continue
                var body: [AstNode] = []
                val after_body = _parse_function_body(tokens, p2, body, errors)
                val fn_node = AstNode(
                    kind: AstNodeKind.Function,
                    text: name_tok.text,
                    type_name: t.text,
                    children: body,
                    int_value: 0,
                    float_value: 0.0
                )
                ast.push(fn_node)
                pos = after_body
                continue

        errors.push("parse_sksl: unexpected top-level token")
        pos = _skip_to_semi_or_brace(tokens, pos + 1)

    ParseResult(ast: ast, errors: errors)
