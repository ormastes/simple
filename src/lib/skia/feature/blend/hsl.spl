# HSL and separable blend modes (W3C Compositing & Blending Level 1)

use std.skia.entity.color.{SkColor4f}
use std.common.math.{math_clamp, math_min, math_max, math_abs}

fn _clamp01(x: f64) -> f64:
    math_clamp(x, 0.0, 1.0)

fn _alpha_compose(sa: f64, da: f64) -> f64:
    sa + da - sa * da

# General: B(Cs,Cd) = Cs*(1-as) + Cd*(1-as) + as*ad*B0
fn _sep(sc: f64, dc: f64, sa: f64, da: f64, b0: f64) -> f64:
    b0 * sa * da + sc * (1.0 - da) + dc * (1.0 - sa)

# ---- separable blend modes ----

fn blend_multiply(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, src.r * dst.r)),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, src.g * dst.g)),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, src.b * dst.b)),
              a: _clamp01(ra))

fn blend_screen(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, src.r + dst.r - src.r * dst.r)),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, src.g + dst.g - src.g * dst.g)),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, src.b + dst.b - src.b * dst.b)),
              a: _clamp01(ra))

fn _hard_light_ch(sc: f64, dc: f64) -> f64:
    if sc <= 0.5:
        2.0 * sc * dc
    else:
        sc + dc - 2.0 * sc * dc

fn blend_overlay(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, _hard_light_ch(dst.r, src.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, _hard_light_ch(dst.g, src.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, _hard_light_ch(dst.b, src.b))),
              a: _clamp01(ra))

fn blend_darken(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, math_min(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, math_min(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, math_min(src.b, dst.b))),
              a: _clamp01(ra))

fn blend_lighten(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, math_max(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, math_max(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, math_max(src.b, dst.b))),
              a: _clamp01(ra))

fn _color_dodge_ch(sc: f64, dc: f64) -> f64:
    if dc == 0.0:
        0.0
    elif sc == 1.0:
        1.0
    else:
        math_min(1.0, dc / (1.0 - sc))

fn blend_color_dodge(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, _color_dodge_ch(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, _color_dodge_ch(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, _color_dodge_ch(src.b, dst.b))),
              a: _clamp01(ra))

fn _color_burn_ch(sc: f64, dc: f64) -> f64:
    if dc == 1.0:
        1.0
    elif sc == 0.0:
        0.0
    else:
        1.0 - math_min(1.0, (1.0 - dc) / sc)

fn blend_color_burn(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, _color_burn_ch(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, _color_burn_ch(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, _color_burn_ch(src.b, dst.b))),
              a: _clamp01(ra))

fn blend_hard_light(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, _hard_light_ch(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, _hard_light_ch(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, _hard_light_ch(src.b, dst.b))),
              a: _clamp01(ra))

fn _approx_sqrt(x: f64) -> f64:
    if x <= 0.0:
        return 0.0
    var g = x
    var i = 0
    while i < 8:
        g = (g + x / g) * 0.5
        i = i + 1
    g

fn _soft_light_ch(sc: f64, dc: f64) -> f64:
    if sc <= 0.5:
        dc - (1.0 - 2.0 * sc) * dc * (1.0 - dc)
    else:
        val d = if dc <= 0.25:
            ((16.0 * dc - 12.0) * dc + 4.0) * dc
        else:
            _approx_sqrt(dc)
        dc + (2.0 * sc - 1.0) * (d - dc)

fn blend_soft_light(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, _soft_light_ch(src.r, dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, _soft_light_ch(src.g, dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, _soft_light_ch(src.b, dst.b))),
              a: _clamp01(ra))

fn blend_difference(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, math_abs(src.r - dst.r))),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, math_abs(src.g - dst.g))),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, math_abs(src.b - dst.b))),
              a: _clamp01(ra))

fn blend_exclusion(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    SkColor4f(r: _clamp01(_sep(src.r, dst.r, src.a, dst.a, src.r + dst.r - 2.0 * src.r * dst.r)),
              g: _clamp01(_sep(src.g, dst.g, src.a, dst.a, src.g + dst.g - 2.0 * src.g * dst.g)),
              b: _clamp01(_sep(src.b, dst.b, src.a, dst.a, src.b + dst.b - 2.0 * src.b * dst.b)),
              a: _clamp01(ra))

# ---- non-separable HSL helpers ----

fn _lum(r: f64, g: f64, b: f64) -> f64:
    0.299 * r + 0.587 * g + 0.114 * b

fn _clip_color(r: f64, g: f64, b: f64) -> SkColor4f:
    val l = _lum(r, g, b)
    val mn = math_min(r, math_min(g, b))
    val mx = math_max(r, math_max(g, b))
    var cr = r
    var cg = g
    var cb = b
    if mn < 0.0:
        val s = l / (l - mn)
        cr = l + (r - l) * s
        cg = l + (g - l) * s
        cb = l + (b - l) * s
    if mx > 1.0:
        val s2 = (1.0 - l) / (mx - l)
        cr = l + (cr - l) * s2
        cg = l + (cg - l) * s2
        cb = l + (cb - l) * s2
    SkColor4f(r: _clamp01(cr), g: _clamp01(cg), b: _clamp01(cb), a: 1.0)

fn _set_lum(r: f64, g: f64, b: f64, lum: f64) -> SkColor4f:
    val d = lum - _lum(r, g, b)
    _clip_color(r + d, g + d, b + d)

fn _sat_of(r: f64, g: f64, b: f64) -> f64:
    math_max(r, math_max(g, b)) - math_min(r, math_min(g, b))

fn _set_sat_channels(r: f64, g: f64, b: f64, s: f64) -> SkColor4f:
    val mn = math_min(r, math_min(g, b))
    val mx = math_max(r, math_max(g, b))
    var nr = 0.0
    var ng = 0.0
    var nb = 0.0
    if mx > mn:
        val scale = s / (mx - mn)
        nr = if r == mn: 0.0 elif r == mx: s else: (r - mn) * scale
        ng = if g == mn: 0.0 elif g == mx: s else: (g - mn) * scale
        nb = if b == mn: 0.0 elif b == mx: s else: (b - mn) * scale
    SkColor4f(r: _clamp01(nr), g: _clamp01(ng), b: _clamp01(nb), a: 1.0)

# ---- non-separable blend modes ----

fn blend_hue(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    val ss = _set_sat_channels(src.r, src.g, src.b, _sat_of(dst.r, dst.g, dst.b))
    val sl = _set_lum(ss.r, ss.g, ss.b, _lum(dst.r, dst.g, dst.b))
    SkColor4f(r: _clamp01(sl.r), g: _clamp01(sl.g), b: _clamp01(sl.b), a: _clamp01(ra))

fn blend_saturation(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    val ss = _set_sat_channels(dst.r, dst.g, dst.b, _sat_of(src.r, src.g, src.b))
    val sl = _set_lum(ss.r, ss.g, ss.b, _lum(dst.r, dst.g, dst.b))
    SkColor4f(r: _clamp01(sl.r), g: _clamp01(sl.g), b: _clamp01(sl.b), a: _clamp01(ra))

fn blend_color_mode(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    val sl = _set_lum(src.r, src.g, src.b, _lum(dst.r, dst.g, dst.b))
    SkColor4f(r: _clamp01(sl.r), g: _clamp01(sl.g), b: _clamp01(sl.b), a: _clamp01(ra))

fn blend_luminosity(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ra = _alpha_compose(src.a, dst.a)
    val sl = _set_lum(dst.r, dst.g, dst.b, _lum(src.r, src.g, src.b))
    SkColor4f(r: _clamp01(sl.r), g: _clamp01(sl.g), b: _clamp01(sl.b), a: _clamp01(ra))
