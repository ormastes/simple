# Porter-Duff blend modes over premultiplied float RGBA

use std.skia.entity.color.{SkColor4f}
use std.common.math.{math_clamp}

fn _clamp01(x: f64) -> f64:
    math_clamp(x, 0.0, 1.0)

fn _mk(r: f64, g: f64, b: f64, a: f64) -> SkColor4f:
    SkColor4f(r: _clamp01(r), g: _clamp01(g), b: _clamp01(b), a: _clamp01(a))

fn blend_clear(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)

fn blend_src(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    src

fn blend_dst(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    dst

fn blend_src_over(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ia = 1.0 - src.a
    _mk(src.r + dst.r * ia, src.g + dst.g * ia, src.b + dst.b * ia, src.a + dst.a * ia)

fn blend_dst_over(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ib = 1.0 - dst.a
    _mk(dst.r + src.r * ib, dst.g + src.g * ib, dst.b + src.b * ib, dst.a + src.a * ib)

fn blend_src_in(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ab = dst.a
    _mk(src.r * ab, src.g * ab, src.b * ab, src.a * ab)

fn blend_dst_in(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val aa = src.a
    _mk(dst.r * aa, dst.g * aa, dst.b * aa, dst.a * aa)

fn blend_src_out(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ib = 1.0 - dst.a
    _mk(src.r * ib, src.g * ib, src.b * ib, src.a * ib)

fn blend_dst_out(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ia = 1.0 - src.a
    _mk(dst.r * ia, dst.g * ia, dst.b * ia, dst.a * ia)

fn blend_src_atop(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ab = dst.a
    val ia = 1.0 - src.a
    _mk(src.r * ab + dst.r * ia, src.g * ab + dst.g * ia,
        src.b * ab + dst.b * ia, src.a * ab + dst.a * ia)

fn blend_dst_atop(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val aa = src.a
    val ib = 1.0 - dst.a
    _mk(dst.r * aa + src.r * ib, dst.g * aa + src.g * ib,
        dst.b * aa + src.b * ib, dst.a * aa + src.a * ib)

fn blend_xor(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    val ia = 1.0 - src.a
    val ib = 1.0 - dst.a
    _mk(src.r * ib + dst.r * ia, src.g * ib + dst.g * ia,
        src.b * ib + dst.b * ia, src.a * ib + dst.a * ia)

fn blend_plus(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    _mk(src.r + dst.r, src.g + dst.g, src.b + dst.b, src.a + dst.a)

fn blend_modulate(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    _mk(src.r * dst.r, src.g * dst.g, src.b * dst.b, src.a * dst.a)

fn blend_screen(src: SkColor4f, dst: SkColor4f) -> SkColor4f:
    _mk(src.r + dst.r - src.r * dst.r, src.g + dst.g - src.g * dst.g,
        src.b + dst.b - src.b * dst.b, src.a + dst.a - src.a * dst.a)
