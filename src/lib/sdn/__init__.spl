# Shim: lib.sdn → common.sdn
# Created for interpreter-mode module resolution
use std.common.sdn.value.{SdnValue}
use std.common.sdn.parser.{parse}

extern fn rt_file_read_text(path: text) -> text

fn parse_file(path: text) -> Result<SdnValue, text>:
    parse(rt_file_read_text(path))

fn render_value(value: SdnValue, indent: i64) -> text:
    match value:
        case Null:
            "null"
        case Bool(b):
            if b: "true" else: "false"
        case Int(i):
            i.to_text()
        case Float(f):
            f.to_text()
        case String(s):
            "\"" + s + "\""
        case Array(items):
            var parts: [text] = []
            for item in items:
                parts = parts.push(render_value(item, indent + 2))
            "[" + parts.join(", ") + "]"
        case Dict(entries):
            var parts: [text] = []
            for key in entries.keys():
                parts = parts.push(key + ": " + render_value(entries[key], indent + 2))
            "{ " + parts.join(", ") + " }"
        case Table(_, _):
            "[]"

export SdnValue
export parse, parse_file, render_value
