# GC Sync Mutable Variant
#
# GC-specific modules for synchronous mutable contexts.
# Most stdlib modules fall back to nogc_sync_mut via the module loader.
# Only modules with GC-specific memory semantics are defined here.

# Re-exported from allocator.spl
export GcAllocator
export gc_allocator_new
export gc_allocate, gc_deallocate, gc_reallocate
export gc_total_allocated

# Re-exported from rc.spl
export GcRc, GcArc, GcWeak
export gc_make_rc, gc_make_arc

# Re-exported from gc.spl (re-export from nogc_sync_mut/gc.spl)
export GcHeap
export GcConfig
export GcStats
export GcPtr
export GcColor
export GcObjectHeader

# Re-exported from ptr/shared.spl
export GcShared, gc_shared_new, gc_shared_get

# Re-exported from ptr/unique.spl
export GcUnique, gc_unique_new, gc_unique_get, gc_unique_take

# Re-exported from unsafe/gc_root.spl
export GcRoot, gc_root_pin, gc_root_unpin, gc_with_pinned

# Re-exported from mem_tracker/tracker.spl
export GcMemTracker, gc_tracker_new, gc_tracker_record, gc_tracker_stats
