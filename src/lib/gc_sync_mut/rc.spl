# GC-Mode Reference Counting — No-Op Wrappers
#
# Under GC mode, bare T is already a GC-managed shared reference.
# Rc/Arc are redundant — these wrappers hold the reference directly
# without any counting overhead. This allows code written for NoGC
# (using Rc/Arc) to compile and run correctly under GC mode.

# ============================================================================
# GcRc - No-Op Reference Counting (GC Mode)
# ============================================================================

class GcRc:
    """No-op Rc for GC mode.

    Under GC, all references are already shared and traced.
    GcRc simply wraps the value — no reference counting needed.
    """
    value: i64

    static fn new(value: i64) -> GcRc:
        """Wrap value in GcRc (no allocation overhead)."""
        GcRc(value: value)

    fn clone() -> GcRc:
        """Clone is trivial — just copy the reference."""
        GcRc(value: self.value)

    fn borrow() -> i64:
        """Borrow value directly."""
        self.value

    fn strong_count() -> usize:
        """Always 1+ under GC (GC tracks reachability, not count)."""
        1

    fn weak_count() -> usize:
        """No weak references under GC."""
        0

    fn downgrade() -> GcWeak:
        """Create weak reference (also no-op under GC)."""
        GcWeak(value: self.value)

    me drop():
        """No-op: GC handles deallocation."""
        # GC reclaims when unreachable

# ============================================================================
# GcArc - No-Op Atomic Reference Counting (GC Mode)
# ============================================================================

class GcArc:
    """No-op Arc for GC mode.

    Same as GcRc — under GC, thread safety is handled by the collector.
    """
    value: i64

    static fn new(value: i64) -> GcArc:
        """Wrap value in GcArc."""
        GcArc(value: value)

    fn clone() -> GcArc:
        """Clone: just copy the reference."""
        GcArc(value: self.value)

    fn borrow() -> i64:
        """Borrow value directly."""
        self.value

    fn strong_count() -> usize:
        """Always 1+ under GC."""
        1

    fn weak_count() -> usize:
        """No weak references under GC."""
        0

    fn downgrade() -> GcWeak:
        """Create weak reference."""
        GcWeak(value: self.value)

    me drop():
        """No-op: GC handles deallocation."""
        # GC reclaims when unreachable

# ============================================================================
# GcWeak - No-Op Weak Reference (GC Mode)
# ============================================================================

class GcWeak:
    """No-op Weak reference for GC mode.

    Under GC, weak references behave like strong references
    since the GC traces all reachable objects.
    """
    value: i64

    fn upgrade() -> i64?:
        """Always succeeds under GC (object is always reachable if we hold it)."""
        Some(self.value)

    fn strong_count() -> usize:
        """Always 1+ under GC."""
        1

    fn weak_count() -> usize:
        """No real weak count under GC."""
        0

    me drop():
        """No-op."""
        # GC reclaims when unreachable

# ============================================================================
# Convenience Functions
# ============================================================================

fn gc_make_rc(value: i64) -> GcRc:
    """Create a GcRc wrapping value."""
    GcRc.new(value)

fn gc_make_arc(value: i64) -> GcArc:
    """Create a GcArc wrapping value."""
    GcArc.new(value)
