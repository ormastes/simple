# GC-Aware Unique Pointer
#
# Under GC mode, unique ownership is simulated on top of GC references.
# GcUnique provides move semantics: after take(), the original is invalidated.
# The underlying memory is still GC-managed.

use std.gc.{GcHeap, GcPtr}

# ============================================================================
# GcUnique - Unique Ownership on GC Heap
# ============================================================================

class GcUnique:
    """Unique pointer backed by GC.

    Provides ownership semantics on top of GC-managed memory.
    After take(), the original GcUnique is invalidated (value set to sentinel).
    The GC still manages the underlying memory.
    """
    gc_ptr: GcPtr
    value: i64
    taken: bool

    static fn new(heap: GcHeap, value: i64) -> GcUnique:
        """Create a unique pointer on the GC heap.

        Args:
            heap: GC heap for allocation
            value: Value to own uniquely
        """
        val ptr = heap.allocate_ptr(value)
        GcUnique(gc_ptr: ptr, value: value, taken: false)

fn gc_unique_new(heap: GcHeap, value: i64) -> GcUnique:
    """Create a new unique pointer on the GC heap."""
    GcUnique.new(heap, value)

fn gc_unique_get(unique: GcUnique) -> i64?:
    """Get value without consuming (borrow).

    Returns nil if already taken.
    """
    if unique.taken:
        nil
    else:
        Some(unique.value)

fn gc_unique_take(unique: GcUnique) -> i64?:
    """Take the value, invalidating the unique pointer.

    Returns nil if already taken.
    """
    if unique.taken:
        nil
    else:
        unique.taken = true
        Some(unique.value)
