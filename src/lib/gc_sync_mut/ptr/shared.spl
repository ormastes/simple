# GC-Aware Shared Pointer
#
# Under GC mode, Shared<T> wraps a GC-managed reference.
# The GC collector traces through GcShared to find reachable objects.
# No manual reference counting — the GC handles lifetimes.

use std.gc.{GcHeap, GcPtr}

# ============================================================================
# GcShared - GC-Managed Shared Reference
# ============================================================================

class GcShared:
    """Shared reference backed by GC.

    Under GC mode, bare T is already shared. GcShared provides an
    explicit wrapper for code that needs to be clear about sharing
    semantics. The GC traces through this wrapper automatically.
    """
    gc_ptr: GcPtr
    value: i64

    static fn new(heap: GcHeap, value: i64) -> GcShared:
        """Create a GC-managed shared reference.

        Args:
            heap: GC heap to register with
            value: Value to share

        Returns:
            GcShared wrapping the value
        """
        val ptr = heap.allocate_ptr(value)
        GcShared(gc_ptr: ptr, value: value)

fn gc_shared_new(heap: GcHeap, value: i64) -> GcShared:
    """Create a new GC-managed shared reference."""
    GcShared.new(heap, value)

fn gc_shared_get(shared: GcShared) -> i64:
    """Get the value from a shared reference."""
    shared.value
