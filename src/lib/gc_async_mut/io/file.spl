"""
# GC Async File I/O

GC async file I/O is a compatibility facade over the no-GC async file module.
The async driver behavior remains selected by the no-GC backend layer.
"""

export use std.nogc_async_mut.io.file.{
    O_RDONLY, O_WRONLY, O_RDWR, O_CREAT, O_TRUNC, O_APPEND, O_NONBLOCK,
    O_EXCL, DEFAULT_MODE, FileStat, AsyncFile, AsyncDir, ThreadPool, stat
}
export use std.nogc_sync_mut.io.file.{FileHandle, File}
export use std.nogc_async_mut.io.{AsyncFileHandle}
