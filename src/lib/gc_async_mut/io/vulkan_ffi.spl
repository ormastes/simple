extern fn rt_vulkan_begin_render_pass_gfx(cmd: i64, render_pass: i64, framebuffer: i64, clear_r: f64, clear_g: f64, clear_b: f64, clear_a: f64) -> bool
extern fn rt_vulkan_end_render_pass_gfx(cmd: i64) -> bool
extern fn rt_vulkan_bind_graphics_pipeline(cmd: i64, pipeline: i64) -> bool
