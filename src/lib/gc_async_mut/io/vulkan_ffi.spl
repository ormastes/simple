extern fn rt_vulkan_draw_indexed(cmd: i64, index_count: i64) -> bool

# ============================================================================
# Graphics Wrapper Structs
# ============================================================================

struct VulkanRenderPass:
    handle: i64

impl VulkanRenderPass:
    fn is_valid() -> bool:
        self.handle > 0

struct VulkanGraphicsPipeline:
    handle: i64

impl VulkanGraphicsPipeline:
    fn is_valid() -> bool:
        self.handle > 0

struct VulkanImage:
    handle: i64
    width: i64
    height: i64

impl VulkanImage:
    fn is_valid() -> bool:
        self.handle > 0

struct VulkanSampler:
    handle: i64

impl VulkanSampler:
    fn is_valid() -> bool:
        self.handle > 0

struct VulkanFramebuffer:
    handle: i64
    width: i64
    height: i64

impl VulkanFramebuffer:
    fn is_valid() -> bool:
        self.handle > 0

struct VulkanSwapchain:
    handle: i64
    width: i64
    height: i64

impl VulkanSwapchain:
    fn is_valid() -> bool:
        self.handle > 0

# Graphics wrapper functions
fn vulkan_create_render_pass(device: i64, color_format: i64, depth_format: i64, load_op: i64, store_op: i64) -> VulkanRenderPass:
    val h = rt_vulkan_create_render_pass(device, color_format, depth_format, load_op, store_op)
    VulkanRenderPass(handle: h)

fn vulkan_create_graphics_pipeline(device: i64, vs: i64, fs: i64, rp: i64, blend: i64, topo: i64) -> VulkanGraphicsPipeline:
    val h = rt_vulkan_create_graphics_pipeline(device, vs, fs, rp, blend, topo)
    VulkanGraphicsPipeline(handle: h)

fn vulkan_create_image(device: i64, width: i64, height: i64, format: i64, usage: i64) -> VulkanImage:
    val h = rt_vulkan_create_image(device, width, height, format, usage)
    VulkanImage(handle: h, width: width, height: height)

fn vulkan_create_sampler(device: i64) -> VulkanSampler:
    val h = rt_vulkan_create_sampler(device)
    VulkanSampler(handle: h)

fn vulkan_create_framebuffer(device: i64, rp: i64, image: i64, width: i64, height: i64) -> VulkanFramebuffer:
    val h = rt_vulkan_create_framebuffer(device, rp, image, width, height)
    VulkanFramebuffer(handle: h, width: width, height: height)

fn vulkan_create_swapchain(device: i64, surface: i64, width: i64, height: i64, format: i64, vsync: i64) -> VulkanSwapchain:
    val h = rt_vulkan_create_swapchain(device, surface, width, height, format, vsync)
    VulkanSwapchain(handle: h, width: width, height: height)

