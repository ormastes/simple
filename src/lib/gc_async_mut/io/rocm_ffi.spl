#![allow(unnamed_duplicate_typed_args)]
#![allow(primitive_api)]
# ROCm HIP Runtime SFFI Bindings
#
# SFFI pattern for AMD GPU compute via HIP (mirrors CUDA API).
# Note: These require ROCm toolkit to be installed.

# ============================================================================
# Tier 1: Extern Declarations (Raw FFI)
# ============================================================================

extern fn rt_rocm_init() -> bool
extern fn rt_rocm_is_available() -> bool
extern fn rt_rocm_device_count() -> i64
extern fn rt_rocm_device_name(device: i64) -> text
extern fn rt_rocm_device_memory(device: i64) -> i64
extern fn rt_rocm_set_device(device: i64) -> bool
extern fn rt_rocm_get_device() -> i64
extern fn rt_rocm_malloc(size: i64) -> i64
extern fn rt_rocm_free(ptr: i64) -> bool
extern fn rt_rocm_memcpy_h2d(dst: i64, src_data: [u8], size: i64) -> bool
extern fn rt_rocm_memcpy_d2h(dst_data: [u8], src: i64, size: i64) -> bool
extern fn rt_rocm_memcpy_d2d(dst: i64, src: i64, size: i64) -> bool
extern fn rt_rocm_memset(ptr: i64, value: i64, size: i64) -> bool
extern fn rt_rocm_compile_hsaco(source: text) -> i64
extern fn rt_rocm_get_function(module: i64, name: text) -> i64
extern fn rt_rocm_launch_kernel(func: i64, grid_x: i64, grid_y: i64, grid_z: i64, block_x: i64, block_y: i64, block_z: i64, shared_mem: i64, args: [i64]) -> bool
extern fn rt_rocm_unload_module(module: i64) -> bool
extern fn rt_rocm_synchronize() -> bool
extern fn rt_rocm_create_stream() -> i64
extern fn rt_rocm_destroy_stream(stream: i64) -> bool
extern fn rt_rocm_stream_synchronize(stream: i64) -> bool
extern fn rt_rocm_get_last_error() -> text

# ============================================================================
# Tier 2: Simple-Friendly Wrapper Functions
# ============================================================================

fn rocm_available() -> bool:
    rt_rocm_is_available()

fn rocm_init() -> bool:
    rt_rocm_init()

fn rocm_device_count() -> i64:
    rt_rocm_device_count()

fn rocm_set_device(id: i64) -> bool:
    rt_rocm_set_device(id)

fn rocm_get_device() -> i64:
    rt_rocm_get_device()

struct RocmDeviceInfo:
    id: i64
    name: text
    total_memory: i64

fn rocm_device_info(id: i64) -> RocmDeviceInfo:
    RocmDeviceInfo(id: id, name: rt_rocm_device_name(id), total_memory: rt_rocm_device_memory(id))

struct RocmPtr:
    ptr: i64
    size: i64
    is_valid: bool

fn rocm_alloc(size: i64) -> RocmPtr:
    val ptr = rt_rocm_malloc(size)
    RocmPtr(ptr: ptr, size: size, is_valid: ptr != 0)

fn rocm_free(mem: RocmPtr) -> bool:
    if mem.is_valid:
        rt_rocm_free(mem.ptr)
    else:
        true

fn rocm_copy_to_device(dst: RocmPtr, src: [u8]) -> bool:
    if not dst.is_valid:
        false
    else:
        rt_rocm_memcpy_h2d(dst.ptr, src, src.len())

fn rocm_copy_from_device(dst: [u8], src: RocmPtr) -> bool:
    if not src.is_valid:
        false
    else:
        rt_rocm_memcpy_d2h(dst, src.ptr, dst.len())

fn rocm_copy_device_to_device(dst: RocmPtr, src: RocmPtr, size: i64) -> bool:
    if not dst.is_valid or not src.is_valid:
        false
    else:
        rt_rocm_memcpy_d2d(dst.ptr, src.ptr, size)

fn rocm_memset(mem: RocmPtr, value: i64) -> bool:
    if not mem.is_valid:
        false
    else:
        rt_rocm_memset(mem.ptr, value, mem.size)

struct RocmModule:
    handle: i64
    is_valid: bool

fn rocm_compile(hsaco_source: text) -> RocmModule:
    val handle = rt_rocm_compile_hsaco(hsaco_source)
    RocmModule(handle: handle, is_valid: handle != 0)

fn rocm_unload(module: RocmModule) -> bool:
    if module.is_valid:
        rt_rocm_unload_module(module.handle)
    else:
        true

struct RocmFunc:
    handle: i64
    module: RocmModule
    name: text
    is_valid: bool

fn rocm_get_kernel(module: RocmModule, name: text) -> RocmFunc:
    if not module.is_valid:
        RocmFunc(handle: 0, module: module, name: name, is_valid: false)
    else:
        val handle = rt_rocm_get_function(module.handle, name)
        RocmFunc(handle: handle, module: module, name: name, is_valid: handle != 0)

struct RocmLaunchConfig:
    gx: i64
    gy: i64
    gz: i64
    blk_x: i64
    blk_y: i64
    blk_z: i64
    shared_mem: i64

fn rocm_launch_config_1d(grid_size: i64, block_size: i64) -> RocmLaunchConfig:
    RocmLaunchConfig(gx: grid_size, gy: 1, gz: 1, blk_x: block_size, blk_y: 1, blk_z: 1, shared_mem: 0)

fn rocm_launch(kfn: RocmFunc, config: RocmLaunchConfig, args: [i64]) -> bool:
    if not kfn.is_valid:
        false
    else:
        rt_rocm_launch_kernel(kfn.handle, config.gx, config.gy, config.gz, config.blk_x, config.blk_y, config.blk_z, config.shared_mem, args)

fn rocm_sync() -> bool:
    rt_rocm_synchronize()

struct RocmStream:
    handle: i64
    is_valid: bool

fn rocm_stream_create() -> RocmStream:
    val handle = rt_rocm_create_stream()
    RocmStream(handle: handle, is_valid: handle != 0)

fn rocm_stream_destroy(stream: RocmStream) -> bool:
    if stream.is_valid:
        rt_rocm_destroy_stream(stream.handle)
    else:
        true

fn rocm_stream_sync(stream: RocmStream) -> bool:
    if stream.is_valid:
        rt_rocm_stream_synchronize(stream.handle)
    else:
        true

fn rocm_last_error() -> text:
    rt_rocm_get_last_error()

fn rocm_run_1d(kfn: RocmFunc, total_elements: i64, block_size: i64, args: [i64]) -> bool:
    val grid_size = (total_elements + block_size - 1) / block_size
    val config = rocm_launch_config_1d(grid_size, block_size)
    rocm_launch(kfn, config, args) and rocm_sync()

fn rocm_alloc_from_host(data: [u8]) -> RocmPtr:
    val mem = rocm_alloc(data.len())
    if mem.is_valid:
        rocm_copy_to_device(mem, data)
    mem

# ============================================================================
# Exports
# ============================================================================
