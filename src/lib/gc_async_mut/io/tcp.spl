"""
# GC Async TCP I/O

GC async TCP is a compatibility facade over the no-GC async TCP backend
library. That no-GC async facade exposes both ready-future async wrappers and
the underlying sync listener/stream types.

Keeping this module as a facade prevents the GC library family from declaring
its own TCP runtime hooks. Platform-specific TCP behavior belongs below the
no-GC backend boundary.
"""

export use std.nogc_async_mut.io.tcp.{
    TcpListener, TcpStream, AsyncTcpListener, AsyncTcpStream
}
