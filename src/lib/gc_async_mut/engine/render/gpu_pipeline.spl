# GPU 2D Pipeline — Sprite-batched GPU renderer for game2d
#
# Provides GpuVertex2D (per-vertex GPU data), SpriteBatch (quad accumulator),
# and GpuRenderer2D (command-buffer consumer with full match coverage).
#
# All RenderCommand variants are handled:
#   Clear, DrawRect, DrawCircle, DrawLine, DrawSprite, DrawTriangles,
#   DrawRectOutlined, DrawCircleOutlined, DrawText
#
# GAME-RENDER-002 fix: previously missing arms (DrawRectOutlined,
# DrawCircleOutlined, DrawText) now implemented.

use std.common.engine.color.{EngineColor}
use std.common.engine.rect.{Rect2}
use std.common.engine.math2d.{Vec2}
use std.common.engine.ids.{TextureId}
use std.common.engine.units.{ZIndex}
use std.nogc_sync_mut.engine.render.command.{RenderCommand, RenderCommandBuffer}
use std.nogc_sync_mut.engine.render.types.{DrawStats}
use std.nogc_sync_mut.engine.render.font_atlas.{FontAtlas, GlyphInfo}

# ============================================================================
# GpuVertex2D — Packed per-vertex data for GPU upload
# ============================================================================

class GpuVertex2D:
    pos_x: f64
    pos_y: f64
    uv_x: f64
    uv_y: f64
    color_r: f64
    color_g: f64
    color_b: f64
    color_a: f64

impl GpuVertex2D:
    static fn from_pos_uv_color(px: f64, py: f64, ux: f64, uy: f64, c: EngineColor) -> GpuVertex2D:
        GpuVertex2D(
            pos_x: px,
            pos_y: py,
            uv_x: ux,
            uv_y: uy,
            color_r: c.r,
            color_g: c.g,
            color_b: c.b,
            color_a: c.a
        )

# ============================================================================
# SpriteBatch — Accumulates quads for a single texture handle
# ============================================================================

class SpriteBatch:
    texture_handle: i64
    vertices: [GpuVertex2D]
    indices: [i64]
    quad_count: i64

impl SpriteBatch:
    static fn create(handle: i64) -> SpriteBatch:
        SpriteBatch(
            texture_handle: handle,
            vertices: [],
            indices: [],
            quad_count: 0
        )

    # Add one quad (two triangles) from axis-aligned rect + UV rect + color.
    # Vertex order: TL, TR, BR, BL  (indices: 0,1,2  0,2,3)
    me add_quad(x: f64, y: f64, w: f64, h: f64, u0: f64, v0: f64, u1: f64, v1: f64, c: EngineColor):
        val base = self.quad_count * 4
        self.vertices.push(GpuVertex2D.from_pos_uv_color(x,     y,     u0, v0, c))
        self.vertices.push(GpuVertex2D.from_pos_uv_color(x + w, y,     u1, v0, c))
        self.vertices.push(GpuVertex2D.from_pos_uv_color(x + w, y + h, u1, v1, c))
        self.vertices.push(GpuVertex2D.from_pos_uv_color(x,     y + h, u0, v1, c))
        self.indices.push(base)
        self.indices.push(base + 1)
        self.indices.push(base + 2)
        self.indices.push(base)
        self.indices.push(base + 2)
        self.indices.push(base + 3)
        self.quad_count = self.quad_count + 1

# ============================================================================
# GpuRenderer2D — Processes a RenderCommandBuffer into SpriteBatches
# ============================================================================

class GpuRenderer2D:
    screen_width: i64
    screen_height: i64
    batches: [SpriteBatch]
    current_batch: SpriteBatch
    font_atlas: FontAtlas

impl GpuRenderer2D:
    static fn create(w: i64, h: i64) -> GpuRenderer2D:
        GpuRenderer2D(
            screen_width: w,
            screen_height: h,
            batches: [],
            current_batch: SpriteBatch.create(0),
            font_atlas: FontAtlas.default_monospace()
        )

    me resize(w: i64, h: i64):
        self.screen_width = w
        self.screen_height = h

    fn screen_to_ndc(sx: f64, sy: f64) -> Vec2:
        val nx = (sx / (self.screen_width * 1.0)) * 2.0 - 1.0
        val ny = 1.0 - (sy / (self.screen_height * 1.0)) * 2.0
        Vec2(x: nx, y: ny)

    me begin_frame():
        self.batches = []
        self.current_batch = SpriteBatch.create(0)

    # Ensure current_batch uses the given texture handle.
    # If it differs, flush the current batch and start a new one.
    me _ensure_batch(handle: i64):
        if self.current_batch.texture_handle != handle:
            if self.current_batch.quad_count > 0:
                self.batches.push(self.current_batch)
            self.current_batch = SpriteBatch.create(handle)

    me _flush():
        if self.current_batch.quad_count > 0:
            self.batches.push(self.current_batch)
            self.current_batch = SpriteBatch.create(self.current_batch.texture_handle)

    # Process a full command buffer and return aggregate draw statistics.
    me submit_commands(buf: RenderCommandBuffer) -> DrawStats:
        self.begin_frame()
        var stats = DrawStats.zero()
        for cmd in buf.commands:
            match cmd:
                case Clear(color: _c):
                    # No geometry for clear — GPU clears are handled by the backend
                    pass_dn
                case DrawRect(rect: r, color: c, z_order: _z):
                    self._ensure_batch(0)
                    self.current_batch.add_quad(r.x, r.y, r.width, r.height, 0.0, 0.0, 1.0, 1.0, c)
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + 2
                    stats.vertices = stats.vertices + 4
                case DrawCircle(cx: _cx, cy: _cy, radius: _r, color: c, z_order: _z):
                    # Bounding-quad approximation — circle tessellation in shader
                    self._ensure_batch(0)
                    val r2 = _r * 2.0
                    self.current_batch.add_quad(_cx - _r, _cy - _r, r2, r2, 0.0, 0.0, 1.0, 1.0, c)
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + 2
                    stats.vertices = stats.vertices + 4
                case DrawLine(x1: _x1, y1: _y1, x2: _x2, y2: _y2, width: _w, color: c, z_order: _z):
                    # Axis-aligned bounding quad for line
                    self._ensure_batch(0)
                    val lx = _x1
                    val ly = _y1
                    val lw = _x2 - _x1
                    val lh = _y2 - _y1
                    self.current_batch.add_quad(lx, ly, lw, lh, 0.0, 0.0, 1.0, 1.0, c)
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + 2
                    stats.vertices = stats.vertices + 4
                case DrawSprite(texture_id: tex, src_rect: src, dst_rect: dst, tint: t, z_order: _z):
                    val handle = tex.raw.index
                    self._ensure_batch(handle)
                    self.current_batch.add_quad(dst.x, dst.y, dst.width, dst.height, src.x, src.y, src.x + src.width, src.y + src.height, t)
                    self._flush()
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + 2
                    stats.vertices = stats.vertices + 4
                case DrawTriangles(vertices: _verts, indices: _idxs, color: _c, z_order: _z):
                    # Custom triangle mesh — counted as 1 draw call
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + (_idxs.len() / 3)
                    stats.vertices = stats.vertices + _verts.len()
                case DrawRectOutlined(rect: r, color: c, z_order: _z):
                    # 4 thin edge quads: top, bottom, left, right (1 px wide)
                    val thickness = 1.0
                    self._ensure_batch(0)
                    # top edge
                    self.current_batch.add_quad(r.x, r.y, r.width, thickness, 0.0, 0.0, 1.0, 1.0, c)
                    # bottom edge
                    self.current_batch.add_quad(r.x, r.y + r.height - thickness, r.width, thickness, 0.0, 0.0, 1.0, 1.0, c)
                    # left edge
                    self.current_batch.add_quad(r.x, r.y + thickness, thickness, r.height - thickness * 2.0, 0.0, 0.0, 1.0, 1.0, c)
                    # right edge
                    self.current_batch.add_quad(r.x + r.width - thickness, r.y + thickness, thickness, r.height - thickness * 2.0, 0.0, 0.0, 1.0, 1.0, c)
                    stats.draw_calls = stats.draw_calls + 4
                    stats.triangles = stats.triangles + 8
                    stats.vertices = stats.vertices + 16
                case DrawCircleOutlined(cx: _cx, cy: _cy, radius: _r, color: c, z_order: _z):
                    # Bounding-quad approximation; outline tessellation in shader
                    val r2 = _r * 2.0
                    self._ensure_batch(0)
                    self.current_batch.add_quad(_cx - _r, _cy - _r, r2, r2, 0.0, 0.0, 1.0, 1.0, c)
                    stats.draw_calls = stats.draw_calls + 1
                    stats.triangles = stats.triangles + 2
                    stats.vertices = stats.vertices + 4
                case DrawText(font: _font, content: s, pos: p, color: c, z_order: _z):
                    # Per-character quads using font atlas geometry metadata.
                    # Texture handle 0 (solid-color pass) — real texture binding: GAME-RENDER-003.
                    self._ensure_batch(0)
                    var cursor_x = p.x
                    var char_count = 0
                    for ch in s.chars():
                        val cp = ch.to_codepoint()
                        if cp == 10:
                            # newline: reset horizontal cursor (vertical advance not tracked here)
                            cursor_x = p.x
                        else:
                            val g = self.font_atlas.glyph(cp)
                            self.current_batch.add_quad(cursor_x, p.y, g.w, g.h, g.u0, g.v0, g.u1, g.v1, c)
                            cursor_x = cursor_x + g.advance_x
                            char_count = char_count + 1
                    stats.draw_calls = stats.draw_calls + char_count
                    stats.triangles = stats.triangles + char_count * 2
                    stats.vertices = stats.vertices + char_count * 4
        stats
