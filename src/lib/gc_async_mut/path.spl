@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# @alloc
# std.path - Path manipulation utilities
# Pure Simple implementation (no SFFI)

pub fn basename(path: text) -> text:
    if path == "":
        return ""
    var clean_path = path
    while clean_path.ends_with("/") and clean_path.len() > 1:
        clean_path = clean_path.substring(0, clean_path.len() - 1)
    val parts: [text] = clean_path.split("/")
    return parts.last() ?? ""

pub fn dirname(path: text) -> text:
    if path == "":
        return "."
    if path == "/":
        return "/"
    var clean_path = path
    while clean_path.ends_with("/") and clean_path.len() > 1:
        clean_path = clean_path.substring(0, clean_path.len() - 1)
    val last_sep = clean_path.rfind("/")
    val sep_idx = match last_sep:
        Some(idx):
            idx
        nil:
            return "."
    if sep_idx == 0:
        return "/"
    return clean_path.substring(0, sep_idx)

pub fn extension(path: text) -> text:
    val name = basename(path)
    if name == "":
        return ""
    val last_dot = name.rfind(".")
    val dot_idx = match last_dot:
        Some(idx):
            idx
        nil:
            return ""
    if dot_idx == 0:
        return ""
    if dot_idx == name.len() - 1:
        return ""
    return name.substring(dot_idx + 1)

pub fn stem(path: text) -> text:
    val name = basename(path)
    val ext = extension(path)
    if ext == "":
        return name
    return name.substring(0, name.len() - ext.len() - 1)

fn _path_concat_parts(parts: [text], separator: text) -> text:
    var result = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            result = result + separator
        result = result + parts[i]
        i = i + 1
    result

pub fn path_join(parts: [text]) -> text:
    if parts.len() == 0:
        return ""
    var segments: [text] = []
    segments.push(parts[0])
    for i in 1..parts.len():
        val part = parts[i]
        if part == "":
            continue
        val last_seg = segments[segments.len() - 1]
        if not last_seg.ends_with("/"):
            segments.push("/")
        if part.starts_with("/"):
            segments.push(part.substring(1))
        else:
            segments.push(part)
    return _path_concat_parts(segments, "")

# @tag(a=first_segment, b=second_segment)
pub fn join2(a: text, b: text) -> text:
    if a == "":
        return b
    if b == "":
        return a
    if a.ends_with("/"):
        return a + (if b.starts_with("/") then b.substring(1) else b)
    return a + (if b.starts_with("/") then b else "/" + b)

pub fn normalize(path: text) -> text:
    if path == "":
        return "."
    val is_abs = path.starts_with("/")
    val parts: [text] = path.split("/")
    var result_parts: [text] = []
    for part in parts:
        if part == "" or part == ".":
            continue
        elif part == "..":
            if result_parts.len() > 0 and result_parts.last() != Some(".."):
                result_parts.pop()
            elif not is_abs:
                result_parts.push("..")
        else:
            result_parts.push(part)
    if result_parts.len() == 0:
        if is_abs:
            return "/"
        return "."
    val normalized = _path_concat_parts(result_parts, "/")
    if is_abs:
        return "/" + normalized
    return normalized

pub fn is_absolute(path: text) -> bool:
    return path.starts_with("/")

pub fn is_relative(path: text) -> bool:
    return not is_absolute(path)

# @tag(path=file_path, ext=file_extension)
pub fn has_extension(path: text, ext: text) -> bool:
    val actual_ext = extension(path)
    var check_ext = ext
    if ext.starts_with("."):
        check_ext = ext.substring(1)
    return actual_ext == check_ext

# @tag(path=file_path, base=base)
pub fn resolve(path: text, base: text) -> text:
    if path.starts_with("/"):
        return normalize(path)
    return normalize(join2(base, path))

# @tag(path=file_path, base=base)
pub fn relative_to(path: text, base: text) -> text:
    val np = normalize(path)
    val nb = normalize(base)
    if np == nb:
        return "."
    if np.starts_with(nb + "/"):
        return np.substring(nb.len() + 1)
    if nb.starts_with(np + "/"):
        val remainder = nb.substring(np.len() + 1)
        val depth = remainder.split("/").len()
        var up_parts: [text] = [".."]
        for x in 1..depth:
            up_parts.push("..")
        return _path_concat_parts(up_parts, "/")
    val pp = np.split("/")
    val bp = nb.split("/")
    var c = 0
    for x in 0..pp.len():
        if c < bp.len() and pp[c] == bp[c]:
            c = c + 1
        else:
            break
    var rel_parts: [text] = []
    for x in c..bp.len():
        if bp[x] != "":
            rel_parts.push("..")
    for x in c..pp.len():
        if pp[x] != "":
            rel_parts.push(pp[x])
    if rel_parts.len() == 0:
        return "."
    return _path_concat_parts(rel_parts, "/")

# Alias: export 'join' pointing to path_join for backward compatibility
fn join(parts: [text]) -> text:
    return path_join(parts)

# ============================================================================
# Convenience Aliases (merged from path_utils.spl)
# ============================================================================

fn get_filename(path: text) -> text:
    """Get the filename from a path (alias for basename)."""
    basename(path)

pub fn dir_name(path: text) -> text:
    """Get the directory name from a path (last component)."""
    basename(path)

pub fn parent_dir(path: text) -> text:
    """Get the parent directory of a path."""
    dirname(path)

pub fn parent_dir_option(path: text) -> text?:
    """Get the parent directory as Option. Returns nil for root paths."""
    val parent = dirname(path)
    if parent == "/" or parent == ".":
        nil
    else:
        parent

# Deprecated: use dir_name instead
pub fn get_dir_name(path: text) -> text:
    dir_name(path)
# Deprecated: use parent_dir instead
pub fn get_parent_dir(path: text) -> text:
    parent_dir(path)
# Deprecated: use parent_dir_option instead
pub fn get_parent_dir_option(path: text) -> text?:
    parent_dir_option(path)

# @tag(base=base, child=child)
pub fn join_path(base: text, child: text) -> text:
    """Join two path components (alias for join2)."""
    join2(base, child)

# Deprecated: use extension instead
pub fn get_extension(path: text) -> text:
    extension(path)

# Deprecated: use stem instead
pub fn get_stem(path: text) -> text:
    stem(path)

pub fn normalize_path(path: text) -> text:
    """Normalize a path, converting backslashes to forward slashes."""
    var norm_parts: [text] = []
    for i in 0..path.len():
        val c = path[i:i + 1]
        if c == "\\":
            norm_parts.push("/")
        else:
            norm_parts.push(c)
    val normalized = _path_concat_parts(norm_parts, "")
    normalize(normalized)

# Deprecated: use is_absolute instead
pub fn is_absolute_path(path: text) -> bool:
    is_absolute(path)

# @tag(path=file_path, base=base)
pub fn make_relative(path: text, base: text) -> text:
    """Convert absolute path to relative from base."""
    val np = normalize_path(path)
    val nb = normalize_path(base)
    if np.starts_with(nb + "/"):
        return np[nb.len() + 1:]
    np

pub fn split_path(path: text) -> [text]:
    """Split path into components (filters out empty parts)."""
    if path == "":
        return []
    val normalized = normalize_path(path)
    val parts = normalized.split("/")
    var result: [text] = []
    for part in parts:
        if part != "" and part != ".":
            result = result.push(part)
    result

