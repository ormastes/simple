# HTTP Path Security — traversal and injection prevention
#
# Validates request paths for static file serving. Rejects directory
# traversal, null bytes, and non-normalized sequences.

# ============================================================================
# Path Validation
# ============================================================================

fn is_safe_static_path(path: text) -> bool:
    if path.length() == 0:
        return false
    if contains_null_byte(path):
        return false
    if contains_traversal(path):
        return false
    if contains_backslash(path):
        return false
    if not starts_with_slash(path):
        return false
    true

fn contains_null_byte(path: text) -> bool:
    var i = 0
    while i < path.length():
        val ch = path[i]
        if ch == "\0":
            return true
        i = i + 1
    false

fn contains_traversal(path: text) -> bool:
    if path.contains(".."):
        return true
    if path.contains("/./"):
        return true
    if path.ends_with("/."):
        return true
    false

fn contains_backslash(path: text) -> bool:
    path.contains("\\")

fn starts_with_slash(path: text) -> bool:
    if path.length() == 0:
        return false
    path[0] == "/"

fn normalize_path(path: text) -> text:
    var segments: [text] = []
    val parts = path.split("/")
    var i = 0
    while i < parts.length():
        val seg = parts[i]
        if seg == "" or seg == ".":
            i = i + 1
            continue
        if seg == "..":
            if segments.len() > 0:
                segments = segments.slice(0, segments.len() - 1)
            i = i + 1
            continue
        segments = segments.push(seg)
        i = i + 1
    "/" + "/".join(segments)

fn validate_static_path(path: text) -> Result<text, text>:
    if not is_safe_static_path(path):
        return Err("path traversal or injection rejected")
    Ok(normalize_path(path))

# ============================================================================
# Exports
# ============================================================================

export is_safe_static_path, contains_null_byte, contains_traversal
export contains_backslash, starts_with_slash, normalize_path, validate_static_path
