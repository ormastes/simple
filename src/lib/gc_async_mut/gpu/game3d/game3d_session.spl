# Game3DSession — 3D game session with scene, asset, animation, physics, and streaming
#
# Wraps GraphicsSession lifecycle for 3D games.
# Modes: "managed_shared", "perf_exclusive" (default for 3D), "legacy_no_session"

use std.io

val GAME3D_ID_BASE: i64 = 3000

class Game3DSession:
    """3D game session tracking scenes, assets, animations, physics, and streaming."""

    session_id: i64
    mode: text
    width: i64
    height: i64
    frame_count: i64
    active_scene_id: i64
    asset_count: i64
    animation_count: i64
    physics_enabled: bool
    fps_target: i64
    frame_time_us: i64
    streaming_active: bool
    active: bool

    static fn create(width: i64, height: i64, mode: text) -> Game3DSession:
        val fps = 60
        val frame_us = 1000000 / fps
        return Game3DSession(
            session_id: GAME3D_ID_BASE,
            mode: mode,
            width: width,
            height: height,
            frame_count: 0,
            active_scene_id: 0,
            asset_count: 0,
            animation_count: 0,
            physics_enabled: false,
            fps_target: fps,
            frame_time_us: frame_us,
            streaming_active: false,
            active: true
        )

    static fn create_managed(width: i64, height: i64) -> Game3DSession:
        return Game3DSession.create(width, height, "managed_shared")

    static fn create_perf(width: i64, height: i64) -> Game3DSession:
        return Game3DSession.create(width, height, "perf_exclusive")

    me begin_frame() -> i64:
        self.frame_count = self.frame_count + 1
        return self.frame_count

    me end_frame(frame_id: i64) -> text:
        return "frame_done:" + frame_id.to_text()

    me set_active_scene(scene_id: i64) -> text:
        self.active_scene_id = scene_id
        return "scene_set:" + scene_id.to_text()

    me load_asset(name: text, asset_type: text) -> i64:
        self.asset_count = self.asset_count + 1
        return self.asset_count

    me start_animation(name: text, target_id: i64) -> i64:
        self.animation_count = self.animation_count + 1
        return self.animation_count

    me enable_physics(enabled: bool):
        self.physics_enabled = enabled

    me enable_streaming(enabled: bool):
        self.streaming_active = enabled

    me update(delta_us: i64) -> text:
        return "updated delta_us=" + delta_us.to_text() + " scene=" + self.active_scene_id.to_text()

    me stats() -> text:
        return "game3d mode=" + self.mode + " frames=" + self.frame_count.to_text() + " scene=" + self.active_scene_id.to_text() + " assets=" + self.asset_count.to_text() + " anims=" + self.animation_count.to_text() + " physics=" + self.physics_enabled.to_text() + " streaming=" + self.streaming_active.to_text() + " fps=" + self.fps_target.to_text()

    me cleanup() -> text:
        self.active = false
        return "game3d_session cleaned up id=" + self.session_id.to_text()
