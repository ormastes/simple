# Backend Acceleration: Vulkan SPIR-V Path
#
# Vulkan backend using SPIR-V shaders. Runtime GLSL compilation is not used.
# Provides clear/rect/readback smoke operations.
#
# Usage:
#   use std.gc_async_mut.gpu.engine2d.backend_accel_vulkan.{
#       VulkanAccelConfig, VulkanAccelPipeline, VulkanAccelCommandBuffer, VulkanAccelBackend}

# ============================================================================
# VulkanAccelConfig
# ============================================================================

class VulkanAccelConfig:
    width: i64
    height: i64
    shader_format: text
    enable_validation: bool
    max_frames_in_flight: i64

    static fn default_config(w: i64, h: i64) -> VulkanAccelConfig:
        VulkanAccelConfig(
            width:                w,
            height:               h,
            shader_format:        "spirv",
            enable_validation:    false,
            max_frames_in_flight: 2
        )

    static fn validation_config(w: i64, h: i64) -> VulkanAccelConfig:
        VulkanAccelConfig(
            width:                w,
            height:               h,
            shader_format:        "spirv",
            enable_validation:    true,
            max_frames_in_flight: 1
        )

    fn is_glsl(self) -> bool:
        self.shader_format == "glsl"

    fn pixel_count(self) -> i64:
        self.width * self.height

    fn to_text(self) -> text:
        "VulkanAccelConfig(" + self.width.to_text() + "x" + self.height.to_text() + " fmt=" + self.shader_format + ")"

# ============================================================================
# VulkanAccelPipeline
# ============================================================================

class VulkanAccelPipeline:
    pipeline_id: i64
    shader_format: text
    is_compute: bool
    is_graphics: bool
    push_constant_size: i64

    static fn create_compute(pid: i64) -> VulkanAccelPipeline:
        VulkanAccelPipeline(
            pipeline_id:        pid,
            shader_format:      "spirv",
            is_compute:         true,
            is_graphics:        false,
            push_constant_size: 16
        )

    static fn create_graphics(pid: i64) -> VulkanAccelPipeline:
        VulkanAccelPipeline(
            pipeline_id:        pid,
            shader_format:      "spirv",
            is_compute:         false,
            is_graphics:        true,
            push_constant_size: 64
        )

    fn is_valid(self) -> bool:
        self.pipeline_id != 0

    fn shader_is_spirv(self) -> bool:
        self.shader_format == "spirv"

    fn to_text(self) -> text:
        var kind = "graphics"
        if self.is_compute:
            kind = "compute"
        "VulkanAccelPipeline(id=" + self.pipeline_id.to_text() + " kind=" + kind + " fmt=" + self.shader_format + ")"

# ============================================================================
# VulkanAccelCommandBuffer
# ============================================================================

class VulkanAccelCommandBuffer:
    cmd_id: i64
    recording: bool
    command_count: i64
    pipeline_id: i64

    static fn create(cid: i64) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(
            cmd_id:        cid,
            recording:     false,
            command_count: 0,
            pipeline_id:   0
        )

    fn begin(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(
            cmd_id:        self.cmd_id,
            recording:     true,
            command_count: self.command_count,
            pipeline_id:   self.pipeline_id
        )

    fn end(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(
            cmd_id:        self.cmd_id,
            recording:     false,
            command_count: self.command_count,
            pipeline_id:   self.pipeline_id
        )

    fn record_clear(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(
            cmd_id:        self.cmd_id,
            recording:     self.recording,
            command_count: self.command_count + 1,
            pipeline_id:   self.pipeline_id
        )

    fn record_rect(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(
            cmd_id:        self.cmd_id,
            recording:     self.recording,
            command_count: self.command_count + 1,
            pipeline_id:   self.pipeline_id
        )

    fn is_recording(self) -> bool:
        self.recording

    fn to_text(self) -> text:
        "VulkanAccelCommandBuffer(id=" + self.cmd_id.to_text() + " cmds=" + self.command_count.to_text() + ")"

# ============================================================================
# VulkanAccelBackend
# ============================================================================

class VulkanAccelBackend:
    config: VulkanAccelConfig
    initialized: bool
    pipeline: VulkanAccelPipeline
    readback_buf_size: i64

    static fn create(w: i64, h: i64) -> VulkanAccelBackend:
        VulkanAccelBackend(
            config:           VulkanAccelConfig.default_config(w, h),
            initialized:      false,
            pipeline:         VulkanAccelPipeline.create_graphics(0),
            readback_buf_size: 0
        )

    fn init(self) -> VulkanAccelBackend:
        if self.config.is_glsl():
            return self
        VulkanAccelBackend(
            config:            self.config,
            initialized:       true,
            pipeline:          VulkanAccelPipeline.create_graphics(1001),
            readback_buf_size: self.config.pixel_count() * 4
        )

    fn is_ready(self) -> bool:
        self.initialized and self.pipeline.is_valid()

    fn shader_format(self) -> text:
        self.config.shader_format

    fn clear(self, color: i64) -> bool:
        self.initialized

    fn draw_rect(self, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool:
        self.initialized

    fn readback_size(self) -> i64:
        self.readback_buf_size

    fn name(self) -> text:
        "vulkan-accel"

    fn to_text(self) -> text:
        "VulkanAccelBackend(" + self.config.to_text() + " ready=" + self.initialized.to_text() + ")"
