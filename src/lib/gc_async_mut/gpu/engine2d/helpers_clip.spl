"""2D Engine — Shared Clip & Bounds Helpers

Pure functions for clip-rect testing, mask checking, and bounds validation.
No backend state or SFFI dependencies. All backends share this logic.

Usage:
    use std.gpu.engine2d.helpers_clip.{
        clip_point_in_bounds, clip_rect_intersect, mask_blocks_at
    }

@tag:stdlib
@tag:gpu
"""

# ============================================================================
# Bounds Checking
# ============================================================================

fn clip_point_in_bounds(x: i32, y: i32, w: i32, h: i32) -> bool:
    """Return true if (x, y) lies within the framebuffer [0, w) x [0, h)."""
    x >= 0 and y >= 0 and x < w and y < h

fn clip_point_in_rect(x: i32, y: i32, rx: i32, ry: i32, rw: i32, rh: i32) -> bool:
    """Return true if (x, y) lies within clip rect (rx, ry, rw, rh)."""
    x >= rx and x < rx + rw and y >= ry and y < ry + rh

fn clip_pixel_allowed(
    x: i32, y: i32,
    fb_w: i32, fb_h: i32,
    clip_enabled: bool, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32
) -> bool:
    """Return true if pixel (x, y) passes framebuffer bounds and clip rect.

    This is the combined check used by _set_pixel / _sw_set_pixel in each
    backend. Extracting it avoids duplicating the three-condition guard.
    """
    if x < 0 or y < 0 or x >= fb_w or y >= fb_h:
        return false
    if clip_enabled:
        if x < clip_x or x >= clip_x + clip_w or y < clip_y or y >= clip_y + clip_h:
            return false
    true

# ============================================================================
# Rect Intersection
# ============================================================================

fn rect_intersect(
    ax: i32, ay: i32, aw: i32, ah: i32,
    bx: i32, by: i32, bw: i32, bh: i32,
    out_x: i32, out_y: i32, out_w: i32, out_h: i32
) -> bool:
    """Compute the intersection of two rects. Returns false if disjoint.

    On success, writes the intersection into (out_x, out_y, out_w, out_h).
    Callers must use return value to guard reads of the out_ parameters.

    Note: Simple does not support out-parameters by reference; callers
    should call rect_intersect_x / _y / _w / _h for each component.
    """
    val ix1 = if ax > bx: ax else: bx
    val iy1 = if ay > by: ay else: by
    val ix2_a = ax + aw
    val ix2_b = bx + bw
    val ix2 = if ix2_a < ix2_b: ix2_a else: ix2_b
    val iy2_a = ay + ah
    val iy2_b = by + bh
    val iy2 = if iy2_a < iy2_b: iy2_a else: iy2_b
    ix2 > ix1 and iy2 > iy1

fn rect_intersect_x(ax: i32, bx: i32) -> i32:
    """Left edge of intersection (max of two left edges)."""
    if ax > bx: ax else: bx

fn rect_intersect_y(ay: i32, by: i32) -> i32:
    """Top edge of intersection (max of two top edges)."""
    if ay > by: ay else: by

fn rect_intersect_w(ax: i32, aw: i32, bx: i32, bw: i32) -> i32:
    """Width of intersection (may be <= 0 if disjoint — check before use)."""
    val ix1 = if ax > bx: ax else: bx
    val ix2_a = ax + aw
    val ix2_b = bx + bw
    val ix2 = if ix2_a < ix2_b: ix2_a else: ix2_b
    ix2 - ix1

fn rect_intersect_h(ay: i32, ah: i32, by: i32, bh: i32) -> i32:
    """Height of intersection (may be <= 0 if disjoint — check before use)."""
    val iy1 = if ay > by: ay else: by
    val iy2_a = ay + ah
    val iy2_b = by + bh
    val iy2 = if iy2_a < iy2_b: iy2_a else: iy2_b
    iy2 - iy1

fn clip_rect_to_viewport(
    x: i32, y: i32, w: i32, h: i32,
    vp_w: i32, vp_h: i32
) -> bool:
    """Return true if rect (x, y, w, h) overlaps viewport (0, 0, vp_w, vp_h)."""
    x < vp_w and y < vp_h and x + w > 0 and y + h > 0

# ============================================================================
# Mask Checking
# ============================================================================

fn mask_blocks_at(mask_buf: [u8], mask_w: i32, x: i32, y: i32) -> bool:
    """Return true if the mask occludes pixel (x, y).

    A mask value of 0 means blocked (occluded). Returns false (not blocked)
    when the mask buffer is empty or the coordinate is out of range.
    """
    if mask_buf.len() == 0:
        return false
    val mi = y * mask_w + x
    if mi < 0 or mi >= mask_buf.len():
        return false
    mask_buf[mi] == 0u8

# ============================================================================
# Pixel Index
# ============================================================================

fn pixel_index(x: i32, y: i32, stride: i32) -> i32:
    """Compute flat pixel buffer index for (x, y) with given row stride."""
    y * stride + x
