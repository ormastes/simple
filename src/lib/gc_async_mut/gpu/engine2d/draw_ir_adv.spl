# Engine2D advanced Draw IR executor.
#
# This is the first Simple2D-facing Draw IR boundary. It executes the shared
# Draw IR contract through the existing Engine2D facade and keeps GPU selection
# as metadata/fallback policy; real GPU plugin migration is a later backend job.

use common.ui.draw_ir.{
    DrawIrBatch,
    DrawIrCommand,
    DrawIrComposition,
    Simple2dDrawIrCompositionPlan,
    Simple2dDrawIrPlan,
    simple_2d_draw_ir_adv_composition_plan,
    simple_2d_draw_ir_adv_plan
}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.generated_kernel_args.{generated_glyph_raster_staging_create, generated_glyph_raster_staging_free}
use std.gc_async_mut.gpu.engine2d.helpers_text.{TextBlitCache}
use std.gc_async_mut.gpu.engine2d.vector_font_offload.{VectorFontOffloadEvidence, vector_font_current_offload_evidence}
use std.gc_async_mut.text_layout.font_rasterizer.{reset_vector_font_raster_stats, reset_bitmap_font_raster_stats, bitmap_font_accelerator_stats}

val ENGINE2D_DRAW_IR_COMMAND_RECT: text = "rect"
val ENGINE2D_DRAW_IR_COMMAND_TEXT: text = "text"

struct Engine2dDrawIrAdvResult:
    schema: text
    unit_id: text
    selected_backend: text
    fallback_required: bool
    fallback_reason: text
    rendered_command_count: i32
    skipped_command_count: i32
    text_command_count: i32
    last_text_font_size: i32
    font_offload_status: text
    font_offload_reason: text
    font_gpu_glyph_returned: bool
    font_production_ready: bool
    font_generated_args_ready: bool
    font_generated_args_reason: text
    font_text_cache_hits: i32
    font_text_cache_misses: i32
    pixels: [u32]

class Engine2dFontOffloadSummary:
    status: text
    reason: text
    gpu_glyph_returned: bool
    production_ready: bool

fn _engine2d_font_offload_summary(evidence: VectorFontOffloadEvidence) -> Engine2dFontOffloadSummary:
    val bitmap = bitmap_font_accelerator_stats()
    val bitmap_gpu_glyph_returned = bitmap.gpu_returned_glyphs > 0 and bitmap.gpu_returned_glyph_pixels > 0
    if bitmap.cpu_fallback_hits > 0:
        return Engine2dFontOffloadSummary(
            status: "cpu-fallback",
            reason: if bitmap.unavailable_reason != "": bitmap.unavailable_reason else: "bitmap-font-gpu-glyph-return-missing",
            gpu_glyph_returned: false,
            production_ready: false
        )
    if bitmap_gpu_glyph_returned:
        return Engine2dFontOffloadSummary(
            status: "gpu-glyph-returned",
            reason: bitmap.unavailable_reason,
            gpu_glyph_returned: true,
            production_ready: true
        )
    Engine2dFontOffloadSummary(
        status: evidence.status_code,
        reason: evidence.reason,
        gpu_glyph_returned: evidence.gpu_glyph_returned,
        production_ready: evidence.production_ready
    )

fn _engine2d_draw_ir_result_from_plan(plan: Simple2dDrawIrPlan, rendered: i32, skipped: i32, text_count: i32, last_font_size: i32, font_status: text, font_reason: text, font_gpu_glyph_returned: bool, font_production_ready: bool, font_generated_args_ready: bool, font_generated_args_reason: text, font_text_cache_hits: i32, font_text_cache_misses: i32, pixels: [u32]) -> Engine2dDrawIrAdvResult:
    Engine2dDrawIrAdvResult(
        schema: plan.schema,
        unit_id: plan.batch_id,
        selected_backend: plan.selected_backend,
        fallback_required: plan.fallback_required,
        fallback_reason: plan.fallback_reason,
        rendered_command_count: rendered,
        skipped_command_count: skipped,
        text_command_count: text_count,
        last_text_font_size: last_font_size,
        font_offload_status: font_status,
        font_offload_reason: font_reason,
        font_gpu_glyph_returned: font_gpu_glyph_returned,
        font_production_ready: font_production_ready,
        font_generated_args_ready: font_generated_args_ready,
        font_generated_args_reason: font_generated_args_reason,
        font_text_cache_hits: font_text_cache_hits,
        font_text_cache_misses: font_text_cache_misses,
        pixels: pixels
    )

fn _engine2d_draw_ir_result_from_composition_plan(plan: Simple2dDrawIrCompositionPlan, rendered: i32, skipped: i32, text_count: i32, last_font_size: i32, font_status: text, font_reason: text, font_gpu_glyph_returned: bool, font_production_ready: bool, font_generated_args_ready: bool, font_generated_args_reason: text, font_text_cache_hits: i32, font_text_cache_misses: i32, pixels: [u32]) -> Engine2dDrawIrAdvResult:
    Engine2dDrawIrAdvResult(
        schema: plan.schema,
        unit_id: plan.composition_id,
        selected_backend: plan.selected_backend,
        fallback_required: plan.fallback_required,
        fallback_reason: plan.fallback_reason,
        rendered_command_count: rendered,
        skipped_command_count: skipped,
        text_command_count: text_count,
        last_text_font_size: last_font_size,
        font_offload_status: font_status,
        font_offload_reason: font_reason,
        font_gpu_glyph_returned: font_gpu_glyph_returned,
        font_production_ready: font_production_ready,
        font_generated_args_ready: font_generated_args_ready,
        font_generated_args_reason: font_generated_args_reason,
        font_text_cache_hits: font_text_cache_hits,
        font_text_cache_misses: font_text_cache_misses,
        pixels: pixels
    )

fn _draw_ir_style_value(command: DrawIrCommand, key: text) -> text:
    var idx = 0
    val n = command.computed_style.len()
    while idx < n:
        if command.computed_style[idx].key == key:
            return command.computed_style[idx].value
        idx = idx + 1
    ""

fn _positive_i32_from_text(raw: text, fallback: i32) -> i32:
    var value = 0
    var idx = 0
    var found = false
    val n = raw.len()
    while idx < n:
        val code = raw.char_code_at(idx) as i32
        if code >= 48 and code <= 57:
            value = value * 10 + (code - 48)
            found = true
        elif found:
            idx = n
        idx = idx + 1
    if found and value > 0:
        return value
    fallback

fn _draw_ir_text_font_size(command: DrawIrCommand) -> i32:
    _positive_i32_from_text(_draw_ir_style_value(command, "font-size"), 12)

fn _draw_ir_text_extent(value: i32, fallback: i32) -> i64:
    if value > 0:
        return value as i64
    fallback as i64

fn engine2d_draw_ir_adv_batch(engine: Engine2D, batch: DrawIrBatch, gpu_available: bool) -> Engine2dDrawIrAdvResult:
    val plan = simple_2d_draw_ir_adv_plan(batch, gpu_available)
    if batch.embedding.clip:
        engine.set_clip(batch.embedding.x, batch.embedding.y, batch.embedding.width, batch.embedding.height)
    var rendered = 0
    var skipped = 0
    var text_count = 0
    var last_font_size = 0
    var font_status = "no-text-commands"
    var font_reason = ""
    var font_gpu_glyph_returned = false
    var font_production_ready = false
    var font_generated_args_ready = false
    var font_generated_args_reason = "no-text-commands"
    var font_cache = TextBlitCache.new()
    val backend_name = engine.backend_name()
    val generated_glyph_args_enabled = gpu_available and plan.selected_backend != "cpu"
    reset_vector_font_raster_stats()
    reset_bitmap_font_raster_stats()
    for command in batch.commands:
        val x = batch.embedding.x + command.x
        val y = batch.embedding.y + command.y
        if command.kind == ENGINE2D_DRAW_IR_COMMAND_RECT:
            engine.draw_rect_filled(x, y, command.width, command.height, command.color)
            rendered = rendered + 1
        elif command.kind == ENGINE2D_DRAW_IR_COMMAND_TEXT:
            val font_size = _draw_ir_text_font_size(command)
            val text_buf = font_cache.transparent_blit_buffer(command.text_value, command.color, font_size)
            if not text_buf.is_empty():
                engine.draw_image(x, y, text_buf.width, text_buf.height, text_buf.pixels)
            val offload_width = _draw_ir_text_extent(text_buf.width, command.width)
            val offload_height = _draw_ir_text_extent(text_buf.height, command.height)
            val staging = generated_glyph_raster_staging_create(offload_width, offload_height, font_size as i64, generated_glyph_args_enabled)
            val evidence = vector_font_current_offload_evidence(backend_name, offload_width, offload_height, generated_glyph_args_enabled, generated_glyph_args_enabled, staging.args_ptr())
            text_count = text_count + 1
            last_font_size = font_size
            font_generated_args_ready = staging.ready()
            font_generated_args_reason = staging.reason()
            val offload = _engine2d_font_offload_summary(evidence)
            font_status = offload.status
            font_reason = offload.reason
            font_gpu_glyph_returned = offload.gpu_glyph_returned
            font_production_ready = offload.production_ready
            generated_glyph_raster_staging_free(staging)
            rendered = rendered + 1
        else:
            skipped = skipped + 1
    if batch.embedding.clip:
        engine.clear_clip()
    _engine2d_draw_ir_result_from_plan(plan, rendered, skipped, text_count, last_font_size, font_status, font_reason, font_gpu_glyph_returned, font_production_ready, font_generated_args_ready, font_generated_args_reason, font_cache.cache_hits, font_cache.cache_misses, engine.read_pixels())

fn engine2d_draw_ir_adv_composition(engine: Engine2D, composition: DrawIrComposition, gpu_available: bool) -> Engine2dDrawIrAdvResult:
    val plan = simple_2d_draw_ir_adv_composition_plan(composition, gpu_available)
    var rendered = 0
    var skipped = 0
    var text_count = 0
    var last_font_size = 0
    var font_status = "no-text-commands"
    var font_reason = ""
    var font_gpu_glyph_returned = false
    var font_production_ready = false
    var font_generated_args_ready = false
    var font_generated_args_reason = "no-text-commands"
    var font_cache = TextBlitCache.new()
    val backend_name = engine.backend_name()
    val generated_glyph_args_enabled = gpu_available and plan.selected_backend != "cpu"
    reset_vector_font_raster_stats()
    reset_bitmap_font_raster_stats()
    for batch in composition.batches:
        if batch.embedding.clip:
            engine.set_clip(batch.embedding.x, batch.embedding.y, batch.embedding.width, batch.embedding.height)
        for command in batch.commands:
            val x = batch.embedding.x + command.x
            val y = batch.embedding.y + command.y
            if command.kind == ENGINE2D_DRAW_IR_COMMAND_RECT:
                engine.draw_rect_filled(x, y, command.width, command.height, command.color)
                rendered = rendered + 1
            elif command.kind == ENGINE2D_DRAW_IR_COMMAND_TEXT:
                val font_size = _draw_ir_text_font_size(command)
                val text_buf = font_cache.transparent_blit_buffer(command.text_value, command.color, font_size)
                if not text_buf.is_empty():
                    engine.draw_image(x, y, text_buf.width, text_buf.height, text_buf.pixels)
                val offload_width = _draw_ir_text_extent(text_buf.width, command.width)
                val offload_height = _draw_ir_text_extent(text_buf.height, command.height)
                val staging = generated_glyph_raster_staging_create(offload_width, offload_height, font_size as i64, generated_glyph_args_enabled)
                val evidence = vector_font_current_offload_evidence(backend_name, offload_width, offload_height, generated_glyph_args_enabled, generated_glyph_args_enabled, staging.args_ptr())
                text_count = text_count + 1
                last_font_size = font_size
                font_generated_args_ready = staging.ready()
                font_generated_args_reason = staging.reason()
                val offload = _engine2d_font_offload_summary(evidence)
                font_status = offload.status
                font_reason = offload.reason
                font_gpu_glyph_returned = offload.gpu_glyph_returned
                font_production_ready = offload.production_ready
                generated_glyph_raster_staging_free(staging)
                rendered = rendered + 1
            else:
                skipped = skipped + 1
        if batch.embedding.clip:
            engine.clear_clip()
    _engine2d_draw_ir_result_from_composition_plan(plan, rendered, skipped, text_count, last_font_size, font_status, font_reason, font_gpu_glyph_returned, font_production_ready, font_generated_args_ready, font_generated_args_reason, font_cache.cache_hits, font_cache.cache_misses, engine.read_pixels())
