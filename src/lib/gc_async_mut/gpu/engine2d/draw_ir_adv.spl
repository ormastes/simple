# Engine2D advanced Draw IR executor.
#
# This is the first Simple2D-facing Draw IR boundary. It executes the shared
# Draw IR contract through the existing Engine2D facade and keeps GPU selection
# as metadata/fallback policy; real GPU plugin migration is a later backend job.

use common.ui.draw_ir.{
    DRAW_IR_BACKEND_GPU,
    DRAW_IR_COMMAND_RECT,
    DRAW_IR_COMMAND_TEXT,
    DrawIrBatch,
    DrawIrComposition,
    Simple2dDrawIrCompositionPlan,
    Simple2dDrawIrPlan,
    simple_2d_draw_ir_adv_composition_plan,
    simple_2d_draw_ir_adv_plan
}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_lane.{
    ENGINE2D_HOST_GPU_LANE_GPU,
    ENGINE2D_HOST_GPU_LANE_HOST,
    engine2d_host_gpu_lane_schedule
}
use std.gc_async_mut.gpu.engine2d.host_gpu_event_queue.{
    Engine2dHostGpuRuntimeDrainResult,
    Engine2dHostGpuRuntimeQueue,
    Engine2dHostGpuRuntimeSubmitResult,
    engine2d_host_gpu_event,
    engine2d_host_gpu_event_handler_decision,
    engine2d_host_gpu_event_submit_to_runtime,
    engine2d_host_gpu_runtime_drain
}

struct Engine2dDrawIrAdvResult:
    schema: text
    unit_id: text
    selected_backend: text
    fallback_required: bool
    fallback_reason: text
    rendered_command_count: i32
    skipped_command_count: i32
    pixels: [u32]

struct Engine2dDrawIrRuntimeQueueResult:
    render: Engine2dDrawIrAdvResult
    runtime_submit: Engine2dHostGpuRuntimeSubmitResult
    runtime_drain: Engine2dHostGpuRuntimeDrainResult
    queued_for_gpu: bool

fn _engine2d_draw_ir_empty_submit(unit_id: text, status: text, diagnostic: text) -> Engine2dHostGpuRuntimeSubmitResult:
    Engine2dHostGpuRuntimeSubmitResult(submitted: false, status: status, queue_handle: 0, event_id: unit_id, packet_id: 0, packet_bytes: 0, diagnostic: diagnostic)

fn _engine2d_draw_ir_empty_drain(status: text, diagnostic: text) -> Engine2dHostGpuRuntimeDrainResult:
    Engine2dHostGpuRuntimeDrainResult(drained: 0, status: status, queue_handle: 0, submitted_count: 0, completed_count: 0, last_status_code: 0, diagnostic: diagnostic)

fn _engine2d_draw_ir_result_from_plan(plan: Simple2dDrawIrPlan, rendered: i32, skipped: i32, pixels: [u32]) -> Engine2dDrawIrAdvResult:
    Engine2dDrawIrAdvResult(
        schema: plan.schema,
        unit_id: plan.batch_id,
        selected_backend: plan.selected_backend,
        fallback_required: plan.fallback_required,
        fallback_reason: plan.fallback_reason,
        rendered_command_count: rendered,
        skipped_command_count: skipped,
        pixels: pixels
    )

fn _engine2d_draw_ir_result_from_composition_plan(plan: Simple2dDrawIrCompositionPlan, rendered: i32, skipped: i32, pixels: [u32]) -> Engine2dDrawIrAdvResult:
    Engine2dDrawIrAdvResult(
        schema: plan.schema,
        unit_id: plan.composition_id,
        selected_backend: plan.selected_backend,
        fallback_required: plan.fallback_required,
        fallback_reason: plan.fallback_reason,
        rendered_command_count: rendered,
        skipped_command_count: skipped,
        pixels: pixels
    )

fn engine2d_draw_ir_adv_batch(engine: Engine2D, batch: DrawIrBatch, gpu_available: bool) -> Engine2dDrawIrAdvResult:
    val plan = simple_2d_draw_ir_adv_plan(batch, gpu_available)
    if batch.embedding.clip:
        engine.set_clip(batch.embedding.x, batch.embedding.y, batch.embedding.width, batch.embedding.height)
    var rendered = 0
    var skipped = 0
    for command in batch.commands:
        val x = batch.embedding.x + command.x
        val y = batch.embedding.y + command.y
        if command.kind == DRAW_IR_COMMAND_RECT:
            engine.draw_rect_filled(x, y, command.width, command.height, command.color)
            rendered = rendered + 1
        elif command.kind == DRAW_IR_COMMAND_TEXT:
            engine.draw_text(x, y, command.text_value, command.color, 12)
            rendered = rendered + 1
        else:
            skipped = skipped + 1
    if batch.embedding.clip:
        engine.clear_clip()
    _engine2d_draw_ir_result_from_plan(plan, rendered, skipped, engine.read_pixels())

fn engine2d_draw_ir_adv_batch_runtime_queue(engine: Engine2D, batch: DrawIrBatch, gpu_available: bool, queue: Engine2dHostGpuRuntimeQueue) -> Engine2dDrawIrRuntimeQueueResult:
    val plan = simple_2d_draw_ir_adv_plan(batch, gpu_available)
    var runtime_submit = _engine2d_draw_ir_empty_submit(batch.batch_id, "host", "Draw IR batch selected CPU path")
    var runtime_drain = _engine2d_draw_ir_empty_drain("empty", "runtime queue not used")
    var queued_for_gpu = false
    if plan.selected_backend == DRAW_IR_BACKEND_GPU:
        val packet_bytes = plan.command_count * 64
        val lane_result = engine2d_host_gpu_lane_schedule(
            ENGINE2D_HOST_GPU_LANE_HOST,
            ENGINE2D_HOST_GPU_LANE_GPU,
            "draw_ir_delta",
            packet_bytes,
            queue.max_packet_bytes,
            false,
            false,
            queue.runtime_available,
            plan.command_count
        )
        val event = engine2d_host_gpu_event(batch.batch_id, ENGINE2D_HOST_GPU_LANE_GPU, "draw_ir_delta", packet_bytes, queue.max_packet_bytes, false, false, false, queue.runtime_available)
        val decision = engine2d_host_gpu_event_handler_decision(event, lane_result)
        runtime_submit = engine2d_host_gpu_event_submit_to_runtime(queue, decision, lane_result)
        queued_for_gpu = runtime_submit.submitted
    val render = engine2d_draw_ir_adv_batch(engine, batch, gpu_available)
    if queued_for_gpu:
        runtime_drain = engine2d_host_gpu_runtime_drain(queue, 1)
    Engine2dDrawIrRuntimeQueueResult(render: render, runtime_submit: runtime_submit, runtime_drain: runtime_drain, queued_for_gpu: queued_for_gpu)

fn engine2d_draw_ir_adv_composition(engine: Engine2D, composition: DrawIrComposition, gpu_available: bool) -> Engine2dDrawIrAdvResult:
    val plan = simple_2d_draw_ir_adv_composition_plan(composition, gpu_available)
    var rendered = 0
    var skipped = 0
    for batch in composition.batches:
        if batch.embedding.clip:
            engine.set_clip(batch.embedding.x, batch.embedding.y, batch.embedding.width, batch.embedding.height)
        for command in batch.commands:
            val x = batch.embedding.x + command.x
            val y = batch.embedding.y + command.y
            if command.kind == DRAW_IR_COMMAND_RECT:
                engine.draw_rect_filled(x, y, command.width, command.height, command.color)
                rendered = rendered + 1
            elif command.kind == DRAW_IR_COMMAND_TEXT:
                engine.draw_text(x, y, command.text_value, command.color, 12)
                rendered = rendered + 1
            else:
                skipped = skipped + 1
        if batch.embedding.clip:
            engine.clear_clip()
    _engine2d_draw_ir_result_from_composition_plan(plan, rendered, skipped, engine.read_pixels())

export Engine2dDrawIrAdvResult
export Engine2dDrawIrRuntimeQueueResult
export engine2d_draw_ir_adv_batch
export engine2d_draw_ir_adv_batch_runtime_queue
export engine2d_draw_ir_adv_composition
