# Metal Backend Proof
#
# Proves Metal command queue, pipeline, dispatch, completion, and readback.
# Reports typed diagnostics on non-macOS platforms.
#
# Usage:
#   use std.gpu.engine2d.backend_metal_proof.{MetalProofBackend, MetalDiagnostics}

extern fn rt_metal_create_device() -> i64
extern fn rt_metal_device_name(handle: i64) -> text
extern fn rt_metal_is_available() -> bool
extern fn rt_metal_create_queue(handle: i64) -> text
extern fn rt_metal_create_pipeline(handle: i64, shader: text) -> text
extern fn rt_metal_dispatch(handle: i64, w: i64, h: i64) -> text
extern fn rt_metal_wait(handle: i64) -> text
extern fn rt_metal_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text
extern fn rt_metal_cleanup(handle: i64) -> i64

# ============================================================================
# MetalDiagnostics
# ============================================================================

class MetalDiagnostics:
    """Typed diagnostics for Metal device availability and capabilities."""

    device_name: text
    available: bool
    supports_gpu_family_apple7: bool
    max_buffer_length: i64
    error_message: text

    static fn probe() -> MetalDiagnostics:
        val avail = rt_metal_is_available()
        if avail == false:
            return MetalDiagnostics(
                device_name: "none",
                available: false,
                supports_gpu_family_apple7: false,
                max_buffer_length: 0,
                error_message: "Metal requires macOS"
            )
        val handle = rt_metal_create_device()
        if handle == 0:
            return MetalDiagnostics(
                device_name: "none",
                available: false,
                supports_gpu_family_apple7: false,
                max_buffer_length: 0,
                error_message: "rt_metal_create_device returned null handle"
            )
        val name = rt_metal_device_name(handle)
        return MetalDiagnostics(
            device_name: name,
            available: true,
            supports_gpu_family_apple7: false,
            max_buffer_length: 1073741824,
            error_message: ""
        )

    me is_available() -> bool:
        return self.available

    me summary() -> text:
        if self.available == false:
            return "Metal unavailable: " + self.error_message
        return "Metal device: " + self.device_name

# ============================================================================
# MetalProofBackend
# ============================================================================

class MetalProofBackend:
    """Proof backend exercising Metal command queue, pipeline, dispatch, and readback."""

    handle: i64
    diagnostics: MetalDiagnostics
    initialized: bool
    command_count: i64
    dispatch_count: i64
    readback_count: i64
    last_error: text

    static fn create() -> MetalProofBackend:
        val diag = MetalDiagnostics.probe()
        return MetalProofBackend(
            handle: 0,
            diagnostics: diag,
            initialized: false,
            command_count: 0,
            dispatch_count: 0,
            readback_count: 0,
            last_error: ""
        )

    me init_device() -> text:
        if self.diagnostics.available == false:
            self.last_error = self.diagnostics.error_message
            return "error: " + self.last_error
        val h = rt_metal_create_device()
        if h == 0:
            self.last_error = "device creation failed"
            return "error: " + self.last_error
        self.handle = h
        self.initialized = true
        return "ok: device=" + self.diagnostics.device_name

    me create_command_queue() -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val result = rt_metal_create_queue(self.handle)
        self.command_count = self.command_count + 1
        return result

    me create_pipeline(shader_name: text) -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val result = rt_metal_create_pipeline(self.handle, shader_name)
        return result

    me dispatch_compute(width: i64, height: i64) -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val result = rt_metal_dispatch(self.handle, width, height)
        self.dispatch_count = self.dispatch_count + 1
        return result

    me wait_completion() -> text:
        if self.initialized == false:
            return "error: device not initialized"
        return rt_metal_wait(self.handle)

    me readback(x: i64, y: i64, w: i64, h: i64) -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val result = rt_metal_readback(self.handle, x, y, w, h)
        self.readback_count = self.readback_count + 1
        return result

    me stats() -> text:
        return (
            "commands=" + self.command_count +
            " dispatches=" + self.dispatch_count +
            " readbacks=" + self.readback_count
        )

    me cleanup() -> text:
        if self.initialized == false:
            return "ok: nothing to clean up"
        val code = rt_metal_cleanup(self.handle)
        self.handle = 0
        self.initialized = false
        if code == 0:
            return "ok: cleanup complete"
        return "warn: cleanup returned " + code
