# Backend Session Abstractions
#
# Shared-session types that allow multiple Engine2D surfaces to share
# a single GPU context (device + shader library + compute pipelines).
#
# Usage:
#   use std.gpu.engine2d.backend_session.{BackendSessionMode, BackendSessionKind,
#       BackendSessionPolicy, BackendSessionHandle,
#       backend_session_create, backend_session_retain, backend_session_release}

# ============================================================================
# Enums
# ============================================================================

enum BackendSessionMode:
    """Controls how a session is owned relative to Engine2D surfaces."""
    LegacyNoSession    # One hidden session per surface — backward compatible
    ManagedShared      # Session is shared and reference-counted
    PerfExclusive      # Session is exclusively owned for maximum performance

enum BackendSessionKind:
    """Identifies the GPU/compute backend technology."""
    Cpu
    Cuda
    Vulkan
    Metal
    WebGpu

# ============================================================================
# BackendSessionPolicy
# ============================================================================

class BackendSessionPolicy:
    """Configuration controlling how a backend session is created and managed."""
    mode: BackendSessionMode
    allow_fallback: bool          # Fall back to Cpu if requested kind unavailable
    strict_backend: bool          # Fail hard if requested kind not available
    allow_readback: bool          # Allow GPU-to-host readback (slower, enables read_pixels)
    perf_counters_enabled: bool   # Enable internal timing/perf counters

    static fn default_for(kind: BackendSessionKind) -> BackendSessionPolicy:
        """Sensible defaults: managed-shared, fallback on, readback on, counters off."""
        BackendSessionPolicy(
            mode: BackendSessionMode.ManagedShared,
            allow_fallback: true,
            strict_backend: false,
            allow_readback: true,
            perf_counters_enabled: false
        )

# ============================================================================
# BackendSessionHandle
# ============================================================================

class BackendSessionHandle:
    """Lightweight metadata descriptor for a live backend session.

    The handle carries identity information (id, kind, mode, device name,
    generation) but does not own GPU resources directly. Use MetalSession
    (or the equivalent for other backends) to hold the actual GPU objects.
    """
    id: i64
    kind: BackendSessionKind
    mode: BackendSessionMode
    device_name: text
    generation: i64

    static fn null() -> BackendSessionHandle:
        """A sentinel handle representing 'no session'."""
        BackendSessionHandle(
            id: 0,
            kind: BackendSessionKind.Cpu,
            mode: BackendSessionMode.LegacyNoSession,
            device_name: "",
            generation: 0
        )

    fn is_null() -> bool:
        self.id == 0

# ============================================================================
# Session lifecycle helpers
# ============================================================================

# Simple global counter for handle IDs.  Production code would use an
# atomic or a registry; this is sufficient for the session-sharing MVP.
extern fn rt_time_now_monotonic_ms() -> i64

fn backend_session_create(kind: BackendSessionKind, policy: BackendSessionPolicy) -> BackendSessionHandle:
    """Allocate a new session handle.

    The caller is responsible for creating the concrete GPU session object
    (e.g. MetalSession) and associating it externally.  This function only
    mints the handle metadata.
    """
    val id = rt_time_now_monotonic_ms()
    BackendSessionHandle(
        id: id,
        kind: kind,
        mode: policy.mode,
        device_name: "default",
        generation: 0
    )

fn backend_session_retain(handle: BackendSessionHandle) -> BackendSessionHandle:
    """Return a copy of the handle with an incremented generation counter.

    Since BackendSessionHandle is a value type (class-by-value semantics in
    Simple), the actual refcount lives in the concrete session object
    (MetalSession.refcount).  This function just bumps the generation to
    mark that another owner has taken a reference.
    """
    BackendSessionHandle(
        id: handle.id,
        kind: handle.kind,
        mode: handle.mode,
        device_name: handle.device_name,
        generation: handle.generation + 1
    )

fn backend_session_release(handle: BackendSessionHandle):
    """Signal that the caller is releasing its reference.

    The concrete session object (MetalSession) tracks the real refcount and
    will clean up GPU resources when the count reaches zero.  Nothing to do
    here for the pure-handle path.
    """
    pass_do_nothing
