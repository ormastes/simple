# 2D Engine — Intel oneAPI GPU Backend
#
# Hardware-accelerated 2D rendering using Intel oneAPI Level Zero with
# SPIR-V compute kernels. Each draw operation dispatches a compute kernel
# operating on a device-side framebuffer. present() copies the GPU
# framebuffer back to host memory for display.
#
# Requires Intel GPU with oneAPI toolkit / Level Zero runtime.
#
# Architecture:
#   - Framebuffer lives in device memory (d_framebuffer)
#   - SPIR-V modules are compiled at init() time
#   - Each draw call submits a kernel to the command queue
#   - present() copies device framebuffer to host buffer
#   - Text rendering falls back to CPU-side bitmap font + upload
#
# Usage:
#   use std.gpu.engine2d.backend_intel.{IntelBackend}

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, render_text_to_buffer}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.gc_async_mut.io.oneapi_ffi.{
    oneapi_available, oneapi_init, oneapi_device_count,
    oneapi_alloc_device, oneapi_free,
    oneapi_copy_to_device, oneapi_copy_from_device,
    oneapi_memset, oneapi_sync,
    oneapi_compile_spirv, oneapi_compile_opencl, oneapi_unload,
    oneapi_get_kernel, oneapi_submit,
    oneapi_create_queue, oneapi_destroy_queue, oneapi_queue_wait,
    OneApiPtr, OneApiModule, OneApiFunc, OneApiQueue
}
use std.gpu.engine2d.backend_intel_kernels.{
    _align_up,
    _set_kernel_args_clear, _set_kernel_args_rect, _set_kernel_args_line,
    _set_kernel_args_circle, _set_kernel_args_rounded_rect,
    _set_kernel_args_triangle, _set_kernel_args_gradient, _set_kernel_args_blit,
    _upload_pixels_to_device_intel, _download_framebuffer_intel, _upload_host_to_device_intel,
    _intel_draw_text_fallback,
    _engine2d_opencl_source, _engine2d_spirv,
    _i64, _i64_from_u32
}

# ============================================================================
# Intel oneAPI Backend
# ============================================================================

class IntelBackend:
    """GPU-accelerated 2D renderer using Intel oneAPI Level Zero.

    Architecture:
    - Framebuffer lives in Intel GPU device memory (d_framebuffer)
    - SPIR-V compute kernels handle each 2D primitive
    - Each draw call submits a kernel to the Level Zero command queue
    - present() copies GPU framebuffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line) has a dedicated
    compute kernel. Work-group sizes are chosen to cover the bounding box
    of the primitive being drawn. oneAPI uses a 1D global/local range model
    so we linearize 2D dispatch as (width * height) work-items.
    """

    host_buf: [u32]
    w: i32
    h: i32
    d_framebuffer: OneApiPtr    # Device pointer to GPU framebuffer
    spirv_module: OneApiModule   # Handle to loaded SPIR-V module
    queue: OneApiQueue           # Command queue for kernel dispatch
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    initialized: bool
    dirty: bool                  # True when GPU has changes not yet copied to host

    # Cached kernel handles
    k_clear: OneApiFunc
    k_rect_filled: OneApiFunc
    k_rect_outline: OneApiFunc
    k_line: OneApiFunc
    k_circle: OneApiFunc
    k_circle_filled: OneApiFunc
    k_rounded_rect: OneApiFunc
    k_triangle_filled: OneApiFunc
    k_gradient_rect: OneApiFunc
    k_blit_image: OneApiFunc

    static fn create() -> IntelBackend:
        """Create an uninitialized Intel backend. Call init() before drawing."""
        val null_ptr = OneApiPtr(ptr: 0, size: 0, is_shared: false, is_valid: false)
        val null_mod = OneApiModule(handle: 0, is_valid: false)
        val null_queue = OneApiQueue(handle: 0, is_valid: false)
        val null_func = OneApiFunc(handle: 0, module: null_mod, name: "", is_valid: false)
        IntelBackend(
            host_buf: [],
            w: 0,
            h: 0,
            d_framebuffer: null_ptr,
            spirv_module: null_mod,
            queue: null_queue,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            initialized: false,
            dirty: false,
            k_clear: null_func,
            k_rect_filled: null_func,
            k_rect_outline: null_func,
            k_line: null_func,
            k_circle: null_func,
            k_circle_filled: null_func,
            k_rounded_rect: null_func,
            k_triangle_filled: null_func,
            k_gradient_rect: null_func,
            k_blit_image: null_func
        )

impl RenderBackend for IntelBackend:

    fn name() -> text:
        "intel"

    me init(width: i32, height: i32) -> bool:
        # Check oneAPI availability
        if not oneapi_available():
            return false

        val init_ok = oneapi_init()
        if not init_ok:
            return false

        if oneapi_device_count() < 1:
            return false

        self.w = width
        self.h = height

        # Create command queue
        self.queue = oneapi_create_queue()
        if not self.queue.is_valid:
            return false

        # Allocate device framebuffer (4 bytes per pixel = u32 ARGB)
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = oneapi_alloc_device(fb_size)
        if not self.d_framebuffer.is_valid:
            oneapi_destroy_queue(self.queue)
            return false

        # Clear device framebuffer to black
        oneapi_memset(self.d_framebuffer, 0)

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        # Compile compute kernels: try OpenCL-C source first, fall back to SPIR-V
        val opencl_src = _engine2d_opencl_source()
        self.spirv_module = oneapi_compile_opencl(opencl_src)
        if not self.spirv_module.is_valid:
            # OpenCL-C compilation failed; fall back to pre-compiled SPIR-V
            val spirv_bytes = _engine2d_spirv()
            self.spirv_module = oneapi_compile_spirv(spirv_bytes)
            if not self.spirv_module.is_valid:
                oneapi_free(self.d_framebuffer)
                oneapi_destroy_queue(self.queue)
                return false

        # Cache kernel handles
        self.k_clear = oneapi_get_kernel(self.spirv_module, "kernel_clear")
        self.k_rect_filled = oneapi_get_kernel(self.spirv_module, "kernel_draw_rect_filled")
        self.k_rect_outline = oneapi_get_kernel(self.spirv_module, "kernel_draw_rect_outline")
        self.k_line = oneapi_get_kernel(self.spirv_module, "kernel_draw_line")
        self.k_circle = oneapi_get_kernel(self.spirv_module, "kernel_draw_circle")
        self.k_circle_filled = oneapi_get_kernel(self.spirv_module, "kernel_draw_circle_filled")
        self.k_rounded_rect = oneapi_get_kernel(self.spirv_module, "kernel_draw_rounded_rect")
        self.k_triangle_filled = oneapi_get_kernel(self.spirv_module, "kernel_draw_triangle_filled")
        self.k_gradient_rect = oneapi_get_kernel(self.spirv_module, "kernel_draw_gradient_rect")
        self.k_blit_image = oneapi_get_kernel(self.spirv_module, "kernel_blit_image")

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    me shutdown():
        if self.spirv_module.is_valid:
            oneapi_unload(self.spirv_module)
            self.spirv_module = OneApiModule(handle: 0, is_valid: false)
        if self.d_framebuffer.is_valid:
            oneapi_free(self.d_framebuffer)
            self.d_framebuffer = OneApiPtr(ptr: 0, size: 0, is_shared: false, is_valid: false)
        if self.queue.is_valid:
            oneapi_destroy_queue(self.queue)
            self.queue = OneApiQueue(handle: 0, is_valid: false)
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.initialized = false

    me clear(color: u32):
        # Launch clear kernel: one work-item per pixel
        val total = _i64(self.w) * _i64(self.h)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_clear(self.d_framebuffer.ptr, color, self.w, self.h)
        oneapi_submit(self.queue, self.k_clear, global_size, local_size)
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val total = _i64(w) * _i64(h)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_rect(self.d_framebuffer.ptr, x, y, w, h, color, self.w, self.h, 0)
        oneapi_submit(self.queue, self.k_rect_outline, global_size, local_size)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val total = _i64(w) * _i64(h)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_rect(self.d_framebuffer.ptr, x, y, w, h, color, self.w, self.h, 1)
        oneapi_submit(self.queue, self.k_rect_filled, global_size, local_size)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        # Line kernel: one work-item per pixel along the line length
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val local_size: i64 = 256
        val global_size = _align_up(_i64(line_len), local_size)
        _set_kernel_args_line(self.d_framebuffer.ptr, x1, y1, x2, y2, color, thickness, self.w, self.h)
        oneapi_submit(self.queue, self.k_line, global_size, local_size)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        # Circle outline: launch kernel covering bounding box
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val total = _i64(bw) * _i64(bh)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_circle(self.d_framebuffer.ptr, cx, cy, r, color, self.w, self.h, 0)
        oneapi_submit(self.queue, self.k_circle, global_size, local_size)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val total = _i64(bw) * _i64(bh)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_circle(self.d_framebuffer.ptr, cx, cy, r, color, self.w, self.h, 1)
        oneapi_submit(self.queue, self.k_circle_filled, global_size, local_size)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        val total = _i64(w) * _i64(h)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_rounded_rect(self.d_framebuffer.ptr, x, y, w, h, radius, color, self.w, self.h)
        oneapi_submit(self.queue, self.k_rounded_rect, global_size, local_size)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val total = _i64(bw) * _i64(bh)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_triangle(self.d_framebuffer.ptr, x1, y1, x2, y2, x3, y3, color, self.w, self.h, min_x, min_y)
        oneapi_submit(self.queue, self.k_triangle_filled, global_size, local_size)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        val total = _i64(w) * _i64(h)
        val local_size: i64 = 256
        val global_size = _align_up(total, local_size)
        _set_kernel_args_gradient(self.d_framebuffer.ptr, x, y, w, h, top_color, bottom_color, self.w, self.h)
        oneapi_submit(self.queue, self.k_gradient_rect, global_size, local_size)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering on GPU is complex; fall back to CPU-side rendering
        # then upload the affected region. For production, a glyph atlas
        # texture would be uploaded and sampled by a kernel.
        _intel_draw_text_fallback(self, x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Upload pixel data to a temporary device buffer, then launch
        # a blit kernel to copy it into the framebuffer
        val pixel_count = _i64(w) * _i64(h)
        val byte_size = pixel_count * 4
        val d_src = oneapi_alloc_device(byte_size)
        if d_src.is_valid:
            # Upload source pixels as byte array to device
            _upload_pixels_to_device_intel(d_src, pixels, pixel_count)
            # Launch blit kernel
            val local_size: i64 = 256
            val global_size = _align_up(pixel_count, local_size)
            _set_kernel_args_blit(self.d_framebuffer.ptr, d_src.ptr, x, y, w, h, self.w, self.h)
            oneapi_submit(self.queue, self.k_blit_image, global_size, local_size)
            oneapi_free(d_src)
        self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Copy GPU framebuffer to host memory
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer_intel(self.d_framebuffer, self.host_buf, fb_size)
            oneapi_queue_wait(self.queue)
            self.dirty = false

    fn read_pixels() -> [u32]:
        # Ensure host buffer is up to date
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer_intel(self.d_framebuffer, self.host_buf, fb_size)
            oneapi_queue_wait(self.queue)
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

impl Engine2DExtended for IntelBackend:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = text_val.len().to_i32() * advance
        val text_h = gh * scale
        if text_w <= 0 or text_h <= 0:
            return
        var buf: [u32] = []
        var _i = 0
        val buf_size = text_w * text_h
        while _i < buf_size:
            buf.push(bg)
            _i = _i + 1
        render_text_to_buffer(buf, text_w, text_h, 0, 0, text_val, fg, font_size)
        self.draw_image(x, y, text_w, text_h, buf)

