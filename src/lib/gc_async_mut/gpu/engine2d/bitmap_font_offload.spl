# Engine2D bitmap-font offload evidence.
#
# Bitmap text currently rasterizes glyph pixels on CPU, then uses backend image
# copy/upload lanes where available. This wrapper makes that state explicit so
# GPU copy evidence is not mistaken for GPU-side glyph rasterization.

use std.gpu.engine2d.generated_kernel_dispatch.{
    GENERATED_2D_BITMAP_GLYPH_RASTER,
    Generated2DOperationProvenance,
    Generated2DKernelExecutionEvidence,
    Generated2DKernelSubmitResult,
    generated_2d_execution_evidence,
    generated_2d_execution_request,
    generated_2d_operation_provenance,
    generated_2d_submit_result
}

class BitmapFontOffloadEvidence:
    backend_name: text
    width: i64
    height: i64
    generated: Generated2DOperationProvenance
    glyph_raster_generated: Generated2DOperationProvenance
    generated_ready: bool
    cpu_glyph_preprocess_required: bool
    gpu_copy_upload_ready: bool
    gpu_glyph_raster_plan_ready: bool
    gpu_glyph_rasterized: bool
    production_ready: bool
    status_code: text
    reason: text

    static fn create(backend: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> BitmapFontOffloadEvidence:
        val generated = generated_2d_operation_provenance(backend, "bitmap_font", width, height, runtime_ready, module_ready, args_ptr)
        val raster_generated = generated_2d_operation_provenance(backend, "bitmap_glyph_raster", width, height, runtime_ready, module_ready, args_ptr)
        val copy_ready = generated.ready and generated.cpu_preprocess_required and generated.generated_artifact_required
        val raster_plan_ready = raster_generated.ready and raster_generated.generated_artifact_required and not raster_generated.cpu_preprocess_required
        val status = _bitmap_font_offload_status(generated, raster_generated, copy_ready, raster_plan_ready)
        BitmapFontOffloadEvidence(
            backend_name: backend,
            width: width,
            height: height,
            generated: generated,
            glyph_raster_generated: raster_generated,
            generated_ready: generated.ready,
            cpu_glyph_preprocess_required: generated.cpu_preprocess_required,
            gpu_copy_upload_ready: copy_ready,
            gpu_glyph_raster_plan_ready: raster_plan_ready,
            gpu_glyph_rasterized: false,
            production_ready: false,
            status_code: status,
            reason: _bitmap_font_offload_reason(generated, raster_generated, copy_ready, raster_plan_ready)
        )

    fn diagnostic_text() -> text:
        "BitmapFontOffloadEvidence[backend={self.backend_name} size={self.width}x{self.height} generated_ready={self.generated_ready.to_text()} cpu_glyph_preprocess={self.cpu_glyph_preprocess_required.to_text()} gpu_copy_upload_ready={self.gpu_copy_upload_ready.to_text()} gpu_glyph_raster_plan_ready={self.gpu_glyph_raster_plan_ready.to_text()} gpu_glyph_rasterized={self.gpu_glyph_rasterized.to_text()} production_ready={self.production_ready.to_text()} status={self.status_code} reason={self.reason} generated={self.generated.diagnostic_text()} raster_generated={self.glyph_raster_generated.diagnostic_text()}]"

class BitmapGlyphRasterReadbackEvidence:
    backend_name: text
    width: i64
    height: i64
    args_ptr: i64
    submit: Generated2DKernelSubmitResult
    execution: Generated2DKernelExecutionEvidence
    gpu_glyph_rasterized: bool
    production_ready: bool
    status_code: text
    reason: text

    static fn create(backend: text, width: i64, height: i64, args_ptr: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, runtime_available: bool, backend_submit_ok: bool, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> BitmapGlyphRasterReadbackEvidence:
        val request = generated_2d_execution_request(backend, GENERATED_2D_BITMAP_GLYPH_RASTER, width, height, module_or_queue_handle, kernel_or_pipeline_handle, args_ptr)
        val submit = generated_2d_submit_result(request, runtime_available, backend_submit_ok)
        val execution = generated_2d_execution_evidence(submit, readback_available, expected_checksum, actual_checksum)
        val ready = execution.device_executed
        BitmapGlyphRasterReadbackEvidence(
            backend_name: backend,
            width: width,
            height: height,
            args_ptr: args_ptr,
            submit: submit,
            execution: execution,
            gpu_glyph_rasterized: ready,
            production_ready: ready,
            status_code: _bitmap_glyph_raster_readback_status(execution),
            reason: _bitmap_glyph_raster_readback_reason(execution)
        )

    fn diagnostic_text() -> text:
        "BitmapGlyphRasterReadbackEvidence[backend={self.backend_name} size={self.width}x{self.height} args={self.args_ptr} gpu_glyph_rasterized={self.gpu_glyph_rasterized.to_text()} production_ready={self.production_ready.to_text()} status={self.status_code} reason={self.reason} execution={self.execution.summary()}]"

fn _bitmap_font_offload_status(generated: Generated2DOperationProvenance, raster_generated: Generated2DOperationProvenance, copy_ready: bool, raster_plan_ready: bool) -> text:
    if not generated.ready:
        return generated.typed_status
    if raster_plan_ready:
        return "gpu-raster-plan-without-readback"
    if not raster_generated.ready and raster_generated.typed_status != "":
        return "gpu-raster-plan-not-ready:" + raster_generated.typed_status
    if copy_ready:
        return "gpu-copy-with-cpu-glyph"
    if generated.ready and generated.cpu_preprocess_required:
        return "cpu-glyph-baseline"
    "bitmap-font-copy-not-ready"

fn _bitmap_font_offload_reason(generated: Generated2DOperationProvenance, raster_generated: Generated2DOperationProvenance, copy_ready: bool, raster_plan_ready: bool) -> text:
    if not generated.ready:
        return generated.reason
    if raster_plan_ready:
        return "bitmap-font-gpu-raster-kernel-ready-readback-required"
    if not raster_generated.ready and raster_generated.reason != "":
        return raster_generated.reason
    if copy_ready:
        return "bitmap-font-glyphs-rasterized-on-cpu-then-uploaded"
    if generated.ready and generated.cpu_preprocess_required:
        return "bitmap-font-glyphs-rasterized-on-cpu"
    "bitmap-font-generated-copy-missing"

fn _bitmap_glyph_raster_readback_status(execution: Generated2DKernelExecutionEvidence) -> text:
    if execution.device_executed:
        return "gpu-glyph-raster-readback-matched"
    "gpu-glyph-raster-" + execution.status_code

fn _bitmap_glyph_raster_readback_reason(execution: Generated2DKernelExecutionEvidence) -> text:
    if execution.device_executed:
        return "bitmap-glyph-raster-gpu-readback-matched"
    execution.reason

fn bitmap_glyph_raster_expected_pixels(glyph_bits: [u32], width: i64, height: i64, color: u32) -> [u32]:
    val pixel_count = width * height
    if width <= 0 or height <= 0 or pixel_count > glyph_bits.len():
        return []
    var pixels: [u32] = []
    var idx: i64 = 0
    while idx < pixel_count:
        if glyph_bits[idx] == 0u32:
            pixels.push(0u32)
        else:
            pixels.push(color)
        idx = idx + 1
    pixels

fn bitmap_glyph_raster_checksum(pixels: [u32]) -> i64:
    if pixels.len() == 0:
        return 0
    var checksum: i64 = 0
    var idx: i64 = 0
    while idx < pixels.len():
        val pixel = pixels[idx] as i64
        checksum = checksum + ((idx + 1) * ((pixel & 0xffffffff) + 1))
        idx = idx + 1
    checksum

fn bitmap_glyph_raster_mask_checksum(glyph_bits: [u32], width: i64, height: i64, color: u32) -> i64:
    val pixel_count = width * height
    if width <= 0 or height <= 0 or pixel_count > glyph_bits.len():
        return 0
    var checksum: i64 = 0
    var idx: i64 = 0
    while idx < pixel_count:
        var pixel: i64 = 0
        if glyph_bits[idx] != 0u32:
            pixel = color as i64
        checksum = checksum + ((idx + 1) * ((pixel & 0xffffffff) + 1))
        idx = idx + 1
    checksum

fn bitmap_font_offload_evidence(backend: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> BitmapFontOffloadEvidence:
    BitmapFontOffloadEvidence.create(backend, width, height, runtime_ready, module_ready, args_ptr)

fn bitmap_glyph_raster_readback_evidence(backend: text, width: i64, height: i64, args_ptr: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, runtime_available: bool, backend_submit_ok: bool, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> BitmapGlyphRasterReadbackEvidence:
    BitmapGlyphRasterReadbackEvidence.create(backend, width, height, args_ptr, module_or_queue_handle, kernel_or_pipeline_handle, runtime_available, backend_submit_ok, readback_available, expected_checksum, actual_checksum)

fn bitmap_glyph_raster_mask_readback_evidence(backend: text, glyph_bits: [u32], width: i64, height: i64, color: u32, args_ptr: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, runtime_available: bool, backend_submit_ok: bool, readback_available: bool, actual_checksum: i64) -> BitmapGlyphRasterReadbackEvidence:
    val expected_checksum = bitmap_glyph_raster_mask_checksum(glyph_bits, width, height, color)
    BitmapGlyphRasterReadbackEvidence.create(backend, width, height, args_ptr, module_or_queue_handle, kernel_or_pipeline_handle, runtime_available, backend_submit_ok, readback_available, expected_checksum, actual_checksum)
