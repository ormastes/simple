            vg.present()
        elif val Some(bm) = self.baremetal_backend:
            bm.present()
        else:
            self.backend.present()

    fn read_pixels() -> [u32]:
        # Checksum-free readback: delegate straight to the backend's read_pixels
        # (which, for the Metal GPU-only/native path, is a single-FFI download
        # returning the [u32] framebuffer). read_pixels_with_source() still
        # computes the O(n) Simple checksum for evidence rows; callers that only
        # need pixels avoid that cost here.
        if val Some(vg) = self.virtio_gpu_backend:
            return vg.read_pixels()
        elif val Some(bm) = self.baremetal_backend:
            return bm.read_pixels()
        else:
            return self.backend.read_pixels()

    fn read_pixels_with_source() -> Engine2DReadback:
        """Read the framebuffer contents as a flat u32 array."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.read_pixels_with_source()
        elif val Some(bm) = self.baremetal_backend:
            bm.read_pixels_with_source()
        else:
            self.backend.read_pixels_with_source()

    # ========================================================================
    # Lifecycle
    # ========================================================================

    me shutdown():
        """Shut down the backend and release all resources."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.shutdown()
        elif val Some(bm) = self.baremetal_backend:
            bm.shutdown()
        else:
            self.backend.shutdown()

    # ========================================================================
    # Frame pacing (AC-7)
    # ========================================================================

    me tick_forever(draw_fn: fn() -> bool):
        """Run the frame loop until draw_fn returns false.

        Uses event-sleep pacing (tick_once) instead of tight spinning so the
        WM thread yields CPU between frames.  FramePacingCounters are updated
        every tick and are readable via get_frame_pacing().

        Args:
            draw_fn: Called each tick to issue draw commands and call present().
                     Return false to stop the loop.
        """
        var running = true
        while running:
            running = draw_fn()
            tick_once(self.pacing)

    fn get_frame_pacing() -> FramePacingCounters:
        """Return the current accumulated frame-pacing counters."""
        self.pacing
