    me draw_shaped_text(x: i32, y: i32, glyph_run: DrawIrGlyphRunPayload, color: u32, font_size: i32) -> bool:
        """Draw a semantic shaped run through the canonical selected face."""
        self.draw_shaped_text_configured(
            x, y, glyph_run, color, engine2d_default_font_config_for(font_size, self.baremetal_backend != nil)
        )

    me draw_shaped_text_configured(x: i32, y: i32, glyph_run: DrawIrGlyphRunPayload, color: u32, config: FontRenderConfig) -> bool:
        val plan = font_execution_plan(config, ["cuda", "metal", "opencl", "vulkan", "rocm", "cpu"])
        if plan.len() == 0 or not font_render_config_selection_supported(config):
