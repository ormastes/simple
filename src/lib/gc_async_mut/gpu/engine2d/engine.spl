# ============================================================================
# Config / environment backend selection
# ============================================================================

fn engine2d_env_backend_override() -> text:
    """Config/environment override for the auto-selected 2D backend.

    The 2D API is one surface; which lane runs it — SIMD CPU vs a GPU backend —
    is selectable by environment without changing any call site. Set
    `SIMPLE_2D_BACKEND` to a backend key (e.g. `cpu_simd`, `software`, `cuda`,
    `vulkan`, `metal`, `rocm`). Returns "" when unset.
    """
    val raw = engine2d_env_get("SIMPLE_2D_BACKEND") ?? ""
    raw.trim()

fn engine2d_env_get(key: text) -> text:
    env_get(key)

fn engine2d_scale_pixel_alpha(pixels: [u32], opacity_milli: i32) -> [u32]:
    """Scale every pixel's alpha channel by opacity_milli/1000 (1000 = no
    change), used by draw_engine_opacity() to fade an embedded surface before
    compositing it into a parent Engine2D."""
    val count = pixels.len()
    var out: [u32] = [0u32; count]
    var i = 0
    while i < count:
        val p = pixels[i]
        val scaled_a = (color_a(p) * opacity_milli) / 1000
        out[i] = rgba(color_r(p), color_g(p), color_b(p), scaled_a)
        i = i + 1
    out

fn engine2d_font_atlas_subrect_pixels(atlas_pixels: [u32], atlas_width: i32, atlas_height: i32,
                                      atlas_x: i32, atlas_y: i32, width: i32, height: i32,
                                      color: u32) -> [u32]:
    font_atlas_subrect_pixels(atlas_pixels, atlas_width, atlas_height,
        atlas_x, atlas_y, width, height, color)

# GLYPH-FIX-3 (2026-07-19) ROOT CAUSE WORKAROUND: `FontRenderConfig.default_for_size()`
# builds `execution_target: "auto"`. `font_render_config_valid()` (font_types.spl)
# short-circuits its execution-policy check only when `execution_target != "auto"`;
# with "auto" it falls through to `config.execution_policy ==
# FontExecutionPolicy.Suggested`. On this freestanding native-build path that
# enum equality reads back false for EVERY FontExecutionPolicy variant
# (Suggested/Preferred/Required all compare false against a freshly
# constructed `FontExecutionPolicy.Suggested` value -- proven via
# `[vec-text-probe] draw_text_configured-entry ... policy_suggested=0
# policy_preferred=0 policy_required=0`), so `font_render_config_valid()`
# returns false, `font_execution_plan()` returns [], and every `draw_text()`
# call on the SimpleOS desktop silently drew zero glyphs with no exception.
# font_types.spl is shared, hosted-proven-correct infrastructure outside this
# investigation's edit surface, so work around it here: when running on the
# baremetal backend (the only place this was reproduced -- hosted/GPU builds
# are unproven and left on their normal "auto" plan to avoid forcing every
# desktop/game caller onto the CPU font path without evidence), pin
# `execution_target` to the concrete "cpu" target (the only backend a
# baremetal/no-GPU boot path ever runs anyway) instead of "auto". That takes
# the `target != "auto"` branch of the disjunction and never evaluates the
# broken enum comparison. `_font_render_config_default_selection()`
# (font_renderer.spl) only inspects family/category/language/script, so this
# does not change font selection, only which (otherwise-unreachable) code
# path validates it. See doc/08_tracking/bug/ for the enum-equality compiler
# defect this papers over -- it likely also affects hosted/GPU builds using
# FontExecutionPolicy.Preferred/Required and should be root-caused separately.
fn engine2d_default_font_config_for(font_size: i32, force_cpu_target: bool) -> FontRenderConfig:
    val base = FontRenderConfig.default_for_size(font_size)
    if not force_cpu_target:
        return base
    FontRenderConfig(
        family: base.family, category: base.category, language: base.language,
        script: base.script, size: base.size, weight: base.weight, style: base.style,
        hinting: base.hinting, antialiasing: base.antialiasing, atlas_policy: base.atlas_policy,
        execution_target: "cpu", execution_policy: base.execution_policy
    )

# GLYPH-FIX-3 (2026-07-19): gated consumer-side probes. Mirrors the
# producer-side probes in font_renderer.spl (_vec_atlas_probe_count /
# _vec_glyph_probe_count) so the atlas_pixels count taken right before the
# FontRenderBatch leaves nogc_sync_mut.text_layout.font_renderer can be
# compared against the count taken right after it lands here in
# gc_async_mut.gpu.engine2d.engine, isolating whether coverage is lost
# during that cross-layer struct/array transfer or earlier/later.
val _VEC_TEXT_PROBE: bool = false
var _vec_text_probe_count: i32 = 0
var _vec_blit_probe_count: i32 = 0
var _vec_entry_probe_count: i32 = 0
# ============================================================================
# Engine2D
# ============================================================================

class Engine2D:
    """2D rendering engine with automatic backend selection.

    Creates the best available backend at initialization time. All drawing
    methods delegate to the active backend through the RenderBackend trait.

    Lifecycle:
        1. Engine2D.create(width, height)  — auto-detect and init backend
        2. clear(), draw_*(), present()     — render frames
        3. shutdown()                       — release resources

    Example:
        var engine = Engine2D.create(800, 600)
        print "Using backend: {engine.backend_name()}"

        engine.clear(rgb(30, 30, 30))
        engine.draw_rect_filled(10, 10, 200, 100, rgb(255, 0, 0))
        engine.draw_text(20, 40, "Hello Engine2D", rgb(255, 255, 255), 14)
        engine.present()

        val pixels = engine.read_pixels()
        engine.shutdown()
    """

    backend: RenderBackend
    # Capability wiring (GPU-dict pilot, design cpu_gpu_dual_algorithm_design.md
    # §1/§7): the concrete backend's honest self-description, captured at
    # construction time (before the concrete instance is boxed into the
    # `backend: RenderBackend` trait field) since `capability()` is NOT a
    # RenderBackend trait requirement — adding one would force every backend to
    # implement it at once (backend_capability.spl convention). Backends that
    # do not yet populate a real capability() report the honest
    # software-emulation/no-accelerated-ops default.
    capability: BackendCapability
    baremetal_backend: BaremetalBackend?
    virtio_gpu_backend: VirtioGpuBackend?
    cuda_backend: CudaBackend? = nil
    vulkan_backend: VulkanBackend? = nil
    vulkan_font_state_unknown: bool = false
    last_vulkan_font_evidence: VulkanFontCompositeEvidence? = nil
    metal_backend: MetalBackend? = nil
    opencl_backend: OpenClBackend? = nil
    rocm_backend: RocmBackend? = nil
    # Set explicitly by create_offscreen() (a software-only embedding target).
    # Declared with an explicit Option type so its slot is real and its type is
    # inferable at read sites (draw_software_offscreen_opacity_consume); the
    # constructor already names it, but without this declaration the read fails
    # HIR field-type inference and the store may not land in a real slot.
    software_backend: SoftwareBackend? = nil
    w: i32
    h: i32
    pacing: FramePacingCounters
    selected_backend_name: text
    font_renderer: FontRenderer? = nil
    last_font_execution_attempts: [text] = []
    last_font_execution_target: text = ""

    me fonts() -> FontRenderer:
        val active = self.font_renderer
        if active != nil:
            return active
        val created = FontRenderer.new()
        self.font_renderer = created
        created

    fn font_execution_attempts() -> [text]: self.last_font_execution_attempts
    fn font_execution_target() -> text: self.last_font_execution_target

    me install_vulkan_font_spirv(spirv_bytes: [u8]) -> bool:
        """Install one bounded precompiled font compositor on a real Vulkan engine."""
        if spirv_bytes.len() == 0 or spirv_bytes.len() > 16777216:
            return false
        val active = self.vulkan_backend
        if active == nil:
            return false
        val vulkan = active
        val evidence = vulkan.install_font_atlas_pipeline(spirv_bytes)
        self.vulkan_backend = vulkan
        evidence.status == "ready"

    me install_cuda_font_ptx(ptx: text) -> bool:
        """Install one verified generated font companion on a real CUDA engine."""
        val active = self.cuda_backend
        if active == nil:
            return false
        val cuda = active
        val installed = cuda.install_font_atlas_ptx(ptx)
        self.cuda_backend = cuda
        installed

    me install_cuda_font_artifact(ptx: text, artifact_sha256: text, program_version: i64,
                                  semantics_version: i64) -> bool:
        """Install caller-provided PTX only when its payload contract matches."""
        if (ptx.len() == 0 or ptx.len() > CUDA_FONT_PTX_MAX_BYTES or
            not font_atlas_composite_program_version_valid(program_version) or
            semantics_version != FONT_ATLAS_COMPOSITE_SEMANTICS_VERSION or
            artifact_sha256.len() != 64 or sha256_text(ptx) != artifact_sha256):
            return false
        # install_cuda_font_ptx performs the existing bounded `.version` and
        # exact entry-symbol gate before its session cache can mutate.
        self.install_cuda_font_ptx(ptx)

    me install_pinned_cuda_font_artifact() -> bool:
        """Install the source-tracked CUDA font companion through the existing gate."""
        val ptx = cuda_font_atlas_composite_ptx()
        if not cuda_font_atlas_composite_ptx_trusted(ptx):
            return false
        self.install_cuda_font_artifact(
            ptx, FONT_ATLAS_COMPOSITE_CUDA_PTX_SHA256,
            FONT_ATLAS_COMPOSITE_CUDA_PROGRAM_VERSION,
            FONT_ATLAS_COMPOSITE_CUDA_SEMANTICS_VERSION)

    me _poison_vulkan_font_surface(fallback_pixels: [u32]):
        if val Some(vulkan) = self.vulkan_backend:
            vulkan.mark_completion_unknown()
            self.vulkan_backend = vulkan
        var software = SoftwareBackend.create()
        software.init(self.w, self.h)
        if fallback_pixels.len() == self.w.to_i64() * self.h.to_i64():
            software.buf = fallback_pixels
        self.capability = software.capability()
        self.backend = software
        self.selected_backend_name = "vulkan-poisoned-software"
        self.vulkan_font_state_unknown = true

    # ========================================================================
    # Constructors
    # ========================================================================

    static fn create(width: i32, height: i32) -> Engine2D:
        """Create engine with auto-detected best backend.

        Tries backends in priority order: metal, cuda, rocm/hip, qualcomm, vulkan, directx, opencl, opengl, intel, webgpu, cpu_simd, software, cpu.
        Falls back to cpu if all others fail.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels

        Returns:
            Initialized Engine2D
        """
        val best = Engine2D.detect_best_backend()
        Engine2D.create_with_backend(width, height, best)

    static fn create_with_backend(width: i32, height: i32, backend_name: text) -> Engine2D:
        """Create engine with a specific backend.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels
            backend_name: Trimmed, case-insensitive backend key. Supported names include "metal", "cuda", "rocm"/"hip"/"amd-hip"/"amd_rocm", "qualcomm", "vulkan", "directx"/"d3d11"/"dx12", "opencl", "opengl", "intel", "webgpu", "cpu_simd"/"simd_cpu"/"cpu-simd", "software", "cpu", "baremetal"/"native"/"platform-native", and "virtio_gpu"/"virtio-gpu".

        Returns:
            Initialized Engine2D (falls back to cpu on failure)

        Note: "baremetal" requires a pre-initialized BaremetalBackend. Use
              create_with_baremetal_backend() instead for baremetal rendering.
        """
        val created = Engine2D.create_requested_backend(width, height, backend_name)
        match created:
            Ok(engine):
                return engine
            Err(_):
                pass_do_nothing

        # Fallback: CPU backend always succeeds
        match Engine2D.create_requested_backend(width, height, "cpu"):
            Ok(engine):
                engine
            Err(_):
                var sw = SoftwareBackend.create()
                sw.init(width, height)
                val capability = sw.capability()
                Engine2D(backend: sw, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "software")

    static fn create_with_backend_fast(width: i32, height: i32, backend_name: text) -> Engine2D:
        """Create an engine in native-only ("no mirror") fast mode.

        For the Metal backend this shrinks the CPU software mirror to 1x1 so draw
        ops stop re-rasterizing the full framebuffer under the interpreter (the
        per-op mirror was the entire render cost — see
        doc/08_tracking/bug/engine2d_interpreted_mirror_dominates_render_2026-07-03.md).
        Draw ops forward to the GPU only, and read_pixels() downloads the GPU
        framebuffer in one FFI hop.

        IMPORTANT: the caller must issue a clear() before drawing so the GPU
        framebuffer is initialized and gpu_frame_complete becomes true; otherwise
        readback falls back to the 1x1 mirror.

        Backends other than Metal have no native framebuffer to read back from
        (their surface lives in a Simple [u32] array with per-op interpreted
        marshalling), so this transparently falls back to the normal
        create_with_backend() path for them — correct, but not accelerated.
        """
        val requested_backend = backend_canonical_name(backend_name)
        if requested_backend == "metal":
            var metal = MetalBackend.create()
            if metal.init(width, height):
                metal.use_gpu_only()
                val capability = metal.capability()
                return Engine2D(backend: metal, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, metal_backend: metal, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "metal")
        Engine2D.create_with_backend(width, height, backend_name)

    static fn create_offscreen(width: i32, height: i32) -> Engine2D:
        """Create an offscreen CPU/software render target for embedding.

        This is the "rendering-inside-rendering" CPU lane: an Engine2D that is
        always backed by the software rasterizer — never a window or GPU
        backend — so a caller can render an independent sub-scene and later
        stitch its pixels into a parent Engine2D via draw_engine() /
        draw_engine_opacity(). The buffer starts fully TRANSPARENT (not the
        default opaque-black fill every other backend init uses) so pixels the
        embedded scene never touches let the parent's own content show through
        once composited, instead of punching an opaque black hole in it.
        """
        var sw = SoftwareBackend.create()
        sw.init(width, height)
        sw.clear(0x00000000u32)
        val capability = sw.capability()
        # NOTE(2026-07-16): explicitly pin every optional accelerator-backend
        # field to nil rather than relying on the class-level `= nil` default
        # being applied for an omitted named field. On this freestanding
        # (cranelift, x86_64-unknown-none) codegen path that default was
        # observed to NOT be applied: an offscreen Engine2D created here (used
        # to render an embedded batch, e.g. the taskbar) had a garbage
        # non-nil `vulkan_backend`, so `draw_rect_filled` took the "elif
        # Some(vulkan)" branch and called through a bogus Vulkan backend,
        # producing a wild instruction pointer (observed as
        # 0xf000d43df000d43d). Root cause is a compiler/codegen bug (defaulted
        # struct-literal fields not zero-initialized when omitted); this is
        # the workaround at the call site until that's fixed upstream.
        # Only DECLARED fields may be named here: the interpreter rejects
        # unknown named ctor args. cpu_backend/directx_backend do NOT exist on
        # Engine2D — naming them (2026-07-16 pin-everything workaround) broke
        # every create_offscreen caller on the hosted lane (standalone 2D
        # showcase regression, proven 2026-07-18), so they are omitted.
        # software_backend IS a declared field (see decl above) and is named
        # with `sw` so draw_software_offscreen_opacity_consume can reach this
        # offscreen's software rasterizer and skip the two full-surface scratch
        # buffers draw_engine_opacity() would otherwise allocate per translucent
        # window (the residual first-frame heap pressure).
        Engine2D(backend: sw, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, cuda_backend: nil, vulkan_backend: nil, vulkan_font_state_unknown: false, last_vulkan_font_evidence: nil, metal_backend: nil, opencl_backend: nil, rocm_backend: nil, software_backend: sw, font_renderer: nil, last_font_execution_attempts: [], last_font_execution_target: "", w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "software")

    me create_shared_vulkan_offscreen(width: i32, height: i32) -> Result<Engine2D, text>:
        """Create one transparent child framebuffer on this engine's Vulkan session."""
        val pixel_count = width.to_i64() * height.to_i64()
        if width <= 0 or height <= 0 or pixel_count <= 0 or pixel_count > 2147483647:
            return Err("invalid-shared-vulkan-surface-size")
        val active = self.vulkan_backend
        if active == nil:
            return Err("shared-vulkan-parent-required")
        val parent = active
        if not parent.owns_session or not parent.session.is_valid():
            return Err("shared-vulkan-session-required")
        var vulkan = VulkanBackend.create()
        if not vulkan.init_with_session(width, height, parent.session):
            return Err(if vulkan.last_error == "": "shared-vulkan-surface-init-failed" else: vulkan.last_error)
        var child = Engine2D(backend: vulkan, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, vulkan_backend: vulkan, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "vulkan")
        child.clear(0x00000000u32)
        Ok(child)

    me create_shared_metal_offscreen(width: i32, height: i32) -> Result<Engine2D, text>:
        """Create one transparent child framebuffer on this engine's Metal session."""
        val pixel_count = width.to_i64() * height.to_i64()
        if width <= 0 or height <= 0 or pixel_count <= 0 or pixel_count > 2147483647:
            return Err("invalid-shared-metal-surface-size")
        val active = self.metal_backend
        if active == nil:
            return Err("shared-metal-parent-required")
        val parent = active
        if not parent.session.is_valid():
            return Err("shared-metal-session-required")
        var metal = MetalBackend.create()
        if not metal.init_with_session(width, height, parent.session):
            return Err(if metal.last_error == "": "shared-metal-surface-init-failed" else: metal.last_error)
        val capability = metal.capability()
        Ok(Engine2D(backend: metal, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, metal_backend: metal, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "metal"))

    static fn create_requested_backend(width: i32, height: i32, backend_name: text) -> Result<Engine2D, text>:
        """Create one canonical backend without silently falling back."""
        val requested_backend = backend_canonical_name(backend_name)
        if requested_backend == "cuda":
            var cuda = CudaBackend.create()
            if cuda.init(width, height):
                var engine = Engine2D(backend: cuda, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, cuda_backend: cuda, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "cuda")
                engine.install_pinned_cuda_font_artifact()
                return Ok(engine)

        if requested_backend == "vulkan":
            var vulkan = VulkanBackend.create()
            if vulkan.init(width, height):
                return Ok(Engine2D(backend: vulkan, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, vulkan_backend: vulkan, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "vulkan"))

        if requested_backend == "directx":
            var directx = DirectXBackend.create()
            if directx.init(width, height):
                # Stamp the backend's honest self-reported name
                # ("directx-software-emulation"): draws are CPU-rasterized by
                # its internal SoftwareBackend even when the D3D11/DXVK device
                # chain initializes. "directx" stays valid as the REQUESTED key.
                val selected_name = directx.name()
                return Ok(Engine2D(backend: directx, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: selected_name))

        if requested_backend == "directx-on-vulkan":
            # DirectX-on-Vulkan emulation: serve a DirectX API request through the
            # real Vulkan backend (the vkd3d/DXVK concept — DirectX translated to
            # Vulkan). Pixels are genuinely Vulkan-rendered and verified bit-exact
            # vs SoftwareBackend; primitive coverage matches VulkanBackend. The
            # selected name discloses the emulation rather than claiming native
            # DirectX. Distinct from the "directx" key, which is the CPU raster
            # path gated by a real vkd3d/Vulkan ICD probe and honestly reported
            # as "directx-software-emulation".
            var dx_vk = VulkanBackend.create()
            if dx_vk.init(width, height):
                return Ok(Engine2D(backend: dx_vk, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "directx-on-vulkan"))

        if requested_backend == "opencl":
            var opencl = OpenClBackend.create()
            if opencl.init(width, height):
                return Ok(Engine2D(backend: opencl, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, opencl_backend: opencl, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "opencl"))

        if requested_backend == "opengl":
            var opengl = OpenGLBackend.create()
            if opengl.init(width, height):
                return Ok(Engine2D(backend: opengl, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "opengl"))

        if requested_backend == "metal":
            var metal = MetalBackend.create()
            if metal.init(width, height):
                val capability = metal.capability()
                return Ok(Engine2D(backend: metal, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, metal_backend: metal, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "metal"))

        if requested_backend == "metal-on-vulkan":
            # Compatibility stays explicit: strict "metal" never claims this lane.
            var metal_vk = VulkanBackend.create()
            if metal_vk.init(width, height):
                return Ok(Engine2D(backend: metal_vk, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "metal-on-vulkan"))

        if requested_backend == "rocm":
            var rocm = RocmBackend.create()
            if rocm.init(width, height):
                return Ok(Engine2D(backend: rocm, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, rocm_backend: rocm, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "rocm"))

        if requested_backend == "intel":
            var intel = IntelBackend.create()
            if intel.init(width, height):
                return Ok(Engine2D(backend: intel, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "intel"))

        if requested_backend == "qualcomm":
            var qualcomm = QualcommBackend.create()
            if qualcomm.init(width, height):
                return Ok(Engine2D(backend: qualcomm, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "qualcomm"))

        if requested_backend == "webgpu":
            var webgpu = WebGpuBackend.create()
            if webgpu.init(width, height):
                return Ok(Engine2D(backend: webgpu, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "webgpu"))

        if requested_backend == "software":
            var sw = SoftwareBackend.create()
            if sw.init(width, height):
                val capability = sw.capability()
                return Ok(Engine2D(backend: sw, capability: capability, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "software"))

        # Note: "baremetal" is NOT auto-detected. It requires a pre-initialized
        # FramebufferDriver and must be created via create_with_baremetal_backend().
        # If requested here by name, fall through to CPU fallback.

        if requested_backend == "cpu_simd":
            if not native_pixel_rows_enabled():
                return Err("backend unavailable: cpu_simd native SIMD pixel rows unavailable")
            var cpu_simd = CpuBackend.create_simd()
            cpu_simd.init(width, height)
            return Ok(Engine2D(backend: cpu_simd, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "cpu_simd"))

        if requested_backend == "cpu":
            var cpu = CpuBackend.create()
            cpu.init(width, height)
            return Ok(Engine2D(backend: cpu, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "cpu"))

        Err("backend unavailable: " + requested_backend)

    static fn create_vulkan_backend(width: i32, height: i32) -> Result<Engine2D, text>:
        """Create canonical Vulkan without retaining unrelated backend factories."""
        var vulkan = VulkanBackend.create()
        if vulkan.init(width, height):
            return Ok(Engine2D(backend: vulkan, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: nil, vulkan_backend: vulkan, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "vulkan"))
        Err("backend unavailable: vulkan")

    static fn create_with_baremetal_backend(backend: BaremetalBackend) -> Engine2D:
        """Create engine with a pre-initialized BaremetalBackend.

        The BaremetalBackend wraps a FramebufferDriver and is used for
        OS-level rendering where only framebuffer hardware is available.

        Args:
            backend: An already-created BaremetalBackend (via BaremetalBackend.create())

        Returns:
            Engine2D using the baremetal backend
        """
        Engine2D.create_with_baremetal_backend_dims(backend.w, backend.h, backend)

    static fn create_with_baremetal_backend_dims(width: i32, height: i32, backend: BaremetalBackend) -> Engine2D:
        """Create engine with explicit dimensions for a baremetal backend.

        The dimension arguments avoid reading cached width/height through a
        fragile backend-parameter path during baremetal boot. The CPU backend
        remains an unused placeholder on this path, so it must not allocate
        or initialize any pixel buffer.

        NOTE(2026-07-16): explicitly pin every optional accelerator-backend
        field to nil rather than relying on the class-level `= nil` default
        being applied for an omitted named field -- see the identical note
        on `create_offscreen()` above. This is the root SimpleOS desktop
        engine, so a garbage non-nil `vulkan_backend`/etc. here would corrupt
        every draw call that checks it (observed: draw_image_scaled_blend
        took the bogus "elif Some(vulkan)" branch and faulted).

        GLYPH-FIX-3 (2026-07-19): the same omitted-named-field landmine also
        applies to plain scalar fields, not just Option accelerator handles.
        `vulkan_font_state_unknown: bool = false` was left out of this list,
        relying on the class-level default -- which freestanding codegen does
        not reliably apply for a field omitted from a constructor call. When
        it reads back non-zero garbage, `draw_text()`'s `if
        self.vulkan_font_state_unknown: return` fires unconditionally and
        silently drops EVERY text draw (both the vector path and the
        baremetal-bitmap fallback) with zero exceptions -- proven via
        `[vec-text-probe] draw_text-entry ... vulkan_font_state_unknown=true`
        on this exact constructor before this fix. Pin it (and the sibling
        `last_vulkan_font_evidence`/`rocm_backend`/`software_backend` fields,
        same category) explicitly rather than adding more fields to the
        growing exception list.
        """
        Engine2D(backend: backend, capability: backend_capability_default(), baremetal_backend: Some(backend), virtio_gpu_backend: nil, cuda_backend: nil, vulkan_backend: nil, vulkan_font_state_unknown: false, last_vulkan_font_evidence: nil, metal_backend: nil, opencl_backend: nil, rocm_backend: nil, software_backend: nil, font_renderer: nil, w: width, h: height, pacing: make_frame_pacing_counters(), selected_backend_name: "baremetal")

    static fn create_with_virtio_gpu_backend(backend: VirtioGpuBackend) -> Engine2D:
        """Create engine with a pre-initialized VirtioGpuBackend."""
        Engine2D(backend: backend, capability: backend_capability_default(), baremetal_backend: nil, virtio_gpu_backend: Some(backend), cuda_backend: nil, vulkan_backend: nil, metal_backend: nil, opencl_backend: nil, font_renderer: nil, w: backend.w, h: backend.h, pacing: make_frame_pacing_counters(), selected_backend_name: "virtio_gpu")

    static fn create_with_backend_strict(width: i32, height: i32, backend_name: text) -> Result<Engine2D, BackendProbeResult>:
        """Create engine with a specific backend, returning diagnostics on failure.

        Unlike create() which silently falls back to CPU, this returns a typed
        BackendProbeResult explaining exactly why the requested backend is unavailable.
        """
        var probe = Engine2D.probe_backend(width, height, backend_name)
        if probe.status == BackendStatus.Initialized:
            match Engine2D.create_requested_backend(width, height, backend_name):
                Ok(engine):
                    Ok(engine)
                Err(message):
                    Err(BackendProbeResult.failed(backend_canonical_name(backend_name), message))
        else:
            Err(probe)

    static fn probe_backend(width: i32, height: i32, backend_name: text) -> BackendProbeResult:
        """Probe whether a backend is available without creating an engine."""
        val requested_backend = backend_canonical_name(backend_name)
        if requested_backend == "cuda":
            var b = CudaBackend.create()
            if b.init(width, height):
                val probe = b.last_probe
                b.shutdown()
                return probe
            return b.last_probe

        if requested_backend == "vulkan":
            var b = VulkanBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("vulkan", "Vulkan initialized")
            if b.last_error != "":
                return BackendProbeResult.unavailable("vulkan", b.last_error)
            return BackendProbeResult.unavailable("vulkan", "vkCreateInstance failed or no devices")

        if requested_backend == "directx":
            var b = DirectXBackend.create()
            # Report the backend's honest self-reported name
            # ("directx-software-emulation"); "directx" is only the requested key.
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success(b.name(), "DirectX(software-emulation raster) initialized")
            if b.last_error != "":
                return BackendProbeResult.unavailable(b.name(), b.last_error)
            return BackendProbeResult.unavailable(b.name(), "d3d11 device or swapchain creation failed")
        if requested_backend == "opencl":
            var b = OpenClBackend.create()
            if b.init(width, height):
                val probe = b.last_probe
                b.shutdown()
                return probe
            return b.last_probe

        if requested_backend == "rocm":
            var b = RocmBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("rocm", "ROCm/HIP initialized")
            return BackendProbeResult.unavailable("rocm", "ROCm/HIP runtime, device, or module unavailable")

        if requested_backend == "metal":
            var b = MetalBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("metal", "Metal initialized")
            return b.last_probe

        if requested_backend == "qualcomm":
            var b = QualcommBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("qualcomm", "Qualcomm Adreno Vulkan delegate initialized")
            return BackendProbeResult.unavailable("qualcomm", "Qualcomm Adreno target or Vulkan delegate unavailable")

        if requested_backend == "webgpu":
            var b = WebGpuBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("webgpu", "WebGPU initialized")
            return BackendProbeResult.unavailable("webgpu", "WebGPU adapter not found")

        if requested_backend == "opengl":
            var b = OpenGLBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("opengl", "OpenGL initialized")
            return BackendProbeResult.unavailable("opengl", "OpenGL context creation failed")

        if requested_backend == "intel":
            var b = IntelBackend.create()
            if b.init(width, height):
                b.shutdown()
                return BackendProbeResult.success("intel", "Intel oneAPI initialized")
            return BackendProbeResult.unavailable("intel", "Intel oneAPI runtime or device unavailable")

        if requested_backend == "software":
            return BackendProbeResult.success("software", "Software always available")

        if requested_backend == "cpu":
            return BackendProbeResult.success("cpu", "CPU always available")

        if requested_backend == "cpu_simd":
            if not native_pixel_rows_enabled():
                return BackendProbeResult.unavailable("cpu_simd", "Native SIMD pixel rows unavailable")
            return BackendProbeResult.success(
                "cpu_simd",
                "Native CPU SIMD pixel rows available: arch=" + active_arch_text() +
                    " feature=" + active_feature_text()
            )

        BackendProbeResult.unavailable(backend_name, "Unknown backend: " + backend_name)

    static fn create_compute_dispatch() -> ComputeDispatchResult:
        """Create the best available compute dispatch without changing render backend selection."""
        compute_dispatch_auto()

    static fn create_compute_dispatch_for_backend(backend_name: text) -> ComputeDispatchResult:
        """Create a compute dispatch for an explicit backend through the strict factory."""
        compute_dispatch_for_backend(backend_name)

    static fn detect_best_compute_backend() -> text:
        """Detect the best available compute backend."""
        Engine2D.create_compute_dispatch().selected_name

    # ========================================================================
    # Backend Discovery
    # ========================================================================

    static fn detect_best_backend() -> text:
        """Detect the best available backend.

        Auto-probe priority: metal > cuda > rocm/hip > qualcomm > vulkan > directx > opencl > opengl > intel > webgpu > cpu_simd > software > cpu

        Explicit native surfaces such as baremetal and virtio_gpu require a
        preinitialized framebuffer, so they are not probed from width/height.

        A `SIMPLE_2D_BACKEND` config/environment override takes precedence when
        the named backend actually initializes; otherwise the auto-probe runs.

        Returns:
            Backend name string
        """
        val override_name = engine2d_env_backend_override()
        if override_name != "":
            val override_canon = backend_canonical_name(override_name)
            val override_probe = Engine2D.probe_backend(1, 1, override_canon)
            if override_probe.status == BackendStatus.Initialized:
                return override_canon
        val order = backend_default_priority_order()
        var idx = 0
        val order_len = order.len()
        while idx < order_len:
            val name = order[idx]
            val probe = Engine2D.probe_backend(1, 1, name)
            if probe.status == BackendStatus.Initialized:
                return name
            idx = idx + 1
        "cpu"

    static fn list_backends() -> [text]:
        """List all available backend names.

        Returns:
            Array of backend name strings that can successfully init
        """
        var available: [text] = []

        val order = backend_default_priority_order()
        var idx = 0
        val order_len = order.len()
        while idx < order_len:
            val name = order[idx]
            val probe = Engine2D.probe_backend(1, 1, name)
            if probe.status == BackendStatus.Initialized:
                available.push(name)
            idx = idx + 1

        available

    static fn create_with_priority(width: i32, height: i32, priority: [text]) -> Engine2D:
        """Create engine using a custom backend priority order.

        Tries backends in the given order, falling back to CPU if none work.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels
            priority: Ordered list of backend names to try

        Returns:
            Initialized Engine2D
        """
        for backend_name in priority:
            val requested_backend = backend_canonical_name(backend_name)
            val engine = Engine2D.create_requested_backend(width, height, requested_backend)
            match engine:
                Ok(value):
                    return value
                Err(_):
                    pass_do_nothing
        # Fallback
        Engine2D.create_with_backend(width, height, "cpu")

    # ========================================================================
    # Backend Info
    # ========================================================================

    me backend_name() -> text:
        """Get the name of the active backend."""
        if val Some(vg) = self.virtio_gpu_backend:
            if self.selected_backend_name != "":
                return self.selected_backend_name
            return vg.name()
        elif val Some(bm) = self.baremetal_backend:
            if self.selected_backend_name != "":
                return self.selected_backend_name
            return bm.name()
        else:
            if self.selected_backend_name != "":
                return self.selected_backend_name
            return self.backend.name()

    fn vulkan_cpu_fallback_reason() -> text:
        """Return the first strict-provenance failure for a Vulkan surface."""
        if val Some(vulkan) = self.vulkan_backend:
            return vulkan.cpu_fallback_reason
        ""

    me width() -> i32:
        self.w

    me height() -> i32:
        self.h

    # ========================================================================
    # Drawing Operations (delegate to backend)
    # ========================================================================

    me clear(color: u32):
        """Clear the framebuffer to a solid color."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.clear(color)
        elif val Some(bm) = self.baremetal_backend:
            bm.clear(color)
        elif val Some(vulkan) = self.vulkan_backend:
            vulkan.clear(color)
            self.vulkan_backend = vulkan
            self.backend = vulkan
        else:
            self.backend.clear(color)

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Draw a rectangle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect(x, y, w, h, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect(x, y, w, h, color)
        else:
            self.backend.draw_rect(x, y, w, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Draw a filled rectangle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect_filled(x, y, w, h, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect_filled(x, y, w, h, color)
        elif val Some(vulkan) = self.vulkan_backend:
            vulkan.draw_rect_filled(x, y, w, h, color)
            self.vulkan_backend = vulkan
            self.backend = vulkan
        else:
            self.backend.draw_rect_filled(x, y, w, h, color)

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        """Draw a line between two points."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_line(x1, y1, x2, y2, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_line(x1, y1, x2, y2, color, thickness)
        else:
            self.backend.draw_line(x1, y1, x2, y2, color, thickness)

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        """Draw a circle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_circle(cx, cy, r, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_circle(cx, cy, r, color)
        else:
            self.backend.draw_circle(cx, cy, r, color)

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        """Draw a filled circle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_circle_filled(cx, cy, r, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_circle_filled(cx, cy, r, color)
        else:
            self.backend.draw_circle_filled(cx, cy, r, color)

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        """Draw a rounded rectangle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rounded_rect(x, y, w, h, radius, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rounded_rect(x, y, w, h, radius, color)
        else:
            self.backend.draw_rounded_rect(x, y, w, h, radius, color)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        """Draw a filled triangle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        else:
            self.backend.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        """Draw a rectangle with vertical gradient."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        else:
            self.backend.draw_gradient_rect(x, y, w, h, top_color, bottom_color)

    me _draw_font_batch(x: i32, y: i32, batch: FontRenderBatch) -> bool:
        self._draw_font_batch_plan(x, y, batch, ["cuda", "metal", "opencl", "vulkan", "rocm", "cpu"])

    me _draw_font_batch_cpu_suffix(x: i32, y: i32, batch: FontRenderBatch, submitted: i64) -> i64:
        var quad_index = if submitted < 0 or submitted > batch.quads.len(): 0 else: submitted
        while quad_index < batch.quads.len():
            val quad = batch.quads[quad_index]
            val pixels = engine2d_font_atlas_subrect_pixels(
                batch.atlas_pixels, batch.atlas_width, batch.atlas_height,
                quad.atlas_x, quad.atlas_y, quad.width, quad.height, quad.color
            )
            # See doc/08_tracking/bug/font_render_batch_transform_identity_default_not_applied_2026-07-19.md
            # (BLOCKER B): the Option<i32>-returning font_destination_origin(...).?
            # round-trip decoded to a CONSTANT (1, 1) for every quad of every
            # draw here on this freestanding target -- confirmed via gated
            # boot probes: dst_x=1 dst_y=1 regardless of x spanning 6..3788
            # and quad.dst_x varying per glyph, which collapsed every draw's
            # glyphs onto the same origin pixel. Same "constructed value loses
            # its real payload" family as the transform_identity class-default
            # bug. Compute the destination with plain i64 arithmetic and an
            # explicit bounds check instead of routing through the Option
            # helper, so the real value survives.
            val dst_x_i64 = x.to_i64() + quad.dst_x.to_i64()
            val dst_y_i64 = y.to_i64() + quad.dst_y.to_i64()
            val dst_x_end = dst_x_i64 + quad.width.to_i64() - 1
            val dst_y_end = dst_y_i64 + quad.height.to_i64() - 1
            val dst_in_range = (quad.width > 0 and quad.height > 0 and
                dst_x_i64 >= -2147483648 and dst_x_i64 <= 2147483647 and
                dst_x_end >= -2147483648 and dst_x_end <= 2147483647 and
                dst_y_i64 >= -2147483648 and dst_y_i64 <= 2147483647 and
                dst_y_end >= -2147483648 and dst_y_end <= 2147483647)
            if _VEC_TEXT_PROBE and _vec_blit_probe_count < 8:
                _vec_blit_probe_count = _vec_blit_probe_count + 1
                var pnz = 0
                var pi: i64 = 0
                while pi < pixels.len():
                    if ((pixels[pi] >> 24) & 0xFFu32) > 0u32:
                        pnz = pnz + 1
                    pi = pi + 1
                var dxs = "nil"
                var dys = "nil"
                if dst_in_range:
                    dxs = "{dst_x_i64}"
                    dys = "{dst_y_i64}"
                print("[vec-text-probe] blit qi={quad_index} w={quad.width} h={quad.height} pix_len={pixels.len()} expect={quad.width.to_i64() * quad.height.to_i64()} pix_nz={pnz} color_a={(quad.color >> 24) & 0xFFu32} dst_x={dxs} dst_y={dys} x={x} y={y}")
            if pixels.len() == quad.width.to_i64() * quad.height.to_i64() and dst_in_range:
                self.draw_image_blend(dst_x_i64 as i32, dst_y_i64 as i32, quad.width, quad.height, pixels)
            quad_index = quad_index + 1
        quad_index

    me _draw_font_batch_plan(x: i32, y: i32, batch: FontRenderBatch, plan: [text]) -> bool:
        # Snapshot once, up front: the same `batch.material_supported()` call
        # expression also appears inside the probe's print() interpolation
        # below (root cause of a duplicate-call CSE hazard; see history).
        # But calling the zero-arg method `batch.material_supported()` on a
        # non-self local here never materializes the receiver into its ABI
        # register (rdi) at all -- disassembly confirmed the call site simply
        # reuses whatever rdi already held (the enclosing self), regardless
        # of call ordering, unlike ordinary explicit-argument method calls
        # (e.g. `cuda.draw_font_batch(x, y, batch)` a few hundred bytes
        # later, which DOES reload every argument, including the receiver,
        # from its spill slot before calling). Inlining the body here avoids
        # the receiver-dispatch call entirely: `batch.valid` /
        # `batch.program_version` / `batch.transform_identity` are plain
        # field loads (no ABI materialization needed) and
        # `font_atlas_composite_program_version_valid` is a free function
        # taking an explicit i64, not a receiver-dispatch call.
        val n_quads_total = batch.quads.len()
        val material_ok = batch.valid and
            font_atlas_composite_program_version_valid(batch.program_version) and
            batch.transform_identity == "uniform-scale;translate-late"
        if _VEC_TEXT_PROBE and _vec_text_probe_count < 8:
            _vec_text_probe_count = _vec_text_probe_count + 1
            val n_quads = n_quads_total
            var nz = 0
            var first_w = 0
            var first_h = 0
            var first_ax = 0
            var first_ay = 0
            var first_color_a: u32 = 0u32
            if n_quads > 0:
                val fq = batch.quads[0]
                first_w = fq.width
                first_h = fq.height
                first_ax = fq.atlas_x
                first_ay = fq.atlas_y
                first_color_a = (fq.color >> 24) & 0xFFu32
                var row = 0
                while row < fq.height:
                    var col = 0
                    while col < fq.width:
                        val idx = (fq.atlas_y + row) * batch.atlas_width + fq.atlas_x + col
                        if idx.to_i64() >= 0 and idx.to_i64() < batch.atlas_pixels.len():
                            val px = batch.atlas_pixels[idx]
                            if ((px >> 24) & 0xFFu32) > 0u32:
                                nz = nz + 1
                        col = col + 1
                    row = row + 1
            print("[vec-text-probe] consumer valid={batch.valid} material_supported={material_ok} n_quads={n_quads} atlas_len={batch.atlas_pixels.len()} first_w={first_w} first_h={first_h} first_ax={first_ax} first_ay={first_ay} first_cov_nz={nz} color_a={first_color_a}")
        if not material_ok or plan.len() == 0:
            return false
        var quad_index: i64 = 0
        var attempts: [text] = []
        var winner = ""
        for target in plan:
            if self.vulkan_font_state_unknown and target != "cpu":
                attempts.push(target + ":poisoned-skip")
            elif quad_index > 0 and target != "cpu":
                attempts.push(target + ":skipped-partial")
            elif target == "cuda":
                val active = self.cuda_backend
                if active == nil:
                    attempts.push("cuda:unavailable")
                else:
                    val cuda = active
                    quad_index = cuda.draw_font_batch(x, y, batch)
                    self.cuda_backend = cuda
                    if quad_index < 0 or quad_index > batch.quads.len(): quad_index = 0
                    attempts.push(if quad_index == batch.quads.len(): "cuda:success" else: "cuda:failed")
                    if quad_index == batch.quads.len(): winner = "cuda"
            elif target == "metal":
                val active = self.metal_backend
                if active == nil:
                    attempts.push("metal:unavailable")
                else:
                    val metal = active
                    quad_index = metal.draw_font_batch(x, y, batch)
                    self.metal_backend = metal
                    if quad_index < 0 or quad_index > batch.quads.len(): quad_index = 0
                    attempts.push(if quad_index == batch.quads.len(): "metal:success" else: "metal:failed")
                    if quad_index == batch.quads.len(): winner = "metal"
            elif target == "opencl":
                val active = self.opencl_backend
                if active == nil:
                    attempts.push("opencl:unavailable")
                else:
                    val opencl = active
                    quad_index = opencl.draw_font_batch(x, y, batch)
                    self.opencl_backend = opencl
                    if quad_index < 0 or quad_index > batch.quads.len(): quad_index = 0
                    attempts.push(if quad_index == batch.quads.len(): "opencl:success" else: "opencl:failed")
                    if quad_index == batch.quads.len(): winner = "opencl"
            elif target == "vulkan":
                val active = self.vulkan_backend
                if active == nil:
                    attempts.push("vulkan:unavailable")
                else:
                    val vulkan = active
                    # var (not val): evidence.fallback_pixels is cleared below;
                    # W1006 mut-capability failure here silently killed
                    # whole-program JIT (2026-07-18).
                    var evidence = vulkan.composite_font_batch(x, y, batch)
                    self.last_vulkan_font_evidence = evidence
                    self.vulkan_backend = vulkan
                    attempts.push("vulkan:" + evidence.reason)
                    if (evidence.reason == "partial-framebuffer-restore-failed" or
                        evidence.reason == "missing-command-cleanup-capability" or
                        evidence.reason == "descriptor-cleanup-failed" or
                        evidence.reason == "atlas-cleanup-failed" or
                        evidence.reason == "fence-completion-unknown" or
                        evidence.reason == "device-lost" or
                        evidence.reason == "fence-cleanup-failed" or
                        evidence.reason == "fence-wait-evidence-failed" or
                        evidence.reason == "cleanup-failed"):
                        self.last_font_execution_attempts = attempts
                        self.last_font_execution_target = ""
                        self._poison_vulkan_font_surface(evidence.fallback_pixels)
                        evidence.fallback_pixels = []
                        self.last_vulkan_font_evidence = evidence
                        quad_index = 0
                        continue
                    if evidence.promotion_ready and evidence.dispatch_count == batch.quads.len():
                        quad_index = batch.quads.len()
                        winner = "vulkan"
            elif target == "rocm":
                val active = self.rocm_backend
                if active == nil:
                    attempts.push("rocm:unavailable")
                else:
                    val rocm = active
                    quad_index = rocm.draw_font_batch(x, y, batch)
                    self.rocm_backend = rocm
                    if rocm.initialized:
                        self.backend = rocm
                    if quad_index < 0 or quad_index > batch.quads.len(): quad_index = 0
                    attempts.push(if quad_index == batch.quads.len(): "rocm:success" else: "rocm:failed")
                    if quad_index == batch.quads.len(): winner = "rocm"
            elif target == "cpu":
                attempts.push("cpu:success")
                quad_index = self._draw_font_batch_cpu_suffix(x, y, batch, quad_index)
                winner = "cpu"
            if winner != "":
                break
        self.last_font_execution_attempts = attempts
        self.last_font_execution_target = winner
        winner != ""

    me draw_glyph_run(x: i32, y: i32, run: FontGlyphRun, color: u32, font_size: i32) -> bool:
        val fonts = self.fonts()
        val batch = fonts.prepare_glyph_run(run, color, font_size)
        self.font_renderer = fonts
        self._draw_font_batch(x, y, batch)

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        """Draw a selected vector face fail-closed, or use the bitmap default."""
        val selected = self.font_renderer
        var has_ttf = false
        if selected != nil:
            has_ttf = selected.has_sffi_ttf()
        if _VEC_TEXT_PROBE and _vec_entry_probe_count < 8:
            _vec_entry_probe_count = _vec_entry_probe_count + 1
            print("[vec-text-probe] draw_text-entry text_len={text_val.len()} font_renderer_nil={selected == nil} has_sffi_ttf={has_ttf} vulkan_font_state_unknown={self.vulkan_font_state_unknown} selected_backend={self.selected_backend_name}")
        if selected != nil:
            val fonts = selected
            if fonts.has_sffi_ttf():
                if _VEC_TEXT_PROBE and _vec_entry_probe_count < 24:
                    _vec_entry_probe_count = _vec_entry_probe_count + 1
                    print("[vec-text-probe] about-to-call-draw_text_configured")
                val configured_ok = self.draw_text_configured(
                    x, y, text_val, color, engine2d_default_font_config_for(font_size, self.baremetal_backend != nil)
                )
                if _VEC_TEXT_PROBE and _vec_entry_probe_count < 24:
                    _vec_entry_probe_count = _vec_entry_probe_count + 1
                    print("[vec-text-probe] returned-from-draw_text_configured ok={configured_ok}")
                return
        if self.vulkan_font_state_unknown:
            return
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_text(x, y, text_val, color, font_size)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_text(x, y, text_val, color, font_size)
        else:
            self.backend.draw_text(x, y, text_val, color, font_size)

    me draw_text_configured(x: i32, y: i32, text_val: text, color: u32, config: FontRenderConfig) -> bool:
        if _VEC_TEXT_PROBE and _vec_entry_probe_count < 24:
            _vec_entry_probe_count = _vec_entry_probe_count + 1
            print("[vec-text-probe] draw_text_configured-FIRST-LINE")
        val plan = font_execution_plan(config, ["cuda", "metal", "opencl", "vulkan", "rocm", "cpu"])
        if _VEC_TEXT_PROBE and _vec_entry_probe_count < 24:
            _vec_entry_probe_count = _vec_entry_probe_count + 1
            val policy_is_suggested = config.execution_policy == FontExecutionPolicy.Suggested
            val policy_is_preferred = config.execution_policy == FontExecutionPolicy.Preferred
            val policy_is_required = config.execution_policy == FontExecutionPolicy.Required
            print("[vec-text-probe] draw_text_configured-entry plan_len={plan.len()} selection_supported={font_render_config_selection_supported(config)} family={config.family} category={config.category} exec_target={config.execution_target} size={config.size} weight={config.weight} style={config.style} hinting={config.hinting} antialiasing={config.antialiasing} atlas_policy={config.atlas_policy} language={config.language} script={config.script} policy_suggested={policy_is_suggested} policy_preferred={policy_is_preferred} policy_required={policy_is_required}")
        if plan.len() == 0 or not font_render_config_selection_supported(config):
            return false
        val fonts = self.fonts()
        val batch = fonts.prepare_text_configured(text_val, color, config)
        self.font_renderer = fonts
        self._draw_font_batch_plan(x, y, batch, plan)

    me draw_text_with_advances(x: i32, y: i32, text_val: text, advance_widths: [i32], color: u32, font_size: i32) -> bool:
        """Draw producer-resolved text through the selected vector face."""
        self.draw_text_with_advances_configured(
            x, y, text_val, advance_widths, color, engine2d_default_font_config_for(font_size, self.baremetal_backend != nil)
        )

    me draw_text_with_advances_configured(x: i32, y: i32, text_val: text, advance_widths: [i32], color: u32, config: FontRenderConfig) -> bool:
        val plan = font_execution_plan(config, ["cuda", "metal", "opencl", "vulkan", "rocm", "cpu"])
