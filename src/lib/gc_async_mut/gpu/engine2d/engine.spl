#![allow(large_file)]  # Intentional: backend dispatch state remains in the Engine2D owner.
# 2D Engine — Engine Facade
#
# High-level entry point that auto-selects the best available rendering
# backend and delegates all drawing operations to it.
#
# Backend priority: metal > cuda > rocm/hip > qualcomm > vulkan > directx > opencl > opengl > intel > webgpu > cpu_simd > software > cpu
#
# Usage:
#   use std.gpu.engine2d.engine.{Engine2D}
#
#   var engine = Engine2D.create(800, 600)
#   engine.clear(color_white())
#   engine.draw_rect_filled(10, 10, 100, 50, color_red())
#   engine.present()
#   val pixels = engine.read_pixels()

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended, Engine2DReadback, engine2d_readback}
use std.gpu.engine2d.color.{color_r, color_g, color_b, color_a, rgba}
use std.gpu.engine2d.backend_emu.{
    emu_draw_text_bg,
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled, emu_draw_image_scaled_blend,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.gpu.engine2d.backend_baremetal.{BaremetalBackend}
use std.gpu.engine2d.backend_virtio_gpu.{VirtioGpuBackend}
use std.gpu.engine2d.backend_cpu.{CpuBackend}
use std.gpu.engine2d.backend_cuda.{CudaBackend}
use std.gpu.engine2d.backend_cuda_font_ptx.{FONT_ATLAS_COMPOSITE_CUDA_PTX_SHA256, FONT_ATLAS_COMPOSITE_CUDA_PROGRAM_VERSION, FONT_ATLAS_COMPOSITE_CUDA_SEMANTICS_VERSION, cuda_font_atlas_composite_ptx, cuda_font_atlas_composite_ptx_trusted}
use std.gc_async_mut.gpu.engine2d.cuda_session.{CUDA_FONT_PTX_MAX_BYTES}
use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gpu.engine2d.backend_vulkan_font
use std.gpu.engine2d.backend_vulkan_font_types.{VulkanFontCompositeEvidence}
use std.gc_async_mut.gpu.engine2d.vulkan_session.{VulkanSession}
use std.gpu.engine2d.backend_directx.{DirectXBackend}
use std.gpu.engine2d.backend_opencl.{OpenClBackend}
use std.gpu.engine2d.backend_opengl.{OpenGLBackend}
use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gpu.engine2d.simd_kernels.{native_pixel_rows_enabled, active_arch_text, active_feature_text}
use std.gpu.engine2d.backend_metal.{MetalBackend}
use std.gpu.engine2d.backend_rocm.{RocmBackend}
