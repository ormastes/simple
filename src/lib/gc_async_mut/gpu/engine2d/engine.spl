        """Set the clipping rectangle. Drawing outside this rect is discarded."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.set_clip(x, y, w, h)
        elif val Some(bm) = self.baremetal_backend:
            bm.set_clip(x, y, w, h)
        else:
