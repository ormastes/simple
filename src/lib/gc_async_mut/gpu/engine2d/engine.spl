    me _draw_font_batch(x: i32, y: i32, batch: FontRenderBatch) -> bool:
        if not batch.valid:
            return false
        var quad_index: i64 = 0
        val active_opencl = self.opencl_backend
        if active_opencl != nil:
            val opencl = active_opencl
            quad_index = opencl.draw_font_batch(x, y, batch)
            self.opencl_backend = opencl
            if quad_index < 0 or quad_index > batch.quads.len():
                quad_index = 0
        while quad_index < batch.quads.len():
            val quad = batch.quads[quad_index]
            val pixels = engine2d_font_atlas_subrect_pixels(
                batch.atlas_pixels, batch.atlas_width, batch.atlas_height,
                quad.atlas_x, quad.atlas_y, quad.width, quad.height, quad.color
            )
            if pixels.len() == (quad.width * quad.height).to_i64():
                self.draw_image_blend(x + quad.dst_x, y + quad.dst_y, quad.width, quad.height, pixels)
            quad_index = quad_index + 1
        true

    me draw_glyph_run(x: i32, y: i32, run: FontGlyphRun, color: u32, font_size: i32) -> bool:
        val fonts = self.fonts()
        val batch = fonts.prepare_glyph_run(run, color, font_size)
        self.font_renderer = fonts
        self._draw_font_batch(x, y, batch)

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        """Draw selected vector text, or the existing bitmap default."""
        val selected = self.font_renderer
        if selected != nil:
            val fonts = selected
            if fonts.has_sffi_ttf():
                val batch = fonts.prepare_text(text_val, color, font_size)
                self.font_renderer = fonts
                if self._draw_font_batch(x, y, batch):
                    return
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_text(x, y, text_val, color, font_size)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_text(x, y, text_val, color, font_size)
        else:
            self.backend.draw_text(x, y, text_val, color, font_size)

    me load_font(path: text) -> bool:
        """Select one trusted TTF/OTF for process-wide Simple 2D text."""
        val active_opencl = self.opencl_backend
        if active_opencl != nil:
            val opencl = active_opencl
            opencl.invalidate_font_atlas()
            self.opencl_backend = opencl
        val fonts = self.fonts()
        val loaded = fonts.try_load_runtime_ttf(path)
        self.font_renderer = fonts
        loaded

    me unload_font():
        """Restore the zero-config bitmap text path."""
        val active_opencl = self.opencl_backend
        if active_opencl != nil:
            val opencl = active_opencl
            opencl.invalidate_font_atlas()
            self.opencl_backend = opencl
        val selected = self.font_renderer
        if selected != nil:
            val fonts = selected
            fonts.clear_ttf()
        self.font_renderer = nil

    me font_cache_stats() -> FontCacheStats:
        val fonts = self.fonts()
        fonts.cache_stats()

    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        """Draw text with an explicit background colour per glyph cell.

        A selected vector face uses its measured advance/line height and the
        same antialiased `draw_text` path. Bitmap mode keeps the existing
        backend cell painter. This is the method `Engine2dCompositorBackend`
        and other GUI wrappers should call.
        """
        val selected = self.font_renderer
        if selected != nil:
            val fonts = selected
            if fonts.has_sffi_ttf() and font_size > 0 and font_size <= 512:
                val text_width = fonts.measure_text_width(text_val, font_size)
                var line_height = fonts.horizontal_line_metric(font_size, 3)
                self.font_renderer = fonts
                if line_height <= 0:
                    line_height = font_size
                if text_width > 0:
                    self.draw_rect_filled(x, y, text_width, line_height, bg)
                self.draw_text(x, y, text_val, fg, font_size)
                return
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        else:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)

