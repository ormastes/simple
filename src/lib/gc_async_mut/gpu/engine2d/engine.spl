    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Typed receivers on the if-val bindings: bare calls on the erased
        # bindings trip the AOT ambiguous-method guard (28 candidates) and
        # blocked `bin/simple compile` of the web showcase (2026-07-18); same
        # class as draw_image_scaled above.
        if val Some(vg) = self.virtio_gpu_backend:
            var vg_typed: VirtioGpuBackend = vg
            vg_typed.draw_image_blend(x, y, w, h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            var bm_typed: BaremetalBackend = bm
            bm_typed.draw_image_blend(x, y, w, h, pixels)
        else:
            # emu_* free-function route like draw_image_scaled: the AOT lane
            # also flags the `self.backend.<method>` trait-object call as a
            # bare 28-candidate ambiguity (2026-07-18).
            emu_draw_image_blend(self.backend, x, y, w, h, pixels)

    me draw_engine(dst_x: i32, dst_y: i32, src: Engine2D):
        """Composite an embedded render target (typically an offscreen Engine2D
        from create_offscreen()) into self at (dst_x, dst_y).

        Reads back src's framebuffer and alpha-blends it over self via
        draw_image_blend — the core "rendering-inside-rendering" primitive:
        a nested engine's finished frame becomes one blit into the parent.
        """
        self.draw_image_blend(dst_x, dst_y, src.width(), src.height(), src.read_pixels())

    me draw_engine_opacity(dst_x: i32, dst_y: i32, src: Engine2D, opacity_milli: i32):
        """Like draw_engine, but scales src's pixel alpha by opacity_milli/1000
        (1000 = fully opaque) before compositing.

        draw_image_blend has no opacity parameter of its own, so a
        sub-opacity embed premultiplies the scale into each source pixel's
        alpha channel first, then blends normally.
        """
        if opacity_milli >= 1000:
            self.draw_engine(dst_x, dst_y, src)
            return
        if opacity_milli <= 0:
            return
        val scaled = engine2d_scale_pixel_alpha(src.read_pixels(), opacity_milli)
        self.draw_image_blend(dst_x, dst_y, src.width(), src.height(), scaled)

    me draw_software_offscreen_opacity_consume(dst_x: i32, dst_y: i32, src: Engine2D, opacity_milli: i32) -> bool:
        """Composite a SOFTWARE offscreen into self at opacity_milli/1000,
        CONSUMING src: scale src's own buffer alpha in place and blend it
        directly, with NO read_pixels() snapshot and NO
        engine2d_scale_pixel_alpha() copy.

        Returns true when the fast in-place path applied (src is software
        backed), false otherwise so the caller falls back to
        draw_engine_opacity(). Only call when src's pixels will not be reused
        unscaled (e.g. a scratch embedded offscreen cleared before its next
        use). This keeps translucent-window compositing on the non-reclaiming
        SimpleOS baremetal bump heap from leaking two full-surface scratch
        arrays per window.
        """
        if opacity_milli <= 0:
            return true
        val src_software: SoftwareBackend? = src.software_backend
        if val Some(sw) = src_software:
            if opacity_milli < 1000:
                sw.scale_alpha_in_place(opacity_milli)
            self.draw_image_blend(dst_x, dst_y, sw.w, sw.h, sw.buf)
            return true
        false

    me draw_vulkan_image_blend_checked(dst_x: i32, dst_y: i32, width: i32, height: i32, pixels: [u32], opacity_milli: i32) -> bool:
        """Blend child pixels only through the active checked Vulkan path."""
        val active = self.vulkan_backend
        if active == nil:
            return false
        val vulkan = active
        val completed = vulkan.draw_image_blend_checked(dst_x, dst_y, width, height, pixels, opacity_milli)
        self.vulkan_backend = vulkan
        completed

    me draw_metal_image_blend_checked(dst_x: i32, dst_y: i32, width: i32, height: i32, pixels: [u32], opacity_milli: i32) -> bool:
        """Blend child pixels only through the active checked Metal path."""
        val active = self.metal_backend
        if active == nil:
            return false
        val metal = active
        val completed = metal.draw_image_blend_checked(dst_x, dst_y, width, height, pixels, opacity_milli)
        self.metal_backend = metal
        completed

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        if dst_w == src_w and dst_h == src_h:
            self.draw_image(dst_x, dst_y, dst_w, dst_h, pixels)
            return
        if val Some(vulkan) = self.vulkan_backend:
            # Typed receiver: the if-val binding is type-erased and the AOT
            # codegen's ambiguous-method guard refuses a bare
            # draw_image_scaled with 26 candidates (blocked `bin/simple
            # compile` of every Engine2D user, 2026-07-18).
            var vulkan_typed: VulkanBackend = vulkan
            vulkan_typed.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
            self.vulkan_backend = vulkan_typed
        elif val Some(vg) = self.virtio_gpu_backend:
            emu_draw_image_scaled(self.backend, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_image_scaled(self.backend, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        else:
            emu_draw_image_scaled(self.backend, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_image_scaled_blend(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        if dst_w == src_w and dst_h == src_h:
            self.draw_image_blend(dst_x, dst_y, dst_w, dst_h, pixels)
            return
        if val Some(vulkan) = self.vulkan_backend:
            vulkan.draw_image_scaled_blend(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
            self.vulkan_backend = vulkan
        else:
            emu_draw_image_scaled_blend(self.backend, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_triangle_outline(self.backend, x1, y1, x2, y2, x3, y3, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_triangle_outline(self.backend, x1, y1, x2, y2, x3, y3, color, thickness)
        else:
            emu_draw_triangle_outline(self.backend, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_blur_rect(self.backend, x, y, w, h, radius)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_blur_rect(self.backend, x, y, w, h, radius)
        else:
            emu_draw_blur_rect(self.backend, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_shadow_rect(self.backend, x, y, w, h, offset_x, offset_y, blur_r, color)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_shadow_rect(self.backend, x, y, w, h, offset_x, offset_y, blur_r, color)
        else:
            emu_draw_shadow_rect(self.backend, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_image_transform(self.backend, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_image_transform(self.backend, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)
        else:
            emu_draw_image_transform(self.backend, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_rect_blend_mode(self.backend, x, y, w, h, color, mode)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_rect_blend_mode(self.backend, x, y, w, h, color, mode)
        else:
            emu_draw_rect_blend_mode(self.backend, x, y, w, h, color, mode)

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.set_mask(mask_pixels, w, h)
        elif val Some(bm) = self.baremetal_backend:
            bm.set_mask(mask_pixels, w, h)
        else:
            self.backend.set_mask(mask_pixels, w, h)

    me clear_mask():
        if val Some(vg) = self.virtio_gpu_backend:
            vg.clear_mask()
        elif val Some(bm) = self.baremetal_backend:
            bm.clear_mask()
        else:
            self.backend.clear_mask()

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        """Set the clipping rectangle. Drawing outside this rect is discarded."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.set_clip(x, y, w, h)
        elif val Some(bm) = self.baremetal_backend:
            bm.set_clip(x, y, w, h)
        else:
            self.backend.set_clip(x, y, w, h)

    me clear_clip():
        """Remove the clipping rectangle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.clear_clip()
        elif val Some(bm) = self.baremetal_backend:
            bm.clear_clip()
        else:
            self.backend.clear_clip()

    me present():
        """Flush the framebuffer to the screen / finalize the frame."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.present()
        elif val Some(bm) = self.baremetal_backend:
            bm.present()
        elif val Some(vulkan) = self.vulkan_backend:
            vulkan.present()
            self.vulkan_backend = vulkan
            self.backend = vulkan
        else:
            self.backend.present()

    me read_pixels() -> [u32]:
        # Checksum-free readback: delegate straight to the backend's read_pixels
        # (which, for the Metal GPU-only/native path, is a single-FFI download
        # returning the [u32] framebuffer). read_pixels_with_source() still
        # computes the O(n) Simple checksum for evidence rows; callers that only
        # need pixels avoid that cost here.
        if val Some(vg) = self.virtio_gpu_backend:
            return vg.read_pixels()
        elif val Some(bm) = self.baremetal_backend:
            return bm.read_pixels()
        elif val Some(vulkan) = self.vulkan_backend:
            val pixels = vulkan.read_pixels()
            self.vulkan_backend = vulkan
            self.backend = vulkan
            return pixels
        else:
            return self.backend.read_pixels()

    me read_pixels_with_source() -> Engine2DReadback:
        """Read the framebuffer contents as a flat u32 array."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.read_pixels_with_source()
        elif val Some(bm) = self.baremetal_backend:
            bm.read_pixels_with_source()
        elif val Some(vulkan) = self.vulkan_backend:
            val readback = vulkan.read_pixels_with_source()
            self.vulkan_backend = vulkan
            self.backend = vulkan
            readback
        else:
            self.backend.read_pixels_with_source()

    # ========================================================================
    # Lifecycle
    # ========================================================================

    me shutdown():
        """Shut down the backend and release all resources."""
        self.unload_font()
        if self.vulkan_font_state_unknown:
            if val Some(vulkan) = self.vulkan_backend:
                vulkan.shutdown()
                if vulkan.completion_unknown:
                    self.vulkan_backend = vulkan
                else:
                    self.vulkan_backend = nil
        if val Some(vg) = self.virtio_gpu_backend:
            vg.shutdown()
        elif val Some(bm) = self.baremetal_backend:
            bm.shutdown()
        else:
            self.backend.shutdown()

    # ========================================================================
    # Frame pacing (AC-7)
    # ========================================================================

    me tick_forever(draw_fn: fn() -> bool):
        """Run the frame loop until draw_fn returns false.

        Uses event-sleep pacing (tick_once) instead of tight spinning so the
        WM thread yields CPU between frames.  FramePacingCounters are updated
        every tick and are readable via get_frame_pacing().

        Args:
            draw_fn: Called each tick to issue draw commands and call present().
                     Return false to stop the loop.
        """
        var running = true
        while running:
            running = draw_fn()
            tick_once(self.pacing)

    fn get_frame_pacing() -> FramePacingCounters:
        """Return the current accumulated frame-pacing counters."""
        self.pacing
