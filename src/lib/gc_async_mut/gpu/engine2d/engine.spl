    me load_font(path: text) -> bool:
        """Select one trusted TTF/OTF for process-wide Simple 2D text."""
        val active_cuda = self.cuda_backend
        if active_cuda != nil:
            val cuda = active_cuda
            cuda.invalidate_font_atlas()
            self.cuda_backend = cuda
        val active_opencl = self.opencl_backend
        if active_opencl != nil:
            val opencl = active_opencl
            opencl.invalidate_font_atlas()
            self.opencl_backend = opencl
        val active_metal = self.metal_backend
        if active_metal != nil:
            val metal = active_metal
            metal.invalidate_font_atlas()
            self.metal_backend = metal
        val active_rocm = self.rocm_backend
        if active_rocm != nil:
            val rocm = active_rocm
            rocm.invalidate_font_atlas()
            self.rocm_backend = rocm
            if rocm.initialized:
                self.backend = rocm
        val fonts = self.fonts()
        val loaded = fonts.try_load_runtime_ttf(path)
        self.font_renderer = fonts
        loaded

    me load_font_bytes(path: text, blob: [u8]) -> bool:
        val fonts = self.fonts()
        val loaded = fonts.try_load_selected_bytes(path, blob)
        self.font_renderer = fonts
        loaded

    me select_font_identity(identity: text) -> bool:
        """Select the exact bundled face named by a stable Draw IR identity."""
        if identity == "":
            return false
        val active = self.font_renderer
        if active != nil:
            val fonts = active
            val current_identity = fonts.current_font_identity()
            self.font_renderer = fonts
            if current_identity == identity:
                return true
        val candidate = selected_font_asset_candidate_for_identity(identity)
        if candidate == nil:
            return false
        val fonts = self.fonts()
        val registered = fonts.try_load_registered_identity(identity)
        self.font_renderer = fonts
        if (not registered and
            (font_renderer_registered_selected_bytes_only() or not self.load_font(candidate.?.local_path))):
            return false
        val loaded_fonts = self.fonts()
        val loaded_identity = loaded_fonts.current_font_identity()
        self.font_renderer = loaded_fonts
        if loaded_identity == identity:
            return true
        self.unload_font()
        false

    me unload_font():
        """Restore the zero-config bitmap text path."""
        val active_cuda = self.cuda_backend
        if active_cuda != nil:
            val cuda = active_cuda
            cuda.invalidate_font_atlas()
            self.cuda_backend = cuda
        val active_opencl = self.opencl_backend
        if active_opencl != nil:
            val opencl = active_opencl
            opencl.invalidate_font_atlas()
            self.opencl_backend = opencl
        val active_metal = self.metal_backend
        if active_metal != nil:
            val metal = active_metal
            metal.invalidate_font_atlas()
            self.metal_backend = metal
        val active_rocm = self.rocm_backend
        if active_rocm != nil:
            val rocm = active_rocm
            rocm.invalidate_font_atlas()
            self.rocm_backend = rocm
            if rocm.initialized:
                self.backend = rocm
        val selected = self.font_renderer
        if selected != nil:
            val fonts = selected
            fonts.clear_ttf()
        self.font_renderer = nil

    me font_cache_stats() -> FontCacheStats:
        val fonts = self.fonts()
        fonts.cache_stats()

    fn vulkan_font_performance_evidence() -> VulkanFontCompositeEvidence?:
        self.last_vulkan_font_evidence

    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        """Draw text with an explicit background colour per glyph cell.

        A selected vector face uses its measured advance/line height and the
        same antialiased `draw_text` path. Bitmap mode keeps the existing
        backend cell painter. This is the method `Engine2dCompositorBackend`
        and other GUI wrappers should call.
        """
        val selected = self.font_renderer
        if selected != nil:
            val fonts = selected
            if fonts.has_sffi_ttf() and font_size > 0 and font_size <= 512:
                val text_width = fonts.measure_text_width(text_val, font_size)
                var line_height = fonts.horizontal_line_metric(font_size, 3)
                self.font_renderer = fonts
                if line_height <= 0:
                    line_height = font_size
                if text_width > 0:
                    self.draw_rect_filled(x, y, text_width, line_height, bg)
                self.draw_text(x, y, text_val, fg, font_size)
                return
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        else:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        """Blit a pixel array onto the framebuffer."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_image(x, y, w, h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_image(x, y, w, h, pixels)
        elif val Some(vulkan) = self.vulkan_backend:
            vulkan.draw_image(x, y, w, h, pixels)
            self.vulkan_backend = vulkan
            self.backend = vulkan
        else:
            self.backend.draw_image(x, y, w, h, pixels)

