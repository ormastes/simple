    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        """Draw text with an explicit background colour per glyph cell.

        Delegates to the backend's `Engine2DExtended.draw_text_bg` which
        paints the text foreground plus a per-pixel background, preserving
        antialiased glyph edges (unlike a pre-paint-rect hack that would
        destroy them). This is the method `Engine2dCompositorBackend`
        (and any other `CompositorBackend`-shaped wrapper) should call
        instead of pre-painting an opaque rect and then overlaying
        `draw_text`.
        """
        if val Some(vg) = self.virtio_gpu_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        elif val Some(bm) = self.baremetal_backend:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)
        else:
            emu_draw_text_bg(self.backend, x, y, text_val, fg, bg, font_size)

