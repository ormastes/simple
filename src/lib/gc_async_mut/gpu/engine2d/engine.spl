    me draw_engine(dst_x: i32, dst_y: i32, src: Engine2D):
        """Composite an embedded render target (typically an offscreen Engine2D
        from create_offscreen()) into self at (dst_x, dst_y).

        Reads back src's framebuffer and alpha-blends it over self via
        draw_image_blend — the core "rendering-inside-rendering" primitive:
        a nested engine's finished frame becomes one blit into the parent.
        """
        self.draw_image_blend(dst_x, dst_y, src.width(), src.height(), src.read_pixels())

    me draw_engine_opacity(dst_x: i32, dst_y: i32, src: Engine2D, opacity_milli: i32):
        """Like draw_engine, but scales src's pixel alpha by opacity_milli/1000
        (1000 = fully opaque) before compositing.

        draw_image_blend has no opacity parameter of its own, so a
        sub-opacity embed premultiplies the scale into each source pixel's
        alpha channel first, then blends normally.
        """
        if opacity_milli >= 1000:
            self.draw_engine(dst_x, dst_y, src)
            return
        if opacity_milli <= 0:
            return
        val scaled = engine2d_scale_pixel_alpha(src.read_pixels(), opacity_milli)
        self.draw_image_blend(dst_x, dst_y, src.width(), src.height(), scaled)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
