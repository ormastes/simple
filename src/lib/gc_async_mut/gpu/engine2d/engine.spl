# 2D Engine — Engine Facade
#
# High-level entry point that auto-selects the best available rendering
# backend and delegates all drawing operations to it.
#
# Backend priority: cuda > vulkan > opengl > software > cpu
#
# Usage:
#   use std.gpu.engine2d.engine.{Engine2D}
#
#   var engine = Engine2D.create(800, 600)
#   engine.clear(color_white())
#   engine.draw_rect_filled(10, 10, 100, 50, color_red())
#   engine.present()
#   val pixels = engine.read_pixels()

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.backend_cpu.{CpuBackend}
use std.gpu.engine2d.backend_cuda.{CudaBackend}
use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gpu.engine2d.backend_opengl.{OpenGLBackend}
use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gpu.engine2d.backend_baremetal.{BaremetalBackend}
use std.gpu.engine2d.backend_virtio_gpu.{VirtioGpuBackend}
use std.gpu.engine2d.backend_metal.{MetalBackend}
use std.gpu.engine2d.backend_rocm.{RocmBackend}
use std.gpu.engine2d.backend_intel.{IntelBackend}
use std.gpu.engine2d.backend_webgpu.{WebGpuBackend}
use std.gpu.engine2d.backend_qualcomm.{QualcommBackend}

# ============================================================================
# Engine2D
# ============================================================================

class Engine2D:
    """2D rendering engine with automatic backend selection.

    Creates the best available backend at initialization time. All drawing
    methods delegate to the active backend through the RenderBackend trait.

    Lifecycle:
        1. Engine2D.create(width, height)  — auto-detect and init backend
        2. clear(), draw_*(), present()     — render frames
        3. shutdown()                       — release resources

    Example:
        var engine = Engine2D.create(800, 600)
        print "Using backend: {engine.backend_name()}"

        engine.clear(rgb(30, 30, 30))
        engine.draw_rect_filled(10, 10, 200, 100, rgb(255, 0, 0))
        engine.draw_text(20, 40, "Hello Engine2D", rgb(255, 255, 255), 14)
        engine.present()

        val pixels = engine.read_pixels()
        engine.shutdown()
    """

    backend: RenderBackend
    baremetal_backend: BaremetalBackend?
    virtio_gpu_backend: VirtioGpuBackend?
    w: i32
    h: i32

    # ========================================================================
    # Constructors
    # ========================================================================

    static fn create(width: i32, height: i32) -> Engine2D:
        """Create engine with auto-detected best backend.

        Tries backends in priority order: cuda, vulkan, opengl, software, cpu.
        Falls back to cpu if all others fail.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels

        Returns:
            Initialized Engine2D
        """
        val best = detect_best_backend()
        Engine2D.create_with_backend(width, height, best)

    static fn create_with_backend(width: i32, height: i32, backend_name: text) -> Engine2D:
        """Create engine with a specific backend.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels
            backend_name: One of "cuda", "vulkan", "opengl", "software", "cpu", "baremetal"

        Returns:
            Initialized Engine2D (falls back to cpu on failure)

        Note: "baremetal" requires a pre-initialized BaremetalBackend. Use
              create_with_baremetal_backend() instead for baremetal rendering.
        """
        if backend_name == "cuda":
            var cuda = CudaBackend.create()
            if cuda.init(width, height):
                return Engine2D(backend: cuda, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "vulkan":
            var vulkan = VulkanBackend.create()
            if vulkan.init(width, height):
                return Engine2D(backend: vulkan, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "opengl":
            var opengl = OpenGLBackend.create()
            if opengl.init(width, height):
                return Engine2D(backend: opengl, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "metal":
            var metal = MetalBackend.create()
            if metal.init(width, height):
                return Engine2D(backend: metal, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "rocm":
            var rocm = RocmBackend.create()
            if rocm.init(width, height):
                return Engine2D(backend: rocm, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "intel":
            var intel = IntelBackend.create()
            if intel.init(width, height):
                return Engine2D(backend: intel, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "qualcomm":
            var qualcomm = QualcommBackend.create()
            if qualcomm.init(width, height):
                return Engine2D(backend: qualcomm, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "webgpu":
            var webgpu = WebGpuBackend.create()
            if webgpu.init(width, height):
                return Engine2D(backend: webgpu, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        if backend_name == "software":
            var sw = SoftwareBackend.create()
            if sw.init(width, height):
                return Engine2D(backend: sw, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

        # Note: "baremetal" is NOT auto-detected. It requires a pre-initialized
        # FramebufferDriver and must be created via create_with_baremetal_backend().
        # If requested here by name, fall through to CPU fallback.

        # Fallback: CPU backend always succeeds
        var cpu = CpuBackend.create()
        cpu.init(width, height)
        Engine2D(backend: cpu, baremetal_backend: nil, virtio_gpu_backend: nil, w: width, h: height)

    static fn create_with_baremetal_backend(backend: BaremetalBackend) -> Engine2D:
        """Create engine with a pre-initialized BaremetalBackend.

        The BaremetalBackend wraps a FramebufferDriver and is used for
        OS-level rendering where only framebuffer hardware is available.

        Args:
            backend: An already-created BaremetalBackend (via BaremetalBackend.create())

        Returns:
            Engine2D using the baremetal backend
        """
        Engine2D.create_with_baremetal_backend_dims(backend.w, backend.h, backend)

    static fn create_with_baremetal_backend_dims(width: i32, height: i32, backend: BaremetalBackend) -> Engine2D:
        """Create engine with explicit dimensions for a baremetal backend.

        The dimension arguments avoid reading cached width/height through a
        fragile backend-parameter path during baremetal boot. The CPU backend
        remains an unused placeholder on this path, so it must not allocate
        or initialize any pixel buffer.
        """
        val cpu = CpuBackend.create()
        Engine2D(backend: cpu, baremetal_backend: backend, virtio_gpu_backend: nil, w: width, h: height)

    static fn create_with_virtio_gpu_backend(backend: VirtioGpuBackend) -> Engine2D:
        """Create engine with a pre-initialized VirtioGpuBackend."""
        var cpu = CpuBackend.create()
        cpu.init(1, 1)
        Engine2D(backend: cpu, baremetal_backend: nil, virtio_gpu_backend: backend, w: backend.w, h: backend.h)

    # ========================================================================
    # Backend Discovery
    # ========================================================================

    static fn detect_best_backend() -> text:
        """Detect the best available backend.

        Priority: cuda > rocm > metal > qualcomm > vulkan > opengl > intel > webgpu > software > cpu

        Returns:
            Backend name string
        """
        var cuda = CudaBackend.create()
        if cuda.init(1, 1):
            cuda.shutdown()
            return "cuda"

        var rocm = RocmBackend.create()
        if rocm.init(1, 1):
            rocm.shutdown()
            return "rocm"

        var metal = MetalBackend.create()
        if metal.init(1, 1):
            metal.shutdown()
            return "metal"

        if QualcommBackend.is_adreno_gpu():
            var qualcomm = QualcommBackend.create()
            if qualcomm.init(1, 1):
                qualcomm.shutdown()
                return "qualcomm"

        var vulkan = VulkanBackend.create()
        if vulkan.init(1, 1):
            vulkan.shutdown()
            return "vulkan"

        var opengl = OpenGLBackend.create()
        if opengl.init(1, 1):
            opengl.shutdown()
            return "opengl"

        var intel = IntelBackend.create()
        if intel.init(1, 1):
            intel.shutdown()
            return "intel"

        var webgpu = WebGpuBackend.create()
        if webgpu.init(1, 1):
            webgpu.shutdown()
            return "webgpu"

        "software"

    static fn list_backends() -> [text]:
        """List all available backend names.

        Returns:
            Array of backend name strings that can successfully init
        """
        var available: [text] = []

        var cuda = CudaBackend.create()
        if cuda.init(1, 1):
            available.push("cuda")
            cuda.shutdown()

        var rocm = RocmBackend.create()
        if rocm.init(1, 1):
            available.push("rocm")
            rocm.shutdown()

        var metal = MetalBackend.create()
        if metal.init(1, 1):
            available.push("metal")
            metal.shutdown()

        var vulkan = VulkanBackend.create()
        if vulkan.init(1, 1):
            available.push("vulkan")
            vulkan.shutdown()

        var opengl = OpenGLBackend.create()
        if opengl.init(1, 1):
            available.push("opengl")
            opengl.shutdown()

        var intel = IntelBackend.create()
        if intel.init(1, 1):
            available.push("intel")
            intel.shutdown()

        var webgpu = WebGpuBackend.create()
        if webgpu.init(1, 1):
            available.push("webgpu")
            webgpu.shutdown()

        if QualcommBackend.is_adreno_gpu():
            var qualcomm = QualcommBackend.create()
            if qualcomm.init(1, 1):
                available.push("qualcomm")
                qualcomm.shutdown()

        # Software and CPU are always available
        available.push("software")
        available.push("cpu")

        available

    static fn create_with_priority(width: i32, height: i32, priority: [text]) -> Engine2D:
        """Create engine using a custom backend priority order.

        Tries backends in the given order, falling back to CPU if none work.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels
            priority: Ordered list of backend names to try

        Returns:
            Initialized Engine2D
        """
        for backend_name in priority:
            val engine = Engine2D.create_with_backend(width, height, backend_name)
            if engine.backend_name() == backend_name:
                return engine
        # Fallback
        Engine2D.create_with_backend(width, height, "cpu")

    # ========================================================================
    # Backend Info
    # ========================================================================

    fn backend_name() -> text:
        """Get the name of the active backend."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.name()
        elif val Some(bm) = self.baremetal_backend:
            bm.name()
        else:
            self.backend.name()

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    # ========================================================================
    # Drawing Operations (delegate to backend)
    # ========================================================================

    me clear(color: u32):
        """Clear the framebuffer to a solid color."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.clear(color)
        elif val Some(bm) = self.baremetal_backend:
            bm.clear(color)
        else:
            self.backend.clear(color)

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Draw a rectangle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect(x, y, w, h, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect(x, y, w, h, color)
        else:
            self.backend.draw_rect(x, y, w, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Draw a filled rectangle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect_filled(x, y, w, h, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect_filled(x, y, w, h, color)
        else:
            self.backend.draw_rect_filled(x, y, w, h, color)

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        """Draw a line between two points."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_line(x1, y1, x2, y2, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_line(x1, y1, x2, y2, color, thickness)
        else:
            self.backend.draw_line(x1, y1, x2, y2, color, thickness)

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        """Draw a circle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_circle(cx, cy, r, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_circle(cx, cy, r, color)
        else:
            self.backend.draw_circle(cx, cy, r, color)

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        """Draw a filled circle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_circle_filled(cx, cy, r, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_circle_filled(cx, cy, r, color)
        else:
            self.backend.draw_circle_filled(cx, cy, r, color)

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        """Draw a rounded rectangle outline."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rounded_rect(x, y, w, h, radius, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rounded_rect(x, y, w, h, radius, color)
        else:
            self.backend.draw_rounded_rect(x, y, w, h, radius, color)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        """Draw a filled triangle."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        else:
            self.backend.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        """Draw a rectangle with vertical gradient."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        else:
            self.backend.draw_gradient_rect(x, y, w, h, top_color, bottom_color)

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        """Draw text using bitmap font."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_text(x, y, text_val, color, font_size)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_text(x, y, text_val, color, font_size)
        else:
            self.backend.draw_text(x, y, text_val, color, font_size)

    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        """Draw text with an explicit background colour per glyph cell.

        Delegates to the backend's `Engine2DExtended.draw_text_bg` which
        paints the text foreground plus a per-pixel background, preserving
        antialiased glyph edges (unlike a pre-paint-rect hack that would
        destroy them). This is the method `Engine2dCompositorBackend`
        (and any other `CompositorBackend`-shaped wrapper) should call
        instead of pre-painting an opaque rect and then overlaying
        `draw_text`.
        """
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_text_bg(x, y, text_val, fg, bg, font_size)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_text_bg(x, y, text_val, fg, bg, font_size)
        else:
            self.backend.draw_text_bg(x, y, text_val, fg, bg, font_size)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        """Blit a pixel array onto the framebuffer."""
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_image(x, y, w, h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_image(x, y, w, h, pixels)
        else:
            self.backend.draw_image(x, y, w, h, pixels)

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_ellipse(cx, cy, rx, ry, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_ellipse(cx, cy, rx, ry, color)
        else:
            self.backend.draw_ellipse(cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_ellipse_filled(cx, cy, rx, ry, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_ellipse_filled(cx, cy, rx, ry, color)
        else:
            self.backend.draw_ellipse_filled(cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_arc(cx, cy, r, start_deg, end_deg, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_arc(cx, cy, r, start_deg, end_deg, color, thickness)
        else:
            self.backend.draw_arc(cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_bezier(x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_bezier(x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)
        else:
            self.backend.draw_bezier(x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_polygon_filled(xs, ys, count, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_polygon_filled(xs, ys, count, color)
        else:
            self.backend.draw_polygon_filled(xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_polyline(xs, ys, count, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_polyline(xs, ys, count, color, thickness)
        else:
            self.backend.draw_polyline(xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect_thick(x, y, w, h, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect_thick(x, y, w, h, color, thickness)
        else:
            self.backend.draw_rect_thick(x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_circle_thick(cx, cy, r, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_circle_thick(cx, cy, r, color, thickness)
        else:
            self.backend.draw_circle_thick(cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
        else:
            self.backend.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_gradient_rect_h(x, y, w, h, left_color, right_color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_gradient_rect_h(x, y, w, h, left_color, right_color)
        else:
            self.backend.draw_gradient_rect_h(x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_radial_gradient(cx, cy, r, center_color, edge_color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_radial_gradient(cx, cy, r, center_color, edge_color)
        else:
            self.backend.draw_radial_gradient(cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_rect_blend(x, y, w, h, color)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_rect_blend(x, y, w, h, color)
        else:
            self.backend.draw_rect_blend(x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_image_blend(x, y, w, h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_image_blend(x, y, w, h, pixels)
        else:
            self.backend.draw_image_blend(x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        else:
            self.backend.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_triangle_outline(x1, y1, x2, y2, x3, y3, color, thickness)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_triangle_outline(x1, y1, x2, y2, x3, y3, color, thickness)
        else:
            self.backend.draw_triangle_outline(x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        if val Some(vg) = self.virtio_gpu_backend:
            vg.draw_blur_rect(x, y, w, h, radius)
        elif val Some(bm) = self.baremetal_backend:
            bm.draw_blur_rect(x, y, w, h, radius)
        else:
            self.backend.draw_blur_rect(x, y, w, h, radius)

