# 2D Engine — Metal Backend MSL Shader Source
#
# Embedded MSL (Metal Shading Language) compute kernels for 2D rendering.
# No imports required — this file returns a single text literal.

# ============================================================================
# MSL Kernel Source
# ============================================================================

fn _engine2d_msl() -> text:
    """Embedded MSL source for 2D rendering compute kernels.

    These kernels operate on a u32 framebuffer in device memory.
    Each pixel is ARGB packed as a 32-bit unsigned integer.

    Buffer layout:
    - buffer(0): device uint* framebuffer
    - buffer(1): constant params (push constants via setBytes)
    - buffer(2): device uint* source (blit only) / device const uchar* index buffer
      (indexed_fill only) / device const uint* codepoints (glyph_atlas_blit only —
      one atlas glyph-index per character, uploaded fresh per draw_text call)
    - buffer(3): device const uint* GpuLut (indexed_fill / glyph_atlas_blit only —
      buffer-backed lookup table, design
      doc/05_design/ui/rendering/cpu_gpu_dual_algorithm_design.md §3.1)

    Kernel list:
    - kernel_clear: Fill entire framebuffer with a color
    - kernel_draw_rect_filled: Fill a rectangle region
    - kernel_draw_rect_outline: Draw rectangle border (1px)
    - kernel_draw_circle_filled: Fill a circle (distance check)
    - kernel_draw_circle: Draw circle outline
    - kernel_draw_line: Bresenham line on GPU (1 thread per step)
    - kernel_draw_rounded_rect: Rounded-rect FILL (body + 4 filled corner arcs)
    - kernel_draw_triangle_filled: Barycentric triangle fill
    - kernel_draw_gradient_rect: Vertical gradient fill
    - kernel_blit_image: Copy source pixels to framebuffer region
    - kernel_indexed_fill: GPU-dict pilot — per-pixel `lut_lookup(palette, idx)`
    - kernel_glyph_atlas_blit: GPU-dict use case #2 — one data-parallel dispatch
      per draw_text call (`lut_lookup(atlas, glyph_index*rows+row)`), replacing
      the former one-dispatch-per-lit-glyph-pixel path
    """
    val source: text = r"""
#include <metal_stdlib>
using namespace metal;

// ---- Parameter structs (match _pack_*_params byte layout) ----

struct ClearParams {
    uint color;
    int width;
    int height;
};

struct RectParams {
    int x;
    int y;
    int w;
    int h;
    uint color;
    int fb_w;
    int fb_h;
};

struct LineParams {
    int x1;
    int y1;
    int x2;
    int y2;
    uint color;
    int thickness;
    int fb_w;
    int fb_h;
};

struct CircleParams {
    int cx;
    int cy;
    int r;
    uint color;
    int fb_w;
    int fb_h;
    int filled;
};

struct RoundedRectParams {
    int x;
    int y;
    int w;
    int h;
    int radius;
    uint color;
    int fb_w;
    int fb_h;
};

struct RoundedRectOutlineParams {
    int x;
    int y;
    int w;
    int h;
    int radius;
    uint color;
    int thickness;
    int fb_w;
    int fb_h;
};

struct TriangleParams {
    int x1;
    int y1;
    int x2;
    int y2;
    int x3;
    int y3;
    uint color;
    int fb_w;
    int fb_h;
    int min_x;
    int min_y;
};

struct GradientParams {
    int x;
    int y;
    int w;
    int h;
    uint top_color;
    uint bottom_color;
    int fb_w;
    int fb_h;
};

struct BlitParams {
    int x;
    int y;
    int w;
    int h;
    int fb_w;
    int fb_h;
};

struct ImageCompositeParams {
    int x;
    int y;
    int w;
    int h;
    int fb_w;
    int fb_h;
    int opacity_milli;
};

struct IndexedFillParams {
    int x;
    int y;
    int w;
    int h;
    int fb_w;
    int fb_h;
};

struct TextBlitParams {
    int x;
    int y;
    int text_len;
    int scale;
    int advance;
    int gh;
    uint color;
    int fb_w;
    int fb_h;
};

struct ClipParams {
    int x;
    int y;
    int w;
    int h;
    int enabled;
};

// ---- Helper: extract ARGB channels ----

static inline uint4 unpack_argb(uint c) {
    return uint4(
        (c >> 16) & 0xFF,  // R
        (c >> 8)  & 0xFF,  // G
        c         & 0xFF,  // B
        (c >> 24) & 0xFF   // A
    );
}

static inline uint pack_argb(uint r, uint g, uint b, uint a) {
    return (a << 24) | (r << 16) | (g << 8) | b;
}

static inline uint lerp_channel(uint a, uint b, int t, int max_t) {
    if (max_t <= 0) return a;
    return (uint)((int)a + ((int)b - (int)a) * t / max_t);
}

// Bounds-checked single-pixel write (mirrors CPU sw_set_pixel framebuffer clip).
static inline bool inside_clip(int x, int y, constant ClipParams& clip) {
    return clip.enabled == 0 ||
        (clip.w > 0 && clip.h > 0 && x >= clip.x && y >= clip.y &&
         x < clip.x + clip.w && y < clip.y + clip.h);
}

static inline void plot(device uint* fb, int x, int y, int fb_w, int fb_h, uint color, constant ClipParams& clip) {
    if (x >= 0 && x < fb_w && y >= 0 && y < fb_h && inside_clip(x, y, clip)) {
        fb[y * fb_w + x] = color;
    }
}

// Porter-Duff src-over, bit-identical to the CPU reference blend() in
// engine2d/color.spl (plain truncating integer division, no rounding term).
// Opaque src returns src unchanged, so all-opaque scenes stay bit-exact
// with the pre-blend raw-store behavior.
static inline uint blend_src_over(uint src, uint dst) {
    uint sa = (src >> 24) & 0xFFu;
    if (sa == 255u) return src;
    if (sa == 0u) return dst;
    uint sr = (src >> 16) & 0xFFu;
    uint sg = (src >> 8) & 0xFFu;
    uint sb = src & 0xFFu;
    uint dr = (dst >> 16) & 0xFFu;
    uint dg = (dst >> 8) & 0xFFu;
    uint db = dst & 0xFFu;
    uint da = (dst >> 24) & 0xFFu;
    uint inv = 255u - sa;
    uint r = (sr * sa + dr * inv) / 255u;
    uint g = (sg * sa + dg * inv) / 255u;
    uint b = (sb * sa + db * inv) / 255u;
    uint a = sa + (da * inv) / 255u;
    return (a << 24) | (r << 16) | (g << 8) | b;
}

// ---- kernel_clear ----

kernel void kernel_clear(
    device uint* fb        [[buffer(0)]],
    constant ClearParams& p [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint tid               [[thread_position_in_grid]]
) {
    int total = p.width * p.height;
    if ((int)tid >= total) return;
    fb[tid] = p.color;
}

// ---- kernel_draw_rect_filled ----

kernel void kernel_draw_rect_filled(
    device uint* fb        [[buffer(0)]],
    constant RectParams& p [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint2 tid              [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int idx = py * p.fb_w + px;
    fb[idx] = blend_src_over(p.color, fb[idx]);
}

// ---- kernel_draw_rect_outline ----

kernel void kernel_draw_rect_outline(
    device uint* fb        [[buffer(0)]],
    constant RectParams& p [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint2 tid              [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    // Only draw border pixels
    bool on_border = (lx == 0 || lx == p.w - 1 || ly == 0 || ly == p.h - 1);
    if (!on_border) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int idx = py * p.fb_w + px;
    fb[idx] = p.color;
}

// ---- kernel_draw_line ----

kernel void kernel_draw_line(
    device uint* fb         [[buffer(0)]],
    constant LineParams& p  [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint tid                [[thread_position_in_grid]]
) {
    // Bit-exact replay of the CPU sw_bresenham loop: thread t draws the pixel
    // the CPU reaches after t error-stepping iterations. This visits exactly the
    // same pixel set as the integer Bresenham reference (no DDA division skips).
    int dx = p.x2 - p.x1;
    int dy = p.y2 - p.y1;
    int adx = dx < 0 ? -dx : dx;
    int ady = dy < 0 ? -dy : dy;
    int sx = dx < 0 ? -1 : 1;
    int sy = dy < 0 ? -1 : 1;
    int steps = adx > ady ? adx : ady;
    if ((int)tid > steps) return;

    int t = (int)tid;
    int cx = p.x1;
    int cy = p.y1;
    int err = adx - ady;
    for (int k = 0; k < t; k++) {
        int e2 = 2 * err;
        if (e2 > -ady) { err -= ady; cx += sx; }
        if (e2 < adx)  { err += adx; cy += sy; }
    }

    // Thickness: CPU draws parallel offset copies of the line. Translating both
    // endpoints by `off` translates every Bresenham pixel by the same offset, so
    // a single thread can emit the base pixel plus each thickness offset.
    int half_w = p.thickness / 2;
    for (int off = -half_w; off <= half_w; off++) {
        if (adx >= ady) {
            plot(fb, cx, cy + off, p.fb_w, p.fb_h, p.color, clip);
        } else {
            plot(fb, cx + off, cy, p.fb_w, p.fb_h, p.color, clip);
        }
    }
}

// ---- kernel_draw_circle ----

// 1D dispatch: thread i replays the CPU midpoint-circle loop i times and emits
// the 8 symmetric pixels for iteration i. Produces the same 8-connected ring as
// the CPU reference (a per-pixel distance annulus gaps near the diagonals).
kernel void kernel_draw_circle(
    device uint* fb           [[buffer(0)]],
    constant CircleParams& p  [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint tid                  [[thread_position_in_grid]]
) {
    int i = (int)tid;
    int px = p.r;
    int py = 0;
    int d = 1 - p.r;
    for (int k = 0; k < i; k++) {
        py += 1;
        // Decision tie-break `d < 0` matches the canonical CPU midpoint loop
        // (backend_software.spl draw_circle, unified to emu's textbook `d < 0`
        // per the D2 equality matrix 2026-07-06). The previous `d <= 0` was the
        // pre-unification software variant and diverged at midpoint-tie radii
        // (16 extra ring pixels at e.g. r=4 and r=14, bit-verified).
        if (d < 0) {
            d += 2 * py + 1;
        } else {
            px -= 1;
            d += 2 * py - 2 * px + 1;
        }
    }
    if (px < py) return;  // CPU loop condition `while px >= py`

    int cx = p.cx;
    int cy = p.cy;
    plot(fb, cx + px, cy + py, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx - px, cy + py, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx + px, cy - py, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx - px, cy - py, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx + py, cy + px, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx - py, cy + px, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx + py, cy - px, p.fb_w, p.fb_h, p.color, clip);
    plot(fb, cx - py, cy - px, p.fb_w, p.fb_h, p.color, clip);
}

// ---- kernel_draw_circle_filled ----

kernel void kernel_draw_circle_filled(
    device uint* fb           [[buffer(0)]],
    constant CircleParams& p  [[buffer(1)]],
    constant ClipParams& clip [[buffer(4)]],
    uint2 tid                 [[thread_position_in_grid]]
) {
    int bw = 2 * p.r + 1;
    int bh = 2 * p.r + 1;
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= bw || ly >= bh) return;

    int dx = lx - p.r;
    int dy = ly - p.r;
    int dist_sq = dx * dx + dy * dy;
    int r_sq = p.r * p.r;
    if (dist_sq > r_sq) return;

    int px = p.cx - p.r + lx;
    int py = p.cy - p.r + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int idx = py * p.fb_w + px;
    fb[idx] = blend_src_over(p.color, fb[idx]);
}

// ---- kernel_draw_rounded_rect ----

// Per-pixel replica of ONE _emu_corner_arc(cx,cy,rad,dx_sign,dy_sign) call's
// span coverage + blend, for absolute-local pixel (lx, ly). Replays the
// exact midpoint-circle recurrence backend_emu.spl _emu_corner_arc uses
// (decision boundary is `d < 0`, NOT `d <= 0` — that is a *different*
// corner-arc algorithm used by sw_corner_arc/_rr_ring_hit for the OUTLINE
// path) and blends `color` over `dst` once per iteration whose span-1 or
// span-2 covers (lx, ly) — i.e. once per core.draw_rect_filled call CPU
// would issue that touches this pixel, in the same order.
//
// NOT a plain membership test: CPU's emu_draw_rounded_rect issues SEVEN
// core.draw_rect_filled calls (3 band rects + 4 corner arcs, each doing up
// to r+1 midpoint iterations x 2 spans), and their pixel footprints OVERLAP
// AT THE SEAMS — e.g. a corner arc's first iteration (py=0) draws its span
// at the arc-center row, which is the adjoining side band's OWN first row,
// so that row gets blended by BOTH the band rect and the corner arc. For an
// opaque color that is a harmless redundant overwrite; for alpha<255 each
// blend RE-COMPOSITES over the prior result — not idempotent. A
// per-region-exclusive kernel (classify each pixel into exactly one of
// middle-band/side-band/corner-arc, blend once) was tried first and
// diverged from the CPU oracle on alpha<255 fills (confirmed via the
// Simple-level replica in engine2d_shared_raster_parity_spec.spl before
// this kernel was fixed) — bit-exactness requires literally replaying every
// one of the seven primitives, in CPU's exact order, blending every hit.
inline uint _rr_corner_arc_blend(int cx, int cy, int rad, int dx_sign, int dy_sign, int lx, int ly, uint color, uint dst) {
    int px = rad;
    int py = 0;
    int d = 1 - rad;
    while (px >= py) {
        int row1 = cy + dy_sign * py;
        int col_a = cx;
        int col_b1 = cx + dx_sign * px;
        int lo1 = (col_a < col_b1) ? col_a : col_b1;
        int hi1 = (col_a < col_b1) ? col_b1 : col_a;
        if (ly == row1 && lx >= lo1 && lx <= hi1) {
            dst = blend_src_over(color, dst);
        }
        int row2 = cy + dy_sign * px;
        int col_b2 = cx + dx_sign * py;
        int lo2 = (col_a < col_b2) ? col_a : col_b2;
        int hi2 = (col_a < col_b2) ? col_b2 : col_a;
        if (ly == row2 && lx >= lo2 && lx <= hi2) {
            dst = blend_src_over(color, dst);
        }
        py += 1;
        if (d < 0) {
            d += 2 * py + 1;
        } else {
            px -= 1;
            d += 2 * (py - px) + 1;
        }
    }
    return dst;
}

// Rounded-rect FILL. Matches CPU emu_draw_rounded_rect (backend_emu.spl,
// the canonical reference SoftwareBackend.draw_rounded_rect now delegates
// to as of the 2026-07-06 outline-vs-fill fix): a full-height middle band
// (cols [x+r, x+w-1-r]), two side bands (rows [y+r, y+h-1-r]), and four
// FILLED corner arcs, replayed in the SAME order CPU issues them (see
// _rr_corner_arc_blend's comment — this order/replay, not a per-region
// membership test, is required for alpha<255 bit-exactness). 2D dispatch
// over the [0,w) x [0,h) bounding box. Formerly this kernel drew the stale
// pre-fix CPU OUTLINE behavior (edges + arc rings), which is why
// CPU-vs-Metal parity diverged after the CPU fill fix landed — see
// doc/08_tracking/bug/engine2d_metal_rounded_rect_kernel_stale_outline_2026-07-07.md
kernel void kernel_draw_rounded_rect(
    device uint* fb                  [[buffer(0)]],
    constant RoundedRectParams& p    [[buffer(1)]],
    constant ClipParams& clip        [[buffer(4)]],
    uint2 tid                        [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int w = p.w;
    int h = p.h;
    int r = p.radius;
    if (r > w / 2) r = w / 2;
    if (r > h / 2) r = h / 2;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;
    int idx = py * p.fb_w + px;

    uint dst = fb[idx];
    // Middle band, left band, right band — same order as CPU emu_draw_rounded_rect.
    if (lx >= r && lx < w - r) {
        dst = blend_src_over(p.color, dst);
    }
    if (lx < r && ly >= r && ly < h - r) {
        dst = blend_src_over(p.color, dst);
    }
    if (lx >= w - r && ly >= r && ly < h - r) {
        dst = blend_src_over(p.color, dst);
    }
    // Four corner arcs — same (cx, cy, dx_sign, dy_sign) call order as CPU.
    dst = _rr_corner_arc_blend(r, r, r, -1, -1, lx, ly, p.color, dst);
    dst = _rr_corner_arc_blend(w - r - 1, r, r, 1, -1, lx, ly, p.color, dst);
    dst = _rr_corner_arc_blend(r, h - r - 1, r, -1, 1, lx, ly, p.color, dst);
    dst = _rr_corner_arc_blend(w - r - 1, h - r - 1, r, 1, 1, lx, ly, p.color, dst);

    fb[idx] = dst;
}

// ---- kernel_draw_rounded_rect_outline ----

// Bit-exact membership test for CPU sw_corner_arc(radius=rad) at
// quadrant-local offset (ax, ay) (both >= 0): replays the same midpoint
// circle recurrence sw_corner_arc uses and checks whether (ax,ay) or the
// swapped (ay,ax) point was emitted. sw_corner_arc draws a THIN 1px ring,
// not a filled disc/annulus, so this cannot be replaced by a distance test.
inline bool _rr_ring_hit(int rad, int ax, int ay) {
    if (rad < 0) return false;
    int px = rad;
    int py = 0;
    int d = 1 - rad;
    while (px >= py) {
        if ((px == ax && py == ay) || (py == ax && px == ay)) return true;
        py += 1;
        if (d <= 0) {
            d += 2 * py + 1;
        } else {
            px -= 1;
            d += 2 * py - 2 * px + 1;
        }
    }
    return false;
}

// Thick rounded-rect OUTLINE. Matches CPU
// SoftwareBackend.draw_rounded_rect_outline: straight edges of `thickness`
// width/height, plus, for each of the `thickness` offsets, a THIN
// midpoint-circle corner ring at radius (r-off) (sw_corner_arc) — NOT a
// filled annulus. 2D dispatch over the [0,w) x [0,h) bounding box; each
// pixel is set if it is covered by the union of those primitives. Since
// every primitive writes the same opaque color, the per-pixel union test is
// bit-exact with the CPU loop (which overwrites covered pixels). Integer
// arithmetic only — no float/sqrt.
kernel void kernel_draw_rounded_rect_outline(
    device uint* fb                         [[buffer(0)]],
    constant RoundedRectOutlineParams& p    [[buffer(1)]],
    constant ClipParams& clip               [[buffer(4)]],
    uint2 tid                               [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int r = p.radius;
    if (r > p.w / 2) r = p.w / 2;
    if (r > p.h / 2) r = p.h / 2;
    int t = p.thickness;
    if (t > r + 1) t = r + 1;   // CPU clamp: draw_rounded_rect_outline

    bool covered = false;

    // Straight edges (draw_rect_filled regions; width/height must be > 0).
    int span_w = p.w - 2 * r;   // top/bottom edge run length
    int span_h = p.h - 2 * r;   // left/right edge run length
    // Top edge: rect(x+r, y, span_w, t) -> local cols [r, r+span_w), rows [0, t)
    if (span_w > 0 && lx >= r && lx < r + span_w && ly >= 0 && ly < t) covered = true;
    // Bottom edge: rect(x+r, y+h-t, span_w, t) -> rows [h-t, h)
    if (span_w > 0 && lx >= r && lx < r + span_w && ly >= p.h - t && ly < p.h) covered = true;
    // Left edge: rect(x, y+r, t, span_h) -> cols [0, t), rows [r, r+span_h)
    if (span_h > 0 && lx >= 0 && lx < t && ly >= r && ly < r + span_h) covered = true;
    // Right edge: rect(x+w-t, y+r, t, span_h) -> cols [w-t, w)
    if (span_h > 0 && lx >= p.w - t && lx < p.w && ly >= r && ly < r + span_h) covered = true;

    // Corner rings: for ax,ay in [0, r] (quadrant-local offset from the
    // corner center), covered if (ax,ay) is on the sw_corner_arc ring for
    // ANY of the t radii r, r-1, ..., r-t+1. Corner centers (local coords):
    //   TL = (r, r)            TR = (w-1-r, r)
    //   BL = (r, h-1-r)        BR = (w-1-r, h-1-r)
    if (!covered) {
        int tlx = r;
        int tly = r;
        int trx = p.w - 1 - r;
        int bry = p.h - 1 - r;
        // top-left: ax = tlx-lx, ay = tly-ly
        if (!covered) {
            int ax = tlx - lx; int ay = tly - ly;
            if (ax >= 0 && ax <= r && ay >= 0 && ay <= r) {
                for (int off = 0; off < t; off++) {
                    if (_rr_ring_hit(r - off, ax, ay)) { covered = true; break; }
                }
            }
        }
        // top-right: ax = lx-trx, ay = tly-ly
        if (!covered) {
            int ax = lx - trx; int ay = tly - ly;
            if (ax >= 0 && ax <= r && ay >= 0 && ay <= r) {
                for (int off = 0; off < t; off++) {
                    if (_rr_ring_hit(r - off, ax, ay)) { covered = true; break; }
                }
            }
        }
        // bottom-left: ax = tlx-lx, ay = ly-bry
        if (!covered) {
            int ax = tlx - lx; int ay = ly - bry;
            if (ax >= 0 && ax <= r && ay >= 0 && ay <= r) {
                for (int off = 0; off < t; off++) {
                    if (_rr_ring_hit(r - off, ax, ay)) { covered = true; break; }
                }
            }
        }
        // bottom-right: ax = lx-trx, ay = ly-bry
        if (!covered) {
            int ax = lx - trx; int ay = ly - bry;
            if (ax >= 0 && ax <= r && ay >= 0 && ay <= r) {
                for (int off = 0; off < t; off++) {
                    if (_rr_ring_hit(r - off, ax, ay)) { covered = true; break; }
                }
            }
        }
    }

    if (!covered) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;
    fb[py * p.fb_w + px] = p.color;
}

// ---- kernel_draw_triangle_filled ----

kernel void kernel_draw_triangle_filled(
    device uint* fb               [[buffer(0)]],
    constant TriangleParams& p    [[buffer(1)]],
    constant ClipParams& clip     [[buffer(4)]],
    uint2 tid                     [[thread_position_in_grid]]
) {
    int bw = 0;  // computed from bounding box
    int bh = 0;
    int max_x = p.x1;
    if (p.x2 > max_x) max_x = p.x2;
    if (p.x3 > max_x) max_x = p.x3;
    int max_y = p.y1;
    if (p.y2 > max_y) max_y = p.y2;
    if (p.y3 > max_y) max_y = p.y3;
    bw = max_x - p.min_x + 1;
    bh = max_y - p.min_y + 1;

    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= bw || ly >= bh) return;

    int px = p.min_x + lx;
    int py = p.min_y + ly;

    // Barycentric coordinate test (2x area method)
    int d = (p.y2 - p.y3) * (p.x1 - p.x3) + (p.x3 - p.x2) * (p.y1 - p.y3);
    if (d == 0) return;

    int w1_num = (p.y2 - p.y3) * (px - p.x3) + (p.x3 - p.x2) * (py - p.y3);
    int w2_num = (p.y3 - p.y1) * (px - p.x3) + (p.x1 - p.x3) * (py - p.y3);

    // Check signs for inside test
    bool inside;
    if (d > 0) {
        int w3_num = d - w1_num - w2_num;
        inside = (w1_num >= 0 && w2_num >= 0 && w3_num >= 0);
    } else {
        int w3_num = d - w1_num - w2_num;
        inside = (w1_num <= 0 && w2_num <= 0 && w3_num <= 0);
    }
    if (!inside) return;

    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int idx = py * p.fb_w + px;
    fb[idx] = blend_src_over(p.color, fb[idx]);
}

// ---- kernel_draw_gradient_rect ----

kernel void kernel_draw_gradient_rect(
    device uint* fb               [[buffer(0)]],
    constant GradientParams& p    [[buffer(1)]],
    constant ClipParams& clip     [[buffer(4)]],
    uint2 tid                     [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    // Interpolate between top_color and bottom_color
    uint4 tc = unpack_argb(p.top_color);
    uint4 bc = unpack_argb(p.bottom_color);
    int max_t = p.h - 1;
    if (max_t < 1) max_t = 1;

    uint r = lerp_channel(tc.x, bc.x, ly, max_t);
    uint g = lerp_channel(tc.y, bc.y, ly, max_t);
    uint b = lerp_channel(tc.z, bc.z, ly, max_t);
    uint a = lerp_channel(tc.w, bc.w, ly, max_t);
    uint c = pack_argb(r, g, b, a);

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int idx = py * p.fb_w + px;
    // CPU-lane oracle (emu_draw_gradient_rect -> core.draw_rect_filled) alpha-
    // blends non-opaque rows via sw_hline_blend's blend() (backend_software.spl
    // draw_rect_filled has_alpha branch); a raw fb[idx]=c write diverged from
    // that on any top/bottom color with alpha<255 (opaque rows are unaffected:
    // blend_src_over short-circuits sa==255 to a raw store, so this is the
    // same bit-exact opaque path already proven, now correct for alpha too).
    fb[idx] = blend_src_over(c, fb[idx]);
}

// ---- kernel_blit_image ----

kernel void kernel_blit_image(
    device uint* fb             [[buffer(0)]],
    constant BlitParams& p      [[buffer(1)]],
    device const uint* src      [[buffer(2)]],
    constant ClipParams& clip   [[buffer(4)]],
    uint2 tid                   [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int src_idx = ly * p.w + lx;
    int dst_idx = py * p.fb_w + px;
    fb[dst_idx] = src[src_idx];
}

// ---- kernel_composite_image ----

kernel void kernel_composite_image(
    device uint* fb                       [[buffer(0)]],
    constant ImageCompositeParams& p      [[buffer(1)]],
    device const uint* src                [[buffer(2)]],
    constant ClipParams& clip             [[buffer(4)]],
    uint2 tid                             [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int src_idx = ly * p.w + lx;
    int dst_idx = py * p.fb_w + px;
    uint color = src[src_idx];
    uint alpha = (color >> 24) & 0xFFu;
    uint opacity = (uint)clamp(p.opacity_milli, 0, 1000);
    uint scaled_alpha = (alpha * opacity) / 1000u;
    uint scaled = (color & 0x00FFFFFFu) | (scaled_alpha << 24);
    fb[dst_idx] = blend_src_over(scaled, fb[dst_idx]);
}

// lut_lookup: GpuLut dense-kind lookup (design GpuLut §3.1/§3.2).
uint lut_lookup(device const uint* lut, uint key) {
    uint count = lut[1];
    return (key < count) ? lut[4 + key] : 0xFFFFFFFFu;
}

// kernel_indexed_fill: GPU-dict pilot (design §3.2).
kernel void kernel_indexed_fill(
    device uint* fb                       [[buffer(0)]],
    constant IndexedFillParams& p         [[buffer(1)]],
    device const uchar* idx_buf           [[buffer(2)]],
    device const uint* lut                [[buffer(3)]],
    constant ClipParams& clip             [[buffer(4)]],
    uint2 tid                             [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int src_idx = ly * p.w + lx;
    uint key = (uint)idx_buf[src_idx];
    uint val = lut_lookup(lut, key);

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;

    int dst_idx = py * p.fb_w + px;
    fb[dst_idx] = val;
}

// kernel_glyph_atlas_blit: GPU-dict use case #2 (design W4). Replaces
// draw_text's former one-`kernel_draw_rect_filled`-dispatch-per-lit-glyph-pixel
// path with ONE data-parallel dispatch over the whole text bounding box.
// buffer(2) is the per-call codepoint array (one atlas glyph-index per
// character, uploaded fresh per draw_text call — small, like indexed_fill's
// idx_buf). buffer(3) is the PERSISTENT glyph atlas GpuLut (uploaded once at
// backend init — the 5x7 font table never changes — dense kind=0/stride=1,
// key = glyph_index*gh + row, reusing lut_lookup unchanged). Raw (unblended)
// writes match the CPU oracle exactly: SoftwareBackend.draw_text's
// sw_set_pixel does `buf[idx] = color`, never a blend.
kernel void kernel_glyph_atlas_blit(
    device uint* fb                      [[buffer(0)]],
    constant TextBlitParams& p           [[buffer(1)]],
    device const uint* codepoints        [[buffer(2)]],
    device const uint* atlas             [[buffer(3)]],
    constant ClipParams& clip            [[buffer(4)]],
    uint2 tid                            [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    int text_w = p.text_len * p.advance;
    int text_h = p.gh * p.scale;
    if (lx >= text_w || ly >= text_h) return;

    int char_index = lx / p.advance;
    if (char_index >= p.text_len) return;
    int within_x = lx - char_index * p.advance;
    int glyph_col = within_x / p.scale;
    if (glyph_col >= 5) return;
    int glyph_row = ly / p.scale;
    if (glyph_row >= p.gh) return;

    uint gi = codepoints[char_index];
    uint key = gi * (uint)p.gh + (uint)glyph_row;
    uint row_bits = lut_lookup(atlas, key);
    if (row_bits == 0xFFFFFFFFu) return;
    uint bit = (row_bits >> (uint)(4 - glyph_col)) & 1u;
    if (bit == 0u) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;
    if (!inside_clip(px, py, clip)) return;
    fb[py * p.fb_w + px] = p.color;
}
"""
    source
