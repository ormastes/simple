# 2D Engine — Metal Backend MSL Shader Source
#
# Embedded MSL (Metal Shading Language) compute kernels for 2D rendering.
# No imports required — this file returns a single text literal.

# ============================================================================
# MSL Kernel Source
# ============================================================================

fn _engine2d_msl() -> text:
    """Embedded MSL source for 2D rendering compute kernels.

    These kernels operate on a u32 framebuffer in device memory.
    Each pixel is ARGB packed as a 32-bit unsigned integer.

    Buffer layout:
    - buffer(0): device uint* framebuffer
    - buffer(1): constant params (push constants via setBytes)
    - buffer(2): device uint* source (blit only)

    Kernel list:
    - kernel_clear: Fill entire framebuffer with a color
    - kernel_draw_rect_filled: Fill a rectangle region
    - kernel_draw_rect_outline: Draw rectangle border (1px)
    - kernel_draw_circle_filled: Fill a circle (distance check)
    - kernel_draw_circle: Draw circle outline
    - kernel_draw_line: Bresenham line on GPU (1 thread per step)
    - kernel_draw_rounded_rect: Rounded-rect outline (edges + corner arcs)
    - kernel_draw_triangle_filled: Barycentric triangle fill
    - kernel_draw_gradient_rect: Vertical gradient fill
    - kernel_draw_gradient_rect_h: Horizontal gradient fill
    - kernel_draw_radial_gradient: Radial gradient fill
    - kernel_draw_ellipse_filled: Filled ellipse
    - kernel_draw_rect_blend: Alpha-blended rect fill
    - kernel_draw_rect_blend_mode: Blend-mode rect fill
    - kernel_blend_image: Alpha-blended source image copy
    - kernel_blit_image: Copy source pixels to framebuffer region
    """
    r"""
#include <metal_stdlib>
using namespace metal;

// ---- Parameter structs (match _pack_*_params byte layout) ----

struct ClearParams {
    uint color;
    int width;
    int height;
};

struct RectParams {
    int x;
    int y;
    int w;
    int h;
    uint color;
    int fb_w;
    int fb_h;
};

struct LineParams {
    int x1;
    int y1;
    int x2;
    int y2;
    uint color;
    int thickness;
    int fb_w;
    int fb_h;
};

struct CircleParams {
    int cx;
    int cy;
    int r;
    uint color;
    int fb_w;
    int fb_h;
    int filled;
};

struct RoundedRectParams {
    int x;
    int y;
    int w;
    int h;
    int radius;
    uint color;
    int fb_w;
    int fb_h;
};

struct TriangleParams {
    int x1;
    int y1;
    int x2;
    int y2;
    int x3;
    int y3;
    uint color;
    int fb_w;
    int fb_h;
    int min_x;
    int min_y;
};

struct GradientParams {
    int x;
    int y;
    int w;
    int h;
    uint top_color;
    uint bottom_color;
    int fb_w;
    int fb_h;
};

struct BlitParams {
    int x;
    int y;
    int w;
    int h;
    int fb_w;
    int fb_h;
};

struct RadialGradientParams {
    int cx;
    int cy;
    int r;
    uint center_color;
    uint edge_color;
    int fb_w;
    int fb_h;
};

struct EllipseParams {
    int cx;
    int cy;
    int rx;
    int ry;
    uint color;
    int fb_w;
    int fb_h;
};

struct BlendModeRectParams {
    int x;
    int y;
    int w;
    int h;
    uint color;
    int fb_w;
    int fb_h;
    int mode;
};

// ---- Helper: extract ARGB channels ----

static inline uint4 unpack_argb(uint c) {
    return uint4(
        (c >> 16) & 0xFF,  // R
        (c >> 8)  & 0xFF,  // G
        c         & 0xFF,  // B
        (c >> 24) & 0xFF   // A
    );
}

static inline uint pack_argb(uint r, uint g, uint b, uint a) {
    return (a << 24) | (r << 16) | (g << 8) | b;
}

static inline uint lerp_channel(uint a, uint b, int t, int max_t) {
    if (max_t <= 0) return a;
    return (uint)((int)a + ((int)b - (int)a) * t / max_t);
}

static inline uint blend_over_color(uint src, uint dst) {
    uint sa = (src >> 24) & 0xFF;
    if (sa == 255) return src;
    if (sa == 0) return dst;
    uint inv = 255 - sa;
    uint sr = (src >> 16) & 0xFF;
    uint sg = (src >> 8) & 0xFF;
    uint sb = src & 0xFF;
    uint dr = (dst >> 16) & 0xFF;
    uint dg = (dst >> 8) & 0xFF;
    uint db = dst & 0xFF;
    uint r = (sr * sa + dr * inv) / 255;
    uint g = (sg * sa + dg * inv) / 255;
    uint b = (sb * sa + db * inv) / 255;
    return (0xFFu << 24) | (r << 16) | (g << 8) | b;
}

static inline uint overlay_channel(uint s, uint d) {
    if (d < 128u) return (2u * s * d) / 255u;
    return 255u - (2u * (255u - s) * (255u - d)) / 255u;
}

static inline int isqrt_i32(int n) {
    if (n <= 0) return 0;
    int x = n;
    int y = (x + 1) / 2;
    while (y < x) {
        x = y;
        y = (x + n / x) / 2;
    }
    return x;
}

// Bounds-checked single-pixel write (mirrors CPU sw_set_pixel framebuffer clip).
static inline void plot(device uint* fb, int x, int y, int fb_w, int fb_h, uint color) {
    if (x >= 0 && x < fb_w && y >= 0 && y < fb_h) {
        fb[y * fb_w + x] = color;
    }
}

// ---- kernel_clear ----

kernel void kernel_clear(
    device uint* fb        [[buffer(0)]],
    constant ClearParams& p [[buffer(1)]],
    uint tid               [[thread_position_in_grid]]
) {
    int total = p.width * p.height;
    if ((int)tid >= total) return;
    fb[tid] = p.color;
}

// ---- kernel_draw_rect_filled ----

kernel void kernel_draw_rect_filled(
    device uint* fb        [[buffer(0)]],
    constant RectParams& p [[buffer(1)]],
    uint2 tid              [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = p.color;
}

// ---- kernel_draw_rect_outline ----

kernel void kernel_draw_rect_outline(
    device uint* fb        [[buffer(0)]],
    constant RectParams& p [[buffer(1)]],
    uint2 tid              [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    // Only draw border pixels
    bool on_border = (lx == 0 || lx == p.w - 1 || ly == 0 || ly == p.h - 1);
    if (!on_border) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = p.color;
}

// ---- kernel_draw_line ----

kernel void kernel_draw_line(
    device uint* fb         [[buffer(0)]],
    constant LineParams& p  [[buffer(1)]],
    uint tid                [[thread_position_in_grid]]
) {
    // Bit-exact replay of the CPU sw_bresenham loop: thread t draws the pixel
    // the CPU reaches after t error-stepping iterations. This visits exactly the
    // same pixel set as the integer Bresenham reference (no DDA division skips).
    int dx = p.x2 - p.x1;
    int dy = p.y2 - p.y1;
    int adx = dx < 0 ? -dx : dx;
    int ady = dy < 0 ? -dy : dy;
    int sx = dx < 0 ? -1 : 1;
    int sy = dy < 0 ? -1 : 1;
    int steps = adx > ady ? adx : ady;
    if ((int)tid > steps) return;

    int t = (int)tid;
    int cx = p.x1;
    int cy = p.y1;
    int err = adx - ady;
    for (int k = 0; k < t; k++) {
        int e2 = 2 * err;
        if (e2 > -ady) { err -= ady; cx += sx; }
        if (e2 < adx)  { err += adx; cy += sy; }
    }

    // Thickness: CPU draws parallel offset copies of the line. Translating both
    // endpoints by `off` translates every Bresenham pixel by the same offset, so
    // a single thread can emit the base pixel plus each thickness offset.
    int half_w = p.thickness / 2;
    for (int off = -half_w; off <= half_w; off++) {
        if (adx >= ady) {
            plot(fb, cx, cy + off, p.fb_w, p.fb_h, p.color);
        } else {
            plot(fb, cx + off, cy, p.fb_w, p.fb_h, p.color);
        }
    }
}

// ---- kernel_draw_circle ----

// 1D dispatch: thread i replays the CPU midpoint-circle loop i times and emits
// the 8 symmetric pixels for iteration i. Produces the same 8-connected ring as
// the CPU reference (a per-pixel distance annulus gaps near the diagonals).
kernel void kernel_draw_circle(
    device uint* fb           [[buffer(0)]],
    constant CircleParams& p  [[buffer(1)]],
    uint tid                  [[thread_position_in_grid]]
) {
    int i = (int)tid;
    int px = p.r;
    int py = 0;
    int d = 1 - p.r;
    for (int k = 0; k < i; k++) {
        py += 1;
        if (d <= 0) {
            d += 2 * py + 1;
        } else {
            px -= 1;
            d += 2 * py - 2 * px + 1;
        }
    }
    if (px < py) return;  // CPU loop condition `while px >= py`

    int cx = p.cx;
    int cy = p.cy;
    plot(fb, cx + px, cy + py, p.fb_w, p.fb_h, p.color);
    plot(fb, cx - px, cy + py, p.fb_w, p.fb_h, p.color);
    plot(fb, cx + px, cy - py, p.fb_w, p.fb_h, p.color);
    plot(fb, cx - px, cy - py, p.fb_w, p.fb_h, p.color);
    plot(fb, cx + py, cy + px, p.fb_w, p.fb_h, p.color);
    plot(fb, cx - py, cy + px, p.fb_w, p.fb_h, p.color);
    plot(fb, cx + py, cy - px, p.fb_w, p.fb_h, p.color);
    plot(fb, cx - py, cy - px, p.fb_w, p.fb_h, p.color);
}

// ---- kernel_draw_circle_filled ----

kernel void kernel_draw_circle_filled(
    device uint* fb           [[buffer(0)]],
    constant CircleParams& p  [[buffer(1)]],
    uint2 tid                 [[thread_position_in_grid]]
) {
    int bw = 2 * p.r + 1;
    int bh = 2 * p.r + 1;
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= bw || ly >= bh) return;

    int dx = lx - p.r;
    int dy = ly - p.r;
    int dist_sq = dx * dx + dy * dy;
    int r_sq = p.r * p.r;
    if (dist_sq > r_sq) return;

    int px = p.cx - p.r + lx;
    int py = p.cy - p.r + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = p.color;
}

// ---- kernel_draw_rounded_rect ----

// Rounded-rect OUTLINE (matches CPU draw_rounded_rect: straight edges + four
// midpoint corner arcs). 1D dispatch; thread k covers edge pixel k on each side
// (when in range) and corner-arc iteration k (replayed midpoint) on all four
// corners. Bit-exact with the CPU reference.
kernel void kernel_draw_rounded_rect(
    device uint* fb                  [[buffer(0)]],
    constant RoundedRectParams& p    [[buffer(1)]],
    uint tid                         [[thread_position_in_grid]]
) {
    int k = (int)tid;
    int x = p.x;
    int y = p.y;
    int w = p.w;
    int h = p.h;
    int r = p.radius;
    if (r > w / 2) r = w / 2;
    if (r > h / 2) r = h / 2;

    // Top/bottom straight edges: cols [x+r, x+w-1-r]  (CPU sw_hline length w-2r)
    if (k < w - 2 * r) {
        int col = x + r + k;
        plot(fb, col, y, p.fb_w, p.fb_h, p.color);
        plot(fb, col, y + h - 1, p.fb_w, p.fb_h, p.color);
    }
    // Left/right straight edges: rows [y+r, y+h-1-r]  (CPU sw_vline length h-2r)
    if (k < h - 2 * r) {
        int row = y + r + k;
        plot(fb, x, row, p.fb_w, p.fb_h, p.color);
        plot(fb, x + w - 1, row, p.fb_w, p.fb_h, p.color);
    }

    // Corner arcs: replay CPU sw_corner_arc midpoint loop to iteration k.
    int px = r;
    int py = 0;
    int d = 1 - r;
    for (int q = 0; q < k; q++) {
        py += 1;
        if (d <= 0) {
            d += 2 * py + 1;
        } else {
            px -= 1;
            d += 2 * py - 2 * px + 1;
        }
    }
    if (px >= py) {
        int tlx = x + r;
        int tly = y + r;
        int trx = x + w - 1 - r;
        int bry = y + h - 1 - r;
        // top-left (sx=-1, sy=-1)
        plot(fb, tlx - px, tly - py, p.fb_w, p.fb_h, p.color);
        plot(fb, tlx - py, tly - px, p.fb_w, p.fb_h, p.color);
        // top-right (sx=+1, sy=-1)
        plot(fb, trx + px, tly - py, p.fb_w, p.fb_h, p.color);
        plot(fb, trx + py, tly - px, p.fb_w, p.fb_h, p.color);
        // bottom-left (sx=-1, sy=+1)
        plot(fb, tlx - px, bry + py, p.fb_w, p.fb_h, p.color);
        plot(fb, tlx - py, bry + px, p.fb_w, p.fb_h, p.color);
        // bottom-right (sx=+1, sy=+1)
        plot(fb, trx + px, bry + py, p.fb_w, p.fb_h, p.color);
        plot(fb, trx + py, bry + px, p.fb_w, p.fb_h, p.color);
    }
}

// ---- kernel_draw_triangle_filled ----

kernel void kernel_draw_triangle_filled(
    device uint* fb               [[buffer(0)]],
    constant TriangleParams& p    [[buffer(1)]],
    uint2 tid                     [[thread_position_in_grid]]
) {
    int bw = 0;  // computed from bounding box
    int bh = 0;
    int max_x = p.x1;
    if (p.x2 > max_x) max_x = p.x2;
    if (p.x3 > max_x) max_x = p.x3;
    int max_y = p.y1;
    if (p.y2 > max_y) max_y = p.y2;
    if (p.y3 > max_y) max_y = p.y3;
    bw = max_x - p.min_x + 1;
    bh = max_y - p.min_y + 1;

    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= bw || ly >= bh) return;

    int px = p.min_x + lx;
    int py = p.min_y + ly;

    // Barycentric coordinate test (2x area method)
    int d = (p.y2 - p.y3) * (p.x1 - p.x3) + (p.x3 - p.x2) * (p.y1 - p.y3);
    if (d == 0) return;

    int w1_num = (p.y2 - p.y3) * (px - p.x3) + (p.x3 - p.x2) * (py - p.y3);
    int w2_num = (p.y3 - p.y1) * (px - p.x3) + (p.x1 - p.x3) * (py - p.y3);

    // Check signs for inside test
    bool inside;
    if (d > 0) {
        int w3_num = d - w1_num - w2_num;
        inside = (w1_num >= 0 && w2_num >= 0 && w3_num >= 0);
    } else {
        int w3_num = d - w1_num - w2_num;
        inside = (w1_num <= 0 && w2_num <= 0 && w3_num <= 0);
    }
    if (!inside) return;

    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = p.color;
}

// ---- kernel_draw_gradient_rect ----

kernel void kernel_draw_gradient_rect(
    device uint* fb               [[buffer(0)]],
    constant GradientParams& p    [[buffer(1)]],
    uint2 tid                     [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    // Interpolate between top_color and bottom_color
    uint4 tc = unpack_argb(p.top_color);
    uint4 bc = unpack_argb(p.bottom_color);
    int max_t = p.h - 1;
    if (max_t < 1) max_t = 1;

    uint r = lerp_channel(tc.x, bc.x, ly, max_t);
    uint g = lerp_channel(tc.y, bc.y, ly, max_t);
    uint b = lerp_channel(tc.z, bc.z, ly, max_t);
    uint a = lerp_channel(tc.w, bc.w, ly, max_t);
    uint c = pack_argb(r, g, b, a);

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = c;
}

// ---- kernel_draw_gradient_rect_h ----

kernel void kernel_draw_gradient_rect_h(
    device uint* fb               [[buffer(0)]],
    constant GradientParams& p    [[buffer(1)]],
    uint2 tid                     [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    uint4 lc = unpack_argb(p.top_color);
    uint4 rc = unpack_argb(p.bottom_color);
    int max_t = p.w - 1;
    if (max_t < 1) max_t = 1;

    uint r = lerp_channel(lc.x, rc.x, lx, max_t);
    uint g = lerp_channel(lc.y, rc.y, lx, max_t);
    uint b = lerp_channel(lc.z, rc.z, lx, max_t);
    uint a = lerp_channel(lc.w, rc.w, lx, max_t);
    uint c = pack_argb(r, g, b, a);

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = c;
}

// ---- kernel_draw_radial_gradient ----

kernel void kernel_draw_radial_gradient(
    device uint* fb                     [[buffer(0)]],
    constant RadialGradientParams& p    [[buffer(1)]],
    uint2 tid                           [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    int span = p.r * 2 + 1;
    if (lx >= span || ly >= span) return;

    int px_rel = lx - p.r;
    int py_rel = ly - p.r;
    int dist_sq = px_rel * px_rel + py_rel * py_rel;
    int r_sq = p.r * p.r;
    if (dist_sq > r_sq) return;

    uint4 cc = unpack_argb(p.center_color);
    uint4 ec = unpack_argb(p.edge_color);
    int dist = isqrt_i32(dist_sq);
    int max_t = p.r;
    if (max_t < 1) max_t = 1;

    uint r = lerp_channel(cc.x, ec.x, dist, max_t);
    uint g = lerp_channel(cc.y, ec.y, dist, max_t);
    uint b = lerp_channel(cc.z, ec.z, dist, max_t);
    uint a = lerp_channel(cc.w, ec.w, dist, max_t);
    uint c = pack_argb(r, g, b, a);

    int px = p.cx + px_rel;
    int py = p.cy + py_rel;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = c;
}

// ---- kernel_draw_ellipse_filled ----

kernel void kernel_draw_ellipse_filled(
    device uint* fb              [[buffer(0)]],
    constant EllipseParams& p    [[buffer(1)]],
    uint tid                     [[thread_position_in_grid]]
) {
    if (p.rx <= 0 || p.ry <= 0) {
        if (tid == 0 && p.cx >= 0 && p.cx < p.fb_w && p.cy >= 0 && p.cy < p.fb_h) {
            fb[p.cy * p.fb_w + p.cx] = p.color;
        }
        return;
    }

    int target = (int)tid;
    int x = 0;
    int y = p.ry;
    int rx2 = p.rx * p.rx;
    int ry2 = p.ry * p.ry;
    int px = 0;
    int py = 2 * rx2 * y;
    int d1 = ry2 - rx2 * p.ry + rx2 / 4;
    int step = 0;

    while (px < py) {
        if (step == target) {
            for (int dx = -x; dx <= x; dx++) {
                int px1 = p.cx + dx;
                int py1 = p.cy + y;
                int py2 = p.cy - y;
                if (px1 >= 0 && px1 < p.fb_w) {
                    if (py1 >= 0 && py1 < p.fb_h) fb[py1 * p.fb_w + px1] = p.color;
                    if (py2 >= 0 && py2 < p.fb_h) fb[py2 * p.fb_w + px1] = p.color;
                }
            }
            return;
        }
        x += 1;
        px += 2 * ry2;
        if (d1 < 0) {
            d1 = d1 + ry2 + px;
        } else {
            y -= 1;
            py -= 2 * rx2;
            d1 = d1 + ry2 + px - py;
        }
        step += 1;
    }

    int d2 = ry2 * (2 * x + 1) * (2 * x + 1) / 4 + rx2 * (y - 1) * (y - 1) - rx2 * ry2;
    while (y >= 0) {
        if (step == target) {
            for (int dx = -x; dx <= x; dx++) {
                int px1 = p.cx + dx;
                int py1 = p.cy + y;
                int py2 = p.cy - y;
                if (px1 >= 0 && px1 < p.fb_w) {
                    if (py1 >= 0 && py1 < p.fb_h) fb[py1 * p.fb_w + px1] = p.color;
                    if (py2 >= 0 && py2 < p.fb_h) fb[py2 * p.fb_w + px1] = p.color;
                }
            }
            return;
        }
        y -= 1;
        py -= 2 * rx2;
        if (d2 > 0) {
            d2 = d2 + rx2 - py;
        } else {
            x += 1;
            px += 2 * ry2;
            d2 = d2 + ry2 - py + px + rx2;
        }
        step += 1;
    }
}

// ---- kernel_draw_rect_blend ----

kernel void kernel_draw_rect_blend(
    device uint* fb            [[buffer(0)]],
    constant RectParams& p     [[buffer(1)]],
    uint2 tid                  [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    fb[idx] = blend_over_color(p.color, fb[idx]);
}

// ---- kernel_draw_rect_blend_mode ----

kernel void kernel_draw_rect_blend_mode(
    device uint* fb                     [[buffer(0)]],
    constant BlendModeRectParams& p     [[buffer(1)]],
    uint2 tid                           [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int idx = py * p.fb_w + px;
    uint dst = fb[idx];
    uint sa = (p.color >> 24) & 0xFFu;
    uint sr = (p.color >> 16) & 0xFFu;
    uint sg = (p.color >> 8) & 0xFFu;
    uint sb = p.color & 0xFFu;
    uint dr = (dst >> 16) & 0xFFu;
    uint dg = (dst >> 8) & 0xFFu;
    uint db = dst & 0xFFu;
    uint da = (dst >> 24) & 0xFFu;

    uint rr = sr;
    uint rg = sg;
    uint rb = sb;
    if (p.mode == 1) {
        rr = (sr * dr) / 255u;
        rg = (sg * dg) / 255u;
        rb = (sb * db) / 255u;
    } else if (p.mode == 2) {
        rr = 255u - ((255u - sr) * (255u - dr)) / 255u;
        rg = 255u - ((255u - sg) * (255u - dg)) / 255u;
        rb = 255u - ((255u - sb) * (255u - db)) / 255u;
    } else if (p.mode == 3) {
        rr = overlay_channel(sr, dr);
        rg = overlay_channel(sg, dg);
        rb = overlay_channel(sb, db);
    }

    uint out_r = dr + ((int(rr) - int(dr)) * int(sa)) / 255;
    uint out_g = dg + ((int(rg) - int(dg)) * int(sa)) / 255;
    uint out_b = db + ((int(rb) - int(db)) * int(sa)) / 255;
    uint out_a = sa > da ? sa : da;
    fb[idx] = pack_argb(out_r, out_g, out_b, out_a);
}

// ---- kernel_blend_image ----

kernel void kernel_blend_image(
    device uint* fb             [[buffer(0)]],
    constant BlitParams& p      [[buffer(1)]],
    device const uint* src      [[buffer(2)]],
    uint2 tid                   [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int src_idx = ly * p.w + lx;
    int dst_idx = py * p.fb_w + px;
    fb[dst_idx] = blend_over_color(src[src_idx], fb[dst_idx]);
}

// ---- kernel_blit_image ----

kernel void kernel_blit_image(
    device uint* fb             [[buffer(0)]],
    constant BlitParams& p      [[buffer(1)]],
    device const uint* src      [[buffer(2)]],
    uint2 tid                   [[thread_position_in_grid]]
) {
    int lx = (int)tid.x;
    int ly = (int)tid.y;
    if (lx >= p.w || ly >= p.h) return;

    int px = p.x + lx;
    int py = p.y + ly;
    if (px < 0 || px >= p.fb_w || py < 0 || py >= p.fb_h) return;

    int src_idx = ly * p.w + lx;
    int dst_idx = py * p.fb_w + px;
    fb[dst_idx] = src[src_idx];
}
"""
