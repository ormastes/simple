    me _dispatch_metal_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> bool:
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        var ok = true
        var i: i64 = 0
        var cursor_x = x
        while i < text_val.len():
            val code = text_val.char_code_at(i)
            val ch = "{code as char}"
            val bitmap = glyph_data(ch)
            var gy = 0
            while gy < gh:
                val row_data = bitmap[gy]
                var gx = 0
                while gx < 5:
                    val bit = (row_data >> (4 - gx)) & 1
                    if bit != 0:
                        ok = ok and self._dispatch_metal_rect_filled(cursor_x + gx * scale, y + gy * scale, scale, scale, color)
                    gx = gx + 1
                gy = gy + 1
            cursor_x = cursor_x + advance
            i = i + 1
        ok

    me _dispatch_metal_1d(pipeline: i64, threads: i64, block_x: i64, params: i64, params_len: i64) -> bool:
        # TODO: [runtime][P2] Interpreter loses the `self` binding when a struct
        # field is passed inline as a call argument after a prior extern call in
        # the same method ("variable `self` not found"). Hoisting self.* into
        # locals first is the workaround applied here and in _dispatch_metal_2d.
        val q = self.command_queue
        val fb = self.d_framebuffer
        val cmd = metal_sffi_create_command_buffer(q)
        if cmd == 0:
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            return false
        metal_sffi_set_buffer(encoder, fb, 0, 0)
        rt_metal_set_bytes(encoder, params, params_len, 1)
        metal_sffi_dispatch_compute(encoder, pipeline, threads, 1, 1, block_x, 1, 1)
        metal_sffi_end_compute_encoder(encoder)
        metal_sffi_commit_command_buffer(cmd)
        metal_sffi_wait_completed(cmd)

    me _dispatch_metal_2d(pipeline: i64, w: i32, h: i32, params: i64, params_len: i64) -> bool:
        val q = self.command_queue
        val fb = self.d_framebuffer
        val cmd = metal_sffi_create_command_buffer(q)
        if cmd == 0:
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            return false
        metal_sffi_set_buffer(encoder, fb, 0, 0)
        rt_metal_set_bytes(encoder, params, params_len, 1)
        val block_x = 16
        val block_y = 16
        val grid_x = ((_metal_i64(w) + block_x - 1) / block_x) * block_x
        val grid_y = ((_metal_i64(h) + block_y - 1) / block_y) * block_y
        metal_sffi_dispatch_compute(encoder, pipeline, grid_x, grid_y, 1, block_x, block_y, 1)
        metal_sffi_end_compute_encoder(encoder)
        metal_sffi_commit_command_buffer(cmd)
        metal_sffi_wait_completed(cmd)

    me _dispatch_metal_blit(x: i32, y: i32, w: i32, h: i32, d_src: i64) -> bool:
        if w <= 0 or h <= 0 or d_src == 0:
            return true
        val params = rt_alloc(24)
        if params == 0:
            return false
        rt_ptr_write_i32(params, 0, x as i64)
        rt_ptr_write_i32(params, 4, y as i64)
        rt_ptr_write_i32(params, 8, w as i64)
        rt_ptr_write_i32(params, 12, h as i64)
        rt_ptr_write_i32(params, 16, self.w as i64)
        rt_ptr_write_i32(params, 20, self.h as i64)
        val cmd = metal_sffi_create_command_buffer(self.command_queue)
        if cmd == 0:
            rt_free(params)
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            rt_free(params)
            return false
        if not metal_sffi_set_buffer(encoder, self.d_framebuffer, 0, 0):
            rt_free(params)
            return false
        if rt_metal_set_bytes(encoder, params, 24, 1) == 0:
            rt_free(params)
            return false
        if not metal_sffi_set_buffer(encoder, d_src, 0, 2):
            rt_free(params)
            return false
        val block_x = 16
        val block_y = 16
        val grid_x = ((_metal_i64(w) + block_x - 1) / block_x) * block_x
        val grid_y = ((_metal_i64(h) + block_y - 1) / block_y) * block_y
        if not metal_sffi_dispatch_compute(encoder, self.session.pipe_blit, grid_x, grid_y, 1, block_x, block_y, 1):
            rt_free(params)
            return false
        metal_sffi_end_compute_encoder(encoder)
        metal_sffi_commit_command_buffer(cmd)
        val ok = metal_sffi_wait_completed(cmd)
        rt_free(params)
        ok

    me _dispatch_metal_image_blend(x: i32, y: i32, w: i32, h: i32, d_src: i64) -> bool:
        if w <= 0 or h <= 0 or d_src == 0:
            return true
        val params = rt_alloc(24)
        if params == 0:
            return false
        rt_ptr_write_i32(params, 0, x as i64)
        rt_ptr_write_i32(params, 4, y as i64)
        rt_ptr_write_i32(params, 8, w as i64)
        rt_ptr_write_i32(params, 12, h as i64)
        rt_ptr_write_i32(params, 16, self.w as i64)
        rt_ptr_write_i32(params, 20, self.h as i64)

        val cmd = metal_sffi_create_command_buffer(self.command_queue)
        if cmd == 0:
            rt_free(params)
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            rt_free(params)
            return false
        metal_sffi_set_buffer(encoder, self.d_framebuffer, 0, 0)
        metal_sffi_set_bytes(encoder, params, 24, 1)
        metal_sffi_set_buffer(encoder, d_src, 0, 2)
        val block_x = 16
        val block_y = 16
        val grid_x = ((_metal_i64(w) + block_x - 1) / block_x) * block_x
        val grid_y = ((_metal_i64(h) + block_y - 1) / block_y) * block_y
        if not metal_sffi_dispatch_compute(encoder, self.session.pipe_image_blend, grid_x, grid_y, 1, block_x, block_y, 1):
            rt_free(params)
            return false
        metal_sffi_end_compute_encoder(encoder)
        metal_sffi_commit_command_buffer(cmd)
        val ok = metal_sffi_wait_completed(cmd)
        rt_free(params)
        ok

impl Engine2DExtended for MetalBackend:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_text_bg(x, y, text_val, fg, bg, font_size)
        if text_val.len() == 0:
            return
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_text_bg(x, y, text_val, fg, bg, font_size)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            self.dirty = true
            return
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = (text_val.len() as i32) * advance
        val text_h = gh * scale
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            var ok = self._dispatch_metal_rect_filled(x, y, text_w, text_h, bg)
            ok = ok and self._dispatch_metal_text(x, y, text_val, fg, font_size)
            self._record_gpu_dispatch(ok)
            if self.strict_gpu_only and not ok:
                var temp = self._prepare_software_replay()
                temp.draw_text_bg(x, y, text_val, fg, bg, font_size)
                if self._finish_software_replay(temp):
                    self.gpu_frame_complete = true
            self.dirty = true
        else:
            self.gpu_frame_complete = false

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        if not self.strict_gpu_only:
            self.mirror.draw_ellipse(cx, cy, rx, ry, color)
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_ellipse(cx, cy, rx, ry, color)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            if rx <= 0 or ry <= 0:
                self._record_gpu_dispatch(self._dispatch_metal_rect_filled(cx, cy, 1, 1, color))
                self.dirty = true
                return
            var ok = true
            var x: i32 = 0
            var y: i32 = ry
            val rx2 = rx * rx
            val ry2 = ry * ry
            var px = 0
            var py = 2 * rx2 * y
            var d1 = ry2 - rx2 * ry + rx2 / 4
            while px < py:
                ok = ok and self._dispatch_metal_rect_filled(cx + x, cy + y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx - x, cy + y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx + x, cy - y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx - x, cy - y, 1, 1, color)
                x = x + 1
                px = px + 2 * ry2
                if d1 < 0:
                    d1 = d1 + ry2 + px
                else:
                    y = y - 1
                    py = py - 2 * rx2
                    d1 = d1 + ry2 + px - py
            var d2 = ry2 * (2 * x + 1) * (2 * x + 1) / 4 + rx2 * (y - 1) * (y - 1) - rx2 * ry2
            while y >= 0:
                ok = ok and self._dispatch_metal_rect_filled(cx + x, cy + y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx - x, cy + y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx + x, cy - y, 1, 1, color)
                ok = ok and self._dispatch_metal_rect_filled(cx - x, cy - y, 1, 1, color)
                y = y - 1
                py = py - 2 * rx2
                if d2 > 0:
                    d2 = d2 + rx2 - py
                else:
                    x = x + 1
                    px = px + 2 * ry2
                    d2 = d2 + ry2 - py + px + rx2
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            var temp = self._prepare_software_replay()
            temp.draw_ellipse(cx, cy, rx, ry, color)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        if not self.strict_gpu_only:
            self.mirror.draw_ellipse_filled(cx, cy, rx, ry, color)
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_ellipse_filled(cx, cy, rx, ry, color)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_ellipse_filled != 0:
            self._record_gpu_dispatch(self._dispatch_metal_ellipse_filled(cx, cy, rx, ry, color))
            self.dirty = true
        else:
            var temp = self._prepare_software_replay()
            temp.draw_ellipse_filled(cx, cy, rx, ry, color)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false

