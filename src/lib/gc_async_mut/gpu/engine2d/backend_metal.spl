        rt_ptr_write_i32(params, 20, self.w as i64)
        rt_ptr_write_i32(params, 24, self.h as i64)
        val threads = (2 * (rx + ry) + 2) as i64
        val pipeline = self.session.pipe_ellipse_filled
        val ok = self._dispatch_metal_1d(pipeline, threads, 256, params, 28)
        rt_free(params)
