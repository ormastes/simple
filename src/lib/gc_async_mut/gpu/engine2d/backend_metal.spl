    me _dispatch_metal_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32) -> bool:
        if r <= 0:
            return self._dispatch_metal_rect_filled(cx, cy, 1, 1, center_color)
        val params = rt_alloc(28)
        if params == 0:
            return false
        rt_ptr_write_i32(params, 0, cx as i64)
        rt_ptr_write_i32(params, 4, cy as i64)
        rt_ptr_write_i32(params, 8, r as i64)
        rt_ptr_write_i32(params, 12, center_color as i64)
        rt_ptr_write_i32(params, 16, edge_color as i64)
        rt_ptr_write_i32(params, 20, self.w as i64)
        rt_ptr_write_i32(params, 24, self.h as i64)
        val span = r * 2 + 1
        val pipeline = self.session.pipe_radial_gradient
        val ok = self._dispatch_metal_2d(pipeline, span, span, params, 28)
        rt_free(params)
        ok

    me _dispatch_metal_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32) -> bool:
        if rx <= 0 or ry <= 0:
            return self._dispatch_metal_rect_filled(cx, cy, 1, 1, color)
