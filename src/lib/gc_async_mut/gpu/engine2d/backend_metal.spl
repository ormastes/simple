    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if not self.strict_gpu_only:
            self.mirror.draw_image_blend(x, y, w, h, pixels)
        if w <= 0 or h <= 0 or pixels.len() < w * h:
            return
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_image_blend(x, y, w, h, pixels)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            self.dirty = true
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_image_blend != 0:
            val pixel_count = w * h
            val byte_size = _metal_i64(pixel_count) * 4
            val d_src = self.session.alloc(byte_size)
            if d_src == 0:
                self.gpu_frame_complete = false
                return
            val src_bytes = _metal_pixels_to_le_bytes(pixels, pixel_count)
            if src_bytes.len() != pixel_count * 4:
                self.session.free(d_src)
                self.gpu_frame_complete = false
                return
            if not self.session.upload_buffer_bytes(d_src, src_bytes):
                self.session.free(d_src)
                self.gpu_frame_complete = false
                return
            val ok = self._dispatch_metal_image_blend(x, y, w, h, d_src)
            self.session.free(d_src)
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            self.gpu_frame_complete = false

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        if not self.strict_gpu_only:
            self.mirror.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        val scaled = _metal_scale_image_pixels(dst_w, dst_h, src_w, src_h, pixels)
        if scaled.len() != dst_w * dst_h:
            self.gpu_frame_complete = false
            return
        self.draw_image(dst_x, dst_y, dst_w, dst_h, scaled)

