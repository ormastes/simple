    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_polyline(xs, ys, count, color, thickness)
        if count < 2:
            return
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_polyline(xs, ys, count, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            self.dirty = true
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_line != 0:
            var ok = true
            var i = 0
            while i < count - 1:
                ok = ok and self._dispatch_metal_line(xs[i], ys[i], xs[i + 1], ys[i + 1], color, thickness)
                i = i + 1
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            self.gpu_frame_complete = false

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_rect_thick(x, y, w, h, color, thickness)
        if w <= 0 or h <= 0 or thickness <= 0:
            return
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_rect_thick(x, y, w, h, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            self.dirty = true
            return
        var t = thickness
        val max_t_w = w / 2
        val max_t_h = h / 2
        if t > max_t_w:
            t = max_t_w
        if t > max_t_h:
            t = max_t_h
        if t <= 0:
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            var ok = true
            ok = ok and self._dispatch_metal_rect_filled(x, y, w, t, color)
            if h > t:
                ok = ok and self._dispatch_metal_rect_filled(x, y + h - t, w, t, color)
            val inner_h = h - 2 * t
            if inner_h > 0:
                ok = ok and self._dispatch_metal_rect_filled(x, y + t, t, inner_h, color)
                if w > t:
                    ok = ok and self._dispatch_metal_rect_filled(x + w - t, y + t, t, inner_h, color)
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            self.gpu_frame_complete = false

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_circle_thick(cx, cy, r, color, thickness)
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_circle_thick(cx, cy, r, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            if r <= 0:
                self._record_gpu_dispatch(self._dispatch_metal_rect_filled(cx, cy, 1, 1, color))
                self.dirty = true
                return
            val r_outer = r
            val r_inner = if r - thickness > 0: r - thickness else: 0
            val r_outer_sq = r_outer * r_outer
            val r_inner_sq = r_inner * r_inner
            var ok = true
            var py: i32 = -r_outer
            while py <= r_outer:
                var px: i32 = -r_outer
                while px <= r_outer:
                    val dist_sq = px * px + py * py
                    if dist_sq <= r_outer_sq and dist_sq >= r_inner_sq:
                        ok = ok and self._dispatch_metal_rect_filled(cx + px, cy + py, 1, 1, color)
                    px = px + 1
                py = py + 1
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            var temp = self._prepare_software_replay()
            temp.draw_circle_thick(cx, cy, r, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            if w <= 0 or h <= 0:
                return
            var r = radius
            if r > w / 2:
                r = w / 2
            if r > h / 2:
                r = h / 2
            val t = thickness
            var ok = true
            ok = ok and self._dispatch_metal_rect_filled(x + r, y, w - 2 * r, t, color)
            ok = ok and self._dispatch_metal_rect_filled(x + r, y + h - t, w - 2 * r, t, color)
            ok = ok and self._dispatch_metal_rect_filled(x, y + r, t, h - 2 * r, color)
            ok = ok and self._dispatch_metal_rect_filled(x + w - t, y + r, t, h - 2 * r, color)
            ok = ok and _metal_draw_thick_corner_arc(self, x + r, y + r, r, t, color, -1, -1)
            ok = ok and _metal_draw_thick_corner_arc(self, x + w - r - 1, y + r, r, t, color, 1, -1)
            ok = ok and _metal_draw_thick_corner_arc(self, x + r, y + h - r - 1, r, t, color, -1, 1)
            ok = ok and _metal_draw_thick_corner_arc(self, x + w - r - 1, y + h - r - 1, r, t, color, 1, 1)
            self._record_gpu_dispatch(ok)
            self.dirty = true
        else:
            var temp = self._prepare_software_replay()
            temp.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false

