    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        if not self.strict_gpu_only:
            self.mirror.draw_rect_blend(x, y, w, h, color)
        if self._strict_replay_required():
            var temp = self._prepare_software_replay()
            temp.draw_rect_blend_mode(x, y, w, h, color, mode)
            if not self._finish_software_replay(temp):
                self.gpu_frame_complete = false
            self.dirty = true
            return
        if mode == 0:
            self.draw_rect_blend(x, y, w, h, color)
            return
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_blend_mode != 0 and mode >= 1 and mode <= 3:
